<!-- REVIEWS -->
<% if (reviews && reviews.reviews && reviews.reviews.length) { %>
<section style="padding:100px 52px;background:var(--ivory);">
  <div style="max-width:1100px;margin:0 auto;">

    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:64px;flex-wrap:wrap;gap:24px;">
      <div>
        <p style="font-size:0.72rem;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:var(--navy);margin-bottom:12px;">Google Reviews</p>
        <h2 style="font-family:'Cormorant Garamond',serif;font-size:clamp(2.4rem,4vw,3.6rem);font-weight:300;color:var(--dark);line-height:1.1;">What our <em style="font-style:italic;color:var(--navy);">clients say</em></h2>
      </div>
      <div style="text-align:right;">
        <div style="font-family:'Cormorant Garamond',serif;font-size:3.6rem;font-weight:300;color:var(--navy);line-height:1;"><%= reviews.rating.toFixed(1) %></div>
        <div style="display:flex;gap:3px;justify-content:flex-end;margin:6px 0;">
          <% for (let i=1;i<=5;i++) { %>
            <span style="color:<%= i<=Math.round(reviews.rating)?'var(--gold)':'var(--ivory-mid)' %>;font-size:1.1rem;">★</span>
          <% } %>
        </div>
        <div style="font-size:0.72rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:var(--slate);"><%= reviews.user_ratings_total %> Google Reviews</div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:2px;background:var(--ivory-mid);">
      <% for (const r of reviews.reviews) { %>
      <div style="background:var(--white);padding:40px 36px;position:relative;">
        <div style="display:flex;gap:3px;margin-bottom:18px;">
          <% for (let i=1;i<=5;i++) { %>
            <span style="color:<%= i<=r.rating?'var(--gold)':'var(--ivory-mid)' %>;font-size:1rem;">★</span>
          <% } %>
        </div>
        <p style="font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-weight:300;font-style:italic;color:var(--dark);line-height:1.7;margin-bottom:24px;">"<%= r.text.length > 220 ? r.text.slice(0,220).trim() + '…' : r.text %>"</p>
        <div style="display:flex;align-items:center;gap:12px;">
          <% if (r.profile_photo_url) { %>
            <img src="<%= r.profile_photo_url %>" style="width:36px;height:36px;border-radius:50%;object-fit:cover;" alt="">
          <% } else { %>
            <div style="width:36px;height:36px;border-radius:50%;background:var(--navy);display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--gold-light);flex-shrink:0;"><%= r.author_name.charAt(0) %></div>
          <% } %>
          <div>
            <div style="font-size:0.82rem;font-weight:600;color:var(--dark);"><%= r.author_name %></div>
            <div style="font-size:0.7rem;color:var(--slate);letter-spacing:0.06em;"><%= r.relative_time_description %></div>
          </div>
        </div>
        <div style="position:absolute;top:0;left:36px;right:36px;height:2px;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform 0.4s ease;" class="review-bar"></div>
      </div>
      <% } %>
    </div>

  </div>
</section>
<% } %>

<!-- CONTACT -->
<section class="contact" id="contact">
  <div class="contact-left">
    <p class="section-eyebrow">Get In Touch</p>
    <h2 class="section-heading">Let's Work<br><em>Together</em></h2>
    <p class="contact-sub"><%= copy.contact_sub %></p>
    <div class="contact-detail">
      <div class="contact-detail-item">
        <span class="detail-label">Location</span>
        <span class="detail-value"><%= copy.contact_location %></span>
      </div>
      <div class="contact-detail-item">
        <span class="detail-label">Serving</span>
        <span class="detail-value"><%= copy.contact_serving %></span>
      </div>
      <div class="contact-detail-item">
        <span class="detail-label">Services</span>
        <span class="detail-value">Social Media · Web Design · Content · Branding</span>
      </div>
    </div>
  </div>
  <div class="contact-right">
    <form class="contact-form" id="contact-form">
      <div class="form-row">
        <div class="form-field">
          <label>First Name</label>
          <input type="text" name="firstName" placeholder="Jane" required>
        </div>
        <div class="form-field">
          <label>Last Name</label>
          <input type="text" name="lastName" placeholder="Smith" required>
        </div>
      </div>
      <div class="form-field">
        <label>Email</label>
        <input type="email" name="email" placeholder="jane@yourbusiness.com" required>
      </div>
      <div class="form-field">
        <label>Business Name</label>
        <input type="text" name="company" placeholder="Your Business LLC">
      </div>
      <div class="form-field">
        <label>Service Interested In</label>
        <select name="service">
          <option value="">Select a service...</option>
          <option>Social Media Management</option>
          <option>Website Design &amp; Development</option>
          <option>Content Creation &amp; Branding</option>
          <option>Full Package</option>
        </select>
      </div>
      <div class="form-field">
        <label>Tell Us About Your Needs</label>
        <textarea name="message" placeholder="A quick idea of your needs — what are you trying to achieve?"></textarea>
      </div>
      <button type="submit" class="btn-submit">Send Message</button>
      <div id="form-msg"></div>
    </form>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-top">
    <div>
      <div class="footer-brand-name">W2 Marketing</div>
      <div class="footer-brand-sub">Social Media &bull; Web Design &bull; Content &bull; Greeley, CO</div>
    </div>
    <ul class="footer-links">
      <li><a href="#services">Services</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#process">Process</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </div>
  <div class="footer-divider"></div>
  <div class="footer-copy">
    <span>&copy; 2025 W2 Marketing &mdash; Greeley, Colorado. All rights reserved.</span>
    <span><a href="/admin/login" style="color:rgba(253,252,250,0.15);text-decoration:none;font-size:0.7rem;letter-spacing:0.04em;transition:color 0.2s;" onmouseover="this.style.color='rgba(253,252,250,0.35)'" onmouseout="this.style.color='rgba(253,252,250,0.15)'">Admin</a></span>
  </div>
</footer>

<script>
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  });

  document.getElementById('contact-form').addEventListener('submit', (e) => {
    e.preventDefault();
    const msg = document.getElementById('form-msg');
    msg.style.display = 'block';
    msg.style.color = 'var(--navy)';
    msg.style.fontSize = '0.85rem';
    msg.style.marginTop = '8px';
    msg.textContent = '✓ Message received! We\'ll be in touch within 1 business day.';
    e.target.reset();
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.service-card, .process-item, .stat-box').forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(20px)';
    el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    observer.observe(el);
  });
</script>
</body>
</html>
