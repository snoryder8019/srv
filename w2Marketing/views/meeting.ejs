<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — W2 Marketing</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/meeting.css">
</head>
<body data-token="<%= token %>">
  <div id="error-toast" class="toast"></div>
  <div id="success-toast" class="toast"></div>

  <!-- SHARE PANEL -->
  <div id="share-panel">
    <div class="share-card">
      <h2>Invite Others <button class="share-close" id="share-close">&times;</button></h2>

      <div class="share-section">
        <div class="share-section-label">Scan to Join</div>
        <div id="qr-container">
          <div id="qr-loading">Loading QR code...</div>
        </div>
      </div>

      <div class="share-section">
        <div class="share-section-label">Meeting Link</div>
        <div class="share-link-row">
          <input type="text" class="share-link-input" id="share-link" readonly value="<%= domain %>/meeting/<%= token %>">
          <button class="share-btn" id="share-copy">Copy</button>
        </div>
      </div>

      <div class="share-section">
        <div class="share-section-label">Email Invite</div>
        <div class="invite-form">
          <div class="invite-row">
            <input type="text" id="invite-name" placeholder="Name (optional)">
            <input type="email" id="invite-email" placeholder="Email address" required>
          </div>
          <button class="share-btn gold" id="invite-send">Send Invite</button>
          <div class="invite-status" id="invite-status"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- PRE-JOIN -->
  <div id="prejoin">
    <div class="prejoin-card">
      <h1><%= title %></h1>
      <div class="subtitle">W2 Marketing</div>

      <div id="preview-container">
        <video id="preview-video" autoplay playsinline muted style="display:none;"></video>
        <div id="preview-placeholder">&#9673;</div>
      </div>

      <div class="prejoin-toggles">
        <button class="toggle-btn" id="pre-mic" title="Toggle microphone">&#9834;</button>
        <button class="toggle-btn" id="pre-cam" title="Toggle camera">&#9673;</button>
      </div>

      <input type="text" class="prejoin-input" id="name-input" placeholder="Enter your name" maxlength="40" autofocus>
      <button class="btn-join" id="join-btn">Join Meeting</button>
    </div>
  </div>

  <!-- NOTES / ASSETS SIDEBAR -->
  <div id="sidebar-panel">
    <button class="sidebar-close" id="sidebar-close">&times;</button>
    <div class="sidebar-tabs">
      <button class="sidebar-tab active" data-tab="notes">Notes</button>
      <button class="sidebar-tab" data-tab="assets">Assets</button>
    </div>

    <!-- Notes Tab -->
    <div class="sidebar-body active" data-tab="notes" id="notes-body">
      <div id="notes-list">
        <div class="notes-empty" id="notes-empty">No notes yet. Add one below.</div>
      </div>
      <textarea id="note-input" placeholder="Type a note..." maxlength="5000"></textarea>
      <div class="note-actions">
        <button class="share-btn gold" id="note-send" style="padding:8px 16px;font-size:0.72rem;">Add Note</button>
      </div>
    </div>

    <!-- Assets Tab -->
    <div class="sidebar-body" data-tab="assets" id="assets-body">
      <div id="assets-list">
        <div class="assets-empty" id="assets-empty">No files shared yet.</div>
      </div>
      <div id="upload-zone">
        <div class="upload-icon">&#8682;</div>
        <p>Click or drag a file to upload</p>
        <input type="file" id="upload-input" style="display:none;">
      </div>
      <div id="upload-progress">Uploading...</div>
    </div>
  </div>

  <!-- IN-CALL -->
  <div id="incall">
    <div class="call-header">
      <div>
        <div class="call-title"><%= title %></div>
        <div class="call-status" id="call-status">connecting...</div>
      </div>
      <div class="call-duration" id="call-duration">00:00</div>
    </div>

    <div id="peers-grid"></div>

    <div id="local-pip" style="display:none;">
      <video id="local-video" autoplay playsinline muted></video>
    </div>

    <!-- LIVE TRANSCRIPT PANEL -->
    <div id="transcript-panel">
      <div class="transcript-header">
        <span class="transcript-title">Live Transcript</span>
        <span>
          <button class="notetaker-flush-btn" id="notetaker-flush" title="Summarize now">TLDR Now</button>
          <span class="transcript-status" id="transcript-status">ready</span>
        </span>
      </div>
      <div id="transcript-lines"></div>
    </div>

    <div class="controls">
      <button class="ctrl-btn" id="ctrl-mic" title="Mute / Unmute">&#9834;</button>
      <button class="ctrl-btn" id="ctrl-cam" title="Camera On / Off">&#9673;</button>
      <button class="ctrl-btn" id="ctrl-screen" title="Share Screen">&#9635;</button>
      <button class="ctrl-btn" id="ctrl-notetaker" title="AI Notetaker">&#9041;</button>
      <button class="ctrl-btn" id="ctrl-notes" title="Notes &amp; Assets">&#9998;</button>
      <button class="ctrl-btn" id="ctrl-share" title="Invite Others">&#9993;</button>
      <button class="ctrl-btn leave" id="ctrl-leave" title="Leave Meeting">&#9587;</button>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/meeting-rtc.js"></script>
  <script src="/js/meeting-ui.js"></script>
</body>
</html>
