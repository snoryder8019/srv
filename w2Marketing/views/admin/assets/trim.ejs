<%- include('../partials/head', { title: 'Video Trimmer' }) %>
<%- include('../partials/sidebar', { page: 'assets', user: user }) %>

<style>
  .trim-wrap { max-width: 860px; margin: 0 auto; }

  /* Drop zone */
  .drop-zone {
    border: 2px dashed var(--ivory-mid); border-radius: 2px;
    padding: 60px 40px; text-align: center; cursor: pointer;
    background: var(--white); transition: all 0.15s;
    margin-bottom: 24px;
  }
  .drop-zone:hover, .drop-zone.drag-over { border-color: var(--gold); background: rgba(201,168,72,0.04); }
  .drop-zone-icon { font-size: 2.5rem; margin-bottom: 12px; }
  .drop-zone-label { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 300; color: var(--dark); margin-bottom: 8px; }
  .drop-zone-sub { font-size: 0.78rem; color: var(--slate); }
  #videoInput { display: none; }

  /* Editor */
  #videoEditor { display: none; }

  .video-preview-wrap {
    background: #000; border-radius: 2px; overflow: hidden;
    text-align: center; margin-bottom: 20px;
  }
  #previewVideo { max-height: 420px; width: 100%; display: block; }

  /* Info row */
  .video-info {
    display: flex; gap: 16px; flex-wrap: wrap;
    margin-bottom: 20px;
  }
  .vi-item { font-size: 0.75rem; }
  .vi-label { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--slate); display: block; margin-bottom: 2px; }
  .vi-val { color: var(--dark); font-weight: 500; }

  /* Timeline */
  .timeline-wrap { position: relative; user-select: none; margin-bottom: 20px; }
  .timeline-bg {
    height: 48px; background: var(--ivory-mid); border-radius: 2px;
    position: relative; overflow: hidden; cursor: crosshair;
  }
  .timeline-fill {
    position: absolute; top: 0; bottom: 0;
    background: rgba(201,168,72,0.35); border-left: 3px solid var(--gold); border-right: 3px solid var(--gold);
    pointer-events: none;
  }
  .timeline-handle {
    position: absolute; top: 0; bottom: 0; width: 16px;
    background: var(--gold); cursor: ew-resize; z-index: 2;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.6rem; color: var(--dark); font-weight: 700;
    border-radius: 1px;
  }
  .tl-handle-start { left: 0; transform: translateX(-50%); }
  .tl-handle-end { right: 0; transform: translateX(50%); }
  .timeline-playhead {
    position: absolute; top: 0; bottom: 0; width: 2px;
    background: var(--navy); pointer-events: none; z-index: 3;
  }

  /* Time inputs */
  .time-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
  .time-field label { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--slate); display: block; margin-bottom: 5px; }
  .time-field input {
    width: 100%; padding: 8px 12px; border: 1.5px solid var(--ivory-mid);
    border-radius: 2px; font-size: 0.85rem; font-family: 'Jost', sans-serif;
    color: var(--dark); background: var(--ivory);
  }
  .time-field input:focus { outline: none; border-color: var(--navy-mid); background: var(--white); }

  /* Presets */
  .preset-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; align-items: center; }
  .preset-label { font-size: 0.7rem; color: var(--slate); font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; }
  .preset-btn {
    padding: 5px 12px; border-radius: 2px; font-size: 0.7rem; font-weight: 600;
    letter-spacing: 0.07em; cursor: pointer; border: 1.5px solid var(--ivory-mid);
    background: var(--white); color: var(--slate); transition: all 0.12s;
  }
  .preset-btn:hover { border-color: var(--navy-mid); color: var(--navy); }

  /* Upload settings */
  .upload-settings { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; margin-bottom: 20px; }
  .us-field label { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--slate); display: block; margin-bottom: 5px; }
  .us-select, .us-input {
    width: 100%; padding: 8px 10px; border: 1.5px solid var(--ivory-mid);
    border-radius: 2px; font-size: 0.82rem; font-family: 'Jost', sans-serif;
    color: var(--dark); background: var(--ivory);
  }
  .us-select:focus, .us-input:focus { outline: none; border-color: var(--navy-mid); background: var(--white); }

  /* Progress */
  .trim-progress { margin-bottom: 16px; display: none; }
  .trim-pb-outer { background: var(--ivory-mid); border-radius: 2px; height: 6px; }
  .trim-pb-inner { background: var(--gold); height: 6px; border-radius: 2px; width: 0%; transition: width 0.3s; }
  .trim-pb-label { font-size: 0.72rem; color: var(--slate); margin-top: 5px; }

  .trim-result { display: none; }
  .trim-result-url {
    font-size: 0.72rem; color: var(--navy); word-break: break-all;
    background: var(--ivory); padding: 8px 10px; border-radius: 2px;
    border: 1px solid var(--ivory-mid); margin-top: 10px;
  }
</style>

<div class="topbar">
  <div class="topbar-title">Video Trimmer</div>
  <div class="topbar-actions">
    <a href="/admin/assets" class="btn btn-ghost btn-sm">← Asset Center</a>
  </div>
</div>

<div class="content">
  <div class="trim-wrap">

    <!-- Drop zone -->
    <div class="card">
      <div class="drop-zone" id="dropZone">
        <input type="file" id="videoInput" accept="video/*">
        <div class="drop-zone-icon">▷</div>
        <div class="drop-zone-label">Drop a video or click to select</div>
        <div class="drop-zone-sub">MP4, WebM, MOV — up to 500MB · Trimming happens in your browser (no upload until Save)</div>
      </div>
    </div>

    <!-- Editor (shown after file selected) -->
    <div id="videoEditor" style="display:none;">

      <div class="card mt-24">
        <div class="card-title">Preview</div>
        <div class="video-preview-wrap">
          <video id="previewVideo" controls></video>
        </div>
        <div class="video-info">
          <div class="vi-item"><span class="vi-label">File</span><span class="vi-val" id="viName">—</span></div>
          <div class="vi-item"><span class="vi-label">Size</span><span class="vi-val" id="viSize">—</span></div>
          <div class="vi-item"><span class="vi-label">Duration</span><span class="vi-val" id="viDuration">—</span></div>
          <div class="vi-item"><span class="vi-label">Trim Range</span><span class="vi-val" id="viRange">—</span></div>
        </div>
      </div>

      <div class="card mt-24">
        <div class="card-title">Trim</div>

        <!-- Timeline -->
        <div class="timeline-wrap" id="timelineWrap">
          <div class="timeline-bg" id="timelineBg">
            <div class="timeline-fill" id="timelineFill"></div>
            <div class="timeline-handle tl-handle-start" id="handleStart">◀</div>
            <div class="timeline-handle tl-handle-end" id="handleEnd">▶</div>
            <div class="timeline-playhead" id="playhead"></div>
          </div>
        </div>

        <!-- Time inputs -->
        <div class="time-row">
          <div class="time-field">
            <label>Start Time (seconds)</label>
            <input type="number" id="startInput" min="0" step="0.1" value="0">
          </div>
          <div class="time-field">
            <label>End Time (seconds)</label>
            <input type="number" id="endInput" min="0" step="0.1" value="0">
          </div>
        </div>

        <!-- Presets -->
        <div class="preset-row">
          <span class="preset-label">Presets:</span>
          <button class="preset-btn" data-preset="first30">First 30s</button>
          <button class="preset-btn" data-preset="first60">First 60s</button>
          <button class="preset-btn" data-preset="last30">Last 30s</button>
          <button class="preset-btn" data-preset="middle">Middle 60s</button>
          <button class="preset-btn" data-preset="full">Full Video</button>
        </div>
      </div>

      <div class="card mt-24">
        <div class="card-title">Save Trimmed Clip</div>

        <div class="upload-settings">
          <div class="us-field">
            <label>Save to Folder</label>
            <select class="us-select" id="trimFolder">
              <option value="general">General</option>
              <option value="sections">Sections</option>
              <option value="portfolio">Portfolio</option>
              <option value="blog">Blog</option>
              <option value="pages">Pages</option>
              <option value="clients">Clients</option>
            </select>
          </div>
          <div class="us-field" style="grid-column:span 2;">
            <label>Filename (optional)</label>
            <input type="text" class="us-input" id="trimFilename" placeholder="Leave blank to auto-generate">
          </div>
        </div>

        <div class="trim-progress" id="trimProgress">
          <div class="trim-pb-outer"><div class="trim-pb-inner" id="trimPbInner"></div></div>
          <div class="trim-pb-label" id="trimPbLabel">Processing...</div>
        </div>

        <div class="trim-result" id="trimResult">
          <div style="color:var(--success,#15803D);font-weight:600;font-size:0.82rem;">✓ Uploaded successfully</div>
          <div class="trim-result-url" id="trimResultUrl"></div>
          <div style="margin-top:10px;display:flex;gap:8px;">
            <button class="btn btn-ghost btn-sm" id="copyTrimUrlBtn">⧉ Copy URL</button>
            <a href="/admin/assets" class="btn btn-navy btn-sm">View in Assets</a>
          </div>
        </div>

        <div class="form-actions" style="margin-top:16px;">
          <button class="btn btn-gold" id="trimBtn">✂ Trim & Upload</button>
          <button class="btn btn-ghost" id="resetTrimBtn">Reset</button>
        </div>
      </div>

    </div><!-- /videoEditor -->

  </div><!-- /trim-wrap -->
</div><!-- /content -->

<script src="/js/videoTrimmer.js"></script>
</div></div></body></html>
