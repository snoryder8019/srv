<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar', { user, page }) %>

<style>
/* ── Agent panel ── */
.agent-btn { display:inline-flex;align-items:center;gap:7px;padding:8px 16px;border-radius:2px;background:linear-gradient(135deg,#1C2B4A,#2E4270);color:#E8D08A;border:1px solid rgba(201,168,72,0.3);font-family:'Jost',sans-serif;font-size:0.72rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;transition:all 0.2s; }
.agent-btn:hover { border-color:rgba(201,168,72,0.65); }
#agentPanel { position:fixed;top:0;right:-440px;width:420px;height:100vh;background:#FDFCFA;border-left:1px solid #E6E1D6;box-shadow:-8px 0 40px rgba(15,27,48,0.12);z-index:500;display:flex;flex-direction:column;transition:right 0.3s cubic-bezier(0.4,0,0.2,1); }
#agentPanel.open { right:0; }
.ap-header { padding:18px 20px;border-bottom:1px solid #E6E1D6;background:linear-gradient(135deg,#0F1B30,#1C2B4A);display:flex;align-items:center;justify-content:space-between;flex-shrink:0; }
.ap-title { font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:300;color:#FDFCFA;letter-spacing:0.04em; }
.ap-close { background:none;border:none;color:rgba(255,255,255,0.45);font-size:1.1rem;cursor:pointer;padding:4px 8px; }
.ap-close:hover { color:#fff; }
.ap-messages { flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:10px; }
.ap-msg { display:flex; }
.ap-msg-user { justify-content:flex-end; }
.ap-msg-agent { justify-content:flex-start; }
.ap-bubble { max-width:82%;padding:10px 14px;border-radius:6px;font-size:0.85rem;line-height:1.55;word-break:break-word; }
.ap-msg-agent .ap-bubble { background:#F5F3EF;color:#0F1B30; }
.ap-msg-user  .ap-bubble { background:#1C2B4A;color:#fff; }
.ap-quick { padding:0 16px 12px;display:flex;flex-wrap:wrap;gap:7px; }
.ap-footer { padding:12px 16px;border-top:1px solid #E6E1D6;display:flex;gap:8px;flex-shrink:0; }
.ap-input { flex:1;padding:9px 12px;border:1px solid #E6E1D6;border-radius:4px;font-family:'Jost',sans-serif;font-size:0.88rem; }
.ap-input:focus { outline:none;border-color:#1C2B4A; }
.ap-send { padding:9px 16px;background:#1C2B4A;color:#fff;border:none;border-radius:4px;font-size:0.78rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer; }
.ap-send:disabled { opacity:0.5; }
.ai-filled { background:rgba(21,128,61,0.05)!important;border-color:rgba(21,128,61,0.4)!important; }
.revert-row { display:none;padding:4px 0 2px;font-size:0.75rem; }
.revert-btn { background:none;border:none;cursor:pointer;font-size:0.75rem;padding:2px 6px;border-radius:2px; }

/* ── Page type selector ── */
.page-type-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:24px; }
.page-type-card { border:2px solid var(--ivory-mid);border-radius:4px;padding:16px;cursor:pointer;transition:all 0.15s;text-align:center; }
.page-type-card:hover { border-color:var(--navy-mid); }
.page-type-card.selected { border-color:var(--navy);background:rgba(28,43,74,0.04); }
.page-type-card .pt-icon { font-size:1.5rem;margin-bottom:8px; }
.page-type-card .pt-label { font-weight:600;font-size:0.82rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--navy); }
.page-type-card .pt-desc { font-size:0.72rem;color:var(--slate);margin-top:4px;line-height:1.4; }

/* ── Block builder ── */
.block-toolbar { display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px; }
.block-card { border:1px solid var(--ivory-mid);border-radius:4px;margin-bottom:10px;overflow:hidden; }
.block-card-header { display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--ivory);cursor:pointer;user-select:none; }
.block-drag-handle { color:var(--slate);font-size:0.9rem;cursor:grab; }
.block-type-badge { font-size:0.62rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;background:var(--navy);color:#fff;padding:2px 7px;border-radius:2px; }
.block-title-text { flex:1;font-size:0.85rem;font-weight:500;color:var(--dark); }
.block-actions { display:flex;gap:4px;margin-left:auto; }
.block-body { padding:14px;display:flex;flex-direction:column;gap:12px; }
.block-body.collapsed { display:none; }
.block-field { display:flex;flex-direction:column;gap:5px; }
.block-field label { font-size:0.62rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--slate); }
.block-field input, .block-field textarea { width:100%;padding:8px 10px;border:1px solid var(--ivory-mid);border-radius:2px;font-family:'Jost',sans-serif;font-size:0.88rem;color:var(--dark); }
.block-field textarea { min-height:80px;resize:vertical; }

/* ── Tabs ── */
.form-tabs { display:flex;gap:0;border-bottom:1px solid var(--ivory-mid);margin-bottom:24px; }
.form-tab { padding:10px 20px;font-size:0.72rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--slate);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px; }
.form-tab.active { color:var(--navy);border-bottom-color:var(--navy); }
.form-tab-panel { display:none; }
.form-tab-panel.active { display:block; }

@media (max-width: 820px) {
  #agentPanel { width:100%;right:-100%; }
  .page-type-grid { grid-template-columns:1fr; }
}
</style>

<div class="topbar">
  <div class="topbar-title"><%= pg && pg._id ? 'Edit Page' : 'New Page' %></div>
  <div class="topbar-actions">
    <button class="agent-btn" onclick="document.getElementById('agentPanel').classList.add('open')">✦ Page Agent</button>
    <a href="/admin/pages" class="btn btn-ghost btn-sm">← Pages</a>
  </div>
</div>

<!-- Agent Panel -->
<div id="agentPanel">
  <div class="ap-header">
    <span class="ap-title">✦ Page Agent</span>
    <button class="ap-close" onclick="document.getElementById('agentPanel').classList.remove('open')">✕</button>
  </div>
  <div class="ap-messages" id="ap-messages">
    <div class="ap-msg ap-msg-agent">
      <div class="ap-bubble">Tell me what this page is for — I'll write the content, suggest a block layout, or help with SEO.</div>
    </div>
  </div>
  <div class="ap-quick" id="ap-quick">
    <button class="btn btn-ghost btn-sm ap-quick-btn" data-prompt="Write an About Us page for W2 Marketing, a digital marketing agency in Greeley CO">About Us</button>
    <button class="btn btn-ghost btn-sm ap-quick-btn" data-prompt="Write a Services page listing social media management, web design, and content creation">Services page</button>
    <button class="btn btn-ghost btn-sm ap-quick-btn" data-prompt="Write a Privacy Policy page for a digital marketing website">Privacy Policy</button>
    <button class="btn btn-ghost btn-sm ap-quick-btn" data-prompt="Build a landing page for our digital marketing services with hero, feature cards, and a CTA">Landing page layout</button>
    <button class="btn btn-ghost btn-sm ap-quick-btn" data-prompt="Write a Contact page with our Greeley CO location and service area information">Contact page</button>
  </div>
  <div class="ap-footer">
    <input class="ap-input" id="ap-input" placeholder="Describe the page…" autocomplete="off">
    <button class="ap-send" id="ap-send" onclick="apSend()">Send</button>
  </div>
</div>

<div class="content">
  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="<%= pg && pg._id ? '/admin/pages/' + pg._id : '/admin/pages' %>" id="page-form">
    <input type="hidden" name="blocksJson" id="blocks-json" value="<%= pg && pg.blocks ? JSON.stringify(pg.blocks).replace(/"/g, '&quot;') : '[]' %>">
    <input type="hidden" name="pageType" id="pageType-field" value="<%= pg && pg.pageType ? pg.pageType : 'content' %>">

    <!-- Page title + slug (always visible) -->
    <div class="card">
      <div class="form-tabs">
        <div class="form-tab active" data-tab="content">Content</div>
        <div class="form-tab" data-tab="settings">Settings &amp; SEO</div>
      </div>

      <!-- CONTENT TAB -->
      <div class="form-tab-panel active" id="tab-content">

        <!-- Title + Slug -->
        <div style="display:flex;flex-direction:column;gap:16px;margin-bottom:24px;">
          <div class="form-field">
            <label>Page Title <span style="color:var(--danger);">*</span></label>
            <input type="text" name="title" id="field-title" value="<%= pg ? pg.title || '' : '' %>" required placeholder="e.g. About Us, Services, Privacy Policy…" oninput="autoSlug(this.value)">
            <div class="revert-row" id="revert-title"></div>
          </div>
          <div class="form-field">
            <label>URL Slug</label>
            <div style="display:flex;align-items:center;">
              <span style="padding:11px 12px;background:var(--ivory);border:1px solid var(--ivory-mid);border-right:none;border-radius:2px 0 0 2px;font-size:0.85rem;color:var(--slate);white-space:nowrap;">yoursite.com/</span>
              <input type="text" name="slug" id="slug-field" value="<%= pg ? pg.slug || '' : '' %>" placeholder="url-slug" style="border-radius:0 2px 2px 0;flex:1;">
            </div>
          </div>
        </div>

        <!-- Page Type Picker -->
        <div style="margin-bottom:20px;">
          <div style="font-size:0.65rem;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--slate);margin-bottom:12px;">Page Type</div>
          <div class="page-type-grid">
            <div class="page-type-card" id="pt-content" onclick="setPageType('content')">
              <div class="pt-icon">✎</div>
              <div class="pt-label">Content</div>
              <div class="pt-desc">Free-form HTML editor for articles, policies, and info pages</div>
            </div>
            <div class="page-type-card" id="pt-data-list" onclick="setPageType('data-list')">
              <div class="pt-icon">⊞</div>
              <div class="pt-label">Data List</div>
              <div class="pt-desc">Auto-paginated list from your blog posts or portfolio</div>
            </div>
            <div class="page-type-card" id="pt-landing" onclick="setPageType('landing')">
              <div class="pt-icon">◈</div>
              <div class="pt-label">Landing Page</div>
              <div class="pt-desc">Build with reusable blocks — hero, text, cards, FAQ, CTA</div>
            </div>
          </div>
        </div>

        <!-- CONTENT EDITOR (content type) -->
        <div id="section-content">
          <div class="form-field">
            <label>Content <span style="font-size:0.62rem;color:var(--slate);text-transform:none;letter-spacing:0;">(HTML supported)</span></label>
            <textarea name="content" id="field-content" rows="20" style="font-family:monospace;font-size:0.85rem;line-height:1.6;" placeholder="Write page content here. HTML tags supported."><%= pg ? pg.content || '' : '' %></textarea>
            <div class="revert-row" id="revert-content"></div>
            <div style="display:flex;gap:7px;flex-wrap:wrap;margin-top:6px;">
              <% const tags = [
                ['<p>','</p>','Paragraph'],
                ['<h2>','</h2>','Heading 2'],
                ['<h3>','</h3>','Heading 3'],
                ['<strong>','</strong>','Bold'],
                ['<em>','</em>','Italic'],
                ['<ul>\n  <li></li>\n</ul>','','List'],
                ['<a href="">','</a>','Link'],
                ['<img src="" alt="">','','Image'],
                ['<blockquote>','</blockquote>','Quote']
              ]; %>
              <% tags.forEach(function(t) { %>
                <button type="button" class="btn btn-ghost btn-sm tag-btn"
                  data-open="<%= encodeURIComponent(t[0]) %>"
                  data-close="<%= encodeURIComponent(t[1]) %>"
                  style="font-size:0.7rem;"><%-t[2]%></button>
              <% }); %>
            </div>
          </div>
        </div>

        <!-- DATA LIST CONFIG (data-list type) -->
        <div id="section-data-list" style="display:none;">
          <div class="form-grid">
            <div class="form-field">
              <label>Data Source</label>
              <select name="dataCollection" id="field-dataCollection">
                <option value="w2_blog" <%= !pg || pg.dataCollection === 'w2_blog' ? 'selected' : '' %>>Blog Posts</option>
                <option value="w2_portfolio" <%= pg && pg.dataCollection === 'w2_portfolio' ? 'selected' : '' %>>Portfolio Items</option>
              </select>
              <span style="font-size:0.65rem;color:var(--slate);margin-top:4px;">Shows published items only, sorted newest first.</span>
            </div>
            <div class="form-field">
              <label>Items Per Page</label>
              <input type="number" name="dataPageSize" id="field-dataPageSize" min="1" max="100" value="<%= pg && pg.dataPageSize ? pg.dataPageSize : 9 %>">
            </div>
          </div>
          <div style="margin-top:16px;padding:14px;background:var(--ivory);border-radius:4px;font-size:0.82rem;color:var(--slate);">
            <strong style="color:var(--dark);">How it works:</strong> This page automatically fetches and paginates your selected data source. Visitors navigate between pages using <code>?p=2</code>, <code>?p=3</code>, etc. No content to write — the cards are auto-generated.
          </div>
        </div>

        <!-- BLOCK BUILDER (landing type) -->
        <div id="section-landing" style="display:none;">
          <div style="margin-bottom:14px;">
            <div style="font-size:0.65rem;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--slate);margin-bottom:10px;">Add Block</div>
            <div class="block-toolbar" id="block-toolbar">
              <button type="button" class="btn btn-ghost btn-sm" onclick="addBlock('hero')">+ Hero</button>
              <button type="button" class="btn btn-ghost btn-sm" onclick="addBlock('text')">+ Text</button>
              <button type="button" class="btn btn-ghost btn-sm" onclick="addBlock('split')">+ Split</button>
              <button type="button" class="btn btn-ghost btn-sm" onclick="addBlock('cta')">+ CTA Banner</button>
              <button type="button" class="btn btn-ghost btn-sm" onclick="addBlock('cards')">+ Cards</button>
              <button type="button" class="btn btn-ghost btn-sm" onclick="addBlock('faq')">+ FAQ</button>
            </div>
          </div>
          <div id="block-list"></div>
          <div id="block-empty" style="padding:32px;text-align:center;color:var(--slate);font-size:0.88rem;border:2px dashed var(--ivory-mid);border-radius:4px;">
            No blocks yet — add one above, or use the Page Agent to generate a full layout.
          </div>
        </div>

      </div><!-- /tab-content -->

      <!-- SETTINGS + SEO TAB -->
      <div class="form-tab-panel" id="tab-settings">
        <div style="display:flex;flex-direction:column;gap:20px;">

          <div class="form-grid cols-3">
            <div class="form-field">
              <label>Status</label>
              <select name="status">
                <option value="draft" <%= !pg || pg.status === 'draft' ? 'selected' : '' %>>Draft</option>
                <option value="published" <%= pg && pg.status === 'published' ? 'selected' : '' %>>Published</option>
              </select>
            </div>
            <div class="form-field span-2">
              <label>&nbsp;</label>
              <div class="form-check" style="margin-top:10px;">
                <input type="checkbox" name="showInNav" id="showInNav" <%= pg && pg.showInNav ? 'checked' : '' %>>
                <label for="showInNav" style="text-transform:none;letter-spacing:0.02em;font-size:0.88rem;color:var(--dark);">Show in site navigation</label>
              </div>
            </div>
          </div>

          <!-- SEO -->
          <div>
            <div style="font-size:0.65rem;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--slate);margin-bottom:12px;">SEO / Meta</div>
            <div class="form-grid" style="margin-bottom:12px;">
              <div class="form-field">
                <label>Meta Title</label>
                <input type="text" name="metaTitle" id="field-metaTitle" value="<%= pg ? pg.metaTitle || pg.title || '' : '' %>" placeholder="Defaults to page title">
                <div class="revert-row" id="revert-metaTitle"></div>
              </div>
              <div class="form-field">
                <label>Meta Description <span style="font-weight:300;text-transform:none;letter-spacing:0;">(max 160 chars)</span></label>
                <input type="text" name="metaDescription" id="field-metaDescription" value="<%= pg ? pg.metaDescription || '' : '' %>" placeholder="Brief description for search engines…" maxlength="160">
                <div class="revert-row" id="revert-metaDescription"></div>
              </div>
            </div>
            <div class="form-grid">
              <div class="form-field">
                <label>OG / Share Image URL</label>
                <input type="url" name="ogImage" value="<%= pg ? pg.ogImage || '' : '' %>" placeholder="https://…">
              </div>
              <div class="form-field">
                <label>Canonical URL <span style="font-weight:300;text-transform:none;letter-spacing:0;">(override)</span></label>
                <input type="url" name="canonicalUrl" value="<%= pg ? pg.canonicalUrl || '' : '' %>" placeholder="Leave blank for default">
              </div>
            </div>
          </div>

          <!-- Indexing -->
          <div>
            <div style="font-size:0.65rem;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--slate);margin-bottom:12px;">Search Engine Indexing</div>
            <div class="form-grid cols-3">
              <div class="form-field">
                <label>Robots Meta</label>
                <select name="robotsMeta">
                  <% const rm = pg ? pg.robotsMeta || 'index,follow' : 'index,follow'; %>
                  <option value="index,follow" <%= rm === 'index,follow' ? 'selected' : '' %>>index, follow (default)</option>
                  <option value="noindex,follow" <%= rm === 'noindex,follow' ? 'selected' : '' %>>noindex, follow</option>
                  <option value="index,nofollow" <%= rm === 'index,nofollow' ? 'selected' : '' %>>index, nofollow</option>
                  <option value="noindex,nofollow" <%= rm === 'noindex,nofollow' ? 'selected' : '' %>>noindex, nofollow</option>
                </select>
              </div>
              <div class="form-field">
                <label>Sitemap Priority</label>
                <input type="number" name="sitemapPriority" min="0" max="1" step="0.1" value="<%= pg && pg.sitemapPriority != null ? pg.sitemapPriority : 0.5 %>">
                <span style="font-size:0.65rem;color:var(--slate);">0.0 (low) → 1.0 (high). Default: 0.5</span>
              </div>
              <div class="form-field">
                <label>Change Frequency</label>
                <select name="sitemapChangefreq">
                  <% const cf = pg ? pg.sitemapChangefreq || 'monthly' : 'monthly'; %>
                  <% ['always','hourly','daily','weekly','monthly','yearly','never'].forEach(function(v) { %>
                    <option value="<%= v %>" <%= cf === v ? 'selected' : '' %>><%= v.charAt(0).toUpperCase() + v.slice(1) %></option>
                  <% }); %>
                </select>
              </div>
            </div>
          </div>

        </div>
      </div><!-- /tab-settings -->

    </div><!-- card -->

    <div style="margin-top:24px;display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
      <button type="submit" class="btn btn-navy"><%= pg && pg._id ? 'Save Changes' : 'Create Page' %></button>
      <a href="/admin/pages" class="btn btn-ghost">Cancel</a>
      <% if (pg && pg._id) { %>
        <% if (pg.status === 'published') { %>
          <a href="/<%= pg.slug %>" target="_blank" class="btn btn-ghost" style="margin-left:auto;">View Live →</a>
        <% } %>
        <form method="POST" action="/admin/pages/<%= pg._id %>/delete" style="margin-left:<%= pg.status === 'published' ? '0' : 'auto' %>;" onsubmit="return confirm('Delete this page?')">
          <button type="submit" class="btn btn-danger btn-sm">Delete</button>
        </form>
      <% } %>
    </div>

  </form>
</div>

<script>
// ── Slug auto-gen ─────────────────────────────────────────────────────────────
let slugEdited = <%= pg && pg.slug ? 'true' : 'false' %>;
function toSlug(s) { return s.toLowerCase().trim().replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,''); }
function autoSlug(v) { if (!slugEdited) document.getElementById('slug-field').value = toSlug(v); }
document.getElementById('slug-field').addEventListener('input', () => { slugEdited = true; });

// ── Tabs ──────────────────────────────────────────────────────────────────────
document.querySelectorAll('.form-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.form-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.form-tab-panel').forEach(p => p.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
  });
});

// ── Page type selector ────────────────────────────────────────────────────────
function setPageType(type) {
  document.getElementById('pageType-field').value = type;
  ['content','data-list','landing'].forEach(t => {
    document.getElementById('pt-' + t).classList.toggle('selected', t === type);
    const sec = document.getElementById('section-' + t);
    if (sec) sec.style.display = t === type ? '' : 'none';
  });
}
// Init from saved value
setPageType('<%= pg && pg.pageType ? pg.pageType : "content" %>');

// ── Tag buttons for HTML editor ───────────────────────────────────────────────
document.querySelectorAll('.tag-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const ta = document.getElementById('field-content');
    const open  = decodeURIComponent(btn.dataset.open);
    const close = decodeURIComponent(btn.dataset.close);
    const s = ta.selectionStart, e = ta.selectionEnd;
    const selected = ta.value.substring(s, e);
    ta.value = ta.value.substring(0, s) + open + selected + close + ta.value.substring(e);
    ta.selectionStart = s + open.length;
    ta.selectionEnd   = s + open.length + selected.length;
    ta.focus();
  });
});

// ── Block builder ─────────────────────────────────────────────────────────────
const BLOCK_FIELDS = {
  hero:  [['heading','Heading','text'],['subheading','Subheading','text'],['cta_text','Button Text','text'],['cta_link','Button Link','text']],
  text:  [['heading','Heading','text'],['subheading','Subheading','text'],['body','Body','textarea']],
  split: [['heading','Heading','text'],['body','Body Text','textarea'],['cta_text','Button Text','text'],['cta_link','Button Link','text']],
  cta:   [['heading','Headline','text'],['subtext','Subtext','textarea'],['btn_text','Button Text','text'],['btn_link','Button Link','text']],
  cards: [['heading','Section Heading','text'],['subtext','Section Subtext','textarea'],
          ['card1_title','Card 1 Title','text'],['card1_body','Card 1 Body','textarea'],
          ['card2_title','Card 2 Title','text'],['card2_body','Card 2 Body','textarea'],
          ['card3_title','Card 3 Title','text'],['card3_body','Card 3 Body','textarea'],
          ['card4_title','Card 4 Title','text'],['card4_body','Card 4 Body','textarea']],
  faq:   [['heading','Section Heading','text'],
          ['q1','Question 1','text'],['a1','Answer 1','textarea'],
          ['q2','Question 2','text'],['a2','Answer 2','textarea'],
          ['q3','Question 3','text'],['a3','Answer 3','textarea'],
          ['q4','Question 4','text'],['a4','Answer 4','textarea'],
          ['q5','Question 5','text'],['a5','Answer 5','textarea']],
};

let pageBlocks = [];
try { pageBlocks = JSON.parse(document.getElementById('blocks-json').value) || []; } catch {}
pageBlocks = pageBlocks.map(b => ({ id: b.id || Math.random().toString(36).slice(2), ...b }));

let dragSrc = null;

function renderBlocks() {
  const list = document.getElementById('block-list');
  const empty = document.getElementById('block-empty');
  empty.style.display = pageBlocks.length ? 'none' : '';
  list.innerHTML = '';
  pageBlocks.forEach((block, i) => {
    const card = document.createElement('div');
    card.className = 'block-card';
    card.draggable = true;
    card.dataset.id = block.id;
    card.addEventListener('dragstart', e => { dragSrc = i; e.dataTransfer.effectAllowed = 'move'; });
    card.addEventListener('dragover', e => { e.preventDefault(); e.dataTransfer.dropEffect = 'move'; card.style.outline = '2px solid var(--gold)'; });
    card.addEventListener('dragleave', () => { card.style.outline = ''; });
    card.addEventListener('drop', e => {
      e.preventDefault(); card.style.outline = '';
      if (dragSrc === null || dragSrc === i) return;
      const moved = pageBlocks.splice(dragSrc, 1)[0];
      pageBlocks.splice(i, 0, moved);
      dragSrc = null; renderBlocks();
    });

    const fields = BLOCK_FIELDS[block.type] || [];
    const previewText = (block.fields?.heading || block.fields?.q1 || block.type);
    card.innerHTML = `
      <div class="block-card-header" onclick="toggleBlock('${block.id}')">
        <span class="block-drag-handle" title="Drag to reorder">⠿</span>
        <span class="block-type-badge">${block.type}</span>
        <span class="block-title-text">${previewText.slice(0,48) || '(empty)'}</span>
        <div class="block-actions">
          ${i > 0 ? `<button type="button" class="btn btn-ghost btn-sm" style="padding:4px 8px;" onclick="event.stopPropagation();moveBlock(${i},-1)">↑</button>` : ''}
          ${i < pageBlocks.length-1 ? `<button type="button" class="btn btn-ghost btn-sm" style="padding:4px 8px;" onclick="event.stopPropagation();moveBlock(${i},1)">↓</button>` : ''}
          <button type="button" class="btn btn-danger btn-sm" style="padding:4px 8px;" onclick="event.stopPropagation();removeBlock('${block.id}')">✕</button>
        </div>
      </div>
      <div class="block-body collapsed" id="block-body-${block.id}">
        ${fields.map(([key, label, type]) => `
          <div class="block-field">
            <label>${label}</label>
            ${type === 'textarea'
              ? `<textarea data-bid="${block.id}" data-key="${key}" oninput="updateBlockField('${block.id}','${key}',this.value)">${(block.fields?.[key] || '').replace(/</g,'&lt;')}</textarea>`
              : `<input type="text" data-bid="${block.id}" data-key="${key}" value="${(block.fields?.[key] || '').replace(/"/g,'&quot;')}" oninput="updateBlockField('${block.id}','${key}',this.value)">`
            }
          </div>`).join('')}
      </div>`;
    list.appendChild(card);
  });
  serializeBlocks();
}

function toggleBlock(id) {
  const body = document.getElementById('block-body-' + id);
  if (body) body.classList.toggle('collapsed');
}

function addBlock(type) {
  pageBlocks.push({ id: Math.random().toString(36).slice(2), type, fields: {} });
  renderBlocks();
  // Expand the new block
  const lastBlock = pageBlocks[pageBlocks.length - 1];
  const body = document.getElementById('block-body-' + lastBlock.id);
  if (body) body.classList.remove('collapsed');
}

function removeBlock(id) {
  pageBlocks = pageBlocks.filter(b => b.id !== id);
  renderBlocks();
}

function moveBlock(i, dir) {
  const j = i + dir;
  if (j < 0 || j >= pageBlocks.length) return;
  [pageBlocks[i], pageBlocks[j]] = [pageBlocks[j], pageBlocks[i]];
  renderBlocks();
}

function updateBlockField(id, key, value) {
  const block = pageBlocks.find(b => b.id === id);
  if (block) { if (!block.fields) block.fields = {}; block.fields[key] = value; }
  serializeBlocks();
}

function serializeBlocks() {
  document.getElementById('blocks-json').value = JSON.stringify(pageBlocks);
}

document.getElementById('page-form').addEventListener('submit', serializeBlocks);

// Init block render
renderBlocks();

// ── AI fill ───────────────────────────────────────────────────────────────────
const fieldStates = {};

function fillField(key, aiValue) {
  const el = document.getElementById('field-' + key);
  if (!el) return;
  if (!fieldStates[key]) fieldStates[key] = { original: el.value, ai: aiValue };
  else fieldStates[key].ai = aiValue;
  el.value = aiValue;
  el.classList.add('ai-filled');
  renderRevertRow(key, 'ai');
}

function renderRevertRow(key, state) {
  const row = document.getElementById('revert-' + key);
  if (!row || !fieldStates[key]) return;
  row.style.display = 'block';
  if (state === 'ai') {
    row.innerHTML = `<button type="button" class="revert-btn" style="color:var(--slate);border:1px solid var(--ivory-mid);" onclick="revertField('${key}','original')">↩ Revert to original</button>`;
  } else {
    row.innerHTML = `<button type="button" class="revert-btn" style="color:var(--gold);border:1px solid rgba(201,168,72,0.3);" onclick="revertField('${key}','ai')">✦ Restore AI suggestion</button>`;
  }
}

function revertField(key, to) {
  const el = document.getElementById('field-' + key);
  if (!el || !fieldStates[key]) return;
  el.value = fieldStates[key][to];
  if (to === 'original') { el.classList.remove('ai-filled'); renderRevertRow(key, 'original'); }
  else { el.classList.add('ai-filled'); renderRevertRow(key, 'ai'); }
}

// ── Agent panel ───────────────────────────────────────────────────────────────
const apMessages = document.getElementById('ap-messages');
let apHistory = [];

function apAddMsg(role, text, isHtml) {
  const row = document.createElement('div');
  row.className = `ap-msg ap-msg-${role}`;
  const bub = document.createElement('div');
  bub.className = 'ap-bubble';
  if (isHtml) bub.innerHTML = text; else bub.textContent = text;
  row.appendChild(bub);
  apMessages.appendChild(row);
  apMessages.scrollTop = apMessages.scrollHeight;
  return bub;
}

async function apSend() {
  const input = document.getElementById('ap-input');
  const text = input.value.trim();
  if (!text) return;
  input.value = '';
  document.getElementById('ap-quick').style.display = 'none';
  apHistory.push({ role: 'user', content: text });
  apAddMsg('user', text);
  const btn = document.getElementById('ap-send');
  btn.disabled = true; btn.textContent = '…';
  const typingBub = apAddMsg('agent', '…');
  typingBub.style.opacity = '0.5';

  try {
    const pageType = document.getElementById('pageType-field').value;
    const r = await fetch('/admin/pages/agent', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        messages: apHistory,
        pageType,
        currentPage: {
          title: document.getElementById('field-title')?.value || '',
          pageType,
        },
      }),
    });
    const data = await r.json();
    typingBub.closest('.ap-msg').remove();
    if (data.error) { apHistory.pop(); apAddMsg('agent', 'Error: ' + data.error); return; }

    apHistory.push({ role: 'assistant', content: data.message });
    apAddMsg('agent', data.message);

    // Fill flat fields
    if (data.fill) {
      Object.entries(data.fill).forEach(([k, v]) => { if (v) fillField(k, String(v)); });
    }

    // Apply suggested blocks (landing pages)
    if (Array.isArray(data.suggestedBlocks) && data.suggestedBlocks.length) {
      const validTypes = Object.keys(BLOCK_FIELDS);
      const newBlocks = data.suggestedBlocks
        .filter(b => b && validTypes.includes(b.type))
        .map(b => ({ id: Math.random().toString(36).slice(2), type: b.type, fields: b.fields || {} }));
      if (newBlocks.length) {
        pageBlocks = newBlocks;
        renderBlocks();
        apAddMsg('agent', `Added ${newBlocks.length} block${newBlocks.length > 1 ? 's' : ''} to your landing page. Expand each one to edit the content.`, false);
        // Switch to landing type if not already
        if (document.getElementById('pageType-field').value !== 'landing') {
          setPageType('landing');
        }
      }
    }
  } catch (e) {
    typingBub.closest('.ap-msg').remove();
    apHistory.pop();
    apAddMsg('agent', 'Connection error — please try again.');
  } finally {
    btn.disabled = false; btn.textContent = 'Send';
  }
}

document.querySelectorAll('.ap-quick-btn').forEach(b => {
  b.addEventListener('click', () => { document.getElementById('ap-input').value = b.dataset.prompt; apSend(); });
});
document.getElementById('ap-input').addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); apSend(); }
});

// Pre-fill from dashboard master agent
(function() {
  try {
    const raw = sessionStorage.getItem('w2_agent_fill');
    if (!raw) return;
    const data = JSON.parse(raw);
    if (data.department !== 'page' || !data.fill) return;
    sessionStorage.removeItem('w2_agent_fill');
    // Flat fields
    Object.entries(data.fill).forEach(([k, v]) => { if (v) fillField(k, String(v)); });
    // Switch to correct page type if provided
    if (data.page_type) setPageType(data.page_type);
    // Suggested blocks for landing pages
    if (Array.isArray(data.suggestedBlocks) && data.suggestedBlocks.length) {
      pageBlocks = [];
      data.suggestedBlocks.forEach(b => {
        const id = 'b' + Date.now() + Math.random().toString(36).slice(2);
        const type = b.type || 'text';
        const fields = {};
        const defs = BLOCK_FIELDS[type] || [];
        defs.forEach(f => { fields[f.key] = b.fields?.[f.key] || b[f.key] || ''; });
        pageBlocks.push({ id, type, fields, images: {} });
      });
      renderBlocks();
      serializeBlocks();
    }
  } catch {}
})();
</script>
<script src="/js/tours/pages.js"></script>

</div></body></html>
