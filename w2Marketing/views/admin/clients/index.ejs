<%- include('../partials/head', { title: 'Clients' }) %>
<%- include('../partials/sidebar', { page: 'clients', user: user }) %>

<div class="topbar">
  <div class="topbar-title">Clients</div>
  <div class="topbar-actions">
    <a href="/admin/clients/new" class="btn btn-navy">+ New Client</a>
  </div>
</div>

<div class="content">
  <% if (!clients.length) { %>
    <div class="empty">
      <div class="empty-icon">◉</div>
      <p>No clients yet. <a href="/admin/clients/new" style="color:var(--navy)">Add your first client.</a></p>
    </div>
  <% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Company</th>
          <th>Email</th>
          <th>Status</th>
          <th>Onboarding</th>
          <th>Added</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for (const c of clients) { %>
        <tr>
          <td style="font-weight:500;"><a href="/admin/clients/<%= c._id %>" style="color:var(--navy);text-decoration:none;"><%= c.name %></a></td>
          <td class="text-slate"><%= c.company || '—' %></td>
          <td class="text-slate"><%= c.email || '—' %></td>
          <td><span class="badge badge-<%= c.status %>"><%= c.status %></span></td>
          <td>
            <% if (c.onboarding?.complete) { %>
              <span class="badge badge-active">Done</span>
            <% } else { %>
              <span class="text-slate" style="font-size:0.8rem;">Step <%= c.onboarding?.step || 0 %></span>
            <% } %>
          </td>
          <td class="text-slate"><%= new Date(c.createdAt).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) %></td>
          <td>
            <a href="/admin/clients/<%= c._id %>" class="btn btn-ghost btn-sm">View</a>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

</div></div>
</body>
</html>
