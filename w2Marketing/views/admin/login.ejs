<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — W2 Marketing</title>
  <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;600;700&family=Great+Vibes&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Raleway', sans-serif;
      background: linear-gradient(135deg, #0a0a1a 0%, #0d1833 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-card {
      background: #fff;
      padding: 52px 48px;
      max-width: 420px;
      width: 100%;
      margin: 24px;
      border-radius: 8px;
      box-shadow: 0 24px 64px rgba(0,0,0,0.4);
    }
    .login-brand {
      font-family: 'Great Vibes', cursive;
      font-size: 2.4rem;
      color: #080808;
      margin-bottom: 2px;
    }
    .login-sub {
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #5f6360;
      margin-bottom: 36px;
    }
    .login-heading {
      font-size: 1.15rem;
      font-weight: 600;
      color: #116dff;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    .login-desc {
      font-size: 0.85rem;
      font-weight: 300;
      color: #5f6360;
      line-height: 1.7;
      margin-bottom: 32px;
    }
    .error-msg {
      background: rgba(220,38,38,0.07);
      border: 1px solid rgba(220,38,38,0.25);
      color: #dc2626;
      padding: 12px 16px;
      font-size: 0.82rem;
      font-weight: 400;
      margin-bottom: 20px;
      border-radius: 4px;
    }
    .btn-google {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      background: #116dff;
      color: #fff;
      text-decoration: none;
      padding: 15px 32px;
      border-radius: 4px;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      transition: background 0.2s;
      width: 100%;
    }
    .btn-google:hover { background: #0a55cc; }
    .btn-google svg { width: 18px; height: 18px; flex-shrink: 0; }
    .login-footer {
      margin-top: 28px;
      font-size: 0.72rem;
      color: #5f6360;
      text-align: center;
      line-height: 1.6;
    }
    .login-footer a { color: #116dff; text-decoration: none; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="login-brand">W2 Marketing</div>
    <div class="login-sub">Admin Portal</div>
    <div class="login-heading">Sign in to continue</div>
    <p class="login-desc">Access to this area is restricted to authorized administrators. Sign in with your Google account to proceed.</p>
    <% if (errorMsg) { %>
      <div class="error-msg"><%= errorMsg %></div>
    <% } %>
    <a href="/auth/google" class="btn-google">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Sign in with Google
    </a>
    <p class="login-footer">
      Only authorized users may access this portal.<br>
      <a href="/">← Back to site</a>
    </p>
  </div>
</body>
</html>
