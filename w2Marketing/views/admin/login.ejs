<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — W2 Marketing</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root { --navy: #1C2B4A; --navy-deep: #0F1B30; --gold: #C9A848; --gold-light: #E8D08A; --ivory: #F5F3EF; --ivory-mid: #E6E1D6; --slate: #6B7380; --dark: #0F1B30; --white: #FDFCFA; }
    body { font-family: 'Jost', sans-serif; background: var(--navy-deep); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .login-wrap { display: grid; grid-template-columns: 1fr 1fr; max-width: 780px; width: 100%; margin: 24px; box-shadow: 0 32px 80px rgba(0,0,0,0.5); }
    .login-left { background: var(--ivory); padding: 60px 48px; display: flex; flex-direction: column; justify-content: center; }
    .login-brand { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 300; color: var(--dark); margin-bottom: 2px; }
    .login-brand-sub { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.26em; text-transform: uppercase; color: var(--navy); margin-bottom: 40px; }
    .login-title { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--slate); margin-bottom: 6px; }
    .login-desc { font-size: 0.88rem; font-weight: 300; color: var(--slate); line-height: 1.7; margin-bottom: 32px; }
    .error-msg { background: rgba(185,28,28,0.07); border: 1px solid rgba(185,28,28,0.2); color: #B91C1C; padding: 12px 14px; font-size: 0.82rem; margin-bottom: 20px; border-radius: 2px; }
    .btn-google { display: flex; align-items: center; justify-content: center; gap: 12px; background: var(--navy); color: var(--white); text-decoration: none; padding: 14px 28px; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; transition: background 0.15s; border-radius: 2px; }
    .btn-google:hover { background: var(--navy-deep); }
    .btn-google svg { width: 18px; height: 18px; flex-shrink: 0; }
    .login-back { margin-top: 20px; font-size: 0.72rem; color: var(--slate); text-align: center; }
    .login-back a { color: var(--navy); text-decoration: none; }
    .login-right { background: var(--navy-deep); display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
    .login-right-text { font-family: 'Cormorant Garamond', serif; font-size: 9rem; font-weight: 300; font-style: italic; color: rgba(201,168,72,0.1); line-height: 1; user-select: none; }
    .login-badge { position: absolute; bottom: 40px; left: 40px; display: flex; align-items: center; gap: 10px; }
    .login-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); }
    .login-badge-text { font-size: 0.68rem; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(232,208,138,0.5); }
    @media (max-width: 600px) { .login-wrap { grid-template-columns: 1fr; } .login-right { display: none; } }
  </style>
</head>
<body>
  <div class="login-wrap">
    <div class="login-left">
      <div class="login-brand">W2 Marketing</div>
      <div class="login-brand-sub">Admin Portal</div>
      <div class="login-title">Sign in to continue</div>
      <p class="login-desc">Restricted to authorized administrators. Sign in with your Google account to access the portal.</p>
      <% if (errorMsg) { %>
        <div class="error-msg"><%= errorMsg %></div>
      <% } %>
      <a href="/auth/google" class="btn-google">
        <svg viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        Sign in with Google
      </a>
      <p class="login-back"><a href="/">← Back to site</a></p>
    </div>
    <div class="login-right">
      <div class="login-right-text">W2</div>
      <div class="login-badge">
        <div class="login-badge-dot"></div>
        <span class="login-badge-text">Secure Admin Access</span>
      </div>
    </div>
  </div>
</body>
</html>
