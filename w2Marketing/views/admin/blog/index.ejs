<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar', { user, page }) %>

<div class="topbar">
  <div class="topbar-title">Blog Posts</div>
  <div class="topbar-actions">
    <a href="/admin/blog/new" class="btn btn-navy">+ New Post</a>
  </div>
</div>
<div class="content">

  <% if (msg === 'created') { %><div class="alert alert-success">Post created successfully.</div><% } %>
  <% if (msg === 'updated') { %><div class="alert alert-success">Post updated successfully.</div><% } %>
  <% if (msg === 'deleted') { %><div class="alert alert-success">Post deleted.</div><% } %>
  <% if (msg === 'published') { %><div class="alert alert-success">Post published.</div><% } %>
  <% if (err) { %><div class="alert alert-error">Something went wrong. Please try again.</div><% } %>

  <% if (!posts || posts.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">✍</div>
      <p>No blog posts yet. Create your first post to get started.</p>
      <div style="margin-top:20px;"><a href="/admin/blog/new" class="btn btn-navy">Create Post</a></div>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Title</th>
            <th>Category</th>
            <th>Status</th>
            <th>Published</th>
            <th>Updated</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% posts.forEach(post => { %>
            <tr>
              <td>
                <div style="font-weight:500;"><%= post.title %></div>
                <div style="font-size:0.75rem;color:var(--slate);margin-top:2px;">/blog/<%= post.slug %></div>
              </td>
              <td><%= post.category || '—' %></td>
              <td>
                <span class="badge <%= post.status === 'published' ? 'badge-active' : 'badge-draft' %>"><%= post.status %></span>
              </td>
              <td style="font-size:0.82rem;color:var(--slate);">
                <%= post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : '—' %>
              </td>
              <td style="font-size:0.82rem;color:var(--slate);">
                <%= new Date(post.updatedAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %>
              </td>
              <td style="text-align:right;white-space:nowrap;">
                <% if (post.status === 'published') { %>
                  <a href="/blog/<%= post.slug %>" target="_blank" class="btn btn-ghost btn-sm" style="margin-right:6px;">View</a>
                <% } else { %>
                  <form method="POST" action="/admin/blog/<%= post._id %>/publish" style="display:inline;">
                    <button type="submit" class="btn btn-navy btn-sm" style="margin-right:6px;">Publish</button>
                  </form>
                <% } %>
                <a href="/admin/blog/<%= post._id %>/edit" class="btn btn-ghost btn-sm" style="margin-right:6px;">Edit</a>
                <form method="POST" action="/admin/blog/<%= post._id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this post?')">
                  <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

</div>
</div></body></html>
