<%- include('partials/head', { title: 'Dashboard' }) %>
<%- include('partials/sidebar', { page: 'dashboard', user: user }) %>

<div class="topbar">
  <div class="topbar-title">Dashboard</div>
  <div class="topbar-actions">
    <a href="/admin/copy" class="btn btn-ghost btn-sm">Edit Copy</a>
    <a href="/admin/portfolio/new" class="btn btn-navy btn-sm">+ New Portfolio Item</a>
  </div>
</div>

<div class="content">
  <div class="stat-grid">
    <div class="stat-card">
      <div class="stat-label">Portfolio Items</div>
      <div class="stat-value"><%= stats.portfolioCount %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Clients</div>
      <div class="stat-value"><%= stats.clientCount %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Open Invoices</div>
      <div class="stat-value gold"><%= stats.invoiceCount %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Auth Method</div>
      <div class="stat-value" style="font-size:1.4rem;margin-top:4px;">JWT</div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
    <div class="card">
      <div class="card-title">Account</div>
      <table>
        <tbody>
          <tr><td class="text-slate" style="width:120px;font-size:0.72rem;letter-spacing:.1em;text-transform:uppercase;">Name</td><td><%= user.displayName %></td></tr>
          <tr><td class="text-slate" style="font-size:0.72rem;letter-spacing:.1em;text-transform:uppercase;">Email</td><td><%= user.email %></td></tr>
          <tr><td class="text-slate" style="font-size:0.72rem;letter-spacing:.1em;text-transform:uppercase;">Role</td><td><span class="badge badge-active">W2 Admin</span></td></tr>
          <tr><td class="text-slate" style="font-size:0.72rem;letter-spacing:.1em;text-transform:uppercase;">Session</td><td class="text-slate">8 hours</td></tr>
        </tbody>
      </table>
    </div>
    <div class="card">
      <div class="card-title">Quick Actions</div>
      <div style="display:flex;flex-direction:column;gap:10px;">
        <a href="/admin/portfolio/new" class="btn btn-navy">+ Add Portfolio Item</a>
        <a href="/admin/clients/new" class="btn btn-ghost">+ Add Client</a>
        <a href="/admin/copy" class="btn btn-ghost">Edit Site Copy</a>
        <a href="/" target="_blank" class="btn btn-ghost">View Live Site ↗</a>
      </div>
    </div>
  </div>
</div>

</div></div>
</body>
</html>
