<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard — W2 Marketing</title>
  <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;600;700;800&family=Great+Vibes&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Raleway', sans-serif; background: #f4f4f6; color: #080808; min-height: 100vh; }

    .layout { display: flex; min-height: 100vh; }

    .sidebar {
      width: 240px;
      background: linear-gradient(180deg, #0a0a1a 0%, #0d1833 100%);
      display: flex;
      flex-direction: column;
      padding: 28px 0;
      flex-shrink: 0;
    }

    .sidebar-brand { padding: 0 24px 28px; border-bottom: 1px solid rgba(255,255,255,0.07); }

    .sidebar-brand-logo {
      font-family: 'Great Vibes', cursive;
      font-size: 1.8rem;
      color: #fff;
    }

    .sidebar-brand-sub {
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #116dff;
      margin-top: 2px;
    }

    .sidebar-nav { padding: 20px 0; flex: 1; }

    .sidebar-nav a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 11px 24px;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      text-decoration: none;
      transition: color 0.2s, background 0.2s;
    }

    .sidebar-nav a:hover,
    .sidebar-nav a.active { color: #7fccf7; background: rgba(17,109,255,0.1); }

    .sidebar-footer { padding: 20px 24px 0; border-top: 1px solid rgba(255,255,255,0.07); }

    .sidebar-user-name {
      font-size: 0.8rem;
      font-weight: 600;
      color: rgba(255,255,255,0.55);
      margin-bottom: 10px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .btn-logout {
      display: block;
      background: rgba(220,38,38,0.12);
      color: rgba(255,120,120,0.75);
      border: 1px solid rgba(220,38,38,0.2);
      padding: 8px 16px;
      border-radius: 4px;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      text-align: center;
      transition: background 0.2s;
    }

    .btn-logout:hover { background: rgba(220,38,38,0.25); }

    .main { flex: 1; display: flex; flex-direction: column; }

    .topbar {
      background: #fff;
      border-bottom: 1px solid #e5e7eb;
      padding: 18px 36px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .topbar-title {
      font-size: 1.3rem;
      font-weight: 300;
      color: #080808;
      letter-spacing: 0.02em;
    }

    .topbar-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(17,109,255,0.08);
      border: 1px solid rgba(17,109,255,0.2);
      border-radius: 4px;
      padding: 6px 14px;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #116dff;
    }

    .content { padding: 36px; flex: 1; }

    .stat-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 36px;
    }

    .stat-card {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      padding: 24px 20px;
    }

    .stat-card-label {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #5f6360;
      margin-bottom: 10px;
    }

    .stat-card-num {
      font-size: 2.4rem;
      font-weight: 800;
      color: #116dff;
      line-height: 1;
    }

    .section-title {
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #080808;
      margin-bottom: 18px;
    }

    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 36px; }

    .info-card {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      padding: 24px 20px;
    }

    .info-card-label {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #5f6360;
      margin-bottom: 6px;
    }

    .info-card-value { font-size: 0.95rem; font-weight: 400; color: #080808; }

    .view-site-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #116dff;
      color: #fff;
      padding: 12px 28px;
      text-decoration: none;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-radius: 4px;
      transition: background 0.2s;
    }

    .view-site-btn:hover { background: #0a55cc; }
  </style>
</head>
<body>
<div class="layout">
  <aside class="sidebar">
    <div class="sidebar-brand">
      <div class="sidebar-brand-logo">W2 Marketing</div>
      <div class="sidebar-brand-sub">Admin Portal</div>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin" class="active">Dashboard</a>
      <a href="/">View Public Site</a>
    </nav>
    <div class="sidebar-footer">
      <div class="sidebar-user-name"><%= user.displayName %></div>
      <a href="/auth/logout" class="btn-logout">Sign Out</a>
    </div>
  </aside>

  <div class="main">
    <div class="topbar">
      <div class="topbar-title">Dashboard</div>
      <div class="topbar-badge">Admin Access</div>
    </div>
    <div class="content">
      <div class="stat-row">
        <div class="stat-card">
          <div class="stat-card-label">Status</div>
          <div class="stat-card-num" style="font-size:1.2rem;color:#16a34a;">Live</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-label">Services</div>
          <div class="stat-card-num">3</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-label">Auth</div>
          <div class="stat-card-num" style="font-size:1.1rem;">JWT</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-label">Session</div>
          <div class="stat-card-num" style="font-size:1.1rem;">8h</div>
        </div>
      </div>

      <div class="section-title">Account Info</div>
      <div class="info-grid">
        <div class="info-card">
          <div class="info-card-label">Signed in as</div>
          <div class="info-card-value"><%= user.email %></div>
        </div>
        <div class="info-card">
          <div class="info-card-label">Display Name</div>
          <div class="info-card-value"><%= user.displayName %></div>
        </div>
        <div class="info-card">
          <div class="info-card-label">Admin Role</div>
          <div class="info-card-value">W2 Marketing Admin</div>
        </div>
        <div class="info-card">
          <div class="info-card-label">Auth Provider</div>
          <div class="info-card-value">Google OAuth 2.0 + JWT</div>
        </div>
      </div>

      <a href="/" class="view-site-btn">View Public Site &rarr;</a>
    </div>
  </div>
</div>
</body>
</html>
