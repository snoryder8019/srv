<%- include('partials/head', { title: 'Dashboard' }) %>
<%- include('partials/sidebar', { page: 'dashboard', user: user }) %>

<style>
/* ── Dashboard-specific responsive styles ── */
.dash-two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 16px;
}

/* Agent panel */
.agent-card { margin-top: 24px; }
.agent-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}
.agent-name-row {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.ai-badge {
  font-size: 0.63rem; font-weight: 700; letter-spacing: .14em;
  text-transform: uppercase; background: var(--navy); color: #fff;
  padding: 2px 8px; border-radius: 2px; white-space: nowrap;
}

/* Chat messages */
#ma-messages {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 14px;
  max-height: 380px;
  overflow-y: auto;
  padding-right: 4px;
}
.ma-msg { display: flex; }
.ma-msg-user  { justify-content: flex-end; }
.ma-msg-agent { justify-content: flex-start; }
.ma-bubble {
  max-width: 82%;
  padding: 10px 14px;
  border-radius: 6px;
  font-size: 0.88rem;
  line-height: 1.55;
  word-break: break-word;
}
.ma-msg-agent .ma-bubble { background: var(--ivory); color: var(--dark); }
.ma-msg-user  .ma-bubble { background: var(--navy); color: #fff; }
.ma-bubble a { color: var(--gold); }

/* Quick prompts */
#ma-quick {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin-bottom: 12px;
}

/* Input row */
.ma-input-row {
  display: flex;
  gap: 8px;
  align-items: flex-end;
}
.ma-input-row input {
  flex: 1;
  min-width: 0;
  padding: 10px 14px;
  border: 1px solid var(--ivory-mid);
  border-radius: 4px;
  font-size: 0.9rem;
  font-family: inherit;
}
.ma-input-row input:focus { outline: none; border-color: var(--navy); }

/* Result card */
#ma-result {
  display: none;
  margin-top: 16px;
  border: 1px solid var(--ivory-mid);
  border-radius: 4px;
  overflow: hidden;
}
.ma-result-header {
  padding: 12px 14px;
  background: var(--ivory);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  flex-wrap: wrap;
}
.ma-result-meta { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; min-width: 0; }
.ma-result-actions { display: flex; gap: 7px; flex-shrink: 0; flex-wrap: wrap; }
#ma-result-dept {
  font-size: 0.65rem; font-weight: 700; letter-spacing: .14em;
  text-transform: uppercase; color: #fff;
  padding: 2px 8px; border-radius: 2px; white-space: nowrap;
}
#ma-result-msg {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--dark);
  word-break: break-word;
}
#ma-result-fields {
  padding: 0 14px 14px;
  display: flex;
  flex-direction: column;
  gap: 5px;
  max-height: 240px;
  overflow-y: auto;
}
.ma-field-row {
  display: flex;
  gap: 8px;
  align-items: flex-start;
  padding: 6px 0;
  border-bottom: 1px solid var(--ivory-mid);
  font-size: 0.82rem;
}
.ma-field-key {
  flex-shrink: 0;
  width: 120px;
  font-weight: 600;
  color: var(--slate);
  text-transform: uppercase;
  letter-spacing: .05em;
  font-size: 0.65rem;
  padding-top: 2px;
}
.ma-field-val { color: var(--dark); line-height: 1.4; word-break: break-word; flex: 1; }

/* TTS / STT controls */
.ma-speak-btn {
  background: none; border: none; cursor: pointer;
  color: var(--slate); font-size: 0.85rem; padding: 2px 5px;
  border-radius: 3px; line-height: 1; opacity: 0.6;
  transition: opacity .15s, color .15s;
  vertical-align: middle; margin-left: 6px; flex-shrink: 0;
}
.ma-speak-btn:hover { opacity: 1; color: var(--navy); }
.ma-speak-btn.speaking { opacity: 1; color: var(--gold); animation: ma-pulse 1s infinite; }
@keyframes ma-pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

.ma-mic-btn {
  padding: 10px 12px; font-size: 1rem; line-height: 1;
  border-radius: 4px; border: 1px solid var(--ivory-mid);
  background: #fff; cursor: pointer; color: var(--slate);
  transition: background .15s, color .15s, border-color .15s;
  flex-shrink: 0;
}
.ma-mic-btn:hover { border-color: var(--navy); color: var(--navy); }
.ma-mic-btn.recording { background: #fee; border-color: #c33; color: #c33; animation: ma-pulse 0.8s infinite; }

#ma-voice-select {
  padding: 6px 8px; font-size: 0.78rem; font-family: inherit;
  border: 1px solid var(--ivory-mid); border-radius: 4px;
  background: #fff; color: var(--dark); cursor: pointer;
  flex-shrink: 0;
}
#ma-voice-select:focus { outline: none; border-color: var(--navy); }

/* Mobile overrides */
@media (max-width: 820px) {
  .dash-two-col { grid-template-columns: 1fr !important; }
  .agent-header { flex-direction: column; align-items: flex-start; }
  #ma-messages { max-height: 260px; }
  .ma-bubble { max-width: 92%; font-size: 0.85rem; }
  .ma-result-header { flex-direction: column; align-items: flex-start; gap: 10px; }
  .ma-result-actions { width: 100%; }
  .ma-result-actions .btn { flex: 1; justify-content: center; }
  .ma-field-key { width: 90px; }
}
@media (max-width: 520px) {
  /* Tighten overall content */
  .content { padding: 14px 12px; }
  .agent-card { margin-top: 14px; }
  .card { padding: 14px 12px; }
  .card + .card { margin-top: 10px; }

  /* Topbar: hide Edit Copy to reduce crowding, keep + Portfolio */
  .topbar-hide-mobile { display: none !important; }

  /* Stat grid: horizontal scroll strip */
  .stat-grid {
    display: flex !important;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    gap: 8px;
    margin-bottom: 14px;
    padding-bottom: 4px;
    scrollbar-width: none;
  }
  .stat-grid::-webkit-scrollbar { display: none; }
  .stat-card {
    flex: 0 0 auto;
    min-width: 96px;
    padding: 10px 12px;
  }
  .stat-label { font-size: 0.55rem; }
  .stat-value { font-size: 1.7rem; }

  /* Agent header */
  .agent-header { margin-bottom: 10px; }
  .agent-header p { display: none; }
  .agent-header a.btn { padding: 5px 10px; font-size: 0.62rem; }

  /* Chat area */
  #ma-messages { max-height: 200px; margin-bottom: 10px; }
  .ma-bubble { max-width: 96%; font-size: 0.82rem; padding: 8px 10px; }

  /* Quick chips — horizontal scroll */
  #ma-quick { flex-wrap: nowrap; overflow-x: auto; padding-bottom: 4px; -webkit-overflow-scrolling: touch; gap: 5px; margin-bottom: 8px; }
  #ma-quick .btn { font-size: 0.6rem; padding: 5px 10px; white-space: nowrap; flex-shrink: 0; }

  /* Input row:
     Row 1: [voice select ──────] [mic]
     Row 2: [input ──────────────] [send] */
  .ma-input-row { flex-wrap: wrap; gap: 6px; }
  #ma-voice-select { order: 1; flex: 1 1 0; min-width: 0; font-size: 0.73rem; padding: 7px 8px; }
  .ma-mic-btn { order: 2; flex-shrink: 0; padding: 8px 11px; font-size: 0.95rem; }
  .ma-input-row input { order: 3; flex: 1 1 0; min-width: 0; font-size: 0.85rem; padding: 9px 12px; }
  .ma-input-row .btn { order: 4; flex-shrink: 0; padding: 9px 14px; font-size: 0.72rem; }

  /* Result card */
  #ma-result { margin-top: 12px; }
  .ma-result-header { padding: 10px 12px; }
  .ma-result-actions { flex-direction: row; flex-wrap: wrap; gap: 6px; }
  .ma-result-actions .btn { flex: 1 1 auto; min-width: 0; justify-content: center; font-size: 0.65rem; padding: 7px 10px; }
  .ma-result-actions .btn:last-child { flex: 0 0 auto; }
  .ma-field-key { width: 64px; font-size: 0.57rem; }
  #ma-result-fields { padding: 0 12px 12px; max-height: 180px; }
  .ma-field-row { font-size: 0.78rem; }

  /* Quick Actions: 2-col grid on phone */
  .quick-actions-grid {
    display: grid !important;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .quick-actions-grid .btn { padding: 9px 10px; font-size: 0.65rem; justify-content: center; }

  /* Account table tighten */
  tbody td { padding: 10px 12px; font-size: 0.82rem; }
  thead th { padding: 9px 12px; }
}
</style>

<div class="topbar">
  <div class="topbar-title">Dashboard</div>
  <div class="topbar-actions">
    <a href="/admin/copy" class="btn btn-ghost btn-sm topbar-hide-mobile">Edit Copy</a>
    <a href="/admin/portfolio/new" class="btn btn-navy btn-sm">+ Portfolio</a>
  </div>
</div>

<div class="content">

  <!-- STATS -->
  <div class="stat-grid">
    <div class="stat-card">
      <div class="stat-label">Portfolio</div>
      <div class="stat-value"><%= stats.portfolioCount %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Clients</div>
      <div class="stat-value"><%= stats.clientCount %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Open Invoices</div>
      <div class="stat-value gold"><%= stats.invoiceCount %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Blog Posts</div>
      <div class="stat-value"><%= stats.blogCount %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Pages</div>
      <div class="stat-value"><%= stats.pageCount %></div>
    </div>
  </div>

  <!-- MASTER AGENT -->
  <div class="card agent-card">
    <div class="agent-header">
      <div>
        <div class="agent-name-row">
          <span style="color:var(--gold);font-size:1.05rem;">✦</span>
          <span class="card-title" style="margin:0;padding:0;border:none;" id="agent-display-name"><%= agentName %></span>
          <span class="ai-badge">AI</span>
        </div>
        <p style="font-size:0.8rem;color:var(--slate);margin-top:4px;">Ask me to write a blog post, update site copy, or build a new section. I can apply changes directly.</p>
      </div>
      <a href="/admin/design" class="btn btn-ghost btn-sm" style="white-space:nowrap;">Configure ↗</a>
    </div>

    <!-- Chat thread -->
    <div id="ma-messages">
      <div class="ma-msg ma-msg-agent">
        <div class="ma-bubble" id="ma-greeting">
          <%= agentName %> is ready — what would you like to create or update today?
        </div>
      </div>
    </div>

    <!-- Quick prompts (replaced with contextual suggestions after first response) -->
    <div id="ma-quick">
      <button class="btn btn-ghost btn-sm ma-quick-btn" onclick="maQuickSend('Write a blog post about social media tips for local businesses in Greeley, CO')">Social media blog</button>
      <button class="btn btn-ghost btn-sm ma-quick-btn" onclick="maQuickSend('Rewrite the hero section with a fresh compelling headline for a digital marketing agency')">Refresh hero copy</button>
      <button class="btn btn-ghost btn-sm ma-quick-btn" onclick="maQuickSend('Create an FAQ section about our digital marketing services and pricing')">Add FAQ section</button>
      <button class="btn btn-ghost btn-sm ma-quick-btn" onclick="maQuickSend('Write a CTA banner encouraging businesses to book a free marketing consultation')">CTA banner</button>
    </div>

    <!-- Input -->
    <div class="ma-input-row">
      <select id="ma-voice-select" title="TTS voice" onchange="maSetVoice(this.value)">
        <option value="lessac">Lessac (F)</option>
        <option value="ryan">Ryan (M)</option>
        <option value="slt">SLT (F)</option>
      </select>
      <button class="ma-mic-btn" id="ma-mic-btn" title="Speak" onclick="maToggleMic()">🎤</button>
      <input id="ma-input" type="text" placeholder="Ask <%= agentName %>…" autocomplete="off">
      <button class="btn btn-navy" id="ma-send" onclick="maSend()">Send</button>
    </div>

    <!-- Result card -->
    <div id="ma-result">
      <div class="ma-result-header">
        <div class="ma-result-meta">
          <span id="ma-result-dept"></span>
          <span id="ma-result-msg"></span>
        </div>
        <div class="ma-result-actions">
          <button id="ma-execute-btn" class="btn btn-gold btn-sm" onclick="maExecute()">Apply Now</button>
          <button id="ma-editor-btn" class="btn btn-ghost btn-sm" onclick="maOpenEditor()">Open in Editor</button>
          <button class="btn btn-ghost btn-sm" onclick="document.getElementById('ma-result').style.display='none'">✕</button>
        </div>
      </div>
      <div id="ma-result-fields"></div>
    </div>
  </div>

  <!-- ACCOUNT + QUICK ACTIONS -->
  <div class="dash-two-col">
    <div class="card">
      <div class="card-title">Account</div>
      <table>
        <tbody>
          <tr>
            <td class="text-slate" style="width:110px;font-size:0.68rem;letter-spacing:.1em;text-transform:uppercase;">Name</td>
            <td><%= user.displayName %></td>
          </tr>
          <tr>
            <td class="text-slate" style="font-size:0.68rem;letter-spacing:.1em;text-transform:uppercase;">Email</td>
            <td style="font-size:0.85rem;word-break:break-all;"><%= user.email %></td>
          </tr>
          <tr>
            <td class="text-slate" style="font-size:0.68rem;letter-spacing:.1em;text-transform:uppercase;">Role</td>
            <td><span class="badge badge-active">W2 Admin</span></td>
          </tr>
        </tbody>
      </table>
    </div>
    <div class="card">
      <div class="card-title">Quick Actions</div>
      <div class="quick-actions-grid" style="display:flex;flex-direction:column;gap:10px;">
        <a href="/admin/blog/new" class="btn btn-navy">+ New Blog Post</a>
        <a href="/admin/pages/new" class="btn btn-navy">+ New Page</a>
        <a href="/admin/portfolio/new" class="btn btn-ghost">+ Portfolio Item</a>
        <a href="/admin/copy" class="btn btn-ghost">Edit Site Copy</a>
        <a href="/admin/design" class="btn btn-ghost">Design &amp; Settings</a>
        <a href="/" target="_blank" class="btn btn-ghost">View Live Site ↗</a>
      </div>
    </div>
  </div>

</div>
</div></div>

<script>
const AGENT_NAME = '<%= agentName.replace(/\\/g,"\\\\").replace(/'/g,"\\'") %>';
const DEPT_COLORS = { blog: '#2E4270', copy: '#1C2B4A', section: '#5B3E2B', page: '#2E5B3E' };

// Conversation history (multi-turn)
let maHistory = [];
let maLastResult = null;
let maExecuting = false;

// ── TTS / STT ─────────────────────────────────────────────────────────────────
let _maVoice = 'lessac';
let _maCurrentAudio = null;

function maSetVoice(v) { _maVoice = v; }

function _ttsClean(text, maxChars = 0) {
  let clean = text
    .replace(/```[\s\S]*?```/g, 'code block.')
    .replace(/`[^`]+`/g, '')
    .replace(/\*\*([^*]+)\*\*/g, '$1')
    .replace(/\*([^*]+)\*/g, '$1')
    .replace(/#+\s/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/https?:\/\/\S+/g, 'link.')
    .replace(/\n+/g, ' ')
    .trim();
  if (maxChars > 0 && clean.length > maxChars) {
    const cut = clean.search(/[.!?](?:\s|$)/);
    clean = cut > 0 && cut < maxChars ? clean.slice(0, cut + 1) : clean.slice(0, maxChars);
  }
  return clean;
}

function _ttsSentences(text) {
  return text.match(/[^.!?]+[.!?]+\s*/g)?.map(s => s.trim()).filter(Boolean) || [text];
}

async function _ttsFetch(sentence) {
  const res = await fetch('/admin/tts', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ text: sentence, voice: _maVoice }),
  });
  const ct = res.headers.get('content-type') || '';
  if (!res.ok || !ct.includes('audio')) throw new Error(`TTS ${res.status}`);
  return URL.createObjectURL(await res.blob());
}

function _ttsPlayUrl(url) {
  return new Promise((resolve, reject) => {
    const audio = new Audio(url);
    _maCurrentAudio = audio;
    audio.onended = () => { URL.revokeObjectURL(url); resolve(); };
    audio.onerror = (e) => { URL.revokeObjectURL(url); reject(e); };
    audio.play().catch(reject);
  });
}

function maStopSpeaking() {
  if (_maCurrentAudio) { _maCurrentAudio.pause(); _maCurrentAudio = null; }
  document.querySelectorAll('.ma-speak-btn.speaking').forEach(b => b.classList.remove('speaking'));
}

async function maSpeak(text, btn, autoSpeak = false) {
  const clean = _ttsClean(text, autoSpeak ? 300 : 0);
  if (!clean) return;
  maStopSpeaking();
  if (btn) btn.classList.add('speaking');
  const sentences = _ttsSentences(clean);
  try {
    let nextFetch = _ttsFetch(sentences[0]);
    for (let i = 0; i < sentences.length; i++) {
      const prefetchNext = sentences[i + 1] ? _ttsFetch(sentences[i + 1]) : null;
      const url = await nextFetch;
      if (!btn || btn.classList.contains('speaking')) {
        await _ttsPlayUrl(url);
      } else {
        URL.revokeObjectURL(url); break;
      }
      nextFetch = prefetchNext;
    }
    _maCurrentAudio = null;
    if (btn) btn.classList.remove('speaking');
  } catch (err) {
    console.warn('[TTS] Piper failed, falling back to Web Speech:', err.message);
    _maCurrentAudio = null;
    if (window.speechSynthesis) {
      const utt = new SpeechSynthesisUtterance(clean);
      utt.rate = 1.0; utt.pitch = 0.95;
      utt.onend = () => { if (btn) btn.classList.remove('speaking'); };
      window.speechSynthesis.speak(utt);
    } else {
      if (btn) btn.classList.remove('speaking');
    }
  }
}

function maSpeakBtn(btn) {
  if (btn.classList.contains('speaking')) { maStopSpeaking(); return; }
  const content = btn.closest('.ma-msg')?.querySelector('.ma-bubble');
  if (!content) return;
  maSpeak(content.innerText || content.textContent, btn);
}

// ── STT (Web Speech API) ──────────────────────────────────────────────────────
let _maRecognition = null;
let _maIsRecording = false;

(function initMaSpeech() {
  const SpeechRec = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRec) return;
  _maRecognition = new SpeechRec();
  _maRecognition.continuous = false;
  _maRecognition.interimResults = false;
  _maRecognition.lang = 'en-US';
  _maRecognition.onresult = (e) => {
    const transcript = e.results[0][0].transcript;
    const input = document.getElementById('ma-input');
    if (input) { input.value = transcript; maSend(); }
    maStopMic();
  };
  _maRecognition.onerror = (e) => {
    if (e.error !== 'no-speech') console.warn('[STT]', e.error);
    maStopMic();
  };
  _maRecognition.onend = () => maStopMic();
})();

function maToggleMic() {
  if (_maIsRecording) { maStopMic(); return; }
  if (!_maRecognition) return;
  _maIsRecording = true;
  document.getElementById('ma-mic-btn')?.classList.add('recording');
  try { _maRecognition.start(); } catch(e) { maStopMic(); }
}

function maStopMic() {
  _maIsRecording = false;
  document.getElementById('ma-mic-btn')?.classList.remove('recording');
  try { if (_maRecognition) _maRecognition.stop(); } catch(e) { /* already stopped */ }
}

// ── Chat helpers ─────────────────────────────────────────────────────────────
function maAddMsg(role, html, isHtml) {
  const box = document.getElementById('ma-messages');
  const row = document.createElement('div');
  row.className = `ma-msg ma-msg-${role}`;
  const bub = document.createElement('div');
  bub.className = 'ma-bubble';
  if (isHtml) bub.innerHTML = html;
  else bub.textContent = html;
  row.appendChild(bub);
  if (role === 'agent') {
    const speakBtn = document.createElement('button');
    speakBtn.className = 'ma-speak-btn';
    speakBtn.title = 'Read aloud';
    speakBtn.textContent = '🔊';
    speakBtn.onclick = () => maSpeakBtn(speakBtn);
    row.appendChild(speakBtn);
  }
  box.appendChild(row);
  box.scrollTop = box.scrollHeight;
  return bub;
}

function maSetLoading(on) {
  const btn = document.getElementById('ma-send');
  btn.disabled = on;
  btn.textContent = on ? '…' : 'Send';
}

// ── Send (two-step: research → generate) ─────────────────────────────────────
async function maSend() {
  const input = document.getElementById('ma-input');
  const text = input.value.trim();
  if (!text || maExecuting) return;
  input.value = '';
  document.getElementById('ma-quick').style.display = 'none';
  document.getElementById('ma-result').style.display = 'none';

  maHistory.push({ role: 'user', content: text });
  maAddMsg('user', text);
  maSetLoading(true);

  // Step 1 — Research: routing + web search
  const searchBub = maAddMsg('agent', '🔍 Researching…');
  searchBub.style.opacity = '0.55';
  searchBub.style.fontSize = '0.8rem';

  let research = null;
  try {
    const rr = await fetch('/admin/master-agent/research', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ messages: maHistory }),
    });
    research = await rr.json();
    if (research && research.searchQuery) {
      searchBub.innerHTML = `🔍 Searched: <em>${research.searchQuery}</em>`;
    }
  } catch {
    searchBub.textContent = '🔍 Researching…';
  }

  // Step 2 — Generate: full content
  const typingBub = maAddMsg('agent', '✦ Writing…');
  typingBub.style.opacity = '0.5';

  try {
    const r = await fetch('/admin/master-agent', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ messages: maHistory, research }),
    });
    const data = await r.json();
    typingBub.closest('.ma-msg').remove();

    if (data.error) {
      maHistory.pop();
      maAddMsg('agent', 'Error: ' + data.error);
      return;
    }

    maLastResult = data;
    maHistory.push({ role: 'assistant', content: data.message });
    const agentBub = maAddMsg('agent', data.message + ' <span style="font-size:0.75rem;color:var(--slate);">See result below ↓</span>', true);
    maShowResult(data);
    // Auto-speak first sentence of response
    const speakBtn = agentBub.closest('.ma-msg')?.querySelector('.ma-speak-btn');
    maSpeak(data.message, speakBtn, true);
  } catch (e) {
    typingBub.closest('.ma-msg').remove();
    maHistory.pop();
    maAddMsg('agent', 'Connection error — please try again.');
  } finally {
    maSetLoading(false);
  }
}

// ── Quick send (used by prompt chips) ────────────────────────────────────────
function maQuickSend(prompt) {
  document.getElementById('ma-input').value = prompt;
  maSend();
}

// ── Result card ──────────────────────────────────────────────────────────────
function maShowResult(data) {
  const res      = document.getElementById('ma-result');
  const deptEl   = document.getElementById('ma-result-dept');
  const msgEl    = document.getElementById('ma-result-msg');
  const fieldsEl = document.getElementById('ma-result-fields');
  const execBtn  = document.getElementById('ma-execute-btn');
  const editorBtn = document.getElementById('ma-editor-btn');

  deptEl.textContent = data.department;
  deptEl.style.background = DEPT_COLORS[data.department] || '#1C2B4A';
  msgEl.textContent = data.message;

  fieldsEl.innerHTML = '';
  const entries = Object.entries(data.fill || {}).filter(([, v]) => v && String(v).trim());
  entries.forEach(([k, v]) => {
    const row = document.createElement('div');
    row.className = 'ma-field-row';
    const preview = String(v).replace(/<[^>]+>/g, ' ').trim().slice(0, 160);
    row.innerHTML = `<span class="ma-field-key">${k.replace(/_/g,' ')}</span><span class="ma-field-val">${preview}${String(v).length > 160 ? '…' : ''}</span>`;
    fieldsEl.appendChild(row);
  });

  execBtn.textContent = 'Apply Now';
  execBtn.disabled = false;
  editorBtn.textContent = data.action?.label || 'Open in Editor';
  res.style.display = 'block';

  // Update quick chips with contextual follow-up suggestions
  const quick = document.getElementById('ma-quick');
  quick.innerHTML = '';
  if (Array.isArray(data.suggestions) && data.suggestions.length) {
    data.suggestions.forEach(s => {
      const btn = document.createElement('button');
      btn.className = 'btn btn-ghost btn-sm ma-quick-btn';
      btn.textContent = s;
      btn.onclick = () => maQuickSend(s);
      quick.appendChild(btn);
    });
    quick.style.display = 'flex';
  }
}

// ── Apply Now ─────────────────────────────────────────────────────────────────
async function maExecute() {
  if (!maLastResult || maExecuting) return;
  maExecuting = true;
  const btn = document.getElementById('ma-execute-btn');
  btn.textContent = 'Saving…';
  btn.disabled = true;

  try {
    const r = await fetch('/admin/master-agent/execute', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        department: maLastResult.department,
        fill: maLastResult.fill,
        section_type: maLastResult.section_type,
        page_type: maLastResult.page_type,
        label: maLastResult.fill?.heading || maLastResult.fill?.title,
      }),
    });
    const data = await r.json();

    if (data.ok) {
      document.getElementById('ma-result').style.display = 'none';
      const linkHtml = data.editUrl
        ? ` <a href="${data.editUrl}" style="color:var(--gold);text-decoration:underline;">View →</a>`
        : '';
      maHistory.push({ role: 'assistant', content: '✓ ' + data.message });
      maAddMsg('agent', `✓ ${data.message}${linkHtml}`, true);
    } else {
      maAddMsg('agent', 'Could not apply: ' + (data.message || data.error));
    }
  } catch (e) {
    maAddMsg('agent', 'Save failed — please try again.');
  } finally {
    maExecuting = false;
    btn.textContent = 'Apply Now';
    btn.disabled = false;
  }
}

// ── Open in Editor ───────────────────────────────────────────────────────────
function maOpenEditor() {
  if (!maLastResult) return;
  try { sessionStorage.setItem('w2_agent_fill', JSON.stringify(maLastResult)); } catch {}
  window.location.href = maLastResult.action?.url || '/admin';
}

// ── Enter key ────────────────────────────────────────────────────────────────
document.getElementById('ma-input').addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); maSend(); }
});
</script>

<!-- ── ADMIN ONBOARDING TOUR ─────────────────────────────────────────────── -->
<style>
#w2tut-overlay {
  position: fixed; inset: 0; z-index: 9990;
  pointer-events: all; /* blocks all page clicks during tour */
}
#w2tut-spot {
  position: fixed; z-index: 9992; pointer-events: none;
  box-shadow: 0 0 0 9999px rgba(8,15,32,0.82);
  transition: left 0.42s cubic-bezier(0.4,0,0.2,1),
              top  0.42s cubic-bezier(0.4,0,0.2,1),
              width  0.42s cubic-bezier(0.4,0,0.2,1),
              height 0.42s cubic-bezier(0.4,0,0.2,1),
              border-radius 0.42s;
}
#w2tut-tip {
  position: fixed; z-index: 9993; pointer-events: none;
  background: #fff; border-radius: 4px;
  padding: 20px 24px; max-width: 360px; min-width: 260px;
  box-shadow: 0 16px 48px rgba(0,0,0,0.35);
  font-family: 'Jost', sans-serif; font-size: 0.9rem;
  font-weight: 300; line-height: 1.65; color: #0F1B30;
  transition: left 0.42s cubic-bezier(0.4,0,0.2,1),
              top  0.42s cubic-bezier(0.4,0,0.2,1);
}
#w2tut-tip strong { font-weight: 600; color: #1C2B4A; }
#w2tut-step-label {
  font-size: 0.6rem; font-weight: 600; letter-spacing: 0.22em;
  text-transform: uppercase; color: #C9A848; margin-bottom: 10px;
}
#w2tut-exit {
  position: fixed; bottom: 32px; left: 32px; z-index: 9993;
  background: transparent; border: 1px solid rgba(255,255,255,0.22);
  color: rgba(255,255,255,0.55); padding: 10px 20px;
  font-family: 'Jost', sans-serif; font-size: 0.76rem; font-weight: 500;
  letter-spacing: 0.1em; text-transform: uppercase;
  cursor: pointer; border-radius: 2px; transition: all 0.2s;
}
#w2tut-exit:hover { border-color: rgba(255,255,255,0.5); color: #fff; }
#w2tut-next {
  position: fixed; bottom: 32px; right: 32px; z-index: 9993;
  background: #C9A848; border: none; color: #0F1B30;
  padding: 13px 30px; font-family: 'Jost', sans-serif;
  font-size: 0.82rem; font-weight: 600; letter-spacing: 0.12em;
  text-transform: uppercase; cursor: pointer; border-radius: 2px;
  transition: background 0.2s;
}
#w2tut-next:hover { background: #E8D08A; }
#w2tut-dots {
  position: fixed; bottom: 40px; left: 50%; transform: translateX(-50%);
  z-index: 9993; display: flex; gap: 8px; pointer-events: none;
}
.w2tut-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: rgba(255,255,255,0.22); transition: background 0.3s;
}
.w2tut-dot.active { background: #C9A848; }
#w2tut-final {
  position: fixed; z-index: 9993; pointer-events: none;
  background: #fff; border-radius: 4px;
  padding: 20px 24px; max-width: 420px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  font-family: 'Jost', sans-serif; font-size: 0.92rem;
  font-weight: 300; line-height: 1.7; color: #0F1B30;
  left: 50%; top: 50%; transform: translate(-50%, -50%);
  text-align: center; display: none;
}
#w2tut-final strong { font-weight: 600; color: #1C2B4A; }
#w2tut-final .tut-final-icon {
  font-size: 1.6rem; margin-bottom: 8px; display: block;
}
/* force hamburger visible during tour */
.w2tut-active #sidebarToggle { display: flex !important; }
</style>

<div id="w2tut-overlay" style="display:none;"></div>
<div id="w2tut-spot" style="display:none;"></div>
<div id="w2tut-tip" style="display:none;"><div id="w2tut-step-label"></div><div id="w2tut-msg"></div></div>
<div id="w2tut-dots" style="display:none;"></div>
<button id="w2tut-exit" style="display:none;">✕ Skip Tour</button>
<button id="w2tut-next" style="display:none;">Next →</button>
<div id="w2tut-final"></div>

<script>
(function() {
  if (localStorage.getItem('w2_admin_tour_done')) return;

  const STEPS = [
    {
      targetId: 'sidebarToggle',
      shape: 'circle', pad: 18,
      label: 'Step 1 of 5',
      msg: 'Welcome! This button opens your <strong>admin navigation menu</strong>. Let\'s explore it together.',
      onNext() {
        const s = document.getElementById('sidebar');
        const o = document.getElementById('sidebarOverlay');
        const t = document.getElementById('sidebarToggle');
        s.classList.add('open');
        if (o) { o.style.display = 'block'; o.classList.add('active'); }
        t.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
    },
    {
      targetSel: 'a[href="/admin/sections"]',
      shape: 'rect', pad: 8,
      label: 'Step 2 of 5',
      msg: 'Here\'s <strong>Sections</strong> — build and manage custom content blocks like CTAs, cards, FAQs, and image splits for your site.',
      onNext() {
        const s = document.getElementById('sidebar');
        const o = document.getElementById('sidebarOverlay');
        const t = document.getElementById('sidebarToggle');
        s.classList.remove('open');
        if (o) { o.classList.remove('active'); o.style.display = ''; }
        t.classList.remove('open');
        document.body.style.overflow = '';
      }
    },
    {
      targetSel: '.agent-card',
      shape: 'rect', pad: 0,
      label: 'Step 3 of 5',
      msg: 'Here you can fill out your site content manually — or try your <strong>AI suggestion</strong>. Your agent can write copy, blog posts, and build new sections.',
      onNext() {
        const el = document.querySelector('.ma-input-row');
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    },
    {
      targetSel: '#ma-quick',
      targetSel2: '.ma-input-row',
      shape: 'rect', pad: 10,
      label: 'Step 4 of 5',
      msg: 'Choose a <strong>preset suggestion</strong> to get started quickly, or type any request in the chat bar. Your agent works best with clear, specific instructions.',
      onNext() {}
    },
    {
      final: true,
      label: 'Step 5 of 5',
      msg: 'All your admin tools let you update <strong>copy, images, layout, and page views</strong> of your site. We recommend spending a little time with your agents before using the dashboard AI assistant — it helps you understand exactly what changes are possible.<br><br>Thank you for testing W2 Marketing! ✦'
    }
  ];

  let step = 0;

  // Show tour UI
  document.body.classList.add('w2tut-active');
  document.getElementById('w2tut-overlay').style.display = 'block';
  document.getElementById('w2tut-dots').style.display = 'flex';
  document.getElementById('w2tut-exit').style.display = 'block';
  document.getElementById('w2tut-next').style.display = 'block';

  showStep(0);

  function showStep(n) {
    step = n;
    const s = STEPS[n];

    // Dots
    document.getElementById('w2tut-dots').innerHTML =
      STEPS.map((_, i) => `<div class="w2tut-dot${i === n ? ' active' : ''}"></div>`).join('');

    // Next button label
    document.getElementById('w2tut-next').textContent = n === STEPS.length - 1 ? 'Done ✓' : 'Next →';

    if (s.final) {
      document.getElementById('w2tut-spot').style.display = 'none';
      document.getElementById('w2tut-tip').style.display = 'none';
      const fin = document.getElementById('w2tut-final');
      fin.style.display = 'block';
      fin.innerHTML = `<span class="tut-final-icon">✦</span><strong style="font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:400;display:block;margin-bottom:10px;">You\'re all set!</strong>${s.msg}`;
      return;
    }

    document.getElementById('w2tut-final').style.display = 'none';
    document.getElementById('w2tut-step-label').textContent = s.label;
    document.getElementById('w2tut-msg').innerHTML = s.msg;

    // Resolve target element
    let el;
    if (s.targetId) {
      el = document.getElementById(s.targetId);
    } else {
      el = document.querySelector(s.targetSel);
    }
    if (!el) return;

    // Scroll element into view first (for agent card on scrolled page)
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });

    setTimeout(function() {
      const rect = el.getBoundingClientRect();
      const spot = document.getElementById('w2tut-spot');
      spot.style.display = 'block';
      const tip  = document.getElementById('w2tut-tip');
      tip.style.display = 'block';
      const pad = s.pad || 0;

      if (s.shape === 'circle') {
        const size = Math.max(rect.width, rect.height) + pad * 2;
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        spot.style.width  = size + 'px';
        spot.style.height = size + 'px';
        spot.style.borderRadius = '50%';
        spot.style.left = (cx - size / 2) + 'px';
        spot.style.top  = (cy - size / 2) + 'px';
      } else {
        let top    = rect.top    - pad;
        let left   = rect.left   - pad;
        let right  = rect.right  + pad;
        let bottom = rect.bottom + pad;
        // Union with optional second target
        if (s.targetSel2) {
          const el2 = document.querySelector(s.targetSel2);
          if (el2) {
            const r2 = el2.getBoundingClientRect();
            top    = Math.min(top,    r2.top    - pad);
            left   = Math.min(left,   r2.left   - pad);
            right  = Math.max(right,  r2.right  + pad);
            bottom = Math.max(bottom, r2.bottom + pad);
          }
        }
        spot.style.left   = left + 'px';
        spot.style.top    = top  + 'px';
        spot.style.width  = (right - left) + 'px';
        spot.style.height = (bottom - top) + 'px';
        spot.style.borderRadius = '6px';
      }

      // Position tooltip
      const spotR = spot.getBoundingClientRect();
      const vw = window.innerWidth, vh = window.innerHeight;
      const tipW = 360, tipH = 140, margin = 18;

      // Prefer below spotlight
      let tipTop = spotR.bottom + margin;
      if (tipTop + tipH > vh - 80) tipTop = spotR.top - tipH - margin;
      tipTop = Math.max(10, Math.min(tipTop, vh - tipH - 80));

      let tipLeft = spotR.left;
      if (tipLeft + tipW > vw - 20) tipLeft = vw - tipW - 20;
      tipLeft = Math.max(16, tipLeft);

      tip.style.left = tipLeft + 'px';
      tip.style.top  = tipTop  + 'px';
    }, n === 0 ? 60 : 80);
  }

  function endTour() {
    localStorage.setItem('w2_admin_tour_done', '1');
    document.body.classList.remove('w2tut-active');
    ['w2tut-overlay','w2tut-spot','w2tut-tip','w2tut-dots',
     'w2tut-exit','w2tut-next','w2tut-final'].forEach(function(id) {
      const el = document.getElementById(id);
      if (el) el.style.display = 'none';
    });
    // Ensure sidebar closed & hamburger reset
    document.getElementById('sidebar').classList.remove('open');
    const o = document.getElementById('sidebarOverlay');
    if (o) { o.classList.remove('active'); o.style.display = ''; }
    document.getElementById('sidebarToggle').classList.remove('open');
    document.body.style.overflow = '';
  }

  document.getElementById('w2tut-next').addEventListener('click', function() {
    if (step < STEPS.length - 1) {
      if (STEPS[step].onNext) STEPS[step].onNext();
      const delay = (step === 0) ? 320 : 60;
      setTimeout(function() { showStep(step + 1); }, delay);
    } else {
      endTour();
    }
  });

  document.getElementById('w2tut-exit').addEventListener('click', endTour);
})();
</script>

</body>
</html>
