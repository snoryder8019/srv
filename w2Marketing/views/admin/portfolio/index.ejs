<%- include('../partials/head', { title: 'Portfolio' }) %>
<%- include('../partials/sidebar', { page: 'portfolio', user: user }) %>

<style>
/* Portfolio table — hide low-priority columns on small screens */
@media (max-width: 640px) {
  .portfolio-table th:nth-child(3),
  .portfolio-table td:nth-child(3),
  .portfolio-table th:nth-child(4),
  .portfolio-table td:nth-child(4),
  .portfolio-table th:nth-child(5),
  .portfolio-table td:nth-child(5),
  .portfolio-table th:nth-child(6),
  .portfolio-table td:nth-child(6),
  .portfolio-table th:nth-child(7),
  .portfolio-table td:nth-child(7) { display: none; }

  .portfolio-table { min-width: 0 !important; }

  /* Thumbnail smaller on mobile */
  .portfolio-table td:nth-child(1) img,
  .portfolio-table td:nth-child(1) div { width: 48px !important; height: 36px !important; }
}
</style>

<div class="topbar">
  <div class="topbar-title">Portfolio</div>
  <div class="topbar-actions">
    <a href="/admin/portfolio/new" class="btn btn-navy">+ New Item</a>
  </div>
</div>

<div class="content">
  <% if (!items.length) { %>
    <div class="empty">
      <div class="empty-icon">◈</div>
      <p>No portfolio items yet. <a href="/admin/portfolio/new" style="color:var(--navy)">Add your first project.</a></p>
    </div>
  <% } else { %>
  <div class="table-wrap">
    <table class="portfolio-table">
      <thead>
        <tr>
          <th>Image</th>
          <th>Title</th>
          <th>Category</th>
          <th>Client</th>
          <th>Date</th>
          <th>Featured</th>
          <th>Order</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for (const item of items) { %>
        <tr>
          <td>
            <% if (item.imageUrl) { %>
              <img src="<%= item.imageUrl %>" style="width:60px;height:44px;object-fit:cover;border-radius:2px;display:block;">
            <% } else { %>
              <div style="width:60px;height:44px;background:var(--ivory);border:1px solid var(--ivory-mid);display:flex;align-items:center;justify-content:center;color:var(--ivory-mid);font-size:0.7rem;">No img</div>
            <% } %>
          </td>
          <td style="font-weight:500;"><%= item.title %></td>
          <td class="text-slate"><%= item.category || '—' %></td>
          <td class="text-slate"><%= item.clientName || '—' %></td>
          <td class="text-slate"><%= item.projectDate ? new Date(item.projectDate).toLocaleDateString('en-US', {month:'short',year:'numeric'}) : '—' %></td>
          <td><% if (item.featured) { %><span class="badge badge-featured">Yes</span><% } %></td>
          <td class="text-slate"><%= item.order %></td>
          <td>
            <div style="display:flex;gap:8px;">
              <a href="/admin/portfolio/<%= item._id %>/edit" class="btn btn-ghost btn-sm">Edit</a>
              <form method="POST" action="/admin/portfolio/<%= item._id %>/delete" onsubmit="return confirm('Delete this item?')">
                <button class="btn btn-danger btn-sm">Del</button>
              </form>
            </div>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

</div></div>
</body>
</html>
