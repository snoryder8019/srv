<!DOCTYPE html>
<html lang="en">
<head>
  <title>GRAFFITI TV — NEWSROOM</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&family=Source+Serif+4:ital,wght@0,700;1,400&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#0c0c10;--accent:#e8b400;--red:#cc1100;--lt:#d8d8cc;--dim:#555550;}
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:var(--bg);color:var(--lt);height:100vh;overflow:hidden;font-family:'Source Serif 4',serif;}
    .shell{
      display:grid;
      grid-template-rows:58px 1fr 46px 50px;
      grid-template-columns:1fr 280px;
      height:100vh;gap:0;
    }

    /* TOP */
    .top-bar{
      grid-column:1/-1;
      background:#08080c;
      border-bottom:3px solid var(--accent);
      display:flex;align-items:stretch;
    }
    .network-bug{
      background:var(--red);
      display:flex;align-items:center;padding:0 20px;
      font-family:'Oswald',sans-serif;font-size:26px;letter-spacing:4px;
      color:#fff;border-right:3px solid var(--accent);
      flex-shrink:0;
    }
    .headline-zone{flex:1;overflow:hidden;display:flex;align-items:center;padding:0 20px;}
    .headline-track{display:flex;animation:hScroll 28s linear infinite;white-space:nowrap;}
    @keyframes hScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .h-item{padding:0 50px;font-family:'Oswald',sans-serif;font-size:18px;letter-spacing:2px;color:var(--lt);}
    .h-item::before{content:'● ';color:var(--accent);}
    .time-zone{
      border-left:3px solid var(--accent);
      padding:0 20px;display:flex;flex-direction:column;align-items:center;justify-content:center;
      flex-shrink:0;min-width:120px;
    }
    .tz-label{font-family:'Oswald',sans-serif;font-size:10px;letter-spacing:3px;color:var(--dim);}
    .tz-time{font-family:'Share Tech Mono',monospace;font-size:22px;color:var(--accent);}

    /* MAIN */
    .main{
      border-right:2px solid #1a1a1a;
      position:relative;overflow:hidden;background:#000;
    }
    /* Breaking news bar */
    .breaking{
      position:absolute;bottom:0;left:0;right:0;z-index:10;
      background:var(--red);
      display:flex;align-items:center;height:36px;
    }
    .breaking-label{
      font-family:'Oswald',sans-serif;font-size:14px;letter-spacing:3px;
      background:var(--accent);color:#000;
      padding:0 14px;height:100%;display:flex;align-items:center;flex-shrink:0;
    }
    .breaking-track{overflow:hidden;flex:1;}
    .breaking-inner{display:flex;animation:hScroll 20s linear infinite;white-space:nowrap;}
    .b-item{padding:0 30px;font-family:'Oswald',sans-serif;font-size:14px;letter-spacing:1px;color:#fff;}
    #mediaContainer{width:100%;height:100%;position:relative;display:flex;align-items:center;justify-content:center;}
    #mediaContainer img,#mediaContainer video{width:100%;height:100%;object-fit:contain;position:absolute;top:0;left:0;}
    .loading-msg{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;background:#000;}
    .news-loading{font-family:'Oswald',sans-serif;font-size:32px;letter-spacing:8px;color:var(--accent);}
    .news-sub{font-size:12px;letter-spacing:4px;color:var(--dim);font-family:'Share Tech Mono',monospace;animation:blinkAnim 1s step-end infinite;}
    @keyframes blinkAnim{0%,100%{opacity:1}50%{opacity:0.2}}

    /* SIDEBAR */
    .sidebar{
      background:#09090d;
      border-left:2px solid #1a1a1a;
      overflow:hidden;display:flex;flex-direction:column;
    }
    .s-header{
      font-family:'Oswald',sans-serif;font-size:13px;letter-spacing:5px;
      padding:12px;text-align:center;
      background:#111116;color:var(--accent);
      border-bottom:2px solid var(--accent);
    }
    .sidebar-scroll{flex:1;overflow:hidden;}
    .sidebar-inner{animation:sideScroll 26s linear infinite;}
    @keyframes sideScroll{0%{transform:translateY(0)}100%{transform:translateY(-50%)}}
    .s-card{padding:14px;border-bottom:1px solid #111116;}
    .s-card-name{font-family:'Oswald',sans-serif;font-size:16px;color:var(--lt);margin-bottom:3px;letter-spacing:1px;}
    .s-card-desc{font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--dim);margin-bottom:6px;line-height:1.5;}
    .card-foot{display:flex;align-items:baseline;justify-content:space-between;}
    .s-card-price{font-family:'Oswald',sans-serif;font-size:20px;color:var(--accent);}
    .s-card-tag{font-family:'Share Tech Mono',monospace;font-size:9px;color:var(--red);letter-spacing:2px;}

    /* MENU TICKER */
    .ticker-bar{
      grid-column:1/-1;
      background:#060608;
      border-top:2px solid #1a1a1a;border-bottom:2px solid var(--accent);
      overflow:hidden;display:flex;align-items:center;
    }
    .ticker-label{font-family:'Oswald',sans-serif;font-size:13px;letter-spacing:3px;padding:0 14px;color:#000;background:var(--accent);height:100%;display:flex;align-items:center;white-space:nowrap;flex-shrink:0;}
    .ticker-track{display:flex;animation:hScroll 38s linear infinite;white-space:nowrap;}
    .t-item{padding:0 28px;font-family:'Share Tech Mono',monospace;font-size:13px;color:#888;letter-spacing:1px;}
    .t-item strong{color:var(--lt);}
    .t-item span{color:var(--accent);}

    /* BOTTOM */
    .bottom-bar{
      grid-column:1/-1;
      background:#08080c;border-top:2px solid #1a1a1a;
      display:flex;align-items:center;justify-content:space-between;padding:0 20px;
    }
    .b-left{font-family:'Oswald',sans-serif;font-size:13px;letter-spacing:3px;color:var(--dim);}
    .b-center{font-family:'Oswald',sans-serif;font-size:22px;letter-spacing:5px;color:var(--lt);}
    .b-right{font-family:'Share Tech Mono',monospace;font-size:13px;color:var(--dim);text-align:right;line-height:1.5;}
  
    .qr-block{padding:10px 8px;border-top:2px solid #e8b400;display:flex;flex-direction:column;align-items:center;gap:5px;}
    .qr-block-box{background:#fff;padding:5px;border-radius:2px;width:94px;height:94px;display:flex;align-items:center;justify-content:center;}
    .qr-block-label{font-family:'IBM Plex Mono',monospace;font-size:8px;letter-spacing:1px;color:#e8b400;text-align:center;text-transform:uppercase;max-width:100px;line-height:1.3;}
  </style>
</head>
