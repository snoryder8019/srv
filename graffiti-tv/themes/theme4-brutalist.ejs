<!DOCTYPE html>
<html lang="en">
<head>
  <title>GRAFFITI TV — BRUTALIST</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=IBM+Plex+Mono:wght@700&family=Barlow+Condensed:wght@900&display=swap" rel="stylesheet">
  <style>
    :root{--blk:#0a0a0a;--wht:#f0f0e8;--red:#ff2200;--yel:#ffe000;--border:3px solid var(--wht);}
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:var(--blk);color:var(--wht);height:100vh;overflow:hidden;font-family:'IBM Plex Mono',monospace;}
    .shell{
      display:grid;
      grid-template-rows:56px 1fr 46px 52px;
      grid-template-columns:1fr 250px;
      height:100vh;
      border:var(--border);
    }

    /* TOP */
    .top-bar{
      grid-column:1/-1;
      display:grid; grid-template-columns:auto 1fr auto;
      border-bottom:var(--border);
    }
    .top-label{
      font-family:'Anton',sans-serif; font-size:36px; letter-spacing:4px;
      padding:0 20px; display:flex; align-items:center;
      border-right:var(--border);
      color:var(--yel);
    }
    .top-ticker-area{overflow:hidden;display:flex;align-items:center;padding:0 16px;}
    .top-ticker-inner{display:flex;animation:tickerScroll 25s linear infinite;white-space:nowrap;}
    @keyframes tickerScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .t-item{padding:0 30px;font-size:14px;letter-spacing:2px;color:#888;}
    .t-item::before{content:'→ ';color:var(--red);}
    .top-right{
      border-left:var(--border);
      padding:0 16px; display:flex; align-items:center;
      font-size:11px; letter-spacing:2px; color:#555;
      flex-direction:column;justify-content:center;gap:2px;
    }
    .top-right .time{font-size:20px;color:var(--wht);}

    /* MAIN */
    .main{
      border-right:var(--border);
      position:relative;overflow:hidden;background:#000;
    }
    /* Bold corner marks */
    .main::before,.main::after{
      content:'';position:absolute;width:30px;height:30px;z-index:10;pointer-events:none;
    }
    .main::before{top:0;left:0;border-right:4px solid var(--yel);border-bottom:4px solid var(--yel);}
    .main::after{bottom:0;right:0;border-left:4px solid var(--yel);border-top:4px solid var(--yel);}
    #mediaContainer{width:100%;height:100%;position:relative;display:flex;align-items:center;justify-content:center;}
    #mediaContainer img,#mediaContainer video{width:100%;height:100%;object-fit:contain;position:absolute;top:0;left:0;filter:contrast(1.1);}
    .loading-msg{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;}
    .l-big{font-family:'Anton',sans-serif;font-size:48px;color:var(--wht);letter-spacing:6px;}
    .l-sub{font-size:12px;letter-spacing:4px;color:#444;animation:pulse 1s step-end infinite;}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}

    /* SIDEBAR */
    .sidebar{overflow:hidden;display:flex;flex-direction:column;}
    .s-header{
      font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:6px;
      padding:10px 12px;border-bottom:var(--border);color:var(--yel);
      background: repeating-linear-gradient(45deg,#111 0,#111 5px,#0a0a0a 5px,#0a0a0a 10px);
    }
    .sidebar-scroll{flex:1;overflow:hidden;}
    .sidebar-inner{animation:sideScroll 22s linear infinite;}
    @keyframes sideScroll{0%{transform:translateY(0)}100%{transform:translateY(-50%)}}
    .s-card{padding:14px 12px;border-bottom:1px solid #1a1a1a;display:grid;grid-template-columns:1fr auto;}
    .s-card-name{font-family:'Barlow Condensed',sans-serif;font-size:17px;letter-spacing:1px;grid-column:1/-1;margin-bottom:2px;}
    .s-card-desc{font-size:10px;color:#444;letter-spacing:1px;grid-column:1/-1;margin-bottom:6px;}
    .s-card-price{font-family:'Anton',sans-serif;font-size:20px;color:var(--yel);justify-self:end;}
    .s-card-tag{font-size:10px;letter-spacing:2px;color:var(--red);align-self:end;padding-bottom:2px;}

    /* MENU BAR */
    .menu-bar{
      grid-column:1/-1;border-top:var(--border);border-bottom:var(--border);
      display:flex;align-items:stretch;overflow:hidden;
    }
    .menu-label{
      font-family:'Anton',sans-serif;font-size:14px;letter-spacing:4px;
      padding:0 16px;border-right:var(--border);display:flex;align-items:center;
      color:var(--blk);background:var(--red);white-space:nowrap;flex-shrink:0;
    }
    .menu-track{display:flex;animation:tickerScroll 35s linear infinite;white-space:nowrap;align-items:center;}
    .m-item{padding:0 24px;font-size:13px;letter-spacing:2px;display:inline-flex;gap:10px;}
    .m-name{color:var(--wht);}
    .m-price{color:var(--yel);}

    /* BOTTOM */
    .bottom-bar{
      grid-column:1/-1;border-top:var(--border);
      display:grid;grid-template-columns:1fr 1fr 1fr;
    }
    .b-cell{
      padding:0 16px;display:flex;align-items:center;font-size:12px;letter-spacing:2px;color:#555;
    }
    .b-cell:not(:last-child){border-right:var(--border);}
    .b-cell.center{justify-content:center;color:var(--red);}
    .b-cell.right{justify-content:flex-end;}
    .b-cell strong{color:var(--wht);}
  
    .qr-block{padding:10px 8px;border-top:2px solid #ffe000;display:flex;flex-direction:column;align-items:center;gap:5px;}
    .qr-block-box{background:#fff;padding:5px;border-radius:2px;width:94px;height:94px;display:flex;align-items:center;justify-content:center;}
    .qr-block-label{font-family:'Share Tech Mono',monospace;font-size:8px;letter-spacing:1px;color:#ffe000;text-align:center;text-transform:uppercase;max-width:100px;line-height:1.3;}
  
    .qr-block{padding:10px 8px;border-top:2px solid #ffe000;display:flex;flex-direction:column;align-items:center;gap:5px;}
    .qr-block-box{background:#fff;padding:5px;border-radius:2px;width:94px;height:94px;display:flex;align-items:center;justify-content:center;}
    .qr-block-label{font-family:monospace;font-size:8px;letter-spacing:1px;color:#ffe000;text-align:center;text-transform:uppercase;max-width:100px;line-height:1.3;}
  </style>
</head>
