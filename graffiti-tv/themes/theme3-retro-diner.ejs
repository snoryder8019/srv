<!DOCTYPE html>
<html lang="en">
<head>
  <title>GRAFFITI TV — DINER</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Boogaloo&family=Pacifico&family=Special+Elite&family=Courier+Prime:wght@700&display=swap" rel="stylesheet">
  <style>
    :root{ --red:#e8001d; --cream:#fff8e7; --navy:#0a1628; --gold:#f5a623; --teal:#00b4a0; }
    *{margin:0;padding:0;box-sizing:border-box;}
    body{
      background:var(--navy);
      font-family:'Special Elite',monospace;
      height:100vh; overflow:hidden;
      background-image:
        radial-gradient(circle at 20px 20px, rgba(255,255,255,0.03) 1px, transparent 1px),
        radial-gradient(circle at 60px 60px, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size:80px 80px;
    }
    .shell{
      display:grid;
      grid-template-rows:70px 1fr 50px 55px;
      grid-template-columns:1fr 270px;
      height:100vh; gap:6px; padding:6px;
    }

    /* TOP */
    .top-bar{
      grid-column:1/-1;
      background:var(--red);
      display:flex; align-items:center; justify-content:space-between;
      padding:0 20px;
      border:4px solid var(--gold);
      box-shadow:0 0 0 2px var(--red), 4px 4px 0 var(--gold);
      position:relative; overflow:hidden;
    }
    .top-bar::before{
      content:'';position:absolute;bottom:0;left:0;right:0;height:4px;
      background:repeating-linear-gradient(90deg,var(--gold) 0,var(--gold) 10px,transparent 10px,transparent 20px);
    }
    .diner-logo{
      font-family:'Pacifico',cursive; font-size:32px;
      color:var(--cream);
      text-shadow:3px 3px 0 var(--navy), -1px -1px 0 var(--gold);
      letter-spacing:2px;
    }
    .diner-sub{
      font-family:'Boogaloo',sans-serif; font-size:18px;
      color:var(--gold); letter-spacing:3px;
      text-transform:uppercase;
    }
    .open-sign{
      background:var(--gold); color:var(--navy);
      font-family:'Boogaloo',sans-serif; font-size:24px;
      padding:6px 18px; border-radius:4px;
      border:3px solid var(--navy);
      animation:openBlink 2s step-end infinite;
      letter-spacing:3px;
    }
    @keyframes openBlink{0%,100%{opacity:1}50%{opacity:0.2}}

    /* MAIN */
    .main{
      background:#000;
      border:4px solid var(--gold);
      box-shadow:6px 6px 0 var(--red), inset 0 0 40px rgba(0,0,0,0.8);
      position:relative; overflow:hidden;
    }
    .main::before{
      content:'NOW SHOWING';
      position:absolute;top:12px;left:50%;transform:translateX(-50%);
      font-family:'Boogaloo',sans-serif;font-size:13px;letter-spacing:5px;
      color:var(--gold);opacity:0.4;z-index:10;pointer-events:none;
    }
    #mediaContainer{width:100%;height:100%;position:relative;display:flex;align-items:center;justify-content:center;}
    #mediaContainer img,#mediaContainer video{width:100%;height:100%;object-fit:contain;position:absolute;top:0;left:0;}
    .loading-msg{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;background:var(--navy);}
    .diner-loading{font-family:'Pacifico',cursive;font-size:28px;color:var(--red);text-shadow:2px 2px 0 var(--gold);}
    .loading-dots{font-family:'Courier Prime',monospace;font-size:32px;color:var(--gold);letter-spacing:8px;animation:dots 1s step-end infinite;}
    @keyframes dots{0%{content:'...'}33%{opacity:0.3}66%{opacity:0.7}100%{opacity:1}}

    /* SIDEBAR */
    .sidebar{
      background:var(--cream);
      border:4px solid var(--navy);
      box-shadow:4px 4px 0 var(--gold);
      overflow:hidden; display:flex; flex-direction:column;
    }
    .sidebar-header{
      background:var(--navy); color:var(--gold);
      font-family:'Pacifico',cursive; font-size:18px;
      text-align:center; padding:10px;
      border-bottom:3px solid var(--red);
      letter-spacing:1px;
    }
    .sidebar-scroll{flex:1;overflow:hidden;}
    .sidebar-inner{animation:sideScroll 25s linear infinite;}
    @keyframes sideScroll{0%{transform:translateY(0)}100%{transform:translateY(-50%)}}
    .s-card{padding:14px;border-bottom:2px dashed #ccc;color:var(--navy);}
    .s-card-name{font-family:'Boogaloo',sans-serif;font-size:18px;color:var(--red);margin-bottom:2px;}
    .s-card-desc{font-family:'Special Elite',serif;font-size:11px;color:#666;margin-bottom:6px;line-height:1.4;}
    .s-card-price{font-family:'Courier Prime',monospace;font-size:20px;font-weight:700;color:var(--navy);}
    .s-card-price::before{content:'$ ';}

    /* MENU TICKER */
    .ticker-bar{
      grid-column:1/-1;
      background:var(--teal);
      border:3px solid var(--navy);
      overflow:hidden;display:flex;align-items:center;
    }
    .ticker-label{font-family:'Boogaloo',sans-serif;font-size:18px;letter-spacing:2px;padding:0 16px;color:var(--navy);background:var(--gold);height:100%;display:flex;align-items:center;flex-shrink:0;}
    .ticker-track{display:flex;animation:tickerScroll 30s linear infinite;white-space:nowrap;}
    @keyframes tickerScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .t-item{padding:0 30px;font-family:'Boogaloo',sans-serif;font-size:19px;color:var(--cream);}
    .t-item::after{content:' ·';color:var(--gold);}

    /* BOTTOM */
    .bottom-bar{
      grid-column:1/-1;
      background:var(--navy);
      border:3px solid var(--gold);
      display:flex;align-items:center;justify-content:space-between;
      padding:0 20px;
    }
    .b-address{font-family:'Special Elite',serif;font-size:14px;color:var(--cream);letter-spacing:1px;}
    .b-hours{font-family:'Boogaloo',sans-serif;font-size:18px;color:var(--gold);}
    .b-time{font-family:'Courier Prime',monospace;font-size:22px;color:var(--teal);font-weight:700;}
  
    .qr-block{padding:10px 8px;border-top:3px solid #e8001d;display:flex;flex-direction:column;align-items:center;gap:5px;background:#0a0a0a;}
    .qr-block-box{background:#fff;padding:5px;border-radius:2px;width:94px;height:94px;display:flex;align-items:center;justify-content:center;}
    .qr-block-label{font-family:'Special Elite',serif;font-size:9px;letter-spacing:1px;color:#e8001d;text-align:center;text-transform:uppercase;max-width:100px;line-height:1.3;}
  </style>
</head>
<body>
<div class="shell">
  <div class="top-bar">
    <div>
      <div class="diner-logo">Graffiti Pasta</div>
      <div class="diner-sub">Denton, Texas</div>
    </div>
    <div class="open-sign">OPEN</div>
  </div>
  <div class="main">
    <div id="mediaContainer">
      <div class="loading-msg">
        <div class="diner-loading">Graffiti Pasta</div>
        <div class="loading-dots">. . .</div>
      </div>
    </div>
  </div>
  <div class="sidebar">
    <div class="sidebar-header">Today's Menu</div>
    <div class="sidebar-scroll"><div class="sidebar-inner">
      <div class="s-card"><div class="s-card-name">Truffle Pasta</div><div class="s-card-desc">Black truffle, parm, butter, herbs</div><div class="s-card-price">24.99</div></div>
      <div class="s-card"><div class="s-card-name">Graffiti Carbonara</div><div class="s-card-desc">Guanciale, egg yolk, pecorino</div><div class="s-card-price">19.99</div></div>
      <div class="s-card"><div class="s-card-name">Cacio e Pepe</div><div class="s-card-desc">Simple. Roman. Perfect.</div><div class="s-card-price">17.99</div></div>
      <div class="s-card"><div class="s-card-name">Arrabbiata</div><div class="s-card-desc">San Marzano, chili, garlic, basil</div><div class="s-card-price">16.99</div></div>
      <div class="s-card"><div class="s-card-name">Bolognese</div><div class="s-card-desc">Slow-braised beef & pork</div><div class="s-card-price">21.99</div></div>
      <div class="s-card"><div class="s-card-name">Negroni</div><div class="s-card-desc">Happy hour 4–7pm daily</div><div class="s-card-price">5.00</div></div>
      <div class="s-card"><div class="s-card-name">Aperol Spritz</div><div class="s-card-desc">Prosecco, Aperol, orange</div><div class="s-card-price">8.99</div></div>
      <!-- dupe -->
      <div class="s-card"><div class="s-card-name">Truffle Pasta</div><div class="s-card-desc">Black truffle, parm, butter, herbs</div><div class="s-card-price">24.99</div></div>
      <div class="s-card"><div class="s-card-name">Graffiti Carbonara</div><div class="s-card-desc">Guanciale, egg yolk, pecorino</div><div class="s-card-price">19.99</div></div>
      <div class="s-card"><div class="s-card-name">Cacio e Pepe</div><div class="s-card-desc">Simple. Roman. Perfect.</div><div class="s-card-price">17.99</div></div>
      <div class="s-card"><div class="s-card-name">Arrabbiata</div><div class="s-card-desc">San Marzano, chili, garlic, basil</div><div class="s-card-price">16.99</div></div>
      <div class="s-card"><div class="s-card-name">Bolognese</div><div class="s-card-desc">Slow-braised beef & pork</div><div class="s-card-price">21.99</div></div>
      <div class="s-card"><div class="s-card-name">Negroni</div><div class="s-card-desc">Happy hour 4–7pm daily</div><div class="s-card-price">5.00</div></div>
      <div class="s-card"><div class="s-card-name">Aperol Spritz</div><div class="s-card-desc">Prosecco, Aperol, orange</div><div class="s-card-price">8.99</div></div>
    </div></div>
    <div class="qr-block"><div class="qr-block-box"><div id="qr-code"></div></div><div class="qr-block-label" id="qr-label">Scan for offer</div></div>
  </div>
  <div class="ticker-bar">
    <div class="ticker-label">SPECIALS</div>
    <div class="ticker-track">
      <span class="t-item">Carbonara $19.99</span><span class="t-item">Truffle Pasta $24.99</span><span class="t-item">Cacio e Pepe $17.99</span><span class="t-item">Bolognese $21.99</span><span class="t-item">Happy Hour 4–7pm</span><span class="t-item">Live Music Fridays</span><span class="t-item">Wood-Fired Pizza $14.99</span><span class="t-item">Wine Pairings Available</span>
      <span class="t-item">Carbonara $19.99</span><span class="t-item">Truffle Pasta $24.99</span><span class="t-item">Cacio e Pepe $17.99</span><span class="t-item">Bolognese $21.99</span><span class="t-item">Happy Hour 4–7pm</span><span class="t-item">Live Music Fridays</span><span class="t-item">Wood-Fired Pizza $14.99</span><span class="t-item">Wine Pairings Available</span>
    </div>
  </div>
  <div class="bottom-bar">
    <div class="b-address">📍 DENTON, TEXAS</div>
    <div class="b-hours">HAPPY HOUR 4–7PM · LIVE MUSIC FRI</div>
    <div class="b-time" id="clock">--:--:--</div>
  </div>
</div>
<script>
  setInterval(()=>{ document.getElementById('clock').textContent=new Date().toLocaleTimeString('en-US',{hour12:false}); },1000);
  let mediaList=[],idx=0;
  async function loadMedia(){
    try{const r=await fetch('/api/linode/media');const d=await r.json();if(d.success&&d.media?.length){mediaList=d.media;playMedia();}else loadFallback();}catch(e){loadFallback();}
  }
  function loadFallback(){document.getElementById('mediaContainer').innerHTML=`<iframe src="https://www.youtube.com/embed/86YLFOog4GM?autoplay=1&mute=1&controls=0&loop=1&playlist=86YLFOog4GM" frameborder="0" allow="autoplay" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>`;}
  function playMedia(){const c=document.getElementById('mediaContainer');const m=mediaList[idx];c.innerHTML='';if(m.type==='video'){const v=document.createElement('video');v.src=m.url;v.autoplay=v.muted=true;v.addEventListener('ended',next);c.appendChild(v);}else{const i=document.createElement('img');i.src=m.url;i.addEventListener('error',next);c.appendChild(i);setTimeout(next,15000);}}
  function next(){idx=(idx+1)%mediaList.length;playMedia();}
  document.addEventListener('DOMContentLoaded',loadMedia);
</script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
(async()=>{
  try{
    const slug=window.location.pathname.split('/')[2];
    const d=await fetch('/api/'+slug+'/offering').then(r=>r.json());
    if(!d.url)return;
    const lbl=document.getElementById('qr-label');if(lbl)lbl.textContent=d.title||'Scan for offer';
    const box=document.getElementById('qr-code');if(box)new QRCode(box,{text:d.url,width:84,height:84,colorDark:'#000',colorLight:'#fff',correctLevel:QRCode.CorrectLevel.M});
  }catch(e){}
})();
</script>
</body></html>
