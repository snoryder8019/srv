<!DOCTYPE html>
<html lang="en">
<head>
  <title>GRAFFITI TV — RAVE MODE</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Audiowide&family=Orbitron:wght@900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <style>
    :root {
      --c1: #ff00ff; --c2: #00ffff; --c3: #ff006e;
      --c4: #7fff00; --bg: #080010;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    body {
      background: var(--bg);
      font-family: 'Audiowide', sans-serif;
      height: 100vh; overflow: hidden;
      animation: bgRave 2s linear infinite;
    }
    @keyframes bgRave {
      0%   { background-color: #080010; }
      16%  { background-color: #100008; }
      33%  { background-color: #001008; }
      50%  { background-color: #080010; }
      66%  { background-color: #100800; }
      83%  { background-color: #001010; }
      100% { background-color: #080010; }
    }

    /* Laser grid floor */
    body::before {
      content:'';
      position:fixed; bottom:0; left:0; right:0;
      height:40%;
      background:
        linear-gradient(rgba(255,0,255,0.15) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,0,255,0.15) 1px, transparent 1px);
      background-size: 40px 40px;
      transform: perspective(400px) rotateX(60deg);
      transform-origin: bottom;
      pointer-events:none;
      z-index:0;
      animation: gridPulse 1s ease-in-out infinite;
    }
    @keyframes gridPulse {
      0%,100% { opacity:0.6; }
      50% { opacity:1; }
    }

    .shell {
      display:grid;
      grid-template-rows: 60px 1fr 50px 50px;
      grid-template-columns: 1fr 240px;
      height:100vh; gap:3px; padding:3px;
      position:relative; z-index:1;
    }

    /* TOP */
    .top-bar {
      grid-column:1/-1;
      display:flex; align-items:center; justify-content:space-between;
      padding:0 20px;
      border:2px solid var(--c1);
      box-shadow: 0 0 30px var(--c1), inset 0 0 30px rgba(255,0,255,0.1);
      animation: borderCycle 4s linear infinite;
    }
    @keyframes borderCycle {
      0%,100% { border-color:var(--c1); box-shadow:0 0 30px var(--c1), inset 0 0 20px rgba(255,0,255,0.1); }
      33% { border-color:var(--c2); box-shadow:0 0 30px var(--c2), inset 0 0 20px rgba(0,255,255,0.1); }
      66% { border-color:var(--c4); box-shadow:0 0 30px var(--c4), inset 0 0 20px rgba(127,255,0,0.1); }
    }
    .top-logo {
      font-family:'Orbitron',sans-serif; font-weight:900;
      font-size:28px; letter-spacing:8px;
      background: linear-gradient(90deg,var(--c1),var(--c2),var(--c4),var(--c1));
      background-size:300% 100%;
      -webkit-background-clip:text; -webkit-text-fill-color:transparent;
      background-clip:text;
      animation: logoShift 3s linear infinite;
    }
    @keyframes logoShift { from{background-position:0%} to{background-position:300%} }
    .bpm-counter {
      font-family:'Share Tech Mono',monospace; font-size:14px;
      color:var(--c4); letter-spacing:2px;
    }
    .bpm-counter span { font-size:32px; animation: bpmFlash 0.5s step-end infinite; }
    @keyframes bpmFlash { 0%,100%{opacity:1} 50%{opacity:0.3} }

    /* MAIN */
    .main {
      background:#000; border:2px solid #222; position:relative; overflow:hidden;
    }
    /* Strobing border */
    .main::after {
      content:''; position:absolute; inset:0;
      border:4px solid transparent;
      animation: strobeBorder 0.25s step-end infinite;
      pointer-events:none; z-index:10;
    }
    @keyframes strobeBorder {
      0%   { border-color: rgba(255,0,255,0.8); }
      25%  { border-color: rgba(0,255,255,0.8); }
      50%  { border-color: rgba(255,0,110,0.8); }
      75%  { border-color: rgba(127,255,0,0.8); }
      100% { border-color: rgba(255,0,255,0.8); }
    }
    #mediaContainer { width:100%; height:100%; position:relative; display:flex; align-items:center; justify-content:center; }
    #mediaContainer img, #mediaContainer video { width:100%; height:100%; object-fit:contain; position:absolute; top:0; left:0; filter:saturate(2) contrast(1.1); }
    .loading-msg { position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:20px; }
    .rave-spinner {
      width:60px; height:60px;
      border:4px solid transparent;
      border-top-color:var(--c1); border-right-color:var(--c2);
      border-radius:50%;
      animation: spin 0.5s linear infinite;
    }
    @keyframes spin { to { transform:rotate(360deg); } }
    .loading-text { font-family:'Orbitron',sans-serif; font-size:16px; color:var(--c1); letter-spacing:4px; animation:borderCycle 1s linear infinite; }

    /* SIDEBAR */
    .sidebar {
      background:#000; border:2px solid #1a1a1a; overflow:hidden;
      display:flex; flex-direction:column;
    }
    .sidebar-header {
      font-family:'Orbitron',sans-serif; font-size:13px; letter-spacing:4px;
      text-align:center; padding:8px;
      background: linear-gradient(90deg,var(--c1),var(--c3));
      color:#000;
    }
    .sidebar-scroll { flex:1; overflow:hidden; }
    .sidebar-inner { animation: sideScroll 20s linear infinite; }
    @keyframes sideScroll { 0%{transform:translateY(0)} 100%{transform:translateY(-50%)} }
    .s-card {
      padding:12px; border-bottom:1px solid #111; position:relative;
    }
    .s-card-name { font-family:'Orbitron',sans-serif; font-size:13px; color:#fff; margin-bottom:3px; }
    .s-card-sub { font-family:'Share Tech Mono',monospace; font-size:10px; color:#444; margin-bottom:6px; }
    .s-card-price { font-family:'Orbitron',sans-serif; font-size:18px; animation:borderCycle 4s linear infinite; -webkit-background-clip:text; color:var(--c1); }
    .s-card::before { content:''; position:absolute; left:0;top:0;bottom:0;width:2px; animation:borderCycle 4s linear infinite; background:var(--c1); }

    /* TICKER */
    .ticker-bar {
      grid-column:1/-1; background:#000; border-top:2px solid var(--c2);
      overflow:hidden; display:flex; align-items:center;
    }
    .ticker-label { font-family:'Orbitron',sans-serif; font-size:14px; letter-spacing:3px; padding:0 14px; color:#000; background:var(--c2); height:100%; display:flex; align-items:center; white-space:nowrap; flex-shrink:0; }
    .ticker-track { display:flex; animation:tickerScroll 30s linear infinite; white-space:nowrap; }
    @keyframes tickerScroll { from{transform:translateX(0)} to{transform:translateX(-50%)} }
    .t-item { padding:0 40px; font-family:'Share Tech Mono',monospace; font-size:15px; color:var(--c2); }
    .t-item::before { content:'// '; color:var(--c1); }

    /* BOTTOM */
    .bottom-bar {
      grid-column:1/-1; display:flex; align-items:center; justify-content:space-between;
      padding:0 20px; border-top:1px solid #111;
    }
    .eq-bars { display:flex; gap:3px; align-items:flex-end; height:30px; }
    .eq-bars div { width:5px; background:var(--c4); animation:eqBounce 0.4s ease-in-out infinite; }
    .eq-bars div:nth-child(1){height:8px;animation-delay:0s}
    .eq-bars div:nth-child(2){height:20px;animation-delay:0.05s}
    .eq-bars div:nth-child(3){height:14px;animation-delay:0.1s}
    .eq-bars div:nth-child(4){height:28px;animation-delay:0.15s}
    .eq-bars div:nth-child(5){height:10px;animation-delay:0.2s}
    .eq-bars div:nth-child(6){height:24px;animation-delay:0.25s}
    .eq-bars div:nth-child(7){height:18px;animation-delay:0.3s}
    .eq-bars div:nth-child(8){height:6px;animation-delay:0.35s}
    .eq-bars div:nth-child(9){height:22px;animation-delay:0.4s}
    @keyframes eqBounce {
      0%,100%{transform:scaleY(0.3);opacity:0.5}
      50%{transform:scaleY(1);opacity:1}
    }
    .b-title { font-family:'Orbitron',sans-serif; font-size:11px; letter-spacing:5px; color:#333; }
    .b-time { font-family:'Share Tech Mono',monospace; font-size:20px; color:var(--c1); text-shadow:0 0 10px var(--c1); }
  
    .qr-block{padding:10px 8px;border-top:2px solid rgba(255,0,255,0.3);display:flex;flex-direction:column;align-items:center;gap:5px;}
    .qr-block-box{background:#fff;padding:5px;border-radius:3px;width:94px;height:94px;display:flex;align-items:center;justify-content:center;}
    .qr-block-label{font-family:'Share Tech Mono',monospace;font-size:8px;letter-spacing:1.5px;color:rgba(255,0,255,0.8);text-align:center;text-transform:uppercase;max-width:100px;line-height:1.3;}
  </style>
</head>
<body>
<div class="shell">
  <div class="top-bar">
    <div class="top-logo">GRAFFITI TV</div>
    <div class="bpm-counter">BPM <span>128</span></div>
  </div>
  <div class="main">
    <div id="mediaContainer">
      <div class="loading-msg"><div class="rave-spinner"></div><div class="loading-text">LOADING...</div></div>
    </div>
  </div>
  <div class="sidebar">
    <div class="sidebar-header">// SPECIALS //</div>
    <div class="sidebar-scroll"><div class="sidebar-inner" id="sidebarInner">
      <div class="s-card"><div class="s-card-name">Truffle Pasta</div><div class="s-card-sub">Black truffle · parm · butter</div><div class="s-card-price">$24.99</div></div>
      <div class="s-card"><div class="s-card-name">Carbonara</div><div class="s-card-sub">Guanciale · pecorino · egg</div><div class="s-card-price">$19.99</div></div>
      <div class="s-card"><div class="s-card-name">Cacio e Pepe</div><div class="s-card-sub">Simple. Roman. Perfect.</div><div class="s-card-price">$17.99</div></div>
      <div class="s-card"><div class="s-card-name">Arrabbiata</div><div class="s-card-sub">San Marzano · chili · garlic</div><div class="s-card-price">$16.99</div></div>
      <div class="s-card"><div class="s-card-name">Bolognese</div><div class="s-card-sub">Slow-braised beef & pork</div><div class="s-card-price">$21.99</div></div>
      <div class="s-card"><div class="s-card-name">Negroni</div><div class="s-card-sub">Happy hour 4–7pm daily</div><div class="s-card-price">$5.00</div></div>
      <div class="s-card"><div class="s-card-name">Aperol Spritz</div><div class="s-card-sub">Prosecco · orange · soda</div><div class="s-card-price">$8.99</div></div>
      <!-- dupe -->
      <div class="s-card"><div class="s-card-name">Truffle Pasta</div><div class="s-card-sub">Black truffle · parm · butter</div><div class="s-card-price">$24.99</div></div>
      <div class="s-card"><div class="s-card-name">Carbonara</div><div class="s-card-sub">Guanciale · pecorino · egg</div><div class="s-card-price">$19.99</div></div>
      <div class="s-card"><div class="s-card-name">Cacio e Pepe</div><div class="s-card-sub">Simple. Roman. Perfect.</div><div class="s-card-price">$17.99</div></div>
      <div class="s-card"><div class="s-card-name">Arrabbiata</div><div class="s-card-sub">San Marzano · chili · garlic</div><div class="s-card-price">$16.99</div></div>
      <div class="s-card"><div class="s-card-name">Bolognese</div><div class="s-card-sub">Slow-braised beef & pork</div><div class="s-card-price">$21.99</div></div>
      <div class="s-card"><div class="s-card-name">Negroni</div><div class="s-card-sub">Happy hour 4–7pm daily</div><div class="s-card-price">$5.00</div></div>
      <div class="s-card"><div class="s-card-name">Aperol Spritz</div><div class="s-card-sub">Prosecco · orange · soda</div><div class="s-card-price">$8.99</div></div>
    </div></div>
    <div class="qr-block"><div class="qr-block-box"><div id="qr-code"></div></div><div class="qr-block-label" id="qr-label">Scan for offer</div></div>
  </div>
  <div class="ticker-bar">
    <div class="ticker-label">MENU</div>
    <div class="ticker-track">
      <span class="t-item">CARBONARA $19.99</span><span class="t-item">TRUFFLE PASTA $24.99</span><span class="t-item">CACIO E PEPE $17.99</span><span class="t-item">BOLOGNESE $21.99</span><span class="t-item">ARRABBIATA $16.99</span><span class="t-item">NEGRONI $5 HAPPY HOUR</span><span class="t-item">WOOD FIRED PIZZA $14.99</span>
      <span class="t-item">CARBONARA $19.99</span><span class="t-item">TRUFFLE PASTA $24.99</span><span class="t-item">CACIO E PEPE $17.99</span><span class="t-item">BOLOGNESE $21.99</span><span class="t-item">ARRABBIATA $16.99</span><span class="t-item">NEGRONI $5 HAPPY HOUR</span><span class="t-item">WOOD FIRED PIZZA $14.99</span>
    </div>
  </div>
  <div class="bottom-bar">
    <div class="eq-bars"><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div></div>
    <div class="b-title">GRAFFITI PASTA · DENTON TX</div>
    <div class="b-time" id="clock">--:--:--</div>
  </div>
</div>
<script>
  setInterval(()=>{ document.getElementById('clock').textContent = new Date().toLocaleTimeString('en-US',{hour12:false}); },1000);
  let mediaList=[],idx=0;
  async function loadMedia(){
    try{
      const r=await fetch('/api/linode/media'); const d=await r.json();
      if(d.success&&d.media?.length){ mediaList=d.media; playMedia(); } else loadFallback();
    }catch(e){loadFallback();}
  }
  function loadFallback(){
    document.getElementById('mediaContainer').innerHTML=`<iframe src="https://www.youtube.com/embed/86YLFOog4GM?autoplay=1&mute=1&controls=0&loop=1&playlist=86YLFOog4GM" frameborder="0" allow="autoplay" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>`;
  }
  function playMedia(){
    const c=document.getElementById('mediaContainer'); const m=mediaList[idx]; c.innerHTML='';
    if(m.type==='video'){const v=document.createElement('video');v.src=m.url;v.autoplay=v.muted=true;v.addEventListener('ended',next);c.appendChild(v);}
    else{const i=document.createElement('img');i.src=m.url;i.addEventListener('error',next);c.appendChild(i);setTimeout(next,15000);}
  }
  function next(){idx=(idx+1)%mediaList.length;playMedia();}
  document.addEventListener('DOMContentLoaded',loadMedia);
  // BPM animation
  let bpm=128;
  setInterval(()=>{bpm=120+Math.floor(Math.random()*20);document.querySelector('.bpm-counter span').textContent=bpm;},2000);
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
(async()=>{
  try{
    const slug=window.location.pathname.split('/')[2];
    const d=await fetch('/api/'+slug+'/offering').then(r=>r.json());
    if(!d.url)return;
    const lbl=document.getElementById('qr-label');if(lbl)lbl.textContent=d.title||'Scan for offer';
    const box=document.getElementById('qr-code');if(box)new QRCode(box,{text:d.url,width:84,height:84,colorDark:'#000',colorLight:'#fff',correctLevel:QRCode.CorrectLevel.M});
  }catch(e){}
})();
</script>
</body></html>
