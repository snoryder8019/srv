<!DOCTYPE html>
<html lang="en">
<head>
  <title>GRAFFITI TV — VAPORWAVE</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Syncopate:wght@700&family=Rajdhani:wght@600&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <style>
    :root{
      --p1:#ff71ce;--p2:#01cdfe;--p3:#05ffa1;--p4:#b967ff;--p5:#fffb96;
      --bg:#0d0015;
    }
    *{margin:0;padding:0;box-sizing:border-box;}
    body{
      background:var(--bg);
      font-family:'Rajdhani',sans-serif;
      height:100vh;overflow:hidden;
      position:relative;
    }
    /* Grid floor */
    body::after{
      content:'';position:fixed;bottom:0;left:0;right:0;height:35%;
      background:
        linear-gradient(rgba(255,113,206,0.2) 1px,transparent 1px),
        linear-gradient(90deg,rgba(1,205,254,0.2) 1px,transparent 1px);
      background-size:50px 30px;
      transform:perspective(500px) rotateX(55deg);
      transform-origin:bottom;
      pointer-events:none;z-index:0;
    }
    /* Gradient sky */
    body::before{
      content:'';position:fixed;top:0;left:0;right:0;height:50%;
      background:linear-gradient(180deg,#0d0015 0%,#1a0030 40%,#2d0060 70%,#150020 100%);
      pointer-events:none;z-index:0;
    }

    .shell{
      display:grid;
      grid-template-rows:65px 1fr 48px 52px;
      grid-template-columns:1fr 255px;
      height:100vh;gap:4px;padding:4px;
      position:relative;z-index:1;
    }

    /* TOP */
    .top-bar{
      grid-column:1/-1;
      background:rgba(13,0,21,0.8);
      border:1px solid var(--p4);
      box-shadow:0 0 30px var(--p4), inset 0 0 30px rgba(185,103,255,0.1);
      display:flex;align-items:center;justify-content:space-between;
      padding:0 24px;
      backdrop-filter:blur(10px);
    }
    .vw-logo{
      font-family:'Syncopate',sans-serif;font-size:24px;letter-spacing:6px;
      background:linear-gradient(90deg,var(--p1),var(--p2),var(--p3));
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
      filter:drop-shadow(0 0 10px var(--p1));
    }
    .vw-sub{font-size:12px;letter-spacing:6px;color:var(--p4);text-transform:uppercase;}
    .vw-date{font-family:'Share Tech Mono',monospace;font-size:13px;color:var(--p2);letter-spacing:2px;text-align:right;}

    /* MAIN */
    .main{
      background:rgba(0,0,0,0.6);
      border:1px solid var(--p2);
      box-shadow:0 0 40px rgba(1,205,254,0.2), inset 0 0 40px rgba(0,0,0,0.8);
      position:relative;overflow:hidden;
      backdrop-filter:blur(4px);
    }
    /* Scanlines */
    .main::before{
      content:'';position:absolute;inset:0;
      background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.15) 3px,rgba(0,0,0,0.15) 4px);
      pointer-events:none;z-index:5;
    }
    /* Corner decorations */
    .corner{position:absolute;width:20px;height:20px;z-index:10;pointer-events:none;}
    .corner.tl{top:8px;left:8px;border-top:2px solid var(--p1);border-left:2px solid var(--p1);}
    .corner.tr{top:8px;right:8px;border-top:2px solid var(--p1);border-right:2px solid var(--p1);}
    .corner.bl{bottom:8px;left:8px;border-bottom:2px solid var(--p3);border-left:2px solid var(--p3);}
    .corner.br{bottom:8px;right:8px;border-bottom:2px solid var(--p3);border-right:2px solid var(--p3);}

    #mediaContainer{width:100%;height:100%;position:relative;display:flex;align-items:center;justify-content:center;}
    #mediaContainer img,#mediaContainer video{width:100%;height:100%;object-fit:contain;position:absolute;top:0;left:0;filter:saturate(1.4) hue-rotate(10deg);}
    .loading-msg{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;}
    .vw-loading{font-family:'Syncopate',sans-serif;font-size:20px;letter-spacing:8px;
      background:linear-gradient(90deg,var(--p1),var(--p2),var(--p3),var(--p1));
      background-size:300%;animation:logoShift 3s linear infinite;
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
    @keyframes logoShift{from{background-position:0%}to{background-position:300%}}
    .vw-loading-sub{font-family:'Share Tech Mono',monospace;font-size:13px;color:var(--p4);letter-spacing:4px;animation:blinkAnim 1s step-end infinite;}
    @keyframes blinkAnim{0%,100%{opacity:1}50%{opacity:0}}

    /* SIDEBAR */
    .sidebar{
      background:rgba(13,0,21,0.7);
      border:1px solid var(--p4);
      box-shadow:inset 0 0 20px rgba(185,103,255,0.1);
      overflow:hidden;display:flex;flex-direction:column;
      backdrop-filter:blur(8px);
    }
    .s-header{
      font-family:'Syncopate',sans-serif;font-size:11px;letter-spacing:5px;
      padding:10px;text-align:center;
      background:linear-gradient(90deg,var(--p4),var(--p1));
      color:#000;
    }
    .sidebar-scroll{flex:1;overflow:hidden;}
    .sidebar-inner{animation:sideScroll 22s linear infinite;}
    @keyframes sideScroll{0%{transform:translateY(0)}100%{transform:translateY(-50%)}}
    .s-card{padding:12px;border-bottom:1px solid rgba(185,103,255,0.15);}
    .s-card-name{font-family:'Syncopate',sans-serif;font-size:11px;color:var(--p5);margin-bottom:3px;letter-spacing:2px;}
    .s-card-desc{font-size:11px;color:rgba(255,255,255,0.3);margin-bottom:5px;font-family:'Share Tech Mono',monospace;}
    .s-card-price{font-family:'Share Tech Mono',monospace;font-size:18px;color:var(--p3);text-shadow:0 0 8px var(--p3);}

    /* TICKER */
    .ticker-bar{
      grid-column:1/-1;
      background:rgba(13,0,21,0.8);border:1px solid var(--p1);
      box-shadow:0 0 15px rgba(255,113,206,0.2);
      overflow:hidden;display:flex;align-items:center;
      backdrop-filter:blur(4px);
    }
    .ticker-label{font-family:'Syncopate',sans-serif;font-size:11px;letter-spacing:3px;padding:0 14px;color:#000;background:var(--p1);height:100%;display:flex;align-items:center;white-space:nowrap;flex-shrink:0;}
    .ticker-track{display:flex;animation:tickerScroll 32s linear infinite;white-space:nowrap;}
    @keyframes tickerScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .t-item{padding:0 30px;font-size:14px;color:var(--p2);font-family:'Share Tech Mono',monospace;letter-spacing:1px;}
    .t-item::before{content:'♦ ';color:var(--p1);}

    /* BOTTOM */
    .bottom-bar{
      grid-column:1/-1;
      background:rgba(13,0,21,0.9);
      border:1px solid rgba(185,103,255,0.3);
      display:flex;align-items:center;justify-content:space-between;padding:0 20px;
    }
    .b-left{font-size:11px;letter-spacing:4px;color:rgba(255,255,255,0.2);}
    .b-center{
      font-family:'Syncopate',sans-serif;font-size:16px;letter-spacing:6px;
      background:linear-gradient(90deg,var(--p1),var(--p2),var(--p3));
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
    }
    .b-right{font-family:'Share Tech Mono',monospace;font-size:20px;color:var(--p1);text-shadow:0 0 10px var(--p1);}
  
    .qr-block{padding:10px 8px;border-top:2px solid #b967ff;display:flex;flex-direction:column;align-items:center;gap:5px;}
    .qr-block-box{background:#fff;padding:5px;border-radius:2px;width:94px;height:94px;display:flex;align-items:center;justify-content:center;}
    .qr-block-label{font-family:'Orbitron',sans-serif;font-size:8px;letter-spacing:1px;color:#b967ff;text-align:center;text-transform:uppercase;max-width:100px;line-height:1.3;}
  </style>
</head>
<body>
<div class="shell">
  <div class="top-bar">
    <div><div class="vw-logo">GRAFFITI TV</div><div class="vw-sub">Denton · Texas</div></div>
    <div class="vw-date" id="dateTime">--/--/-- --:--:--</div>
  </div>
  <div class="main">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
    <div id="mediaContainer">
      <div class="loading-msg">
        <div class="vw-loading">GRAFFITI TV</div>
        <div class="vw-loading-sub">INITIALIZING...</div>
      </div>
    </div>
  </div>
  <div class="sidebar">
    <div class="s-header">MENU</div>
    <div class="sidebar-scroll"><div class="sidebar-inner">
      <div class="s-card"><div class="s-card-name">TRUFFLE PASTA</div><div class="s-card-desc">truffle · parm · butter</div><div class="s-card-price">$24.99</div></div>
      <div class="s-card"><div class="s-card-name">CARBONARA</div><div class="s-card-desc">guanciale · egg · pecorino</div><div class="s-card-price">$19.99</div></div>
      <div class="s-card"><div class="s-card-name">CACIO E PEPE</div><div class="s-card-desc">simple · roman · perfect</div><div class="s-card-price">$17.99</div></div>
      <div class="s-card"><div class="s-card-name">ARRABBIATA</div><div class="s-card-desc">san marzano · chili · garlic</div><div class="s-card-price">$16.99</div></div>
      <div class="s-card"><div class="s-card-name">BOLOGNESE</div><div class="s-card-desc">beef & pork · slow braised</div><div class="s-card-price">$21.99</div></div>
      <div class="s-card"><div class="s-card-name">NEGRONI</div><div class="s-card-desc">happy hour 4–7pm</div><div class="s-card-price">$5.00</div></div>
      <div class="s-card"><div class="s-card-name">APEROL SPRITZ</div><div class="s-card-desc">prosecco · aperol · orange</div><div class="s-card-price">$8.99</div></div>
      <!-- dupe -->
      <div class="s-card"><div class="s-card-name">TRUFFLE PASTA</div><div class="s-card-desc">truffle · parm · butter</div><div class="s-card-price">$24.99</div></div>
      <div class="s-card"><div class="s-card-name">CARBONARA</div><div class="s-card-desc">guanciale · egg · pecorino</div><div class="s-card-price">$19.99</div></div>
      <div class="s-card"><div class="s-card-name">CACIO E PEPE</div><div class="s-card-desc">simple · roman · perfect</div><div class="s-card-price">$17.99</div></div>
      <div class="s-card"><div class="s-card-name">ARRABBIATA</div><div class="s-card-desc">san marzano · chili · garlic</div><div class="s-card-price">$16.99</div></div>
      <div class="s-card"><div class="s-card-name">BOLOGNESE</div><div class="s-card-desc">beef & pork · slow braised</div><div class="s-card-price">$21.99</div></div>
      <div class="s-card"><div class="s-card-name">NEGRONI</div><div class="s-card-desc">happy hour 4–7pm</div><div class="s-card-price">$5.00</div></div>
      <div class="s-card"><div class="s-card-name">APEROL SPRITZ</div><div class="s-card-desc">prosecco · aperol · orange</div><div class="s-card-price">$8.99</div></div>
    </div></div>
    <div class="qr-block"><div class="qr-block-box"><div id="qr-code"></div></div><div class="qr-block-label" id="qr-label">Scan for offer</div></div>
  </div>
  <div class="ticker-bar">
    <div class="ticker-label">SPECIALS</div>
    <div class="ticker-track">
      <span class="t-item">GRAFFITI PASTA DENTON TX</span><span class="t-item">HANDMADE PASTA DAILY</span><span class="t-item">CARBONARA $19.99</span><span class="t-item">TRUFFLE PASTA $24.99</span><span class="t-item">LIVE MUSIC FRIDAYS</span><span class="t-item">HAPPY HOUR 4–7PM</span><span class="t-item">NEGRONI $5</span>
      <span class="t-item">GRAFFITI PASTA DENTON TX</span><span class="t-item">HANDMADE PASTA DAILY</span><span class="t-item">CARBONARA $19.99</span><span class="t-item">TRUFFLE PASTA $24.99</span><span class="t-item">LIVE MUSIC FRIDAYS</span><span class="t-item">HAPPY HOUR 4–7PM</span><span class="t-item">NEGRONI $5</span>
    </div>
  </div>
  <div class="bottom-bar">
    <div class="b-left">SIGNAL LIVE</div>
    <div class="b-center">GRAFFITI TV</div>
    <div class="b-right" id="clock">--:--:--</div>
  </div>
</div>
<script>
  function tick(){
    const now=new Date();
    document.getElementById('clock').textContent=now.toLocaleTimeString('en-US',{hour12:false});
    document.getElementById('dateTime').textContent=now.toLocaleDateString('en-US')+' '+now.toLocaleTimeString('en-US',{hour12:false});
  }
  setInterval(tick,1000);tick();
  let mediaList=[],idx=0;
  async function loadMedia(){try{const r=await fetch('/api/linode/media');const d=await r.json();if(d.success&&d.media?.length){mediaList=d.media;playMedia();}else loadFallback();}catch(e){loadFallback();}}
  function loadFallback(){document.getElementById('mediaContainer').innerHTML=`<iframe src="https://www.youtube.com/embed/86YLFOog4GM?autoplay=1&mute=1&controls=0&loop=1&playlist=86YLFOog4GM" frameborder="0" allow="autoplay" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>`;}
  function playMedia(){const c=document.getElementById('mediaContainer');const m=mediaList[idx];c.innerHTML='';if(m.type==='video'){const v=document.createElement('video');v.src=m.url;v.autoplay=v.muted=true;v.addEventListener('ended',next);c.appendChild(v);}else{const i=document.createElement('img');i.src=m.url;i.addEventListener('error',next);c.appendChild(i);setTimeout(next,15000);}}
  function next(){idx=(idx+1)%mediaList.length;playMedia();}
  document.addEventListener('DOMContentLoaded',loadMedia);
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
(async()=>{
  try{
    const slug=window.location.pathname.split('/')[2];
    const d=await fetch('/api/'+slug+'/offering').then(r=>r.json());
    if(!d.url)return;
    const lbl=document.getElementById('qr-label');if(lbl)lbl.textContent=d.title||'Scan for offer';
    const box=document.getElementById('qr-code');if(box)new QRCode(box,{text:d.url,width:84,height:84,colorDark:'#000',colorLight:'#fff',correctLevel:QRCode.CorrectLevel.M});
  }catch(e){}
})();
</script>
</body></html>
