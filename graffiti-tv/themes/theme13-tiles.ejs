<!DOCTYPE html>
<html lang="en">
<head>
  <title>GRAFFITI TV — TILES</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@900&family=DM+Sans:wght@700&family=DM+Mono&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:#111;height:100vh;overflow:hidden;font-family:'DM Sans',sans-serif;}

    /* 3x3 mosaic — media gets 2x2, rest are tiles */
    .mosaic{
      display:grid;
      grid-template-columns:1fr 1fr 1fr;
      grid-template-rows:1fr 1fr 1fr;
      height:100vh;
      gap:4px;padding:4px;
    }

    /* Media takes top-left 2x2 */
    .tile-media{
      grid-column:1/3;grid-row:1/3;
      background:#000;position:relative;overflow:hidden;
    }
    #mediaContainer{width:100%;height:100%;position:relative;}
    #mediaContainer img,#mediaContainer video{width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0;}
    .loading-msg{position:absolute;inset:0;background:#111;display:flex;align-items:center;justify-content:center;}
    .loading-msg span{font-family:'Unbounded',sans-serif;font-size:2rem;color:rgba(255,255,255,0.1);}
    .media-label{
      position:absolute;bottom:0;left:0;right:0;z-index:5;
      padding:16px 20px;
      background:linear-gradient(transparent,rgba(0,0,0,0.85));
    }
    .ml-big{font-family:'Unbounded',sans-serif;font-size:clamp(1.5rem,3vw,3rem);color:#fff;line-height:1;letter-spacing:-1px;}
    .ml-sub{font-family:'DM Mono',monospace;font-size:11px;color:rgba(255,255,255,0.4);letter-spacing:3px;margin-top:6px;}

    /* Individual tiles */
    .tile{
      display:flex;flex-direction:column;align-items:center;justify-content:center;
      padding:16px;text-align:center;position:relative;overflow:hidden;
      gap:6px;
    }
    .tile-big{font-family:'Unbounded',sans-serif;font-size:clamp(1.5rem,3vw,3.5rem);line-height:1;color:#fff;}
    .tile-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:3px;color:rgba(255,255,255,0.5);}
    .tile-sub{font-size:12px;color:rgba(255,255,255,0.35);font-family:'DM Mono',monospace;}

    /* Color-coded tiles */
    .t-orange{background:#ff4500;}
    .t-teal{background:#00897b;}
    .t-purple{background:#6a1b9a;}
    .t-navy{background:#1565c0;}
    .t-dark{background:#1a1a1a;border:1px solid #222;}
    .t-gold{background:#f57f17;}
    .t-wine{background:#880e4f;}

    /* Scrolling menu tile */
    .tile-menu{background:#1a1a1a;border:1px solid #222;padding:12px;overflow:hidden;justify-content:flex-start;align-items:stretch;}
    .tm-header{font-family:'Unbounded',sans-serif;font-size:11px;letter-spacing:3px;color:rgba(255,255,255,0.3);margin-bottom:10px;}
    .tm-scroll-wrap{flex:1;overflow:hidden;}
    .tm-scroll{animation:scrollUp 18s linear infinite;}
    @keyframes scrollUp{0%{transform:translateY(0)}100%{transform:translateY(-50%)}}
    .tm-row{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid #222;font-size:13px;}
    .tm-name{color:#ccc;}
    .tm-price{font-family:'DM Mono',monospace;color:#ff4500;}

    /* Bottom ticker spans full width */
    .tile-ticker{
      grid-column:1/-1;
      background:#000;border-top:2px solid #222;
      overflow:hidden;display:flex;align-items:center;
      padding:0;
    }
    .tt-label{font-family:'Unbounded',sans-serif;font-size:12px;letter-spacing:3px;padding:0 16px;color:#000;background:#ff4500;height:100%;display:flex;align-items:center;flex-shrink:0;white-space:nowrap;}
    .tt-track{display:flex;animation:tickerScroll 28s linear infinite;white-space:nowrap;}
    @keyframes tickerScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .tt-item{padding:0 30px;font-family:'DM Mono',monospace;font-size:13px;color:rgba(255,255,255,0.4);}
    .tt-item strong{color:#fff;}
  
    .tile-qr{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;padding:10px;background:#1a0a2e;}
    .qr-block-box{background:#fff;padding:5px;border-radius:3px;width:84px;height:84px;display:flex;align-items:center;justify-content:center;}
    .tile-qr-label{font-family:'Unbounded',sans-serif;font-size:7px;letter-spacing:1.5px;color:rgba(255,69,0,0.9);text-align:center;text-transform:uppercase;max-width:90px;line-height:1.3;}
  </style>
</head>
<body>
<div class="mosaic">
  <!-- 2x2 media -->
  <div class="tile-media">
    <div id="mediaContainer"><div class="loading-msg"><span>GFTV</span></div></div>
    <div class="media-label">
      <div class="ml-big">Graffiti Pasta</div>
      <div class="ml-sub">DENTON · TEXAS</div>
    </div>
  </div>

  <!-- Right column top -->
  <div class="tile t-orange">
    <div class="tile-big">$5</div>
    <div class="tile-label">NEGRONI</div>
    <div class="tile-sub">HAPPY HOUR 4–7PM</div>
  </div>

  <!-- Right column middle -->
  <div class="tile t-teal">
    <div class="tile-big">FRI</div>
    <div class="tile-label">LIVE MUSIC</div>
    <div class="tile-sub">EVERY FRIDAY NIGHT</div>
  </div>

  <!-- Right column bottom -->
  <div class="tile t-purple">
    <div class="tile-big" id="clock" style="font-size:clamp(1.2rem,2vw,2.2rem)">--:--:--</div>
    <div class="tile-label">LOCAL TIME</div>
    <div class="tile-sub">DENTON · TX</div>
  </div>

  <!-- Bottom left 2 tiles -->
  <div class="tile-menu tile">
    <div class="tm-header">TONIGHT'S MENU</div>
    <div class="tm-scroll-wrap"><div class="tm-scroll">
      <div class="tm-row"><span class="tm-name">Truffle Pasta</span><span class="tm-price">$24.99</span></div>
      <div class="tm-row"><span class="tm-name">Carbonara</span><span class="tm-price">$19.99</span></div>
      <div class="tm-row"><span class="tm-name">Cacio e Pepe</span><span class="tm-price">$17.99</span></div>
      <div class="tm-row"><span class="tm-name">Arrabbiata</span><span class="tm-price">$16.99</span></div>
      <div class="tm-row"><span class="tm-name">Bolognese</span><span class="tm-price">$21.99</span></div>
      <div class="tm-row"><span class="tm-name">Pizza</span><span class="tm-price">$14.99</span></div>
      <div class="tm-row"><span class="tm-name">Aperol Spritz</span><span class="tm-price">$8.99</span></div>
      <div class="tm-row"><span class="tm-name">Truffle Pasta</span><span class="tm-price">$24.99</span></div>
      <div class="tm-row"><span class="tm-name">Carbonara</span><span class="tm-price">$19.99</span></div>
      <div class="tm-row"><span class="tm-name">Cacio e Pepe</span><span class="tm-price">$17.99</span></div>
      <div class="tm-row"><span class="tm-name">Arrabbiata</span><span class="tm-price">$16.99</span></div>
      <div class="tm-row"><span class="tm-name">Bolognese</span><span class="tm-price">$21.99</span></div>
      <div class="tm-row"><span class="tm-name">Pizza</span><span class="tm-price">$14.99</span></div>
      <div class="tm-row"><span class="tm-name">Aperol Spritz</span><span class="tm-price">$8.99</span></div>
    </div></div>
  </div>

  <!-- Full width ticker -->
  <div class="tile-ticker">
    <div class="tt-label">GRAFFITI TV</div>
    <div class="tt-track">
      <span class="tt-item"><strong>Carbonara</strong> $19.99</span><span class="tt-item"><strong>Truffle Pasta</strong> $24.99</span><span class="tt-item"><strong>Cacio e Pepe</strong> $17.99</span><span class="tt-item"><strong>Bolognese</strong> $21.99</span><span class="tt-item">Happy Hour 4–7pm</span><span class="tt-item">Live Music Fridays</span><span class="tt-item">Wood-Fired Pizza $14.99</span><span class="tt-item">Street Art Meets Italian Soul</span>
      <span class="tt-item"><strong>Carbonara</strong> $19.99</span><span class="tt-item"><strong>Truffle Pasta</strong> $24.99</span><span class="tt-item"><strong>Cacio e Pepe</strong> $17.99</span><span class="tt-item"><strong>Bolognese</strong> $21.99</span><span class="tt-item">Happy Hour 4–7pm</span><span class="tt-item">Live Music Fridays</span><span class="tt-item">Wood-Fired Pizza $14.99</span><span class="tt-item">Street Art Meets Italian Soul</span>
    </div>
    <div class="tile tile-qr"><div class="qr-block-box"><div id="qr-code"></div></div><div class="tile-qr-label" id="qr-label">Scan for offer</div></div>
</div>
<script>
  setInterval(()=>{document.getElementById('clock').textContent=new Date().toLocaleTimeString('en-US',{hour12:false});},1000);
  let ml=[],idx=0;
  async function load(){try{const r=await fetch('/api/linode/media');const d=await r.json();if(d.success&&d.media?.length){ml=d.media;play();}else fb();}catch(e){fb();}}
  function fb(){document.getElementById('mediaContainer').innerHTML=`<iframe src="https://www.youtube.com/embed/86YLFOog4GM?autoplay=1&mute=1&controls=0&loop=1&playlist=86YLFOog4GM" frameborder="0" allow="autoplay" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>`;}
  function play(){const c=document.getElementById('mediaContainer');const m=ml[idx];c.innerHTML='';if(m.type==='video'){const v=document.createElement('video');v.src=m.url;v.autoplay=v.muted=v.loop=true;v.style.cssText='width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0';c.appendChild(v);}else{const i=document.createElement('img');i.src=m.url;i.style.cssText='width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0';i.onerror=next;c.appendChild(i);setTimeout(next,15000);}}
  function next(){idx=(idx+1)%ml.length;play();}
  document.addEventListener('DOMContentLoaded',load);
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
(async()=>{
  try{
    const slug=window.location.pathname.split('/')[2];
    const d=await fetch('/api/'+slug+'/offering').then(r=>r.json());
    if(!d.url)return;
    const lbl=document.getElementById('qr-label');if(lbl)lbl.textContent=d.title||'Scan for offer';
    const box=document.getElementById('qr-code');if(box)new QRCode(box,{text:d.url,width:84,height:84,colorDark:'#000',colorLight:'#fff',correctLevel:QRCode.CorrectLevel.M});
  }catch(e){}
})();
</script>
</body></html>
