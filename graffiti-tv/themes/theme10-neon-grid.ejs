      <div class="stat-num">4–7PM</div>
      <div class="stat-label">DAILY · NEGRONI $5</div>
    </div>
    <div class="s-panel" style="flex:2">
      <div class="sp-label">TONIGHT'S MENU</div>
      <div class="menu-scroll-wrap"><div class="menu-scroll">
        <div class="mrow"><span class="mrow-name">Truffle Pasta</span><span class="mrow-price">$24.99</span></div>
        <div class="mrow"><span class="mrow-name">Carbonara</span><span class="mrow-price">$19.99</span></div>
        <div class="mrow"><span class="mrow-name">Cacio e Pepe</span><span class="mrow-price">$17.99</span></div>
        <div class="mrow"><span class="mrow-name">Arrabbiata</span><span class="mrow-price">$16.99</span></div>
        <div class="mrow"><span class="mrow-name">Bolognese</span><span class="mrow-price">$21.99</span></div>
        <div class="mrow"><span class="mrow-name">Amatriciana</span><span class="mrow-price">$18.99</span></div>
        <div class="mrow"><span class="mrow-name">Pizza</span><span class="mrow-price">$14.99</span></div>
        <div class="mrow"><span class="mrow-name">Negroni</span><span class="mrow-price">$5 HH</span></div>
        <div class="mrow"><span class="mrow-name">Aperol Spritz</span><span class="mrow-price">$8.99</span></div>
        <div class="mrow"><span class="mrow-name">Truffle Pasta</span><span class="mrow-price">$24.99</span></div>
        <div class="mrow"><span class="mrow-name">Carbonara</span><span class="mrow-price">$19.99</span></div>
        <div class="mrow"><span class="mrow-name">Cacio e Pepe</span><span class="mrow-price">$17.99</span></div>
        <div class="mrow"><span class="mrow-name">Arrabbiata</span><span class="mrow-price">$16.99</span></div>
        <div class="mrow"><span class="mrow-name">Bolognese</span><span class="mrow-price">$21.99</span></div>
        <div class="mrow"><span class="mrow-name">Amatriciana</span><span class="mrow-price">$18.99</span></div>
        <div class="mrow"><span class="mrow-name">Pizza</span><span class="mrow-price">$14.99</span></div>
        <div class="mrow"><span class="mrow-name">Negroni</span><span class="mrow-price">$5 HH</span></div>
        <div class="mrow"><span class="mrow-name">Aperol Spritz</span><span class="mrow-price">$8.99</span></div>
      </div></div>
    </div>
    <div class="s-panel stat-panel">
      <div class="sp-label">LIVE MUSIC</div>
      <div class="stat-num">FRI</div>
      <div class="stat-label">EVERY FRIDAY NIGHT</div>
    </div>
  </div><div class="bottom">
    <div class="b-label">LIVE</div>
    <div class="b-track">
      <span class="b-item"><strong>Carbonara</strong> $19.99</span><span class="b-item"><strong>Truffle Pasta</strong> $24.99</span><span class="b-item"><strong>Cacio e Pepe</strong> $17.99</span><span class="b-item"><strong>Bolognese</strong> $21.99</span><span class="b-item">Happy Hour 4–7pm · Negroni $5</span><span class="b-item">Live Music Every Friday</span><span class="b-item">Wood-Fired Pizza Nightly</span>
      <span class="b-item"><strong>Carbonara</strong> $19.99</span><span class="b-item"><strong>Truffle Pasta</strong> $24.99</span><span class="b-item"><strong>Cacio e Pepe</strong> $17.99</span><span class="b-item"><strong>Bolognese</strong> $21.99</span><span class="b-item">Happy Hour 4–7pm · Negroni $5</span><span class="b-item">Live Music Every Friday</span><span class="b-item">Wood-Fired Pizza Nightly</span>
    </div>
  <div class="qr-panel"><div class="qr-block-box"><div id="qr-code"></div></div><div class="qr-block-label" id="qr-label">Scan for offer</div></div>
  </div>
</div>
<script>
  setInterval(()=>{document.getElementById('clock').textContent=new Date().toLocaleTimeString('en-US',{hour12:false});},1000);
  let ml=[],idx=0;
  async function load(){try{const r=await fetch('/api/linode/media');const d=await r.json();if(d.success&&d.media?.length){ml=d.media;play();}else fb();}catch(e){fb();}}
  function fb(){document.getElementById('mediaContainer').innerHTML=`<iframe src="https://www.youtube.com/embed/86YLFOog4GM?autoplay=1&mute=1&controls=0&loop=1&playlist=86YLFOog4GM" frameborder="0" allow="autoplay" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>`;}
  function play(){const c=document.getElementById('mediaContainer');const m=ml[idx];c.innerHTML='';if(m.type==='video'){const v=document.createElement('video');v.src=m.url;v.autoplay=v.muted=v.loop=true;v.style.cssText='width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0';c.appendChild(v);}else{const i=document.createElement('img');i.src=m.url;i.style.cssText='width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0';i.onerror=next;c.appendChild(i);setTimeout(next,15000);}}
  function next(){idx=(idx+1)%ml.length;play();}
  document.addEventListener('DOMContentLoaded',load);
</script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
(async()=>{
  try{
    const slug=window.location.pathname.split('/')[2];
    const d=await fetch('/api/'+slug+'/offering').then(r=>r.json());
    if(!d.url)return;
    const lbl=document.getElementById('qr-label');if(lbl)lbl.textContent=d.title||'Scan for offer';
    const box=document.getElementById('qr-code');if(box)new QRCode(box,{text:d.url,width:84,height:84,colorDark:'#000',colorLight:'#fff',correctLevel:QRCode.CorrectLevel.M});
  }catch(e){}
})();
</script>
</body></html>
