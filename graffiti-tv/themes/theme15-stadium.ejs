<!DOCTYPE html>
<html lang="en">
<head>
  <title>GRAFFITI TV — STADIUM</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Black+Ops+One&family=Teko:wght@700&family=Source+Code+Pro:wght@600&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:#0d1117;height:100vh;overflow:hidden;font-family:'Teko',sans-serif;color:#fff;}

    .shell{
      display:grid;
      grid-template-rows:80px 1fr 56px 48px;
      height:100vh;
    }

    /* SCOREBOARD HEADER */
    .scoreboard{
      background:#000;
      border-bottom:4px solid #f5c400;
      display:grid;
      grid-template-columns:1fr auto 1fr;
      align-items:center;
      padding:0 24px;gap:20px;
    }
    .sb-left{display:flex;flex-direction:column;}
    .sb-name{font-family:'Black Ops One',serif;font-size:28px;color:#f5c400;letter-spacing:2px;line-height:1;}
    .sb-sub{font-size:16px;color:#666;letter-spacing:4px;}
    .sb-center{text-align:center;}
    .sb-time{font-family:'Source Code Pro',monospace;font-size:40px;color:#fff;text-shadow:0 0 20px rgba(255,255,255,0.3);line-height:1;}
    .sb-date{font-size:12px;color:#555;letter-spacing:3px;margin-top:2px;}
    .sb-right{display:flex;gap:12px;justify-content:flex-end;align-items:center;}
    .sb-badge{
      background:#f5c400;color:#000;
      font-family:'Black Ops One',serif;font-size:13px;
      padding:4px 12px;letter-spacing:2px;
      animation:badgePulse 2s ease-in-out infinite;
    }
    @keyframes badgePulse{0%,100%{opacity:1}50%{opacity:0.7}}
    .sb-badge.alt{background:#cc0000;color:#fff;}

    /* MAIN AREA: media + right column */
    .main-area{
      display:grid;
      grid-template-columns:1fr 300px;
    }

    /* Media */
    .media-zone{background:#000;position:relative;overflow:hidden;}
    #mediaContainer{width:100%;height:100%;position:relative;}
    #mediaContainer img,#mediaContainer video{width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0;}
    .loading-msg{position:absolute;inset:0;background:#0d1117;display:flex;align-items:center;justify-content:center;}
    .loading-msg span{font-family:'Black Ops One',serif;font-size:3rem;color:rgba(245,196,0,0.2);}

    /* Stadium lights flare corners */
    .media-zone::before{
      content:'';position:absolute;inset:0;pointer-events:none;z-index:2;
      background:
        radial-gradient(circle at 0% 0%, rgba(245,196,0,0.15) 0%, transparent 30%),
        radial-gradient(circle at 100% 0%, rgba(245,196,0,0.15) 0%, transparent 30%);
    }

    /* RIGHT STATS COLUMN */
    .stats-col{
      background:#000;border-left:2px solid #1a1a1a;
      display:flex;flex-direction:column;
    }
    .stat-block{
      flex:1;border-bottom:2px solid #111;
      display:flex;flex-direction:column;align-items:center;justify-content:center;
      padding:16px;text-align:center;position:relative;overflow:hidden;
    }
    .stat-block::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
    .sb1::before{background:#f5c400;}
    .sb2::before{background:#cc0000;}
    .sb3::before{background:#00cc88;}
    .sb4::before{background:#0088cc;}

    .stat-num{font-family:'Black Ops One',serif;font-size:clamp(2rem,3vw,3.5rem);color:#fff;line-height:1;text-shadow:0 0 20px rgba(255,255,255,0.2);}
    .stat-unit{font-size:1rem;color:#f5c400;letter-spacing:2px;margin-top:2px;}
    .stat-desc{font-family:'Source Code Pro',monospace;font-size:10px;color:#444;letter-spacing:2px;margin-top:6px;}

    /* Menu scrolling panel replaces one stat */
    .stat-menu{padding:12px;overflow:hidden;align-items:stretch;justify-content:flex-start;}
    .stat-menu-header{font-family:'Black Ops One',serif;font-size:13px;letter-spacing:2px;color:#f5c400;margin-bottom:8px;text-align:left;}
    .stat-menu-scroll{overflow:hidden;flex:1;}
    .stat-menu-inner{animation:scrollUp 18s linear infinite;}
    @keyframes scrollUp{0%{transform:translateY(0)}100%{transform:translateY(-50%)}}
    .smrow{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid #111;font-size:15px;}
    .smrow-name{color:#ccc;}
    .smrow-price{font-family:'Source Code Pro',monospace;color:#f5c400;font-size:13px;}

    /* JUMBOTRON TICKER */
    .jumbotron{
      background:#f5c400;overflow:hidden;display:flex;align-items:center;
    }
    .jt-label{font-family:'Black Ops One',serif;font-size:15px;letter-spacing:3px;padding:0 18px;color:#000;white-space:nowrap;flex-shrink:0;border-right:3px solid rgba(0,0,0,0.2);}
    .jt-track{display:flex;animation:tickerScroll 26s linear infinite;white-space:nowrap;}
    @keyframes tickerScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .jt-item{padding:0 32px;font-family:'Teko',sans-serif;font-size:20px;color:#000;letter-spacing:1px;}
    .jt-item::before{content:'▶ ';}

    /* BOTTOM STATUS */
    .status-bar{
      background:#000;border-top:2px solid #1a1a1a;
      display:flex;align-items:center;justify-content:space-between;
      padding:0 24px;
    }
    .status-item{display:flex;align-items:center;gap:8px;font-size:15px;color:#555;letter-spacing:2px;}
    .status-dot{width:8px;height:8px;border-radius:50%;background:#00cc88;animation:dotBlink 1.5s step-end infinite;}
    @keyframes dotBlink{0%,100%{opacity:1}50%{opacity:0.2}}
  
    .stat-qr{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;padding:10px;background:#0a0d14;border:1px solid rgba(245,196,0,0.2);}
    .qr-block-box{background:#fff;padding:5px;border-radius:3px;width:84px;height:84px;display:flex;align-items:center;justify-content:center;}
    .stat-qr-label{font-family:'Black Ops One',serif;font-size:8px;letter-spacing:2px;color:rgba(245,196,0,0.7);text-align:center;text-transform:uppercase;max-width:90px;line-height:1.3;}
  
    .stat-qr{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;padding:10px;background:#0a0d14;border:1px solid rgba(245,196,0,0.2);}
    .qr-block-box{background:#fff;padding:5px;border-radius:3px;width:84px;height:84px;display:flex;align-items:center;justify-content:center;}
    .stat-qr-label{font-family:monospace;font-size:8px;letter-spacing:2px;color:rgba(245,196,0,0.7);text-align:center;text-transform:uppercase;max-width:90px;line-height:1.3;}
  </style>
</head>
<body>
<div class="shell">
  <div class="scoreboard">
    <div class="sb-left">
      <div class="sb-name">GRAFFITI PASTA</div>
      <div class="sb-sub">DENTON · TEXAS</div>
    </div>
    <div class="sb-center">
      <div class="sb-time" id="clock">--:--:--</div>
      <div class="sb-date">LIVE TONIGHT</div>
    </div>
    <div class="sb-right">
      <div class="sb-badge">HAPPY HOUR 4–7</div>
      <div class="sb-badge alt">LIVE MUSIC FRI</div>
    </div>
  </div>

  <div class="main-area">
    <div class="media-zone">
      <div id="mediaContainer"><div class="loading-msg"><span>GFTV</span></div></div>
    </div>
    <div class="stats-col">
      <div class="stat-block sb1">
        <div class="stat-num">$5</div>
        <div class="stat-unit">NEGRONI</div>
        <div class="stat-desc">HAPPY HOUR ONLY</div>
      </div>
      <div class="stat-block sb2">
        <div class="stat-num">$24</div>
        <div class="stat-unit">TRUFFLE PASTA</div>
        <div class="stat-desc">TONIGHT'S SPECIAL</div>
      </div>
      <div class="stat-block sb3 stat-menu">
        <div class="stat-menu-header">FULL MENU</div>
        <div class="stat-menu-scroll"><div class="stat-menu-inner">
          <div class="smrow"><span class="smrow-name">Carbonara</span><span class="smrow-price">$19.99</span></div>
          <div class="smrow"><span class="smrow-name">Cacio e Pepe</span><span class="smrow-price">$17.99</span></div>
          <div class="smrow"><span class="smrow-name">Arrabbiata</span><span class="smrow-price">$16.99</span></div>
          <div class="smrow"><span class="smrow-name">Bolognese</span><span class="smrow-price">$21.99</span></div>
          <div class="smrow"><span class="smrow-name">Pizza</span><span class="smrow-price">$14.99</span></div>
          <div class="smrow"><span class="smrow-name">Aperol Spritz</span><span class="smrow-price">$8.99</span></div>
          <div class="smrow"><span class="smrow-name">Carbonara</span><span class="smrow-price">$19.99</span></div>
          <div class="smrow"><span class="smrow-name">Cacio e Pepe</span><span class="smrow-price">$17.99</span></div>
          <div class="smrow"><span class="smrow-name">Arrabbiata</span><span class="smrow-price">$16.99</span></div>
          <div class="smrow"><span class="smrow-name">Bolognese</span><span class="smrow-price">$21.99</span></div>
          <div class="smrow"><span class="smrow-name">Pizza</span><span class="smrow-price">$14.99</span></div>
          <div class="smrow"><span class="smrow-name">Aperol Spritz</span><span class="smrow-price">$8.99</span></div>
        </div></div>
      </div>
      <div class="stat-block sb4">
        <div class="stat-num">FRI</div>
        <div class="stat-unit">LIVE MUSIC</div>
        <div class="stat-desc">EVERY FRIDAY NIGHT</div>
      </div>
    </div>
  </div>

  <div class="jumbotron">
    <div class="jt-label">TONIGHT</div>
    <div class="jt-track">
      <span class="jt-item">GRAFFITI PASTA DENTON TEXAS</span><span class="jt-item">HANDMADE PASTA DAILY</span><span class="jt-item">CARBONARA $19.99</span><span class="jt-item">TRUFFLE PASTA $24.99</span><span class="jt-item">HAPPY HOUR 4–7PM</span><span class="jt-item">NEGRONI $5</span><span class="jt-item">LIVE MUSIC EVERY FRIDAY</span>
      <span class="jt-item">GRAFFITI PASTA DENTON TEXAS</span><span class="jt-item">HANDMADE PASTA DAILY</span><span class="jt-item">CARBONARA $19.99</span><span class="jt-item">TRUFFLE PASTA $24.99</span><span class="jt-item">HAPPY HOUR 4–7PM</span><span class="jt-item">NEGRONI $5</span><span class="jt-item">LIVE MUSIC EVERY FRIDAY</span>
    </div>
  </div>

  <div class="status-bar">
    <div class="status-item"><span class="status-dot"></span>LIVE BROADCAST</div>
    <div class="status-item">GRAFFITI TV · CH 1</div>
    <div class="status-item">DENTON · TX</div>
    <div class="stat-qr"><div class="qr-block-box"><div id="qr-code"></div></div><div class="stat-qr-label" id="qr-label">Scan for offer</div></div>
  </div>
</div>
<script>
  setInterval(()=>{document.getElementById('clock').textContent=new Date().toLocaleTimeString('en-US',{hour12:false});},1000);
  let ml=[],idx=0;
  async function load(){try{const r=await fetch('/api/linode/media');const d=await r.json();if(d.success&&d.media?.length){ml=d.media;play();}else fb();}catch(e){fb();}}
  function fb(){document.getElementById('mediaContainer').innerHTML=`<iframe src="https://www.youtube.com/embed/86YLFOog4GM?autoplay=1&mute=1&controls=0&loop=1&playlist=86YLFOog4GM" frameborder="0" allow="autoplay" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>`;}
  function play(){const c=document.getElementById('mediaContainer');const m=ml[idx];c.innerHTML='';if(m.type==='video'){const v=document.createElement('video');v.src=m.url;v.autoplay=v.muted=v.loop=true;v.style.cssText='width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0';c.appendChild(v);}else{const i=document.createElement('img');i.src=m.url;i.style.cssText='width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0';i.onerror=next;c.appendChild(i);setTimeout(next,15000);}}
  function next(){idx=(idx+1)%ml.length;play();}
  document.addEventListener('DOMContentLoaded',load);
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
(async()=>{
  try{
    const slug=window.location.pathname.split('/')[2];
    const d=await fetch('/api/'+slug+'/offering').then(r=>r.json());
    if(!d.url)return;
    const lbl=document.getElementById('qr-label');if(lbl)lbl.textContent=d.title||'Scan for offer';
    const box=document.getElementById('qr-code');if(box)new QRCode(box,{text:d.url,width:84,height:84,colorDark:'#000',colorLight:'#fff',correctLevel:QRCode.CorrectLevel.M});
  }catch(e){}
})();
</script>
</body></html>
