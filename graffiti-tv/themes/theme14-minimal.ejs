<!DOCTYPE html>
<html lang="en">
<head>
  <title>GRAFFITI TV — MINIMAL</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,700;1,400&family=Montserrat:wght@900&family=IBM+Plex+Mono&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:#f8f7f4;height:100vh;overflow:hidden;font-family:'Cormorant Garamond',serif;color:#111;}

    .shell{
      display:grid;
      grid-template-columns:420px 1fr;
      grid-template-rows:1fr 70px;
      height:100vh;
    }

    /* LEFT: all text, clean */
    .left-panel{
      padding:40px 36px;
      display:flex;flex-direction:column;justify-content:space-between;
      border-right:1px solid #ddd;background:#f8f7f4;
    }
    .lp-top{}
    .brand{
      font-family:'Montserrat',sans-serif;font-weight:900;
      font-size:clamp(1.6rem,2.5vw,2.8rem);
      letter-spacing:-1px;line-height:1;color:#111;
    }
    .brand span{color:#c0392b;}
    .tagline{
      font-style:italic;font-size:1.1rem;color:#888;
      margin-top:8px;letter-spacing:0.5px;
    }
    .divider{height:1px;background:#ddd;margin:24px 0;}

    .menu-title{font-family:'Montserrat',sans-serif;font-size:11px;letter-spacing:5px;color:#aaa;margin-bottom:16px;}
    .menu-item{
      display:flex;align-items:baseline;justify-content:space-between;
      padding:9px 0;border-bottom:1px solid #eee;
    }
    .mi-name{font-size:1.1rem;color:#111;}
    .mi-desc{font-size:0.85rem;font-style:italic;color:#aaa;margin-top:2px;}
    .mi-price{font-family:'IBM Plex Mono',monospace;font-size:1rem;color:#c0392b;white-space:nowrap;margin-left:12px;}

    .lp-bottom{}
    .info-row{display:flex;gap:20px;flex-wrap:wrap;}
    .info-chip{
      background:#111;color:#f8f7f4;
      font-family:'IBM Plex Mono',monospace;font-size:11px;
      padding:4px 12px;letter-spacing:1px;
    }
    .time-display{
      font-family:'IBM Plex Mono',monospace;font-size:2rem;
      color:#111;letter-spacing:2px;margin-top:16px;
    }

    /* RIGHT: full bleed media */
    .right-media{
      grid-row:1/2;
      position:relative;overflow:hidden;background:#000;
    }
    #mediaContainer{width:100%;height:100%;position:relative;}
    #mediaContainer img,#mediaContainer video{width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0;}
    .loading-msg{position:absolute;inset:0;background:#eee;display:flex;align-items:center;justify-content:center;}
    .loading-msg span{font-family:'Montserrat',sans-serif;font-size:1.5rem;color:#ccc;letter-spacing:4px;}

    /* BOTTOM TICKER */
    .bottom-ticker{
      grid-column:1/-1;
      background:#111;border-top:1px solid #000;
      overflow:hidden;display:flex;align-items:center;
    }
    .bt-label{font-family:'Montserrat',sans-serif;font-size:12px;letter-spacing:4px;padding:0 20px;color:#f8f7f4;white-space:nowrap;flex-shrink:0;border-right:1px solid #333;}
    .bt-track{display:flex;animation:tickerScroll 32s linear infinite;white-space:nowrap;}
    @keyframes tickerScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .bt-item{padding:0 36px;font-family:'IBM Plex Mono',monospace;font-size:13px;color:rgba(248,247,244,0.4);}
    .bt-item strong{color:#f8f7f4;}
  
    .qr-minimal{padding:16px;border-top:1px solid #ddd;display:flex;flex-direction:column;align-items:center;gap:6px;background:#f8f7f4;}
    .qr-block-box{background:#fff;border:1px solid #e0e0e0;padding:5px;width:84px;height:84px;display:flex;align-items:center;justify-content:center;}
    .qr-minimal-label{font-family:'Jost',sans-serif;font-size:9px;letter-spacing:2px;color:#c0392b;text-align:center;text-transform:uppercase;max-width:100px;line-height:1.3;}
  
    .qr-minimal{padding:16px;border-top:1px solid #ddd;display:flex;flex-direction:column;align-items:center;gap:6px;}
    .qr-block-box{background:#fff;border:1px solid #e0e0e0;padding:5px;width:84px;height:84px;display:flex;align-items:center;justify-content:center;}
    .qr-minimal-label{font-family:sans-serif;font-size:9px;letter-spacing:2px;color:#c0392b;text-align:center;text-transform:uppercase;max-width:100px;line-height:1.3;}
  </style>
</head>
<body>
<div class="shell">
  <div class="left-panel">
    <div class="lp-top">
      <div class="brand">Graffiti <span>Pasta</span></div>
      <div class="tagline">Street art meets Italian soul — Denton, TX</div>
      <div class="divider"></div>
      <div class="menu-title">TONIGHT'S MENU</div>
      <div class="menu-item"><div><div class="mi-name">Truffle Pasta</div><div class="mi-desc">black truffle · parm · butter</div></div><div class="mi-price">$24.99</div></div>
      <div class="menu-item"><div><div class="mi-name">Graffiti Carbonara</div><div class="mi-desc">guanciale · egg yolk · pecorino</div></div><div class="mi-price">$19.99</div></div>
      <div class="menu-item"><div><div class="mi-name">Cacio e Pepe</div><div class="mi-desc">tonnarelli · pecorino · pepper</div></div><div class="mi-price">$17.99</div></div>
      <div class="menu-item"><div><div class="mi-name">Arrabbiata</div><div class="mi-desc">san marzano · chili · garlic</div></div><div class="mi-price">$16.99</div></div>
      <div class="menu-item"><div><div class="mi-name">Bolognese</div><div class="mi-desc">slow-braised beef & pork</div></div><div class="mi-price">$21.99</div></div>
      <div class="menu-item"><div><div class="mi-name">Wood-Fired Pizza</div><div class="mi-desc">rotating toppings nightly</div></div><div class="mi-price">$14.99</div></div>
    </div>
    <div class="lp-bottom">
      <div class="divider"></div>
      <div class="info-row">
        <span class="info-chip">HAPPY HOUR 4–7PM</span>
        <span class="info-chip">LIVE MUSIC FRI</span>
        <span class="info-chip">NEGRONI $5</span>
      </div>
      <div class="time-display" id="clock">--:--:--</div>
    </div>
    <div class="qr-minimal"><div class="qr-block-box"><div id="qr-code"></div></div><div class="qr-minimal-label" id="qr-label">Scan for offer</div></div>
  </div>

  <div class="right-media">
    <div id="mediaContainer"><div class="loading-msg"><span>LOADING</span></div></div>
  </div>

  <div class="bottom-ticker">
    <div class="bt-label">GRAFFITI PASTA</div>
    <div class="bt-track">
      <span class="bt-item"><strong>Carbonara</strong> $19.99</span><span class="bt-item"><strong>Truffle Pasta</strong> $24.99</span><span class="bt-item"><strong>Cacio e Pepe</strong> $17.99</span><span class="bt-item"><strong>Bolognese</strong> $21.99</span><span class="bt-item">Happy Hour 4–7pm daily</span><span class="bt-item">Live Music Every Friday</span><span class="bt-item">Reservations Welcome</span>
      <span class="bt-item"><strong>Carbonara</strong> $19.99</span><span class="bt-item"><strong>Truffle Pasta</strong> $24.99</span><span class="bt-item"><strong>Cacio e Pepe</strong> $17.99</span><span class="bt-item"><strong>Bolognese</strong> $21.99</span><span class="bt-item">Happy Hour 4–7pm daily</span><span class="bt-item">Live Music Every Friday</span><span class="bt-item">Reservations Welcome</span>
    </div>
  </div>
</div>
<script>
  setInterval(()=>{document.getElementById('clock').textContent=new Date().toLocaleTimeString('en-US',{hour12:false});},1000);
  let ml=[],idx=0;
  async function load(){try{const r=await fetch('/api/linode/media');const d=await r.json();if(d.success&&d.media?.length){ml=d.media;play();}else fb();}catch(e){fb();}}
  function fb(){document.getElementById('mediaContainer').innerHTML=`<iframe src="https://www.youtube.com/embed/86YLFOog4GM?autoplay=1&mute=1&controls=0&loop=1&playlist=86YLFOog4GM" frameborder="0" allow="autoplay" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>`;}
  function play(){const c=document.getElementById('mediaContainer');const m=ml[idx];c.innerHTML='';if(m.type==='video'){const v=document.createElement('video');v.src=m.url;v.autoplay=v.muted=v.loop=true;v.style.cssText='width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0';c.appendChild(v);}else{const i=document.createElement('img');i.src=m.url;i.style.cssText='width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0';i.onerror=next;c.appendChild(i);setTimeout(next,15000);}}
  function next(){idx=(idx+1)%ml.length;play();}
  document.addEventListener('DOMContentLoaded',load);
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
(async()=>{
  try{
    const slug=window.location.pathname.split('/')[2];
    const d=await fetch('/api/'+slug+'/offering').then(r=>r.json());
    if(!d.url)return;
    const lbl=document.getElementById('qr-label');if(lbl)lbl.textContent=d.title||'Scan for offer';
    const box=document.getElementById('qr-code');if(box)new QRCode(box,{text:d.url,width:84,height:84,colorDark:'#000',colorLight:'#fff',correctLevel:QRCode.CorrectLevel.M});
  }catch(e){}
})();
</script>
</body></html>
