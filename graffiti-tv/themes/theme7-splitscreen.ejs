          <div class="menu-row"><span class="menu-row-name">Amatriciana</span><span class="menu-row-price">$18.99</span></div>
          <div class="menu-row"><span class="menu-row-name">Wood-Fired Pizza</span><span class="menu-row-price">$14.99</span></div>
          <div class="menu-row"><span class="menu-row-name">Negroni</span><span class="menu-row-price">$5 HH</span></div>
          <div class="menu-row"><span class="menu-row-name">Aperol Spritz</span><span class="menu-row-price">$8.99</span></div>
          <!-- dupe -->
          <div class="menu-row"><span class="menu-row-name">Truffle Pasta</span><span class="menu-row-price">$24.99</span></div>
          <div class="menu-row"><span class="menu-row-name">Graffiti Carbonara</span><span class="menu-row-price">$19.99</span></div>
          <div class="menu-row"><span class="menu-row-name">Cacio e Pepe</span><span class="menu-row-price">$17.99</span></div>
          <div class="menu-row"><span class="menu-row-name">Arrabbiata</span><span class="menu-row-price">$16.99</span></div>
          <div class="menu-row"><span class="menu-row-name">Bolognese</span><span class="menu-row-price">$21.99</span></div>
          <div class="menu-row"><span class="menu-row-name">Amatriciana</span><span class="menu-row-price">$18.99</span></div>
          <div class="menu-row"><span class="menu-row-name">Wood-Fired Pizza</span><span class="menu-row-price">$14.99</span></div>
          <div class="menu-row"><span class="menu-row-name">Negroni</span><span class="menu-row-price">$5 HH</span></div>
          <div class="menu-row"><span class="menu-row-name">Aperol Spritz</span><span class="menu-row-price">$8.99</span></div>
        </div>
      </div>
    </div>

    <!-- CLOCK PANEL -->
    <div class="panel panel-clock">
      <div class="big-clock" id="clock">--:--:--</div>
      <div class="clock-sub">DENTON · TEXAS</div>
      <div class="panel-badges">
        <span class="badge badge-red">LIVE MUSIC FRI</span>
        <span class="badge badge-blue">HAPPY HOUR 4–7</span>
        <span class="badge badge-yellow">OPEN NOW</span>
      </div>
      <div class="qr-block"><div class="qr-block-box"><div id="qr-code"></div></div><div class="qr-block-label" id="qr-label">Scan for offer</div></div>
    </div>

    <!-- SPECIALS HORIZONTAL SCROLL -->
    <div class="panel panel-special">
      <div class="panel-label">// Chef's Specials</div>
      <div class="special-track-wrap">
        <div class="special-track">
          <div class="special-item"><div class="si-name">Truffle Pasta</div><div class="si-desc">black truffle · parm · butter</div><div class="si-price">$24.99</div></div>
          <div class="special-item"><div class="si-name">Carbonara</div><div class="si-desc">guanciale · egg · pecorino</div><div class="si-price">$19.99</div></div>
          <div class="special-item"><div class="si-name">Cacio e Pepe</div><div class="si-desc">roman · simple · perfect</div><div class="si-price">$17.99</div></div>
          <div class="special-item"><div class="si-name">Negroni</div><div class="si-desc">happy hour daily 4–7pm</div><div class="si-price">$5</div></div>
          <div class="special-item"><div class="si-name">Truffle Pasta</div><div class="si-desc">black truffle · parm · butter</div><div class="si-price">$24.99</div></div>
          <div class="special-item"><div class="si-name">Carbonara</div><div class="si-desc">guanciale · egg · pecorino</div><div class="si-price">$19.99</div></div>
          <div class="special-item"><div class="si-name">Cacio e Pepe</div><div class="si-desc">roman · simple · perfect</div><div class="si-price">$17.99</div></div>
          <div class="special-item"><div class="si-name">Negroni</div><div class="si-desc">happy hour daily 4–7pm</div><div class="si-price">$5</div></div>
        </div>
      </div>
    </div>

  </div>
<script>
  setInterval(()=>{ document.getElementById('clock').textContent=new Date().toLocaleTimeString('en-US',{hour12:false}); },1000);
  let mediaList=[],idx=0;
  async function loadMedia(){try{const r=await fetch('/api/linode/media');const d=await r.json();if(d.success&&d.media?.length){mediaList=d.media;playMedia();}else loadFallback();}catch(e){loadFallback();}}
  function loadFallback(){document.getElementById('mediaContainer').innerHTML=`<iframe src="https://www.youtube.com/embed/86YLFOog4GM?autoplay=1&mute=1&controls=0&loop=1&playlist=86YLFOog4GM" frameborder="0" allow="autoplay" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>`;}
  function playMedia(){const c=document.getElementById('mediaContainer');const m=mediaList[idx];c.innerHTML='';if(m.type==='video'){const v=document.createElement('video');v.src=m.url;v.autoplay=v.muted=true;v.loop=true;c.appendChild(v);}else{const i=document.createElement('img');i.src=m.url;i.addEventListener('error',next);c.appendChild(i);setTimeout(next,15000);}}
  function next(){idx=(idx+1)%mediaList.length;playMedia();}
  document.addEventListener('DOMContentLoaded',loadMedia);
</script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
(async()=>{
  try{
    const slug=window.location.pathname.split('/')[2];
    const d=await fetch('/api/'+slug+'/offering').then(r=>r.json());
    if(!d.url)return;
    const lbl=document.getElementById('qr-label');if(lbl)lbl.textContent=d.title||'Scan for offer';
    const box=document.getElementById('qr-code');if(box)new QRCode(box,{text:d.url,width:84,height:84,colorDark:'#000',colorLight:'#fff',correctLevel:QRCode.CorrectLevel.M});
  }catch(e){}
})();
</script>
</body></html>
