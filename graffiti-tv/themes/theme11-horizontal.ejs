<!DOCTYPE html>
<html lang="en">
<head>
  <title>GRAFFITI TV — HORIZONTAL</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Righteous&family=Nunito:wght@900&family=Courier+Prime:wght@700&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:#1a0a2e;height:100vh;overflow:hidden;font-family:'Nunito',sans-serif;}

    .shell{
      display:grid;
      grid-template-rows: 55px 1fr 1fr 50px;
      grid-template-columns: 1fr;
      height:100vh;gap:3px;padding:3px;
    }

    /* TOP BAR */
    .top{
      display:flex;align-items:center;justify-content:space-between;padding:0 20px;
      background:linear-gradient(90deg,#6600cc,#cc0066,#ff6600);
      position:relative;overflow:hidden;
    }
    .top::after{
      content:'';position:absolute;inset:0;
      background:linear-gradient(90deg,#6600cc,#cc0066,#ff6600);
      background-size:200%;animation:gradSlide 4s linear infinite;
      opacity:0.5;
    }
    @keyframes gradSlide{from{background-position:0%}to{background-position:200%}}
    .top-logo{font-family:'Righteous',cursive;font-size:30px;letter-spacing:4px;color:#fff;z-index:1;text-shadow:0 0 20px rgba(255,255,255,0.5);}
    .top-right{z-index:1;text-align:right;}
    .top-time{font-family:'Courier Prime',monospace;font-size:22px;color:#fff;}
    .top-loc{font-size:12px;color:rgba(255,255,255,0.6);letter-spacing:2px;}

    /* TOP ROW: media left + specials right */
    .row1{
      display:grid;grid-template-columns:1fr 360px;gap:3px;
    }
    .media-main{background:#000;position:relative;overflow:hidden;}
    #mediaContainer{width:100%;height:100%;position:relative;}
    #mediaContainer img,#mediaContainer video{width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0;}
    .loading-msg{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:#000;}
    .loading-msg span{font-family:'Righteous',cursive;font-size:3rem;color:rgba(102,0,204,0.4);}

    /* Gradient overlay on media */
    .media-main::after{
      content:'';position:absolute;inset:0;pointer-events:none;
      background:linear-gradient(135deg,rgba(102,0,204,0.25) 0%,transparent 50%,rgba(204,0,102,0.2) 100%);
    }

    .specials-panel{
      background:rgba(0,0,0,0.7);
      backdrop-filter:blur(10px);
      border:1px solid rgba(255,255,255,0.08);
      padding:16px;display:flex;flex-direction:column;gap:8px;
      overflow:hidden;
    }
    .sp-header{font-family:'Righteous',cursive;font-size:14px;letter-spacing:3px;color:#cc0066;margin-bottom:4px;}
    .special-card{
      background:rgba(255,255,255,0.04);
      border:1px solid rgba(255,255,255,0.07);
      border-radius:4px;padding:10px 12px;
      display:flex;justify-content:space-between;align-items:center;
      flex:1;
    }
    .sc-info{}
    .sc-name{font-size:16px;color:#fff;font-weight:900;}
    .sc-desc{font-size:11px;color:rgba(255,255,255,0.35);margin-top:2px;font-family:'Courier Prime',monospace;}
    .sc-price{font-family:'Courier Prime',monospace;font-size:22px;color:#ff6600;font-weight:700;}

    /* BOTTOM ROW: 4 equal info panels */
    .row2{
      display:grid;grid-template-columns:repeat(4,1fr);gap:3px;
    }
    .info-panel{
      background:rgba(0,0,0,0.6);
      border:1px solid rgba(255,255,255,0.06);
      padding:14px;display:flex;flex-direction:column;justify-content:center;align-items:center;
      text-align:center;gap:6px;position:relative;overflow:hidden;
    }
    .info-panel::before{
      content:'';position:absolute;top:0;left:0;right:0;height:2px;
    }
    .ip1::before{background:linear-gradient(90deg,#6600cc,#cc0066);}
    .ip2::before{background:linear-gradient(90deg,#cc0066,#ff6600);}
    .ip3::before{background:linear-gradient(90deg,#ff6600,#ffcc00);}
    .ip4::before{background:linear-gradient(90deg,#ffcc00,#6600cc);}
    .ip-big{font-family:'Righteous',cursive;font-size:clamp(1.4rem,2.5vw,2.5rem);color:#fff;line-height:1;}
    .ip-label{font-family:'Courier Prime',monospace;font-size:10px;letter-spacing:3px;color:rgba(255,255,255,0.3);}

    /* TICKER BOTTOM */
    .ticker{
      background:#000;border-top:2px solid rgba(255,255,255,0.06);
      overflow:hidden;display:flex;align-items:center;
    }
    .t-tag{font-family:'Righteous',cursive;font-size:13px;letter-spacing:3px;padding:0 14px;color:#000;background:linear-gradient(90deg,#cc0066,#ff6600);height:100%;display:flex;align-items:center;flex-shrink:0;white-space:nowrap;}
    .t-track{display:flex;animation:tickerScroll 28s linear infinite;white-space:nowrap;}
    @keyframes tickerScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .t-item{padding:0 36px;font-family:'Courier Prime',monospace;font-size:14px;color:rgba(255,255,255,0.4);}
    .t-item strong{color:#ff6600;}
  
    .qr-info-panel{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;padding:10px;background:#0a0020;border:1px solid rgba(102,0,204,0.4);}
    .qr-block-box{background:#fff;padding:5px;border-radius:3px;width:84px;height:84px;display:flex;align-items:center;justify-content:center;}
    .qr-block-label{font-family:'DM Mono',monospace;font-size:8px;letter-spacing:1px;color:rgba(204,0,102,0.9);text-align:center;text-transform:uppercase;max-width:90px;line-height:1.3;}
  </style>
</head>
<body>
<div class="shell">
  <div class="top">
    <div class="top-logo">GRAFFITI TV</div>
    <div class="top-right">
      <div class="top-time" id="clock">--:--:--</div>
      <div class="top-loc">DENTON · TEXAS</div>
    </div>
  </div>

  <div class="row1">
    <div class="media-main">
      <div id="mediaContainer"><div class="loading-msg"><span>GFTV</span></div></div>
    </div>
    <div class="specials-panel">
      <div class="sp-header">// TONIGHT'S MENU</div>
      <div class="special-card"><div class="sc-info"><div class="sc-name">Truffle Pasta</div><div class="sc-desc">black truffle · parm · butter</div></div><div class="sc-price">$24.99</div></div>
      <div class="special-card"><div class="sc-info"><div class="sc-name">Carbonara</div><div class="sc-desc">guanciale · egg yolk · pecorino</div></div><div class="sc-price">$19.99</div></div>
      <div class="special-card"><div class="sc-info"><div class="sc-name">Cacio e Pepe</div><div class="sc-desc">tonnarelli · pecorino · pepper</div></div><div class="sc-price">$17.99</div></div>
      <div class="special-card"><div class="sc-info"><div class="sc-name">Bolognese</div><div class="sc-desc">slow-braised beef & pork</div></div><div class="sc-price">$21.99</div></div>
    </div>

  <div class="row2">
    <div class="info-panel ip1">
      <div class="ip-big">4–7PM</div>
      <div class="ip-label">HAPPY HOUR DAILY</div>
    </div>
    <div class="info-panel ip2">
      <div class="ip-big">$5</div>
      <div class="ip-label">NEGRONI HAPPY HOUR</div>
    </div>
    <div class="info-panel ip3">
      <div class="ip-big">FRI</div>
      <div class="ip-label">LIVE MUSIC NIGHTS</div>
    </div>
    <div class="info-panel ip4">
      <div class="ip-big" id="clock2" style="font-size:1.8rem">--:--</div>
      <div class="ip-label">LOCAL TIME</div>
    </div>
    <div class="qr-info-panel"><div class="qr-block-box"><div id="qr-code"></div></div><div class="qr-block-label" id="qr-label">Scan for offer</div></div>
  </div>

  <div class="ticker">
    <div class="t-tag">GRAFFITI PASTA</div>
    <div class="t-track">
      <span class="t-item"><strong>Carbonara</strong> $19.99</span><span class="t-item"><strong>Truffle Pasta</strong> $24.99</span><span class="t-item"><strong>Cacio e Pepe</strong> $17.99</span><span class="t-item"><strong>Bolognese</strong> $21.99</span><span class="t-item"><strong>Arrabbiata</strong> $16.99</span><span class="t-item">Happy Hour 4–7pm · Negroni $5</span><span class="t-item">Live Music Every Friday Night</span><span class="t-item">Wood-Fired Pizza Nightly · $14.99</span>
      <span class="t-item"><strong>Carbonara</strong> $19.99</span><span class="t-item"><strong>Truffle Pasta</strong> $24.99</span><span class="t-item"><strong>Cacio e Pepe</strong> $17.99</span><span class="t-item"><strong>Bolognese</strong> $21.99</span><span class="t-item"><strong>Arrabbiata</strong> $16.99</span><span class="t-item">Happy Hour 4–7pm · Negroni $5</span><span class="t-item">Live Music Every Friday Night</span><span class="t-item">Wood-Fired Pizza Nightly · $14.99</span>
    </div>
  </div>
</div>
<script>
  function tick(){const t=new Date();const ts=t.toLocaleTimeString('en-US',{hour12:false});document.getElementById('clock').textContent=ts;document.getElementById('clock2').textContent=ts.substring(0,5);}
  setInterval(tick,1000);tick();
  let ml=[],idx=0;
  async function load(){try{const r=await fetch('/api/linode/media');const d=await r.json();if(d.success&&d.media?.length){ml=d.media;play();}else fb();}catch(e){fb();}}
  function fb(){document.getElementById('mediaContainer').innerHTML=`<iframe src="https://www.youtube.com/embed/86YLFOog4GM?autoplay=1&mute=1&controls=0&loop=1&playlist=86YLFOog4GM" frameborder="0" allow="autoplay" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>`;}
  function play(){const c=document.getElementById('mediaContainer');const m=ml[idx];c.innerHTML='';if(m.type==='video'){const v=document.createElement('video');v.src=m.url;v.autoplay=v.muted=v.loop=true;v.style.cssText='width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0';c.appendChild(v);}else{const i=document.createElement('img');i.src=m.url;i.style.cssText='width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0';i.onerror=next;c.appendChild(i);setTimeout(next,15000);}}
  function next(){idx=(idx+1)%ml.length;play();}
  document.addEventListener('DOMContentLoaded',load);
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
(async()=>{
  try{
    const slug=window.location.pathname.split('/')[2];
    const d=await fetch('/api/'+slug+'/offering').then(r=>r.json());
    if(!d.url)return;
    const lbl=document.getElementById('qr-label');if(lbl)lbl.textContent=d.title||'Scan for offer';
    const box=document.getElementById('qr-code');if(box)new QRCode(box,{text:d.url,width:84,height:84,colorDark:'#000',colorLight:'#fff',correctLevel:QRCode.CorrectLevel.M});
  }catch(e){}
})();
</script>
</body></html>
