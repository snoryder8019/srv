<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= tenant.branding.name %> — Live Display</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    html,body{width:100%;height:100%;overflow:hidden;background:#000;}
    iframe{width:100%;height:100%;border:none;display:block;position:absolute;top:0;left:0;}

    /* Fade overlay */
    #overlay{position:fixed;inset:0;background:#000;z-index:9999;opacity:0;pointer-events:none;transition:opacity 0.7s ease;}
    #overlay.fading{opacity:1;}

    /* Theme tag */
    #themeTag{position:fixed;bottom:8px;right:12px;font-family:monospace;font-size:9px;letter-spacing:2px;color:rgba(255,255,255,0.08);z-index:10000;pointer-events:none;}

    /* Back arrow — top left */
    #backBtn{
      position:fixed;top:16px;left:16px;z-index:10001;
      width:44px;height:44px;border-radius:50%;
      background:rgba(0,0,0,0.45);backdrop-filter:blur(6px);
      border:1.5px solid rgba(255,255,255,0.18);
      display:flex;align-items:center;justify-content:center;
      cursor:pointer;opacity:0;transition:opacity 0.3s ease;
      -webkit-tap-highlight-color:transparent;
      touch-action:manipulation;
    }
    #backBtn svg{width:18px;height:18px;fill:none;stroke:#fff;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round;}

    /* Show back arrow on touch/hover */
    body.show-nav #backBtn{opacity:1;}

    /* Invisible tap zone — right 85% of screen advances, left 15% goes back */
    #tapNext{position:fixed;top:0;left:15%;width:85%;height:100%;z-index:10000;cursor:pointer;-webkit-tap-highlight-color:transparent;touch-action:manipulation;}
    #tapPrev{position:fixed;top:0;left:0;width:15%;height:100%;z-index:10000;cursor:pointer;-webkit-tap-highlight-color:transparent;touch-action:manipulation;}
  </style>
</head>
<body>
  <div id="overlay"></div>
  <iframe id="themeFrame" src="/theme/<%= tenant.slug %>/1" allowfullscreen></iframe>
  <div id="themeTag">1/15</div>

  <!-- Back arrow button -->
  <button id="backBtn" aria-label="Previous template" title="Previous">
    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
  </button>

  <!-- Tap zones (invisible) -->
  <div id="tapNext" aria-hidden="true"></div>
  <div id="tapPrev" aria-hidden="true"></div>

<script>
  const ORDER  = <%- JSON.stringify(shuffled) %>;
  const TOTAL  = <%= total %>;
  const TENANT = '<%= tenant.slug %>';
  const INTERVAL = 10 * 60 * 1000;
  let pos = 0;
  let switching = false;

  function switchTheme(dir) {
    if (switching) return;
    switching = true;
    const overlay = document.getElementById('overlay');
    const frame   = document.getElementById('themeFrame');
    const tag     = document.getElementById('themeTag');
    overlay.classList.add('fading');
    setTimeout(() => {
      pos = ((pos + dir) + ORDER.length) % ORDER.length;
      const id = ORDER[pos];
      frame.src = `/theme/${TENANT}/${id}`;
      tag.textContent = `${id}/${TOTAL}`;
      frame.onload = () => setTimeout(() => { overlay.classList.remove('fading'); switching = false; }, 150);
      setTimeout(() => { overlay.classList.remove('fading'); switching = false; }, 2500);
    }, 750);
  }

  // Auto-advance
  setInterval(() => switchTheme(1), INTERVAL);

  // Keyboard
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight' || e.key === ' ') switchTheme(1);
    if (e.key === 'ArrowLeft')                   switchTheme(-1);
  });

  // Tap zones
  document.getElementById('tapNext').addEventListener('click', () => switchTheme(1));
  document.getElementById('tapPrev').addEventListener('click', () => switchTheme(-1));

  // Back button
  document.getElementById('backBtn').addEventListener('click', e => {
    e.stopPropagation();
    switchTheme(-1);
  });

  // Show nav briefly on any touch/tap, then fade
  let navTimer;
  function showNav() {
    document.body.classList.add('show-nav');
    clearTimeout(navTimer);
    navTimer = setTimeout(() => document.body.classList.remove('show-nav'), 3000);
  }
  document.addEventListener('touchstart', showNav, { passive: true });
  document.addEventListener('mousemove', showNav, { passive: true });
</script>
</body>
</html>
