<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= tenant.branding.name %> — Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#09090b;--panel:#111113;--border:#1e1e22;--accent:<%- tenant.branding.color || '#ff5000' %>;--text:#e8e8e8;--dim:#555;--green:#00cc88;--red:#cc1100;}
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:var(--bg);color:var(--text);font-family:'IBM Plex Mono',monospace;min-height:100vh;}
    .layout{display:grid;grid-template-columns:220px 1fr;min-height:100vh;}
    .sidebar{background:#000;border-right:1px solid var(--border);display:flex;flex-direction:column;padding:0;}
    .sb-header{padding:20px;border-bottom:1px solid var(--border);}
    .sb-logo{font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:3px;color:var(--accent);}
    .sb-tenant{font-size:10px;letter-spacing:2px;color:var(--dim);margin-top:4px;}
    .sb-plan{display:inline-block;margin-top:8px;background:var(--accent);color:#000;font-size:9px;padding:2px 8px;letter-spacing:2px;}
    nav{flex:1;padding:12px 0;}
    .nav-item{display:flex;align-items:center;gap:10px;padding:11px 20px;font-size:12px;letter-spacing:1px;color:var(--dim);cursor:pointer;border-left:3px solid transparent;}
    .nav-item:hover{color:var(--text);background:rgba(255,255,255,0.02);}
    .nav-item.active{color:var(--accent);border-left-color:var(--accent);}
    .sb-bottom{padding:16px 20px;border-top:1px solid var(--border);font-size:10px;color:var(--dim);}
    .live-dot{width:7px;height:7px;border-radius:50%;background:var(--green);display:inline-block;margin-right:6px;animation:blink 1.5s step-end infinite;}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:0.2}}

    .main{padding:28px;overflow-y:auto;}
    .page{display:none;} .page.active{display:block;}
    .page-title{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:3px;margin-bottom:2px;}
    .page-sub{font-size:10px;letter-spacing:3px;color:var(--dim);margin-bottom:24px;}

    /* AUTH */
    .auth-wrap{display:flex;align-items:center;justify-content:center;min-height:100vh;background:var(--bg);}
    .auth-box{background:var(--panel);border:1px solid var(--border);padding:40px;width:360px;text-align:center;}
    .auth-logo{font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:4px;color:var(--accent);margin-bottom:4px;}
    .auth-name{font-size:11px;letter-spacing:3px;color:var(--dim);margin-bottom:24px;}
    .auth-input{width:100%;background:var(--bg);border:1px solid var(--border);color:var(--text);padding:12px;font-family:'IBM Plex Mono',monospace;font-size:14px;margin-bottom:12px;letter-spacing:2px;outline:none;}
    .auth-btn{width:100%;background:var(--accent);color:#000;border:none;padding:12px;font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:3px;cursor:pointer;}
    .auth-err{color:var(--red);font-size:12px;margin-top:8px;min-height:18px;}

    /* STATS */
    .stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:20px;}
    .stat{background:var(--panel);border:1px solid var(--border);padding:18px;text-align:center;}
    .stat-num{font-family:'Bebas Neue',sans-serif;font-size:2.5rem;color:var(--accent);line-height:1;}
    .stat-lbl{font-size:9px;letter-spacing:3px;color:var(--dim);margin-top:3px;}

    /* CARDS & TABLES */
    .card{background:var(--panel);border:1px solid var(--border);padding:18px;margin-bottom:14px;}
    .card-title{font-size:9px;letter-spacing:4px;color:var(--dim);margin-bottom:14px;}
    table{width:100%;border-collapse:collapse;font-size:12px;}
    th{text-align:left;padding:7px 10px;font-size:9px;letter-spacing:3px;color:var(--dim);border-bottom:1px solid var(--border);}
    td{padding:9px 10px;border-bottom:1px solid rgba(255,255,255,0.03);vertical-align:middle;}
    tr:hover td{background:rgba(255,255,255,0.015);}
    .badge{display:inline-block;padding:2px 7px;font-size:9px;letter-spacing:1px;}
    .badge-on{background:rgba(0,204,136,0.12);color:var(--green);border:1px solid rgba(0,204,136,0.2);}
    .badge-off{background:rgba(204,17,0,0.1);color:var(--red);border:1px solid rgba(204,17,0,0.2);}

    /* FORMS */
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;}
    .field{display:flex;flex-direction:column;gap:4px;}
    .field label{font-size:9px;letter-spacing:3px;color:var(--dim);}
    .field input,.field textarea{background:var(--bg);border:1px solid var(--border);color:var(--text);padding:9px 10px;font-family:'IBM Plex Mono',monospace;font-size:12px;outline:none;}
    .field input:focus,.field textarea:focus{border-color:#333;}
    .field textarea{resize:vertical;min-height:56px;}

    /* BUTTONS */
    .btn{display:inline-flex;align-items:center;padding:7px 14px;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:1px;cursor:pointer;border:none;}
    .btn-acc{background:var(--accent);color:#000;}
    .btn-del{background:var(--red);color:#fff;}
    .btn-tog{background:transparent;color:var(--dim);border:1px solid var(--border);}
    .btn-sm{padding:3px 9px;font-size:10px;}
    .btns{display:flex;gap:5px;}

    /* ANALYTICS */
    .bar-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
    .bar-lbl{width:160px;font-size:11px;color:var(--dim);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
    .bar-wrap{flex:1;height:6px;background:var(--border);}
    .bar-fill{height:100%;background:var(--accent);}
    .bar-val{width:32px;text-align:right;font-size:11px;}

    /* TOAST */
    #toast{position:fixed;bottom:20px;right:20px;background:var(--green);color:#000;padding:10px 18px;font-size:12px;letter-spacing:1px;z-index:9999;display:none;}
    #toast.show{display:block;}

    /* COMING SOON */
    .cs{text-align:center;padding:80px 20px;}
    .cs-icon{font-size:3.5rem;margin-bottom:16px;}
    .cs-title{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:4px;margin-bottom:8px;}
    .cs-sub{font-size:12px;color:var(--dim);letter-spacing:1px;}
  </style>
</head>
<body>

<div id="authWrap" class="auth-wrap">
  <div class="auth-box">
    <div class="auth-logo"><%- tenant.branding.name.toUpperCase().split(' ')[0] %> TV</div>
    <div class="auth-name"><%- tenant.branding.name %> · Admin Panel</div>
    <input class="auth-input" type="password" id="passInput" placeholder="ENTER PASSWORD" onkeydown="if(event.key==='Enter')login()">
    <button class="auth-btn" onclick="login()">ENTER →</button>
    <div class="auth-err" id="authErr"></div>
  </div>
</div>

<div class="layout" id="appLayout" style="display:none">
  <div class="sidebar">
    <div class="sb-header">
      <div class="sb-logo">GFTV</div>
      <div class="sb-tenant"><%- tenant.branding.name %></div>
      <div class="sb-plan"><%- (plans[tenant.plan]||{}).label || tenant.plan %></div>
    </div>
    <nav>
      <div class="nav-item active" onclick="goto('dash')">📊 Dashboard</div>
      <div class="nav-item" onclick="goto('menu')">🍝 Menu</div>
      <div class="nav-item" onclick="goto('specials')">⭐ Specials</div>
      <div class="nav-item" onclick="goto('events')">📅 Events</div>
      <div class="nav-item" onclick="goto('offerings')">🎁 QR Offers</div>
      <div class="nav-item" onclick="goto('subscribers')">📧 Subscribers</div>
      <div class="nav-item" onclick="goto('analytics')">📈 Analytics</div>
      <div class="nav-item" onclick="goto('broadcast')">📡 Broadcast</div>
    </nav>
    <div class="sb-bottom">
      <div><span class="live-dot"></span>LIVE DISPLAY</div>
      <div style="margin-top:6px"><a href="/tv/<%- tenant.slug %>" target="_blank" style="color:var(--dim);text-decoration:none;font-size:10px;letter-spacing:1px;">VIEW DISPLAY →</a></div>
    </div>
  </div>

  <div class="main">
    <div id="toast"></div>

    <div class="page active" id="page-dash">
      <div class="page-title">Dashboard</div>
      <div class="page-sub"><%- tenant.branding.name.toUpperCase() %> · <%- tenant.branding.location||'' %></div>
      <div class="stats-row" id="dashStats"></div>
      <div class="card"><div class="card-title">UPCOMING EVENTS</div><div id="dashEvents"></div></div>
    </div>

    <div class="page" id="page-menu">
      <div class="page-title">Menu</div><div class="page-sub">MANAGE YOUR MENU ITEMS</div>
      <div class="card">
        <div class="card-title">ADD ITEM</div>
        <div class="form-row"><div class="field"><label>NAME</label><input id="m-name" placeholder="Carbonara"></div><div class="field"><label>PRICE ($)</label><input id="m-price" type="number" step="0.01" placeholder="19.99"></div></div>
        <div class="field" style="margin-bottom:10px"><label>DESCRIPTION</label><input id="m-desc" placeholder="Guanciale, egg yolk, pecorino..."></div>
        <button class="btn btn-acc" onclick="add('menu')">+ ADD</button>
      </div>
      <div class="card"><div class="card-title">ALL ITEMS</div><table><thead><tr><th>NAME</th><th>DESC</th><th>PRICE</th><th>STATUS</th><th>ACTIONS</th></tr></thead><tbody id="tb-menu"></tbody></table></div>
    </div>

    <div class="page" id="page-specials">
      <div class="page-title">Specials</div><div class="page-sub">TONIGHT'S FEATURED ITEMS</div>
      <div class="card">
        <div class="card-title">ADD SPECIAL</div>
        <div class="form-row"><div class="field"><label>NAME</label><input id="s-name" placeholder="Truffle Pasta"></div><div class="field"><label>PRICE ($)</label><input id="s-price" type="number" step="0.01" placeholder="24.99"></div></div>
        <div class="field" style="margin-bottom:10px"><label>DESCRIPTION</label><input id="s-desc" placeholder="Chef's pick tonight..."></div>
        <button class="btn btn-acc" onclick="add('specials')">+ ADD</button>
      </div>
      <div class="card"><div class="card-title">CURRENT SPECIALS</div><table><thead><tr><th>NAME</th><th>DESC</th><th>PRICE</th><th>STATUS</th><th>ACTIONS</th></tr></thead><tbody id="tb-specials"></tbody></table></div>
    </div>

    <div class="page" id="page-events">
      <div class="page-title">Events</div><div class="page-sub">CALENDAR & UPCOMING EVENTS</div>
      <div class="card">
        <div class="card-title">ADD EVENT</div>
        <div class="form-row"><div class="field"><label>TITLE</label><input id="e-title" placeholder="Live Music Night"></div><div class="field"><label>DATE</label><input id="e-date" type="date"></div></div>
        <div class="form-row"><div class="field"><label>TIME</label><input id="e-time" placeholder="8:00 PM"></div><div class="field"><label>DESCRIPTION</label><input id="e-desc" placeholder="Live band, great food..."></div></div>
        <button class="btn btn-acc" onclick="add('events')">+ ADD</button>
      </div>
      <div class="card"><div class="card-title">ALL EVENTS</div><table><thead><tr><th>TITLE</th><th>DATE</th><th>TIME</th><th>DESC</th><th>STATUS</th><th>ACTIONS</th></tr></thead><tbody id="tb-events"></tbody></table></div>
    </div>

    <div class="page" id="page-offerings">
      <div class="page-title">QR Offers</div><div class="page-sub">PROMOTIONS SHOWN WITH QR CODES ON DISPLAY</div>
      <div class="card">
        <div class="card-title">ADD OFFERING</div>
        <div class="form-row"><div class="field"><label>TITLE</label><input id="o-title" placeholder="Free Aperol Spritz"></div><div class="field"><label>CODE</label><input id="o-code" placeholder="SPRITZ4U"></div></div>
        <div class="field" style="margin-bottom:10px"><label>DESCRIPTION</label><input id="o-desc" placeholder="With any pasta order, Mon–Thu"></div>
        <button class="btn btn-acc" onclick="add('offerings')">+ ADD</button>
      </div>
      <div class="card"><div class="card-title">ACTIVE OFFERS</div><table><thead><tr><th>TITLE</th><th>CODE</th><th>DESC</th><th>STATUS</th><th>ACTIONS</th></tr></thead><tbody id="tb-offerings"></tbody></table></div>
    </div>

    <div class="page" id="page-subscribers">
      <div class="page-title">Subscribers</div><div class="page-sub">EMAIL LIST</div>
      <div class="stats-row"><div class="stat"><div class="stat-num" id="subCount">0</div><div class="stat-lbl">SUBSCRIBERS</div></div></div>
      <div class="card"><div class="card-title">ALL SUBSCRIBERS</div><table><thead><tr><th>EMAIL</th><th>NAME</th><th>DATE</th></tr></thead><tbody id="tb-subs"></tbody></table></div>
    </div>

    <div class="page" id="page-analytics">
      <div class="page-title">Analytics</div><div class="page-sub">THEME VIEWS & ENGAGEMENT</div>
      <div class="stats-row" id="aStats"></div>
      <div class="card"><div class="card-title">THEME VIEW COUNTS</div><div id="themeChart"></div></div>
    </div>

    <div class="page" id="page-broadcast">
      <div class="cs"><div class="cs-icon">📡</div><div class="cs-title">Live Broadcast</div><div class="cs-sub">Stream management and live overlay controls coming soon.</div></div>
    </div>
  </div>
</div>

<script>
const TENANT='<%- tenant.slug %>';
const THEME_NAMES={1:'VHS Underground',2:'Rave Mode',3:'Retro Diner',4:'Brutalist',5:'Vaporwave',6:'Newsroom',7:'Split Screen',8:'Cinema',9:'Polaroid Board',10:'Neon Grid',11:'Horizontal',12:'Typewriter',13:'Tiles',14:'Minimal',15:'Stadium'};
let PASS='', DATA={};

function login(){
  PASS=document.getElementById('passInput').value;
  fetch(`/api/admin/${TENANT}/data`,{headers:{'x-tenant-pass':PASS}})
    .then(r=>{if(!r.ok)throw new Error();return r.json();})
    .then(d=>{DATA=d;document.getElementById('authWrap').style.display='none';document.getElementById('appLayout').style.display='grid';render();})
    .catch(()=>{document.getElementById('authErr').textContent='Incorrect password.';});
}

function goto(p){
  document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(x=>x.classList.remove('active'));
  document.getElementById('page-'+p).classList.add('active');
  event.currentTarget.classList.add('active');
  refresh();
}

async function refresh(){
  const d=await fetch(`/api/admin/${TENANT}/data`,{headers:{'x-tenant-pass':PASS}}).then(r=>r.json());
  DATA=d; render();
}

function render(){
  // Dashboard
  const stats=[
    {n:(DATA.menu||[]).filter(x=>x.active).length,l:'MENU ITEMS'},
    {n:(DATA.events||[]).filter(x=>x.active).length,l:'EVENTS'},
    {n:(DATA.offerings||[]).filter(x=>x.active).length,l:'QR OFFERS'},
    {n:(DATA.subscribers||[]).length,l:'SUBSCRIBERS'},
  ];
  document.getElementById('dashStats').innerHTML=stats.map(s=>`<div class="stat"><div class="stat-num">${s.n}</div><div class="stat-lbl">${s.l}</div></div>`).join('');
  const evs=(DATA.events||[]).filter(x=>x.active).slice(0,5);
  document.getElementById('dashEvents').innerHTML=evs.length
    ?`<table><thead><tr><th>TITLE</th><th>DATE</th><th>TIME</th></tr></thead><tbody>${evs.map(e=>`<tr><td>${e.title}</td><td>${e.date}</td><td>${e.time||'-'}</td></tr>`).join('')}</tbody></table>`
    :'<div style="color:var(--dim);font-size:12px;padding:8px 0">No upcoming events</div>';

  // Tables
  renderTbl('menu',['name','desc','price'],(DATA.menu||[]));
  renderTbl('specials',['name','desc','price'],(DATA.specials||[]));
  renderEvents(DATA.events||[]);
  renderTbl('offerings',['title','code','desc'],(DATA.offerings||[]));

  // Subscribers
  const subs=DATA.subscribers||[];
  document.getElementById('subCount').textContent=subs.length;
  document.getElementById('tb-subs').innerHTML=subs.map(s=>`<tr><td>${s.email}</td><td>${s.name||'-'}</td><td style="color:var(--dim)">${new Date(s.date).toLocaleDateString()}</td></tr>`).join('');

  // Analytics
  const themes=DATA.analytics?.themes||{};
  const total=Object.values(themes).reduce((a,b)=>a+b,0);
  document.getElementById('aStats').innerHTML=`<div class="stat"><div class="stat-num">${total}</div><div class="stat-lbl">TOTAL VIEWS</div></div><div class="stat"><div class="stat-num">${subs.length}</div><div class="stat-lbl">SUBSCRIBERS</div></div>`;
  const max=Math.max(...Object.values(themes),1);
  document.getElementById('themeChart').innerHTML=Object.entries(themes).sort((a,b)=>b[1]-a[1]).map(([id,c])=>`<div class="bar-row"><div class="bar-lbl">${THEME_NAMES[id]||'Theme '+id}</div><div class="bar-wrap"><div class="bar-fill" style="width:${Math.round(c/max*100)}%"></div></div><div class="bar-val">${c}</div></div>`).join('')||'<div style="color:var(--dim);font-size:12px">No data yet</div>';
}

function renderTbl(col, fields, items){
  const tb=document.getElementById('tb-'+col);if(!tb)return;
  tb.innerHTML=items.map(item=>`<tr>${fields.map(f=>`<td>${f==='price'?'$'+parseFloat(item[f]||0).toFixed(2):item[f]||''}</td>`).join('')}<td><span class="badge ${item.active?'badge-on':'badge-off'}">${item.active?'ON':'OFF'}</span></td><td><div class="btns"><button class="btn btn-tog btn-sm" onclick="tog('${col}',${item.id},${!item.active})">${item.active?'HIDE':'SHOW'}</button><button class="btn btn-del btn-sm" onclick="del('${col}',${item.id})">DEL</button></div></td></tr>`).join('');
}
function renderEvents(items){
  const tb=document.getElementById('tb-events');if(!tb)return;
  tb.innerHTML=items.map(item=>`<tr><td>${item.title}</td><td>${item.date}</td><td>${item.time||'-'}</td><td style="color:var(--dim)">${item.desc||''}</td><td><span class="badge ${item.active?'badge-on':'badge-off'}">${item.active?'ON':'OFF'}</span></td><td><div class="btns"><button class="btn btn-tog btn-sm" onclick="tog('events',${item.id},${!item.active})">${item.active?'HIDE':'SHOW'}</button><button class="btn btn-del btn-sm" onclick="del('events',${item.id})">DEL</button></div></td></tr>`).join('');
}

async function add(col){
  let body={};
  if(col==='menu')      body={name:v('m-name'),desc:v('m-desc'),price:parseFloat(v('m-price'))};
  if(col==='specials')  body={name:v('s-name'),desc:v('s-desc'),price:parseFloat(v('s-price'))};
  if(col==='events')    body={title:v('e-title'),date:v('e-date'),time:v('e-time'),desc:v('e-desc')};
  if(col==='offerings') body={title:v('o-title'),code:v('o-code'),desc:v('o-desc')};
  await fetch(`/api/admin/${TENANT}/${col}`,{method:'POST',headers:{'Content-Type':'application/json','x-tenant-pass':PASS},body:JSON.stringify(body)});
  toast('✓ Added');await refresh();
}
async function tog(col,id,active){
  await fetch(`/api/admin/${TENANT}/${col}/${id}`,{method:'PUT',headers:{'Content-Type':'application/json','x-tenant-pass':PASS},body:JSON.stringify({active})});
  toast(active?'✓ Shown':'✓ Hidden');await refresh();
}
async function del(col,id){
  if(!confirm('Delete?'))return;
  await fetch(`/api/admin/${TENANT}/${col}/${id}`,{method:'DELETE',headers:{'x-tenant-pass':PASS}});
  toast('✓ Deleted');await refresh();
}
function v(id){return document.getElementById(id)?.value||'';}
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2200);}
</script>
</body>
</html>
