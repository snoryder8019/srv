<!DOCTYPE html>
<html lang="en">
<head>
  <title>Graffiti TV &mdash; MadLads Lab</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Graffiti TV — dynamic, rotating TV displays for restaurants, bars, and venues. A MadLads Lab product.">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;600;800;900&family=DM+Mono&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#09090b;--panel:#111113;--border:#1e1e22;--accent:#ff5000;--gold:#f5c400;--text:#e8e8e8;--dim:#6e6e72;}
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;overflow-x:hidden;}
    a{color:inherit;text-decoration:none;}

    /* Nav */
    nav.top{display:flex;align-items:center;justify-content:space-between;padding:18px 40px;border-bottom:1px solid var(--border);background:rgba(9,9,11,0.9);backdrop-filter:blur(10px);position:sticky;top:0;z-index:100;}
    .nav-logo{font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:4px;color:var(--accent);}
    .nav-logo span{color:var(--text);}
    .nav-right{display:flex;gap:22px;align-items:center;font-family:'DM Mono',monospace;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--dim);}
    .nav-right a{transition:color 0.2s;}
    .nav-right a:hover{color:var(--text);}
    .nav-right .ext{color:var(--accent);}

    /* Hero — split: copy + live preview */
    .hero{max-width:1240px;margin:0 auto;padding:70px 40px 50px;display:grid;grid-template-columns:1fr 1.1fr;gap:60px;align-items:center;}
    .hero-eyebrow{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:4px;color:var(--accent);margin-bottom:18px;}
    .hero-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(3.2rem,6vw,5.6rem);line-height:0.95;letter-spacing:-1px;margin-bottom:22px;}
    .hero-title span{color:var(--accent);}
    .hero-lead{font-size:17px;color:#bcbcc0;line-height:1.6;margin-bottom:18px;}
    .hero-desc{font-size:14px;color:var(--dim);line-height:1.7;margin-bottom:30px;}
    .hero-cta{display:flex;gap:12px;flex-wrap:wrap;}
    .btn{padding:13px 26px;font-weight:700;font-size:13px;letter-spacing:2px;display:inline-block;transition:all 0.2s;text-transform:uppercase;}
    .btn-primary{background:var(--accent);color:#fff;}
    .btn-primary:hover{background:#ff6a1f;transform:translateY(-1px);}
    .btn-ghost{background:transparent;color:var(--text);border:1px solid var(--border);}
    .btn-ghost:hover{border-color:var(--accent);color:var(--accent);}
    .hero-note{margin-top:14px;font-size:11px;color:var(--dim);font-family:'DM Mono',monospace;letter-spacing:2px;text-transform:uppercase;}

    /* TV preview frame */
    .tv-frame{position:relative;aspect-ratio:16/10;background:#000;border:2px solid #1c1c1e;border-radius:6px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,0.7),0 0 0 1px #2a2a2e;}
    .tv-frame iframe{position:absolute;inset:0;width:100%;height:100%;border:none;display:block;}
    .tv-overlay{position:absolute;inset:0;background:radial-gradient(ellipse at center,transparent 60%,rgba(0,0,0,0.35) 100%);pointer-events:none;}
    .tv-scanlines{position:absolute;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.06) 2px,rgba(0,0,0,0.06) 4px);pointer-events:none;}
    .tv-corner{position:absolute;top:10px;left:12px;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:2px;color:rgba(255,255,255,0.5);background:rgba(0,0,0,0.55);padding:3px 8px;border-radius:2px;}
    .tv-corner .dot{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--accent);margin-right:6px;animation:pulse 2s ease infinite;vertical-align:middle;}
    @keyframes pulse{0%,100%{opacity:0.4;}50%{opacity:1;}}
    .tv-badge{position:absolute;bottom:10px;right:12px;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:2px;color:rgba(255,255,255,0.45);background:rgba(0,0,0,0.55);padding:3px 8px;border-radius:2px;}

    /* About strip */
    .about{padding:60px 40px;background:var(--panel);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
    .about-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:32px;}
    .about-card h3{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:2px;color:var(--text);margin-bottom:8px;}
    .about-card .num{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:2px;color:var(--accent);margin-bottom:12px;display:block;}
    .about-card p{font-size:13px;color:var(--dim);line-height:1.7;}

    /* Footer */
    footer{padding:30px 40px;display:flex;justify-content:space-between;align-items:center;font-family:'DM Mono',monospace;font-size:11px;letter-spacing:2px;color:var(--dim);text-transform:uppercase;}
    footer a{color:var(--accent);}
    footer a:hover{color:#ff7a3a;}

    @media(max-width:900px){
      nav.top{padding:14px 20px;}
      .hero{grid-template-columns:1fr;padding:50px 20px 30px;gap:36px;}
      .about{padding:50px 20px;}
      .about-inner{grid-template-columns:1fr;gap:24px;}
      footer{padding:24px 20px;flex-direction:column;gap:10px;text-align:center;}
    }
  </style>
</head>
<body>

<nav class="top">
  <div class="nav-logo">GRAFFITI<span>TV</span></div>
  <div class="nav-right">
    <a href="/tv/graffiti-pasta" target="_blank">View Display →</a>
    <a href="https://madladslab.com" target="_blank" rel="noopener" class="ext">madladslab.com ↗</a>
  </div>
</nav>

<section class="hero">
  <div class="hero-copy">
    <div class="hero-eyebrow">A MADLADS LAB PRODUCT</div>
    <h1 class="hero-title">Your Venue.<br><span>On Screen.</span></h1>
    <p class="hero-lead">Graffiti TV runs dynamic, always-on displays for restaurants, bars, and venues — 15 rotating design themes, live menus, QR offers, and events, all driven from a single dashboard.</p>
    <p class="hero-desc">Built and operated by MadLads Lab. The panel to the right is a real live display rotating through every theme in the library — what you see is what your screen would look like.</p>
    <div class="hero-cta">
      <a href="/tv/graffiti-pasta" target="_blank" class="btn btn-primary">View Live Display →</a>
      <a href="https://madladslab.com" target="_blank" rel="noopener" class="btn btn-ghost">Visit MadLadsLab</a>
    </div>
    <div class="hero-note">15 Themes · Auto-Rotate · QR Offers · Live Menus</div>
  </div>

  <div class="tv-frame">
    <iframe id="themeFrame" src="/theme/graffiti-pasta/1" allowfullscreen></iframe>
    <div class="tv-overlay"></div>
    <div class="tv-scanlines"></div>
    <div class="tv-corner"><span class="dot"></span>LIVE</div>
    <div class="tv-badge" id="themeTag">THEME 01 / 15</div>
  </div>
</section>

<section class="about">
  <div class="about-inner">
    <div class="about-card">
      <span class="num">01 — DISPLAY</span>
      <h3>Always-On Screens</h3>
      <p>Plug any TV into a Chromecast, Fire Stick, or browser. Your display is a URL — no extra hardware, no installs, no IT call.</p>
    </div>
    <div class="about-card">
      <span class="num">02 — DESIGN</span>
      <h3>15 Rotating Themes</h3>
      <p>Editorial, brutalist, VHS, vaporwave, retro diner, neon grid, and more. The screen never gets stale — themes auto-rotate every 10 minutes.</p>
    </div>
    <div class="about-card">
      <span class="num">03 — CONTROL</span>
      <h3>Live From Your Phone</h3>
      <p>Update menus, specials, QR offers, and events in real time. Changes appear on-screen instantly. Email subscribers go straight to your dashboard.</p>
    </div>
  </div>
</section>

<footer>
  <span>&copy; <%= new Date().getFullYear() %> MadLads Lab · Denton, TX</span>
  <span><a href="https://madladslab.com" target="_blank" rel="noopener">madladslab.com →</a></span>
</footer>

<script>
  // Rotate the preview iframe through all 15 themes
  const ORDER = [1,8,10,3,14,6,11,2,13,5,7,12,4,15,9];
  const TOTAL = 15;
  const INTERVAL = 20 * 1000; // 20s per theme in the preview
  let pos = 0;
  const frame = document.getElementById('themeFrame');
  const tag = document.getElementById('themeTag');
  setInterval(() => {
    pos = (pos + 1) % ORDER.length;
    const id = ORDER[pos];
    frame.src = '/theme/graffiti-pasta/' + id;
    tag.textContent = 'THEME ' + String(id).padStart(2,'0') + ' / ' + TOTAL;
  }, INTERVAL);
</script>
</body>
</html>
