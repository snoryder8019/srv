<!DOCTYPE html>
<html lang="en">
<head>
  <title>GRAFFITI TV</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    html,body{width:100%;height:100%;overflow:hidden;background:#000;}
    iframe{width:100%;height:100%;border:none;display:block;position:absolute;top:0;left:0;}
    #overlay{position:fixed;inset:0;background:#000;z-index:9999;opacity:0;pointer-events:none;transition:opacity 0.7s ease;}
    #overlay.fading{opacity:1;}
    #themeTag{position:fixed;bottom:10px;right:14px;font-family:monospace;font-size:10px;letter-spacing:2px;color:rgba(255,255,255,0.12);z-index:10000;pointer-events:none;}

    /* QR Overlay — floats over theme every N rotations */
    #qrOverlay{
      position:fixed;inset:0;z-index:8000;pointer-events:none;
      display:none;align-items:center;justify-content:center;
      background:rgba(0,0,0,0.72);
      backdrop-filter:blur(6px);
    }
    #qrOverlay.show{display:flex;}
    .qr-card{
      background:#fff;border-radius:4px;padding:24px 28px;
      display:flex;gap:28px;align-items:center;
      box-shadow:0 20px 60px rgba(0,0,0,0.8);
      max-width:700px;pointer-events:all;
      animation:qrIn 0.5s ease;
    }
    @keyframes qrIn{from{transform:scale(0.85);opacity:0}to{transform:scale(1);opacity:1}}
    #qrCode canvas,#qrCode img{width:160px!important;height:160px!important;}
    .qr-text{font-family:sans-serif;color:#111;}
    .qr-eyebrow{font-size:11px;letter-spacing:4px;color:#aaa;text-transform:uppercase;margin-bottom:8px;}
    .qr-title{font-size:1.8rem;font-weight:900;color:#111;line-height:1.1;margin-bottom:8px;}
    .qr-desc{font-size:14px;color:#555;margin-bottom:12px;line-height:1.5;}
    .qr-code-text{font-family:monospace;background:#f5f5f5;padding:4px 10px;font-size:16px;font-weight:700;color:#c0392b;border-radius:2px;display:inline-block;}
    .qr-dismiss{display:block;margin-top:14px;font-size:12px;color:#bbb;letter-spacing:2px;cursor:pointer;}

    /* Email signup overlay */
    #emailOverlay{
      position:fixed;inset:0;z-index:8000;pointer-events:none;
      display:none;align-items:center;justify-content:center;
      background:rgba(0,0,0,0.75);backdrop-filter:blur(6px);
    }
    #emailOverlay.show{display:flex;}
    .email-card{
      background:#111;border:1px solid #333;border-radius:4px;padding:36px 40px;
      max-width:480px;width:90%;pointer-events:all;
      animation:qrIn 0.5s ease;font-family:sans-serif;
    }
    .ec-logo{font-size:13px;letter-spacing:5px;color:#666;margin-bottom:16px;}
    .ec-title{font-size:2rem;font-weight:900;color:#fff;margin-bottom:8px;}
    .ec-sub{font-size:14px;color:#666;margin-bottom:24px;line-height:1.5;}
    .ec-input{
      width:100%;background:#1a1a1a;border:1px solid #333;color:#fff;
      padding:12px 16px;font-size:15px;margin-bottom:10px;border-radius:2px;
      outline:none;font-family:monospace;
    }
    .ec-input:focus{border-color:#555;}
    .ec-btn{
      width:100%;background:#c0392b;color:#fff;border:none;
      padding:13px;font-size:15px;font-weight:700;letter-spacing:2px;
      cursor:pointer;margin-bottom:12px;
    }
    .ec-msg{font-size:13px;color:#00cc88;min-height:20px;text-align:center;}
    .ec-dismiss{display:block;text-align:center;font-size:11px;color:#444;letter-spacing:2px;cursor:pointer;margin-top:8px;}
    .ec-calendar{
      margin-top:20px;padding-top:20px;border-top:1px solid #1e1e1e;
    }
    .ec-cal-title{font-size:12px;letter-spacing:3px;color:#555;margin-bottom:12px;}
    .ec-event{display:flex;gap:14px;align-items:flex-start;margin-bottom:12px;}
    .ec-event-date{font-family:monospace;font-size:11px;color:#c0392b;white-space:nowrap;margin-top:2px;}
    .ec-event-name{font-size:14px;color:#aaa;}
    .ec-event-desc{font-size:11px;color:#555;}
  </style>
</head>
<body>
  <div id="overlay"></div>
  <iframe id="themeFrame" src="/theme/1" allowfullscreen></iframe>
  <div id="themeTag">1/15</div>

  <!-- QR Code overlay -->
  <div id="qrOverlay">
    <div class="qr-card">
      <div id="qrCode"></div>
      <div class="qr-text">
        <div class="qr-eyebrow">SPECIAL OFFER</div>
        <div class="qr-title" id="qrTitle">Free Aperol Spritz</div>
        <div class="qr-desc" id="qrDesc">With any pasta order, Mon–Thu. Show this code at the door.</div>
        <div class="qr-code-text" id="qrCode2">SPRITZ4U</div>
        <span class="qr-dismiss" onclick="dismissQR()">TAP ANYWHERE TO DISMISS →</span>
      </div>
    </div>
  </div>

  <!-- Email signup overlay -->
  <div id="emailOverlay">
    <div class="email-card">
      <div class="ec-logo">GRAFFITI TV</div>
      <div class="ec-title">Stay in the loop.</div>
      <div class="ec-sub">Get updates on specials, live music nights, and exclusive offers from Graffiti Pasta, Denton TX.</div>
      <input class="ec-input" id="subName" placeholder="Your name (optional)">
      <input class="ec-input" id="subEmail" placeholder="your@email.com">
      <button class="ec-btn" onclick="submitEmail()">SUBSCRIBE →</button>
      <div class="ec-msg" id="subMsg"></div>
      <span class="ec-dismiss" onclick="dismissEmail()">MAYBE LATER</span>
      <div class="ec-calendar" id="calEvents"></div>
    </div>
  </div>

<script>
  // Shuffled rotation order — mixed up variety
  const ORDER = [1,8,10,3,14,6,11,2,13,5,7,12,4,15,9];
  const TOTAL = 15;
  const INTERVAL = 10 * 60 * 1000; // 10 min
  let pos = 0;

  // QR + email show every N theme changes
  let changeCount = 0;
  const QR_EVERY = 4;    // show QR every 4 rotations
  const EMAIL_EVERY = 7; // show email every 7

  let offerings = [];
  let events = [];

  async function fetchData() {
    try {
      const [o, e] = await Promise.all([
        fetch('/api/gftv/offerings').then(r=>r.json()),
        fetch('/api/gftv/events').then(r=>r.json())
      ]);
      offerings = o.filter(x=>x.active);
      events = e.filter(x=>x.active);
      populateCalendar();
    } catch(e) {}
  }

  function populateCalendar() {
    const el = document.getElementById('calEvents');
    if (!events.length) { el.style.display='none'; return; }
    el.innerHTML = `<div class="ec-cal-title">UPCOMING EVENTS</div>` +
      events.slice(0,4).map(ev => `
        <div class="ec-event">
          <div class="ec-event-date">${new Date(ev.date).toLocaleDateString('en-US',{month:'short',day:'numeric'})}<br>${ev.time||''}</div>
          <div><div class="ec-event-name">${ev.title}</div><div class="ec-event-desc">${ev.desc||''}</div></div>
        </div>`).join('');
  }

  function switchTheme(dir=1) {
    const overlay = document.getElementById('overlay');
    const frame   = document.getElementById('themeFrame');
    const tag     = document.getElementById('themeTag');
    overlay.classList.add('fading');
    setTimeout(() => {
      pos = ((pos + dir) + ORDER.length) % ORDER.length;
      const themeId = ORDER[pos];
      frame.src = '/theme/' + themeId;
      tag.textContent = themeId + '/15';
      frame.onload = () => setTimeout(() => overlay.classList.remove('fading'), 150);
      setTimeout(() => overlay.classList.remove('fading'), 2500);

      changeCount++;
      if (changeCount % EMAIL_EVERY === 0) {
        setTimeout(showEmail, 3000);
      } else if (changeCount % QR_EVERY === 0 && offerings.length) {
        setTimeout(showQR, 3000);
      }
    }, 750);
  }

  // QR overlay
  let qrInstance = null;
  function showQR() {
    if (!offerings.length) return;
    const offer = offerings[Math.floor(Math.random() * offerings.length)];
    document.getElementById('qrTitle').textContent = offer.title;
    document.getElementById('qrDesc').textContent = offer.desc;
    document.getElementById('qrCode2').textContent = offer.code;
    const qrEl = document.getElementById('qrCode');
    qrEl.innerHTML = '';
    new QRCode(qrEl, {
      text: `https://graffititv.madladslab.com/?offer=${offer.code}`,
      width:160, height:160,
      colorDark:'#111', colorLight:'#ffffff',
      correctLevel: QRCode.CorrectLevel.H
    });
    document.getElementById('qrOverlay').classList.add('show');
    setTimeout(dismissQR, 20000); // auto dismiss after 20s
  }
  function dismissQR() { document.getElementById('qrOverlay').classList.remove('show'); }
  document.getElementById('qrOverlay').addEventListener('click', dismissQR);

  // Email overlay
  function showEmail() { document.getElementById('emailOverlay').classList.add('show'); }
  function dismissEmail() { document.getElementById('emailOverlay').classList.remove('show'); }
  async function submitEmail() {
    const email = document.getElementById('subEmail').value.trim();
    const name  = document.getElementById('subName').value.trim();
    if (!email) { document.getElementById('subMsg').textContent = 'Please enter your email.'; return; }
    try {
      const r = await fetch('/api/gftv/subscribe', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({email,name})
      });
      const d = await r.json();
      document.getElementById('subMsg').textContent = d.msg || 'Subscribed!';
      setTimeout(dismissEmail, 3000);
    } catch(e) {
      document.getElementById('subMsg').textContent = 'Something went wrong. Try again.';
    }
  }

  // Keyboard nav
  document.addEventListener('keydown', e => {
    if (e.key==='ArrowRight'||e.key===' ') switchTheme(1);
    if (e.key==='ArrowLeft') switchTheme(-1);
    if (e.key==='q') showQR();
    if (e.key==='e') showEmail();
  });

  setInterval(() => switchTheme(1), INTERVAL);
  fetchData();
</script>
</body>
</html>
