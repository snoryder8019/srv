<!DOCTYPE html>
<html lang="en">
<head>
  <title>GFTV Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;700&family=Bebas+Neue&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#0a0a0a;--panel:#111;--border:#1e1e1e;--accent:#e8b400;--red:#cc1100;--green:#00cc88;--text:#d0d0d0;--dim:#555;}
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:var(--bg);color:var(--text);font-family:'IBM Plex Mono',monospace;min-height:100vh;}

    /* SIDEBAR NAV */
    .layout{display:grid;grid-template-columns:220px 1fr;min-height:100vh;}
    .sidebar{background:#000;border-right:1px solid var(--border);padding:24px 0;display:flex;flex-direction:column;}
    .sidebar-logo{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:4px;color:var(--accent);padding:0 20px 24px;border-bottom:1px solid var(--border);}
    .sidebar-logo span{display:block;font-size:11px;letter-spacing:3px;color:var(--dim);font-family:'IBM Plex Mono',monospace;margin-top:2px;}
    .nav{padding:16px 0;flex:1;}
    .nav-item{
      display:flex;align-items:center;gap:10px;
      padding:11px 20px;font-size:13px;letter-spacing:1px;
      color:var(--dim);cursor:pointer;border-left:3px solid transparent;
      transition:all 0.15s;
    }
    .nav-item:hover{color:var(--text);background:rgba(255,255,255,0.03);}
    .nav-item.active{color:var(--accent);border-left-color:var(--accent);background:rgba(232,180,0,0.05);}
    .nav-icon{font-size:16px;}
    .sidebar-bottom{padding:16px 20px;border-top:1px solid var(--border);font-size:11px;color:var(--dim);}
    .live-dot{width:8px;height:8px;border-radius:50%;background:var(--green);display:inline-block;margin-right:6px;animation:blink 1.5s step-end infinite;}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:0.2}}

    /* MAIN */
    .main{padding:32px;overflow-y:auto;}
    .page{display:none;}
    .page.active{display:block;}
    .page-title{font-family:'Bebas Neue',sans-serif;font-size:32px;letter-spacing:4px;color:var(--text);margin-bottom:4px;}
    .page-sub{font-size:11px;letter-spacing:2px;color:var(--dim);margin-bottom:28px;}

    /* AUTH GATE */
    .auth-gate{display:flex;align-items:center;justify-content:center;min-height:80vh;}
    .auth-box{background:var(--panel);border:1px solid var(--border);padding:40px;width:360px;text-align:center;}
    .auth-title{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:4px;color:var(--accent);margin-bottom:20px;}
    .auth-input{width:100%;background:var(--bg);border:1px solid var(--border);color:var(--text);padding:12px;font-family:'IBM Plex Mono',monospace;font-size:14px;margin-bottom:12px;letter-spacing:2px;}
    .auth-btn{width:100%;background:var(--accent);color:#000;border:none;padding:12px;font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:3px;cursor:pointer;}
    .auth-err{color:var(--red);font-size:12px;margin-top:8px;}

    /* CARDS / PANELS */
    .card{background:var(--panel);border:1px solid var(--border);padding:20px;margin-bottom:16px;}
    .card-title{font-size:11px;letter-spacing:3px;color:var(--dim);margin-bottom:16px;}
    .stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:24px;}
    .stat-card{background:var(--panel);border:1px solid var(--border);padding:20px;text-align:center;}
    .stat-card .num{font-family:'Bebas Neue',sans-serif;font-size:3rem;color:var(--accent);line-height:1;}
    .stat-card .lbl{font-size:10px;letter-spacing:3px;color:var(--dim);margin-top:4px;}

    /* TABLE */
    table{width:100%;border-collapse:collapse;font-size:13px;}
    th{text-align:left;padding:8px 12px;font-size:10px;letter-spacing:3px;color:var(--dim);border-bottom:1px solid var(--border);}
    td{padding:10px 12px;border-bottom:1px solid rgba(255,255,255,0.03);vertical-align:middle;}
    tr:hover td{background:rgba(255,255,255,0.02);}
    .badge{display:inline-block;padding:2px 8px;font-size:10px;letter-spacing:1px;}
    .badge-green{background:rgba(0,204,136,0.15);color:var(--green);border:1px solid rgba(0,204,136,0.2);}
    .badge-red{background:rgba(204,17,0,0.15);color:var(--red);border:1px solid rgba(204,17,0,0.2);}
    .badge-yellow{background:rgba(232,180,0,0.15);color:var(--accent);border:1px solid rgba(232,180,0,0.2);}

    /* FORM */
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;}
    .form-grid.full{grid-template-columns:1fr;}
    .field{display:flex;flex-direction:column;gap:4px;}
    .field label{font-size:10px;letter-spacing:2px;color:var(--dim);}
    .field input,.field textarea,.field select{
      background:var(--bg);border:1px solid var(--border);color:var(--text);
      padding:10px 12px;font-family:'IBM Plex Mono',monospace;font-size:13px;
      outline:none;
    }
    .field input:focus,.field textarea:focus{border-color:var(--dim);}
    .field textarea{resize:vertical;min-height:70px;}

    /* BUTTONS */
    .btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:1px;cursor:pointer;border:none;}
    .btn-primary{background:var(--accent);color:#000;}
    .btn-danger{background:var(--red);color:#fff;}
    .btn-ghost{background:transparent;color:var(--dim);border:1px solid var(--border);}
    .btn-sm{padding:4px 10px;font-size:11px;}
    .actions{display:flex;gap:6px;}

    /* ANALYTICS BAR */
    .bar-row{display:flex;align-items:center;gap:12px;margin-bottom:10px;}
    .bar-label{width:180px;font-size:12px;color:var(--dim);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .bar-wrap{flex:1;height:8px;background:var(--border);}
    .bar-fill{height:100%;background:var(--accent);}
    .bar-val{width:40px;text-align:right;font-size:12px;color:var(--text);}

    /* COMING SOON */
    .coming-soon{text-align:center;padding:80px 20px;color:var(--dim);}
    .cs-icon{font-size:4rem;margin-bottom:20px;}
    .cs-title{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:4px;color:var(--text);margin-bottom:8px;}
    .cs-sub{font-size:13px;color:var(--dim);letter-spacing:1px;}

    /* SUBSCRIBERS */
    .sub-count{font-family:'Bebas Neue',sans-serif;font-size:4rem;color:var(--green);line-height:1;}
    .toast{position:fixed;bottom:24px;right:24px;background:var(--green);color:#000;padding:12px 20px;font-size:13px;letter-spacing:1px;z-index:9999;display:none;}
    .toast.show{display:block;}
  </style>
</head>
<body>

<!-- AUTH GATE -->
<div id="authGate" class="auth-gate">
  <div class="auth-box">
    <div class="auth-title">GFTV ADMIN</div>
    <input class="auth-input" type="password" id="passInput" placeholder="ENTER PASSWORD" onkeydown="if(event.key==='Enter')login()">
    <button class="auth-btn" onclick="login()">ENTER →</button>
    <div class="auth-err" id="authErr"></div>
  </div>
</div>

<!-- MAIN LAYOUT (hidden until auth) -->
<div class="layout" id="mainLayout" style="display:none">
  <div class="sidebar">
    <div class="sidebar-logo">GFTV<span>ADMIN PANEL</span></div>
    <div class="nav">
      <div class="nav-item active" onclick="goto('dashboard')"><span class="nav-icon">📊</span> Dashboard</div>
      <div class="nav-item" onclick="goto('menu')"><span class="nav-icon">🍝</span> Menu</div>
      <div class="nav-item" onclick="goto('specials')"><span class="nav-icon">⭐</span> Specials</div>
      <div class="nav-item" onclick="goto('events')"><span class="nav-icon">📅</span> Events</div>
      <div class="nav-item" onclick="goto('offerings')"><span class="nav-icon">🎁</span> Offerings</div>
      <div class="nav-item" onclick="goto('subscribers')"><span class="nav-icon">📧</span> Subscribers</div>
      <div class="nav-item" onclick="goto('analytics')"><span class="nav-icon">📈</span> Analytics</div>
      <div class="nav-item" onclick="goto('broadcast')"><span class="nav-icon">📡</span> Live Broadcast</div>
    </div>
    <div class="sidebar-bottom"><span class="live-dot"></span>GRAFFITI TV LIVE</div>
  </div>

  <div class="main">
    <div id="toast" class="toast"></div>

    <!-- DASHBOARD -->
    <div class="page active" id="page-dashboard">
      <div class="page-title">Dashboard</div>
      <div class="page-sub">GRAFFITI PASTA · DENTON TX</div>
      <div class="stats-grid" id="dashStats"></div>
      <div class="card">
        <div class="card-title">UPCOMING EVENTS</div>
        <div id="dashEvents"></div>
      </div>
    </div>

    <!-- MENU -->
    <div class="page" id="page-menu">
      <div class="page-title">Menu Items</div>
      <div class="page-sub">MANAGE YOUR MENU</div>
      <div class="card">
        <div class="card-title">ADD ITEM</div>
        <div class="form-grid">
          <div class="field"><label>NAME</label><input id="m-name" placeholder="Carbonara"></div>
          <div class="field"><label>PRICE</label><input id="m-price" type="number" step="0.01" placeholder="19.99"></div>
        </div>
        <div class="form-grid full">
          <div class="field"><label>DESCRIPTION</label><input id="m-desc" placeholder="Guanciale, egg yolk, pecorino..."></div>
        </div>
        <button class="btn btn-primary" onclick="addItem('menu')">+ ADD ITEM</button>
      </div>
      <div class="card"><div class="card-title">ALL ITEMS</div><table><thead><tr><th>NAME</th><th>DESCRIPTION</th><th>PRICE</th><th>STATUS</th><th>ACTIONS</th></tr></thead><tbody id="menu-table"></tbody></table></div>
    </div>

    <!-- SPECIALS -->
    <div class="page" id="page-specials">
      <div class="page-title">Specials</div>
      <div class="page-sub">TONIGHT'S FEATURED ITEMS</div>
      <div class="card">
        <div class="card-title">ADD SPECIAL</div>
        <div class="form-grid">
          <div class="field"><label>NAME</label><input id="s-name" placeholder="Truffle Pasta"></div>
          <div class="field"><label>PRICE</label><input id="s-price" type="number" step="0.01" placeholder="24.99"></div>
        </div>
        <div class="form-grid full">
          <div class="field"><label>DESCRIPTION</label><input id="s-desc" placeholder="Chef's pick tonight..."></div>
        </div>
        <button class="btn btn-primary" onclick="addItem('specials')">+ ADD SPECIAL</button>
      </div>
      <div class="card"><div class="card-title">CURRENT SPECIALS</div><table><thead><tr><th>NAME</th><th>DESCRIPTION</th><th>PRICE</th><th>STATUS</th><th>ACTIONS</th></tr></thead><tbody id="specials-table"></tbody></table></div>
    </div>

    <!-- EVENTS -->
    <div class="page" id="page-events">
      <div class="page-title">Events</div>
      <div class="page-sub">CALENDAR & UPCOMING EVENTS</div>
      <div class="card">
        <div class="card-title">ADD EVENT</div>
        <div class="form-grid">
          <div class="field"><label>TITLE</label><input id="e-title" placeholder="Live Music Night"></div>
          <div class="field"><label>DATE</label><input id="e-date" type="date"></div>
        </div>
        <div class="form-grid">
          <div class="field"><label>TIME</label><input id="e-time" placeholder="8:00 PM"></div>
          <div class="field"><label>DESCRIPTION</label><input id="e-desc" placeholder="Live band, great food..."></div>
        </div>
        <button class="btn btn-primary" onclick="addItem('events')">+ ADD EVENT</button>
      </div>
      <div class="card"><div class="card-title">ALL EVENTS</div><table><thead><tr><th>TITLE</th><th>DATE</th><th>TIME</th><th>DESCRIPTION</th><th>STATUS</th><th>ACTIONS</th></tr></thead><tbody id="events-table"></tbody></table></div>
    </div>

    <!-- OFFERINGS / QR -->
    <div class="page" id="page-offerings">
      <div class="page-title">Offerings & QR Codes</div>
      <div class="page-sub">PROMOTIONS SHOWN ON TV WITH QR CODES</div>
      <div class="card">
        <div class="card-title">ADD OFFERING</div>
        <div class="form-grid">
          <div class="field"><label>TITLE</label><input id="o-title" placeholder="Free Aperol Spritz"></div>
          <div class="field"><label>CODE</label><input id="o-code" placeholder="SPRITZ4U"></div>
        </div>
        <div class="form-grid full">
          <div class="field"><label>DESCRIPTION</label><input id="o-desc" placeholder="With any pasta order, Mon–Thu"></div>
        </div>
        <button class="btn btn-primary" onclick="addItem('offerings')">+ ADD OFFERING</button>
      </div>
      <div class="card"><div class="card-title">ACTIVE OFFERINGS</div><table><thead><tr><th>TITLE</th><th>CODE</th><th>DESCRIPTION</th><th>STATUS</th><th>ACTIONS</th></tr></thead><tbody id="offerings-table"></tbody></table></div>
    </div>

    <!-- SUBSCRIBERS -->
    <div class="page" id="page-subscribers">
      <div class="page-title">Subscribers</div>
      <div class="page-sub">EMAIL LIST FROM TV SIGNUPS</div>
      <div class="stats-grid">
        <div class="stat-card"><div class="num" id="subCount">0</div><div class="lbl">TOTAL SUBSCRIBERS</div></div>
      </div>
      <div class="card"><div class="card-title">ALL SUBSCRIBERS</div><table><thead><tr><th>EMAIL</th><th>NAME</th><th>DATE JOINED</th></tr></thead><tbody id="subscribers-table"></tbody></table></div>
    </div>

    <!-- ANALYTICS -->
    <div class="page" id="page-analytics">
      <div class="page-title">Analytics</div>
      <div class="page-sub">THEME VIEWS & ENGAGEMENT</div>
      <div class="stats-grid" id="analyticsStats"></div>
      <div class="card">
        <div class="card-title">THEME VIEW COUNTS</div>
        <div id="themeAnalytics"></div>
      </div>
    </div>

    <!-- LIVE BROADCAST -->
    <div class="page" id="page-broadcast">
      <div class="coming-soon">
        <div class="cs-icon">📡</div>
        <div class="cs-title">Live Broadcast</div>
        <div class="cs-sub">Stream management, RTMP config, and live overlay controls<br>are coming soon to GFTV Admin.</div>
      </div>
    </div>
  </div>
</div>

<script>
  let PASS = '';
  const THEME_NAMES = {1:'VHS Underground',2:'Rave Mode',3:'Retro Diner',4:'Brutalist',5:'Vaporwave',6:'Newsroom',7:'Split Screen',8:'Cinema',9:'Polaroid Board',10:'Neon Grid',11:'Horizontal',12:'Typewriter',13:'Tiles',14:'Minimal',15:'Stadium'};

  function login() {
    PASS = document.getElementById('passInput').value;
    fetch('/api/admin/data',{headers:{'x-admin-pass':PASS}})
      .then(r => { if(!r.ok) throw new Error('bad'); return r.json(); })
      .then(d => {
        document.getElementById('authGate').style.display='none';
        document.getElementById('mainLayout').style.display='grid';
        loadAll(d);
      })
      .catch(() => { document.getElementById('authErr').textContent='Incorrect password.'; });
  }

  function goto(page) {
    document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
    document.getElementById('page-'+page).classList.add('active');
    document.querySelectorAll('.nav-item').forEach(n=>{ if(n.textContent.toLowerCase().includes(page.substring(0,4))) n.classList.add('active'); });
    refreshPage(page);
  }

  async function api(method, path, body) {
    const r = await fetch(path, { method, headers:{'Content-Type':'application/json','x-admin-pass':PASS}, body: body ? JSON.stringify(body) : undefined });
    return r.json();
  }

  function toast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg; t.classList.add('show');
    setTimeout(()=>t.classList.remove('show'), 2500);
  }

  let DATA = {};

  function loadAll(d) { DATA = d; renderAll(); }

  async function refreshPage(page) {
    const d = await api('GET','/api/admin/data');
    DATA = d; renderAll();
  }

  function renderAll() {
    renderDashboard();
    renderTable('menu', ['name','desc','price'], DATA.menu||[]);
    renderTable('specials', ['name','desc','price'], DATA.specials||[]);
    renderEventsTable(DATA.events||[]);
    renderTable('offerings', ['title','code','desc'], DATA.offerings||[]);
    renderSubscribers(DATA.subscribers||[]);
    renderAnalytics();
  }

  function renderDashboard() {
    const stats = [
      {num:(DATA.menu||[]).filter(x=>x.active).length, lbl:'MENU ITEMS'},
      {num:(DATA.events||[]).filter(x=>x.active).length, lbl:'UPCOMING EVENTS'},
      {num:(DATA.offerings||[]).filter(x=>x.active).length, lbl:'ACTIVE OFFERS'},
      {num:(DATA.subscribers||[]).length, lbl:'SUBSCRIBERS'},
    ];
    document.getElementById('dashStats').innerHTML = stats.map(s=>`<div class="stat-card"><div class="num">${s.num}</div><div class="lbl">${s.lbl}</div></div>`).join('');
    const evs = (DATA.events||[]).filter(x=>x.active).slice(0,5);
    document.getElementById('dashEvents').innerHTML = evs.length
      ? `<table><thead><tr><th>TITLE</th><th>DATE</th><th>TIME</th><th>DESC</th></tr></thead><tbody>${evs.map(e=>`<tr><td>${e.title}</td><td>${e.date}</td><td>${e.time||'-'}</td><td style="color:var(--dim)">${e.desc||''}</td></tr>`).join('')}</tbody></table>`
      : '<div style="color:var(--dim);font-size:13px;padding:8px 0">No upcoming events</div>';
  }

  function renderTable(col, fields, items) {
    const tb = document.getElementById(col+'-table');
    if (!tb) return;
    tb.innerHTML = items.map(item => `
      <tr>
        ${fields.map(f=>`<td>${item[f]||''}</td>`).join('')}
        ${col==='menu'||col==='specials' ? `<td>${item.price?'$'+parseFloat(item.price).toFixed(2):''}</td>`.replace('<td>$'+item.price+'</td>','') : ''}
        <td><span class="badge ${item.active?'badge-green':'badge-red'}">${item.active?'ACTIVE':'OFF'}</span></td>
        <td><div class="actions">
          <button class="btn btn-ghost btn-sm" onclick="toggleItem('${col}',${item.id},${!item.active})">${item.active?'HIDE':'SHOW'}</button>
          <button class="btn btn-danger btn-sm" onclick="deleteItem('${col}',${item.id})">DEL</button>
        </div></td>
      </tr>`).join('');
  }

  function renderEventsTable(items) {
    const tb = document.getElementById('events-table');
    if (!tb) return;
    tb.innerHTML = items.map(item=>`
      <tr>
        <td>${item.title}</td><td>${item.date}</td><td>${item.time||'-'}</td><td style="color:var(--dim)">${item.desc||''}</td>
        <td><span class="badge ${item.active?'badge-green':'badge-red'}">${item.active?'ACTIVE':'OFF'}</span></td>
        <td><div class="actions">
          <button class="btn btn-ghost btn-sm" onclick="toggleItem('events',${item.id},${!item.active})">${item.active?'HIDE':'SHOW'}</button>
          <button class="btn btn-danger btn-sm" onclick="deleteItem('events',${item.id})">DEL</button>
        </div></td>
      </tr>`).join('');
  }

  function renderSubscribers(subs) {
    document.getElementById('subCount').textContent = subs.length;
    const tb = document.getElementById('subscribers-table');
    if (!tb) return;
    tb.innerHTML = subs.map(s=>`<tr><td>${s.email}</td><td>${s.name||'-'}</td><td style="color:var(--dim)">${new Date(s.date).toLocaleDateString()}</td></tr>`).join('');
  }

  function renderAnalytics() {
    const themes = DATA.analytics?.themes || {};
    const total = Object.values(themes).reduce((a,b)=>a+b,0);
    document.getElementById('analyticsStats').innerHTML = `
      <div class="stat-card"><div class="num">${total}</div><div class="lbl">TOTAL THEME VIEWS</div></div>
      <div class="stat-card"><div class="num">${Object.keys(themes).length}</div><div class="lbl">THEMES SEEN</div></div>
      <div class="stat-card"><div class="num">${(DATA.subscribers||[]).length}</div><div class="lbl">SUBSCRIBERS</div></div>`;
    const max = Math.max(...Object.values(themes), 1);
    document.getElementById('themeAnalytics').innerHTML = Object.entries(themes)
      .sort((a,b)=>b[1]-a[1])
      .map(([id,count])=>`
        <div class="bar-row">
          <div class="bar-label">${THEME_NAMES[id]||'Theme '+id}</div>
          <div class="bar-wrap"><div class="bar-fill" style="width:${Math.round(count/max*100)}%"></div></div>
          <div class="bar-val">${count}</div>
        </div>`).join('') || '<div style="color:var(--dim);font-size:13px">No data yet — themes update as they are viewed.</div>';
  }

  async function addItem(col) {
    let body = {};
    if (col==='menu')      body = {name:v('m-name'),desc:v('m-desc'),price:parseFloat(v('m-price'))};
    if (col==='specials')  body = {name:v('s-name'),desc:v('s-desc'),price:parseFloat(v('s-price'))};
    if (col==='events')    body = {title:v('e-title'),date:v('e-date'),time:v('e-time'),desc:v('e-desc')};
    if (col==='offerings') body = {title:v('o-title'),code:v('o-code'),desc:v('o-desc')};
    await api('POST',`/api/admin/${col}`,body);
    toast('✓ Added!');
    const d = await api('GET','/api/admin/data');
    DATA=d; renderAll();
  }

  async function toggleItem(col, id, active) {
    await api('PUT',`/api/admin/${col}/${id}`,{active});
    toast(active?'✓ Shown':'✓ Hidden');
    const d = await api('GET','/api/admin/data'); DATA=d; renderAll();
  }

  async function deleteItem(col, id) {
    if (!confirm('Delete this item?')) return;
    await api('DELETE',`/api/admin/${col}/${id}`);
    toast('✓ Deleted');
    const d = await api('GET','/api/admin/data'); DATA=d; renderAll();
  }

  function v(id) { return document.getElementById(id)?.value || ''; }
</script>
</body></html>
