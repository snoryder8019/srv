<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta property="og:title" content="W2 Marketing - Social Media & Web Design | Greeley, CO" />
  <meta property="og:description" content="Social media management, website design, and content creation for local businesses in Greeley, Colorado." />
  <title>W2 Marketing | Greeley, CO</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;600;800&family=Great+Vibes&display=swap" rel="stylesheet">
<style>
  :root {
    --blue-primary: #116dff;
    --blue-mid: #3899ec;
    --blue-light: #7fccf7;
    --dark: #080808;
    --dark-gray: #363535;
    --mid-gray: #5f6360;
    --white: #ffffff;
    --section-pad: 90px 40px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Raleway', Helvetica, Arial, sans-serif;
    background: var(--white);
    color: var(--dark);
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 48px;
    background: rgba(8, 8, 8, 0.88);
    backdrop-filter: blur(8px);
    transition: background 0.3s;
  }

  .nav-logo {
    font-family: 'Great Vibes', cursive;
    font-size: 2.2rem;
    color: var(--white);
    letter-spacing: 0.02em;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 2.4rem;
    list-style: none;
  }

  .nav-links a {
    color: rgba(255,255,255,0.82);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--blue-light); }

  .nav-cta {
    background: var(--blue-primary);
    color: var(--white) !important;
    padding: 10px 22px;
    border-radius: 4px;
    transition: background 0.2s !important;
  }

  .nav-cta:hover { background: #0a55cc !important; }

  /* ── HERO ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    background: var(--dark);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 60%, rgba(17, 109, 255, 0.35) 0%, transparent 55%),
      radial-gradient(ellipse at 75% 30%, rgba(56, 153, 236, 0.25) 0%, transparent 50%),
      linear-gradient(160deg, #0a0a12 0%, #080818 60%, #0d0d22 100%);
    animation: heroPulse 10s ease-in-out infinite alternate;
  }

  @keyframes heroPulse {
    0%   { opacity: 0.9; }
    100% { opacity: 1; }
  }

  /* animated grid lines */
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(17,109,255,0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(17,109,255,0.07) 1px, transparent 1px);
    background-size: 64px 64px;
    animation: gridDrift 20s linear infinite;
  }

  @keyframes gridDrift {
    0%   { background-position: 0 0; }
    100% { background-position: 64px 64px; }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    padding: 0 24px;
  }

  .hero-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--blue-light);
    margin-bottom: 18px;
  }

  .hero-heading {
    font-size: clamp(2.8rem, 7vw, 5.2rem);
    font-weight: 300;
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 14px;
    text-shadow: 0 2px 32px rgba(0,0,0,0.5);
  }

  .hero-heading span {
    font-family: 'Great Vibes', cursive;
    font-size: 1.25em;
    font-weight: 400;
    color: var(--blue-light);
    display: block;
  }

  .hero-sub {
    font-size: 1.1rem;
    font-weight: 300;
    color: rgba(255,255,255,0.65);
    max-width: 560px;
    margin: 0 auto 42px;
    line-height: 1.7;
    letter-spacing: 0.02em;
  }

  .hero-btns {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--blue-primary);
    color: var(--white);
    padding: 16px 36px;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 0.2s, transform 0.2s;
  }

  .btn-primary:hover { background: #0a55cc; transform: translateY(-2px); }

  .btn-outline {
    border: 2px solid rgba(255,255,255,0.35);
    color: var(--white);
    padding: 14px 36px;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: border-color 0.2s, transform 0.2s;
  }

  .btn-outline:hover { border-color: var(--blue-light); transform: translateY(-2px); }

  .hero-scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.35);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .scroll-line {
    width: 1px;
    height: 44px;
    background: linear-gradient(to bottom, transparent, var(--blue-mid));
    animation: scrollPulse 1.8s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
    50%       { opacity: 1;   transform: scaleY(1);   }
  }

  /* ── SERVICES ── */
  .services {
    padding: var(--section-pad);
    background: #fafafa;
    text-align: center;
  }

  .section-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--blue-primary);
    margin-bottom: 14px;
  }

  .section-heading {
    font-size: clamp(2rem, 5vw, 3.8rem);
    font-weight: 300;
    color: var(--dark);
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .section-heading em {
    font-family: 'Great Vibes', cursive;
    font-style: normal;
    font-size: 1.18em;
    color: var(--blue-primary);
  }

  .section-sub {
    font-size: 1rem;
    font-weight: 300;
    color: var(--mid-gray);
    max-width: 560px;
    margin: 0 auto 64px;
    line-height: 1.8;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 32px;
    max-width: 1080px;
    margin: 0 auto;
  }

  .service-card {
    background: var(--white);
    border-radius: 8px;
    padding: 48px 36px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.07);
    text-align: left;
    transition: transform 0.3s, box-shadow 0.3s;
    position: relative;
    overflow: hidden;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--blue-primary), var(--blue-light));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s;
  }

  .service-card:hover { transform: translateY(-6px); box-shadow: 0 16px 48px rgba(17,109,255,0.13); }
  .service-card:hover::before { transform: scaleX(1); }

  .service-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--blue-primary), var(--blue-mid));
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    font-size: 1.5rem;
  }

  .service-title-light {
    font-size: 0.9rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--mid-gray);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .service-title-main {
    font-family: 'Great Vibes', cursive;
    font-size: 2.4rem;
    color: var(--dark);
    line-height: 1.1;
    margin-bottom: 18px;
  }

  .service-desc {
    font-size: 0.92rem;
    font-weight: 300;
    color: var(--mid-gray);
    line-height: 1.8;
  }

  /* ── ABOUT STRIP ── */
  .about-strip {
    padding: var(--section-pad);
    background: var(--dark);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 80px;
    flex-wrap: wrap;
  }

  .about-text { max-width: 500px; }

  .about-text .section-label { color: var(--blue-light); }

  .about-text .section-heading { color: var(--white); }

  .about-text .section-sub {
    color: rgba(255,255,255,0.55);
    margin-bottom: 36px;
  }

  .stats-row {
    display: flex;
    gap: 48px;
    flex-wrap: wrap;
  }

  .stat { text-align: left; }

  .stat-num {
    font-size: 3rem;
    font-weight: 800;
    color: var(--blue-light);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-top: 4px;
  }

  .about-img-block {
    position: relative;
    width: 360px;
    flex-shrink: 0;
  }

  .about-img-inner {
    width: 100%;
    height: 300px;
    border-radius: 12px;
    background: linear-gradient(135deg, #116dff22, #3899ec44);
    border: 1px solid rgba(17,109,255,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-img-inner span {
    font-family: 'Great Vibes', cursive;
    font-size: 4rem;
    color: var(--blue-light);
    opacity: 0.7;
  }

  .about-img-badge {
    position: absolute;
    bottom: -16px;
    right: -16px;
    background: var(--blue-primary);
    color: var(--white);
    border-radius: 50%;
    width: 96px;
    height: 96px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.5rem;
    line-height: 1;
    box-shadow: 0 8px 24px rgba(17,109,255,0.4);
  }

  .about-img-badge small { font-size: 0.55rem; letter-spacing: 0.1em; font-weight: 600; text-transform: uppercase; }

  /* ── PROCESS ── */
  .process {
    padding: var(--section-pad);
    background: var(--white);
    text-align: center;
  }

  .process-steps {
    display: flex;
    gap: 0;
    max-width: 960px;
    margin: 64px auto 0;
    position: relative;
    flex-wrap: wrap;
    justify-content: center;
  }

  .process-steps::before {
    content: '';
    position: absolute;
    top: 28px;
    left: 10%;
    right: 10%;
    height: 2px;
    background: linear-gradient(90deg, var(--blue-primary), var(--blue-light));
  }

  .process-step {
    flex: 1;
    min-width: 160px;
    max-width: 220px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 0 12px;
    position: relative;
  }

  .step-num {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--white);
    border: 2px solid var(--blue-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--blue-primary);
    position: relative;
    z-index: 1;
    transition: background 0.3s, color 0.3s;
  }

  .process-step:hover .step-num { background: var(--blue-primary); color: var(--white); }

  .step-title {
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--dark);
  }

  .step-desc {
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--mid-gray);
    line-height: 1.7;
    text-align: center;
  }

  /* ── CONTACT ── */
  .contact {
    padding: var(--section-pad);
    background: linear-gradient(135deg, #0a0a1a 0%, #0d1833 100%);
    text-align: center;
  }

  .contact .section-label { color: var(--blue-light); }
  .contact .section-heading { color: var(--white); margin-bottom: 48px; }

  .contact-form {
    max-width: 580px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .form-row { display: flex; gap: 18px; }

  .form-field {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-field label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    text-align: left;
  }

  .form-field input,
  .form-field textarea,
  .form-field select {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 4px;
    padding: 14px 18px;
    color: var(--white);
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 300;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder { color: rgba(255,255,255,0.25); }

  .form-field input:focus,
  .form-field textarea:focus,
  .form-field select:focus {
    border-color: var(--blue-mid);
    background: rgba(17,109,255,0.08);
  }

  .form-field textarea { resize: vertical; min-height: 120px; }

  .form-field select option { background: #0d1833; }

  .btn-submit {
    background: var(--blue-primary);
    color: var(--white);
    border: none;
    padding: 18px 48px;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    margin-top: 8px;
  }

  .btn-submit:hover { background: #0a55cc; transform: translateY(-2px); }

  /* ── FOOTER ── */
  footer {
    background: #050505;
    padding: 48px 48px 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
  }

  .footer-logo {
    font-family: 'Great Vibes', cursive;
    font-size: 2.8rem;
    color: var(--white);
  }

  .footer-tagline {
    font-size: 0.8rem;
    font-weight: 300;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
  }

  .footer-links {
    display: flex;
    gap: 32px;
    list-style: none;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-links a {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--blue-light); }

  .footer-divider {
    width: 100%;
    max-width: 640px;
    height: 1px;
    background: rgba(255,255,255,0.07);
  }

  .footer-copy {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.05em;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    nav { padding: 16px 24px; }
    .nav-links { display: none; }
    .about-strip { gap: 48px; padding: 60px 24px; }
    .about-img-block { width: 100%; }
    .form-row { flex-direction: column; }
    .process-steps::before { display: none; }
    .contact { padding: 60px 24px; }
    .services { padding: 60px 24px; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#" class="nav-logo">W2 Marketing</a>
  <ul class="nav-links">
    <li><a href="#services">Services</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#process">Process</a></li>
    <li><a href="#contact" class="nav-cta">Get Started</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <p class="hero-eyebrow">Greeley, Colorado &mdash; Digital Marketing Agency</p>
    <h1 class="hero-heading">
      Grow Your Brand <span>Online</span>
    </h1>
    <p class="hero-sub">Social media management, website design, and content creation — built for local businesses ready to stand out.</p>
    <div class="hero-btns">
      <a href="#contact" class="btn-primary">Start a Project</a>
      <a href="#services" class="btn-outline">Our Services</a>
    </div>
  </div>
  <div class="hero-scroll">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<!-- SERVICES -->
<section class="services" id="services">
  <p class="section-label">What We Do</p>
  <h2 class="section-heading">Our <em>Services</em></h2>
  <p class="section-sub">Everything your business needs to build a powerful presence — from pixels to posts.</p>

  <div class="services-grid">
    <div class="service-card">
      <div class="service-icon">📱</div>
      <p class="service-title-light">Social Media</p>
      <h3 class="service-title-main">Management</h3>
      <p class="service-desc">Strategy, scheduling, and engagement across all major platforms. We handle the day-to-day so you can focus on running your business.</p>
    </div>

    <div class="service-card">
      <div class="service-icon">💻</div>
      <p class="service-title-light">Website</p>
      <h3 class="service-title-main">Design & Dev</h3>
      <p class="service-desc">Custom, responsive websites that convert visitors into customers. Built for speed, SEO, and your brand identity.</p>
    </div>

    <div class="service-card">
      <div class="service-icon">✨</div>
      <p class="service-title-light">Content Creation &</p>
      <h3 class="service-title-main">Branding</h3>
      <p class="service-desc">Photography, graphics, copy, and full brand identity systems — everything you need to tell your story with confidence.</p>
    </div>
  </div>
</section>

<!-- ABOUT STRIP -->
<section class="about-strip" id="about">
  <div class="about-text">
    <p class="section-label">About Us</p>
    <h2 class="section-heading" style="color:#fff">A quick idea of your <em style="color:var(--blue-light)">needs</em></h2>
    <p class="section-sub">We're a Greeley-based marketing team that partners with local businesses to make digital marketing simple, effective, and actually enjoyable. No fluff — just results.</p>
    <div class="stats-row">
      <div class="stat">
        <div class="stat-num">50+</div>
        <div class="stat-label">Clients Served</div>
      </div>
      <div class="stat">
        <div class="stat-num">3x</div>
        <div class="stat-label">Avg. Engagement Lift</div>
      </div>
      <div class="stat">
        <div class="stat-num">100%</div>
        <div class="stat-label">Local Focus</div>
      </div>
    </div>
  </div>
  <div class="about-img-block">
    <div class="about-img-inner">
      <span>W2</span>
    </div>
    <div class="about-img-badge">
      <span>5</span>
      <small>Years</small>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section class="process" id="process">
  <p class="section-label">How It Works</p>
  <h2 class="section-heading">Simple <em>Process</em></h2>
  <p class="section-sub">From first conversation to live campaigns, we keep it clear and collaborative every step of the way.</p>

  <div class="process-steps">
    <div class="process-step">
      <div class="step-num">01</div>
      <p class="step-title">Discovery</p>
      <p class="step-desc">We learn your goals, audience, and brand voice in a quick strategy call.</p>
    </div>
    <div class="process-step">
      <div class="step-num">02</div>
      <p class="step-title">Strategy</p>
      <p class="step-desc">We build a custom plan tailored to your business and budget.</p>
    </div>
    <div class="process-step">
      <div class="step-num">03</div>
      <p class="step-title">Create</p>
      <p class="step-desc">Content, designs, and assets get produced and reviewed with you.</p>
    </div>
    <div class="process-step">
      <div class="step-num">04</div>
      <p class="step-title">Launch & Grow</p>
      <p class="step-desc">We go live, track results, and optimize continuously.</p>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section class="contact" id="contact">
  <p class="section-label">Get In Touch</p>
  <h2 class="section-heading">Let's Work <em style="font-family:'Great Vibes',cursive;font-style:normal;color:var(--blue-light);font-size:1.2em;">Together</em></h2>

  <form class="contact-form" onsubmit="handleSubmit(event)">
    <div class="form-row">
      <div class="form-field">
        <label>First Name</label>
        <input type="text" placeholder="Jane" required>
      </div>
      <div class="form-field">
        <label>Last Name</label>
        <input type="text" placeholder="Smith" required>
      </div>
    </div>
    <div class="form-field">
      <label>Email</label>
      <input type="email" placeholder="jane@yourbusiness.com" required>
    </div>
    <div class="form-field">
      <label>Business Name</label>
      <input type="text" placeholder="Your Business LLC">
    </div>
    <div class="form-field">
      <label>Service Interested In</label>
      <select>
        <option value="">Select a service...</option>
        <option>Social Media Management</option>
        <option>Website Design & Development</option>
        <option>Content Creation & Branding</option>
        <option>Full Package</option>
      </select>
    </div>
    <div class="form-field">
      <label>Tell Us About Your Needs</label>
      <textarea placeholder="A quick idea of your needs — what are you trying to achieve?"></textarea>
    </div>
    <button type="submit" class="btn-submit">Send Message</button>
    <div id="form-msg" style="display:none;color:var(--blue-light);font-size:0.9rem;margin-top:8px;"></div>
