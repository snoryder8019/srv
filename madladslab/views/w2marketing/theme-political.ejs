<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta property="og:title" content="Vance Political Strategies — Washington, D.C." />
  <meta property="og:description" content="Senior political advisory services for campaigns, candidates, and causes. Strategy, messaging, and ground game — all under one roof." />
  <title>Vance Political Strategies | Washington, D.C.</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  /* ── NAVY & GOLD POLITICAL PALETTE ── */
  :root {
    --navy:       #1C2B4A;   /* deep navy primary          */
    --navy-deep:  #0F1B30;   /* darkest navy               */
    --navy-mid:   #2E4270;   /* medium navy                */
    --gold:       #C9A848;   /* gold accent                */
    --gold-light: #E8D08A;   /* pale gold                  */
    --crimson:    #8B1C1C;   /* power red                  */
    --ivory:      #F5F3EF;   /* ivory base                 */
    --ivory-mid:  #E6E1D6;   /* warm neutral               */
    --slate:      #6B7380;   /* cool gray                  */
    --dark:       #0F1B30;   /* near black                 */
    --white:      #FDFCFA;   /* warm white                 */
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Jost', sans-serif;
    background: var(--white);
    color: var(--dark);
    overflow-x: hidden;
  }

  /* ── THEME SWITCHER PILL ── */
  .theme-switcher {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9999;
    display: flex;
    gap: 8px;
    background: rgba(15,27,48,0.92);
    backdrop-filter: blur(8px);
    border-radius: 32px;
    padding: 8px 14px;
    align-items: center;
    box-shadow: 0 4px 24px rgba(0,0,0,0.25);
  }

  .theme-switcher span {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-right: 4px;
  }

  .theme-btn {
    padding: 6px 14px;
    border-radius: 24px;
    border: none;
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
  }

  .theme-btn.active {
    background: var(--navy);
    color: var(--gold-light);
  }

  .theme-btn.inactive {
    background: transparent;
    color: rgba(255,255,255,0.5);
    border: 1px solid rgba(255,255,255,0.15);
  }

  .theme-btn.inactive:hover { color: var(--white); border-color: rgba(255,255,255,0.4); }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 52px;
    background: rgba(253,252,250,0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  nav.scrolled {
    border-color: var(--ivory-mid);
    box-shadow: 0 2px 24px rgba(28,43,74,0.1);
  }

  .nav-wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1;
    text-decoration: none;
  }

  .nav-wordmark-top {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--dark);
    letter-spacing: 0.04em;
  }

  .nav-wordmark-sub {
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--navy);
    margin-top: 2px;
  }

  .nav-links {
    display: flex;
    gap: 2.4rem;
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--slate);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--navy); }

  .nav-cta {
    background: var(--navy) !important;
    color: var(--white) !important;
    padding: 10px 24px;
    border-radius: 2px;
  }

  .nav-cta:hover { background: var(--navy-deep) !important; }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }

  .hero-left {
    background: var(--ivory);
    display: flex;
    align-items: center;
    padding: 120px 64px 80px;
  }

  .hero-text { max-width: 500px; }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 28px;
  }

  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--navy);
  }

  .hero-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 5.5vw, 5rem);
    font-weight: 300;
    line-height: 1.08;
    color: var(--dark);
    margin-bottom: 28px;
  }

  .hero-heading em {
    font-style: italic;
    color: var(--navy);
  }

  .hero-sub {
    font-size: 1rem;
    font-weight: 300;
    color: var(--slate);
    line-height: 1.85;
    margin-bottom: 44px;
    max-width: 400px;
  }

  .hero-btns {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--navy);
    color: var(--white);
    padding: 15px 36px;
    border-radius: 2px;
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: background 0.2s, transform 0.2s;
    display: inline-block;
  }

  .btn-primary:hover { background: var(--navy-deep); transform: translateY(-2px); }

  .btn-ghost {
    border: 1.5px solid var(--navy-mid);
    color: var(--navy);
    padding: 14px 36px;
    border-radius: 2px;
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
    display: inline-block;
  }

  .btn-ghost:hover { border-color: var(--navy-deep); color: var(--navy-deep); transform: translateY(-2px); }

  .hero-right {
    background: var(--navy-deep);
    position: relative;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  /* decorative panels */
  .hero-right::before {
    content: '';
    position: absolute;
    top: 60px; right: 60px;
    width: 220px; height: 280px;
    border: 1px solid rgba(201,168,72,0.15);
    border-radius: 2px;
  }

  .hero-right::after {
    content: '';
    position: absolute;
    top: 80px; right: 80px;
    width: 220px; height: 280px;
    border: 1px solid rgba(201,168,72,0.07);
    border-radius: 2px;
  }

  .hero-right-content {
    position: relative;
    z-index: 2;
    padding: 64px;
    width: 100%;
  }

  .hero-name-large {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(4rem, 7vw, 8rem);
    font-weight: 300;
    font-style: italic;
    color: rgba(201,168,72,0.12);
    line-height: 0.9;
    user-select: none;
    letter-spacing: -0.02em;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: rgba(201,168,72,0.12);
    border: 1px solid rgba(201,168,72,0.3);
    border-radius: 2px;
    padding: 12px 20px;
    margin-top: 32px;
  }

  .hero-badge-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--gold);
  }

  .hero-badge-text {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-light);
  }

  /* decorative circle */
  .hero-circle {
    position: absolute;
    top: -80px; left: -80px;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(46,66,112,0.35) 0%, transparent 70%);
  }

  /* ── MARQUEE BAR ── */
  .marquee-bar {
    background: var(--navy);
    padding: 14px 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .marquee-track {
    display: inline-flex;
    gap: 0;
    animation: marqueeScroll 22s linear infinite;
  }

  @keyframes marqueeScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    padding: 0 32px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(232,208,138,0.8);
  }

  .marquee-dot {
    width: 4px; height: 4px;
    border-radius: 50%;
    background: rgba(201,168,72,0.4);
    flex-shrink: 0;
  }

  /* ── SERVICES ── */
  .services {
    padding: 100px 52px;
    background: var(--white);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 64px;
    flex-wrap: wrap;
    gap: 24px;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 12px;
  }

  .section-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    font-weight: 300;
    color: var(--dark);
    line-height: 1.1;
  }

  .section-heading em {
    font-style: italic;
    color: var(--navy);
  }

  .section-sub {
    font-size: 0.92rem;
    font-weight: 300;
    color: var(--slate);
    line-height: 1.8;
    max-width: 340px;
    text-align: right;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    max-width: 1100px;
    margin: 0 auto;
    background: var(--ivory-mid);
  }

  .service-card {
    background: var(--white);
    padding: 52px 40px;
    position: relative;
    transition: background 0.3s;
    overflow: hidden;
  }

  .service-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 40px; right: 40px;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .service-card:hover { background: var(--ivory); }
  .service-card:hover::after { transform: scaleX(1); }

  .service-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 4rem;
    font-weight: 300;
    color: var(--ivory-mid);
    line-height: 1;
    margin-bottom: 24px;
    transition: color 0.3s;
  }

  .service-card:hover .service-num { color: var(--gold-light); }

  .service-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-weight: 400;
    color: var(--dark);
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .service-desc {
    font-size: 0.88rem;
    font-weight: 300;
    color: var(--slate);
    line-height: 1.85;
  }

  /* ── ADVISOR SECTION ── */
  .advisor-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
  }

  .advisor-left {
    background: var(--ivory);
    padding: 100px 64px;
    display: flex;
    align-items: center;
  }

  .advisor-text { max-width: 480px; }

  .advisor-quote {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-style: italic;
    font-weight: 300;
    color: var(--dark);
    line-height: 1.5;
    margin-bottom: 32px;
    position: relative;
    padding-left: 28px;
  }

  .advisor-quote::before {
    content: '';
    position: absolute;
    left: 0; top: 8px; bottom: 8px;
    width: 3px;
    background: var(--gold);
  }

  .advisor-desc {
    font-size: 0.92rem;
    font-weight: 300;
    color: var(--slate);
    line-height: 1.9;
    margin-bottom: 36px;
  }

  .advisor-sig {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-style: italic;
    color: var(--navy);
  }

  .advisor-right {
    background: var(--dark);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .advisor-right-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 64px;
  }

  .advisor-initial {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18rem;
    font-weight: 300;
    font-style: italic;
    color: rgba(28,43,74,0.35);
    line-height: 1;
    user-select: none;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .advisor-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: rgba(201,168,72,0.12);
    position: relative;
    z-index: 3;
  }

  .stat-box {
    background: rgba(15,27,48,0.8);
    padding: 36px 32px;
    text-align: center;
  }

  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.2rem;
    font-weight: 300;
    color: var(--gold);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(253,252,250,0.35);
    margin-top: 8px;
  }

  /* ── PROCESS ── */
  .process {
    padding: 100px 52px;
    background: var(--ivory);
  }

  .process-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .process-list {
    margin-top: 64px;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--ivory-mid);
  }

  .process-item {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    align-items: center;
    gap: 40px;
    padding: 36px 0;
    border-bottom: 1px solid var(--ivory-mid);
    cursor: default;
    transition: background 0.2s;
  }

  .process-item:hover { background: rgba(28,43,74,0.04); margin: 0 -20px; padding: 36px 20px; }

  .process-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.4rem;
    font-weight: 300;
    color: var(--gold-light);
    line-height: 1;
  }

  .process-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--dark);
    margin-bottom: 6px;
  }

  .process-desc {
    font-size: 0.86rem;
    font-weight: 300;
    color: var(--slate);
    line-height: 1.7;
  }

  .process-arrow {
    font-size: 1.2rem;
    color: var(--gold);
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
    transform: translateX(-8px);
  }

  .process-item:hover .process-arrow { opacity: 1; transform: translateX(0); }

  /* ── CONTACT ── */
  .contact {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 700px;
  }

  .contact-left {
    background: var(--navy-deep);
    padding: 100px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-left .section-eyebrow { color: var(--gold-light); }

  .contact-left .section-heading { color: var(--white); margin-bottom: 24px; }

  .contact-sub {
    font-size: 0.92rem;
    font-weight: 300;
    color: rgba(253,252,250,0.55);
    line-height: 1.9;
    margin-bottom: 52px;
    max-width: 380px;
  }

  .contact-detail {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .contact-detail-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .detail-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    min-width: 72px;
    padding-top: 2px;
  }

  .detail-value {
    font-size: 0.92rem;
    font-weight: 300;
    color: rgba(253,252,250,0.7);
    line-height: 1.6;
  }

  .contact-right {
    background: var(--ivory);
    padding: 100px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 440px;
  }

  .form-row { display: flex; gap: 20px; }

  .form-field {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-field label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--slate);
  }

  .form-field input,
  .form-field textarea,
  .form-field select {
    background: var(--white);
    border: 1px solid var(--ivory-mid);
    border-radius: 2px;
    padding: 14px 16px;
    font-family: 'Jost', sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--dark);
    outline: none;
    transition: border-color 0.2s;
    -webkit-appearance: none;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder { color: var(--ivory-mid); }

  .form-field input:focus,
  .form-field textarea:focus,
  .form-field select:focus { border-color: var(--navy); }

  .form-field textarea { resize: vertical; min-height: 110px; }

  .btn-submit {
    background: var(--navy);
    color: var(--white);
    border: none;
    padding: 16px 40px;
    border-radius: 2px;
    font-family: 'Jost', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    align-self: flex-start;
  }

  .btn-submit:hover { background: var(--navy-deep); transform: translateY(-2px); }

  #form-msg {
    display: none;
    font-size: 0.85rem;
    color: var(--navy);
  }

  /* ── FOOTER ── */
  footer {
    background: var(--dark);
    padding: 64px 52px 36px;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 52px;
    flex-wrap: wrap;
    gap: 40px;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
  }

  .footer-brand-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.4rem;
    font-weight: 300;
    color: var(--white);
    line-height: 1.1;
  }

  .footer-brand-sub {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 6px;
  }

  .footer-links {
    display: flex;
    gap: 36px;
    list-style: none;
    align-items: center;
    flex-wrap: wrap;
  }

  .footer-links a {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(253,252,250,0.35);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--gold-light); }

  .footer-divider {
    max-width: 1100px;
    margin: 0 auto 28px;
    height: 1px;
    background: rgba(253,252,250,0.07);
  }

  .footer-copy {
    max-width: 1100px;
    margin: 0 auto;
    font-size: 0.72rem;
    color: rgba(253,252,250,0.2);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    nav { padding: 16px 24px; }
    .nav-links { display: none; }
    .hero { grid-template-columns: 1fr; }
    .hero-right { min-height: 380px; }
    .hero-left { padding: 120px 32px 60px; }
    .services-grid { grid-template-columns: 1fr; }
    .advisor-section { grid-template-columns: 1fr; }
    .advisor-left { padding: 72px 32px; }
    .contact { grid-template-columns: 1fr; }
    .contact-left { padding: 72px 32px; }
    .contact-right { padding: 72px 32px; }
    .services { padding: 72px 24px; }
    .process { padding: 72px 24px; }
    .section-header { flex-direction: column; align-items: flex-start; }
    .section-sub { text-align: left; }
    .footer-top { flex-direction: column; }
