<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta property="og:title" content="Candace Wallace Creative — Greeley, CO" />
  <meta property="og:description" content="Boutique digital marketing led by Candace Wallace. Social media, web design, and brand strategy for businesses ready to grow." />
  <title>Candace Wallace Creative | Greeley, CO</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  /* ── PANTONE 2025 MOCHA MOUSSE PALETTE ── */
  :root {
    --mocha:      #9E7B5A;   /* Pantone 17-1230 Mocha Mousse   */
    --mocha-deep: #6B4E37;   /* espresso                        */
    --mocha-mid:  #C4956A;   /* warm caramel                    */
    --cream:      #F6EDE3;   /* ivory base                      */
    --cream-mid:  #EDD9C5;   /* warm neutral                    */
    --blush:      #E8C9AF;   /* soft blush                      */
    --sage:       #8FA591;   /* sage accent                     */
    --dark:       #2A1E16;   /* near black warm                 */
    --mid:        #7A6357;   /* warm gray-brown                 */
    --white:      #FDFAF7;   /* warm white                      */
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Jost', sans-serif;
    background: var(--white);
    color: var(--dark);
    overflow-x: hidden;
  }

  /* ── THEME SWITCHER PILL ── */
  .theme-switcher {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9999;
    display: flex;
    gap: 8px;
    background: rgba(42,30,22,0.92);
    backdrop-filter: blur(8px);
    border-radius: 32px;
    padding: 8px 14px;
    align-items: center;
    box-shadow: 0 4px 24px rgba(0,0,0,0.25);
  }

  .theme-switcher span {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-right: 4px;
  }

  .theme-btn {
    padding: 6px 14px;
    border-radius: 24px;
    border: none;
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
  }

  .theme-btn.active {
    background: var(--mocha);
    color: var(--white);
  }

  .theme-btn.inactive {
    background: transparent;
    color: rgba(255,255,255,0.5);
    border: 1px solid rgba(255,255,255,0.15);
  }

  .theme-btn.inactive:hover { color: var(--white); border-color: rgba(255,255,255,0.4); }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 52px;
    background: rgba(253,250,247,0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  nav.scrolled {
    border-color: var(--cream-mid);
    box-shadow: 0 2px 24px rgba(158,123,90,0.08);
  }

  .nav-wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1;
    text-decoration: none;
  }

  .nav-wordmark-top {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--dark);
    letter-spacing: 0.04em;
  }

  .nav-wordmark-sub {
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--mocha);
    margin-top: 2px;
  }

  .nav-links {
    display: flex;
    gap: 2.4rem;
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--mid);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--mocha); }

  .nav-cta {
    background: var(--mocha) !important;
    color: var(--white) !important;
    padding: 10px 24px;
    border-radius: 2px;
  }

  .nav-cta:hover { background: var(--mocha-deep) !important; }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }

  .hero-left {
    background: var(--cream);
    display: flex;
    align-items: center;
    padding: 120px 64px 80px;
  }

  .hero-text { max-width: 500px; }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mocha);
    margin-bottom: 28px;
  }

  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--mocha);
  }

  .hero-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 5.5vw, 5rem);
    font-weight: 300;
    line-height: 1.08;
    color: var(--dark);
    margin-bottom: 28px;
  }

  .hero-heading em {
    font-style: italic;
    color: var(--mocha);
  }

  .hero-sub {
    font-size: 1rem;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.85;
    margin-bottom: 44px;
    max-width: 400px;
  }

  .hero-btns {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--mocha);
    color: var(--white);
    padding: 15px 36px;
    border-radius: 2px;
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: background 0.2s, transform 0.2s;
    display: inline-block;
  }

  .btn-primary:hover { background: var(--mocha-deep); transform: translateY(-2px); }

  .btn-ghost {
    border: 1.5px solid var(--mocha-mid);
    color: var(--mocha);
    padding: 14px 36px;
    border-radius: 2px;
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
    display: inline-block;
  }

  .btn-ghost:hover { border-color: var(--mocha-deep); color: var(--mocha-deep); transform: translateY(-2px); }

  .hero-right {
    background: var(--mocha-deep);
    position: relative;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  /* decorative panels */
  .hero-right::before {
    content: '';
    position: absolute;
    top: 60px; right: 60px;
    width: 220px; height: 280px;
    border: 1px solid rgba(253,250,247,0.12);
    border-radius: 2px;
  }

  .hero-right::after {
    content: '';
    position: absolute;
    top: 80px; right: 80px;
    width: 220px; height: 280px;
    border: 1px solid rgba(253,250,247,0.06);
    border-radius: 2px;
  }

  .hero-right-content {
    position: relative;
    z-index: 2;
    padding: 64px;
    width: 100%;
  }

  .hero-name-large {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(4rem, 7vw, 8rem);
    font-weight: 300;
    font-style: italic;
    color: rgba(253,250,247,0.15);
    line-height: 0.9;
    user-select: none;
    letter-spacing: -0.02em;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: rgba(158,123,90,0.25);
    border: 1px solid rgba(158,123,90,0.4);
    border-radius: 2px;
    padding: 12px 20px;
    margin-top: 32px;
  }

  .hero-badge-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--mocha-mid);
  }

  .hero-badge-text {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--blush);
  }

  /* decorative mocha circle */
  .hero-circle {
    position: absolute;
    top: -80px; left: -80px;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(196,149,106,0.2) 0%, transparent 70%);
  }

  /* ── MARQUEE BAR ── */
  .marquee-bar {
    background: var(--mocha);
    padding: 14px 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .marquee-track {
    display: inline-flex;
    gap: 0;
    animation: marqueeScroll 22s linear infinite;
  }

  @keyframes marqueeScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    padding: 0 32px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(253,250,247,0.85);
  }

  .marquee-dot {
    width: 4px; height: 4px;
    border-radius: 50%;
    background: rgba(253,250,247,0.4);
    flex-shrink: 0;
  }

  /* ── SERVICES ── */
  .services {
    padding: 100px 52px;
    background: var(--white);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 64px;
    flex-wrap: wrap;
    gap: 24px;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mocha);
    margin-bottom: 12px;
  }

  .section-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    font-weight: 300;
    color: var(--dark);
    line-height: 1.1;
  }

  .section-heading em {
    font-style: italic;
    color: var(--mocha);
  }

  .section-sub {
    font-size: 0.92rem;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.8;
    max-width: 340px;
    text-align: right;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    max-width: 1100px;
    margin: 0 auto;
    background: var(--cream-mid);
  }

  .service-card {
    background: var(--white);
    padding: 52px 40px;
    position: relative;
    transition: background 0.3s;
    overflow: hidden;
  }

  .service-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 40px; right: 40px;
    height: 2px;
    background: var(--mocha);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .service-card:hover { background: var(--cream); }
  .service-card:hover::after { transform: scaleX(1); }

  .service-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 4rem;
    font-weight: 300;
    color: var(--cream-mid);
    line-height: 1;
    margin-bottom: 24px;
    transition: color 0.3s;
  }

  .service-card:hover .service-num { color: var(--blush); }

  .service-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-weight: 400;
    color: var(--dark);
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .service-desc {
    font-size: 0.88rem;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.85;
  }

  /* ── CANDACE SECTION ── */
  .candace-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
  }

  .candace-left {
    background: var(--cream);
    padding: 100px 64px;
    display: flex;
    align-items: center;
  }

  .candace-text { max-width: 480px; }

  .candace-quote {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-style: italic;
    font-weight: 300;
    color: var(--dark);
    line-height: 1.5;
    margin-bottom: 32px;
    position: relative;
    padding-left: 28px;
  }

  .candace-quote::before {
    content: '';
    position: absolute;
    left: 0; top: 8px; bottom: 8px;
    width: 3px;
    background: var(--mocha);
  }

  .candace-desc {
    font-size: 0.92rem;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.9;
    margin-bottom: 36px;
  }

  .candace-sig {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-style: italic;
    color: var(--mocha);
  }

  .candace-right {
    background: var(--dark);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .candace-right-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 64px;
  }

  .candace-initial {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18rem;
    font-weight: 300;
    font-style: italic;
    color: rgba(158,123,90,0.12);
    line-height: 1;
    user-select: none;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .candace-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: rgba(158,123,90,0.15);
    position: relative;
    z-index: 3;
  }

  .stat-box {
    background: rgba(42,30,22,0.8);
    padding: 36px 32px;
    text-align: center;
  }

  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.2rem;
    font-weight: 300;
    color: var(--mocha-mid);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(253,250,247,0.35);
    margin-top: 8px;
  }

  /* ── PROCESS ── */
  .process {
    padding: 100px 52px;
    background: var(--cream);
  }

  .process-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .process-list {
    margin-top: 64px;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--cream-mid);
  }

  .process-item {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    align-items: center;
    gap: 40px;
    padding: 36px 0;
    border-bottom: 1px solid var(--cream-mid);
    cursor: default;
    transition: background 0.2s;
  }

  .process-item:hover { background: rgba(158,123,90,0.04); margin: 0 -20px; padding: 36px 20px; }

  .process-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.4rem;
    font-weight: 300;
    color: var(--blush);
    line-height: 1;
  }

  .process-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--dark);
    margin-bottom: 6px;
  }

  .process-desc {
    font-size: 0.86rem;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.7;
  }

  .process-arrow {
    font-size: 1.2rem;
    color: var(--mocha);
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
    transform: translateX(-8px);
  }

  .process-item:hover .process-arrow { opacity: 1; transform: translateX(0); }

  /* ── CONTACT ── */
  .contact {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 700px;
  }

  .contact-left {
    background: var(--mocha-deep);
    padding: 100px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-left .section-eyebrow { color: var(--blush); }

  .contact-left .section-heading { color: var(--white); margin-bottom: 24px; }

  .contact-sub {
    font-size: 0.92rem;
    font-weight: 300;
    color: rgba(253,250,247,0.55);
    line-height: 1.9;
    margin-bottom: 52px;
    max-width: 380px;
  }

  .contact-detail {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .contact-detail-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .detail-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mocha-mid);
    min-width: 72px;
    padding-top: 2px;
  }

  .detail-value {
    font-size: 0.92rem;
    font-weight: 300;
    color: rgba(253,250,247,0.7);
    line-height: 1.6;
  }

  .contact-right {
    background: var(--cream);
    padding: 100px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 440px;
  }

  .form-row { display: flex; gap: 20px; }

  .form-field {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-field label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mid);
  }

  .form-field input,
  .form-field textarea,
  .form-field select {
    background: var(--white);
    border: 1px solid var(--blush);
    border-radius: 2px;
    padding: 14px 16px;
    font-family: 'Jost', sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--dark);
    outline: none;
    transition: border-color 0.2s;
    -webkit-appearance: none;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder { color: var(--blush); }

  .form-field input:focus,
  .form-field textarea:focus,
  .form-field select:focus { border-color: var(--mocha); }

  .form-field textarea { resize: vertical; min-height: 110px; }

  .btn-submit {
    background: var(--mocha);
    color: var(--white);
    border: none;
    padding: 16px 40px;
    border-radius: 2px;
    font-family: 'Jost', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    align-self: flex-start;
  }

  .btn-submit:hover { background: var(--mocha-deep); transform: translateY(-2px); }

  #form-msg {
    display: none;
    font-size: 0.85rem;
    color: var(--mocha);
  }

  /* ── FOOTER ── */
  footer {
    background: var(--dark);
    padding: 64px 52px 36px;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 52px;
    flex-wrap: wrap;
    gap: 40px;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
  }

  .footer-brand-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.4rem;
    font-weight: 300;
    color: var(--white);
    line-height: 1.1;
  }

  .footer-brand-sub {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--mocha);
    margin-top: 6px;
  }

  .footer-links {
    display: flex;
    gap: 36px;
    list-style: none;
    align-items: center;
    flex-wrap: wrap;
  }

  .footer-links a {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(253,250,247,0.35);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--mocha-mid); }

  .footer-divider {
    max-width: 1100px;
    margin: 0 auto 28px;
    height: 1px;
    background: rgba(253,250,247,0.07);
  }

  .footer-copy {
    max-width: 1100px;
    margin: 0 auto;
    font-size: 0.72rem;
    color: rgba(253,250,247,0.2);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    nav { padding: 16px 24px; }
    .nav-links { display: none; }
    .hero { grid-template-columns: 1fr; }
    .hero-right { min-height: 380px; }
    .hero-left { padding: 120px 32px 60px; }
    .services-grid { grid-template-columns: 1fr; }
    .candace-section { grid-template-columns: 1fr; }
    .candace-left { padding: 72px 32px; }
    .contact { grid-template-columns: 1fr; }
    .contact-left { padding: 72px 32px; }
    .contact-right { padding: 72px 32px; }
    .services { padding: 72px 24px; }
    .process { padding: 72px 24px; }
    .section-header { flex-direction: column; align-items: flex-start; }
    .section-sub { text-align: left; }
    .footer-top { flex-direction: column; }
