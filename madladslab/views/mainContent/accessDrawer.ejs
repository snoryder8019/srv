<% if (typeof user === 'object' && user) {
    const allModules = [
        { key: 'agents',      label: 'Agent Hub',  path: '/agents/hub',     icon: '🗂️' },
        { key: 'agents',      label: 'Digest',     path: '/agents/digest',  icon: '📋' },
        { key: 'agents',      label: 'Briefs',     path: '/agents/reports', icon: '📄' },
        { key: 'agents',      label: 'Display',    path: '/agents/display', icon: '📺' },
        { key: 'grafitti',    label: 'Grafitti TV', path: '/grafitti',      icon: '📺' },
        { key: 'skins',       label: 'Skins',      path: '/skins',          icon: '🎨' },
        { key: 'payments',    label: 'Payments',   path: '/payments',       icon: '💳' },
        { key: 'hue',         label: 'Hue',        path: '/hue',            icon: '💡' },
        { key: 'w2marketing', label: 'W2 Marketing', path: '/w2marketing',  icon: '📣' },
    ];
    const perms = user.permissions || {};
    const isSuper = user.isAdmin === true;
    const visibleModules = isSuper
        ? allModules.map(m => ({ ...m, level: 'admin' }))
        : allModules
            .filter(m => perms[m.key])
            .map(m => ({ ...m, level: perms[m.key] }));
    const initials = ((user.displayName || user.firstName || user.email || '?')[0]).toUpperCase();
%>

<!-- Access Drawer Panel -->
<div id="accessDrawerOverlay"></div>
<div id="accessDrawer">
    <div class="adr-header">
        <div class="adr-user">
            <div class="adr-avatar"><%= initials %></div>
            <div>
                <div class="adr-name"><%= user.displayName || user.firstName || user.email %></div>
                <div class="adr-email"><%= user.email %></div>
            </div>
        </div>
        <button class="adr-close" id="accessDrawerClose">×</button>
    </div>

    <% if (isSuper) { %>
    <div class="adr-section-title" style="padding-bottom:4px;">Admin Panel</div>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:4px; padding:0 10px 6px;">
        <% [
            { label:'Dashboard',  path:'/admin',          icon:'⚡' },
            { label:'Users',      path:'/admin/users',    icon:'👥' },
            { label:'Sites',      path:'/admin/sites',    icon:'🌐' },
            { label:'Analytics',  path:'/admin/analytics',icon:'📊' },
            { label:'Live Chats', path:'/admin/livechats',icon:'💬' },
            { label:'Monitor',    path:'/admin/monitor',  icon:'🖥️' },
            { label:'Settings',   path:'/admin/settings', icon:'⚙️' },
        ].forEach(function(p) { %>
        <a href="<%= p.path %>" style="
            display:flex; align-items:center; gap:5px; padding:5px 7px; border-radius:6px;
            background:rgba(124,58,237,0.06); border:1px solid rgba(124,58,237,0.15);
            color:#a78bfa; font-size:0.72rem; text-decoration:none; white-space:nowrap;
        "><%= p.icon %> <%= p.label %></a>
        <% }); %>
    </div>
    <% } %>

    <div class="adr-section-title">
        <% if (visibleModules.length > 0) { %>My Access (<%= visibleModules.length %>)<% } else { %>No modules assigned<% } %>
    </div>

    <div class="adr-grid">
        <% visibleModules.forEach(function(m) { %>
        <a href="<%= m.path %>" class="adr-card adr-card--<%= m.level %>">
            <span class="adr-icon"><%= m.icon %></span>
            <span class="adr-label"><%= m.label %></span>
            <span class="adr-level"><%= m.level %></span>
        </a>
        <% }); %>
        <% if (visibleModules.length === 0) { %>
        <div class="adr-empty">Contact an admin to get module access.</div>
        <% } %>
    </div>

    <div class="adr-section-title">Sites & Apps</div>
    <div class="adr-sites">
        <% [
            { label: 'MadLadsLab',     url: 'https://madladslab.com',            live: true  },
            { label: 'BallzInHolez',   url: 'https://ballzinholez.com',          live: true  },
            { label: 'PS',             url: 'https://ps.madladslab.com',          live: true  },
            { label: 'Game State',     url: 'https://svc.madladslab.com',         live: true  },
            { label: 'Games',          url: 'https://games.madladslab.com',       live: true  },
            { label: 'Servers',        url: 'https://servers.madladslab.com',     live: true  },
            { label: 'ACM',            url: 'https://acmcreativeconcepts.com',    live: true  },
            { label: 'SNA',            url: 'https://somenewsarticle.com',        live: true  },
            { label: 'TWWW',           url: 'https://theworldwidewallet.com',     live: true  },
            { label: 'MadThree',       url: 'https://three.madladslab.com',       live: true  },
            { label: 'Graffiti TV',    url: 'https://graffititv.madladslab.com',  live: true  },
            { label: 'NoCometalWorkz', url: 'https://nocometalworkz.com',         live: true  },
            { label: 'GreaLityTV',     url: 'https://greealitytv.com',            live: true  },
            { label: 'W2 Marketing',   url: 'https://w2marketing.biz',            live: true  },
        ].forEach(function(s) { %>
        <a href="<%= s.url %>" target="_blank" class="adr-site-link">
            <span class="adr-site-dot <%= s.live ? 'adr-site-dot--live' : '' %>"></span>
            <span class="adr-site-name"><%= s.label %></span>
        </a>
        <% }); %>
    </div>

    <div class="adr-footer">
        <a href="/logout" class="adr-logout">Sign Out</a>
    </div>
</div>

<style>
#accessDrawerOverlay {
    display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1100;
}
#accessDrawer {
    position: fixed; top: 0; right: -300px; width: 280px; max-width: 92vw;
    height: 100vh; background: #0f172a; border-left: 1px solid rgba(255,255,255,0.08);
    z-index: 1101; overflow-y: auto; transition: right 0.22s ease;
    display: flex; flex-direction: column;
}
#accessDrawer.open { right: 0; }
#accessDrawerOverlay.open { display: block; }

.adr-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 14px 10px; border-bottom: 1px solid rgba(255,255,255,0.07); flex-shrink: 0;
}
.adr-user { display: flex; align-items: center; gap: 8px; }
.adr-avatar {
    width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
    background: linear-gradient(135deg, #7c3aed, #2563eb);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 0.75rem; color: #fff;
}
.adr-name { font-size: 0.82rem; font-weight: 600; color: #e2e8f0; }
.adr-email { font-size: 0.7rem; color: #475569; }
.adr-close { background: none; border: none; color: #475569; font-size: 1.2rem; cursor: pointer; line-height: 1; }
.adr-close:hover { color: #e2e8f0; }

.adr-admin-link {
    display: flex; align-items: center; gap: 6px; margin: 8px 10px 0;
    padding: 7px 10px; border-radius: 6px;
    background: rgba(124,58,237,0.08); border: 1px solid rgba(124,58,237,0.25);
    color: #a78bfa; font-size: 0.78rem; font-weight: 600; text-decoration: none;
}
.adr-admin-link:hover { background: rgba(124,58,237,0.18); }

.adr-section-title {
    padding: 10px 14px 4px; font-size: 0.62rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em; color: #334155; flex-shrink: 0;
}
.adr-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px;
    padding: 4px 10px 10px; flex: 1;
}
.adr-card {
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    padding: 8px 6px; border-radius: 7px; text-decoration: none; text-align: center;
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);
    transition: background 0.12s;
}
.adr-card:hover { background: rgba(255,255,255,0.08); }
.adr-icon { font-size: 1.1rem; line-height: 1; }
.adr-label { font-size: 0.68rem; font-weight: 600; color: #94a3b8; line-height: 1.2; }
.adr-level {
    font-size: 0.55rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.04em; padding: 1px 5px; border-radius: 999px;
}
.adr-card--read  .adr-level { background: rgba(3,105,161,0.2); color: #38bdf8; }
.adr-card--write .adr-level { background: rgba(217,119,6,0.2);  color: #fb923c; }
.adr-card--admin .adr-level { background: rgba(220,38,38,0.15); color: #f87171; }

.adr-empty { grid-column: 1/-1; color: #475569; font-size: 0.78rem; padding: 8px 0; text-align: center; }

.adr-sites {
    display: flex; flex-direction: column; gap: 2px; padding: 2px 10px 10px; flex-shrink: 0;
}
.adr-site-link {
    display: flex; align-items: center; gap: 8px; padding: 5px 8px; border-radius: 5px;
    text-decoration: none; color: #64748b; font-size: 0.74rem; transition: background 0.1s;
}
.adr-site-link:hover { background: rgba(255,255,255,0.05); color: #94a3b8; }
.adr-site-dot {
    width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
    background: #1e293b; border: 1px solid #334155;
}
.adr-site-dot--live {
    background: #22c55e; border-color: #16a34a;
    box-shadow: 0 0 6px rgba(34,197,94,0.5);
    animation: adr-pulse 2.5s ease-in-out infinite;
}
@keyframes adr-pulse {
    0%, 100% { box-shadow: 0 0 5px rgba(34,197,94,0.5); }
    50%       { box-shadow: 0 0 10px rgba(34,197,94,0.8); }
}
.adr-site-name { flex: 1; }

.adr-footer {
    padding: 8px 14px; border-top: 1px solid rgba(255,255,255,0.07); flex-shrink: 0;
}
.adr-logout { font-size: 0.75rem; color: #475569; text-decoration: none; }
.adr-logout:hover { color: #e2e8f0; }
</style>

<script>
var _adrDrawer  = document.getElementById('accessDrawer');
var _adrOverlay = document.getElementById('accessDrawerOverlay');
document.getElementById('accessDrawerClose').addEventListener('click', closeAccessDrawer);
_adrOverlay.addEventListener('click', closeAccessDrawer);
document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeAccessDrawer(); });

function openAccessDrawer()  {
    _adrDrawer.classList.add('open');
    _adrOverlay.classList.add('open');
    document.body.style.overflow = 'hidden';
}
function closeAccessDrawer() {
    _adrDrawer.classList.remove('open');
    _adrOverlay.classList.remove('open');
    document.body.style.overflow = '';
}
</script>

<% } %>
