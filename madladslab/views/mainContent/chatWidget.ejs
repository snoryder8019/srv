<!-- Live Chat Widget -->
<style>
/* Chat Widget Styles - Matches madLadsLab luxury dark theme */
#chatWidget {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 9999;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

#chatButton {
  width: 64px;
  height: 64px;
  border-radius: 32px;
  background: linear-gradient(135deg, rgba(255,255,255,0.12), rgba(255,255,255,0.08));
  border: 1px solid rgba(255,255,255,0.15);
  box-shadow: 0 8px 24px rgba(0,0,0,0.4), 0 2px 8px rgba(0,0,0,0.2);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  backdrop-filter: blur(10px);
}

#chatButton:hover {
  transform: scale(1.08);
  background: linear-gradient(135deg, rgba(255,255,255,0.16), rgba(255,255,255,0.12));
  box-shadow: 0 12px 32px rgba(0,0,0,0.5), 0 4px 12px rgba(0,0,0,0.3);
}

#chatButton svg {
  width: 28px;
  height: 28px;
  fill: rgba(255,255,255,0.9);
  transition: transform 0.3s;
}

#chatButton.open svg {
  transform: rotate(90deg);
}

#chatPanel {
  position: fixed;
  bottom: 104px;
  right: 24px;
  width: 380px;
  max-width: calc(100vw - 48px);
  height: 560px;
  max-height: calc(100vh - 140px);
  background: #0a0a0a;
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 16px;
  box-shadow: 0 16px 48px rgba(0,0,0,0.6), 0 4px 16px rgba(0,0,0,0.4);
  display: none;
  flex-direction: column;
  overflow: hidden;
  backdrop-filter: blur(20px);
  animation: slideUp 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

#chatPanel.open {
  display: flex;
}

#chatHeader {
  padding: 20px;
  background: rgba(255,255,255,0.04);
  border-bottom: 1px solid rgba(255,255,255,0.08);
  display: flex;
  align-items: center;
  gap: 12px;
}

#chatHeader img {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.15);
}

#chatHeader .info {
  flex: 1;
}

#chatHeader .info h3 {
  margin: 0;
  font-size: 15px;
  font-weight: 600;
  color: rgba(255,255,255,0.95);
  letter-spacing: 0.02em;
}

#chatHeader .info p {
  margin: 2px 0 0;
  font-size: 12px;
  color: rgba(255,255,255,0.5);
}

#chatHeader .status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #4caf50;
  flex-shrink: 0;
}

#chatHeader .status-dot.offline {
  background: rgba(255,255,255,0.2);
}

#chatMessages {
  flex: 1;
  padding: 20px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 16px;
  background: #0a0a0a;
}

#chatMessages::-webkit-scrollbar {
  width: 6px;
}

#chatMessages::-webkit-scrollbar-track {
  background: rgba(255,255,255,0.03);
  border-radius: 3px;
}

#chatMessages::-webkit-scrollbar-thumb {
  background: rgba(255,255,255,0.1);
  border-radius: 3px;
}

#chatMessages::-webkit-scrollbar-thumb:hover {
  background: rgba(255,255,255,0.15);
}

.chat-message {
  display: flex;
  gap: 10px;
  animation: fadeIn 0.3s;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.chat-message.user {
  justify-content: flex-end;
}

.chat-message .bubble {
  max-width: 75%;
  padding: 12px 16px;
  border-radius: 12px;
  font-size: 14px;
  line-height: 1.5;
  word-wrap: break-word;
}

.chat-message.assistant .bubble {
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.9);
  border: 1px solid rgba(255,255,255,0.06);
}

.chat-message.user .bubble {
  background: linear-gradient(135deg, rgba(255,255,255,0.15), rgba(255,255,255,0.1));
  color: rgba(255,255,255,0.95);
  border: 1px solid rgba(255,255,255,0.12);
}

.chat-message.admin .bubble {
  background: rgba(255, 170, 0, 0.12);
  color: rgba(255,255,255,0.95);
  border: 1px solid rgba(255, 170, 0, 0.3);
  box-shadow: 0 2px 8px rgba(255, 170, 0, 0.1);
}

.chat-message.admin .agent-label {
  display: inline-block;
  background: rgba(255, 170, 0, 0.2);
  color: #ffaa00;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 6px;
}

.chat-message .avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
}

#chatForm {
  padding: 16px;
  background: rgba(255,255,255,0.04);
  border-top: 1px solid rgba(255,255,255,0.08);
  display: flex;
  gap: 10px;
}

#chatInput {
  flex: 1;
  padding: 12px 16px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  color: rgba(255,255,255,0.95);
  font-size: 14px;
  font-family: inherit;
  outline: none;
  transition: all 0.2s;
}

#chatInput:focus {
  background: rgba(255,255,255,0.08);
  border-color: rgba(255,255,255,0.2);
}

#chatInput::placeholder {
  color: rgba(255,255,255,0.4);
}

#chatSendBtn {
  padding: 0 18px;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 8px;
  color: rgba(255,255,255,0.9);
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

#chatSendBtn:hover:not(:disabled) {
  background: rgba(255,255,255,0.16);
  transform: translateY(-1px);
}

#chatSendBtn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.typing-indicator {
  display: flex;
  gap: 4px;
  padding: 12px 16px;
  background: rgba(255,255,255,0.08);
  border-radius: 12px;
  width: fit-content;
}

.typing-indicator span {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  animation: typing 1.4s infinite;
}

.typing-indicator span:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-indicator span:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% { opacity: 0.3; transform: translateY(0); }
  30% { opacity: 1; transform: translateY(-6px); }
}

@media (max-width: 480px) {
  #chatPanel {
    width: calc(100vw - 32px);
    height: calc(100vh - 120px);
    bottom: 96px;
    right: 16px;
  }
  #chatButton {
    bottom: 16px;
    right: 16px;
  }
}

/* Markdown rendering inside chat bubbles */
.bubble.markdown-body p { margin: 0 0 8px; }
.bubble.markdown-body p:last-child { margin-bottom: 0; }
.bubble.markdown-body ul,
.bubble.markdown-body ol { margin: 4px 0 8px; padding-left: 18px; }
.bubble.markdown-body li { margin-bottom: 2px; }
.bubble.markdown-body code {
  background: rgba(255,255,255,0.12);
  padding: 1px 5px;
  border-radius: 3px;
  font-size: 12px;
  font-family: 'Courier New', monospace;
}
.bubble.markdown-body pre {
  background: rgba(0,0,0,0.4);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 6px;
  padding: 10px 12px;
  overflow-x: auto;
  margin: 6px 0;
}
.bubble.markdown-body pre code {
  background: none;
  padding: 0;
  font-size: 12px;
}
.bubble.markdown-body strong { color: rgba(255,255,255,1); }
.bubble.markdown-body em { color: rgba(255,255,255,0.75); }
.bubble.markdown-body h1,
.bubble.markdown-body h2,
.bubble.markdown-body h3 {
  margin: 6px 0 4px;
  font-size: 14px;
  font-weight: 600;
  color: rgba(255,255,255,0.95);
}
.bubble.markdown-body a { color: rgba(120,180,255,0.9); }
.bubble.markdown-body blockquote {
  border-left: 2px solid rgba(255,255,255,0.2);
  margin: 4px 0;
  padding-left: 10px;
  color: rgba(255,255,255,0.6);
}
.bubble.markdown-body hr { border-color: rgba(255,255,255,0.1); margin: 8px 0; }
</style>

<% if (typeof chatAgent === 'object' && chatAgent) { %>
<!-- Chat Widget HTML -->
<div id="chatWidget">
  <div id="chatButton" onclick="toggleChat()">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
      <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/>
    </svg>
  </div>

  <div id="chatPanel">
    <div id="chatHeader">
        <img src="/images/beaker_logo_no_stash.png" alt="<%= chatAgent.name %>">
      <div class="info">
        <h3><%= chatAgent.name %></h3>
        <p><%= chatAgent.description || 'madLadsLab Assistant' %></p>
      </div>
      <div id="chatStatusDot" class="status-dot offline"></div>
    </div>

    <div id="chatMessages">
      <div class="chat-message assistant">
            <div class="avatar"><%= chatAgent.name[0].toUpperCase() %></div>
        <div class="bubble">Hey there! I'm <%= chatAgent.name %>, your guide to madLadsLab. How can I help you today?</div>
      </div>
    </div>

    <form id="chatForm" onsubmit="sendMessage(event)">
      <input
        type="text"
        id="chatInput"
        placeholder="Type your message..."
        autocomplete="off"
        maxlength="500"
      >
      <button type="submit" id="chatSendBtn">Send</button>
    </form>
  </div>
</div>
<% } %>

<% if (typeof chatAgent === 'object' && chatAgent) { %>
<script src="/socket.io/socket.io.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
(function() {
  const SITE_TOKEN = <%- JSON.stringify(chatAgent._siteToken || '') %>;
  const STORAGE_KEY = 'fwdchat_session_' + SITE_TOKEN;
  let sessionId = localStorage.getItem(STORAGE_KEY);
  if (!sessionId) {
    sessionId = 'chat_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
    localStorage.setItem(STORAGE_KEY, sessionId);
  }

  // Agent avatar (falls back to initials)
  const CHAT_AVATAR_URL = '';
  const CHAT_AGENT_INITIAL = <%- JSON.stringify((chatAgent.name || '?')[0].toUpperCase()) %>;

  function avatarHtml() {
    if (CHAT_AVATAR_URL) {
      return `<img src="${CHAT_AVATAR_URL}" style="width:32px;height:32px;border-radius:50%;object-fit:cover;flex-shrink:0;" alt="avatar">`;
    }
    return `<div class="avatar">${CHAT_AGENT_INITIAL}</div>`;
  }

  // Cookie helpers
  function getCookie(name) {
    const match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]*)'));
    return match ? decodeURIComponent(match[1]) : null;
  }
  function setCookie(name, value, days) {
    const expires = new Date(Date.now() + days * 864e5).toUTCString();
    document.cookie = `${name}=${encodeURIComponent(value)}; expires=${expires}; path=/; SameSite=Lax`;
  }

  // Visitor identity: logged-in session (server-injected) merged with stored cookies
  const serverUser = <%- JSON.stringify(
    (typeof user === 'object' && user)
      ? { name: user.displayName || user.firstName || null, email: user.email || null }
      : null
  ) %>;
  const VISITOR = {
    name:  (serverUser && serverUser.name)  || getCookie('ml_visitor_name')  || null,
    email: (serverUser && serverUser.email) || getCookie('ml_visitor_email') || null,
    phone: getCookie('ml_visitor_phone') || null,
  };

  let pepeSocket = null;
  let typingEl = null;
  let inputLocked = false;

  function getSocket() {
    if (pepeSocket && pepeSocket.connected) return pepeSocket;

    pepeSocket = io('/forwardchat', {
      transports: ['websocket', 'polling'],
      query: { site: SITE_TOKEN },
      reconnection: true,
      reconnectionDelay: 2000,
      reconnectionAttempts: 5
    });

    pepeSocket.on('connect', () => {
      document.getElementById('chatStatusDot').classList.remove('offline');
      pepeSocket.emit('visitor:identify', sessionId);
    });

    pepeSocket.on('admin:message', ({ message }) => {
      removeTyping();
      addMessage('admin', message);
    });

    pepeSocket.on('disconnect', () => {
      document.getElementById('chatStatusDot').classList.add('offline');
    });

    pepeSocket.on('typing', (isTyping) => {
      if (isTyping) {
        showTyping();
      } else {
        removeTyping();
      }
    });

    pepeSocket.on('response', ({ message }) => {
      removeTyping();
      addMessage('assistant', message);
      document.getElementById('chatSendBtn').disabled = false;
      document.getElementById('chatInput').disabled = false;
      document.getElementById('chatInput').focus();
      inputLocked = false;
    });

    pepeSocket.on('lead:captured', (data) => {
      // Write cookies for 30 days so returning visitors are recognised
      if (data.name)  { setCookie('ml_visitor_name',  data.name,  30); VISITOR.name  = data.name; }
      if (data.email) { setCookie('ml_visitor_email', data.email, 30); VISITOR.email = data.email; }
      if (data.phone) { setCookie('ml_visitor_phone', data.phone, 30); VISITOR.phone = data.phone; }
    });

    pepeSocket.on('error', ({ error, limitReached }) => {
      removeTyping();
      addMessage('assistant', error);
      if (limitReached) {
        document.getElementById('chatSendBtn').disabled = true;
        document.getElementById('chatInput').disabled = true;
        document.getElementById('chatInput').placeholder = 'Session limit reached';
      } else {
        document.getElementById('chatSendBtn').disabled = false;
        document.getElementById('chatInput').disabled = false;
      }
      inputLocked = false;
    });

    return pepeSocket;
  }

  window.toggleChat = function() {
    const button = document.getElementById('chatButton');
    const panel = document.getElementById('chatPanel');
    const isOpen = panel.classList.contains('open');

    if (isOpen) {
      panel.classList.remove('open');
      button.classList.remove('open');
    } else {
      panel.classList.add('open');
      button.classList.add('open');
      document.getElementById('chatInput').focus();
      // Connect on first open
      getSocket();
    }
  };

  window.sendMessage = function(e) {
    e.preventDefault();
    if (inputLocked) return;

    const input = document.getElementById('chatInput');
    const sendBtn = document.getElementById('chatSendBtn');
    const message = input.value.trim();
    if (!message) return;

    addMessage('user', message);
    input.value = '';
    sendBtn.disabled = true;
    input.disabled = true;
    inputLocked = true;

    getSocket().emit('message', { sessionId, message, visitor: VISITOR });
  };

  function showTyping() {
    if (typingEl) return;
    const messages = document.getElementById('chatMessages');
    typingEl = document.createElement('div');
    typingEl.className = 'chat-message assistant';
    typingEl.id = 'pepe-typing';
    typingEl.innerHTML = `
      ${avatarHtml()}
      <div class="typing-indicator"><span></span><span></span><span></span></div>
    `;
    messages.appendChild(typingEl);
    messages.scrollTop = messages.scrollHeight;
  }

  function removeTyping() {
    if (typingEl) {
      typingEl.remove();
      typingEl = null;
    }
  }

  function addMessage(role, content) {
    const messages = document.getElementById('chatMessages');
    const div = document.createElement('div');
    div.className = 'chat-message ' + role;

    if (role === 'assistant') {
      const md = typeof marked !== 'undefined' ? marked.parse(content) : escapeHtml(content);
      div.innerHTML = `${avatarHtml()}<div class="bubble markdown-body">${md}</div>`;
    } else if (role === 'admin') {
      const md = typeof marked !== 'undefined' ? marked.parse(content) : escapeHtml(content);
      div.innerHTML = `<div class="avatar">👨‍💼</div><div class="bubble markdown-body"><div class="agent-label">Human Agent</div>${md}</div>`;
    } else {
      div.innerHTML = `<div class="bubble">${escapeHtml(content)}</div>`;
    }

    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  function escapeHtml(text) {
    const d = document.createElement('div');
    d.textContent = text;
    return d.innerHTML;
  }
})();
</script>
<% } %>
