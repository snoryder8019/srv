<% if (user && user.isAdmin) { %>
<header class="admin-topbar">
    <div class="topbar-left">
        <a href="/admin" class="logo">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            <span>Command Center</span>
        </a>
    </div>
    <div class="topbar-right">
        <div class="user-menu">
            <button onclick="openAccessDrawer()" title="My Apps" style="
                background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
                border-radius: 7px; padding: 6px 10px; cursor: pointer; color: rgba(255,255,255,0.7);
                display: flex; flex-direction: column; gap: 3px; align-items: center; margin-right: 8px;
            ">
                <span style="display:block; width:16px; height:2px; background:currentColor; border-radius:2px;"></span>
                <span style="display:block; width:16px; height:2px; background:currentColor; border-radius:2px;"></span>
                <span style="display:block; width:16px; height:2px; background:currentColor; border-radius:2px;"></span>
            </button>
            <div class="user-avatar">
                <%= user.name ? user.name.charAt(0).toUpperCase() : 'A' %>
            </div>
            <span class="user-name"><%= user.name %></span>
            <a href="/logout" class="logout-btn" title="Logout">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
            </a>
        </div>
    </div>
</header>
<% } %>
<%- include('./accessDrawer.ejs') %>
