<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MadLabs — Agent Display</title>
<style>
/* ── Reset & base ─────────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg:        #030508;
  --surface:   rgba(255,255,255,0.03);
  --border:    rgba(255,255,255,0.06);
  --text:      #e8eaf0;
  --muted:     rgba(255,255,255,0.35);
  --glow-w:    rgba(255,255,255,0.12);

  /* category palette */
  --c-business:  #00c8ff;
  --c-ops:       #ff9f0a;
  --c-security:  #ff453a;
  --c-research:  #bf5af2;
  --c-personal:  #32d74b;
  --c-creative:  #ff375f;
  --c-education: #ffd60a;
  --c-other:     #636366;

  --font-mono: 'Courier New', Courier, monospace;
}

html, body {
  width: 100%; height: 100%;
  overflow: hidden;
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ── Canvas starfield ─────────────────────────────────────────────────────── */
#starfield {
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
}

/* ── Layout ───────────────────────────────────────────────────────────────── */
.display-root {
  position: relative; z-index: 1;
  display: grid;
  grid-template-rows: 64px 1fr 52px;
  height: 100vh;
  padding: 10px;
  gap: 10px;
}

/* ── Top bar ──────────────────────────────────────────────────────────────── */
.topbar {
  display: flex; align-items: center; gap: 18px;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 0 20px;
  backdrop-filter: blur(12px);
  position: relative;
  overflow: hidden;
}
.topbar::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
  animation: scanline 4s ease-in-out infinite;
}
@keyframes scanline {
  0%,100% { opacity: 0; transform: scaleX(0.3); }
  50% { opacity: 1; transform: scaleX(1); }
}

.topbar-logo {
  font-size: 1rem; font-weight: 700; letter-spacing: 0.15em;
  color: #fff; text-transform: uppercase;
  display: flex; align-items: center; gap: 8px;
}
.topbar-logo .logo-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: #00c8ff;
  box-shadow: 0 0 8px #00c8ff, 0 0 16px #00c8ff40;
  animation: pulse-dot 2s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%,100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.7); }
}

.topbar-sep { width: 1px; height: 30px; background: var(--border); }

.topbar-stat {
  display: flex; flex-direction: column; align-items: center;
  min-width: 60px;
}
.topbar-stat .val {
  font-size: 1.4rem; font-weight: 700; line-height: 1;
  font-variant-numeric: tabular-nums;
  transition: color 0.4s;
}
.topbar-stat .lbl {
  font-size: 0.58rem; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--muted); margin-top: 2px;
}
.topbar-stat.active .val { color: #32d74b; text-shadow: 0 0 12px #32d74b80; }
.topbar-stat.bg .val     { color: #bf5af2; text-shadow: 0 0 12px #bf5af280; }
.topbar-stat.tasks .val  { color: #ffd60a; text-shadow: 0 0 12px #ffd60a80; }

.topbar-spacer { flex: 1; }

.topbar-clock {
  font-size: 1.55rem; font-weight: 300; letter-spacing: 0.08em;
  font-variant-numeric: tabular-nums;
  color: rgba(255,255,255,0.85);
  font-family: var(--font-mono);
}
.topbar-date {
  font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--muted); text-align: right;
}

/* ── Category grid ────────────────────────────────────────────────────────── */
.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: repeat(2, 1fr);
  gap: 10px;
}

/* ── Category panel ───────────────────────────────────────────────────────── */
.cat-panel {
  background: var(--surface);
  border-radius: 12px;
  border: 1px solid var(--border);
  overflow: hidden;
  display: flex; flex-direction: column;
  position: relative;
  backdrop-filter: blur(8px);
  transition: border-color 0.4s, box-shadow 0.4s;
}
.cat-panel::after {
  content: '';
  position: absolute; inset: 0;
  border-radius: 12px;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.6s;
}
.cat-panel.has-active::after {
  opacity: 1;
}

/* Per-category glow color */
.cat-panel[data-cat="business"]  { --cc: var(--c-business); }
.cat-panel[data-cat="ops"]       { --cc: var(--c-ops); }
.cat-panel[data-cat="security"]  { --cc: var(--c-security); }
.cat-panel[data-cat="research"]  { --cc: var(--c-research); }
.cat-panel[data-cat="personal"]  { --cc: var(--c-personal); }
.cat-panel[data-cat="creative"]  { --cc: var(--c-creative); }
.cat-panel[data-cat="education"] { --cc: var(--c-education); }
.cat-panel[data-cat="other"]     { --cc: var(--c-other); }

.cat-panel.has-active {
  border-color: color-mix(in srgb, var(--cc) 30%, transparent);
  box-shadow: 0 0 20px color-mix(in srgb, var(--cc) 12%, transparent),
              inset 0 0 30px color-mix(in srgb, var(--cc) 4%, transparent);
}

.cat-header {
  display: flex; align-items: center; gap: 8px;
  padding: 10px 14px 8px;
  border-bottom: 1px solid var(--border);
  position: relative;
}
.cat-header::before {
  content: '';
  position: absolute; bottom: -1px; left: 14px; right: 14px; height: 1px;
  background: linear-gradient(90deg, var(--cc), transparent);
  opacity: 0.5;
}

.cat-icon { font-size: 1rem; }
.cat-name {
  font-size: 0.68rem; font-weight: 700; letter-spacing: 0.16em;
  text-transform: uppercase; color: var(--cc);
  text-shadow: 0 0 8px color-mix(in srgb, var(--cc) 60%, transparent);
}
.cat-count {
  margin-left: auto;
  font-size: 0.6rem; color: var(--muted); letter-spacing: 0.08em;
}

.cat-body {
  flex: 1; overflow: hidden;
  padding: 8px;
  display: flex; flex-direction: column; gap: 5px;
}

/* ── Agent row ────────────────────────────────────────────────────────────── */
.agent-row {
  display: flex; align-items: center; gap: 7px;
  padding: 6px 8px;
  border-radius: 7px;
  background: rgba(255,255,255,0.025);
  border: 1px solid rgba(255,255,255,0.04);
  position: relative;
  overflow: hidden;
  animation: row-in 0.5s ease both;
  transition: background 0.3s, border-color 0.3s;
}
.agent-row.is-active {
  background: color-mix(in srgb, var(--cc) 6%, transparent);
  border-color: color-mix(in srgb, var(--cc) 20%, transparent);
}
.agent-row.is-bg {
  animation: row-in 0.5s ease both, bg-breathe 3s ease-in-out infinite;
}
@keyframes row-in {
  from { opacity: 0; transform: translateY(4px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes bg-breathe {
  0%,100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--cc) 20%, transparent); }
  50%     { box-shadow: 0 0 8px 2px color-mix(in srgb, var(--cc) 20%, transparent); }
}

/* Scan sweep on active rows */
.agent-row.is-active::before {
  content: '';
  position: absolute; top: 0; left: -100%; width: 60%;  height: 100%;
  background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--cc) 8%, transparent), transparent);
  animation: sweep 4s ease-in-out infinite;
}
@keyframes sweep {
  0%   { left: -60%; }
  100% { left: 160%; }
}

.agent-dot {
  width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
  transition: background 0.4s, box-shadow 0.4s;
}
.agent-dot.idle    { background: #636366; }
.agent-dot.running { background: #32d74b; box-shadow: 0 0 6px #32d74b; animation: blink 1.4s ease-in-out infinite; }
.agent-dot.stopped { background: #636366; opacity: 0.4; }
.agent-dot.error   { background: #ff453a; box-shadow: 0 0 6px #ff453a; animation: blink 0.7s ease-in-out infinite; }
@keyframes blink {
  0%,100% { opacity: 1; }
  50% { opacity: 0.35; }
}

.agent-name {
  font-size: 0.72rem; font-weight: 600; color: var(--text);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  flex: 1;
}
.agent-model {
  font-size: 0.55rem; letter-spacing: 0.05em;
  color: var(--muted); white-space: nowrap;
  font-family: var(--font-mono);
}
.agent-badges { display: flex; gap: 3px; align-items: center; }

.badge {
  font-size: 0.5rem; letter-spacing: 0.08em; text-transform: uppercase;
  padding: 1px 5px; border-radius: 3px; font-weight: 700;
  white-space: nowrap;
}
.badge-bg   { background: rgba(191,90,242,0.2); color: #bf5af2; border: 1px solid rgba(191,90,242,0.3); }
.badge-role { background: rgba(255,255,255,0.07); color: var(--muted); border: 1px solid var(--border); }
.badge-tier {
  font-size: 0.45rem;
}
.badge-tier.apex      { background: rgba(255,215,0,0.15); color: #ffd700; border: 1px solid rgba(255,215,0,0.3); }
.badge-tier.executive { background: rgba(0,200,255,0.12); color: #00c8ff; border: 1px solid rgba(0,200,255,0.3); }
.badge-tier.manager   { background: rgba(255,159,10,0.12); color: #ff9f0a; border: 1px solid rgba(255,159,10,0.3); }
.badge-tier.worker    { display: none; }

.agent-score {
  font-size: 0.58rem; font-weight: 700; font-family: var(--font-mono);
  min-width: 24px; text-align: right; color: var(--muted);
}
.agent-score.high { color: #32d74b; }
.agent-score.med  { color: #ffd60a; }
.agent-score.low  { color: #ff453a; }

/* empty state */
.cat-empty {
  flex: 1; display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,0.12); font-size: 0.65rem; letter-spacing: 0.12em;
  text-transform: uppercase;
}

/* ── Ticker bar ───────────────────────────────────────────────────────────── */
.ticker-bar {
  background: rgba(255,255,255,0.025);
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
  display: flex; align-items: center;
  gap: 0;
  position: relative;
}
.ticker-label {
  flex-shrink: 0;
  padding: 0 14px;
  font-size: 0.58rem; letter-spacing: 0.18em; text-transform: uppercase;
  color: #00c8ff; font-weight: 700;
  border-right: 1px solid var(--border);
  height: 100%; display: flex; align-items: center;
  background: rgba(0,200,255,0.05);
}
.ticker-track {
  flex: 1; overflow: hidden; height: 100%;
  display: flex; align-items: center;
}
.ticker-inner {
  display: flex; align-items: center; gap: 40px;
  white-space: nowrap;
  animation: ticker-scroll 40s linear infinite;
  padding-left: 20px;
}
@keyframes ticker-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
.ticker-item {
  display: flex; align-items: center; gap: 7px;
  font-size: 0.68rem; color: rgba(255,255,255,0.6);
}
.ticker-item .t-dot {
  width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0;
}
.ticker-item .t-agent { color: rgba(255,255,255,0.85); font-weight: 600; }
.ticker-item .t-sep { color: rgba(255,255,255,0.2); }
.ticker-item .t-action { color: rgba(255,255,255,0.55); }
.ticker-item .t-time { color: rgba(255,255,255,0.25); font-family: var(--font-mono); font-size: 0.58rem; }

/* ── Category icon map ────────────────────────────────────────────────────── */
/* used via JS data attribute only */

/* ── Animated bg grid ─────────────────────────────────────────────────────── */
.bg-grid {
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background-image:
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size: 60px 60px;
  animation: grid-drift 20s ease-in-out infinite alternate;
}
@keyframes grid-drift {
  from { background-position: 0 0; }
  to   { background-position: 30px 20px; }
}

/* ── Corner accent ────────────────────────────────────────────────────────── */
.corner-accent {
  position: fixed; pointer-events: none; z-index: 0;
  width: 300px; height: 300px; border-radius: 50%;
  filter: blur(80px); opacity: 0.04;
}
.corner-accent.tl { top: -80px; left: -80px; background: #00c8ff; }
.corner-accent.tr { top: -80px; right: -80px; background: #bf5af2; }
.corner-accent.bl { bottom: -80px; left: -80px; background: #32d74b; }
.corner-accent.br { bottom: -80px; right: -80px; background: #ff453a; }

/* ── Activity pulse ring ──────────────────────────────────────────────────── */
@keyframes ring-pulse {
  0%   { transform: scale(1); opacity: 0.7; }
  100% { transform: scale(2.8); opacity: 0; }
}
.activity-ring {
  position: absolute; inset: 0; border-radius: 50%;
  border: 1px solid currentColor;
  animation: ring-pulse 1.5s ease-out forwards;
  pointer-events: none;
}

/* ── Number counter animation ─────────────────────────────────────────────── */
.count-up { display: inline-block; transition: all 0.4s cubic-bezier(0.34,1.56,0.64,1); }

/* ── Scrollbar hide ───────────────────────────────────────────────────────── */
::-webkit-scrollbar { display: none; }
* { scrollbar-width: none; }

/* ── Responsive (TV scale) ────────────────────────────────────────────────── */
@media (min-width: 1920px) {
  .display-root { padding: 16px; gap: 14px; }
  .topbar { padding: 0 28px; }
  .topbar-logo { font-size: 1.1rem; }
  .topbar-clock { font-size: 1.85rem; }
  .topbar-stat .val { font-size: 1.7rem; }
  .cat-name { font-size: 0.75rem; }
  .agent-name { font-size: 0.82rem; }
  .cat-panel { border-radius: 14px; }
  .agent-row { padding: 8px 10px; }
  .ticker-inner { font-size: 0.76rem; }
}
</style>
</head>
<body>

<!-- Corner glows -->
<div class="corner-accent tl"></div>
<div class="corner-accent tr"></div>
<div class="corner-accent bl"></div>
<div class="corner-accent br"></div>

<!-- Animated grid -->
<div class="bg-grid"></div>

<!-- Starfield canvas -->
<canvas id="starfield"></canvas>

<%
const catMeta = {
  business:  { icon: '💼', label: 'Business'  },
  ops:       { icon: '⚙️',  label: 'Ops'       },
  security:  { icon: '🔒', label: 'Security'  },
  research:  { icon: '🔬', label: 'Research'  },
  personal:  { icon: '🌿', label: 'Personal'  },
  creative:  { icon: '✦',  label: 'Creative'  },
  education: { icon: '📚', label: 'Education' },
  other:     { icon: '◈',  label: 'Other'     }
};
%>

<div class="display-root">

  <!-- ── Top bar ──────────────────────────────────────────────────────────── -->
  <div class="topbar">
    <div class="topbar-logo">
      <div class="logo-dot"></div>
      MadLabs
    </div>
    <div class="topbar-sep"></div>
    <div class="topbar-stat active">
      <span class="val count-up" id="stat-active"><%= activeAgents %></span>
      <span class="lbl">Active</span>
    </div>
    <div class="topbar-stat">
      <span class="val count-up" id="stat-total"><%= totalAgents %></span>
      <span class="lbl">Agents</span>
    </div>
    <div class="topbar-stat bg">
      <span class="val count-up" id="stat-bg"><%= bgRunning %></span>
      <span class="lbl">BG Running</span>
    </div>
    <div class="topbar-stat tasks">
      <span class="val count-up" id="stat-tasks"><%= pendingTasks %></span>
      <span class="lbl">Pending</span>
    </div>
    <div class="topbar-stat">
      <span class="val count-up" id="stat-done"><%= doneTasks %></span>
      <span class="lbl">Done</span>
    </div>
    <div class="topbar-spacer"></div>
    <div>
      <div class="topbar-clock" id="clock">--:--:--</div>
      <div class="topbar-date" id="dateline">---</div>
    </div>
  </div>

  <!-- ── Category grid ────────────────────────────────────────────────────── -->
  <div class="category-grid">
    <% CATS.forEach(function(cat) {
      const meta = catMeta[cat] || { icon: '◈', label: cat };
      const agentsInCat = byCategory[cat] || [];
      const hasActive = agentsInCat.some(a => ['idle','running'].includes(a.status));
    %>
    <div class="cat-panel <%= hasActive ? 'has-active' : '' %>" data-cat="<%= cat %>">
      <div class="cat-header">
        <span class="cat-icon"><%= meta.icon %></span>
        <span class="cat-name"><%= meta.label %></span>
        <span class="cat-count"><%= agentsInCat.length %> agent<%= agentsInCat.length !== 1 ? 's' : '' %></span>
      </div>
      <div class="cat-body" id="cat-<%= cat %>">
        <% if (agentsInCat.length === 0) { %>
          <div class="cat-empty">No agents</div>
        <% } else {
          agentsInCat.forEach(function(agent) {
            const isBg = agent.config && agent.config.backgroundRunning;
            const isActive = ['idle','running'].includes(agent.status);
            const score = agent.bgProductivity ? agent.bgProductivity.score : 50;
            const scoreClass = score >= 70 ? 'high' : score >= 40 ? 'med' : 'low';
            const modelShort = (agent.model || '').replace('qwen2.5:','q').replace('llama3.1:','ll').replace('deepseek-r1:','ds').replace('llama3.2:','ll');
        %>
        <div class="agent-row <%= isActive ? 'is-active' : '' %> <%= isBg ? 'is-bg' : '' %>"
             data-id="<%= agent._id %>"
             data-status="<%= agent.status %>"
             style="--cc: var(--c-<%= cat %>)">
          <div class="agent-dot <%= agent.status %>"></div>
          <div class="agent-name"><%= agent.name %></div>
          <div class="agent-badges">
            <% if (agent.tier && agent.tier !== 'worker') { %>
              <span class="badge badge-tier <%= agent.tier %>"><%= agent.tier.charAt(0).toUpperCase() %></span>
            <% } %>
            <% if (isBg) { %><span class="badge badge-bg">BG</span><% } %>
            <% if (agent.role && agent.role !== 'assistant') { %>
              <span class="badge badge-role"><%= agent.role.replace('forwardChat','fwd') %></span>
            <% } %>
          </div>
          <% if (isBg) { %>
            <div class="agent-score <%= scoreClass %>"><%= score %></div>
          <% } else { %>
            <div class="agent-model"><%= modelShort %></div>
          <% } %>
        </div>
        <% }); } %>
      </div>
    </div>
    <% }); %>
  </div>

  <!-- ── Ticker ────────────────────────────────────────────────────────────── -->
  <div class="ticker-bar">
    <div class="ticker-label">Live</div>
    <div class="ticker-track">
      <div class="ticker-inner" id="tickerInner">
        <!-- populated by JS -->
      </div>
    </div>
  </div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script>
// ── Initial data ──────────────────────────────────────────────────────────────
const INIT_ACTIONS = <%- recentActions %>;

// ── Starfield ─────────────────────────────────────────────────────────────────
(function() {
  const canvas = document.getElementById('starfield');
  const ctx = canvas.getContext('2d');
  let W, H, stars = [];

  function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  function seed() {
    stars = Array.from({ length: 180 }, () => ({
      x: Math.random() * W, y: Math.random() * H,
      r: Math.random() * 1.2 + 0.2,
      a: Math.random() * 0.7 + 0.05,
      speed: Math.random() * 0.015 + 0.003,
      phase: Math.random() * Math.PI * 2
    }));
  }
  function draw(t) {
    ctx.clearRect(0, 0, W, H);
    stars.forEach(s => {
      const flicker = s.a * (0.7 + 0.3 * Math.sin(t * s.speed * 60 + s.phase));
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,255,255,${flicker})`;
      ctx.fill();
    });
    requestAnimationFrame(draw);
  }
  window.addEventListener('resize', () => { resize(); seed(); });
  resize(); seed(); requestAnimationFrame(draw);
})();

// ── Clock ─────────────────────────────────────────────────────────────────────
(function clock() {
  const clockEl = document.getElementById('clock');
  const dateEl  = document.getElementById('dateline');
  const DAYS  = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  function tick() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2,'0');
    const m = String(now.getMinutes()).padStart(2,'0');
    const s = String(now.getSeconds()).padStart(2,'0');
    clockEl.textContent = `${h}:${m}:${s}`;
    dateEl.textContent = `${DAYS[now.getDay()]}  ${MONTHS[now.getMonth()]} ${now.getDate()}`;
  }
  tick(); setInterval(tick, 1000);
})();

// ── Ticker ────────────────────────────────────────────────────────────────────
const CAT_COLOR = {
  business:'#00c8ff', ops:'#ff9f0a', security:'#ff453a',
  research:'#bf5af2', personal:'#32d74b', creative:'#ff375f',
  education:'#ffd60a', other:'#636366'
};

const tickerItems = [];

function timeAgo(dateStr) {
  const diff = Date.now() - new Date(dateStr).getTime();
  const m = Math.floor(diff / 60000);
  if (m < 1) return 'just now';
  if (m < 60) return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 24) return `${h}h ago`;
  return `${Math.floor(h/24)}d ago`;
}

function buildTickerHTML(items) {
  if (!items.length) return '<span class="ticker-item"><span style="color:rgba(255,255,255,0.25)">No recent activity</span></span>';
  // duplicate for seamless loop
  const both = [...items, ...items];
  return both.map(a => {
    const color = CAT_COLOR[a.category] || '#636366';
    const txt = (a.summary || a.action || a.type || 'activity').substring(0, 80);
    const agent = a.agentName || a.agent || '—';
    return `<span class="ticker-item">
      <span class="t-dot" style="background:${color};box-shadow:0 0 4px ${color}"></span>
      <span class="t-agent">${esc(agent)}</span>
      <span class="t-sep">·</span>
      <span class="t-action">${esc(txt)}</span>
      <span class="t-time">${timeAgo(a.createdAt || a.timestamp || Date.now())}</span>
    </span>`;
  }).join('');
}

function esc(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function initTicker(actions) {
  const el = document.getElementById('tickerInner');
  el.innerHTML = buildTickerHTML(actions);
  // reset animation
  el.style.animation = 'none';
  void el.offsetWidth;
  el.style.animation = '';
}

initTicker(INIT_ACTIONS);

// ── Socket.IO live updates ────────────────────────────────────────────────────
const socket = io('/agents', { transports: ['websocket','polling'] });

socket.on('status:change', ({ agentId, status }) => {
  const row = document.querySelector(`.agent-row[data-id="${agentId}"]`);
  if (!row) return;
  // Update dot
  const dot = row.querySelector('.agent-dot');
  if (dot) { dot.className = `agent-dot ${status}`; }
  row.dataset.status = status;
  const active = ['idle','running'].includes(status);
  row.classList.toggle('is-active', active);
  // Panel glow
  const panel = row.closest('.cat-panel');
  if (panel) {
    const anyActive = [...panel.querySelectorAll('.agent-row')].some(r => ['idle','running'].includes(r.dataset.status));
    panel.classList.toggle('has-active', anyActive);
  }
  flashStat('stat-active');
});

socket.on('background:tick', ({ agentId, result }) => {
  const row = document.querySelector(`.agent-row[data-id="${agentId}"]`);
  if (!row) return;
  // Update score display
  if (result && result.productivity !== undefined) {
    const scoreEl = row.querySelector('.agent-score');
    if (scoreEl) {
      const s = result.productivity;
      scoreEl.textContent = s;
      scoreEl.className = `agent-score ${s >= 70 ? 'high' : s >= 40 ? 'med' : 'low'}`;
    }
  }
  // Push to ticker
  if (result && result.title) {
    INIT_ACTIONS.unshift({
      agentName: row.querySelector('.agent-name')?.textContent,
      summary: result.title,
      createdAt: new Date().toISOString()
    });
    initTicker(INIT_ACTIONS.slice(0, 30));
  }
  flashStat('stat-bg');
});

socket.on('action:new', ({ agentId, action }) => {
  if (!action) return;
  INIT_ACTIONS.unshift({ ...action, createdAt: action.createdAt || new Date().toISOString() });
  initTicker(INIT_ACTIONS.slice(0, 30));
});

socket.on('background:started', ({ agentId }) => {
  const row = document.querySelector(`.agent-row[data-id="${agentId}"]`);
  if (row) row.classList.add('is-bg');
  const bgEl = document.getElementById('stat-bg');
  if (bgEl) bgEl.textContent = parseInt(bgEl.textContent||0) + 1;
});

socket.on('background:stopped', ({ agentId }) => {
  const row = document.querySelector(`.agent-row[data-id="${agentId}"]`);
  if (row) row.classList.remove('is-bg');
  const bgEl = document.getElementById('stat-bg');
  if (bgEl) bgEl.textContent = Math.max(0, parseInt(bgEl.textContent||0) - 1);
});

// ── Stat flash ────────────────────────────────────────────────────────────────
function flashStat(id) {
  const el = document.getElementById(id);
  if (!el) return;
  el.style.transform = 'scale(1.2)';
  el.style.opacity = '1';
  setTimeout(() => { el.style.transform = ''; el.style.opacity = ''; }, 300);
}

// ── Refresh stats every 60s ───────────────────────────────────────────────────
async function refreshStats() {
  try {
    const r = await fetch('/api/agents');
    const d = await r.json();
    if (!d.success) return;
    const agents = d.agents;
    const active = agents.filter(a => ['idle','running'].includes(a.status)).length;
    const bg = agents.filter(a => a.config?.backgroundRunning).length;
    animateCounter('stat-active', active);
    animateCounter('stat-total', agents.length);
    animateCounter('stat-bg', bg);
  } catch(e) {}
}
setInterval(refreshStats, 60000);

function animateCounter(id, target) {
  const el = document.getElementById(id);
  if (!el) return;
  const cur = parseInt(el.textContent) || 0;
  if (cur === target) return;
  const step = (target - cur) / 12;
  let val = cur;
  const iv = setInterval(() => {
    val += step;
    el.textContent = Math.round(val);
    if ((step > 0 && val >= target) || (step < 0 && val <= target)) {
      el.textContent = target;
      clearInterval(iv);
    }
  }, 40);
}

// ── Keyboard shortcuts ────────────────────────────────────────────────────────
document.addEventListener('keydown', e => {
  if (e.key === 'Escape' || e.key === 'q') window.location.href = '/agents/hub';
  if (e.key === 'r' || e.key === 'R') location.reload();
});
</script>
</body>
</html>
