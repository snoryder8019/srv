<!DOCTYPE html>
<html>
<head>
  <link rel="icon" type="image/png" href="/images/beaker_logo_no_stash.png">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <title>Org Briefs - madLadsLab</title>
  <link rel="stylesheet" href="/stylesheets/admin.css">
  <link rel="stylesheet" href="/stylesheets/agents.css">
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
</head>
<body>
  <%- include('../mainContent/adminHeader.ejs') %>

  <div class="reports-layout">

    <!-- ── Sidebar: report list ── -->
    <div class="reports-sidebar">
      <div class="reports-sidebar-header">
        <span class="reports-sidebar-title">Org Briefs</span>
        <a href="/agents" class="reports-back">← agents</a>
      </div>

      <div class="reports-generate-box">
        <div class="reports-gen-row">
          <select id="rptModel" class="hub-select" style="flex:1">
            <option value="qwen2.5:7b">qwen2.5:7b</option>
            <option value="qwen2.5:14b">qwen2.5:14b</option>
            <option value="deepseek-r1:7b">deepseek-r1:7b</option>
            <option value="llama3.2:3b">llama3.2:3b</option>
          </select>
          <select id="rptWindow" class="hub-select">
            <option value="24">24h</option>
            <option value="48" selected>48h</option>
            <option value="72">72h</option>
            <option value="168">7d</option>
          </select>
        </div>
        <button id="rptGenerateBtn" class="reports-gen-btn" onclick="generateBrief()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Generate Brief
        </button>
        <div id="rptStatus" class="reports-gen-status" style="display:none"></div>
      </div>

      <div class="reports-list" id="reportsList">
        <% if (reports && reports.length > 0) { %>
          <% reports.forEach((r, i) => { %>
            <div class="reports-list-item <%= i === 0 ? 'active' : '' %>"
              data-report-id="<%= r._id %>"
              onclick="selectReport('<%= r._id %>', this)">
              <span class="rpt-date"><%= new Date(r.generatedAt).toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric' }) %></span>
              <span class="rpt-time"><%= new Date(r.generatedAt).toLocaleTimeString('en-US', { hour:'2-digit', minute:'2-digit' }) %></span>
              <div class="rpt-meta"><%= r.agentCount %> agents · <%= r.windowHours %>h window · <%= r.tokens?.toLocaleString() %> tok</div>
              <button class="rpt-delete-btn" onclick="event.stopPropagation(); deleteReport('<%= r._id %>', this.closest('.reports-list-item'))" title="Delete">✕</button>
            </div>
          <% }); %>
        <% } else { %>
          <div class="reports-list-empty">No briefs yet — generate one above</div>
        <% } %>
      </div>
    </div>

    <!-- ── Main: brief reader ── -->
    <div class="reports-reader" id="reportsReader">
      <% if (reports && reports.length > 0) { %>
        <div class="reports-brief-content" id="briefContent">
          <!-- rendered by JS on load -->
        </div>
      <% } else { %>
        <div class="reports-empty-state">
          <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="color:#333">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
          <p>Generate your first brief to see what your agents have been doing</p>
        </div>
      <% } %>
    </div>

  </div>

  <script>
    // Report data from server
    const REPORTS_DATA = <%- JSON.stringify(reports.map(r => ({ _id: r._id, brief: r.brief, generatedAt: r.generatedAt, model: r.model, windowHours: r.windowHours, agentCount: r.agentCount, actionCount: r.actionCount, tasksPending: r.tasksPending, needsHuman: r.needsHuman, completedInWindow: r.completedInWindow, tokens: r.tokens }))) %>;

    marked.setOptions({ breaks: true });

    function renderBrief(report) {
      const container = document.getElementById('briefContent') || document.getElementById('reportsReader');

      // Replace empty state with brief content div if needed
      const reader = document.getElementById('reportsReader');
      if (!document.getElementById('briefContent')) {
        reader.innerHTML = '<div class="reports-brief-content" id="briefContent"></div>';
      }

      const statsBar = `
        <div class="brief-stats-bar">
          <span>${report.agentCount} agents</span>
          <span>${report.actionCount} findings</span>
          <span>${report.completedInWindow} tasks done</span>
          ${report.needsHuman > 0 ? `<span class="brief-stat-alert">${report.needsHuman} needs human</span>` : ''}
          <span class="brief-stat-muted">${report.model} · ${report.windowHours}h window · ${(report.tokens||0).toLocaleString()} tok</span>
          <span class="brief-stat-muted">${new Date(report.generatedAt).toLocaleString()}</span>
        </div>`;

      document.getElementById('briefContent').innerHTML = statsBar + '<div class="brief-markdown">' + marked.parse(report.brief || '') + '</div>';
    }

    function selectReport(id, el) {
      document.querySelectorAll('.reports-list-item').forEach(i => i.classList.remove('active'));
      el.classList.add('active');
      const report = REPORTS_DATA.find(r => r._id.toString() === id.toString());
      if (report) renderBrief(report);
    }

    async function generateBrief() {
      const btn = document.getElementById('rptGenerateBtn');
      const status = document.getElementById('rptStatus');
      const model = document.getElementById('rptModel').value;
      const windowHours = parseInt(document.getElementById('rptWindow').value);

      btn.disabled = true;
      btn.textContent = 'Generating…';
      status.style.display = '';
      status.textContent = `Collecting org data and calling ${model}…`;

      try {
        const res = await fetch('/agents/api/agents/reports/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ model, windowHours })
        });
        const data = await res.json();
        if (!data.success) throw new Error(data.error);

        // Prepend to sidebar list
        const list = document.getElementById('reportsList');
        const emptyEl = list.querySelector('.reports-list-empty');
        if (emptyEl) emptyEl.remove();

        const r = data.report;
        const item = document.createElement('div');
        item.className = 'reports-list-item active';
        item.dataset.reportId = r._id;
        item.innerHTML = `
          <span class="rpt-date">${new Date(r.generatedAt).toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric' })}</span>
          <span class="rpt-time">${new Date(r.generatedAt).toLocaleTimeString('en-US', { hour:'2-digit', minute:'2-digit' })}</span>
          <div class="rpt-meta">${r.agentCount} agents · ${r.windowHours}h window · ${(r.tokens||0).toLocaleString()} tok</div>
          <button class="rpt-delete-btn" onclick="event.stopPropagation(); deleteReport('${r._id}', this.closest('.reports-list-item'))" title="Delete">✕</button>`;
        item.onclick = () => selectReport(r._id, item);

        document.querySelectorAll('.reports-list-item').forEach(i => i.classList.remove('active'));
        list.insertBefore(item, list.firstChild);

        // Add to data cache and render
        REPORTS_DATA.unshift(r);
        renderBrief(r);

        status.textContent = `Done — ${(r.tokens||0).toLocaleString()} tokens`;
      } catch (e) {
        status.textContent = 'Error: ' + e.message;
        status.style.color = '#ff4444';
      }

      btn.disabled = false;
      btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg> Generate Brief';
    }

    async function deleteReport(id, el) {
      if (!confirm('Delete this brief?')) return;
      await fetch(`/agents/api/agents/reports/${id}`, { method: 'DELETE' });
      el.remove();
      // Clear reader if this was the active one
      const reader = document.getElementById('reportsReader');
      if (document.querySelectorAll('.reports-list-item').length === 0) {
        reader.innerHTML = '<div class="reports-empty-state"><p>No briefs — generate one above</p></div>';
      } else {
        // Select first remaining
        const first = document.querySelector('.reports-list-item');
        if (first) first.click();
      }
    }

    // Auto-render first report on load
    document.addEventListener('DOMContentLoaded', () => {
      if (REPORTS_DATA.length > 0) renderBrief(REPORTS_DATA[0]);
    });
  </script>

  <style>
    .reports-layout {
      display: flex;
      height: calc(100vh - 54px);
      background: #0d0d0d;
      overflow: hidden;
    }

    /* ── Sidebar ── */
    .reports-sidebar {
      width: 240px;
      min-width: 240px;
      background: #111;
      border-right: 1px solid #222;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .reports-sidebar-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 1rem;
      border-bottom: 1px solid #1e1e1e;
      flex-shrink: 0;
    }
    .reports-sidebar-title { font-size: 0.85rem; font-weight: 600; color: #e0e0e0; }
    .reports-back { font-size: 0.75rem; color: #555; text-decoration: none; }
    .reports-back:hover { color: #999; }

    .reports-generate-box {
      padding: 0.75rem;
      border-bottom: 1px solid #1e1e1e;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      flex-shrink: 0;
    }
    .reports-gen-row { display: flex; gap: 0.35rem; }
    .reports-gen-btn {
      display: flex; align-items: center; justify-content: center; gap: 0.4rem;
      width: 100%; padding: 0.45rem; border-radius: 5px; border: none;
      background: #00ff88; color: #000; font-size: 0.8rem; font-weight: 700;
      cursor: pointer; transition: background 0.15s;
    }
    .reports-gen-btn:hover { background: #00cc77; }
    .reports-gen-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .reports-gen-status { font-size: 0.72rem; color: #555; text-align: center; }

    .reports-list { flex: 1; overflow-y: auto; }
    .reports-list-empty { padding: 1.5rem 1rem; font-size: 0.8rem; color: #444; text-align: center; font-style: italic; }
    .reports-list-item {
      position: relative;
      padding: 0.65rem 0.85rem;
      border-bottom: 1px solid #191919;
      cursor: pointer;
      transition: background 0.1s;
    }
    .reports-list-item:hover { background: rgba(255,255,255,0.03); }
    .reports-list-item.active { background: rgba(0,255,136,0.07); border-left: 2px solid #00ff88; }
    .rpt-date { display: block; font-size: 0.82rem; font-weight: 600; color: #ddd; }
    .rpt-time { display: inline; font-size: 0.72rem; color: #555; }
    .rpt-meta { font-size: 0.68rem; color: #444; margin-top: 0.2rem; }
    .rpt-delete-btn {
      position: absolute; top: 0.5rem; right: 0.5rem;
      background: none; border: none; color: #333; font-size: 0.72rem;
      cursor: pointer; padding: 0.2rem 0.3rem; border-radius: 3px;
    }
    .rpt-delete-btn:hover { color: #ff6666; background: rgba(255,68,68,0.1); }

    /* ── Reader ── */
    .reports-reader {
      flex: 1;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
    }

    .reports-empty-state {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 0.75rem; color: #444;
    }
    .reports-empty-state p { font-size: 0.88rem; color: #555; }

    .reports-brief-content { display: flex; flex-direction: column; }

    .brief-stats-bar {
      display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
      padding: 0.6rem 2rem; background: #111; border-bottom: 1px solid #1e1e1e;
      font-size: 0.75rem; color: #888; flex-shrink: 0;
    }
    .brief-stat-alert { color: #ff4444; font-weight: 600; }
    .brief-stat-muted { color: #444; }

    .brief-markdown {
      padding: 2rem 2.5rem;
      max-width: 820px;
      color: #d0d0d0;
      line-height: 1.75;
      font-size: 0.93rem;
    }
    .brief-markdown h1 { font-size: 1.5rem; color: #fff; margin: 0 0 0.5rem; font-weight: 700; }
    .brief-markdown h2 { font-size: 1.05rem; color: #00ff88; margin: 1.75rem 0 0.5rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; border-bottom: 1px solid #1e1e1e; padding-bottom: 0.35rem; }
    .brief-markdown h3 { font-size: 0.9rem; color: #aaa; margin: 1rem 0 0.3rem; font-weight: 600; }
    .brief-markdown p  { margin: 0.4rem 0; }
    .brief-markdown ul, .brief-markdown ol { padding-left: 1.5rem; margin: 0.4rem 0; }
    .brief-markdown li { margin-bottom: 0.25rem; }
    .brief-markdown strong { color: #e0e0e0; }
    .brief-markdown code { background: rgba(0,255,136,0.08); color: #00ff88; padding: 0.1em 0.35em; border-radius: 3px; font-size: 0.85em; font-family: monospace; }
    .brief-markdown blockquote { border-left: 3px solid #333; margin: 0.5rem 0; padding: 0.2rem 0.75rem; color: #666; }
    .brief-markdown hr { border: none; border-top: 1px solid #222; margin: 1.5rem 0; }
  </style>

  <%- include('../mainContent/adminNav.ejs') %>
</body>
</html>
