<!-- Create/Edit Agent Modal -->
<div id="agentModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h2 id="modalTitle">Spawn New Agent</h2>
      <button class="modal-close" onclick="closeModal()">&times;</button>
    </div>

    <form id="agentForm">
      <input type="hidden" id="agentId" name="agentId">

      <!-- ── Preset Dropdown ─────────────────────────────────── -->
      <div id="presetSection" class="create-section">
        <div class="create-section-label">Start from preset</div>
        <select id="presetSelect" class="create-preset-select" onchange="applyPreset(this.value)">
          <option value="">— choose a preset or configure manually —</option>
          <optgroup label="Platform / Dev">
            <option value="vibecoder">⚡  Vibecoder — fullstack dev agent</option>
            <option value="debugger">🐛  Debug Detective — root cause analyst</option>
            <option value="monitor">🖥  Server Monitor — service health watcher</option>
            <option value="coordinator">📋  Coordinator — task &amp; delegation agent</option>
            <option value="agent_builder">🏗  Agent Architect — designs &amp; deploys agents</option>
          </optgroup>
          <optgroup label="Research / Security">
            <option value="researcher">🔬  Researcher — evidence-first analyst</option>
            <option value="auditor">🔒  Security Auditor — OWASP code reviewer</option>
            <option value="scout">🗄  Data Scout — MongoDB analyst</option>
          </optgroup>
          <optgroup label="Consumer">
            <option value="support_bot">💬  Support Agent — consumer chat</option>
            <option value="lead_bot">🎯  Sales Assistant — lead qualification</option>
          </optgroup>
          <optgroup label="Maintenance">
            <option value="prompt_doctor">✏️  Prompt Doctor — prompt auditor</option>
            <option value="kb_curator">🗂  KB Curator — knowledge base maintenance</option>
          </optgroup>
          <optgroup label="Support Roles">
            <option value="summarizer">📋  Summarizer — condenses threads &amp; findings</option>
            <option value="fact_checker">🔍  Fact Checker — verifies claims &amp; citations</option>
            <option value="tone_adjuster">🎨  Tone Adjuster — consistent voice &amp; style</option>
            <option value="context_injector">💉  Context Injector — enriches requests with KB</option>
            <option value="quality_gate">🚦  Quality Gate — approves / flags / blocks outputs</option>
            <option value="escalation_handler">🚨  Escalation Handler — routes edge cases</option>
            <option value="data_validator">✅  Data Validator — validates structured outputs</option>
            <option value="memory_manager">🧠  Memory Manager — controls what gets persisted</option>
            <option value="task_planner">🗓  Task Planner — decomposes goals into tasks</option>
            <option value="output_formatter">📐  Output Formatter — standardises response format</option>
            <option value="content_filter">🛡  Content Filter — blocks out-of-scope responses</option>
          </optgroup>
          <optgroup label="Creative / Persona">
            <option value="narrator">📖  Narrator — world-building &amp; lore</option>
            <option value="persona_bot">🎭  Persona Scout — research &amp; embody</option>
            <option value="copywriter">✍️  Copywriter — marketing &amp; brand copy</option>
          </optgroup>
          <optgroup label="Blank">
            <option value="custom">✦  Custom — blank slate</option>
          </optgroup>
        </select>
      </div>

      <!-- ── Project + Category ──────────────────────────────── -->
      <div class="create-section">
        <div class="create-section-label">Organisation</div>
        <div class="form-row">
          <div class="form-group">
            <label for="agentProject">Project</label>
            <div class="create-project-row">
              <select id="agentProject" name="project" class="create-project-select">
                <option value="">— no project —</option>
              </select>
              <button type="button" class="create-new-project-btn" onclick="toggleNewProjectForm()" title="New project">+</button>
            </div>
            <div id="newProjectForm" class="create-new-project-form" style="display:none">
              <input type="text" id="newProjectName" placeholder="Project name" class="create-inline-input">
              <select id="newProjectCategory" class="create-inline-select">
                <option value="business">business</option>
                <option value="personal">personal</option>
                <option value="education">education</option>
                <option value="research">research</option>
                <option value="creative">creative</option>
                <option value="ops">ops</option>
                <option value="security">security</option>
                <option value="other">other</option>
              </select>
              <div class="create-inline-btns">
                <button type="button" class="create-inline-save" onclick="saveNewProject()">Create</button>
                <button type="button" class="create-inline-cancel" onclick="toggleNewProjectForm()">Cancel</button>
              </div>
            </div>
          </div>
          <div class="form-group">
            <label for="agentCategory">Category</label>
            <select id="agentCategory" name="category">
              <option value="business">business</option>
              <option value="personal">personal</option>
              <option value="education">education</option>
              <option value="research">research</option>
              <option value="creative">creative</option>
              <option value="ops">ops</option>
              <option value="security">security</option>
              <option value="other" selected>other</option>
            </select>
          </div>
        </div>
      </div>

      <!-- ── Identity ────────────────────────────────────────── -->
      <div class="create-section">
        <div class="create-section-label">Identity</div>
        <div class="form-group">
          <label for="agentName">Name *</label>
          <input type="text" id="agentName" name="name" required placeholder="e.g. Research Assistant">
        </div>
        <div class="form-group">
          <label for="agentDescription">Description</label>
          <textarea id="agentDescription" name="description" rows="2" placeholder="What this agent does…"></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="agentModel">Model *</label>
            <select id="agentModel" name="model" required>
              <option value="qwen2.5:7b">Qwen 2.5 7B</option>
              <option value="qwen2.5:14b">Qwen 2.5 14B</option>
              <option value="llama3.1:8b">Llama 3.1 8B</option>
              <option value="deepseek-r1:7b">DeepSeek R1 7B</option>
            </select>
          </div>
          <div class="form-group">
            <label for="agentRole">Pipeline Role</label>
            <select id="agentRole" name="role">
              <option value="assistant">assistant — standard chat</option>
              <option value="researcher">researcher — TLDR pipeline</option>
              <option value="vibecoder">vibecoder — task list pipeline</option>
              <option value="forwardChat">forwardChat — consumer deployment</option>
            </select>
          </div>
          <input type="hidden" id="agentProvider" name="provider" value="ollama">
        </div>
      </div>

      <!-- ── Domains ─────────────────────────────────────────── -->
      <div class="create-section">
        <div class="create-section-label">Domains <span class="create-section-sub">sets capabilities tags</span></div>
        <div class="create-domain-grid" id="domainGrid">
          <label class="domain-check"><input type="checkbox" value="backend-api"> Backend / API</label>
          <label class="domain-check"><input type="checkbox" value="frontend-ui"> Frontend / UI</label>
          <label class="domain-check"><input type="checkbox" value="devops-infra"> DevOps / Infra</label>
          <label class="domain-check"><input type="checkbox" value="security"> Security</label>
          <label class="domain-check"><input type="checkbox" value="data-analytics"> Data / Analytics</label>
          <label class="domain-check"><input type="checkbox" value="database"> Database</label>
          <label class="domain-check"><input type="checkbox" value="customer-support"> Customer Support</label>
          <label class="domain-check"><input type="checkbox" value="sales-marketing"> Sales / Marketing</label>
          <label class="domain-check"><input type="checkbox" value="finance"> Finance</label>
          <label class="domain-check"><input type="checkbox" value="content-creative"> Content / Creative</label>
          <label class="domain-check"><input type="checkbox" value="research"> Research</label>
          <label class="domain-check"><input type="checkbox" value="game-dev"> Game Dev</label>
          <label class="domain-check"><input type="checkbox" value="automation"> Automation</label>
          <label class="domain-check"><input type="checkbox" value="platform-ops"> Platform Ops</label>
          <label class="domain-check"><input type="checkbox" value="nlp-ai"> NLP / AI</label>
        </div>
      </div>

      <!-- ── Working Directory (dir tree) ───────────────────── -->
      <div class="create-section">
        <div class="create-dirtree-header" onclick="toggleDirTree()">
          <div class="create-section-label" style="margin:0">Working Directory <span class="create-section-sub" id="dirTreeSelectedLabel">not set</span></div>
          <span class="create-dirtree-toggle" id="dirTreeToggle">▸ browse</span>
        </div>
        <input type="hidden" id="agentWorkingDir" name="workingDir" value="">
        <div id="dirTreePanel" style="display:none">
          <div class="create-dirtree-wrap">
            <div class="create-dirtree-path" id="dirTreeCurrentPath">/srv</div>
            <div class="create-dirtree-list" id="dirTreeList">
              <div class="create-dirtree-loading">Loading…</div>
            </div>
          </div>
          <button type="button" class="create-dirtree-clear" onclick="clearWorkingDir()">Clear selection</button>
        </div>
      </div>

      <!-- ── Support relationship ────────────────────────────── -->
      <div class="create-section" id="supportAgentSection">
        <div class="create-section-label">Support Relationship <span class="create-section-sub">optional</span></div>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.85rem;color:#aaa">
          <input type="checkbox" id="isSupportAgent" name="isSupportAgent" onchange="toggleSupportAgentFields()">
          This agent supports another agent
        </label>
        <div id="supportAgentFields" style="display:none;margin-top:0.75rem;padding:0.75rem;background:#0a0a0a;border:1px solid #222;border-radius:6px">
          <div class="form-row">
            <div class="form-group">
              <label for="supportsAgentId">Supports agent</label>
              <select id="supportsAgentId" name="supportsAgentId">
                <option value="">— select agent —</option>
              </select>
            </div>
            <div class="form-group">
              <label for="supportRole">Support role</label>
              <select id="supportRole" name="supportRole">
                <optgroup label="Content">
                  <option value="prompt-cleaner">Prompt Cleaner — rewrites &amp; tightens prompts</option>
                  <option value="tone-adjuster">Tone Adjuster — enforces consistent voice</option>
                  <option value="output-formatter">Output Formatter — standardises response format</option>
                  <option value="summarizer">Summarizer — condenses long threads &amp; findings</option>
                  <option value="content-filter">Content Filter — blocks out-of-scope responses</option>
                </optgroup>
                <optgroup label="Quality">
                  <option value="reviewer">Reviewer — audits outputs before delivery</option>
                  <option value="fact-checker">Fact Checker — verifies claims &amp; citations</option>
                  <option value="quality-gate">Quality Gate — approves / rejects responses</option>
                  <option value="data-validator">Data Validator — validates structured outputs</option>
                </optgroup>
                <optgroup label="Memory &amp; Context">
                  <option value="kb-curator">KB Curator — maintains knowledge base</option>
                  <option value="memory-manager">Memory Manager — controls what gets persisted</option>
                  <option value="context-injector">Context Injector — enriches requests with context</option>
                </optgroup>
                <optgroup label="Operations">
                  <option value="background-support">Background Support — autonomous assist</option>
                  <option value="task-planner">Task Planner — breaks goals into steps</option>
                  <option value="escalation-handler">Escalation Handler — manages edge cases</option>
                </optgroup>
                <optgroup label="Other">
                  <option value="custom">Custom</option>
                </optgroup>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="supportLabel">Label <span style="color:#555;font-weight:400;font-size:0.8rem">(optional)</span></label>
            <input type="text" id="supportLabel" name="supportLabel" placeholder="e.g. Vincent's prompt doctor">
          </div>
        </div>
      </div>

      <!-- ── System Prompt ───────────────────────────────────── -->
      <div class="create-section">
        <div class="create-section-label">System Prompt</div>

        <div class="prompt-builder" id="promptBuilder">
          <div class="prompt-builder-header" onclick="togglePromptBuilder()">
            <h4>Prompt Builder</h4>
            <button type="button" class="prompt-builder-toggle" id="promptBuilderToggle">▸ expand</button>
          </div>
          <div class="prompt-builder-body" id="promptBuilderBody" style="display:none">
            <div class="prompt-builder-row">
              <div class="form-group" style="margin:0">
                <label style="font-size:0.78rem;color:#888">Tone</label>
                <select id="pb-tone" style="width:100%;background:#111;border:1px solid #2a2a2a;color:#ccc;border-radius:4px;padding:0.3rem 0.5rem;font-size:0.82rem">
                  <option value="">— select —</option>
                  <option value="professional">Professional</option>
                  <option value="friendly">Friendly</option>
                  <option value="technical">Technical</option>
                  <option value="concise">Concise</option>
                  <option value="conversational">Conversational</option>
                </select>
              </div>
              <div class="form-group" style="margin:0">
                <label style="font-size:0.78rem;color:#888">Response style</label>
                <select id="pb-style" style="width:100%;background:#111;border:1px solid #2a2a2a;color:#ccc;border-radius:4px;padding:0.3rem 0.5rem;font-size:0.82rem">
                  <option value="">— select —</option>
                  <option value="bullets">Bullet points</option>
                  <option value="prose">Prose</option>
                  <option value="mixed">Mixed</option>
                  <option value="structured">Structured (headers)</option>
                  <option value="brief">Brief (1–3 sentences)</option>
                </select>
              </div>
            </div>
            <div class="form-group" style="margin:0 0 0.6rem">
              <label style="font-size:0.78rem;color:#888">Domain / expertise</label>
              <input type="text" id="pb-domain" style="width:100%;background:#111;border:1px solid #2a2a2a;color:#ccc;border-radius:4px;padding:0.3rem 0.5rem;font-size:0.82rem" placeholder="e.g. customer support for a SaaS billing product">
            </div>
            <div class="form-group" style="margin:0 0 0.6rem">
              <label style="font-size:0.78rem;color:#888">Hard rules <span style="color:#555;font-weight:400">(comma-separated)</span></label>
              <input type="text" id="pb-rules" style="width:100%;background:#111;border:1px solid #2a2a2a;color:#ccc;border-radius:4px;padding:0.3rem 0.5rem;font-size:0.82rem" placeholder="never discuss competitors, never promise refunds">
            </div>
            <div class="form-group" style="margin:0 0 0.6rem">
              <label style="font-size:0.78rem;color:#888">Escalation path</label>
              <input type="text" id="pb-escalation" style="width:100%;background:#111;border:1px solid #2a2a2a;color:#ccc;border-radius:4px;padding:0.3rem 0.5rem;font-size:0.82rem" placeholder="direct to support@company.com">
            </div>
            <div class="prompt-builder-apply">
              <button type="button" class="btn-secondary btn-sm" onclick="applyPromptBuilder()">Build Prompt →</button>
              <small>Assembles fields into the system prompt below. Edit freely after.</small>
            </div>
          </div>
        </div>

        <textarea id="systemPrompt" name="systemPrompt" rows="7" placeholder="You are a helpful AI assistant.">You are a helpful AI assistant.</textarea>
      </div>

      <!-- ── Parameters ──────────────────────────────────────── -->
      <div class="create-section">
        <div class="create-section-label">Parameters</div>
        <div class="form-row">
          <div class="form-group">
            <label for="temperature">Temperature</label>
            <input type="number" id="temperature" name="temperature" min="0" max="2" step="0.05" value="0.7">
          </div>
          <div class="form-group">
            <label for="maxTokens">Max Tokens</label>
            <input type="number" id="maxTokens" name="maxTokens" value="8192" step="1024">
          </div>
        </div>
      </div>

      <div class="form-actions">
        <button type="button" class="btn-secondary" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn-primary">
          <span id="submitBtnText">Create Agent</span>
        </button>
      </div>
    </form>
  </div>
</div>
