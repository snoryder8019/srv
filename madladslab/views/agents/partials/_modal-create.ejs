<!-- Create/Edit Agent Modal -->
<div id="agentModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h2 id="modalTitle">Spawn New Agent</h2>
      <button class="modal-close" onclick="closeModal()">&times;</button>
    </div>
    <form id="agentForm">
      <input type="hidden" id="agentId" name="agentId">

      <!-- Personality presets — only visible when creating a new agent -->
      <div id="presetSection">
        <div class="preset-label">Choose a preset <span class="preset-label-sub">or configure manually below</span></div>
        <div class="preset-grid" id="presetGrid">

          <!-- ── Platform / Ops ──────────────────────── -->
          <button type="button" class="preset-card" data-preset="monitor" title="Verifies services, ports, and processes with tools before every report. Silent when healthy.">
            <span class="preset-icon">🖥</span>
            <span class="preset-name">Server Monitor</span>
            <span class="preset-role-tag">ops</span>
            <span class="preset-desc">Verifies services and ports with tools. Silent when healthy.</span>
          </button>
          <button type="button" class="preset-card" data-preset="vibecoder" title="Plans → reads → writes → verifies. Never writes from memory.">
            <span class="preset-icon">⚡</span>
            <span class="preset-name">Vibecoder</span>
            <span class="preset-role-tag">dev</span>
            <span class="preset-desc">Fullstack dev agent. Plans, reads, writes, verifies.</span>
          </button>
          <button type="button" class="preset-card" data-preset="debugger" title="Traces errors through code paths and logs. Confirms root cause before proposing a fix.">
            <span class="preset-icon">🐛</span>
            <span class="preset-name">Debug Detective</span>
            <span class="preset-role-tag">dev</span>
            <span class="preset-desc">Root cause analyst. Traces, confirms, fixes.</span>
          </button>
          <button type="button" class="preset-card" data-preset="agent_builder" title="Surveys the server, audits existing agents, designs and deploys purpose-built agents.">
            <span class="preset-icon">🏗</span>
            <span class="preset-name">Agent Architect</span>
            <span class="preset-role-tag">platform</span>
            <span class="preset-desc">Designs and deploys purpose-built agents.</span>
          </button>
          <button type="button" class="preset-card" data-preset="coordinator" title="Organizes work into tasks, delegates to agents, tracks blockers.">
            <span class="preset-icon">📋</span>
            <span class="preset-name">Coordinator</span>
            <span class="preset-role-tag">ops</span>
            <span class="preset-desc">Organizes tasks, delegates, tracks blockers.</span>
          </button>

          <!-- ── Research / Analysis ─────────────────── -->
          <button type="button" class="preset-card" data-preset="researcher" title="Evidence-first analyst. Cites every claim. Delivers TLDR + structured findings.">
            <span class="preset-icon">🔬</span>
            <span class="preset-name">Researcher</span>
            <span class="preset-role-tag">research</span>
            <span class="preset-desc">Evidence-first. Cites every claim. TLDR output.</span>
          </button>
          <button type="button" class="preset-card" data-preset="auditor" title="Finds real OWASP vulnerabilities in code. Confirms every finding before reporting.">
            <span class="preset-icon">🔒</span>
            <span class="preset-name">Security Auditor</span>
            <span class="preset-role-tag">security</span>
            <span class="preset-desc">OWASP code reviewer. Confirms before reporting.</span>
          </button>
          <button type="button" class="preset-card" data-preset="scout" title="MongoDB analyst. Queries before answering. Surfaces anomalies and data health issues.">
            <span class="preset-icon">🗄</span>
            <span class="preset-name">Data Scout</span>
            <span class="preset-role-tag">data</span>
            <span class="preset-desc">MongoDB analyst. Queries, surfaces anomalies.</span>
          </button>

          <!-- ── Consumer Deployment ─────────────────── -->
          <button type="button" class="preset-card" data-preset="support_bot" title="Consumer-facing support bot. Answers questions, captures leads, escalates unresolved issues.">
            <span class="preset-icon">💬</span>
            <span class="preset-name">Support Agent</span>
            <span class="preset-role-tag">consumer</span>
            <span class="preset-desc">Consumer chat. Answers, captures leads, escalates.</span>
          </button>
          <button type="button" class="preset-card" data-preset="lead_bot" title="Consultative sales bot. Qualifies visitors, answers questions, drives next steps.">
            <span class="preset-icon">🎯</span>
            <span class="preset-name">Sales Assistant</span>
            <span class="preset-role-tag">consumer</span>
            <span class="preset-desc">Qualifies visitors, drives demos and sign-ups.</span>
          </button>

          <!-- ── Support / Maintenance ───────────────── -->
          <button type="button" class="preset-card" data-preset="prompt_doctor" title="Audits and rewrites system prompts. Tightens bloat, resolves contradictions.">
            <span class="preset-icon">✏️</span>
            <span class="preset-name">Prompt Doctor</span>
            <span class="preset-role-tag">support</span>
            <span class="preset-desc">Audits and rewrites system prompts.</span>
          </button>
          <button type="button" class="preset-card" data-preset="kb_curator" title="Audits knowledge base entries. Removes stale data, promotes high-signal findings.">
            <span class="preset-icon">🗂</span>
            <span class="preset-name">KB Curator</span>
            <span class="preset-role-tag">support</span>
            <span class="preset-desc">Audits KB entries. Culls stale, promotes useful.</span>
          </button>

          <!-- ── Persona ─────────────────────────────── -->
          <button type="button" class="preset-card" data-preset="persona_bot" title="Research-driven. Builds a four-layer profile then fully embodies the persona in chat.">
            <span class="preset-icon">🎭</span>
            <span class="preset-name">Persona Scout</span>
            <span class="preset-role-tag">persona</span>
            <span class="preset-desc">Researches, profiles, then embodies a persona.</span>
          </button>
          <button type="button" class="preset-card" data-preset="narrator" title="World-building and narrative AI. Reads existing material for consistency before creating.">
            <span class="preset-icon">📖</span>
            <span class="preset-name">Narrator</span>
            <span class="preset-role-tag">creative</span>
            <span class="preset-desc">World-building and narrative design.</span>
          </button>

          <!-- ── Blank ───────────────────────────────── -->
          <button type="button" class="preset-card" data-preset="custom" title="Blank slate. Define name, role, and system prompt from scratch.">
            <span class="preset-icon">✦</span>
            <span class="preset-name">Custom</span>
            <span class="preset-role-tag">blank</span>
            <span class="preset-desc">Blank slate. Build from scratch.</span>
          </button>

        </div>
      </div>

      <div class="form-group">
        <label for="agentName">Agent Name *</label>
        <input type="text" id="agentName" name="name" required placeholder="e.g., Research Assistant">
      </div>

      <div class="form-group">
        <label for="agentDescription">Description</label>
        <textarea id="agentDescription" name="description" rows="2" placeholder="What this agent does..."></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="agentModel">Model *</label>
          <select id="agentModel" name="model" required>
            <option value="qwen2.5:7b">Qwen 2.5 7B</option>
            <option value="llama3.1:8b">Llama 3.1 8B</option>
            <option value="deepseek-r1:7b">DeepSeek R1 7B</option>
          </select>
        </div>

        <div class="form-group">
          <label for="agentProvider">Provider</label>
          <select id="agentProvider" name="provider">
            <option value="ollama">Ollama</option>
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="agentRole">Role</label>
          <select id="agentRole" name="role">
            <option value="assistant">Assistant</option>
            <option value="researcher">Researcher (TLDR pipeline)</option>
            <option value="vibecoder">Vibecoder (task list pipeline)</option>
            <option value="forwardChat">forwardChat (consumer deployment)</option>
          </select>
        </div>
      </div>

      <!-- Support agent relationship -->
      <div class="form-group" id="supportAgentSection">
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer">
          <input type="checkbox" id="isSupportAgent" name="isSupportAgent" onchange="toggleSupportAgentFields()">
          This agent supports another agent
        </label>
        <div id="supportAgentFields" style="display:none;margin-top:0.75rem;padding:0.75rem;background:#0a0a0a;border:1px solid #222;border-radius:6px">
          <div class="form-row">
            <div class="form-group">
              <label for="supportsAgentId">Supports agent</label>
              <select id="supportsAgentId" name="supportsAgentId">
                <option value="">— select agent —</option>
              </select>
            </div>
            <div class="form-group">
              <label for="supportRole">Support role</label>
              <select id="supportRole" name="supportRole">
                <option value="prompt-cleaner">Prompt Cleaner — rewrites bloated system prompts</option>
                <option value="kb-curator">KB Curator — curates knowledge base entries</option>
                <option value="reviewer">Reviewer — quality-checks agent outputs</option>
                <option value="background-support">Background Support — assists autonomous research</option>
                <option value="custom">Custom</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="supportLabel">Label <span style="color:#555;font-weight:400;font-size:0.8rem">(optional)</span></label>
            <input type="text" id="supportLabel" name="supportLabel" placeholder="e.g., Vincent's prompt doctor">
          </div>
        </div>
      </div>

      <div class="form-group">
        <label for="systemPrompt">System Prompt</label>

        <!-- Prompt Builder — collapsed by default, expands to help structure the prompt -->
        <div class="prompt-builder" id="promptBuilder">
          <div class="prompt-builder-header" onclick="togglePromptBuilder()">
            <h4>Prompt Builder</h4>
            <button type="button" class="prompt-builder-toggle" id="promptBuilderToggle">▸ expand</button>
          </div>
          <div class="prompt-builder-body" id="promptBuilderBody" style="display:none">
            <div class="prompt-builder-row">
              <div class="form-group" style="margin:0">
                <label style="font-size:0.78rem;color:#888">Tone</label>
                <select id="pb-tone" style="width:100%;background:#111;border:1px solid #2a2a2a;color:#ccc;border-radius:4px;padding:0.3rem 0.5rem;font-size:0.82rem">
                  <option value="">— select —</option>
                  <option value="professional">Professional — formal, clear, concise</option>
                  <option value="friendly">Friendly — warm, approachable, helpful</option>
                  <option value="technical">Technical — precise, detailed, expert-level</option>
                  <option value="concise">Concise — minimal words, maximum signal</option>
                  <option value="conversational">Conversational — natural, relaxed, human</option>
                </select>
              </div>
              <div class="form-group" style="margin:0">
                <label style="font-size:0.78rem;color:#888">Response style</label>
                <select id="pb-style" style="width:100%;background:#111;border:1px solid #2a2a2a;color:#ccc;border-radius:4px;padding:0.3rem 0.5rem;font-size:0.82rem">
                  <option value="">— select —</option>
                  <option value="bullets">Bullet points — structured lists</option>
                  <option value="prose">Prose — full sentences and paragraphs</option>
                  <option value="mixed">Mixed — prose with bullets for lists</option>
                  <option value="structured">Structured — headers and sections</option>
                  <option value="brief">Brief — 1–3 sentences max</option>
                </select>
              </div>
            </div>
            <div class="form-group" style="margin:0 0 0.6rem">
              <label style="font-size:0.78rem;color:#888">Domain / expertise <span style="color:#555;font-weight:400">(what this agent knows about)</span></label>
              <input type="text" id="pb-domain" style="width:100%;background:#111;border:1px solid #2a2a2a;color:#ccc;border-radius:4px;padding:0.3rem 0.5rem;font-size:0.82rem" placeholder="e.g. customer support for a SaaS billing product">
            </div>
            <div class="form-group" style="margin:0 0 0.6rem">
              <label style="font-size:0.78rem;color:#888">Hard rules <span style="color:#555;font-weight:400">(what this agent must never do — comma-separated)</span></label>
              <input type="text" id="pb-rules" style="width:100%;background:#111;border:1px solid #2a2a2a;color:#ccc;border-radius:4px;padding:0.3rem 0.5rem;font-size:0.82rem" placeholder="e.g. never discuss competitor products, never promise refunds">
            </div>
            <div class="form-group" style="margin:0 0 0.6rem">
              <label style="font-size:0.78rem;color:#888">Escalation path <span style="color:#555;font-weight:400">(who/what to redirect to when agent can't help)</span></label>
              <input type="text" id="pb-escalation" style="width:100%;background:#111;border:1px solid #2a2a2a;color:#ccc;border-radius:4px;padding:0.3rem 0.5rem;font-size:0.82rem" placeholder="e.g. direct to support@company.com or say 'I'll connect you with a human'">
            </div>
            <div class="prompt-builder-apply">
              <button type="button" class="btn-secondary btn-sm" onclick="applyPromptBuilder()">Build Prompt →</button>
              <small>Assembles fields into the system prompt below. You can edit freely after.</small>
            </div>
          </div>
        </div>

        <textarea id="systemPrompt" name="systemPrompt" rows="6" placeholder="You are a helpful AI assistant...">You are a helpful AI assistant.</textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="temperature">Temperature</label>
          <input type="number" id="temperature" name="temperature" min="0" max="2" step="0.1" value="0.7">
        </div>

        <div class="form-group">
          <label for="maxTokens">Max Tokens</label>
          <input type="number" id="maxTokens" name="maxTokens" value="8192" step="1024">
        </div>
      </div>

      <div class="form-actions">
        <button type="button" class="btn-secondary" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn-primary">
          <span id="submitBtnText">Create Agent</span>
        </button>
      </div>
    </form>
  </div>
</div>
