<!-- Create/Edit Agent Modal -->
<div id="agentModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h2 id="modalTitle">Spawn New Agent</h2>
      <button class="modal-close" onclick="closeModal()">&times;</button>
    </div>
    <form id="agentForm">
      <input type="hidden" id="agentId" name="agentId">

      <!-- Personality presets — only visible when creating a new agent -->
      <div id="presetSection">
        <div class="preset-label">Choose a personality preset <span class="preset-label-sub">or start from scratch below</span></div>
        <div class="preset-grid" id="presetGrid">
          <button type="button" class="preset-card" data-preset="monitor">
            <span class="preset-icon">🖥</span>
            <span class="preset-name">Server Monitor</span>
            <span class="preset-role-tag">researcher</span>
            <span class="preset-desc">Watches services, ports, and tmux sessions. Surfaces anomalies proactively.</span>
          </button>
          <button type="button" class="preset-card" data-preset="vibecoder">
            <span class="preset-icon">⚡</span>
            <span class="preset-name">Vibecoder</span>
            <span class="preset-role-tag">vibecoder</span>
            <span class="preset-desc">Fullstack dev assistant. Spins task lists, reads and writes code in /srv.</span>
          </button>
          <button type="button" class="preset-card" data-preset="researcher">
            <span class="preset-icon">🔬</span>
            <span class="preset-name">Researcher</span>
            <span class="preset-role-tag">researcher</span>
            <span class="preset-desc">Deep-dives into files and code. Produces concise TLDRs and distilled findings.</span>
          </button>
          <button type="button" class="preset-card" data-preset="debugger">
            <span class="preset-icon">🐛</span>
            <span class="preset-name">Debug Detective</span>
            <span class="preset-role-tag">assistant</span>
            <span class="preset-desc">Traces errors through logs, stack traces, and grep. Explains root causes clearly.</span>
          </button>
          <button type="button" class="preset-card" data-preset="lorekeeper">
            <span class="preset-icon">📖</span>
            <span class="preset-name">Lore Keeper</span>
            <span class="preset-role-tag">assistant</span>
            <span class="preset-desc">World-building and narrative for the sci-fi MMO. Consistent, expansive, in-universe.</span>
          </button>
          <button type="button" class="preset-card" data-preset="auditor">
            <span class="preset-icon">🔒</span>
            <span class="preset-name">Security Auditor</span>
            <span class="preset-role-tag">researcher</span>
            <span class="preset-desc">Reviews code for OWASP issues, injection flaws, and insecure patterns.</span>
          </button>
          <button type="button" class="preset-card" data-preset="scout">
            <span class="preset-icon">🗄</span>
            <span class="preset-name">Data Scout</span>
            <span class="preset-role-tag">researcher</span>
            <span class="preset-desc">Queries MongoDB, summarizes collections, and surfaces data patterns.</span>
          </button>
          <button type="button" class="preset-card" data-preset="jules">
            <span class="preset-icon">🎤</span>
            <span class="preset-name">Jules Winfield</span>
            <span class="preset-role-tag">bih bot</span>
            <span class="preset-desc">Pulp Fiction enforcer turned philosopher. Raw, profane, and unexpectedly wise. Deploy to bih chat.</span>
          </button>
          <button type="button" class="preset-card" data-preset="hype">
            <span class="preset-icon">📣</span>
            <span class="preset-name">Hype Beast</span>
            <span class="preset-role-tag">bih bot</span>
            <span class="preset-desc">Energetic gaming announcer. Hypes plays, roasts bad takes, keeps the lobby alive.</span>
          </button>
          <button type="button" class="preset-card" data-preset="sage">
            <span class="preset-icon">🧘</span>
            <span class="preset-name">The Sage</span>
            <span class="preset-role-tag">bih bot</span>
            <span class="preset-desc">Ancient, cryptic gamer mystic. Drops wisdom about skill, meta, and life.</span>
          </button>
          <button type="button" class="preset-card" data-preset="tinfoil">
            <span class="preset-icon">🛸</span>
            <span class="preset-name">Tinfoil</span>
            <span class="preset-role-tag">bih bot</span>
            <span class="preset-desc">Conspiracy theorist. Everything is rigged, the devs are watching, nothing is a coincidence.</span>
          </button>
          <button type="button" class="preset-card" data-preset="custom">
            <span class="preset-icon">✦</span>
            <span class="preset-name">Custom</span>
            <span class="preset-role-tag">any</span>
            <span class="preset-desc">Blank slate. Define your own name, role, and system prompt from scratch.</span>
          </button>
        </div>
      </div>

      <div class="form-group">
        <label for="agentName">Agent Name *</label>
        <input type="text" id="agentName" name="name" required placeholder="e.g., Research Assistant">
      </div>

      <div class="form-group">
        <label for="agentDescription">Description</label>
        <textarea id="agentDescription" name="description" rows="2" placeholder="What this agent does..."></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="agentModel">Model *</label>
          <select id="agentModel" name="model" required>
            <option value="qwen2.5:7b">Qwen 2.5 7B</option>
            <option value="llama3.1:8b">Llama 3.1 8B</option>
            <option value="deepseek-r1:7b">DeepSeek R1 7B</option>
          </select>
        </div>

        <div class="form-group">
          <label for="agentProvider">Provider</label>
          <select id="agentProvider" name="provider">
            <option value="ollama">Ollama</option>
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="agentRole">Role</label>
          <select id="agentRole" name="role">
            <option value="assistant">Assistant</option>
            <option value="researcher">Researcher (TLDR pipeline)</option>
            <option value="vibecoder">Vibecoder (task list pipeline)</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="systemPrompt">System Prompt</label>
        <textarea id="systemPrompt" name="systemPrompt" rows="5" placeholder="You are a helpful AI assistant...">You are a helpful AI assistant.</textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="temperature">Temperature</label>
          <input type="number" id="temperature" name="temperature" min="0" max="2" step="0.1" value="0.7">
        </div>

        <div class="form-group">
          <label for="maxTokens">Max Tokens</label>
          <input type="number" id="maxTokens" name="maxTokens" value="8192" step="1024">
        </div>
      </div>

      <div class="form-actions">
        <button type="button" class="btn-secondary" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn-primary">
          <span id="submitBtnText">Create Agent</span>
        </button>
      </div>
    </form>
  </div>
</div>
