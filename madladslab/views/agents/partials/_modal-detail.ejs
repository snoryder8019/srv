<!-- Agent Detail Modal with Tabs -->
<div id="agentDetailModal" class="modal">
  <div class="modal-content modal-detail">
    <div class="modal-header">
      <div class="detail-header-content">
        <h2 id="detailAgentName">Agent Details</h2>
        <div class="agent-detail-status status-idle">
          <span class="status-dot"></span>
          idle
        </div>
      </div>
      <button class="modal-close" onclick="closeAgentDetail()">&times;</button>
    </div>

    <!-- Tab Navigation -->
    <div class="tab-nav">
      <button class="tab-btn active" data-tab="overview" onclick="switchTab('overview')">Overview</button>
      <button class="tab-btn" data-tab="tuning" onclick="switchTab('tuning')">Tuning</button>
      <button class="tab-btn" data-tab="logs" onclick="switchTab('logs')">Logs</button>
      <button class="tab-btn" data-tab="memory" onclick="switchTab('memory')">Memory</button>
      <button class="tab-btn" data-tab="actions" onclick="switchTab('actions')">Actions</button>
      <button class="tab-btn" data-tab="permissions" onclick="switchTab('permissions')">Permissions</button>
    </div>

    <!-- Tab Contents -->
    <div class="tab-panels">
      <div id="overviewTab" class="tab-content active">
        <p class="loading">Loading...</p>
      </div>

      <div id="tuningTab" class="tab-content">
        <p class="loading">Loading...</p>
      </div>

      <div id="logsTab" class="tab-content">
        <p class="loading">Loading...</p>
      </div>

      <div id="memoryTab" class="tab-content">
        <p class="loading">Loading...</p>
      </div>

      <div id="actionsTab" class="tab-content">
        <p class="loading">Loading...</p>
      </div>

      <div id="permissionsTab" class="tab-content">
        <p class="loading">Loading...</p>
      </div>
    </div>
  </div>
</div>
