<!-- Chat Modal -->
<div id="chatModal" class="modal">
  <div class="modal-content modal-chat">
    <div class="modal-header">
      <h2 id="chatTitle">Chat with Agent</h2>
      <button class="modal-close" onclick="closeChatModal()">&times;</button>
    </div>
    <div id="chatContextStrip" class="chat-context-strip" style="display:none"></div>
    <div class="chat-container">
      <div id="chatMessages" class="chat-messages"></div>
      <div class="chat-input-container">
        <input type="text" id="chatInput" placeholder="Type your message..." />
        <button id="sendChatBtn" class="btn-primary">Send</button>
      </div>
    </div>
  </div>
</div>
