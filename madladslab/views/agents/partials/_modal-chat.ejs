<!-- Chat Modal -->
<div id="chatModal" class="modal">
  <div class="modal-content modal-chat">
    <div class="modal-header">
      <div class="chat-title-wrap">
        <span id="chatTitleAvatar" class="chat-title-avatar"></span>
        <h2 id="chatTitle">Chat with <span id="chatTitleName">Agent</span></h2>
      </div>
      <div class="chat-header-controls">
        <select id="chatVoiceSelect" class="chat-voice-select" title="TTS voice" onchange="chatSetVoice(this.value)">
          <optgroup label="US English">
            <option value="lessac">Lessac (F)</option>
            <option value="ryan">Ryan (M)</option>
            <option value="slt">SLT (F)</option>
            <option value="clb">CLB (F)</option>
            <option value="bdl">BDL (M)</option>
            <option value="rms">RMS (M)</option>
            <option value="awb">AWB (M)</option>
            <option value="ksp">KSP (M)</option>
            <option value="lnh">LNH (F)</option>
            <option value="aew">AEW (M)</option>
            <option value="jmk">JMK (M)</option>
            <option value="fem">FEM (F)</option>
            <option value="ljm">LJM (F)</option>
            <option value="slp">SLP (F)</option>
            <option value="axb">AXB (F)</option>
            <option value="eey">EEY (F)</option>
            <option value="gka">GKA (M)</option>
            <option value="aup">AUP (M)</option>
            <option value="ahw">AHW (M)</option>
            <option value="rxr">RXR (M)</option>
          </optgroup>
          <optgroup label="British English">
            <option value="cori">Cori (F)</option>
          </optgroup>
        </select>
      </div>
      <button class="modal-close" onclick="closeChatModal()">&times;</button>
    </div>
    <div id="chatContextStrip" class="chat-context-strip" style="display:none"></div>
    <div class="chat-container">
      <div id="chatMessages" class="chat-messages"></div>
      <div class="chat-input-container">
        <button id="chatMicBtn" class="chat-mic-btn" onclick="chatToggleMic()" title="Voice input">&#x1F3A4;</button>
        <input type="text" id="chatInput" placeholder="Type your message..." />
        <button id="sendChatBtn" class="btn-primary">Send</button>
      </div>
    </div>
  </div>
</div>
