<div class="agent-card" data-agent-id="<%= agent._id %>">
  <div class="agent-card-header">
    <div class="agent-status-badge status-<%= agent.status %>">
      <span class="status-dot"></span>
      <%= agent.status %>
    </div>
    <span class="bg-badge" id="bg-badge-<%= agent._id %>" style="display:none" onclick="event.stopPropagation(); openAgentDetail('<%= agent._id %>'); setTimeout(()=>switchTab('actions'),300)" title="Background process running — click to view output">
      <span class="status-dot" style="background:#ff88cc"></span>
      bg <span class="bg-badge-ticks">0</span>
    </span>
    <div class="agent-menu">
      <button class="menu-btn" onclick="event.stopPropagation(); toggleAgentMenu('<%= agent._id %>')">⋯</button>
      <div class="menu-dropdown" id="menu-<%= agent._id %>">
        <a href="#" onclick="editAgent('<%= agent._id %>'); return false;">Edit</a>
        <a href="#" onclick="deleteAgent('<%= agent._id %>'); return false;" class="danger">Delete</a>
      </div>
    </div>
  </div>

  <div class="agent-card-body">
    <div class="agent-icon">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
      </svg>
    </div>
    <h3 class="agent-name"><%= agent.name %></h3>
    <p class="agent-description"><%= agent.description || 'No description provided' %></p>

    <div class="agent-meta">
      <div class="meta-item">
        <span class="meta-label">Model:</span>
        <span class="meta-value"><%= agent.model %></span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Role:</span>
        <span class="meta-value role-badge role-<%= agent.role || 'assistant' %>"><%= agent.role || 'assistant' %></span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Temp:</span>
        <span class="meta-value"><%= agent.config.temperature %></span>
      </div>
    </div>

    <div class="agent-stats">
      <div class="stat-item">
        <span class="stat-value"><%= agent.stats.totalMessages %></span>
        <span class="stat-label">Messages</span>
      </div>
      <div class="stat-item">
        <span class="stat-value"><%= agent.stats.totalTokens.toLocaleString() %></span>
        <span class="stat-label">Tokens</span>
      </div>
      <div class="stat-item">
        <span class="stat-value"><%= agent.stats.lastActive ? new Date(agent.stats.lastActive).toLocaleDateString() : 'Never' %></span>
        <span class="stat-label">Last Active</span>
      </div>
    </div>
  </div>

  <div class="agent-card-footer">
    <button class="btn-chat" data-agent-id="<%= agent._id %>" onclick="event.stopPropagation(); openChat('<%= agent._id %>', '<%= agent.name %>')">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>
      Chat
      <span class="chat-unread-badge" id="chat-badge-<%= agent._id %>"></span>
    </button>
    <button class="btn-manage" onclick="event.stopPropagation(); openAgentDetail('<%= agent._id %>')">Manage</button>

    <!-- forwardChat discipline panel -->
    <div class="fwdchat-panel" id="fwdchat-panel-<%= agent._id %>">
      <button class="btn-fwdchat-toggle" onclick="event.stopPropagation(); toggleFwdChatPanel('<%= agent._id %>')" title="forwardChat deployments">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l.94-.94a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        forwardChat
        <% const bihOn = agent.forwardChat && agent.forwardChat.bihEnabled; %>
        <% const siteCount = agent.forwardChat && agent.forwardChat.sites ? agent.forwardChat.sites.filter(s => s.enabled).length : 0; %>
        <% if (bihOn || siteCount > 0) { %>
          <span class="fwdchat-count-badge"><%= (bihOn ? 1 : 0) + siteCount %></span>
        <% } %>
      </button>

      <div class="fwdchat-dropdown" id="fwdchat-dd-<%= agent._id %>" style="display:none">
        <!-- Sites dropdown row -->
        <div class="fwdchat-row fwdchat-sites-row">
          <select class="fwdchat-site-select" id="fwdchat-site-sel-<%= agent._id %>"
            onclick="event.stopPropagation()"
            onchange="onFwdChatSiteSelect('<%= agent._id %>', this.value)">
            <option value="">+ assign site</option>
          </select>
        </div>

        <!-- Active site assignments -->
        <div class="fwdchat-active-sites" id="fwdchat-sites-<%= agent._id %>">
          <% if (agent.forwardChat && agent.forwardChat.sites && agent.forwardChat.sites.length > 0) { %>
            <% agent.forwardChat.sites.forEach(function(s) { %>
              <div class="fwdchat-site-tag <%= s.enabled ? 'active' : '' %>" data-site-id="<%= s.siteId %>">
                <span class="fwdchat-site-dot"></span>
                <span class="fwdchat-site-name">site</span>
                <button onclick="event.stopPropagation(); removeFwdChatSite('<%= agent._id %>', '<%= s.siteId %>')" title="Remove">×</button>
              </div>
            <% }); %>
          <% } %>
        </div>

        <div class="fwdchat-footer-row">
          <a href="#" onclick="event.stopPropagation(); event.preventDefault(); openFwdChatSiteManager()" class="fwdchat-manage-link">manage sites</a>
        </div>
      </div>
    </div>

    <button class="btn-status" onclick="event.stopPropagation(); toggleStatus('<%= agent._id %>', '<%= agent.status %>')">
      <% if (agent.status === 'running' || agent.status === 'idle') { %>
        Stop
      <% } else { %>
        Start
      <% } %>
    </button>
  </div>
</div>
