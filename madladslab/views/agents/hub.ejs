<!DOCTYPE html>
<html>
<head>
  <link rel="icon" type="image/png" href="/images/beaker_logo_no_stash.png">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <title>Agent Hub - madLadsLab</title>
  <link rel="stylesheet" href="/stylesheets/admin.css">
  <link rel="stylesheet" href="/stylesheets/agents.css">
  <script src="/socket.io/socket.io.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
</head>
<body>
  <%- include('../mainContent/adminHeader.ejs') %>

  <!-- Hub Layout: full-height, no admin-container wrapping -->
  <div class="hub-layout">

    <!-- ═══ TOP BAR ═══ -->
    <div class="hub-topbar">
      <div class="hub-topbar-left">
        <span class="hub-topbar-title">Agent Hub</span>
        <div class="hub-org-stats" id="hubOrgStats">
          <span class="hub-stat" id="hubStatTotal">— agents</span>
          <span class="hub-stat-sep">·</span>
          <span class="hub-stat hub-stat-run" id="hubStatBg">— bg running</span>
          <span class="hub-stat-sep">·</span>
          <span class="hub-stat hub-stat-task" id="hubStatTasks">— tasks pending</span>
          <span class="hub-stat-sep">·</span>
          <span class="hub-stat hub-stat-human" id="hubStatHuman">— needs human</span>
        </div>
      </div>
      <div class="hub-topbar-right">
        <button class="hub-btn-spawn" onclick="hubOpenCreate()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Spawn Agent
        </button>
        <button class="hub-btn-reset-all" onclick="hubConfirmResetAll()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.14"/></svg>
          Reset All NSP
        </button>
      </div>
    </div>

    <!-- ═══ ADMIN BAR (superuser only) ═══ -->
    <% if (user.isAdmin) { %>
    <div class="hub-admin-bar">
      <span class="hub-admin-bar-label">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Superuser
      </span>
      <div class="hub-admin-bar-sep"></div>
      <span class="hub-admin-bar-action-label">Wipe collection:</span>
      <button class="hub-btn-admin-wipe" onclick="hubAdminWipe('agents','Agents collection (ALL agents)')">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        agents
      </button>
      <button class="hub-btn-admin-wipe" onclick="hubAdminWipe('notes','agent_notes')">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        agent_notes
      </button>
      <button class="hub-btn-admin-wipe" onclick="hubAdminWipe('actions','agent_actions')">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        agent_actions
      </button>
      <button class="hub-btn-admin-wipe" onclick="hubAdminWipe('tasks','agent_tasks')">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        agent_tasks
      </button>
      <button class="hub-btn-admin-wipe" onclick="hubAdminWipe('projects','agent_projects')">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        agent_projects
      </button>
      <button class="hub-btn-admin-wipe" onclick="hubAdminWipe('reports','agent_reports')">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        agent_reports
      </button>
    </div>
    <% } %>

    <!-- ═══ BODY (sidebar + detail) ═══ -->
    <div class="hub-body" id="hubBody">

      <!-- ── SIDEBAR ── -->
      <div class="hub-sidebar" id="hubSidebar">
        <div class="hub-sidebar-search">
          <input type="text" id="hubSearch" placeholder="filter agents…" oninput="hubFilterAgents(this.value)">
          <button class="hub-sidebar-spawn" onclick="hubOpenCreate()" title="Spawn new agent">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
        </div>
        <div class="hub-agent-list" id="hubAgentList">
          <% if (agents && agents.length > 0) { %>
            <% agents.forEach(agent => { %>
              <div class="hub-agent-row" data-agent-id="<%= agent._id %>" data-agent-name="<%= agent.name.toLowerCase() %>"
                onclick="hubSelectAgent('<%= agent._id %>')">
                <div class="hub-row-status status-<%= agent.status %>" id="hub-row-status-<%= agent._id %>">
                  <span class="status-dot"></span>
                </div>
                <div class="hub-row-info">
                  <span class="hub-row-name"><%= agent.name %></span>
                  <span class="hub-row-meta"><%= agent.role %> · <%= agent.model.split(':')[0] %></span>
                </div>
                <div class="hub-row-badges">
                  <span class="hub-row-bg" id="hub-row-bg-<%= agent._id %>" style="display:none" title="background running">●</span>
                  <span class="hub-row-tasks" id="hub-row-tasks-<%= agent._id %>" style="display:none"></span>
                  <span class="hub-row-human" id="hub-row-human-<%= agent._id %>" style="display:none"></span>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <div class="hub-sidebar-empty">No agents yet</div>
          <% } %>
        </div>
      </div>

      <!-- ── DETAIL PANEL ── -->
      <div class="hub-detail" id="hubDetail">

        <!-- Empty state -->
        <div class="hub-detail-empty" id="hubDetailEmpty">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="color:#333">
            <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          <p>Select an agent to inspect its namespaces</p>
        </div>

        <!-- Agent detail content -->
        <div class="hub-detail-content" id="hubDetailContent" style="display:none">

          <!-- Agent header -->
          <div class="hub-agent-header" id="hubAgentHeader">
            <!-- filled by JS -->
          </div>

          <!-- Tab bar -->
          <div class="hub-tabs" id="hubTabBar">
            <button class="hub-tab-btn active" data-tab="notes" onclick="hubSwitchTab('notes')">
              Notes <span class="hub-tab-badge" id="hub-tbadge-notes"></span>
            </button>
            <button class="hub-tab-btn" data-tab="actions" onclick="hubSwitchTab('actions')">
              Actions <span class="hub-tab-badge" id="hub-tbadge-actions"></span>
            </button>
            <button class="hub-tab-btn" data-tab="tasks" onclick="hubSwitchTab('tasks')">
              Tasks <span class="hub-tab-badge" id="hub-tbadge-tasks"></span>
            </button>
            <button class="hub-tab-btn" data-tab="crons" onclick="hubSwitchTab('crons')">
              Crons <span class="hub-tab-badge" id="hub-tbadge-crons"></span>
            </button>
            <button class="hub-tab-btn" data-tab="memory" onclick="hubSwitchTab('memory')">Memory</button>
            <button class="hub-tab-btn" data-tab="logs" onclick="hubSwitchTab('logs')">Logs</button>
            <button class="hub-tab-btn" data-tab="background" onclick="hubSwitchTab('background')">Background</button>
            <button class="hub-tab-btn" data-tab="settings" onclick="hubSwitchTab('settings')">Settings</button>
          </div>

          <!-- Tab panels -->
          <div class="hub-tab-panels">
            <div id="hub-tab-notes"      class="hub-tab-panel active"><div class="hub-loading">Loading…</div></div>
            <div id="hub-tab-actions"    class="hub-tab-panel"><div class="hub-loading">Loading…</div></div>
            <div id="hub-tab-tasks"      class="hub-tab-panel"><div class="hub-loading">Loading…</div></div>
            <div id="hub-tab-crons"      class="hub-tab-panel"><div class="hub-loading">Loading…</div></div>
            <div id="hub-tab-memory"     class="hub-tab-panel"><div class="hub-loading">Loading…</div></div>
            <div id="hub-tab-logs"       class="hub-tab-panel"><div class="hub-loading">Loading…</div></div>
            <div id="hub-tab-background" class="hub-tab-panel"><div class="hub-loading">Loading…</div></div>
            <div id="hub-tab-settings"   class="hub-tab-panel"><div class="hub-loading">Loading…</div></div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- ═══ RESET CONFIRM MODAL ═══ -->
  <div class="hub-modal-overlay" id="hubResetModal" style="display:none" onclick="if(event.target===this)hubCloseResetModal()">
    <div class="hub-modal-box">
      <div class="hub-modal-header">
        <h3 id="hubResetModalTitle">Reset Namespaces</h3>
        <button onclick="hubCloseResetModal()" class="hub-modal-close">&times;</button>
      </div>
      <p class="hub-modal-desc" id="hubResetModalDesc">Choose which collections to wipe. This cannot be undone.</p>
      <div class="hub-reset-checks">
        <label><input type="checkbox" id="hrck-tasks"   checked> <span>agent_tasks</span> <small>pending tasks queue</small></label>
        <label><input type="checkbox" id="hrck-notes"   checked> <span>agent_notes</span> <small>agent-written notes</small></label>
        <label><input type="checkbox" id="hrck-crons"   checked> <span>agent_crons</span> <small>scheduled jobs</small></label>
        <label><input type="checkbox" id="hrck-actions" checked> <span>agent_actions</span> <small>findings &amp; outputs</small></label>
        <label class="hub-reset-memory-row"><input type="checkbox" id="hrck-memory"> <span>in-doc memory</span> <small>KB, conversations, summaries (agent document)</small></label>
      </div>
      <div class="hub-modal-footer">
        <button class="hub-btn-cancel" onclick="hubCloseResetModal()">Cancel</button>
        <button class="hub-btn-danger" id="hubResetConfirmBtn" onclick="hubExecuteReset()">Reset Selected</button>
      </div>
    </div>
  </div>

  <!-- ═══ MODALS ═══ -->
  <%- include('./partials/_modal-create.ejs') %>
  <%- include('./partials/_modal-chat.ejs') %>
  <%- include('./partials/_modal-logs.ejs') %>

  <script>
    const SPAWN_USER_NAME = <%- JSON.stringify(user.displayName || user.email || 'your operator') %>;
    const SPAWN_AGENT_ROSTER = <%- JSON.stringify(agents.map(function(a){ return a.name + ' (' + a.role + ')'; }).join(', ') || 'none yet') %>;
  </script>
  <script src="/javascripts/agents-presets.js"></script>
  <script src="/javascripts/agents-ui.js"></script>
  <script src="/javascripts/agents-client.js"></script>
  <script src="/javascripts/agents-hub.js"></script>

  <%- include('../mainContent/adminNav.ejs') %>
</body>
</html>
