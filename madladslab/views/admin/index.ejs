<!DOCTYPE html>
<html>
<head>
    <link rel="icon" type="image/png" href="/images/beaker_logo_no_stash.png">
    <meta name="facebook-domain-verification" content="834yvsr0tr68eevl291uhwkt4nsd1c" />
    <link rel="stylesheet" href="/stylesheets/admin.css">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
    <meta property="og:title" content="madLadsLab Admin" />
    <meta property="og:description" content="Web Applications, Video, Email, IT" />
    <meta property="og:image" content="https://madladslab.com/images/madTitle.jpg" />
    <meta property="og:url" content="https://madladslab.com" />
    <meta property="og:type" content="website" />
    <title>Admin Dashboard - madLadsLab</title>
</head>
<body>
  <%-include('../mainContent/adminHeader.ejs')%>

  <div class="admin-container">

    <main class="admin-main">
      <div class="admin-header">
        <h1>Dashboard</h1>
        <p class="admin-subtitle">Welcome back, <%= user.name %></p>
      </div>

      <div class="dashboard-grid">
        <!-- User Info Card -->
        <div class="dashboard-card">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </div>
          <div class="card-content">
            <h3>User Profile</h3>
            <p class="card-label">Email:</p>
            <p class="card-value"><%= user.email %></p>
            <p class="card-label">Role:</p>
            <p class="card-value"><%= user.role %></p>
          </div>
        </div>

        <!-- Sites Summary Card -->
        <div class="dashboard-card">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
              <line x1="8" y1="21" x2="16" y2="21"></line>
              <line x1="12" y1="17" x2="12" y2="21"></line>
            </svg>
          </div>
          <div class="card-content">
            <h3>Sites</h3>
            <p class="card-stat"><%= sites.length %></p>
            <p class="card-description">Total sites managed</p>
            <a href="/admin/sites" class="card-link">Manage Sites →</a>
          </div>
        </div>

        <!-- Applications Card -->
        <div class="dashboard-card">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <rect x="3" y="3" width="7" height="7"></rect>
              <rect x="14" y="3" width="7" height="7"></rect>
              <rect x="14" y="14" width="7" height="7"></rect>
              <rect x="3" y="14" width="7" height="7"></rect>
            </svg>
          </div>
          <div class="card-content">
            <h3>Applications</h3>
            <p class="card-stat"><%= directories.length %></p>
            <p class="card-description">Active applications</p>
          </div>
        </div>

        <!-- Quick Actions Card -->
        <div class="dashboard-card">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
            </svg>
          </div>
          <div class="card-content">
            <h3>Quick Actions</h3>
            <div class="quick-actions">
              <a href="/admin/sites" class="quick-action-btn">Add Site</a>
              <a href="/admin/analytics" class="quick-action-btn">View Analytics</a>
              <a href="/admin/monitor" class="quick-action-btn">System Monitor</a>
              <a href="/admin/settings" class="quick-action-btn">Settings</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Sites -->
      <div class="content-section">
        <h2>Recent Sites</h2>
        <div class="table-container">
          <% if (sites && sites.length > 0) { %>
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Site Name</th>
                  <th>URL</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% sites.slice(0, 5).forEach(site => { %>
                  <tr>
                    <td><%= site.siteName %></td>
                    <td><a href="<%= site.siteUrl %>" target="_blank"><%= site.siteUrl %></a></td>
                    <td><span class="status-badge status-active">Active</span></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } else { %>
            <p class="empty-state">No sites available. <a href="/admin/sites">Add your first site</a></p>
          <% } %>
        </div>
      </div>

      <!-- Applications Directory -->
      <div class="content-section">
        <h2>Application Modules</h2>
        <div class="app-modules-grid">
          <% directories.forEach(dir => { %>
            <a href="/<%= dir %>" class="app-module-card">
              <div class="app-module-icon"><%= dir.charAt(0).toUpperCase() %></div>
              <div class="app-module-name"><%= dir %></div>
            </a>
          <% }); %>
        </div>
      </div>
    </main>
  </div>

  <style>
    /* Dashboard-specific styles */
    .dashboard-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .dashboard-card {
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 8px;
      padding: 1.5rem;
      transition: all 0.3s ease;
    }

    .dashboard-card:hover {
      border-color: #00ff88;
      box-shadow: 0 4px 12px rgba(0, 255, 136, 0.1);
    }

    .card-icon {
      width: 48px;
      height: 48px;
      background: rgba(0, 255, 136, 0.1);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      color: #00ff88;
    }

    .card-content h3 {
      font-size: 1.1rem;
      color: #fff;
      margin-bottom: 0.5rem;
    }

    .card-label {
      font-size: 0.85rem;
      color: #888;
      margin-top: 0.75rem;
      margin-bottom: 0.25rem;
    }

    .card-value {
      font-size: 0.95rem;
      color: #e0e0e0;
    }

    .card-stat {
      font-size: 2.5rem;
      font-weight: 700;
      color: #00ff88;
      margin: 0.5rem 0;
    }

    .card-description {
      color: #888;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }

    .card-link {
      color: #00ff88;
      text-decoration: none;
      font-size: 0.9rem;
      transition: color 0.2s;
    }

    .card-link:hover {
      color: #00cc77;
    }

    .quick-actions {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-top: 1rem;
    }

    .quick-action-btn {
      background: rgba(0, 255, 136, 0.08);
      border: 1px solid rgba(0, 255, 136, 0.25);
      color: #00ff88;
      padding: 0.5rem 1rem;
      border-radius: 4px;
      text-decoration: none;
      text-align: center;
      font-size: 0.9rem;
      transition: all 0.2s;
    }

    .quick-action-btn:hover {
      background: rgba(0, 255, 136, 0.16);
      border-color: #00ff88;
    }

    .app-modules-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
      gap: 1rem;
    }

    .app-module-card {
      background: #0a0a0a;
      border: 1px solid #2a2a2a;
      border-radius: 8px;
      padding: 1.25rem 0.75rem;
      text-align: center;
      text-decoration: none;
      transition: all 0.3s ease;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.6rem;
    }

    .app-module-card:hover {
      border-color: #00ff88;
      background: rgba(0, 255, 136, 0.05);
    }

    .app-module-icon {
      width: 44px;
      height: 44px;
      background: rgba(0, 255, 136, 0.1);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
      font-weight: 700;
      color: #00ff88;
    }

    .app-module-name {
      color: #e0e0e0;
      font-size: 0.85rem;
      text-transform: capitalize;
      word-break: break-word;
    }

    @media (max-width: 768px) {
      .dashboard-grid {
        grid-template-columns: 1fr 1fr;
      }

      .app-modules-grid {
        grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
      }
    }

    @media (max-width: 480px) {
      .dashboard-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <%-include('../mainContent/adminNav.ejs')%>
</body>
</html>
