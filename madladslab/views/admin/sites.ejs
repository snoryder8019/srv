<!DOCTYPE html>
<html>
<head>
    <link rel="icon" type="image/png" href="/images/beaker_logo_no_stash.png">
    <link rel="stylesheet" href="/stylesheets/admin.css">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
    <title>Sites Management - madLadsLab Admin</title>
</head>
<body>
  <%-include('../mainContent/adminHeader.ejs')%>

  <div class="admin-container">
    <%-include('../mainContent/adminSidebar.ejs')%>

    <main class="admin-main">
      <div class="admin-header">
        <h1>Sites Management</h1>
        <p class="admin-subtitle">Manage all your sites and monitoring</p>
      </div>

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <!-- Add New Site -->
      <div class="content-section">
        <h2>Add New Site</h2>
        <form method="POST" action="/admin/create-site" class="admin-form">
          <div class="form-row">
            <div class="form-group">
              <label for="siteName">Site Name</label>
              <input type="text" id="siteName" name="siteName" required placeholder="e.g., My Portfolio" />
            </div>
            <div class="form-group">
              <label for="siteUrl">Site URL</label>
              <input type="url" id="siteUrl" name="siteUrl" required placeholder="https://example.com" />
            </div>
          </div>
          <button type="submit" class="btn btn-primary">Add Site</button>
        </form>
      </div>

      <!-- Sites List -->
      <div class="content-section">
        <h2>All Sites (<%= sites ? sites.length : 0 %>)</h2>
        <div class="table-container">
          <% if (sites && sites.length > 0) { %>
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Site Name</th>
                  <th>URL</th>
                  <th>Status</th>
                  <th>Created</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% sites.forEach((site, index) => { %>
                  <tr data-site-id="<%= site._id %>">
                    <td><strong><%= site.siteName || 'Unnamed Site' %></strong></td>
                    <td>
                      <% if (site.siteUrl) { %>
                        <a href="<%= site.siteUrl %>" target="_blank" rel="noopener noreferrer">
                          <%= site.siteUrl %>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" style="display: inline; vertical-align: middle;">
                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                            <polyline points="15 3 21 3 21 9"></polyline>
                            <line x1="10" y1="14" x2="21" y2="3"></line>
                          </svg>
                        </a>
                      <% } else { %>
                        <span style="color: #888;">No URL</span>
                      <% } %>
                    </td>
                    <td><span class="status-badge status-active">Active</span></td>
                    <td><%= site.createdAt ? new Date(site.createdAt).toLocaleDateString() : 'N/A' %></td>
                    <td>
                      <div class="action-buttons">
                        <button class="btn-icon btn-edit" title="Edit" data-site-id="<%= site._id %>" data-site-name="<%= site.siteName || '' %>" data-site-url="<%= site.siteUrl || '' %>">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                          </svg>
                        </button>
                        <button class="btn-icon btn-danger btn-delete" title="Delete" data-site-id="<%= site._id %>" data-site-name="<%= site.siteName || 'this site' %>">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                          </svg>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } else { %>
            <div class="empty-state">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" style="margin-bottom: 1rem; opacity: 0.3;">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                <line x1="8" y1="21" x2="16" y2="21"></line>
                <line x1="12" y1="17" x2="12" y2="21"></line>
              </svg>
              <p>No sites added yet. Create your first site above to get started!</p>
            </div>
          <% } %>
        </div>
      </div>
    </main>
  </div>

  <style>
    /* Sites-specific styles */
    .admin-form {
      max-width: 100%;
    }

    .form-row {
      margin-bottom: 1rem;
    }

    .action-buttons {
      display: flex;
      gap: 0.5rem;
    }

    .btn-icon {
      background: rgba(0, 255, 0, 0.1);
      border: 1px solid rgba(0, 255, 0, 0.3);
      color: #00ff00;
      padding: 0.5rem;
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .btn-icon:hover {
      background: rgba(0, 255, 0, 0.2);
      border-color: #00ff00;
    }

    .btn-danger {
      background: rgba(255, 0, 0, 0.1);
      border-color: rgba(255, 0, 0, 0.3);
      color: #ff4444;
    }

    .btn-danger:hover {
      background: rgba(255, 0, 0, 0.2);
      border-color: #ff4444;
    }

    .empty-state {
      text-align: center;
      padding: 3rem 2rem;
      color: #888;
    }

    .empty-state p {
      margin-top: 1rem;
    }

    .modal-close:hover {
      background: rgba(255, 55, 95, 0.1);
      color: #ff375f;
    }

    @media (max-width: 768px) {
      .form-row {
        grid-template-columns: 1fr;
      }

      .modal-content {
        padding: 1.5rem;
      }
    }
  </style>

  <!-- Edit Site Modal -->
  <div id="editModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Edit Site</h2>
        <button class="modal-close" onclick="closeEditModal()">&times;</button>
      </div>
      <form id="editForm" method="POST" action="/admin/update-site">
        <input type="hidden" id="editSiteId" name="siteId" />
        <div class="form-group">
          <label for="editSiteName">Site Name</label>
          <input type="text" id="editSiteName" name="siteName" required />
        </div>
        <div class="form-group">
          <label for="editSiteUrl">Site URL</label>
          <input type="url" id="editSiteUrl" name="siteUrl" required />
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="closeEditModal()">Cancel</button>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // Parse URL parameters for success/error messages
    const urlParams = new URLSearchParams(window.location.search);
    const success = urlParams.get('success');
    const error = urlParams.get('error');

    if (success || error) {
      // Clean URL after showing message
      setTimeout(() => {
        window.history.replaceState({}, document.title, window.location.pathname);
      }, 3000);
    }

    // Edit functionality
    document.querySelectorAll('.btn-edit').forEach(btn => {
      btn.addEventListener('click', function() {
        const siteId = this.dataset.siteId;
        const siteName = this.dataset.siteName;
        const siteUrl = this.dataset.siteUrl;

        document.getElementById('editSiteId').value = siteId;
        document.getElementById('editSiteName').value = siteName;
        document.getElementById('editSiteUrl').value = siteUrl;
        document.getElementById('editModal').classList.add('show');
      });
    });

    function closeEditModal() {
      document.getElementById('editModal').classList.remove('show');
    }

    // Delete functionality
    document.querySelectorAll('.btn-delete').forEach(btn => {
      btn.addEventListener('click', function() {
        const siteId = this.dataset.siteId;
        const siteName = this.dataset.siteName;

        if (confirm(`Are you sure you want to delete "${siteName}"? This action cannot be undone.`)) {
          // Create a form and submit it
          const form = document.createElement('form');
          form.method = 'POST';
          form.action = '/admin/delete-site';

          const input = document.createElement('input');
          input.type = 'hidden';
          input.name = 'siteId';
          input.value = siteId;

          form.appendChild(input);
          document.body.appendChild(form);
          form.submit();
        }
      });
    });

    // Close modal on backdrop click
    document.getElementById('editModal').addEventListener('click', function(e) {
      if (e.target === this) closeEditModal();
    });
  </script>

  <%-include('../mainContent/adminNav.ejs')%>
</body>
</html>
