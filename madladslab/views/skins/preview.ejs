<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Roboto:wght@400;700&family=Open+Sans:wght@400;700&family=Lato:wght@400;700&family=Poppins:wght@400;700&family=Nunito:wght@400;700&family=DM+Sans:wght@400;700&family=Source+Sans+Pro:wght@400;700&family=Merriweather:wght@400;700&family=Playfair+Display:wght@400;700&family=Space+Mono&family=Fira+Code&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    :root {
      --skin-primary:       <%= skin.primaryColor   || '#6c63ff' %>;
      --skin-secondary:     <%= skin.secondaryColor || '#ff6584' %>;
      --skin-accent:        <%= skin.accentColor    || '#43e97b' %>;
      --skin-bg:            <%= skin.bgColor        || '#ffffff' %>;
      --skin-text:          <%= skin.textColor      || '#1a1a1a' %>;
      --skin-font-body:     <%= skin.fontBody       || "'Inter', sans-serif" %>;
      --skin-font-heading:  <%= skin.fontHeading    || "'Inter', sans-serif" %>;
      --skin-radius:        <%= skin.borderRadius   || '8px' %>;
    }
    body {
      margin: 0; background: var(--skin-bg); color: var(--skin-text);
      font-family: var(--skin-font-body); line-height: 1.6;
    }
    h1, h2, h3 { font-family: var(--skin-font-heading); }
    a { color: var(--skin-primary); }
    nav {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 2rem;
      background: <%= skin.darkMode ? 'rgba(0,0,0,0.4)' : 'rgba(255,255,255,0.9)' %>;
      border-bottom: 1px solid <%= skin.darkMode ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)' %>;
      position: sticky; top: 0; backdrop-filter: blur(10px);
    }
    .nav-logo { font-family: var(--skin-font-heading); font-weight: 700; font-size: 1.2rem; color: var(--skin-primary); }
    .nav-links { display: flex; gap: 1.5rem; }
    .nav-links a { text-decoration: none; color: var(--skin-text); font-size: 0.9rem; opacity: 0.7; }
    .btn { display: inline-block; padding: 0.6rem 1.4rem; border-radius: var(--skin-radius); font-family: var(--skin-font-body); font-size: 0.95rem; text-decoration: none; cursor: pointer; border: none; transition: opacity 0.2s; }
    .btn-primary { background: var(--skin-primary); color: #fff; }
    .btn-outline { background: transparent; color: var(--skin-primary); border: 2px solid var(--skin-primary); }
    .hero { text-align: center; padding: 6rem 2rem; }
    .hero h1 { font-size: clamp(2rem,5vw,3.5rem); margin-bottom: 1rem; }
    .hero p  { max-width: 560px; margin: 0 auto 2rem; opacity: 0.75; font-size: 1.1rem; }
    .btn-group { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
    .section { padding: 4rem 2rem; max-width: 1100px; margin: 0 auto; }
    .section h2 { font-size: clamp(1.5rem,3vw,2.2rem); margin-bottom: 0.5rem; }
    .subtitle { opacity: 0.65; margin-bottom: 2.5rem; }
    .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.25rem; }
    .card { background: <%= skin.darkMode ? '#1a1a1a' : '#f8f8f8' %>; border: 1px solid <%= skin.darkMode ? '#2a2a2a' : '#e5e5e5' %>; border-radius: var(--skin-radius); padding: 1.5rem; }
    .card-icon { font-size: 1.6rem; margin-bottom: 0.75rem; }
    .card h3 { margin: 0 0 0.5rem; font-size: 1rem; }
    .card p  { margin: 0; font-size: 0.875rem; opacity: 0.65; }
    .cta-strip { text-align: center; padding: 4rem 2rem; background: <%= skin.darkMode ? '#0a0a0a' : '#f0f0f0' %>; }
    .cta-strip h2 { font-size: clamp(1.5rem,3vw,2rem); margin-bottom: 0.75rem; }
    .cta-strip p { opacity: 0.7; margin-bottom: 2rem; }
    .footer { padding: 2rem; text-align: center; font-size: 0.8rem; opacity: 0.4; border-top: 1px solid <%= skin.darkMode ? '#1e1e1e' : '#e5e5e5' %>; }

    /* Preview bar */
    .preview-bar {
      position: fixed; bottom: 0; left: 0; right: 0;
      background: #0d0d0d; border-top: 1px solid #222;
      padding: 0.6rem 1.5rem; display: flex; align-items: center;
      justify-content: space-between; z-index: 999; font-size: 0.85rem;
    }
    .preview-bar span { color: #555; }
    .preview-bar strong { color: #00ff88; }
    .preview-bar a { color: #aaa; text-decoration: none; margin-left: 1rem; transition: color 0.2s; }
    .preview-bar a:hover { color: #00ff88; }

    <%= skin.customCss || '' %>
  </style>
</head>
<body>
  <nav>
    <span class="nav-logo"><%= skin.name %></span>
    <div class="nav-links">
      <a href="#">Features</a>
      <a href="#">Pricing</a>
      <a href="#">About</a>
    </div>
    <a href="#" class="btn btn-primary">Get Started</a>
  </nav>

  <div class="hero">
    <h1>Build Something Amazing</h1>
    <p>The perfect starting point for your next SaaS, agency, or small business website.</p>
    <div class="btn-group">
      <a href="#" class="btn btn-primary">Get Started Free</a>
      <a href="#" class="btn btn-outline">See How It Works</a>
    </div>
  </div>

  <div class="section">
    <h2>Why it works</h2>
    <p class="subtitle">Everything your customers need, nothing they don't.</p>
    <div class="cards-grid">
      <div class="card"><div class="card-icon">🚀</div><h3>Fast</h3><p>Optimized for speed and performance across all devices.</p></div>
      <div class="card"><div class="card-icon">🎨</div><h3>Beautiful</h3><p>Stunning design that converts visitors into customers.</p></div>
      <div class="card"><div class="card-icon">🔒</div><h3>Secure</h3><p>Built with security best practices from the ground up.</p></div>
      <div class="card"><div class="card-icon">📊</div><h3>Insightful</h3><p>Analytics and insights to help you make smart decisions.</p></div>
    </div>
  </div>

  <div class="cta-strip">
    <h2>Ready to get started?</h2>
    <p>Join thousands of happy customers today.</p>
    <a href="#" class="btn btn-primary" style="margin-right:0.75rem">Get Started Free</a>
    <a href="#" class="btn btn-outline">Learn More</a>
  </div>

  <div class="footer" style="padding-bottom:3.5rem">
    © 2026 <%= skin.name %>. Built with madLadsLab Skins.
  </div>

  <div class="preview-bar">
    <span>Previewing: <strong><%= skin.name %></strong> — <%= skin.category || 'general' %></span>
    <div>
      <a href="/skins/editor/<%= skin._id %>">← Edit</a>
      <a href="/skins/export/<%= skin._id %>">Export CSS</a>
      <a href="/skins">All Skins</a>
    </div>
  </div>
</body>
</html>
