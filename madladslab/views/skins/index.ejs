<!DOCTYPE html>
<html>
<head>
  <link rel="icon" type="image/png" href="/images/beaker_logo_no_stash.png">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <link rel="stylesheet" href="/stylesheets/admin.css">
  <title><%= title %></title>
</head>
<body>
  <%-include('../mainContent/adminHeader.ejs')%>

  <div class="admin-container">
    <%-include('../mainContent/adminSidebar.ejs')%>

    <main class="admin-main">
      <div class="admin-header">
        <div>
          <h1>Skins</h1>
          <p class="admin-subtitle">Landing page styles &amp; client handoffs</p>
        </div>
        <a href="/skins/new" class="btn-new">+ New Skin</a>
      </div>

      <!-- Category Filter -->
      <div class="filter-bar">
        <% const cats = ['all','saas','small-business','agency','ecommerce','portfolio']; %>
        <% cats.forEach(cat => { %>
          <a href="/skins<%= cat === 'all' ? '' : '?category=' + cat %>"
             class="filter-chip <%= activeCategory === cat ? 'active' : '' %>">
            <%= cat.charAt(0).toUpperCase() + cat.slice(1) %>
          </a>
        <% }); %>
      </div>

      <!-- Skins Grid -->
      <% if (skins && skins.length > 0) { %>
        <div class="skins-grid">
          <% skins.forEach(skin => { %>
            <div class="skin-card" data-id="<%= skin._id %>">
              <!-- Mini preview swatch -->
              <div class="skin-preview" style="
                background: <%= skin.bgColor || (skin.darkMode ? '#0d0d0d' : '#ffffff') %>;
                border-bottom: 3px solid <%= skin.primaryColor || '#6c63ff' %>;
              ">
                <div class="swatch-hero" style="color: <%= skin.textColor || '#1a1a1a' %>">
                  <div class="swatch-headline" style="font-family: <%= skin.fontHeading || 'sans-serif' %>">Aa</div>
                  <div class="swatch-dots">
                    <span style="background:<%= skin.primaryColor || '#6c63ff' %>"></span>
                    <span style="background:<%= skin.secondaryColor || '#ff6584' %>"></span>
                    <span style="background:<%= skin.accentColor || '#43e97b' %>"></span>
                  </div>
                </div>
              </div>

              <!-- Card meta -->
              <div class="skin-meta">
                <div class="skin-name"><%= skin.name %></div>
                <div class="skin-category"><%= skin.category || 'general' %></div>
                <% if (skin.description) { %>
                  <div class="skin-desc"><%= skin.description %></div>
                <% } %>
              </div>

              <!-- Actions -->
              <div class="skin-actions">
                <a href="/skins/preview/<%= skin._id %>" target="_blank" class="action-btn">Preview</a>
                <a href="/skins/editor/<%= skin._id %>" class="action-btn">Edit</a>
                <a href="/skins/export/<%= skin._id %>" class="action-btn action-export">Export CSS</a>
                <button class="action-btn action-delete" data-id="<%= skin._id %>" data-name="<%= skin.name %>">Delete</button>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="empty-state-box">
          <div class="empty-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="3"></rect>
              <path d="M9 9h6M9 12h6M9 15h4"></path>
            </svg>
          </div>
          <p>No skins yet for this category.</p>
          <a href="/skins/new" class="btn-new">Create your first skin</a>
        </div>
      <% } %>
    </main>
  </div>

  <!-- Delete confirm modal -->
  <div class="modal-backdrop" id="deleteModal" style="display:none">
    <div class="modal">
      <h3>Delete Skin</h3>
      <p>Delete "<span id="deleteModalName"></span>"? This cannot be undone.</p>
      <div class="modal-actions">
        <button class="btn-cancel" id="cancelDelete">Cancel</button>
        <button class="btn-danger" id="confirmDelete">Delete</button>
      </div>
    </div>
  </div>

  <style>
    .admin-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:1.5rem; }
    .btn-new {
      background: #00ff88; color: #000; font-weight: 600;
      padding: 0.55rem 1.2rem; border-radius: 6px;
      text-decoration: none; font-size: 0.9rem; white-space: nowrap;
      transition: opacity 0.2s;
    }
    .btn-new:hover { opacity: 0.85; }

    .filter-bar { display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:2rem; }
    .filter-chip {
      padding: 0.4rem 1rem; border-radius: 20px;
      border: 1px solid #333; color: #aaa;
      text-decoration: none; font-size: 0.85rem;
      text-transform: capitalize; transition: all 0.2s;
    }
    .filter-chip:hover { border-color: #00ff88; color: #00ff88; }
    .filter-chip.active { background: #00ff88; color: #000; border-color: #00ff88; font-weight: 600; }

    .skins-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1.5rem;
    }

    .skin-card {
      background: #111; border: 1px solid #222;
      border-radius: 10px; overflow: hidden;
      transition: border-color 0.2s, transform 0.2s;
    }
    .skin-card:hover { border-color: #00ff88; transform: translateY(-2px); }

    .skin-preview {
      height: 120px; display: flex;
      align-items: center; justify-content: center;
    }
    .swatch-hero { text-align: center; }
    .swatch-headline { font-size: 2.5rem; font-weight: 700; opacity: 0.9; }
    .swatch-dots { display:flex; gap:6px; justify-content:center; margin-top:6px; }
    .swatch-dots span { width:12px; height:12px; border-radius:50%; display:inline-block; }

    .skin-meta { padding: 1rem 1rem 0.5rem; }
    .skin-name { font-size: 1rem; font-weight: 600; color: #fff; margin-bottom: 0.25rem; }
    .skin-category {
      font-size: 0.75rem; color: #00ff88;
      text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.4rem;
    }
    .skin-desc { font-size: 0.85rem; color: #777; }

    .skin-actions {
      display: flex; flex-wrap: wrap; gap: 0.4rem;
      padding: 0.75rem 1rem 1rem;
    }
    .action-btn {
      padding: 0.35rem 0.75rem; border-radius: 5px; font-size: 0.8rem;
      border: 1px solid #333; color: #ccc; text-decoration: none;
      background: transparent; cursor: pointer; transition: all 0.2s;
    }
    .action-btn:hover { border-color: #00ff88; color: #00ff88; }
    .action-export:hover { border-color: #43e97b; color: #43e97b; }
    .action-delete { color: #888; }
    .action-delete:hover { border-color: #ff4444; color: #ff4444; }

    .empty-state-box {
      text-align: center; padding: 4rem 2rem;
      color: #555; border: 1px dashed #2a2a2a; border-radius: 10px;
    }
    .empty-icon { color: #333; margin-bottom: 1rem; }
    .empty-state-box p { margin-bottom: 1.5rem; }

    /* Modal */
    .modal-backdrop {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.7);
      display: flex; align-items: center; justify-content: center;
      z-index: 1000;
    }
    .modal {
      background: #1a1a1a; border: 1px solid #333;
      border-radius: 10px; padding: 2rem; max-width: 380px; width: 90%;
    }
    .modal h3 { margin: 0 0 0.75rem; color: #fff; }
    .modal p  { color: #aaa; margin-bottom: 1.5rem; }
    .modal-actions { display:flex; gap:0.75rem; justify-content:flex-end; }
    .btn-cancel {
      background: transparent; border: 1px solid #444; color: #aaa;
      padding: 0.5rem 1.2rem; border-radius: 6px; cursor: pointer;
    }
    .btn-danger {
      background: #ff4444; border: none; color: #fff;
      padding: 0.5rem 1.2rem; border-radius: 6px; cursor: pointer; font-weight: 600;
    }
    .btn-danger:hover { background: #cc0000; }
  </style>

  <script>
    let pendingDeleteId = null;

    document.querySelectorAll('.action-delete').forEach(btn => {
      btn.addEventListener('click', () => {
        pendingDeleteId = btn.dataset.id;
        document.getElementById('deleteModalName').textContent = btn.dataset.name;
        document.getElementById('deleteModal').style.display = 'flex';
      });
    });

    document.getElementById('cancelDelete').addEventListener('click', () => {
      document.getElementById('deleteModal').style.display = 'none';
      pendingDeleteId = null;
    });

    document.getElementById('confirmDelete').addEventListener('click', async () => {
      if (!pendingDeleteId) return;
      try {
        const res = await fetch(`/skins/api/skins/${pendingDeleteId}`, { method: 'DELETE' });
        if (res.ok) {
          location.reload();
        } else {
          alert('Delete failed');
        }
      } catch (e) {
        alert('Error deleting skin');
      }
    });
  </script>

  <%-include('../mainContent/adminNav.ejs')%>
</body>
</html>
