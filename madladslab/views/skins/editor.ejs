<!DOCTYPE html>
<html>
<head>
  <link rel="icon" type="image/png" href="/images/beaker_logo_no_stash.png">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <link rel="stylesheet" href="/stylesheets/admin.css">
  <title><%= title %></title>
</head>
<body class="editor-body">
  <%-include('../mainContent/adminHeader.ejs')%>

  <div class="editor-layout">

    <!-- Left Panel: Controls -->
    <aside class="editor-panel">
      <div class="panel-header">
        <a href="/skins" class="back-link">← Skins</a>
        <h2><%= skin ? 'Edit Skin' : 'New Skin' %></h2>
      </div>

      <!-- Tabs -->
      <div class="tab-bar">
        <button class="tab active" data-tab="info">Info</button>
        <button class="tab" data-tab="colors">Colors</button>
        <button class="tab" data-tab="typography">Type</button>
        <button class="tab" data-tab="layout">Layout</button>
        <button class="tab" data-tab="css">CSS</button>
      </div>

      <form id="skinForm">
        <!-- Info Tab -->
        <div class="tab-content active" id="tab-info">
          <div class="field-group">
            <label>Skin Name *</label>
            <input type="text" name="name" class="ctrl-input" required
                   value="<%= skin ? skin.name : '' %>" placeholder="e.g. Cool Blue SaaS">
          </div>
          <div class="field-group">
            <label>Category</label>
            <select name="category" class="ctrl-input">
              <% const cats = ['saas','small-business','agency','ecommerce','portfolio']; %>
              <% cats.forEach(cat => { %>
                <option value="<%= cat %>"
                  <%= (skin && skin.category === cat) ? 'selected' : '' %>>
                  <%= cat.charAt(0).toUpperCase() + cat.slice(1) %>
                </option>
              <% }); %>
            </select>
          </div>
          <div class="field-group">
            <label>Description</label>
            <textarea name="description" class="ctrl-input ctrl-textarea"
                      placeholder="Brief description of this skin's vibe…"><%= skin ? (skin.description || '') : '' %></textarea>
          </div>
          <div class="field-group toggle-row">
            <label>Dark Mode</label>
            <label class="toggle">
              <input type="checkbox" name="darkMode" id="darkModeToggle"
                     <%= (skin && skin.darkMode) ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>
        </div>

        <!-- Colors Tab -->
        <div class="tab-content" id="tab-colors">
          <div class="field-group">
            <label>Primary Color</label>
            <div class="color-row">
              <input type="color" name="primaryColor" class="color-picker"
                     value="<%= skin ? (skin.primaryColor || '#6c63ff') : '#6c63ff' %>">
              <input type="text" class="color-hex ctrl-input" placeholder="#6c63ff"
                     value="<%= skin ? (skin.primaryColor || '#6c63ff') : '#6c63ff' %>">
            </div>
          </div>
          <div class="field-group">
            <label>Secondary Color</label>
            <div class="color-row">
              <input type="color" name="secondaryColor" class="color-picker"
                     value="<%= skin ? (skin.secondaryColor || '#ff6584') : '#ff6584' %>">
              <input type="text" class="color-hex ctrl-input" placeholder="#ff6584"
                     value="<%= skin ? (skin.secondaryColor || '#ff6584') : '#ff6584' %>">
            </div>
          </div>
          <div class="field-group">
            <label>Accent Color</label>
            <div class="color-row">
              <input type="color" name="accentColor" class="color-picker"
                     value="<%= skin ? (skin.accentColor || '#43e97b') : '#43e97b' %>">
              <input type="text" class="color-hex ctrl-input" placeholder="#43e97b"
                     value="<%= skin ? (skin.accentColor || '#43e97b') : '#43e97b' %>">
            </div>
          </div>
          <div class="field-group">
            <label>Background Color</label>
            <div class="color-row">
              <input type="color" name="bgColor" class="color-picker"
                     value="<%= skin ? (skin.bgColor || '#ffffff') : '#ffffff' %>">
              <input type="text" class="color-hex ctrl-input" placeholder="#ffffff"
                     value="<%= skin ? (skin.bgColor || '#ffffff') : '#ffffff' %>">
            </div>
          </div>
          <div class="field-group">
            <label>Text Color</label>
            <div class="color-row">
              <input type="color" name="textColor" class="color-picker"
                     value="<%= skin ? (skin.textColor || '#1a1a1a') : '#1a1a1a' %>">
              <input type="text" class="color-hex ctrl-input" placeholder="#1a1a1a"
                     value="<%= skin ? (skin.textColor || '#1a1a1a') : '#1a1a1a' %>">
            </div>
          </div>
        </div>

        <!-- Typography Tab -->
        <div class="tab-content" id="tab-typography">
          <div class="field-group">
            <label>Body Font</label>
            <select name="fontBody" class="ctrl-input" id="fontBodySelect">
              <% const fonts = ["'Inter', sans-serif","'Roboto', sans-serif","'Open Sans', sans-serif","'Lato', sans-serif","'Poppins', sans-serif","'Nunito', sans-serif","'DM Sans', sans-serif","'Source Sans Pro', sans-serif","'Georgia', serif","'Merriweather', serif","'Playfair Display', serif","'Space Mono', monospace","'Fira Code', monospace"]; %>
              <% fonts.forEach(f => { %>
                <option value="<%= f %>"
                  <%= (skin && skin.fontBody === f) ? 'selected' : '' %>>
                  <%= f.split("'")[1] || f %>
                </option>
              <% }); %>
            </select>
          </div>
          <div class="field-group">
            <label>Heading Font</label>
            <select name="fontHeading" class="ctrl-input" id="fontHeadingSelect">
              <% fonts.forEach(f => { %>
                <option value="<%= f %>"
                  <%= (skin && skin.fontHeading === f) ? 'selected' : '' %>>
                  <%= f.split("'")[1] || f %>
                </option>
              <% }); %>
            </select>
          </div>
          <div class="field-group">
            <label>Border Radius</label>
            <div class="slider-row">
              <input type="range" name="borderRadius" id="radiusSlider"
                     min="0" max="24" step="2"
                     value="<%= skin ? parseInt(skin.borderRadius || '8') : 8 %>">
              <span class="slider-val" id="radiusVal">
                <%= skin ? (skin.borderRadius || '8px') : '8px' %>
              </span>
            </div>
          </div>
        </div>

        <!-- Layout Tab -->
        <div class="tab-content" id="tab-layout">
          <div class="field-group">
            <label>Hero Layout</label>
            <div class="layout-options">
              <% const layouts = [
                { id: 'hero-centered', label: 'Centered', icon: '⬛' },
                { id: 'hero-split',    label: 'Split',    icon: '▪▪' },
                { id: 'minimal',       label: 'Minimal',  icon: '—' },
                { id: 'bold',          label: 'Bold',     icon: '▮' },
                { id: 'magazine',      label: 'Magazine', icon: '▤' },
              ]; %>
              <% layouts.forEach(l => { %>
                <label class="layout-option">
                  <input type="radio" name="layout" value="<%= l.id %>"
                         <%= (!skin && l.id === 'hero-centered') || (skin && skin.layout === l.id) ? 'checked' : '' %>>
                  <span class="layout-btn">
                    <span class="layout-icon"><%= l.icon %></span>
                    <span><%= l.label %></span>
                  </span>
                </label>
              <% }); %>
            </div>
          </div>
        </div>

        <!-- CSS Tab -->
        <div class="tab-content" id="tab-css">
          <div class="field-group">
            <label>Custom CSS Overrides</label>
            <p class="field-hint">Added after the generated skin styles. Use <code>var(--skin-primary)</code> etc.</p>
            <textarea name="customCss" class="ctrl-input ctrl-textarea ctrl-code"
                      rows="14" placeholder=".hero { min-height: 100vh; }"><%= skin ? (skin.customCss || '') : '' %></textarea>
          </div>
        </div>
      </form>

      <!-- Panel Footer: Actions -->
      <div class="panel-footer">
        <% if (skin) { %>
          <a href="/skins/export/<%= skin._id %>" class="footer-btn export-btn">Export CSS</a>
          <a href="/skins/preview/<%= skin._id %>" target="_blank" class="footer-btn preview-btn">Preview</a>
        <% } %>
        <button id="saveBtn" class="footer-btn save-btn">
          <%= skin ? 'Save Changes' : 'Create Skin' %>
        </button>
      </div>
    </aside>

    <!-- Right Panel: Live Preview -->
    <div class="preview-pane">
      <div class="preview-toolbar">
        <span class="preview-label">Live Preview</span>
        <div class="viewport-btns">
          <button class="vp-btn active" data-width="100%">Desktop</button>
          <button class="vp-btn" data-width="768px">Tablet</button>
          <button class="vp-btn" data-width="375px">Mobile</button>
        </div>
      </div>
      <div class="preview-frame-wrap">
        <iframe id="previewFrame" src="about:blank"></iframe>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" class="toast"></div>

  <style>
    html, body { height: 100%; overflow: hidden; }
    .editor-body { display: flex; flex-direction: column; height: 100vh; }

    .editor-layout {
      display: flex; flex: 1; overflow: hidden;
      height: calc(100vh - 56px); /* subtract admin header */
    }

    /* Left panel */
    .editor-panel {
      width: 320px; min-width: 280px;
      background: #0d0d0d; border-right: 1px solid #1e1e1e;
      display: flex; flex-direction: column; overflow: hidden;
    }

    .panel-header {
      padding: 1rem 1.25rem 0.75rem;
      border-bottom: 1px solid #1e1e1e;
    }
    .back-link { color: #555; text-decoration: none; font-size: 0.8rem; display:block; margin-bottom:0.4rem; }
    .back-link:hover { color: #00ff88; }
    .panel-header h2 { margin: 0; font-size: 1rem; color: #fff; }

    /* Tabs */
    .tab-bar {
      display: flex; border-bottom: 1px solid #1e1e1e;
      overflow-x: auto; flex-shrink: 0;
    }
    .tab {
      flex: 1; padding: 0.6rem 0.25rem; font-size: 0.78rem;
      background: none; border: none; color: #666; cursor: pointer;
      border-bottom: 2px solid transparent; transition: all 0.2s;
      white-space: nowrap;
    }
    .tab:hover { color: #ccc; }
    .tab.active { color: #00ff88; border-bottom-color: #00ff88; }

    /* Tab content */
    #skinForm { flex: 1; overflow-y: auto; }
    .tab-content { display: none; padding: 1rem 1.25rem; }
    .tab-content.active { display: block; }

    .field-group { margin-bottom: 1.1rem; }
    .field-group label { display: block; font-size: 0.78rem; color: #888; margin-bottom: 0.35rem; text-transform: uppercase; letter-spacing: 0.04em; }
    .ctrl-input {
      width: 100%; background: #111; border: 1px solid #2a2a2a;
      color: #e0e0e0; border-radius: 5px; padding: 0.5rem 0.65rem;
      font-size: 0.875rem; box-sizing: border-box;
      transition: border-color 0.2s;
    }
    .ctrl-input:focus { outline: none; border-color: #00ff88; }
    .ctrl-textarea { resize: vertical; min-height: 80px; }
    .ctrl-code { font-family: 'Fira Code', 'Courier New', monospace; font-size: 0.8rem; }

    .field-hint { font-size: 0.78rem; color: #555; margin: 0 0 0.5rem; }
    .field-hint code { background: #1a1a1a; padding: 0.1em 0.3em; border-radius: 3px; color: #00ff88; }

    /* Toggle */
    .toggle-row { display: flex; align-items: center; justify-content: space-between; }
    .toggle { position: relative; display: inline-block; width: 40px; height: 22px; }
    .toggle input { opacity: 0; width: 0; height: 0; }
    .toggle-slider {
      position: absolute; inset: 0; background: #2a2a2a;
      border-radius: 22px; cursor: pointer; transition: 0.2s;
    }
    .toggle-slider::before {
      content: ''; position: absolute; height: 16px; width: 16px;
      left: 3px; bottom: 3px; background: #666;
      border-radius: 50%; transition: 0.2s;
    }
    .toggle input:checked + .toggle-slider { background: rgba(0,255,136,0.25); }
    .toggle input:checked + .toggle-slider::before { transform: translateX(18px); background: #00ff88; }

    /* Color */
    .color-row { display: flex; gap: 0.5rem; align-items: center; }
    .color-picker { width: 40px; height: 36px; border: none; background: none; cursor: pointer; padding: 0; border-radius: 4px; }
    .color-hex { flex: 1; }

    /* Slider */
    .slider-row { display: flex; align-items: center; gap: 0.75rem; }
    .slider-row input[type=range] { flex: 1; accent-color: #00ff88; }
    .slider-val { color: #00ff88; font-size: 0.85rem; min-width: 36px; }

    /* Layout options */
    .layout-options { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
    .layout-option input { display: none; }
    .layout-btn {
      display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
      padding: 0.65rem 0.5rem; border: 1px solid #2a2a2a;
      border-radius: 6px; cursor: pointer; font-size: 0.78rem; color: #666;
      transition: all 0.2s; text-align: center;
    }
    .layout-icon { font-size: 1.1rem; }
    .layout-option input:checked + .layout-btn { border-color: #00ff88; color: #00ff88; background: rgba(0,255,136,0.05); }

    /* Panel footer */
    .panel-footer {
      display: flex; gap: 0.5rem; padding: 0.75rem 1.25rem;
      border-top: 1px solid #1e1e1e; flex-shrink: 0;
    }
    .footer-btn {
      flex: 1; padding: 0.6rem; border-radius: 6px; font-size: 0.85rem;
      text-align: center; text-decoration: none; cursor: pointer;
      border: 1px solid #2a2a2a; background: #111; color: #aaa;
      transition: all 0.2s;
    }
    .footer-btn:hover { border-color: #555; color: #fff; }
    .save-btn { background: #00ff88; color: #000; border-color: #00ff88; font-weight: 700; }
    .save-btn:hover { background: #00cc77; border-color: #00cc77; }
    .export-btn:hover { border-color: #43e97b; color: #43e97b; }
    .preview-btn:hover { border-color: #6c63ff; color: #6c63ff; }

    /* Right panel */
    .preview-pane {
      flex: 1; display: flex; flex-direction: column;
      background: #0a0a0a; overflow: hidden;
    }
    .preview-toolbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.5rem 1rem; border-bottom: 1px solid #1e1e1e;
      background: #0d0d0d; flex-shrink: 0;
    }
    .preview-label { font-size: 0.78rem; color: #555; text-transform: uppercase; letter-spacing: 0.08em; }
    .viewport-btns { display: flex; gap: 0.35rem; }
    .vp-btn {
      padding: 0.3rem 0.7rem; font-size: 0.75rem;
      border: 1px solid #2a2a2a; background: none; color: #666;
      border-radius: 4px; cursor: pointer; transition: all 0.2s;
    }
    .vp-btn:hover { color: #ccc; border-color: #444; }
    .vp-btn.active { color: #00ff88; border-color: #00ff88; }

    .preview-frame-wrap {
      flex: 1; display: flex; align-items: flex-start;
      justify-content: center; overflow: auto; padding: 1rem; background: #111;
    }
    #previewFrame {
      border: none; background: #fff;
      border-radius: 4px; transition: width 0.3s;
      width: 100%; height: 100%;
      box-shadow: 0 4px 24px rgba(0,0,0,0.5);
    }

    /* Toast */
    .toast {
      position: fixed; bottom: 1.5rem; right: 1.5rem;
      background: #1a1a1a; border: 1px solid #2a2a2a;
      color: #e0e0e0; padding: 0.75rem 1.25rem; border-radius: 8px;
      font-size: 0.9rem; opacity: 0; pointer-events: none;
      transition: opacity 0.3s; z-index: 9999;
    }
    .toast.show { opacity: 1; }
    .toast.success { border-color: #00ff88; color: #00ff88; }
    .toast.error   { border-color: #ff4444; color: #ff4444; }

    @media (max-width: 768px) {
      html, body { overflow: auto; }
      .editor-body { height: auto; }
      .editor-layout { flex-direction: column; height: auto; overflow: visible; }
      .editor-panel { width: 100%; min-width: unset; border-right: none; border-bottom: 1px solid #1e1e1e; }
      #skinForm { overflow: visible; }
      .preview-pane { height: 60vh; }
    }
  </style>

  <script>
    const skinId = '<%= skin ? skin._id : "" %>';
    const GOOGLE_FONTS_URL = 'https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Roboto:wght@400;700&family=Open+Sans:wght@400;700&family=Lato:wght@400;700&family=Poppins:wght@400;700&family=Nunito:wght@400;700&family=DM+Sans:wght@400;700&family=Source+Sans+Pro:wght@400;700&family=Merriweather:wght@400;700&family=Playfair+Display:wght@400;700&family=Space+Mono&family=Fira+Code&display=swap';

    // ── Tab switching ──────────────────────────────────────────────────────────
    document.querySelectorAll('.tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
      });
    });

    // ── Viewport switcher ──────────────────────────────────────────────────────
    document.querySelectorAll('.vp-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.vp-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const frame = document.getElementById('previewFrame');
        frame.style.width = btn.dataset.width;
        frame.style.height = btn.dataset.width === '100%' ? '100%' : '90vh';
      });
    });

    // ── Color pickers sync with hex inputs ────────────────────────────────────
    document.querySelectorAll('.color-picker').forEach((picker, i) => {
      const hex = picker.closest('.color-row').querySelector('.color-hex');
      picker.addEventListener('input', () => { hex.value = picker.value; updatePreview(); });
      hex.addEventListener('input', () => {
        if (/^#[0-9a-fA-F]{6}$/.test(hex.value)) { picker.value = hex.value; updatePreview(); }
      });
    });

    // ── Border radius slider ───────────────────────────────────────────────────
    const radiusSlider = document.getElementById('radiusSlider');
    const radiusVal    = document.getElementById('radiusVal');
    radiusSlider.addEventListener('input', () => {
      radiusVal.textContent = radiusSlider.value + 'px';
      updatePreview();
    });

    // ── Debounced preview update on any form change ───────────────────────────
    let debounceTimer;
    document.getElementById('skinForm').addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(updatePreview, 200);
    });
    document.getElementById('skinForm').addEventListener('change', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(updatePreview, 200);
    });

    // ── Gather form values ────────────────────────────────────────────────────
    function getFormData() {
      const form = document.getElementById('skinForm');
      const data = {};
      new FormData(form).forEach((v, k) => { data[k] = v; });
      // checkboxes not in FormData when unchecked
      data.darkMode = document.getElementById('darkModeToggle').checked;
      data.borderRadius = radiusSlider.value + 'px';
      // sync hex inputs as the color pickers are the named inputs
      document.querySelectorAll('.color-row').forEach(row => {
        const picker = row.querySelector('.color-picker');
        const hex    = row.querySelector('.color-hex');
        data[picker.name] = hex.value || picker.value;
      });
      return data;
    }

    // ── Build live preview HTML ───────────────────────────────────────────────
    function buildPreviewHtml(d) {
      const layout = d.layout || 'hero-centered';
      const heroClass = layout === 'hero-split' ? 'hero-split' : layout === 'bold' ? 'hero-bold' : layout === 'magazine' ? 'hero-magazine' : 'hero-centered';

      return `<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link href="${GOOGLE_FONTS_URL}" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    :root {
      --skin-primary:       ${d.primaryColor   || '#6c63ff'};
      --skin-secondary:     ${d.secondaryColor || '#ff6584'};
      --skin-accent:        ${d.accentColor    || '#43e97b'};
      --skin-bg:            ${d.bgColor        || '#ffffff'};
      --skin-text:          ${d.textColor      || '#1a1a1a'};
      --skin-font-body:     ${d.fontBody       || "'Inter', sans-serif"};
      --skin-font-heading:  ${d.fontHeading    || "'Inter', sans-serif"};
      --skin-radius:        ${d.borderRadius   || '8px'};
    }
    body {
      margin: 0; background: var(--skin-bg); color: var(--skin-text);
      font-family: var(--skin-font-body); line-height: 1.6;
    }
    h1, h2, h3 { font-family: var(--skin-font-heading); }
    a { color: var(--skin-primary); }
    nav {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 2rem;
      background: ${d.darkMode ? 'rgba(0,0,0,0.4)' : 'rgba(255,255,255,0.9)'};
      border-bottom: 1px solid ${d.darkMode ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)'};
      position: sticky; top: 0; backdrop-filter: blur(10px);
    }
    .nav-logo { font-family: var(--skin-font-heading); font-weight: 700; font-size: 1.2rem; color: var(--skin-primary); }
    .nav-links { display: flex; gap: 1.5rem; }
    .nav-links a { text-decoration: none; color: var(--skin-text); font-size: 0.9rem; opacity: 0.7; }
    .nav-links a:hover { opacity: 1; }
    .btn { display: inline-block; padding: 0.6rem 1.4rem; border-radius: var(--skin-radius); font-family: var(--skin-font-body); font-size: 0.95rem; text-decoration: none; cursor: pointer; border: none; transition: opacity 0.2s; }
    .btn-primary { background: var(--skin-primary); color: #fff; }
    .btn-outline { background: transparent; color: var(--skin-primary); border: 2px solid var(--skin-primary); }
    .hero-centered { text-align: center; padding: 6rem 2rem; }
    .hero-centered h1 { font-size: clamp(2rem,5vw,3.5rem); margin-bottom: 1rem; }
    .hero-centered p  { max-width: 560px; margin: 0 auto 2rem; opacity: 0.75; font-size: 1.1rem; }
    .hero-centered .btn-group { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
    .hero-split { display: grid; grid-template-columns: 1fr 1fr; min-height: 80vh; }
    .hero-split .split-text { display: flex; flex-direction: column; justify-content: center; padding: 4rem 3rem; }
    .hero-split .split-text h1 { font-size: clamp(1.8rem,4vw,3rem); margin-bottom: 1rem; }
    .hero-split .split-text p { opacity: 0.75; margin-bottom: 2rem; font-size: 1rem; }
    .hero-split .split-img { background: linear-gradient(135deg, var(--skin-primary), var(--skin-secondary)); display: flex; align-items: center; justify-content: center; font-size: 5rem; }
    .hero-bold { background: var(--skin-primary); color: #fff; padding: 7rem 2rem; text-align: center; }
    .hero-bold h1 { font-size: clamp(2.5rem,6vw,5rem); margin-bottom: 1rem; }
    .hero-bold p { max-width: 560px; margin: 0 auto 2.5rem; opacity: 0.85; font-size: 1.15rem; }
    .hero-bold .btn-primary { background: #fff; color: var(--skin-primary); }
    .hero-magazine { padding: 3rem 2rem; }
    .hero-magazine .mag-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; max-width: 1100px; margin: 0 auto; }
    .hero-magazine .mag-main { background: linear-gradient(135deg, var(--skin-primary), var(--skin-secondary)); border-radius: var(--skin-radius); padding: 3rem; color: #fff; }
    .hero-magazine .mag-main h1 { font-size: clamp(1.8rem,3vw,2.8rem); margin-bottom: 1rem; }
    .hero-magazine .mag-side { display: flex; flex-direction: column; gap: 1rem; }
    .hero-magazine .mag-card { background: ${d.darkMode ? '#1a1a1a' : '#f5f5f5'}; border-radius: var(--skin-radius); padding: 1.25rem; }
    .hero-magazine .mag-card h3 { margin: 0 0 0.5rem; font-size: 0.95rem; }
    .hero-magazine .mag-card p  { margin: 0; font-size: 0.85rem; opacity: 0.7; }
    .section { padding: 4rem 2rem; max-width: 1100px; margin: 0 auto; }
    .section h2 { font-size: clamp(1.5rem,3vw,2.2rem); margin-bottom: 0.5rem; }
    .section .subtitle { opacity: 0.65; margin-bottom: 2.5rem; }
    .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.25rem; }
    .card { background: ${d.darkMode ? '#1a1a1a' : '#f8f8f8'}; border: 1px solid ${d.darkMode ? '#2a2a2a' : '#e5e5e5'}; border-radius: var(--skin-radius); padding: 1.5rem; }
    .card-icon { width: 44px; height: 44px; background: rgba(108,99,255,0.1); border-radius: calc(var(--skin-radius) / 1.5); display: flex; align-items: center; justify-content: center; font-size: 1.4rem; margin-bottom: 1rem; }
    .card h3 { margin: 0 0 0.5rem; font-size: 1rem; }
    .card p  { margin: 0; font-size: 0.875rem; opacity: 0.65; }
    .cta-strip { text-align: center; padding: 4rem 2rem; background: ${d.darkMode ? '#0a0a0a' : '#f0f0f0'}; }
    .cta-strip h2 { font-size: clamp(1.5rem,3vw,2rem); margin-bottom: 0.75rem; }
    .cta-strip p { opacity: 0.7; margin-bottom: 2rem; }
    .footer { padding: 2rem; text-align: center; font-size: 0.8rem; opacity: 0.4; border-top: 1px solid ${d.darkMode ? '#1e1e1e' : '#e5e5e5'}; }
    ${d.customCss || ''}
  </style>
</head>
<body>
  <nav>
    <span class="nav-logo">${d.name || 'Brand'}</span>
    <div class="nav-links">
      <a href="#">Features</a>
      <a href="#">Pricing</a>
      <a href="#">About</a>
    </div>
    <a href="#" class="btn btn-primary">Get Started</a>
  </nav>

  ${heroHtml(layout, d)}

  <div class="section">
    <h2>Why it works</h2>
    <p class="subtitle">Everything your customers need, nothing they don't.</p>
    <div class="cards-grid">
      ${['🚀 Fast', '🎨 Beautiful', '🔒 Secure', '📊 Insightful'].map((label, i) => `
        <div class="card">
          <div class="card-icon">${label.split(' ')[0]}</div>
          <h3>${label.split(' ')[1]}</h3>
          <p>Short description of what makes this feature great for your customers.</p>
        </div>`).join('')}
    </div>
  </div>

  <div class="cta-strip">
    <h2>Ready to get started?</h2>
    <p>Join thousands of happy customers today.</p>
    <a href="#" class="btn btn-primary" style="margin-right:0.75rem">Get Started Free</a>
    <a href="#" class="btn btn-outline">Learn More</a>
  </div>

  <div class="footer">© 2026 ${d.name || 'Company'}. Built with madLadsLab Skins.</div>
</body>
</html>`;
    }

    function heroHtml(layout, d) {
      if (layout === 'hero-split') return `<div class="hero-split"><div class="split-text"><h1>Your Big Headline Goes Here</h1><p>A compelling subheadline that explains the core value proposition in two short lines.</p><div><a href="#" class="btn btn-primary" style="margin-right:0.5rem">Get Started</a><a href="#" class="btn btn-outline">See Demo</a></div></div><div class="split-img">✦</div></div>`;
      if (layout === 'bold') return `<div class="hero-bold"><h1>Make It Bold.</h1><p>Stand out from the crowd with a powerful visual impact that converts visitors into customers.</p><a href="#" class="btn btn-primary">Start Free Trial</a></div>`;
      if (layout === 'magazine') return `<div class="hero-magazine"><div class="mag-grid"><div class="mag-main"><h1>The Story That Changes Everything</h1><p style="opacity:0.9;margin-bottom:1.5rem">A short editorial lead that hooks your reader immediately.</p><a href="#" class="btn" style="background:#fff;color:var(--skin-primary)">Read More</a></div><div class="mag-side"><div class="mag-card"><h3>Feature One</h3><p>Brief takeaway for this card.</p></div><div class="mag-card"><h3>Feature Two</h3><p>Brief takeaway for this card.</p></div><div class="mag-card"><h3>Feature Three</h3><p>Brief takeaway for this card.</p></div></div></div></div>`;
      if (layout === 'minimal') return `<div style="padding:8rem 2rem;max-width:680px;margin:0 auto"><h1 style="font-size:clamp(1.8rem,4vw,3rem);margin-bottom:1rem">Simple. Elegant. Effective.</h1><p style="font-size:1.1rem;opacity:0.7;margin-bottom:2rem">Strip away the noise. Let the product speak.</p><a href="#" class="btn btn-primary">Get Started</a></div>`;
      // hero-centered (default)
      return `<div class="hero-centered"><h1>Build Something Amazing</h1><p>The perfect starting point for your next SaaS, agency, or small business website.</p><div class="btn-group"><a href="#" class="btn btn-primary">Get Started Free</a><a href="#" class="btn btn-outline">See How It Works</a></div></div>`;
    }

    // ── Update iframe ─────────────────────────────────────────────────────────
    function updatePreview() {
      const d = getFormData();
      const html = buildPreviewHtml(d);
      const frame = document.getElementById('previewFrame');
      const doc = frame.contentDocument || frame.contentWindow.document;
      doc.open(); doc.write(html); doc.close();
    }

    // ── Save ──────────────────────────────────────────────────────────────────
    document.getElementById('saveBtn').addEventListener('click', async () => {
      const data = getFormData();
      if (!data.name) { showToast('Skin name is required', 'error'); return; }

      const url    = skinId ? `/skins/api/skins/${skinId}` : '/skins/api/skins';
      const method = skinId ? 'PUT' : 'POST';

      try {
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error((await res.json()).error || 'Save failed');
        const saved = await res.json();
        showToast('Saved!', 'success');
        if (!skinId) {
          setTimeout(() => { window.location.href = `/skins/editor/${saved._id}`; }, 800);
        }
      } catch (err) {
        showToast(err.message, 'error');
      }
    });

    function showToast(msg, type = '') {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = 'toast show ' + type;
      setTimeout(() => { t.className = 'toast'; }, 2800);
    }

    // Initial preview render
    updatePreview();
  </script>

  <%-include('../mainContent/adminNav.ejs')%>
</body>
</html>
