<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %></title>
  <link rel="icon" type="image/png" href="/images/beaker_logo_no_stash.png">
  <style>
    :root {
      --red: #e74c3c; --red-dark: #c0392b; --red-glow: rgba(231,76,60,0.35);
      --bg: #060404; --text: #e0e0e0; --text-dim: #666;
      --cyan: #00ddff; --gold: #ffaa00; --green: #00ff88;
      --mono: 'Courier New', monospace;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    html, body { width: 100%; height: 100%; overflow: hidden; background: var(--bg); }
    #scene { position: absolute; inset: 0; display: block; z-index: 1; }

    /* ===== WEATHER WIDGET ===== */
    #weather-widget {
      position: absolute; top: 14px; left: 50%; transform: translateX(-50%);
      z-index: 15; font-family: var(--mono); text-align: center;
      pointer-events: none; white-space: nowrap;
    }
    #wx-main { display: flex; align-items: center; gap: 10px; justify-content: center; }
    #wx-emoji { font-size: 1.6rem; line-height: 1; }
    #wx-temp { font-size: 1.5rem; color: #fff; font-weight: bold; letter-spacing: -0.02em; }
    #wx-feels { font-size: 0.65rem; color: var(--text-dim); }
    #wx-desc { font-size: 0.62rem; color: var(--red); letter-spacing: 0.12em; margin-top: 2px; }
    #wx-row2 { font-size: 0.6rem; color: #444; margin-top: 3px; }
    #wx-row2 span { color: var(--text-dim); }
    #wx-location { font-size: 0.6rem; color: #333; margin-top: 2px; letter-spacing: 0.05em; }

    /* ===== CAMERA (fullscreen backdrop) ===== */
    #cam-pip {
      position: absolute; inset: 0; z-index: 0;
      background: #000; overflow: hidden;
      opacity: 0; transition: opacity 0.5s;
    }
    #cam-pip.visible { opacity: 1; }
    #cam-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transform: scaleX(-1); opacity: 0.78; }
    /* overlay canvas is top-level (outside cam-pip), z-index: 2, above three.js */
    #cam-overlay { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; transform: scaleX(-1); z-index: 2; }
    #cam-status { position: absolute; top: 14px; right: 110px; font-family: var(--mono); font-size: 0.6rem; color: var(--red); z-index: 20; pointer-events: none; }
    #cam-status.active { color: var(--green); }

    /* ===== HUD ===== */
    .hud { position: absolute; z-index: 15; font-family: var(--mono); pointer-events: none; }
    .hud a, .hud button { pointer-events: auto; }
    #hud-tl { top: 14px; left: 14px; }
    #hud-tl a { color: var(--red); font-size: 0.78rem; text-decoration: none; opacity: 0.7; transition: opacity 0.15s; }
    #hud-tl a:hover { opacity: 1; }
    #hud-tl h2 { font-size: 0.95rem; color: var(--red); text-shadow: 0 0 14px var(--red-glow); margin-top: 5px; letter-spacing: 0.06em; }
    .live-badge { display: inline-block; background: var(--red); color: #fff; font-size: 0.52rem; padding: 1px 5px; border-radius: 2px; margin-left: 7px; animation: pulse-b 1.5s ease-in-out infinite; vertical-align: middle; letter-spacing: 0.08em; }
    @keyframes pulse-b { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

    #hud-tr { top: 14px; right: 14px; text-align: right; color: var(--text-dim); font-size: 0.65rem; line-height: 2.1; }
    #hud-clock { font-size: 1rem; color: #555; letter-spacing: 0.06em; display: block; margin-bottom: 4px; }
    .state-row { display: flex; align-items: center; justify-content: flex-end; gap: 6px; }
    .dot { width: 6px; height: 6px; border-radius: 50%; background: #222; transition: background 0.3s, box-shadow 0.3s; }
    .dot.on { background: var(--green); box-shadow: 0 0 7px var(--green); }
    .dot.warn { background: var(--gold); box-shadow: 0 0 7px var(--gold); }

    #hud-bl { bottom: 16px; left: 16px; font-size: 0.68rem; color: var(--text-dim); line-height: 1.8; }
    .dl { font-size: 0.58rem; color: #333; letter-spacing: 0.08em; }
    .dv { color: var(--text); }
    .dv.hi { color: var(--red); text-shadow: 0 0 7px var(--red-glow); }
    .bar { display: inline-block; height: 4px; background: var(--red-dark); border-radius: 2px; vertical-align: middle; transition: width 0.1s, background 0.3s; }

    /* ===== FILE INFO ===== */
    #file-info {
      position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%);
      z-index: 15; font-family: var(--mono); font-size: 0.7rem;
      text-align: center; pointer-events: none;
      opacity: 0; transition: opacity 0.2s;
    }
    #fi-name { color: var(--cyan); font-size: 0.8rem; letter-spacing: 0.04em; }
    #fi-path { color: #333; font-size: 0.6rem; margin-top: 2px; }
    #fi-hint { color: var(--red); font-size: 0.58rem; margin-top: 3px; letter-spacing: 0.06em; }
    #fi-pinch { color: var(--gold); font-size: 0.65rem; margin-top: 2px; display: none; }
    #fi-pinch.show { display: block; }

    /* ===== GESTURE FLASH ===== */
    #gesture-flash { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); font-size: 3rem; z-index: 30; pointer-events: none; opacity: 0; transition: opacity 0.1s; text-align: center; }
    #gesture-flash.show { opacity: 1; }
    #gesture-flash.fade { opacity: 0; transition: opacity 0.7s; }
    #gl-sub { display: block; font-family: var(--mono); font-size: 0.7rem; color: var(--red); margin-top: -4px; letter-spacing: 0.1em; }

    /* ===== CHAT TOGGLE + PANEL ===== */
    #chat-toggle {
      position: absolute; bottom: 16px; right: 16px; z-index: 25; pointer-events: auto;
      background: var(--red-dark); border: 1px solid var(--red); color: #fff;
      font-family: var(--mono); font-size: 0.7rem; padding: 7px 14px; border-radius: 3px;
      cursor: pointer; transition: background 0.15s, box-shadow 0.15s; letter-spacing: 0.05em;
    }
    #chat-toggle:hover { background: var(--red); box-shadow: 0 0 12px var(--red-glow); }
    #chat-panel {
      position: absolute; top: 0; right: -420px; bottom: 0; width: 400px; z-index: 22;
      background: rgba(6,4,4,0.96); border-left: 1px solid #1a0808;
      display: flex; flex-direction: column; transition: right 0.3s ease;
      backdrop-filter: blur(10px);
    }
    #chat-panel.open { right: 0; }
    .chat-header { padding: 12px 14px; border-bottom: 1px solid #1a0808; background: linear-gradient(135deg,#1a0505,#2a0808); display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
    .chat-header h3 { font-family: var(--mono); font-size: 0.78rem; color: var(--red); letter-spacing: 0.06em; }
    #chat-close { background: none; border: none; color: var(--text-dim); cursor: pointer; font-size: 1rem; }
    #chat-close:hover { color: var(--red); }
    #chat-ctx { padding: 5px 12px; border-bottom: 1px solid #120505; font-family: var(--mono); font-size: 0.58rem; color: #333; flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    #chat-ctx span { color: #555; }
    #chat-feed { flex: 1; overflow-y: auto; padding: 12px; display: flex; flex-direction: column; gap: 10px; }
    #chat-feed::-webkit-scrollbar { width: 3px; }
    #chat-feed::-webkit-scrollbar-thumb { background: #2a0808; border-radius: 2px; }
    .msg { font-family: var(--mono); font-size: 0.73rem; line-height: 1.5; padding: 8px 10px; border-radius: 3px; max-width: 94%; }
    .msg.user { background: #180808; border: 1px solid #280a0a; color: var(--text-dim); align-self: flex-end; }
    .msg.assistant { background: #0f0404; border: 1px solid var(--red-dark); color: var(--text); align-self: flex-start; box-shadow: inset 0 0 18px rgba(231,76,60,0.04); }
    .msg .ts { font-size: 0.53rem; color: #2a2a2a; display: block; margin-top: 4px; }
    .msg .ctx-tag { display: inline-block; font-size: 0.56rem; color: var(--red); border: 1px solid #2a0606; padding: 0 4px; border-radius: 2px; margin-bottom: 4px; }
    .chat-controls { padding: 10px 12px; border-top: 1px solid #1a0808; flex-shrink: 0; }
    .chat-controls textarea { width: 100%; background: #0c0404; border: 1px solid #260a0a; color: var(--text); font-family: var(--mono); font-size: 0.7rem; padding: 7px 9px; border-radius: 3px; resize: none; height: 50px; outline: none; }
    .chat-controls textarea:focus { border-color: var(--red-dark); }
    .cbrow { display: flex; gap: 6px; margin-top: 6px; }
    .cbtn { flex: 1; padding: 7px 0; background: #130505; border: 1px solid #260a0a; color: var(--text-dim); font-family: var(--mono); font-size: 0.63rem; cursor: pointer; border-radius: 3px; transition: all 0.15s; }
    .cbtn:hover { background: #260a0a; color: var(--text); }
    .cbtn.p { background: var(--red-dark); border-color: var(--red); color: #fff; }
    .cbtn.p:hover { background: var(--red); }
    .cbtn:disabled { opacity: 0.3; cursor: default; }

    /* ===== START OVERLAY ===== */
    #start-overlay { position: absolute; inset: 0; z-index: 40; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px; background: rgba(6,4,4,0.88); backdrop-filter: blur(4px); }
    #start-overlay.hidden { display: none; }
    #start-overlay h1 { font-family: var(--mono); font-size: 1.3rem; color: var(--red); text-shadow: 0 0 28px var(--red-glow); letter-spacing: 0.1em; }
    #start-overlay p { font-family: var(--mono); font-size: 0.72rem; color: var(--text-dim); max-width: 360px; text-align: center; line-height: 1.7; }
    #start-btn { background: var(--red-dark); border: 1px solid var(--red); color: #fff; font-family: var(--mono); font-size: 0.82rem; padding: 11px 30px; border-radius: 3px; cursor: pointer; transition: all 0.2s; letter-spacing: 0.08em; }
    #start-btn:hover:not(:disabled) { background: var(--red); box-shadow: 0 0 22px var(--red-glow); }
    #start-btn:disabled { opacity: 0.4; cursor: default; }
    #init-status { font-family: var(--mono); font-size: 0.62rem; color: var(--text-dim); letter-spacing: 0.05em; }

    @media (max-width: 600px) {
      #chat-panel { width: 100%; right: -100%; }
      #cam-pip { width: 130px; height: 98px; bottom: 80px; }
      #weather-widget { display: none; }
    }
  </style>
</head>
<body>
<canvas id="scene"></canvas>

<!-- Camera backdrop (fullscreen, behind Three.js) -->
<div id="cam-pip">
  <video id="cam-video" autoplay playsinline muted></video>
</div>
<!-- MediaPipe overlay (top-level, above Three.js canvas) -->
<canvas id="cam-overlay"></canvas>
<span id="cam-status">● OFF</span>

<!-- Gesture flash -->
<div id="gesture-flash"><span id="ge"></span><span id="gl-sub"></span></div>

<!-- Weather widget -->
<div id="weather-widget">
  <div id="wx-main">
    <span id="wx-emoji">&#x2601;</span>
    <div>
      <div style="display:flex;align-items:baseline;gap:6px">
        <span id="wx-temp">--°F</span>
        <span id="wx-feels">feels --°</span>
      </div>
      <div id="wx-desc">LOADING...</div>
    </div>
  </div>
  <div id="wx-row2"><span id="wx-details">-- · --</span></div>
  <div id="wx-location"></div>
</div>

<!-- HUD top-left -->
<div class="hud" id="hud-tl">
  <a href="/stevenClawbert">&#8592; Steven Clawbert</a>
  <h2>LIVE VISION <span class="live-badge">LIVE</span></h2>
</div>

<!-- HUD top-right -->
<div class="hud" id="hud-tr">
  <span id="hud-clock">--:--:--</span>
  <div class="state-row"><div class="dot" id="dot-face"></div><span id="lbl-face">no face</span></div>
  <div class="state-row"><div class="dot" id="dot-hand"></div><span id="lbl-hand">no hand</span></div>
  <div class="state-row"><div class="dot" id="dot-mp"></div><span>mediapipe</span></div>
</div>

<!-- HUD bottom-left -->
<div class="hud" id="hud-bl">
  <div class="dl">GESTURE</div>
  <div class="dv" id="dl-gesture">—</div>
  <div class="dl" style="margin-top:5px">PINCH</div>
  <div class="dv" id="dl-pinch">—</div>
  <div class="dl" style="margin-top:5px">SMILE</div>
  <div><span class="bar" id="bar-smile" style="width:0;max-width:90px"></span> <span class="dv" id="dl-smile">0%</span></div>
  <div class="dl" style="margin-top:5px">GAZE</div>
  <div class="dv" id="dl-gaze">center</div>
</div>

<!-- File info (center bottom) -->
<div id="file-info">
  <div id="fi-name"></div>
  <div id="fi-path"></div>
  <div id="fi-hint"></div>
  <div id="fi-pinch"></div>
</div>

<!-- Chat toggle -->
<button id="chat-toggle">&#x2737; CHAT</button>

<!-- Chat panel -->
<div id="chat-panel">
  <div class="chat-header">
    <h3>&#x2B21; STEVEN CLAWBERT</h3>
    <button id="chat-close">&#10005;</button>
  </div>
  <div id="chat-ctx">context: <span id="ctx-live">awaiting camera...</span></div>
  <div id="chat-feed"></div>
  <div class="chat-controls">
    <textarea id="chat-input" placeholder="Type a message..."></textarea>
    <div class="cbrow">
      <button class="cbtn" id="btn-text">&#x2191; Text</button>
      <button class="cbtn p" id="btn-capture">&#x25CE; Capture + Send</button>
    </div>
  </div>
</div>

<!-- Start overlay -->
<div id="start-overlay">
  <h1>&#x2737; LIVE VISION</h1>
  <p>Three.js scene driven by eye tracking &amp; hand gestures.<br>
     Gaze = subtle camera tilt &middot; Pinch+drag = pan &middot; Wrist dial = zoom<br>
     Tap node = open &middot; Grab = drag &middot; Two-hand squash = collapse<br>
     Open-Meteo weather &middot; Steven AI multimodal vision</p>
  <button id="start-btn" disabled>ACTIVATE CAMERA</button>
  <div id="init-status">initializing mediapipe...</div>
</div>

<script type="importmap">
{ "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/"
} }
</script>

<script type="module">
import * as THREE from 'three';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

// =================== THREE.JS SCENE ===================

const canvas = document.getElementById('scene');
const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setClearColor(0x060404, 0.52);

const scene = new THREE.Scene();
scene.fog = new THREE.FogExp2(0x080303, 0.007);

const camera = new THREE.PerspectiveCamera(58, window.innerWidth / window.innerHeight, 0.1, 500);
camera.position.set(0, 4, 44);

const controls = new OrbitControls(camera, renderer.domElement);
controls.enableDamping = true;
controls.dampingFactor = 0.06;
controls.minDistance = 8;
controls.maxDistance = 130;
controls.autoRotate = false;
controls.autoRotateSpeed = 0;
controls.target.set(8, 0, 0); // center between orb and file nodes

scene.add(new THREE.AmbientLight(0x180303, 4));
const pLight = new THREE.PointLight(0xe74c3c, 7, 80);
pLight.position.set(0, 0, 0);
scene.add(pLight);
const fileLight = new THREE.PointLight(0x00ddff, 2, 50);
fileLight.position.set(22, 0, 0);
scene.add(fileLight);

// ---- starfield ----
(function() {
  const pos = new Float32Array(4000 * 3);
  for (let i = 0; i < pos.length; i++) pos[i] = (Math.random() - 0.5) * 500;
  const g = new THREE.BufferGeometry();
  g.setAttribute('position', new THREE.BufferAttribute(pos, 3));
  scene.add(new THREE.Points(g, new THREE.PointsMaterial({ color: 0xff3311, size: 0.14, sizeAttenuation: true, transparent: true, opacity: 0.35 })));
})();

// ---- orb (Steven's core) ----
const orbMat = new THREE.MeshPhongMaterial({ color: 0x1a0404, emissive: 0xe74c3c, emissiveIntensity: 0.7, transparent: true, opacity: 0.75, shininess: 120 });
const orb = new THREE.Mesh(new THREE.IcosahedronGeometry(3.2, 4), orbMat);
scene.add(orb);
const wireOrb = new THREE.Mesh(new THREE.IcosahedronGeometry(3.35, 2), new THREE.MeshBasicMaterial({ color: 0xe74c3c, wireframe: true, transparent: true, opacity: 0.12 }));
scene.add(wireOrb);
const glowMat = new THREE.MeshBasicMaterial({ color: 0xe74c3c, transparent: true, opacity: 0.06 });
scene.add(new THREE.Mesh(new THREE.SphereGeometry(4.8, 16, 16), glowMat));
const ring1 = new THREE.Mesh(new THREE.TorusGeometry(6.5, 0.04, 6, 80), new THREE.MeshBasicMaterial({ color: 0x440000, transparent: true, opacity: 0.5 }));
ring1.rotation.x = Math.PI * 0.3; scene.add(ring1);

// ---- particles ----
const PC = 2000;
const pPos = new Float32Array(PC * 3), pVel = new Float32Array(PC * 3), pCol = new Float32Array(PC * 3);
for (let i = 0; i < PC; i++) {
  const th = Math.random() * Math.PI * 2, ph = Math.acos(2 * Math.random() - 1), r = 7 + Math.random() * 16;
  pPos[i*3] = r * Math.sin(ph) * Math.cos(th);
  pPos[i*3+1] = r * Math.sin(ph) * Math.sin(th);
  pPos[i*3+2] = r * Math.cos(ph);
  const tx = -Math.sin(th), tz = Math.cos(th), sp = 0.007 + Math.random() * 0.01;
  pVel[i*3] = tx * sp; pVel[i*3+1] = (Math.random() - 0.5) * 0.003; pVel[i*3+2] = tz * sp;
  pCol[i*3] = 0.85; pCol[i*3+1] = 0.12; pCol[i*3+2] = 0.07;
}
const pGeo = new THREE.BufferGeometry();
pGeo.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
pGeo.setAttribute('color',    new THREE.BufferAttribute(pCol, 3));
const particles = new THREE.Points(pGeo, new THREE.PointsMaterial({ size: 0.2, sizeAttenuation: true, vertexColors: true, transparent: true, opacity: 0.8 }));
scene.add(particles);

// ---- hand cursor ----
const handCursor = new THREE.Mesh(new THREE.SphereGeometry(1.2, 8, 8), new THREE.MeshBasicMaterial({ color: 0xffaa00, transparent: true, opacity: 0, wireframe: true }));
scene.add(handCursor);

// =================== SHARED STATE ===================
const state = {
  faceFound: false, handFound: false,
  smile: 0, gazeX: 0, gazeY: 0,
  gazeCamX: 0, gazeCamY: 0,
  gesture: null, pinching: false, _wasPinching: false,
  pinchStartTime: 0, pinchStartHp: null,
  dialZoomVel: 0, handAngle: null,
  twoHandPrevDist: null,
  pulseIntensity: 0, pulseColor: new THREE.Color(0xe74c3c),
  attractMode: false, repelMode: false, explosionForce: 0,
};
window._liveState = state;

// =================== FILE NODE SYSTEM ===================

const NODE_STYLES = {
  dir:     { color: 0x00ddff, emissive: 0x002244, size: 0.85 },
  js:      { color: 0xffcc00, emissive: 0x443300, size: 0.65 },
  mjs:     { color: 0xffcc00, emissive: 0x443300, size: 0.60 },
  ejs:     { color: 0xff4466, emissive: 0x441122, size: 0.65 },
  json:    { color: 0x00ffcc, emissive: 0x004433, size: 0.58 },
  css:     { color: 0xcc88ff, emissive: 0x331155, size: 0.58 },
  md:      { color: 0x88cc88, emissive: 0x224422, size: 0.60 },
  default: { color: 0x887766, emissive: 0x221100, size: 0.52 }
};

const fileNodes = new Map();
let hoveredNode = null;
let grabbedNode = null;
let pinchCamLastPos = null;
const GRAB_RADIUS = 4.5;
const FILE_ORIGIN = new THREE.Vector3(22, 0, 0);

function makeNodeGeometry(item, style) {
  const s = style.size;
  if (item.isDir) return new THREE.IcosahedronGeometry(s, 0);
  const ext = item.name.split('.').pop().toLowerCase();
  if (['js','mjs','cjs'].includes(ext)) return new THREE.BoxGeometry(s, s, s);
  if (ext === 'json') return new THREE.CylinderGeometry(s*0.6, s*0.6, s*0.9, 6);
  if (['css','scss'].includes(ext)) return new THREE.SphereGeometry(s*0.75, 8, 6);
  if (ext === 'md') return new THREE.OctahedronGeometry(s*0.85, 0);
  if (ext === 'ejs') return new THREE.BoxGeometry(s*0.9, s*0.9, s*0.9);
  return new THREE.TetrahedronGeometry(s*0.8, 0);
}

function spawnFileNode(item, position, parentPath) {
  if (fileNodes.has(item.path)) return;
  const ext = item.isDir ? 'dir' : (item.name.split('.').pop().toLowerCase());
  const style = NODE_STYLES[ext] || NODE_STYLES.default;
  const mat = new THREE.MeshPhongMaterial({ color: style.color, emissive: style.emissive, emissiveIntensity: 1.4, shininess: 80 });
  const mesh = new THREE.Mesh(makeNodeGeometry(item, style), mat);
  mesh.position.copy(position);
  mesh.userData.filePath = item.path;
  mesh.userData.isDir = item.isDir;
  mesh.userData.fileName = item.name;
  scene.add(mesh);
  fileNodes.set(item.path, {
    item, mesh, mat,
    vel: new THREE.Vector3(), pos: position.clone(),
    grabbed: false, expanded: false, parentPath,
    baseEI: 1.4, style
  });
}

async function loadFileDir(dirPath, origin) {
  try {
    const r = await fetch('/stevenClawbert/live/ls?path=' + encodeURIComponent(dirPath));
    const data = await r.json();
    if (!data.success) return;
    const items = data.items.slice(0, 18);
    const count = items.length;
    items.forEach((item, i) => {
      if (fileNodes.has(item.path)) return;
      const angle = (i / count) * Math.PI * 2;
      const rad = 6.5 + Math.random() * 2.5;
      const pos = new THREE.Vector3(
        origin.x + Math.cos(angle) * rad,
        origin.y + (Math.random() - 0.5) * 5,
        origin.z + Math.sin(angle) * rad
      );
      spawnFileNode(item, pos, dirPath);
    });
  } catch (e) { console.warn('[fileNodes]', e); }
}

function updateFileInfo(node) {
  const panel = document.getElementById('file-info');
  if (!node) { panel.style.opacity = '0'; return; }
  panel.style.opacity = '1';
  const icon = node.item.isDir ? '📁' : '📄';
  document.getElementById('fi-name').textContent = icon + ' ' + node.item.name;
  document.getElementById('fi-path').textContent = node.item.path || '';
  document.getElementById('fi-hint').textContent = node.item.isDir
    ? 'TAP → expand · GRAB → drag · TWO-HAND SQUASH → collapse'
    : 'TAP → send to chat · GRAB → drag';
}

function setFilePinchIndicator(show) {
  const el = document.getElementById('fi-pinch');
  el.textContent = show ? '● PINCHED' : '';
  el.classList.toggle('show', show);
}

// Expand dir by spawning children around it
async function expandFileNode(node) {
  if (node.expanded || !node.item.isDir) return;
  node.expanded = true;
  node.mat.emissive.setHex(0x00aa55);
  node.mat.emissiveIntensity = 2.5;
  await loadFileDir(node.item.path, node.pos.clone());
  setTimeout(() => { node.mat.emissive.setHex(node.style.emissive); node.mat.emissiveIntensity = node.baseEI; }, 800);
}

// =================== PARTICLE PHYSICS ===================

function updateParticles() {
  const hp = handCursor.position;
  for (let i = 0; i < PC; i++) {
    const ix = i*3;
    let px = pPos[ix], py = pPos[ix+1], pz = pPos[ix+2];
    // Core pull
    const d0sq = px*px + py*py + pz*pz + 0.5;
    const f0 = 0.00010 / Math.sqrt(d0sq);
    pVel[ix] -= px * f0; pVel[ix+1] -= py * f0; pVel[ix+2] -= pz * f0;
    // Hand force
    if (state.handFound) {
      const dhx = hp.x - px, dhy = hp.y - py, dhz = hp.z - pz;
      const dhsq = dhx*dhx + dhy*dhy + dhz*dhz + 0.1;
      const dh = Math.sqrt(dhsq);
      if (state.attractMode) {
        const fa = 0.0005 * Math.min(1, 18/dhsq);
        pVel[ix] += dhx/dh*fa; pVel[ix+1] += dhy/dh*fa; pVel[ix+2] += dhz/dh*fa;
      } else if (state.repelMode || state.explosionForce > 0.01) {
        const fr = (0.0018 + state.explosionForce) * Math.min(1, 28/dhsq);
        pVel[ix] -= dhx/dh*fr; pVel[ix+1] -= dhy/dh*fr; pVel[ix+2] -= dhz/dh*fr;
      }
    }
    // Swirl
    pVel[ix]   += -pz * 0.000045;
    pVel[ix+2] +=  px * 0.000045;
    // Damp + integrate
    pVel[ix] *= 0.986; pVel[ix+1] *= 0.986; pVel[ix+2] *= 0.986;
    pPos[ix] += pVel[ix]; pPos[ix+1] += pVel[ix+1]; pPos[ix+2] += pVel[ix+2];
    // Color
    const sb = Math.min(1, state.smile * 1.4);
    let r = 0.85 + sb * 0.15, g = 0.12 + sb * 0.55, b = 0.07 + sb * 0.08;
    if (state.pulseIntensity > 0.01) {
      const pc = state.pulseColor;
      r = r*(1-state.pulseIntensity) + pc.r*state.pulseIntensity;
      g = g*(1-state.pulseIntensity) + pc.g*state.pulseIntensity;
      b = b*(1-state.pulseIntensity) + pc.b*state.pulseIntensity;
    }
    pCol[ix] = r; pCol[ix+1] = g; pCol[ix+2] = b;
  }
  pGeo.attributes.position.needsUpdate = true;
  pGeo.attributes.color.needsUpdate = true;
}

// =================== ANIMATION LOOP ===================

const clock = new THREE.Clock();

function animate() {
  requestAnimationFrame(animate);
  const t = clock.getElapsedTime();

  // Orb pulse
  orbMat.emissiveIntensity = 0.55 + state.smile * 0.9 + 0.4 * Math.sin(t * 2.2) + state.pulseIntensity * 1.6;
  orb.rotation.y += 0.003; orb.rotation.x += 0.001;
  wireOrb.rotation.y -= 0.002; wireOrb.rotation.z += 0.0012;
  glowMat.opacity = 0.04 + state.smile * 0.05 + state.pulseIntensity * 0.1;
  ring1.rotation.z += 0.001;
  pLight.intensity = 5 + state.smile * 4 + state.pulseIntensity * 8;
  pLight.color.lerpColors(new THREE.Color(0xe74c3c), state.pulseColor, state.pulseIntensity);

  // ---- GAZE CAMERA TILT (subtle parallax — no rotation) ----
  if (state.faceFound) {
    state.gazeCamX += (-state.gazeX * 1.8 - state.gazeCamX) * 0.03;
    state.gazeCamY += ( state.gazeY * 1.0  - state.gazeCamY) * 0.03;
    controls.target.x += (8 + state.gazeCamX - controls.target.x) * 0.06;
    controls.target.y += (state.gazeCamY - controls.target.y) * 0.06;
  } else {
    controls.target.x += (8 - controls.target.x) * 0.02;
    controls.target.y += (0 - controls.target.y) * 0.02;
  }

  // ---- FILE NODE PHYSICS + INTERACTION ----
  updateFileNodeInteraction();
  for (const [, fn] of fileNodes) {
    if (!fn.grabbed) {
      fn.vel.y -= 0.0008;
      fn.vel.multiplyScalar(0.94);
      fn.pos.add(fn.vel);
      // Gentle float: keep near original spawn height
      fn.pos.y += (fn.mesh.userData._spawnY - fn.pos.y || 0) * 0.001;
      fn.mesh.position.copy(fn.pos);
      fn.mesh.rotation.y += 0.006;
      fn.mesh.rotation.x += 0.002;
    }
  }

  handCursor.material.opacity = state.handFound ? (state.pinching ? 0.6 : 0.25) : 0;
  updateParticles();
  state.pulseIntensity *= 0.93;
  state.explosionForce *= 0.88;

  if (window._runDetect) window._runDetect(t);
  controls.update();
  renderer.render(scene, camera);
}

function updateFileNodeInteraction() {
  if (!state.handFound) {
    if (grabbedNode) releaseNode(false);
    if (hoveredNode) { resetNodeHover(hoveredNode); hoveredNode = null; updateFileInfo(null); }
    pinchCamLastPos = null;
    return;
  }
  const hp = handCursor.position;

  // Find nearest file node
  let nearest = null, nearestDist = GRAB_RADIUS;
  for (const [, fn] of fileNodes) {
    const d = hp.distanceTo(fn.mesh.position);
    if (d < nearestDist) { nearest = fn; nearestDist = d; }
  }

  if (nearest !== hoveredNode) {
    if (hoveredNode && !hoveredNode.grabbed) resetNodeHover(hoveredNode);
    hoveredNode = nearest;
    if (hoveredNode) {
      hoveredNode.mesh.scale.setScalar(1.55);
      hoveredNode.mat.emissiveIntensity = 2.8;
      updateFileInfo(hoveredNode);
    } else {
      updateFileInfo(null);
    }
  }

  if (state.pinching) {
    // Grab node immediately on pinch
    if (!grabbedNode && hoveredNode) {
      grabbedNode = hoveredNode;
      grabbedNode.grabbed = true;
      state.attractMode = false;
      state.repelMode = false;
      pinchCamLastPos = null;
    }
    if (grabbedNode) {
      grabbedNode.pos.lerp(hp, 0.65);
      grabbedNode.mesh.position.copy(grabbedNode.pos);
      setFilePinchIndicator(true);
      pinchCamLastPos = null;
    } else {
      // Pinch in empty space — pan camera
      setFilePinchIndicator(false);
      if (pinchCamLastPos) {
        const dx = hp.x - pinchCamLastPos.x;
        const dy = hp.y - pinchCamLastPos.y;
        controls.target.x -= dx * 0.65;
        controls.target.y -= dy * 0.65;
        camera.position.x -= dx * 0.65;
        camera.position.y -= dy * 0.65;
      }
      pinchCamLastPos = hp.clone();
    }
  } else {
    setFilePinchIndicator(false);
    pinchCamLastPos = null;
    if (grabbedNode) releaseNode(true);
  }
}

function resetNodeHover(fn) {
  fn.mesh.scale.setScalar(1);
  fn.mat.emissiveIntensity = fn.baseEI;
}

function releaseNode(tryExpand) {
  if (!grabbedNode) return;
  const fn = grabbedNode;
  fn.grabbed = false;
  grabbedNode = null;
  if (tryExpand && fn.item.isDir && !fn.expanded) {
    fn.mesh.userData._spawnY = fn.pos.y;
    expandFileNode(fn);
    state.pulseColor.setHex(0x00ddff);
    state.pulseIntensity = 0.7;
  }
  resetNodeHover(fn);
}

// TAP: quick pinch+release — expand dir or send file to chat
function tapFileNode(node) {
  if (node.item.isDir) {
    if (node.expanded) {
      collapseFileNode(node);
    } else {
      node.mesh.userData._spawnY = node.pos.y;
      expandFileNode(node);
      state.pulseColor.setHex(0x00ddff);
      state.pulseIntensity = 0.5;
    }
  } else {
    state.pulseColor.setHex(node.style.color ? new THREE.Color(node.style.color).getHex() : 0xffaa00);
    state.pulseIntensity = 0.5;
    const inp = document.getElementById('msg-input');
    if (inp) inp.value = 'Tell me about: ' + node.item.path;
  }
}

// TWO-HAND SQUASH: collapse expanded dir, removing its children
function collapseFileNode(node) {
  if (!node || !node.expanded) return;
  const pathPrefix = node.item.path + '/';
  for (const [key, fn] of fileNodes) {
    if (fn.parentPath === node.item.path ||
        (fn.item.path && fn.item.path.startsWith(pathPrefix) && fn.item.path !== node.item.path)) {
      if (hoveredNode === fn) { hoveredNode = null; updateFileInfo(null); }
      if (grabbedNode === fn) { grabbedNode = null; }
      scene.remove(fn.mesh);
      fn.mesh.geometry.dispose();
      fn.mat.dispose();
      fileNodes.delete(key);
    }
  }
  node.expanded = false;
  node.mat.emissive.setHex(node.style.emissive);
  node.mat.emissiveIntensity = node.baseEI;
  state.pulseColor.setHex(0xff4422);
  state.pulseIntensity = 0.35;
}

window.addEventListener('resize', () => {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
});

animate();
loadFileDir('/srv/madladslab', FILE_ORIGIN);

// =================== MEDIAPIPE + CAMERA ===================

const MP_VER = '0.10.14';
const MP_CDN = `https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@${MP_VER}`;
const MODEL_BASE = 'https://storage.googleapis.com/mediapipe-models';

let faceLandmarker = null, gestureRecognizer = null;
let mpReady = false, cameraActive = false, lastVideoTime = -1;

const video = document.getElementById('cam-video');
const ovCanvas = document.getElementById('cam-overlay');
const ovCtx = ovCanvas.getContext('2d');
const initStatus = document.getElementById('init-status');

async function initMediaPipe() {
  try {
    initStatus.textContent = 'loading mediapipe...';
    const { FaceLandmarker, GestureRecognizer, FilesetResolver } = await import(`${MP_CDN}/vision_bundle.mjs`);
    initStatus.textContent = 'loading wasm...';
    const wasm = await FilesetResolver.forVisionTasks(MP_CDN + '/wasm');
    initStatus.textContent = 'loading face model...';
    faceLandmarker = await FaceLandmarker.createFromOptions(wasm, {
      baseOptions: { modelAssetPath: MODEL_BASE + '/face_landmarker/face_landmarker/float16/1/face_landmarker.task', delegate: 'GPU' },
      outputFaceBlendshapes: true, runningMode: 'VIDEO', numFaces: 1
    });
    initStatus.textContent = 'loading gesture model...';
    gestureRecognizer = await GestureRecognizer.createFromOptions(wasm, {
      baseOptions: { modelAssetPath: MODEL_BASE + '/gesture_recognizer/gesture_recognizer/float16/1/gesture_recognizer.task', delegate: 'GPU' },
      runningMode: 'VIDEO', numHands: 2
    });
    mpReady = true;
    document.getElementById('dot-mp').classList.add('on');
    initStatus.textContent = 'ready — activate camera';
    document.getElementById('start-btn').disabled = false;
  } catch (err) {
    console.error('[MP]', err);
    initStatus.textContent = 'detection unavailable — camera still works';
    document.getElementById('dot-mp').classList.add('warn');
    document.getElementById('start-btn').disabled = false;
  }
}

async function startCamera() {
  try {
    const stream = await navigator.mediaDevices.getUserMedia({ video: { width: { ideal: 640 }, height: { ideal: 480 }, facingMode: 'user' } });
    video.srcObject = stream;
    await new Promise(r => video.addEventListener('loadeddata', r, { once: true }));
    cameraActive = true;
    document.getElementById('cam-pip').classList.add('visible');
    document.getElementById('cam-status').textContent = '● LIVE';
    document.getElementById('cam-status').classList.add('active');
    resizeOverlay();
  } catch (err) {
    console.error('[cam]', err);
    document.getElementById('cam-status').textContent = '● DENIED';
  }
}

function resizeOverlay() {
  ovCanvas.width = window.innerWidth;
  ovCanvas.height = window.innerHeight;
}

// ---- Iris gaze estimation ----
const L_IRIS = 468, R_IRIS = 473;
const L_EYE_IN = 133, L_EYE_OUT = 33, R_EYE_IN = 362, R_EYE_OUT = 263;

function estimateGaze(lms) {
  if (!lms || lms.length < 474) return;
  const li = lms[L_IRIS], ri = lms[R_IRIS];
  const lEl = lms[L_EYE_IN], lEr = lms[L_EYE_OUT];
  const rEl = lms[R_EYE_IN], rEr = lms[R_EYE_OUT];
  const lGx = (li.x - lEl.x) / (Math.abs(lEr.x - lEl.x) + 0.001) - 0.5;
  const rGx = (ri.x - rEl.x) / (Math.abs(rEr.x - rEl.x) + 0.001) - 0.5;
  const rawX = (lGx + rGx) / 2;
  const rawY = ((lEl.y + lEr.y) / 2 - li.y) * 5;
  state.gazeX += (Math.max(-1, Math.min(1, rawX * 3)) - state.gazeX) * 0.12;
  state.gazeY += (Math.max(-1, Math.min(1, rawY)) - state.gazeY) * 0.12;
  const gx = state.gazeX, gy = state.gazeY;
  document.getElementById('dl-gaze').textContent =
    (gx > 0.2 ? 'R' : gx < -0.2 ? 'L' : 'C') + '/' + (gy > 0.15 ? 'U' : gy < -0.15 ? 'D' : 'M') +
    ' (' + gx.toFixed(2) + ',' + gy.toFixed(2) + ')';
}

function extractSmile(bs) {
  if (!bs || !bs[0]) return 0;
  const cats = bs[0].categories;
  const l = cats.find(c => c.categoryName === 'mouthSmileLeft')?.score || 0;
  const r = cats.find(c => c.categoryName === 'mouthSmileRight')?.score || 0;
  return (l + r) / 2;
}

// ---- Overlay drawing ----
function drawOverlay(faceLms, handLms) {
  ovCtx.clearRect(0, 0, ovCanvas.width, ovCanvas.height);
  const w = ovCanvas.width, h = ovCanvas.height;
  if (faceLms) {
    ovCtx.fillStyle = 'rgba(231,76,60,0.55)';
    for (let i = 0; i < faceLms.length; i += 7) {
      ovCtx.beginPath(); ovCtx.arc(faceLms[i].x*w, faceLms[i].y*h, 0.7, 0, Math.PI*2); ovCtx.fill();
    }
    [faceLms[L_IRIS], faceLms[R_IRIS]].forEach(iris => {
      if (!iris) return;
      ovCtx.strokeStyle = 'rgba(0,221,255,0.9)'; ovCtx.lineWidth = 1;
      ovCtx.beginPath(); ovCtx.arc(iris.x*w, iris.y*h, 4.5, 0, Math.PI*2); ovCtx.stroke();
    });
  }
  if (handLms) {
    const CONN = [[0,1],[1,2],[2,3],[3,4],[0,5],[5,6],[6,7],[7,8],[0,9],[9,10],[10,11],[11,12],[0,13],[13,14],[14,15],[15,16],[0,17],[17,18],[18,19],[19,20],[5,9],[9,13],[13,17]];
    for (const hand of handLms) {
      ovCtx.strokeStyle = 'rgba(255,170,0,0.8)'; ovCtx.lineWidth = 1.5;
      for (const [a,b] of CONN) { ovCtx.beginPath(); ovCtx.moveTo(hand[a].x*w, hand[a].y*h); ovCtx.lineTo(hand[b].x*w, hand[b].y*h); ovCtx.stroke(); }
      ovCtx.fillStyle = 'rgba(255,170,0,0.9)';
      for (const lm of hand) { ovCtx.beginPath(); ovCtx.arc(lm.x*w, lm.y*h, 2, 0, Math.PI*2); ovCtx.fill(); }
      // Highlight thumb tip + index tip
      ovCtx.fillStyle = '#fff';
      [hand[4], hand[8]].forEach(pt => { ovCtx.beginPath(); ovCtx.arc(pt.x*w, pt.y*h, 3.5, 0, Math.PI*2); ovCtx.fill(); });
      // Pinch line
      if (state.pinching) {
        ovCtx.strokeStyle = 'rgba(0,255,136,0.9)'; ovCtx.lineWidth = 2;
        ovCtx.beginPath(); ovCtx.moveTo(hand[4].x*w, hand[4].y*h); ovCtx.lineTo(hand[8].x*w, hand[8].y*h); ovCtx.stroke();
      }
    }
  }
}

// ---- Hand → 3D world ----
function updateHandCursor(handLms) {
  if (!handLms || !handLms.length) { state.handFound = false; return; }
  state.handFound = true;
  const tip = handLms[0][8]; // index tip
  const wx = (0.5 - tip.x) * 70;
  const wy = (0.5 - tip.y) * 54;
  handCursor.position.x += (wx - handCursor.position.x) * 0.44;
  handCursor.position.y += (wy - handCursor.position.y) * 0.44;
  handCursor.position.z = 0;
}

// ---- Pinch detection (thumb tip [4] ↔ index tip [8]) ----
function detectPinch(handLms) {
  if (!handLms || !handLms.length) return false;
  const h = handLms[0];
  const dx = h[4].x - h[8].x, dy = h[4].y - h[8].y;
  return Math.sqrt(dx*dx + dy*dy) < 0.055;
}

// ---- Gesture effects ----
const GESTURE_META = {
  'Thumb_Up':    { emoji: '👍', color: 0x00ddff },
  'Open_Palm':   { emoji: '✋', color: 0xffffff },
  'Victory':     { emoji: '✌️', color: 0x00ff88 },
  'Closed_Fist': { emoji: '✊', color: 0xff4422 },
  'Pointing_Up': { emoji: '☝️', color: 0xffaa00 },
  'Thumb_Down':  { emoji: '👎', color: 0xff6622 },
};
let lastGestureFlash = 0;

function flashGesture(name) {
  const m = GESTURE_META[name]; if (!m) return;
  const now = Date.now(); if (now - lastGestureFlash < 2500) return;
  lastGestureFlash = now;
  state.pulseColor.setHex(m.color); state.pulseIntensity = 1.0;
  if (name === 'Open_Palm') { state.attractMode = true; setTimeout(() => { state.attractMode = false; }, 1800); }
  if (name === 'Closed_Fist') { state.repelMode = true; state.explosionForce = 0.007; setTimeout(() => { state.repelMode = false; }, 1800); }
  document.getElementById('ge').textContent = m.emoji;
  document.getElementById('gl-sub').textContent = name.toUpperCase();
  const f = document.getElementById('gesture-flash');
  f.classList.add('show'); f.classList.remove('fade');
  setTimeout(() => { f.classList.add('fade'); f.classList.remove('show'); }, 120);
  setTimeout(() => f.classList.remove('fade'), 900);
}

// ---- Detection loop (called from Three.js animate) ----
let detectSkip = 0;
window._runDetect = function() {
  if (!mpReady || !cameraActive || video.readyState < 2 || video.currentTime === lastVideoTime) return;
  lastVideoTime = video.currentTime;
  if (++detectSkip % 2 !== 0) return;
  const now = performance.now();

  // Face
  try {
    const fr = faceLandmarker.detectForVideo(video, now);
    if (fr.faceLandmarks?.[0]) {
      state.faceFound = true;
      estimateGaze(fr.faceLandmarks[0]);
      state.smile += (extractSmile(fr.faceBlendshapes) - state.smile) * 0.14;
      const sp = Math.round(state.smile * 100);
      document.getElementById('dl-smile').textContent = sp + '%';
      document.getElementById('bar-smile').style.width = sp + 'px';
      document.getElementById('bar-smile').style.background = sp > 50 ? 'var(--green)' : sp > 25 ? 'var(--gold)' : 'var(--red)';
      document.getElementById('dot-face').classList.add('on');
      document.getElementById('lbl-face').textContent = 'face ✓';
      const ctx = []; if (sp > 40) ctx.push('smiling'); if (state.gazeX > 0.3) ctx.push('gaze→right'); else if (state.gazeX < -0.3) ctx.push('gaze→left');
      window._ctx = ctx.join(', ') || 'neutral'; document.getElementById('ctx-live').textContent = window._ctx;
      drawOverlay(fr.faceLandmarks[0], null);
    } else {
      state.faceFound = false; state.smile *= 0.96;
      document.getElementById('dot-face').classList.remove('on');
      document.getElementById('lbl-face').textContent = 'no face';
    }
  } catch(e) {}

  // Hands
  try {
    const gr = gestureRecognizer.recognizeForVideo(video, now);
    if (gr.gestures?.[0]) {
      state.handFound = true;
      const top = gr.gestures[0][0];
      const prevPinch = state.pinching;
      state.pinching = detectPinch(gr.landmarks);
      document.getElementById('dl-pinch').textContent = state.pinching ? '● PINCHING' : '—';
      document.getElementById('dl-pinch').classList.toggle('hi', state.pinching);

      if (top.score > 0.65 && top.categoryName !== 'None') {
        state.gesture = top.categoryName;
        document.getElementById('dl-gesture').textContent = (GESTURE_META[top.categoryName]?.emoji || '') + ' ' + top.categoryName;
        document.getElementById('dl-gesture').classList.add('hi');
        flashGesture(top.categoryName);
      } else {
        state.gesture = null;
        document.getElementById('dl-gesture').textContent = '—';
        document.getElementById('dl-gesture').classList.remove('hi');
        if (!state.pinching) { state.attractMode = false; state.repelMode = false; }
      }

      updateHandCursor(gr.landmarks);

      // ---- Two-hand squash: collapse hovered dir ----
      if (gr.landmarks.length >= 2) {
        const w0 = gr.landmarks[0][0], w1 = gr.landmarks[1][0];
        const twoD = Math.hypot(w0.x - w1.x, w0.y - w1.y);
        if (state.twoHandPrevDist !== null) {
          const squash = state.twoHandPrevDist - twoD;
          if (squash > 0.09 && hoveredNode?.expanded) {
            collapseFileNode(hoveredNode);
          }
        }
        state.twoHandPrevDist = twoD;
      } else {
        state.twoHandPrevDist = null;
      }

      document.getElementById('dot-hand').classList.add('on');
      document.getElementById('lbl-hand').textContent = gr.landmarks.length >= 2 ? 'hands ✓✓' : 'hand ✓';
      drawOverlay(null, gr.landmarks);
    } else {
      state.handFound = false; state.pinching = false; state.gesture = null;
      state.attractMode = false; state.repelMode = false;
      state.twoHandPrevDist = null;
      document.getElementById('dot-hand').classList.remove('on');
      document.getElementById('lbl-hand').textContent = 'no hand';
      document.getElementById('dl-gesture').textContent = '—'; document.getElementById('dl-gesture').classList.remove('hi');
      document.getElementById('dl-pinch').textContent = '—'; document.getElementById('dl-pinch').classList.remove('hi');
      drawOverlay(null, null);
    }
  } catch(e) {}
};

// =================== LIVE WEATHER (Open-Meteo, no key) ===================

const WMO = { 0:['Clear sky','☀️'],1:['Mainly clear','🌤️'],2:['Partly cloudy','⛅'],3:['Overcast','☁️'],45:['Foggy','🌫️'],48:['Icy fog','🌫️'],51:['Light drizzle','🌦️'],53:['Drizzle','🌦️'],55:['Heavy drizzle','🌧️'],61:['Light rain','🌧️'],63:['Rain','🌧️'],65:['Heavy rain','🌧️'],71:['Light snow','🌨️'],73:['Snow','❄️'],75:['Heavy snow','❄️'],80:['Rain showers','🌦️'],81:['Rain showers','🌧️'],82:['Violent showers','⛈️'],95:['Thunderstorm','⛈️'],96:['Thunderstorm+hail','⛈️'],99:['Thunderstorm+hail','⛈️'] };
const DIRS = ['N','NE','E','SE','S','SW','W','NW'];
const bearing = deg => DIRS[Math.round(deg / 45) % 8];

async function fetchWeather() {
  try {
    let lat, lon, loc = '';
    try {
      const p = await new Promise((res, rej) => navigator.geolocation.getCurrentPosition(res, rej, { timeout: 6000 }));
      lat = p.coords.latitude.toFixed(4); lon = p.coords.longitude.toFixed(4);
    } catch {
      const ip = await fetch('https://ipapi.co/json/').then(r => r.json()).catch(() => null);
      if (!ip) throw new Error('no location');
      lat = ip.latitude; lon = ip.longitude; loc = (ip.city || '') + (ip.region_code ? ', ' + ip.region_code : '');
    }
    const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,apparent_temperature,relative_humidity_2m,wind_speed_10m,wind_direction_10m,weather_code&temperature_unit=fahrenheit&wind_speed_unit=mph&timezone=auto`;
    const d = await fetch(url).then(r => r.json());
    const c = d.current;
    const [desc, emoji] = WMO[c.weather_code] || ['Unknown', '🌡️'];
    document.getElementById('wx-emoji').textContent = emoji;
    document.getElementById('wx-temp').textContent = Math.round(c.temperature_2m) + '°F';
    document.getElementById('wx-feels').textContent = 'feels ' + Math.round(c.apparent_temperature) + '°';
    document.getElementById('wx-desc').textContent = desc.toUpperCase();
    document.getElementById('wx-details').textContent = `H:${c.relative_humidity_2m}% · ${Math.round(c.wind_speed_10m)}mph ${bearing(c.wind_direction_10m)}`;
    document.getElementById('wx-location').textContent = loc;
    // Update orb color tint based on weather
    if (c.weather_code === 0 || c.weather_code === 1) {
      state.pulseColor.setHex(0xffaa44); state.pulseIntensity = 0.3;
    } else if (c.weather_code >= 95) {
      state.pulseColor.setHex(0xaaaaff); state.pulseIntensity = 0.4;
    }
  } catch (e) {
    document.getElementById('wx-desc').textContent = 'UNAVAILABLE';
  }
}

// =================== LIVE CLOCK ===================

function startClock() {
  const el = document.getElementById('hud-clock');
  const tick = () => { el.textContent = new Date().toLocaleTimeString('en-US', { hour12: false }); };
  tick(); setInterval(tick, 1000);
}

// =================== CHAT ===================

const chatFeed = document.getElementById('chat-feed');
const chatInput = document.getElementById('chat-input');
let chatBusy = false;

function ts() { return new Date().toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' }); }

function appendMsg(role, text, ctxTag) {
  const d = document.createElement('div');
  d.className = 'msg ' + role;
  if (ctxTag) { const t = document.createElement('span'); t.className = 'ctx-tag'; t.textContent = ctxTag; d.appendChild(t); d.appendChild(document.createElement('br')); }
  d.appendChild(document.createTextNode(text));
  const s = document.createElement('span'); s.className = 'ts'; s.textContent = ts(); d.appendChild(s);
  chatFeed.appendChild(d);
  chatFeed.scrollTop = chatFeed.scrollHeight;
  return d;
}

function captureFrame() {
  if (!cameraActive || video.readyState < 2) return null;
  const c = document.createElement('canvas');
  c.width = video.videoWidth || 320; c.height = video.videoHeight || 240;
  c.getContext('2d').drawImage(video, 0, 0);
  return c.toDataURL('image/jpeg', 0.75);
}

async function sendToSteven({ msg, withImage, ctx }) {
  if (chatBusy) return;
  chatBusy = true;
  document.getElementById('btn-capture').disabled = true;
  document.getElementById('btn-text').disabled = true;
  appendMsg('user', msg || '(camera capture)', ctx || null);
  const typing = appendMsg('assistant', '...', null);
  try {
    const payload = { userMessage: msg };
    if (withImage) payload.imageBase64 = captureFrame();
    if (ctx) payload.gestureContext = ctx;
    const r = await fetch('/stevenClawbert/live/vision', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
    const data = await r.json();
    typing.remove();
    appendMsg('assistant', data.success ? data.response : '⚠ ' + (data.error || 'error'));
    state.pulseIntensity = 0.7; state.pulseColor.setHex(0xe74c3c);
  } catch(e) { typing.remove(); appendMsg('assistant', '⚠ network error'); }
  finally { chatBusy = false; document.getElementById('btn-capture').disabled = false; document.getElementById('btn-text').disabled = false; chatInput.value = ''; }
}

// =================== UI EVENTS ===================

document.getElementById('start-btn').addEventListener('click', async () => {
  document.getElementById('start-btn').disabled = true;
  initStatus.textContent = 'requesting camera...';
  await startCamera();
  document.getElementById('start-overlay').classList.add('hidden');
  document.getElementById('chat-panel').classList.add('open');
  appendMsg('assistant', mpReady
    ? "Camera active. Gaze tilts the view, pinch+drag pans, wrist dial zooms. Tap file nodes to expand."
    : "Camera active. MediaPipe still loading — gestures will come online shortly.");
});

document.getElementById('chat-toggle').addEventListener('click', () => document.getElementById('chat-panel').classList.toggle('open'));
document.getElementById('chat-close').addEventListener('click', () => document.getElementById('chat-panel').classList.remove('open'));

document.getElementById('btn-capture').addEventListener('click', () => {
  const msg = chatInput.value.trim() || 'What do you see?';
  const ctx = [state.gesture ? (GESTURE_META[state.gesture]?.emoji + ' ' + state.gesture) : '', window._ctx || ''].filter(Boolean).join(' · ');
  if (!document.getElementById('chat-panel').classList.contains('open')) document.getElementById('chat-panel').classList.add('open');
  sendToSteven({ msg, withImage: true, ctx });
});

document.getElementById('btn-text').addEventListener('click', () => {
  const msg = chatInput.value.trim(); if (!msg) return;
  sendToSteven({ msg, withImage: false, ctx: window._ctx });
});

chatInput.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); document.getElementById('btn-capture').click(); } });


// =================== BOOT ===================
startClock();
fetchWeather();
setInterval(fetchWeather, 5 * 60 * 1000); // update every 5 min
initMediaPipe();
</script>
</body>
</html>
