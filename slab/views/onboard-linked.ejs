<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Account Linked — <%= brand?.name || 'Home' %></title>
  <%
    const _FM = { 'Cormorant Garamond':'Cormorant+Garamond:wght@300;400;600','Playfair Display':'Playfair+Display:wght@400;600;700','Lora':'Lora:wght@400;600;700','Merriweather':'Merriweather:wght@300;400;700','Libre Baskerville':'Libre+Baskerville:wght@400;700','Jost':'Jost:wght@300;400;500;600','Inter':'Inter:wght@300;400;500;600','Poppins':'Poppins:wght@300;400;500;600','Raleway':'Raleway:wght@300;400;500;600','Nunito':'Nunito:wght@300;400;500;600','DM Sans':'DM+Sans:wght@300;400;500;600' };
    const _hF = _FM[design.font_heading] || _FM['Cormorant Garamond'];
    const _bF = _FM[design.font_body] || _FM['Jost'];
    const _fp = _hF === _bF ? _hF : _hF + '&family=' + _bF;
  %>
  <link href="https://fonts.googleapis.com/css2?family=<%= _fp %>&display=swap" rel="stylesheet">
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  :root {
    --navy: <%= design.color_primary || '#1C2B4A' %>;
    --navy-deep: <%= design.color_primary_deep || '#0F1B30' %>;
    --gold: <%= design.color_accent || '#C9A848' %>;
    --ivory: <%= design.color_bg || '#F5F3EF' %>;
    --slate: #6B7380; --dark: <%= design.color_primary_deep || '#0F1B30' %>; --white: #FDFCFA;
  }
  body { font-family: '<%= design.font_body || 'Jost' %>', sans-serif; background: var(--ivory); color: var(--on-surface); min-height: 100vh; display: flex; flex-direction: column; }
  .ob-header { background: var(--navy-deep); padding: 20px 32px; }
  .ob-brand { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: var(--white); text-decoration: none; }
  .ob-brand-sub { font-size: 0.55rem; font-weight: 600; letter-spacing: .22em; text-transform: uppercase; color: var(--gold); margin-top: 2px; }
  .ob-center { flex: 1; display: flex; align-items: center; justify-content: center; padding: 40px 20px; }
  .ob-card {
    background: var(--surface); border-radius: 6px; padding: 40px 36px; text-align: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08); max-width: 460px; width: 100%;
  }
  .ob-card .check { font-size: 2.4rem; color: #15803D; margin-bottom: 12px; }
  .ob-card h1 { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 400; color: var(--navy); margin-bottom: 8px; }
  .ob-card p { font-size: 0.88rem; color: var(--slate); line-height: 1.6; margin-bottom: 20px; }
  .ob-btn { display: inline-block; padding: 12px 28px; background: var(--gold); color: var(--navy-deep); border-radius: 4px; text-decoration: none; font-weight: 600; font-size: 0.85rem; transition: background .2s; }
  .ob-btn:hover { background: <%= design.color_accent_light || '#E8D08A' %>; }
  .ob-footer { text-align: center; padding: 24px; font-size: 0.75rem; color: var(--slate); }
  .ob-footer a { color: var(--gold); text-decoration: none; }
</style>
</head>
<body>
<%- include("partials/preview-banner") %>
<div class="ob-header">
  <div>
    <a href="/" class="ob-brand"><%- brand?.name || '' %></a>
    <div class="ob-brand-sub">Client Portal</div>
  </div>
</div>
<div class="ob-center">
  <div class="ob-card">
    <div class="check">&#10003;</div>
    <h1>Account linked!</h1>
    <p>Your Google account is now connected. You'll be able to access your client portal here to view invoices, share files, and collaborate with our team.</p>
    <a href="/" class="ob-btn">Back to <%= brand?.name || 'Home' %></a>
  </div>
</div>
<div class="ob-footer">&copy; <%= new Date().getFullYear() %> <a href="/"><%- brand?.name || '' %></a> &mdash; <%= brand?.location || '' %></div>
</body>
</html>
