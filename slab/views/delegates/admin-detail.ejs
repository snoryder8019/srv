<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Delegate Detail — Superadmin — sLab</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#0a0a0a; color:#e5e5e5; min-height:100vh; }
    .topbar { background:#141414; border-bottom:1px solid #262626; padding:14px 24px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:8px; }
    .topbar-left { display:flex; align-items:center; gap:16px; }
    .logo { font-size:20px; font-weight:600; color:#fff; } .logo span { color:#c9a848; }
    .badge { font-size:10px; text-transform:uppercase; letter-spacing:1.2px; color:#c9a848; background:#262626; padding:3px 8px; border-radius:4px; }
    .topbar-right { display:flex; align-items:center; gap:16px; font-size:13px; }
    .topbar-right a { color:#a3a3a3; text-decoration:none; font-size:12px; } .topbar-right a:hover { color:#c9a848; }
    .container { max-width:900px; margin:0 auto; padding:24px; }
    .back { display:inline-block; color:#a3a3a3; text-decoration:none; font-size:12px; margin-bottom:16px; } .back:hover { color:#c9a848; }
    h1 { font-size:22px; font-weight:600; color:#fff; margin-bottom:4px; }
    .meta-line { font-size:13px; color:#737373; margin-bottom:20px; }
    .meta-line a { color:#c9a848; text-decoration:none; }
    .status { display:inline-block; padding:2px 8px; border-radius:10px; font-size:11px; font-weight:500; }
    .status-active { background:#14532d; color:#86efac; }
    .status-pending { background:#422006; color:#fdba74; }
    .status-suspended { background:#451a1a; color:#fca5a5; }
    .card { background:#141414; border:1px solid #262626; border-radius:8px; padding:24px; margin-bottom:20px; }
    .card-title { font-size:14px; font-weight:600; color:#fff; margin-bottom:16px; padding-bottom:10px; border-bottom:1px solid #262626; }
    .info-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .info-item label { font-size:10px; text-transform:uppercase; letter-spacing:0.8px; color:#525252; display:block; margin-bottom:2px; }
    .info-item span { font-size:13px; color:#e5e5e5; }
    .actions-row { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:20px; }
    .btn { padding:8px 16px; border-radius:4px; font-family:'Inter',sans-serif; font-size:12px; font-weight:600; cursor:pointer; border:none; }
    .btn-green { background:#14532d; color:#86efac; } .btn-green:hover { background:#166534; }
    .btn-amber { background:#422006; color:#fdba74; } .btn-amber:hover { background:#4a2506; }
    .btn-red { background:#451a1a; color:#fca5a5; } .btn-red:hover { background:#502020; }
    .btn-gold { background:#c9a848; color:#0a0a0a; } .btn-gold:hover { background:#d4b85c; }
    .btn-sm { padding:5px 12px; font-size:11px; border-radius:4px; border:1px solid #333; background:transparent; color:#a3a3a3; cursor:pointer; }
    .btn-sm:hover { border-color:#c9a848; color:#c9a848; }
    h2 { font-size:16px; font-weight:500; margin-bottom:16px; }
    .section { margin-bottom:28px; }
    table { width:100%; border-collapse:collapse; background:#141414; border-radius:8px; overflow:hidden; border:1px solid #262626; }
    th { text-align:left; padding:10px 14px; font-size:11px; text-transform:uppercase; letter-spacing:0.8px; color:#737373; background:#1a1a1a; border-bottom:1px solid #262626; }
    td { padding:10px 14px; font-size:13px; border-bottom:1px solid #1f1f1f; }
    tr:last-child td { border-bottom:0; }
    .empty { color:#525252; font-size:13px; padding:16px; text-align:center; }
    .attach-form { display:flex; gap:8px; align-items:center; margin-bottom:16px; flex-wrap:wrap; }
    .attach-form select { background:#1a1a1a; border:1px solid #333; color:#e5e5e5; padding:8px 10px; border-radius:4px; font-family:'Inter',sans-serif; font-size:13px; min-width:250px; }
    .payout-form { display:flex; gap:8px; align-items:flex-end; flex-wrap:wrap; }
    .payout-form .form-group { display:flex; flex-direction:column; gap:4px; }
    .payout-form label { font-size:10px; text-transform:uppercase; letter-spacing:0.8px; color:#525252; }
    .payout-form input, .payout-form select { background:#1a1a1a; border:1px solid #333; color:#e5e5e5; padding:8px 10px; border-radius:4px; font-family:'Inter',sans-serif; font-size:13px; }
    .payout-form input:focus, .payout-form select:focus { border-color:#c9a848; outline:none; }
    @media (max-width:600px) { .info-grid { grid-template-columns:1fr; } .container { padding:16px; } .payout-form { flex-direction:column; align-items:stretch; } }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-left">
      <div class="logo"><span>s</span>Lab</div>
      <span class="badge">Superadmin</span>
    </div>
    <div class="topbar-right">
      <a href="/superadmin">Dashboard</a>
      <a href="/delegates/admin">Delegates</a>
      <a href="/superadmin/logout">Logout</a>
    </div>
  </div>

  <div class="container">
    <a href="/delegates/admin" class="back">&larr; Back to Delegates</a>

    <h1><%= delegate.firstName %> <%= delegate.lastName %></h1>
    <div class="meta-line">
      <a href="mailto:<%= delegate.email %>"><%= delegate.email %></a>
      &nbsp;&middot;&nbsp; <span class="status status-<%= delegate.status %>"><%= delegate.status %></span>
      &nbsp;&middot;&nbsp; Ref: <span style="color:#c9a848;font-family:monospace;"><%= delegate.refCode %></span>
      &nbsp;&middot;&nbsp; Joined <%= new Date(delegate.createdAt).toLocaleDateString() %>
    </div>

    <!-- Status actions -->
    <div class="actions-row">
      <% if (delegate.status !== 'active') { %>
        <form method="POST" action="/delegates/admin/<%= delegate._id %>/status"><input type="hidden" name="status" value="active"><button class="btn btn-green">Activate</button></form>
      <% } %>
      <% if (delegate.status !== 'pending') { %>
        <form method="POST" action="/delegates/admin/<%= delegate._id %>/status"><input type="hidden" name="status" value="pending"><button class="btn btn-amber">Set Pending</button></form>
      <% } %>
      <% if (delegate.status !== 'suspended') { %>
        <form method="POST" action="/delegates/admin/<%= delegate._id %>/status"><input type="hidden" name="status" value="suspended"><button class="btn btn-red" onclick="return confirm('Suspend this delegate?')">Suspend</button></form>
      <% } %>
    </div>

    <!-- Delegate info card -->
    <div class="card">
      <div class="card-title">Contact Info</div>
      <div class="info-grid">
        <div class="info-item"><label>Phone</label><span><%= delegate.phone || '—' %></span></div>
        <div class="info-item"><label>Address</label><span><%= delegate.address || '—' %></span></div>
        <div class="info-item"><label>City / State</label><span><%= delegate.city || '—' %>, <%= delegate.state || '—' %> <%= delegate.zip || '' %></span></div>
        <div class="info-item"><label>Tax Info Provided</label><span style="color:<%= delegate.taxInfoProvided ? '#4ade80' : '#f87171' %>;"><%= delegate.taxInfoProvided ? 'Yes' : 'No' %></span></div>
        <div class="info-item"><label>Total Earned</label><span style="color:#c9a848;">$<%= (delegate.totalEarned || 0).toFixed(2) %></span></div>
        <div class="info-item"><label>Total Paid</label><span style="color:#4ade80;">$<%= (delegate.totalPaid || 0).toFixed(2) %></span></div>
      </div>
    </div>

    <!-- Attach tenant -->
    <div class="section">
      <h2>Assigned Accounts</h2>
      <% if (availableTenants.length) { %>
      <form method="POST" action="/delegates/admin/<%= delegate._id %>/attach" class="attach-form">
        <select name="tenantId">
          <% for (const t of availableTenants) { %>
          <option value="<%= t._id %>"><%= t.brand?.name || t.domain %> (<%= t.domain %>)</option>
          <% } %>
        </select>
        <button type="submit" class="btn btn-gold">Attach Tenant</button>
      </form>
      <% } %>

      <% if (tenantDetails.length) { %>
      <table>
        <thead><tr><th>Domain</th><th>Brand</th><th>Status</th><th>Attached</th><th>Year</th><th>Rate</th><th></th></tr></thead>
        <tbody>
          <% for (const t of tenantDetails) { %>
          <tr>
            <td><%= t.tenantDomain %></td>
            <td><%= t.brandName %></td>
            <td><span class="status status-<%= t.tenantStatus %>"><%= t.tenantStatus %></span></td>
            <td><%= new Date(t.attachedAt).toLocaleDateString() %></td>
            <td>Yr <%= t.year %></td>
            <td style="color:#c9a848;font-weight:600;">$<%= t.rate.toFixed(2) %>/mo</td>
            <td>
              <form method="POST" action="/delegates/admin/<%= delegate._id %>/detach" style="display:inline;">
                <input type="hidden" name="tenantId" value="<%= t.tenantId %>">
                <button type="submit" class="btn-sm" onclick="return confirm('Detach this tenant?')">Detach</button>
              </form>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
      <% } else { %>
        <div class="empty">No accounts attached yet.</div>
      <% } %>
    </div>

    <!-- Log payout -->
    <div class="section">
      <h2>Log Payout</h2>
      <form method="POST" action="/delegates/admin/<%= delegate._id %>/payout" class="payout-form">
        <div class="form-group">
          <label>Amount ($)</label>
          <input type="number" name="amount" step="0.01" min="0.01" required placeholder="0.00" style="width:120px;">
        </div>
        <div class="form-group">
          <label>Method</label>
          <select name="method">
            <option value="manual">Manual / Check</option>
            <option value="paypal">PayPal</option>
            <option value="venmo">Venmo</option>
            <option value="zelle">Zelle</option>
            <option value="wire">Wire Transfer</option>
          </select>
        </div>
        <div class="form-group">
          <label>Note (optional)</label>
          <input type="text" name="note" placeholder="e.g. March 2026 commission" style="width:240px;">
        </div>
        <button type="submit" class="btn btn-gold">Log Payout</button>
      </form>
    </div>

    <!-- Payout history -->
    <div class="section">
      <h2>Payout History</h2>
      <% if (payouts.length) { %>
      <table>
        <thead><tr><th>Date</th><th>Period</th><th>Amount</th><th>Method</th><th>Note</th><th>By</th></tr></thead>
        <tbody>
          <% for (const p of payouts) { %>
          <tr>
            <td><%= new Date(p.createdAt).toLocaleDateString() %></td>
            <td><%= p.period %></td>
            <td style="color:#4ade80;font-weight:600;">$<%= p.amount.toFixed(2) %></td>
            <td><%= p.method %></td>
            <td style="color:#737373;"><%= p.note || '—' %></td>
            <td style="color:#737373;"><%= p.createdBy %></td>
          </tr>
          <% } %>
        </tbody>
      </table>
      <% } else { %>
        <div class="empty">No payouts recorded yet.</div>
      <% } %>
    </div>
  </div>
</body>
</html>
