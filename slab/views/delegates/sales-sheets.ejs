<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sales Sheets — Delegate Panel — sLab</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#0a0a0a; color:#e5e5e5; min-height:100vh; }
    .topbar { background:#141414; border-bottom:1px solid #262626; padding:14px 24px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:8px; }
    .topbar-left { display:flex; align-items:center; gap:16px; }
    .logo { font-size:20px; font-weight:600; color:#fff; } .logo span { color:#c9a848; }
    .badge { font-size:10px; text-transform:uppercase; letter-spacing:1.2px; color:#c9a848; background:#262626; padding:3px 8px; border-radius:4px; }
    .topbar-right { display:flex; align-items:center; gap:16px; font-size:13px; color:#737373; }
    .topbar-right a { color:#a3a3a3; text-decoration:none; font-size:12px; } .topbar-right a:hover { color:#c9a848; }
    .container { max-width:960px; margin:0 auto; padding:24px; }
    h1 { font-size:22px; font-weight:600; color:#fff; margin-bottom:4px; }
    .subtitle { font-size:13px; color:#737373; margin-bottom:24px; }
    .promo-banner { background:linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); border:1px solid #c9a848; border-radius:8px; padding:20px 24px; margin-bottom:28px; display:flex; align-items:center; gap:16px; flex-wrap:wrap; }
    .promo-icon { font-size:28px; }
    .promo-text h3 { font-size:14px; font-weight:600; color:#c9a848; margin-bottom:4px; }
    .promo-text p { font-size:13px; color:#a3a3a3; line-height:1.5; }
    .ref-box { background:#0a0a0a; border:1px solid #333; border-radius:6px; padding:10px 16px; margin-left:auto; text-align:center; }
    .ref-box label { font-size:10px; text-transform:uppercase; letter-spacing:0.8px; color:#525252; display:block; margin-bottom:4px; }
    .ref-box code { font-size:16px; font-weight:700; color:#c9a848; }
    .ref-url { font-size:11px; color:#525252; margin-top:6px; word-break:break-all; }
    .ref-url a { color:#737373; }
    .brands-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:16px; margin-bottom:28px; }
    .brand-card { background:#141414; border:1px solid #262626; border-radius:8px; padding:24px; transition:border-color 0.2s; cursor:pointer; text-decoration:none; color:inherit; display:block; }
    .brand-card:hover { border-color:#c9a848; }
    .brand-name { font-size:18px; font-weight:600; color:#fff; margin-bottom:4px; }
    .brand-domain { font-size:12px; color:#737373; margin-bottom:12px; }
    .brand-tagline { font-size:13px; color:#a3a3a3; line-height:1.5; margin-bottom:16px; min-height:40px; }
    .brand-stats { display:flex; gap:16px; padding-top:12px; border-top:1px solid #262626; }
    .brand-stat { text-align:center; flex:1; }
    .brand-stat-value { font-size:20px; font-weight:700; color:#fff; }
    .brand-stat-value.gold { color:#c9a848; }
    .brand-stat-value.green { color:#4ade80; }
    .brand-stat-label { font-size:10px; text-transform:uppercase; letter-spacing:0.8px; color:#525252; margin-top:2px; }
    .empty-state { background:#141414; border:1px solid #262626; border-radius:8px; padding:40px; text-align:center; }
    .empty-state h3 { font-size:16px; color:#fff; margin-bottom:8px; }
    .empty-state p { font-size:13px; color:#737373; line-height:1.6; }
    .pitch-section { background:#141414; border:1px solid #262626; border-radius:8px; padding:24px; margin-bottom:20px; }
    .pitch-section h2 { font-size:16px; font-weight:600; color:#fff; margin-bottom:16px; padding-bottom:10px; border-bottom:1px solid #262626; }
    .pitch-points { list-style:none; }
    .pitch-points li { padding:8px 0; font-size:13px; color:#a3a3a3; line-height:1.5; border-bottom:1px solid #1f1f1f; display:flex; gap:8px; }
    .pitch-points li:last-child { border-bottom:0; }
    .pitch-points .bullet { color:#c9a848; font-weight:700; flex-shrink:0; }
    @media (max-width:600px) { .brands-grid { grid-template-columns:1fr; } .container { padding:16px; } .promo-banner { flex-direction:column; } .ref-box { margin-left:0; } }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-left">
      <div class="logo"><span>s</span>Lab</div>
      <span class="badge">Delegate</span>
    </div>
    <div class="topbar-right">
      <span><%= delegate.firstName %> <%= delegate.lastName %></span>
      <a href="/delegates/panel">Dashboard</a>
      <a href="/delegates/panel/sales-sheets">Sales Sheets</a>
      <a href="/delegates/panel/settings">Settings</a>
      <a href="/delegates/logout">Logout</a>
    </div>
  </div>

  <div class="container">
    <h1>Sales Sheets</h1>
    <div class="subtitle">Your assigned brands and lead tracking across all platforms</div>

    <!-- Promo Banner -->
    <div class="promo-banner">
      <div class="promo-text">
        <h3><%= promo.type %></h3>
        <p><%= promo.description %></p>
      </div>
      <div class="ref-box">
        <label>Your Referral Code</label>
        <code><%= delegate.refCode %></code>
        <div class="ref-url">Share: <a href="/start?ref=<%= delegate.refCode %>">/start?ref=<%= delegate.refCode %></a></div>
      </div>
    </div>

    <!-- Pitch Quick-Reference -->
    <div class="pitch-section">
      <h2>Pitch Quick-Reference</h2>
      <ul class="pitch-points">
        <li><span class="bullet">1.</span> 30 days free on any platform — no credit card required to start</li>
        <li><span class="bullet">2.</span> Full white-label site with admin panel, CRM, email marketing & AI tools</li>
        <li><span class="bullet">3.</span> Custom domain, branding, and content — all managed from one dashboard</li>
        <li><span class="bullet">4.</span> Plans start at $50/month — multi-slab discounts up to 18% off</li>
        <li><span class="bullet">5.</span> Share your referral link: they sign up, you earn commission</li>
      </ul>
    </div>

    <!-- Brand Cards -->
    <% if (brands.length) { %>
    <div class="brands-grid">
      <% for (const b of brands) { %>
      <a href="/delegates/panel/sales-sheets/<%= b.tenantId %>" class="brand-card">
        <div class="brand-name"><%= b.brandName %></div>
        <div class="brand-domain"><%= b.domain %></div>
        <div class="brand-tagline"><%= b.tagline || b.description || 'No description set' %></div>
        <div class="brand-stats">
          <div class="brand-stat">
            <div class="brand-stat-value"><%= b.leadCount %></div>
            <div class="brand-stat-label">Leads</div>
          </div>
          <div class="brand-stat">
            <div class="brand-stat-value green"><%= b.convertedCount %></div>
            <div class="brand-stat-label">Converted</div>
          </div>
          <div class="brand-stat">
            <div class="brand-stat-value gold"><%= b.leadCount ? Math.round((b.convertedCount / b.leadCount) * 100) : 0 %>%</div>
            <div class="brand-stat-label">Conv. Rate</div>
          </div>
        </div>
      </a>
      <% } %>
    </div>
    <% } else { %>
    <div class="empty-state">
      <h3>No brands assigned yet</h3>
      <p>Your admin will attach brands to your account. Once assigned, you'll see sales sheets with brand details, pricing info, and lead tracking tools here.</p>
    </div>
    <% } %>
  </div>
</body>
</html>
