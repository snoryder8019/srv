<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Delegate Settings — sLab</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#0a0a0a; color:#e5e5e5; min-height:100vh; }
    .topbar { background:#141414; border-bottom:1px solid #262626; padding:14px 24px; display:flex; align-items:center; justify-content:space-between; }
    .topbar-left { display:flex; align-items:center; gap:16px; }
    .logo { font-size:20px; font-weight:600; color:#fff; } .logo span { color:#c9a848; }
    .badge { font-size:10px; text-transform:uppercase; letter-spacing:1.2px; color:#c9a848; background:#262626; padding:3px 8px; border-radius:4px; }
    .topbar-right { display:flex; align-items:center; gap:16px; font-size:13px; }
    .topbar-right a { color:#a3a3a3; text-decoration:none; font-size:12px; } .topbar-right a:hover { color:#c9a848; }
    .container { max-width:640px; margin:0 auto; padding:24px; }
    .card { background:#141414; border:1px solid #262626; border-radius:8px; padding:28px; margin-bottom:20px; }
    .card-title { font-size:16px; font-weight:600; color:#fff; margin-bottom:20px; padding-bottom:12px; border-bottom:1px solid #262626; }
    .form-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px; }
    .form-row.full { grid-template-columns:1fr; }
    .form-group { display:flex; flex-direction:column; gap:5px; }
    .form-group label { font-size:11px; font-weight:600; letter-spacing:0.8px; text-transform:uppercase; color:#737373; }
    .form-group input { background:#1a1a1a; border:1px solid #333; color:#e5e5e5; padding:10px 12px; border-radius:4px; font-family:'Inter',sans-serif; font-size:14px; outline:none; }
    .form-group input:focus { border-color:#c9a848; }
    .form-group input:disabled { opacity:0.5; cursor:not-allowed; }
    .error { background:rgba(248,113,113,0.1); border:1px solid rgba(248,113,113,0.2); color:#f87171; padding:10px 14px; border-radius:4px; font-size:13px; margin-bottom:16px; }
    .msg { background:rgba(74,222,128,0.1); border:1px solid rgba(74,222,128,0.2); color:#4ade80; padding:10px 14px; border-radius:4px; font-size:13px; margin-bottom:16px; }
    .btn { padding:10px 20px; background:#c9a848; color:#0a0a0a; border:none; border-radius:4px; font-family:'Inter',sans-serif; font-size:13px; font-weight:600; cursor:pointer; }
    .btn:hover { background:#d4b85c; }
    .btn-ghost { background:transparent; color:#a3a3a3; border:1px solid #333; } .btn-ghost:hover { border-color:#c9a848; color:#c9a848; }
    .info-row { font-size:13px; color:#737373; margin-bottom:6px; }
    .info-row strong { color:#e5e5e5; }
    @media (max-width:520px) { .form-row { grid-template-columns:1fr; } }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-left">
      <div class="logo"><span>s</span>Lab</div>
      <span class="badge">Delegate</span>
    </div>
    <div class="topbar-right">
      <a href="/delegates/panel">Dashboard</a>
      <a href="/delegates/logout">Logout</a>
    </div>
  </div>

  <div class="container">
    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <% if (msg) { %><div class="msg"><%= msg %></div><% } %>

    <div class="card">
      <div class="card-title">Profile Information</div>
      <div class="info-row">Email: <strong><%= delegate.email %></strong> (cannot be changed)</div>
      <div class="info-row" style="margin-bottom:20px;">Referral Code: <strong style="color:#c9a848;"><%= delegate.refCode %></strong></div>

      <form method="POST" action="/delegates/panel/settings">
        <div class="form-row">
          <div class="form-group">
            <label>First Name *</label>
            <input type="text" name="firstName" value="<%= delegate.firstName %>" required>
          </div>
          <div class="form-group">
            <label>Last Name *</label>
            <input type="text" name="lastName" value="<%= delegate.lastName %>" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Phone</label>
            <input type="text" name="phone" value="<%= delegate.phone || '' %>">
          </div>
          <div class="form-group">
            <label>Address</label>
            <input type="text" name="address" value="<%= delegate.address || '' %>">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>City</label>
            <input type="text" name="city" value="<%= delegate.city || '' %>">
          </div>
          <div class="form-group">
            <label>State</label>
            <input type="text" name="state" value="<%= delegate.state || '' %>">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Zip</label>
            <input type="text" name="zip" value="<%= delegate.zip || '' %>">
          </div>
          <div class="form-group"></div>
        </div>
        <button type="submit" class="btn">Save Profile</button>
      </form>
    </div>

    <div class="card">
      <div class="card-title">Change Password</div>
      <form method="POST" action="/delegates/panel/password">
        <div class="form-row full">
          <div class="form-group">
            <label>Current Password</label>
            <input type="password" name="current_password" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>New Password</label>
            <input type="password" name="new_password" required placeholder="Min 12 chars">
          </div>
          <div class="form-group">
            <label>Confirm New Password</label>
            <input type="password" name="confirm_password" required>
          </div>
        </div>
        <button type="submit" class="btn btn-ghost">Change Password</button>
      </form>
    </div>
  </div>
</body>
</html>
