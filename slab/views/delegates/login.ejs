<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Delegate Login — sLab</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#0a0a0a; color:#e5e5e5; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px; }
    .login-wrap { max-width:400px; width:100%; }
    .logo { font-size:24px; font-weight:600; color:#fff; text-align:center; margin-bottom:8px; } .logo span { color:#c9a848; }
    .subtitle { text-align:center; font-size:13px; color:#737373; margin-bottom:32px; }
    .card { background:#141414; border:1px solid #262626; border-radius:8px; padding:32px; }
    .error { background:rgba(248,113,113,0.1); border:1px solid rgba(248,113,113,0.2); color:#f87171; padding:10px 14px; border-radius:4px; font-size:13px; margin-bottom:16px; }
    .msg { background:rgba(74,222,128,0.1); border:1px solid rgba(74,222,128,0.2); color:#4ade80; padding:10px 14px; border-radius:4px; font-size:13px; margin-bottom:16px; }
    .form-group { margin-bottom:16px; display:flex; flex-direction:column; gap:5px; }
    .form-group label { font-size:11px; font-weight:600; letter-spacing:0.8px; text-transform:uppercase; color:#737373; }
    .form-group input { background:#1a1a1a; border:1px solid #333; color:#e5e5e5; padding:10px 12px; border-radius:4px; font-family:'Inter',sans-serif; font-size:14px; outline:none; }
    .form-group input:focus { border-color:#c9a848; }
    .btn { width:100%; padding:12px; background:#c9a848; color:#0a0a0a; border:none; border-radius:4px; font-family:'Inter',sans-serif; font-size:14px; font-weight:600; cursor:pointer; }
    .btn:hover { background:#d4b85c; }
    .btn-google { display:flex; align-items:center; justify-content:center; gap:10px; background:#1a1a1a; color:#e5e5e5; border:1px solid #333; text-decoration:none; padding:11px; border-radius:4px; font-size:14px; font-weight:500; }
    .btn-google:hover { border-color:#c9a848; color:#c9a848; }
    .divider { display:flex; align-items:center; gap:10px; margin:18px 0; font-size:11px; color:#525252; text-transform:uppercase; letter-spacing:1px; }
    .divider::before, .divider::after { content:''; flex:1; height:1px; background:#262626; }
    .signup-link { text-align:center; margin-top:16px; font-size:13px; color:#737373; }
    .signup-link a { color:#c9a848; text-decoration:none; } .signup-link a:hover { text-decoration:underline; }
  </style>
</head>
<body>
  <div class="login-wrap">
    <div class="logo"><span>s</span>Lab</div>
    <div class="subtitle">Sales Delegate Portal</div>
    <div class="card">
      <% if (error) { %><div class="error"><%= error %></div><% } %>
      <% if (msg) { %><div class="msg"><%= msg %></div><% } %>

      <a href="/auth/google/delegate" class="btn-google">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        Sign in with Google
      </a>

      <div class="divider">or use email</div>

      <form method="POST" action="/delegates/login">
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" required placeholder="you@example.com" autofocus>
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" required>
        </div>
        <button type="submit" class="btn">Log In</button>
      </form>
      <div class="signup-link">Don't have an account? <a href="/delegates/signup">Apply now</a></div>
    </div>
  </div>
</body>
</html>
