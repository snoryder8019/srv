<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GFTV — <%= tenant.name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:'Inter',sans-serif;background:#0a0a0a;color:#e5e5e5;min-height:100vh;}
    .topbar{background:#141414;border-bottom:1px solid #262626;padding:12px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;}
    .topbar-left{display:flex;align-items:center;gap:14px;}
    .back-btn{color:#525252;text-decoration:none;font-size:13px;display:flex;align-items:center;gap:6px;padding:6px 12px;border:1px solid #262626;border-radius:4px;}
    .back-btn:hover{color:#c9a848;border-color:#c9a848;}
    .logo{font-size:18px;font-weight:600;color:#fff;} .logo span{color:#f5c400;}
    .tenant-badge{background:rgba(245,196,0,0.1);border:1px solid rgba(245,196,0,0.2);color:#f5c400;padding:4px 12px;border-radius:4px;font-size:12px;font-family:'IBM Plex Mono',monospace;letter-spacing:2px;}
    .topbar-right{display:flex;gap:8px;align-items:center;}
    .btn{padding:7px 14px;font-size:12px;border-radius:6px;border:1px solid #333;background:transparent;color:#a3a3a3;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:6px;}
    .btn:hover{border-color:#f5c400;color:#f5c400;}
    .btn-gold{background:#f5c400;color:#0a0a0a;border-color:#f5c400;font-weight:600;} .btn-gold:hover{background:#e6b800;color:#0a0a0a;}
    .btn-red{background:rgba(204,17,0,0.15);color:#f87171;border-color:#451a1a;} .btn-red:hover{background:#cc1100;color:#fff;}

    .content{padding:28px;max-width:1200px;margin:0 auto;}

    /* Hero row */
    .hero-row{display:grid;grid-template-columns:1fr auto;gap:20px;margin-bottom:24px;align-items:start;}
    .hero-name{font-family:'Bebas Neue',sans-serif;font-size:3rem;letter-spacing:3px;line-height:1;margin-bottom:4px;}
    .hero-meta{display:flex;gap:14px;align-items:center;flex-wrap:wrap;margin-top:8px;}
    .hero-meta span{font-size:12px;color:#525252;}
    .hero-meta strong{color:#a3a3a3;}
    .plan-pill{padding:4px 12px;border-radius:20px;font-size:11px;font-weight:600;letter-spacing:1px;}
    .plan-starter{background:rgba(255,255,255,0.05);color:#a3a3a3;border:1px solid #333;}
    .plan-pro{background:rgba(245,196,0,0.12);color:#f5c400;border:1px solid rgba(245,196,0,0.3);}
    .promo-pill{background:rgba(249,115,22,0.12);color:#fb923c;border:1px solid rgba(249,115,22,0.2);padding:4px 12px;border-radius:20px;font-size:11px;font-weight:600;letter-spacing:1px;}

    /* Stats */
    .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:24px;}
    .stat{background:#141414;border:1px solid #262626;border-radius:8px;padding:16px;}
    .stat-label{font-size:10px;text-transform:uppercase;letter-spacing:1px;color:#737373;margin-bottom:4px;}
    .stat-value{font-size:26px;font-weight:700;color:#fff;}
    .stat-value.gold{color:#f5c400;} .stat-value.green{color:#34d399;} .stat-value.red{color:#f87171;}

    /* Sections */
    .section{margin-bottom:24px;}
    .section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
    .section-title{font-size:13px;font-weight:600;color:#e5e5e5;letter-spacing:0.5px;}
    table{width:100%;border-collapse:collapse;background:#141414;border-radius:8px;overflow:hidden;border:1px solid #262626;}
    th{text-align:left;padding:10px 14px;font-size:10px;text-transform:uppercase;letter-spacing:0.8px;color:#737373;background:#1a1a1a;border-bottom:1px solid #262626;}
    td{padding:10px 14px;font-size:13px;border-bottom:1px solid #1f1f1f;vertical-align:middle;}
    tr:last-child td{border-bottom:0;} tr:hover td{background:#1a1a1a;}
    .empty{color:#525252;font-size:13px;padding:20px;text-align:center;}

    /* Badges */
    .badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:10px;letter-spacing:0.5px;font-weight:600;}
    .badge-active{background:rgba(52,211,153,0.1);color:#34d399;border:1px solid rgba(52,211,153,0.2);}
    .badge-off{background:rgba(248,113,113,0.1);color:#f87171;border:1px solid rgba(248,113,113,0.2);}

    /* Revenue card */
    .rev-card{background:#141414;border:1px solid #262626;border-radius:8px;padding:20px;margin-bottom:24px;}
    .rev-title{font-size:11px;text-transform:uppercase;letter-spacing:2px;color:#525252;margin-bottom:14px;}
    .rev-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid #1f1f1f;}
    .rev-row:last-child{border-bottom:0;}
    .rev-label{font-size:13px;color:#a3a3a3;}
    .rev-val{font-size:16px;font-weight:700;color:#f5c400;font-family:'IBM Plex Mono',monospace;}
    .promo-notice{background:rgba(249,115,22,0.08);border:1px solid rgba(249,115,22,0.2);border-radius:6px;padding:10px 14px;font-size:12px;color:#fb923c;margin-bottom:14px;display:flex;align-items:center;gap:8px;}

    /* Quick actions */
    .actions-bar{display:flex;gap:8px;flex-wrap:wrap;}
    .action-btn{padding:8px 16px;font-size:12px;border-radius:6px;border:1px solid #262626;background:#141414;color:#a3a3a3;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:6px;}
    .action-btn:hover{border-color:#f5c400;color:#f5c400;}
  </style>
</head>
<body>

<div class="topbar">
  <div class="topbar-left">
    <a href="/superadmin#tab-gftv" class="back-btn">← Back to GFTV</a>
    <div class="logo">GRAFFITI<span>TV</span></div>
    <div class="tenant-badge"><%= tenant.slug.toUpperCase() %></div>
  </div>
  <div class="topbar-right">
    <a href="https://graffititv.madladslab.com/tv/<%= tenant.slug %>" target="_blank" class="btn">📺 Live Display</a>
    <a href="https://graffititv.madladslab.com/admin/<%= tenant.slug %>" target="_blank" class="btn">⚙ Tenant Admin</a>
    <a href="https://graffititv.madladslab.com/preview/<%= tenant.slug %>" target="_blank" class="btn">👁 Preview</a>
  </div>
</div>

<div class="content">

  <!-- HERO -->
  <div class="hero-row">
    <div>
      <div class="hero-name"><%= tenant.name %></div>
      <div class="hero-meta">
        <span class="plan-pill plan-<%= tenant.plan %>"><%= tenant.plan.toUpperCase() %> — $<%= planPrices[tenant.plan] || 0 %>/mo</span>
        <% if (tenant.isPromo) { %><span class="promo-pill">PROMO — EXCLUDED FROM MRR</span><% } %>
        <% if (tenant.active) { %><span class="badge badge-active">ACTIVE</span><% } else { %><span class="badge badge-off">DISABLED</span><% } %>
        <span><strong>Email:</strong> <%= tenant.email %></span>
        <% if (tenant.branding?.location) { %><span><strong>Location:</strong> <%= tenant.branding.location %></span><% } %>
        <span><strong>Created:</strong> <%= new Date(tenant.createdAt).toLocaleDateString() %></span>
      </div>
    </div>
  </div>

  <!-- STATS -->
  <div class="stats">
    <div class="stat">
      <div class="stat-label">MRR Contribution</div>
      <div class="stat-value gold"><%= tenant.isPromo ? '—' : '$' + (planPrices[tenant.plan] || 0) %></div>
    </div>
    <div class="stat">
      <div class="stat-label">Menu Items</div>
      <div class="stat-value"><%= (data.menu || []).filter(i => i.active).length %></div>
    </div>
    <div class="stat">
      <div class="stat-label">Events</div>
      <div class="stat-value"><%= (data.events || []).filter(i => i.active).length %></div>
    </div>
    <div class="stat">
      <div class="stat-label">QR Offers</div>
      <div class="stat-value"><%= (data.offerings || []).filter(i => i.active).length %></div>
    </div>
    <div class="stat">
      <div class="stat-label">Subscribers</div>
      <div class="stat-value green"><%= (data.subscribers || []).length %></div>
    </div>
    <div class="stat">
      <div class="stat-label">Theme Views</div>
      <div class="stat-value"><%= Object.values(data.analytics?.themes || {}).reduce((a,b)=>a+b,0) %></div>
    </div>
  </div>

  <!-- REVENUE -->
  <div class="rev-card">
    <div class="rev-title">Revenue</div>
    <% if (tenant.isPromo) { %>
    <div class="promo-notice">⚠ This tenant is marked as Promo — excluded from MRR calculations.</div>
    <% } %>
    <div class="rev-row"><div class="rev-label">Monthly Recurring Revenue</div><div class="rev-val"><%= tenant.isPromo ? '—' : '$' + (planPrices[tenant.plan] || 0) %></div></div>
    <div class="rev-row"><div class="rev-label">Annual Run Rate</div><div class="rev-val"><%= tenant.isPromo ? '—' : '$' + ((planPrices[tenant.plan] || 0) * 12) %></div></div>
    <div class="rev-row"><div class="rev-label">Plan</div><div class="rev-val" style="font-size:13px;"><%= tenant.plan.toUpperCase() %></div></div>
    <div class="rev-row" style="margin-top:12px;">
      <div class="rev-label" style="font-size:12px;color:#525252;">Toggle promo status</div>
      <form method="POST" action="/superadmin/gftv/tenants/<%= tenant.slug %>/toggle-promo" style="display:inline;">
        <button type="submit" class="btn <%= tenant.isPromo ? '' : 'btn-red' %>" style="font-size:11px;">
          <%= tenant.isPromo ? '✓ Unmark as Promo' : '⚠ Mark as Promo (exclude MRR)' %>
        </button>
      </form>
    </div>
  </div>

  <!-- QUICK ACTIONS -->
  <div class="section">
    <div class="section-header"><div class="section-title">Quick Actions</div></div>
    <div class="actions-bar">
      <a href="https://graffititv.madladslab.com/tv/<%= tenant.slug %>" target="_blank" class="action-btn">📺 View Live Display</a>
      <a href="https://graffititv.madladslab.com/admin/<%= tenant.slug %>" target="_blank" class="action-btn">⚙ Open Tenant Admin</a>
      <a href="https://graffititv.madladslab.com/preview/<%= tenant.slug %>" target="_blank" class="action-btn">👁 Preview Display</a>
      <a href="https://graffititv.madladslab.com/api/<%= tenant.slug %>/menu" target="_blank" class="action-btn">🍝 Menu API</a>
      <a href="https://graffititv.madladslab.com/api/<%= tenant.slug %>/events" target="_blank" class="action-btn">📅 Events API</a>
    </div>
  </div>

  <!-- ANALYTICS -->
  <div class="section">
    <div class="section-header"><div class="section-title">Theme Analytics</div></div>
    <% const themeNames = {1:'VHS Underground',2:'Rave Mode',3:'Retro Diner',4:'Brutalist',5:'Vaporwave',6:'Newsroom',7:'Split Screen',8:'Cinema',9:'Polaroid Board',10:'Neon Grid',11:'Horizontal',12:'Typewriter',13:'Tiles',14:'Minimal',15:'Stadium'}; %>
    <% const themeViews = data.analytics?.themes || {}; %>
    <% const maxViews = Math.max(...Object.values(themeViews), 1); %>
    <% if (Object.keys(themeViews).length) { %>
    <table>
      <thead><tr><th>Theme</th><th>Views</th><th>Share</th></tr></thead>
      <tbody>
        <% Object.entries(themeViews).sort((a,b)=>b[1]-a[1]).forEach(([id,count]) => { %>
        <tr>
          <td><%= themeNames[id] || 'Theme ' + id %></td>
          <td style="font-family:'IBM Plex Mono',monospace;color:#f5c400;"><%= count %></td>
          <td>
            <div style="display:flex;align-items:center;gap:8px;">
              <div style="flex:1;height:4px;background:#262626;border-radius:2px;max-width:200px;">
                <div style="height:100%;background:#f5c400;border-radius:2px;width:<%= Math.round(count/maxViews*100) %>%;"></div>
              </div>
              <span style="font-size:11px;color:#525252;"><%= Math.round(count/Object.values(themeViews).reduce((a,b)=>a+b,0)*100) %>%</span>
            </div>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% } else { %><div class="empty">No theme views recorded yet</div><% } %>
  </div>

  <!-- SUBSCRIBERS -->
  <div class="section">
    <div class="section-header"><div class="section-title">Email Subscribers (<%= (data.subscribers||[]).length %>)</div></div>
    <% const subs = data.subscribers || []; %>
    <% if (subs.length) { %>
    <table>
      <thead><tr><th>Email</th><th>Name</th><th>Date Joined</th></tr></thead>
      <tbody>
        <% subs.slice().reverse().forEach(s => { %>
        <tr>
          <td><%= s.email %></td>
          <td style="color:#737373;"><%= s.name || '—' %></td>
          <td style="color:#525252;font-size:12px;"><%= new Date(s.date).toLocaleDateString() %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% } else { %><div class="empty" style="background:#141414;border:1px solid #262626;border-radius:8px;">No subscribers yet</div><% } %>
  </div>

  <!-- MENU SNAPSHOT -->
  <div class="section">
    <div class="section-header">
      <div class="section-title">Menu Snapshot (<%= (data.menu||[]).filter(i=>i.active).length %> active items)</div>
    </div>
    <% const menuItems = (data.menu||[]).filter(i=>i.active); %>
    <% if (menuItems.length) { %>
    <table>
      <thead><tr><th>Item</th><th>Description</th><th>Price</th></tr></thead>
      <tbody>
        <% menuItems.forEach(item => { %>
        <tr>
          <td style="font-weight:500;"><%= item.name %></td>
          <td style="color:#737373;font-size:12px;"><%= item.desc || '—' %></td>
          <td style="font-family:'IBM Plex Mono',monospace;color:#f5c400;">$<%= parseFloat(item.price||0).toFixed(2) %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% } else { %><div class="empty" style="background:#141414;border:1px solid #262626;border-radius:8px;">No menu items</div><% } %>
  </div>

  <!-- UPCOMING EVENTS -->
  <div class="section">
    <div class="section-header"><div class="section-title">Upcoming Events</div></div>
    <% const events = (data.events||[]).filter(e=>e.active); %>
    <% if (events.length) { %>
    <table>
      <thead><tr><th>Event</th><th>Date</th><th>Time</th><th>Description</th></tr></thead>
      <tbody>
        <% events.forEach(e => { %>
        <tr>
          <td style="font-weight:500;"><%= e.title %></td>
          <td style="font-family:'IBM Plex Mono',monospace;color:#a3a3a3;"><%= e.date %></td>
          <td style="color:#737373;"><%= e.time || '—' %></td>
          <td style="color:#525252;font-size:12px;"><%= e.desc || '' %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% } else { %><div class="empty" style="background:#141414;border:1px solid #262626;border-radius:8px;">No upcoming events</div><% } %>
  </div>

</div>
</body>
</html>
