<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Subscribe — MadLabs Platform</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#0a0a0a; color:#e5e5e5; min-height:100vh; display:flex; align-items:center; justify-content:center; }
    .page { max-width:480px; width:100%; padding:24px; }
    .logo { font-size:28px; font-weight:700; color:#fff; text-align:center; margin-bottom:4px; } .logo span { color:#c9a848; }
    .tagline { text-align:center; font-size:14px; color:#737373; margin-bottom:32px; }
    .card { background:#141414; border:1px solid #262626; border-radius:10px; padding:28px; }
    h1 { font-size:20px; font-weight:600; color:#fff; margin-bottom:6px; }
    .subtitle { font-size:13px; color:#737373; margin-bottom:24px; line-height:1.5; }
    .form-group { margin-bottom:16px; }
    .form-group label { display:block; font-size:11px; text-transform:uppercase; letter-spacing:0.8px; color:#737373; margin-bottom:5px; }
    .form-group input, .form-group select { width:100%; background:#0a0a0a; border:1px solid #333; color:#e5e5e5; padding:10px 14px; border-radius:6px; font-family:'Inter',sans-serif; font-size:13px; }
    .form-group input:focus, .form-group select:focus { border-color:#c9a848; outline:none; }
    .form-group input::placeholder { color:#525252; }
    .btn { width:100%; padding:12px; font-size:14px; border-radius:6px; border:none; background:#c9a848; color:#0a0a0a; cursor:pointer; font-family:'Inter',sans-serif; font-weight:600; transition:background .15s; }
    .btn:hover { background:#b8960b; }
    .success { background:#14532d; color:#86efac; padding:14px 18px; border-radius:8px; margin-bottom:20px; font-size:14px; text-align:center; line-height:1.5; }
    .perks { margin-top:20px; }
    .perk { display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:13px; color:#a3a3a3; }
    .perk-icon { color:#c9a848; font-size:16px; flex-shrink:0; margin-top:1px; }
    .footer { text-align:center; margin-top:20px; font-size:12px; color:#525252; }
    .footer a { color:#737373; text-decoration:none; } .footer a:hover { color:#c9a848; }
  </style>
</head>
<body>
  <div class="page">
    <div class="logo">mad<span>Labs</span>lab</div>
    <div class="tagline">Build your brand. Launch your platform.</div>

    <div class="card">
      <% if (success) { %>
        <div class="success">
          You're in! We'll keep you posted on platform updates, early access, and exclusive offers.
        </div>
      <% } %>

      <h1>Stay in the loop</h1>
      <p class="subtitle">Get early access to new features, platform updates, and exclusive offers for creators and businesses.</p>

      <form method="POST" action="/superadmin/subscribe">
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" placeholder="you@example.com" required />
        </div>
        <div class="form-group">
          <label>Name (optional)</label>
          <input type="text" name="name" placeholder="Your name" />
        </div>
        <div class="form-group">
          <label>I'm interested in</label>
          <select name="interest">
            <option value="general">General updates</option>
            <option value="business">Business / SaaS tools</option>
            <option value="creator">Creator platform</option>
            <option value="developer">Developer / API access</option>
            <option value="community">Community TV (GreeAlityTV)</option>
            <option value="gaming">Gaming hub</option>
            <option value="restaurant">Restaurant ops (OpsTrain)</option>
          </select>
        </div>
        <input type="hidden" name="source" value="subscribe-page" />
        <button type="submit" class="btn">Subscribe</button>
      </form>

      <div class="perks">
        <div class="perk"><span class="perk-icon">&#10003;</span> Early access to new features</div>
        <div class="perk"><span class="perk-icon">&#10003;</span> Exclusive launch offers</div>
        <div class="perk"><span class="perk-icon">&#10003;</span> Platform tips and guides</div>
        <div class="perk"><span class="perk-icon">&#10003;</span> No spam — unsubscribe anytime</div>
      </div>
    </div>

    <div class="footer">
      <a href="/">Home</a> &middot; <a href="/start">Get Started</a> &middot; <a href="/terms">Terms</a>
    </div>
  </div>
</body>
</html>
