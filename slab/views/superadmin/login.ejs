<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Superadmin — Slab</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#0a0a0a; color:#e5e5e5; min-height:100vh; display:flex; align-items:center; justify-content:center; }
    .card { background:#141414; max-width:380px; width:100%; border-radius:12px; border:1px solid #262626; padding:40px 32px; text-align:center; }
    .logo { font-size:24px; font-weight:600; color:#fff; margin-bottom:4px; }
    .logo span { color:#c9a848; }
    .sub { font-size:12px; color:#525252; text-transform:uppercase; letter-spacing:1.5px; margin-bottom:28px; }
    .error { background:#451a1a; color:#fca5a5; padding:10px 14px; border-radius:6px; font-size:13px; margin-bottom:16px; }
    .btn { display:inline-flex; align-items:center; gap:10px; padding:12px 28px; background:#1a1a1a; border:1px solid #333; border-radius:6px; color:#e5e5e5; font-family:'Inter',sans-serif; font-size:14px; font-weight:500; text-decoration:none; transition:border 0.2s; }
    .btn:hover { border-color:#c9a848; }
    .btn svg { width:18px; height:18px; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo"><span>S</span>lab</div>
    <div class="sub">Platform Control</div>
    <% if (error) { %>
      <div class="error"><%= error === 'unauthorized' ? 'Not authorized as superadmin.' : 'Sign-in failed.' %></div>
    <% } %>
    <a href="/auth/google/superadmin" class="btn">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
      Sign in with Google
    </a>
  </div>
</body>
</html>
