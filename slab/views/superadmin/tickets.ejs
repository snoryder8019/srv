<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Escalated Tickets — Superadmin</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#0a0a0a; color:#e5e5e5; min-height:100vh; }
    .topbar { background:#141414; border-bottom:1px solid #262626; padding:14px 24px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:100; }
    .topbar-left { display:flex; align-items:center; gap:16px; }
    .logo { font-size:18px; font-weight:500; color:#fff; font-family:'Space Grotesk',sans-serif; letter-spacing:0.05em; } .logo span { color:#c9a848; }
    .topbar-right { display:flex; align-items:center; gap:16px; font-size:13px; color:#737373; }
    .topbar-right a { color:#a3a3a3; text-decoration:none; font-size:12px; } .topbar-right a:hover { color:#c9a848; }
    .container { max-width:1100px; margin:0 auto; padding:24px; }
    .stats { display:grid; grid-template-columns:repeat(auto-fit, minmax(140px, 1fr)); gap:14px; margin-bottom:24px; }
    .stat { background:#141414; border:1px solid #262626; border-radius:8px; padding:16px; }
    .stat-label { font-size:10px; text-transform:uppercase; letter-spacing:1px; color:#737373; margin-bottom:4px; }
    .stat-value { font-size:24px; font-weight:700; color:#fff; }
    .stat-value.gold { color:#c9a848; } .stat-value.green { color:#34d399; } .stat-value.red { color:#f87171; }
    .filters { display:flex; gap:8px; margin-bottom:20px; flex-wrap:wrap; }
    .filter-btn { padding:6px 14px; font-size:12px; border-radius:6px; border:1px solid #333; background:transparent; color:#a3a3a3; cursor:pointer; text-decoration:none; font-family:'Inter',sans-serif; }
    .filter-btn:hover { border-color:#c9a848; color:#c9a848; }
    .filter-btn.active { background:#c9a848; color:#0a0a0a; border-color:#c9a848; font-weight:600; }
    table { width:100%; border-collapse:collapse; background:#141414; border-radius:8px; overflow:hidden; border:1px solid #262626; }
    th { text-align:left; padding:10px 14px; font-size:11px; text-transform:uppercase; letter-spacing:0.8px; color:#737373; background:#1a1a1a; border-bottom:1px solid #262626; }
    td { padding:10px 14px; font-size:13px; border-bottom:1px solid #1f1f1f; }
    tr:last-child td { border-bottom:0; }
    tr:hover td { background:#1a1a1a; }
    .status { display:inline-block; padding:2px 8px; border-radius:10px; font-size:11px; font-weight:500; }
    .status-escalated { background:#451a1a; color:#fca5a5; }
    .status-resolved { background:#14532d; color:#86efac; }
    .status-closed { background:#262626; color:#a3a3a3; }
    .link { color:#c9a848; text-decoration:none; } .link:hover { text-decoration:underline; }
    .btn { padding:6px 12px; font-size:12px; border-radius:5px; border:1px solid #333; background:transparent; color:#a3a3a3; cursor:pointer; font-family:'Inter',sans-serif; text-decoration:none; }
    .btn:hover { border-color:#c9a848; color:#c9a848; }
    .empty { color:#525252; font-size:13px; padding:40px; text-align:center; }
    .back-link { color:#737373; text-decoration:none; font-size:13px; } .back-link:hover { color:#c9a848; }
    .table-wrap { overflow-x:auto; -webkit-overflow-scrolling:touch; border-radius:8px; }
    .table-wrap table { min-width:580px; }
    @media (max-width:768px) {
      .topbar { padding:10px 14px; flex-wrap:wrap; gap:8px; }
      .topbar-left { gap:10px; } .topbar-right { gap:8px; font-size:11px; flex-wrap:wrap; }
      .logo { font-size:17px; }
      .container { padding:14px; }
      .stats { grid-template-columns:repeat(2, 1fr); gap:8px; }
      .stat { padding:10px; } .stat-value { font-size:18px; } .stat-label { font-size:9px; }
      .filters { gap:6px; }
      .filter-btn { padding:4px 10px; font-size:10px; }
      th, td { padding:8px 10px; font-size:12px; }
    }
    @media (max-width:480px) { .topbar-right span { display:none; } }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-left">
      <div class="logo">mad<span>Labs</span>lab</div>
      <span style="color:#737373; font-size:13px;">/ Escalated Tickets</span>
    </div>
    <div class="topbar-right">
      <a href="/superadmin">&larr; Dashboard</a>
      <span><%= superAdmin.email %></span>
    </div>
  </div>

  <div class="container">
    <div class="stats">
      <div class="stat"><div class="stat-label">Active</div><div class="stat-value red"><%= stats.active %></div></div>
      <div class="stat"><div class="stat-label">Resolved</div><div class="stat-value green"><%= stats.resolved %></div></div>
      <div class="stat"><div class="stat-label">Closed</div><div class="stat-value"><%= stats.closed %></div></div>
      <div class="stat"><div class="stat-label">Total</div><div class="stat-value gold"><%= stats.total %></div></div>
    </div>

    <div class="filters">
      <a class="filter-btn <%= !filters.status ? 'active' : '' %>" href="/superadmin/tickets">Escalated</a>
      <a class="filter-btn <%= filters.status === 'resolved' ? 'active' : '' %>" href="/superadmin/tickets?status=resolved">Resolved</a>
      <a class="filter-btn <%= filters.status === 'closed' ? 'active' : '' %>" href="/superadmin/tickets?status=closed">Closed</a>
      <a class="filter-btn <%= filters.status === 'all' ? 'active' : '' %>" href="/superadmin/tickets?status=all">All</a>
    </div>

    <% if (tickets.length === 0) { %>
      <div class="empty">No tickets found.</div>
    <% } else { %>
      <div class="table-wrap"><table>
        <thead>
          <tr>
            <th>Subject</th>
            <th>Tenant</th>
            <th>From</th>
            <th>Status</th>
            <th>Escalated</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% tickets.forEach(t => { %>
          <tr>
            <td><strong><%= t.subject || '(no subject)' %></strong></td>
            <td style="color:#c9a848; font-size:12px;"><%= t.tenantDbName || t.tenantDb || '—' %></td>
            <td style="font-size:12px; color:#a3a3a3;"><%= t.authorEmail || t.author?.email || '—' %></td>
            <td>
              <span class="status status-<%= t.status %>"><%= t.status %></span>
            </td>
            <td style="font-size:12px; color:#525252;">
              <%= t.escalatedAt ? new Date(t.escalatedAt).toLocaleDateString() : '—' %>
            </td>
            <td>
              <% if (t.tenantDbName && t.ticketId) { %>
                <a class="link" href="/superadmin/tickets/<%= t.tenantDbName %>/<%= t.ticketId %>">View</a>
              <% } else if (t.tenantDb && t.ticketId) { %>
                <a class="link" href="/superadmin/tickets/<%= t.tenantDb %>/<%= t.ticketId %>">View</a>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table></div>
    <% } %>
  </div>
</body>
</html>
