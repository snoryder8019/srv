<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GreeAlityTV — Superadmin</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#0a0a0a; color:#e5e5e5; min-height:100vh; }
    .topbar { background:#141414; border-bottom:1px solid #262626; padding:14px 24px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:100; }
    .topbar-left { display:flex; align-items:center; gap:16px; }
    .logo { font-size:18px; font-weight:500; color:#fff; font-family:'Space Grotesk',sans-serif; letter-spacing:0.05em; } .logo span { color:#c9a848; }
    .topbar-right { display:flex; align-items:center; gap:16px; font-size:13px; }
    .topbar-right a { color:#a3a3a3; text-decoration:none; font-size:12px; } .topbar-right a:hover { color:#c9a848; }
    .container { max-width:1100px; margin:0 auto; padding:24px; }
    .stats { display:grid; grid-template-columns:repeat(auto-fit, minmax(120px, 1fr)); gap:12px; margin-bottom:24px; }
    .stat { background:#141414; border:1px solid #262626; border-radius:8px; padding:14px; text-align:center; }
    .stat-label { font-size:10px; text-transform:uppercase; letter-spacing:1px; color:#737373; margin-bottom:4px; }
    .stat-value { font-size:22px; font-weight:700; color:#fff; }
    .stat-value.gold { color:#c9a848; } .stat-value.green { color:#34d399; } .stat-value.blue { color:#38bdf8; } .stat-value.purple { color:#a78bfa; }
    .section { margin-bottom:28px; }
    h2 { font-size:16px; font-weight:500; margin-bottom:14px; }
    .content-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(200px, 1fr)); gap:12px; margin-bottom:24px; }
    .content-card { background:#141414; border:1px solid #262626; border-radius:8px; padding:16px; text-align:center; }
    .content-card-icon { font-size:24px; margin-bottom:6px; }
    .content-card-num { font-size:28px; font-weight:700; color:#c9a848; }
    .content-card-lbl { font-size:11px; text-transform:uppercase; letter-spacing:0.8px; color:#525252; margin-top:2px; }
    table { width:100%; border-collapse:collapse; background:#141414; border-radius:8px; overflow:hidden; border:1px solid #262626; }
    th { text-align:left; padding:10px 14px; font-size:10px; text-transform:uppercase; letter-spacing:0.8px; color:#737373; background:#1a1a1a; border-bottom:1px solid #262626; }
    td { padding:10px 14px; font-size:13px; border-bottom:1px solid #1f1f1f; }
    tr:last-child td { border-bottom:0; }
    tr:hover td { background:#1a1a1a; }
    .badge { display:inline-block; padding:2px 7px; border-radius:10px; font-size:10px; font-weight:500; }
    .badge-admin { background:#14532d; color:#86efac; }
    .badge-contributor { background:#422006; color:#fdba74; }
    .badge-delegate { background:#3b0764; color:#d8b4fe; }
    .badge-viewer { background:#262626; color:#a3a3a3; }
    .badge-verified { background:#1e3a5f; color:#7dd3fc; }
    .empty { color:#525252; font-size:13px; padding:20px; text-align:center; }
    .table-wrap { overflow-x:auto; -webkit-overflow-scrolling:touch; border-radius:8px; }
    .table-wrap table { min-width:500px; }
    @media (max-width:768px) {
      .topbar { padding:10px 14px; flex-wrap:wrap; gap:8px; }
      .topbar-left { gap:10px; } .topbar-right { gap:8px; font-size:11px; flex-wrap:wrap; }
      .logo { font-size:17px; }
      .container { padding:14px; }
      .stats { grid-template-columns:repeat(3, 1fr); gap:8px; }
      .stat { padding:10px; } .stat-value { font-size:18px; } .stat-label { font-size:9px; }
      .content-grid { grid-template-columns:repeat(2, 1fr); gap:8px; }
      .content-card { padding:12px; }
      .content-card-num { font-size:22px; }
      th, td { padding:8px 10px; font-size:12px; }
    }
    @media (max-width:480px) {
      .stats { grid-template-columns:repeat(2, 1fr); }
      .content-grid { grid-template-columns:repeat(2, 1fr); }
      .topbar-right a:not(:first-child) { display:none; }
    }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-left">
      <div class="logo">mad<span>Labs</span>lab</div>
      <span style="color:#737373; font-size:13px;">/ GreeAlityTV</span>
    </div>
    <div class="topbar-right">
      <a href="/superadmin">&larr; Dashboard</a>
      <a href="https://greealitytv.com" target="_blank">GreeAlityTV Live</a>
      <span><%= superAdmin.email %></span>
    </div>
  </div>

  <div class="container">
    <!-- User Stats -->
    <div class="stats">
      <div class="stat"><div class="stat-label">Total Users</div><div class="stat-value gold"><%= userStats.total %></div></div>
      <div class="stat"><div class="stat-label">Admins</div><div class="stat-value green"><%= userStats.admins %></div></div>
      <div class="stat"><div class="stat-label">Contributors</div><div class="stat-value"><%= userStats.contributors %></div></div>
      <div class="stat"><div class="stat-label">Delegates</div><div class="stat-value purple"><%= userStats.delegates %></div></div>
      <div class="stat"><div class="stat-label">Verified</div><div class="stat-value blue"><%= userStats.verified %></div></div>
    </div>

    <!-- Content Stats -->
    <div class="section">
      <h2>Content</h2>
      <div class="content-grid">
        <div class="content-card">
          <div class="content-card-icon">&#128196;</div>
          <div class="content-card-num"><%= contentStats.posts %></div>
          <div class="content-card-lbl">Posts</div>
        </div>
        <div class="content-card">
          <div class="content-card-icon">&#127909;</div>
          <div class="content-card-num"><%= contentStats.videos %></div>
          <div class="content-card-lbl">Videos</div>
        </div>
        <div class="content-card">
          <div class="content-card-icon">&#128220;</div>
          <div class="content-card-num"><%= contentStats.petitions %></div>
          <div class="content-card-lbl">Petitions</div>
        </div>
        <div class="content-card">
          <div class="content-card-icon">&#127970;</div>
          <div class="content-card-num"><%= contentStats.locals %></div>
          <div class="content-card-lbl">Local Listings</div>
        </div>
        <div class="content-card">
          <div class="content-card-icon">&#128188;</div>
          <div class="content-card-num"><%= contentStats.gigs %></div>
          <div class="content-card-lbl">Gigs</div>
        </div>
        <div class="content-card">
          <div class="content-card-icon">&#9733;</div>
          <div class="content-card-num"><%= contentStats.delegates %></div>
          <div class="content-card-lbl">Delegates</div>
        </div>
      </div>
    </div>

    <!-- Users Table -->
    <div class="section">
      <h2>Users (<%= users.length %>)</h2>
      <% if (users.length === 0) { %>
        <div class="empty">No users found.</div>
      <% } else { %>
        <div class="table-wrap"><table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Flags</th>
              <th>Joined</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(u => { %>
            <tr>
              <td><strong><%= u.displayName || u.firstName || '—' %></strong></td>
              <td style="font-size:12px; color:#a3a3a3;"><%= u.email || '—' %></td>
              <td>
                <% if (u.isAdmin) { %><span class="badge badge-admin">admin</span>
                <% } else if (u.role === 'contributor') { %><span class="badge badge-contributor">contributor</span>
                <% } else if (u.role === 'delegate') { %><span class="badge badge-delegate">delegate</span>
                <% } else { %><span class="badge badge-viewer"><%= u.role || 'viewer' %></span>
                <% } %>
              </td>
              <td>
                <% if (u.isVerified) { %><span class="badge badge-verified">verified</span><% } %>
                <% if (u.canPost) { %><span class="badge" style="background:#1a1a1a; color:#737373;">post</span><% } %>
                <% if (u.canUploadVideo) { %><span class="badge" style="background:#1a1a1a; color:#737373;">video</span><% } %>
                <% if (u.canBroadcast) { %><span class="badge" style="background:#1a1a1a; color:#737373;">broadcast</span><% } %>
              </td>
              <td style="font-size:12px; color:#525252;"><%= u.createdAt ? new Date(u.createdAt).toLocaleDateString() : '—' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table></div>
      <% } %>
    </div>
  </div>
</body>
</html>
