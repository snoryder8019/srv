function applyState(s){
  const incoming = s.view || 'overview';
  if (incoming === 'calendar' && document.getElementById('curView').textContent === 'calendar') {
    calMode = calMode === 'month' ? 'week' : calMode === 'week' ? 'day' : 'month';
  } else if (incoming === 'calendar' && s.custom?.calMode) {
    calMode = s.custom.calMode;
  }
  if (s.custom?.billsMonth) billsMonth = s.custom.billsMonth;
  if (s.custom?.focusDate !== undefined) { calFocusDate = s.custom.focusDate || null; if (document.getElementById('curView').textContent === 'calendar') renderCalendar(); }
  if (typeof s.custom?.couch === 'boolean') { couchMode = s.custom.couch; applyCouchMode(); }
  if (s.custom?.bigCalMode && ['month','week','day'].includes(s.custom.bigCalMode)) {
    bigCalMode = s.custom.bigCalMode;
    renderBigMonth();
  }
  if (typeof s.custom?.billsIncludePaid === 'boolean' && s.custom.billsIncludePaid !== billsIncludePaid) {
    billsIncludePaid = s.custom.billsIncludePaid; loadAggregate();
  }
  showView(incoming);
  document.getElementById('curBy').textContent = s.updatedBy || '—';
  if (s.message) { document.getElementById('bcastMsg').textContent = s.message; setTimeout(()=> document.getElementById('bcastMsg').textContent = '', 12000); }
  else if (s.message === '') { document.getElementById('bcastMsg').textContent = ''; }
  if (s.custom?.agentReply !== undefined) {
    agentReply = s.custom.agentReply;
    document.getElementById('agent-out').textContent = agentReply || 'Ask something from the remote.';
    renderFeeds();
    if (agentReply) showBubble(agentReply); else hideBubble();
  }
  if (s.custom?.photoMsg)   document.getElementById('photo-msg').textContent = s.custom.photoMsg;
}

// ── Topic-background images (SD-generated, cached on server) ───────────
// Fetches /api/topic-images and assigns each image URL as a CSS var on every
// element tagged with [data-topic]. Re-applies after dynamic renderers swap
// DOM, and polls so freshly-generated images (warm-up takes minutes on first
// boot) light up as they finish.
let topicMap = {};
async function loadTopicImages(){
  try {
    const r = await fetch('/superadmin/scottsGateway/api/topic-images');
    const j = await r.json();
    if (!j.ok) return;
    const next = {};
    for (const it of j.items) if (it.ready && it.url) next[it.slug] = it.url;
    topicMap = next;
    applyTopicBackgrounds();
  } catch (e) {}
}
function applyTopicBackgrounds(root){
  const scope = root || document;
  scope.querySelectorAll('[data-topic]').forEach(el => {
    const slug = el.dataset.topic;
    const url = topicMap[slug];
    if (url) el.style.setProperty('--topic-bg', `url('${url}')`);
  });
}
// Wrap dynamic renderers so backgrounds re-apply after each DOM swap.
if (typeof renderMoneyCards === 'function') {
  const _rmc = renderMoneyCards;
  renderMoneyCards = function(){ _rmc.apply(this, arguments); applyTopicBackgrounds(document.getElementById('money-stage')); };
}
if (typeof renderFeeds === 'function') {
  const _rf = renderFeeds;
  renderFeeds = function(){
    _rf.apply(this, arguments);
    // cards[3] swaps between river-flows and snow depending on season
    const flowsCard = document.querySelector('#feed-stage .feed-card[data-feed="flows"]');
    if (flowsCard) flowsCard.dataset.topic = (typeof feedData !== 'undefined' && feedData && feedData.winter && feedData.snow) ? 'snow' : 'river-flows';
    applyTopicBackgrounds(document.getElementById('feed-stage'));
  };
}

let es;
function connect(){
  es = new EventSource('/superadmin/scottsGateway/api/stream');
  es.addEventListener('open', () => { dot.classList.add('on'); connTxt.textContent = 'live'; });
  es.addEventListener('state', (ev) => { try { applyState(JSON.parse(ev.data)); } catch {} });
  es.addEventListener('tasks', (ev) => {
    try { tasks = JSON.parse(ev.data).tasks; renderTasks(); renderOverviewTasks(); } catch {}
    // A task change may have set an outcome on a past item — refresh the
    // Review card so the TV reflects the remote's last action immediately.
    loadReview();
  });
  es.addEventListener('error', () => { dot.classList.remove('on'); connTxt.textContent = 'reconnecting'; });
}

connect();
loadAggregate(); loadTasks(); loadFeeds(); loadLocal(); loadPhotos(); loadFinance(); loadInterests(); loadReview(); loadTopicImages();
setInterval(loadAggregate, 120000);
setInterval(loadFinance, 10 * 60 * 1000);
setInterval(loadFeeds, 30 * 60 * 1000);
setInterval(loadLocal, 30 * 60 * 1000);
setInterval(loadInterests, 30 * 60 * 1000);
setInterval(loadReview, 5 * 60 * 1000);
setInterval(() => { photoItems = []; loadPhotos(); }, 5 * 60 * 1000);
setInterval(loadTopicImages, 30 * 1000);

applyState(<%- JSON.stringify(state) %>);
</script>
</body>
</html>
