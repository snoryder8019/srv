async function loadFinance(){
  try { const r = await fetch('/superadmin/scottsGateway/api/finance/history?months=13'); const j = await r.json();
    if (j.ok) { financeData = j; renderMoneyCards(); }
  } catch (e) {}
}
function fmt$(n){ const v = Math.round(Number(n)||0); return (v<0?'-$':'$') + Math.abs(v).toLocaleString(); }
function pctDelta(now, prev){
  if (!prev) return null;
  const d = ((now - prev) / Math.abs(prev)) * 100;
  return { val: d, str: (d>=0?'+':'') + d.toFixed(0) + '%', up: d >= 0 };
}

function renderMoneyCards(){
  const stage = document.getElementById('money-stage');
  if (!stage) return;
  const series = financeData?.series || [];
  const tk = monthKeyToday();
  const thisMonth = series.find(r => r.month === tk) || { income:0, bills:0, paid:0 };
  const i = series.findIndex(r => r.month === tk);
  const lastMonth = i > 0 ? series[i-1] : null;
  // Last year same month: 12 months before "this month"
  const lyKey = (() => { const [y,m] = tk.split('-').map(Number); return `${y-1}-${String(m).padStart(2,'0')}`; })();
  const lastYear = series.find(r => r.month === lyKey) || null;

  // ── Card 1: 12-month bar chart ──
  const maxVal = Math.max(1, ...series.map(r => Math.max(r.income||0, r.bills||0)));
  const bars = series.slice(-12).map(r => {
    const ih = Math.max(1, (r.income / maxVal) * 100);
    const oh = Math.max(1, (r.bills  / maxVal) * 100);
    const isNow = r.month === tk;
    const [y,m] = r.month.split('-').map(Number);
    const lbl = new Date(y, m-1, 1).toLocaleDateString([], {month:'short'}).slice(0,3);
    return `<div class="barcol ${isNow?'now':''}" title="${r.month}: in $${Math.round(r.income).toLocaleString()} · out $${Math.round(r.bills).toLocaleString()}">
      <div class="bars"><div class="bar in" style="height:${ih}%"></div><div class="bar out" style="height:${oh}%"></div></div>
      <div class="lbl">${lbl}</div>
    </div>`;
  }).join('');

  // ── Card 2: vs last month ──
  const dIn  = lastMonth ? pctDelta(thisMonth.income, lastMonth.income) : null;
  const dOut = lastMonth ? pctDelta(thisMonth.bills,  lastMonth.bills)  : null;
  // ── Card 3: vs last year same month ──
  const yIn  = lastYear ? pctDelta(thisMonth.income, lastYear.income) : null;
  const yOut = lastYear ? pctDelta(thisMonth.bills,  lastYear.bills)  : null;

  // ── Card 4: itemized open (interleaved) ──
  const openItems = aggData ? [
    ...aggData.invoices.filter(x => x.status !== 'paid').map(x => ({
      kind:'in', who:x.who, brand:x.brand, brandKey:x.brandKey, label:x.clientName||'(unnamed)', amt:Number(x.total||x.amount||0), due:x.dueDate,
    })),
    ...aggData.bills.filter(x => x.status !== 'paid').map(x => ({
      kind:'out', who:x.who, brand:x.brand||'Household', brandKey:x.brandKey||'household', label:x.label||'(bill)', amt:Number(x.amount||0), due:x.dueDate,
    })),
  ].sort((a,b)=> new Date(a.due||9e15) - new Date(b.due||9e15)).slice(0, 8) : [];

  stage.innerHTML = `
    <div class="money-card tbg" data-money="chart" data-topic="bills">
      <h4>Income vs Bills <b>· 12 mo</b></h4>
      <div class="barchart">${bars || '<div style="color:#525252;font-size:calc(11px * var(--cm, 1));margin:auto">loading…</div>'}</div>
      <div class="chart-legend"><span><span class="sw" style="background:#34d399"></span>Income</span><span><span class="sw" style="background:#f87171"></span>Bills</span></div>
    </div>

    <div class="money-card tbg" data-money="vslast" data-topic="money-in">
      <h4>This month <b>vs last 30d</b></h4>
      <div class="cmp">
        <div class="cmp-row"><span class="label">Income</span><span><span class="val">${fmt$(thisMonth.income)}</span>${dIn?`<span class="delta ${dIn.up?'up':'down'}">${dIn.str}</span>`:''}</span></div>
        <div class="cmp-row"><span class="label">Last month</span><span class="val" style="color:#737373">${fmt$(lastMonth?.income||0)}</span></div>
        <div class="cmp-row"><span class="label">Bills</span><span><span class="val">${fmt$(thisMonth.bills)}</span>${dOut?`<span class="delta ${dOut.up?'down':'up'}">${dOut.str}</span>`:''}</span></div>
        <div class="cmp-row"><span class="label">Last month</span><span class="val" style="color:#737373">${fmt$(lastMonth?.bills||0)}</span></div>
        <div class="cmp-row" style="border-top:1px solid #1c1c1f;padding-top:5px"><span class="label">Net this mo</span><span class="val" style="color:${thisMonth.income-thisMonth.bills>=0?'#34d399':'#f87171'}">${fmt$(thisMonth.income-thisMonth.bills)}</span></div>
      </div>
    </div>

    <div class="money-card tbg" data-money="vsly" data-topic="money-in">
      <h4>This month <b>vs LY same month</b></h4>
      <div class="cmp">
        <div class="cmp-row"><span class="label">Income now</span><span><span class="val">${fmt$(thisMonth.income)}</span>${yIn?`<span class="delta ${yIn.up?'up':'down'}">${yIn.str}</span>`:''}</span></div>
        <div class="cmp-row"><span class="label">Income LY</span><span class="val" style="color:#737373">${fmt$(lastYear?.income||0)}</span></div>
        <div class="cmp-row"><span class="label">Bills now</span><span><span class="val">${fmt$(thisMonth.bills)}</span>${yOut?`<span class="delta ${yOut.up?'down':'up'}">${yOut.str}</span>`:''}</span></div>
        <div class="cmp-row"><span class="label">Bills LY</span><span class="val" style="color:#737373">${fmt$(lastYear?.bills||0)}</span></div>
        ${lastYear?'':'<div class="cmp-row"><span style="color:#525252;font-style:italic;font-size:calc(10px * var(--cm, 1))">No data 12 mo ago</span></div>'}
      </div>
    </div>

    <div class="money-card tbg" data-money="items" data-topic="money-out">
      <h4>Open items <b>· by due date</b></h4>
      <ul class="mm-items" style="flex:1">${
        openItems.map(x => {
          const overdue = x.due && new Date(x.due) < new Date();
          return `<li><span>${whoChip(x.who)}${brandChip(x.brand, x.brandKey)}${escapeHtml(x.label).slice(0,22)}</span><b class="${x.kind} ${overdue?'overdue':''}">${x.kind==='in'?'+':'−'}${fmt$(x.amt)}</b></li>`;
        }).join('') || '<li><span style="color:#525252;font-style:italic">No open items.</span></li>'
      }</ul>
    </div>`;
  if (!moneySlideStarted) startMoneySlide();
}
let moneySlideStarted = false, moneyIdx = 0;
function startMoneySlide(){
  moneySlideStarted = true;
  (function step(){
    const cards = document.querySelectorAll('#money-stage .money-card');
    cards.forEach((c,i) => c.classList.toggle('show', i === moneyIdx));
    moneyIdx = (moneyIdx + 1) % Math.max(1, cards.length);
    setTimeout(step, 7500);
  })();
}

// Big calendar centerpiece on overview — mode is 'month' | 'week' | 'day'
function renderBigMonth(){
  if (!aggData) return;
  const today = new Date(); today.setHours(0,0,0,0);
  const dayKey = (d) => { const x=new Date(d); return `${x.getFullYear()}-${String(x.getMonth()+1).padStart(2,'0')}-${String(x.getDate()).padStart(2,'0')}`; };
  const todayKey = dayKey(today);

  const slots = [];
  aggData.calendar.forEach(e => slots.push({ when: e.startsAt||e.date, kind:'event',label: e.title||'(event)' }));
  aggData.bookings.forEach(b => slots.push({ when: b.startAt,           kind:'book', label: (b.service||'booking') + ' · ' + (b.name||'') }));
  aggData.meetings.forEach(m => slots.push({ when: m.scheduledAt || m.createdAt, kind:'meet', label: m.title||'meeting' }));
  aggData.workdays.forEach(w => slots.push({ when: w.date,               kind:'work', label: `${w.who} work` }));
  const byDay = {};
  slots.forEach(s => { if (!s.when) return; (byDay[dayKey(s.when)] ||= []).push(s); });
  Object.values(byDay).forEach(arr => arr.sort((a,b)=> new Date(a.when)-new Date(b.when)));

  const grid = document.getElementById('bm-grid');
  const ttl = document.getElementById('bm-title');

  if (bigCalMode === 'month') {
    ttl.textContent = today.toLocaleDateString([], {month:'long', year:'numeric'}) + ' · 30 day';
    grid.style.gridTemplateColumns = 'repeat(7,1fr)';
    grid.style.gridTemplateRows = 'auto repeat(5,1fr)';
    const first = new Date(today.getFullYear(), today.getMonth(), 1);
    const start = new Date(first); start.setDate(first.getDate() - first.getDay());
    let html = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].map(l => `<div class="dow">${l}</div>`).join('');
    for (let i = 0; i < 35; i++) {
      const d = new Date(start); d.setDate(start.getDate() + i);
      const k = dayKey(d); const ev = byDay[k] || [];
      const isToday = k === todayKey;
      const otherMonth = d.getMonth() !== today.getMonth();
      html += `<div class="bmday ${isToday?'today':''} ${otherMonth?'dim':''}"><div class="num">${d.getDate()}</div>`;
      ev.slice(0, 3).forEach(s => { html += `<div class="ev ${s.kind}">${fmtT(s.when)} ${escapeHtml(s.label)}</div>`; });
      if (ev.length > 3) html += `<div class="ev" style="background:transparent;color:#525252">+${ev.length-3}</div>`;
      html += '</div>';
    }
    grid.innerHTML = html;
  } else if (bigCalMode === 'week') {
    const start = new Date(today); start.setDate(today.getDate() - today.getDay());
    const end = new Date(start); end.setDate(start.getDate()+6);
    ttl.textContent = `${start.toLocaleDateString([], {month:'short',day:'numeric'})} – ${end.toLocaleDateString([], {month:'short',day:'numeric'})} · 7 day`;
    grid.style.gridTemplateColumns = 'repeat(7,1fr)';
    grid.style.gridTemplateRows = 'auto 1fr';
    let html = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].map(l => `<div class="dow">${l}</div>`).join('');
    for (let i = 0; i < 7; i++) {
      const d = new Date(start); d.setDate(start.getDate() + i);
      const k = dayKey(d); const ev = byDay[k] || [];
      const isToday = k === todayKey;
      html += `<div class="bmday ${isToday?'today':''}"><div class="num">${d.toLocaleDateString([],{weekday:'short'}).slice(0,2)} ${d.getDate()}</div>`;
      ev.slice(0, 10).forEach(s => { html += `<div class="ev ${s.kind}">${fmtT(s.when)} ${escapeHtml(s.label)}</div>`; });
      html += '</div>';
    }
    grid.innerHTML = html;
  } else {
    const d = calFocusDate ? (() => { const [y,mo,da] = calFocusDate.split('-').map(Number); return new Date(y,mo-1,da); })() : today;
    const k = dayKey(d);
    ttl.textContent = d.toLocaleDateString([], {weekday:'long', month:'long', day:'numeric'}) + ' · 1 day';
    grid.style.gridTemplateColumns = '1fr';
    grid.style.gridTemplateRows = 'auto 1fr';
    const ev = byDay[k] || [];
    let html = `<div class="dow" style="text-align:left;padding-left:8px">${d.toDateString()}</div><div class="bmday today" style="min-height:0">`;
    if (!ev.length) html += `<div class="ev" style="color:#525252;font-style:italic">Open day — nothing scheduled.</div>`;
    ev.forEach(s => html += `<div class="ev ${s.kind}">${fmtT(s.when)} ${escapeHtml(s.label)}</div>`);
    html += '</div>';
    grid.innerHTML = html;
  }
}

