  cards[4].innerHTML = `<h3>Radar · National (CONUS)</h3>
    <div class="feed-radar"><img alt="CONUS radar loop"
      src="https://radar.weather.gov/ridge/standard/CONUS-LARGE_loop.gif?t=${bust}"
      onerror="this.replaceWith(Object.assign(document.createElement('div'),{textContent:'radar unavailable',style:'color:#525252;font-size:calc(11px * var(--cm, 1));padding:8px'}))"></div>`;
  if (feedData.winter && feedData.snow) {
    cards[5].innerHTML = `<h3>Snow · ${escapeHtml(feedData.snow.place)}</h3><div class="feed-days">${feedData.snow.daily.slice(0,10).map(d => `
      <div class="feed-day"><div class="lbl">${new Date(d.date).toLocaleDateString([],{weekday:'short'})}</div>
      <div class="ic">${d.icon}</div><div class="hi">${Math.round(d.hi)}°</div><div class="lo">${Math.round(d.lo)}°</div>
