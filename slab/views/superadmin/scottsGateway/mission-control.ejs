      <div class="ic">${d.icon}</div><div class="hi">${Math.round(d.hi)}°</div><div class="lo">${Math.round(d.lo)}°</div>
      ${(d.snowIn||0)>0?`<div class="snow">❄${d.snowIn.toFixed(1)}″</div>`:''}</div>`).join('')}</div>`;
  }
  // Cards 3/4: NOAA radar loops (KFTG = Denver/Front Range, CONUS = national)
