<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mission Control — Scott's Gateway</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  <style>
    /* ── Reset + base ──────────────────────────────────────────────────── */
    *{margin:0;padding:0;box-sizing:border-box;min-width:0;min-height:0}
    html,body{height:100vh;width:100vw;overflow:hidden}

    /* Seasonal palettes — color only, no holiday theming. Picked by month. */
    :root           { --accent:#c9a848; --accent-bg:#2a2410; --bg-top:#0c0c11; --bg-bot:#000;     --line:#1a1a1d; --ui-scale:1; --cm:1; }
    body.couch      { --cm:1.7; }  /* Couch-mode font multiplier — scales text only, layout unchanged */
    body.s-winter   { --accent:#7dd3fc; --accent-bg:#0c2438; --bg-top:#0a1218; --bg-bot:#000;     --line:#13202a; }  /* Jan–Feb cool blues */
    body.s-spring   { --accent:#86efac; --accent-bg:#0e2818; --bg-top:#0b150e; --bg-bot:#000;     --line:#162519; }  /* Mar–May fresh greens */
    body.s-summer   { --accent:#fb923c; --accent-bg:#2e1a0a; --bg-top:#161009; --bg-bot:#000;     --line:#2a1c0e; }  /* Jun–Aug warm orange */
    body.s-autumn   { --accent:#f59e0b; --accent-bg:#2c1d07; --bg-top:#180f06; --bg-bot:#000;     --line:#2a1c08; }  /* Sep–Oct amber */
    body.s-prewinter{ --accent:#c9a848; --accent-bg:#231a10; --bg-top:#100c08; --bg-bot:#000;     --line:#1f1610; }  /* Nov–Dec deep gold */

    body{font-family:'Inter',sans-serif;background:radial-gradient(ellipse at top,var(--bg-top),var(--bg-bot));color:#e5e5e5;font-size:calc(13px * var(--cm, 1));line-height:1.35}
    .frame{height:100vh;display:grid;grid-template-rows:44px 1fr 28px;gap:0}

    /* ── Header (compact) ──────────────────────────────────────────────── */
    header{display:flex;align-items:center;gap:12px;padding:0 14px;border-bottom:1px solid #1a1a1d}
    .brand{font-family:'Space Grotesk',sans-serif;font-size:calc(13px * var(--cm, 1));font-weight:600;color:#fff;letter-spacing:.02em;white-space:nowrap}
    .brand span{color:#c9a848}
    .clock{font-family:'Space Grotesk',monospace;font-size:calc(14px * var(--cm, 1));color:#c9a848;margin-left:auto}
    .miniqr{display:flex;align-items:center;gap:6px;background:#0f0f12;border:1px solid #1c1c1f;border-radius:6px;padding:3px 6px}
    .miniqr img{display:block;width:32px;height:32px;background:#fff;border-radius:3px;padding:2px}
    .miniqr .lbl{font-size:calc(9px * var(--cm, 1));color:#737373;line-height:1.2}
    .miniqr .lbl b{color:#c9a848;display:block}
    .conn{display:flex;align-items:center;gap:5px;font-size:calc(10px * var(--cm, 1));color:#737373}
    .dot{width:7px;height:7px;border-radius:50%;background:#525252}
    .dot.on{background:#34d399;box-shadow:0 0 6px #34d399}

    /* ── Main: every panel fills exactly 100% of available main height ── */
    main{position:relative;overflow:hidden}
    .panel{position:absolute;inset:0;padding:8px 12px;opacity:0;transition:opacity .25s;display:flex;flex-direction:column;gap:8px;overflow:hidden}
    .panel.show{opacity:1;z-index:2}
    h2{font-family:'Space Grotesk',sans-serif;font-size:calc(16px * var(--cm, 1));font-weight:600;color:#fff;display:flex;align-items:baseline;gap:10px;flex-shrink:0}
    h2 em{color:#c9a848;font-style:normal}
    h2 .modetag{font-size:calc(9px * var(--cm, 1));letter-spacing:.8px;text-transform:uppercase;color:#737373;font-weight:500;margin-left:auto}

    /* ── Common tiles + lists ──────────────────────────────────────────── */
    .tile{background:#101014;border:1px solid #1f1f22;border-radius:6px;padding:8px 10px;min-height:0;display:flex;flex-direction:column;justify-content:center}
    .tile h4{font-size:calc(9px * var(--cm, 1));letter-spacing:.8px;text-transform:uppercase;color:#737373;margin-bottom:3px;white-space:nowrap}
    .tile .v{font-family:'Space Grotesk',sans-serif;font-size:calc(22px * var(--cm, 1));font-weight:700;color:#fff;line-height:1}
    .tile .v.gold{color:#c9a848} .tile .v.red{color:#f87171} .tile .v.green{color:#34d399}
    .listbox{background:#0f0f12;border:1px solid #1c1c1f;border-radius:6px;padding:6px 10px;overflow:hidden;display:flex;flex-direction:column;min-height:0}
    .listbox h4{font-size:calc(9px * var(--cm, 1));letter-spacing:.8px;text-transform:uppercase;color:#737373;margin-bottom:6px;flex-shrink:0}
    .listbox ul{list-style:none;display:flex;flex-direction:column;gap:3px;overflow:hidden;flex:1}
    .listbox li{font-size:calc(11px * var(--cm, 1));color:#d4d4d4;display:flex;justify-content:space-between;gap:8px;padding:3px 0;border-bottom:1px dashed #1c1c1f;align-items:center;white-space:nowrap}
    .listbox li:last-child{border-bottom:0}
    .listbox li > span:first-child{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1}
    .listbox li .when{font-family:'Space Grotesk',monospace;font-size:calc(10px * var(--cm, 1));color:#737373;flex-shrink:0}
    .listbox li.done{opacity:.4;text-decoration:line-through}

    .chip{display:inline-block;padding:1px 6px;font-size:calc(9px * var(--cm, 1));border-radius:3px;letter-spacing:.4px;text-transform:uppercase;margin-right:5px;background:#262629;color:#a3a3a3;font-weight:500}
    .chip.scott{background:#1e3a5f;color:#7dd3fc}
    .chip.candace{background:#3f1d3a;color:#f9a8d4}
    .chip.violet{background:#2e1b4d;color:#c4b5fd}
    .chip.odin{background:#1f3a2e;color:#86efac}
    .chip.family{background:#2a2410;color:#c9a848}
    .chip.bill{background:#451a1a;color:#f87171}
    .chip.event{background:#1c1f3a;color:#a5b4fc}
    .chip.reminder{background:#15101c;color:#d8b4fe}
    .chip.appointment{background:#0c1a26;color:#7dd3fc}
    .chip.task{background:#262629;color:#a3a3a3}
    /* Brand chips — one per tenant, color-coded so eye can pick out source quickly */
    .chip.brand{background:#1f1f22;color:#a3a3a3;font-weight:600}
    .chip.brand-madladslab{background:#1c2540;color:#a5b4fc}
    .chip.brand-w2marketing,.chip.brand-w2{background:#3f1d3a;color:#f9a8d4}
    .chip.brand-slab{background:#2a2410;color:#c9a848}
    .chip.brand-opstrain{background:#0f2c1e;color:#86efac}
    .chip.brand-bih{background:#1a2a3a;color:#7dd3fc}
    .chip.brand-ps{background:#2c1e3a;color:#c4b5fd}
    .chip.brand-tripletwenty{background:#1c0f0f;color:#fb923c}
    .chip.brand-household,.chip.brand-family{background:#262629;color:#737373}

    /* Tile breakdowns — small inline rows under the big number */
    .tile .breakdown{font-size:calc(9px * var(--cm, 1));color:#737373;margin-top:5px;display:flex;flex-direction:column;gap:1px;line-height:1.3}
    .tile .breakdown .b-row{display:flex;justify-content:space-between;gap:6px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .tile .breakdown .b-row b{font-family:'Space Grotesk',monospace;font-weight:600;color:#d4d4d4}

    /* ── Overview: nested flex (column outer, row bands) ─────────────────
       Proportions are the same as the grid version: stats auto-row,
       mid-row gets 2fr, bottom-row gets 1fr. */
    .ov{display:flex;flex-direction:column;gap:6px;flex:1;min-height:0;width:100%;height:100%}
    .ov .row{display:flex;gap:6px;min-width:0}
    .ov .row > *{min-width:0;min-height:0}
    .ov .row-stats{flex-shrink:0}
    .ov .row-stats > .tile{flex:1 1 0}
    .ov .row-mid{flex:2 1 0;min-height:0}
    .ov .row-bot{flex:1 1 0;min-height:0}
    /* Mid band: feed 25% · month 50% · money 25% */
    .ov .feed-stage{flex:1 1 0;background:#0f0f12;border:1px solid #1c1c1f;border-radius:6px;position:relative;overflow:hidden}
    .ov .big-month {flex:2 1 0;background:#0f0f12;border:1px solid #1c1c1f;border-radius:6px;padding:8px 12px;display:flex;flex-direction:column;gap:6px;overflow:hidden}
    .ov .money-mini{flex:1 1 0;background:#0f0f12;border:1px solid #1c1c1f;border-radius:6px;padding:6px 10px;display:flex;flex-direction:column;gap:5px;overflow:hidden}
    /* Bottom band: next 50% · mini 25% · tasks 25% */
    .ov .next      {flex:2 1 0}
    .ov .mini-stage{flex:1 1 0;background:#0f0f12;border:1px solid #1c1c1f;border-radius:6px;position:relative;overflow:hidden}
    .ov .tasks-mini{flex:1 1 0}
    .ov .big-month h4{font-size:calc(9px * var(--cm, 1));letter-spacing:.8px;text-transform:uppercase;color:#737373;flex-shrink:0;display:flex;justify-content:space-between}
    .ov .big-month h4 b{color:var(--accent);font-weight:600}
    .money-mini{position:relative}
    .money-card{position:absolute;inset:6px 10px;opacity:0;transition:opacity .45s;display:flex;flex-direction:column;gap:5px;overflow:hidden}
    .money-card.show{opacity:1;z-index:2}
    .money-card h4{font-size:calc(9px * var(--cm, 1));letter-spacing:.8px;text-transform:uppercase;color:#737373;flex-shrink:0;display:flex;justify-content:space-between}
    .money-card h4 b{color:var(--accent);font-weight:600}
    /* Bar chart (12-month income vs bills) */
    .barchart{flex:1;display:flex;align-items:flex-end;gap:3px;padding-top:8px;min-height:0}
    .barcol{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;min-width:0}
    .barcol .bars{display:flex;gap:1px;width:100%;height:100%;align-items:flex-end;min-height:0}
    .barcol .bar{flex:1;border-radius:2px 2px 0 0;min-height:1px;position:relative}
    .barcol .bar.in{background:linear-gradient(180deg,#34d399,#0f5132)}
    .barcol .bar.out{background:linear-gradient(180deg,#f87171,#7f1d1d)}
    .barcol .lbl{font-size:calc(8px * var(--cm, 1));color:#525252;text-transform:uppercase;letter-spacing:.3px}
    .barcol.now .lbl{color:var(--accent);font-weight:600}
    .chart-legend{display:flex;gap:10px;font-size:calc(9px * var(--cm, 1));color:#a3a3a3;justify-content:center;flex-shrink:0}
    .chart-legend .sw{display:inline-block;width:8px;height:8px;border-radius:2px;margin-right:4px;vertical-align:middle}
    /* Comparison rows */
    .cmp{display:flex;flex-direction:column;gap:6px;flex:1;justify-content:center}
    .cmp-row{display:flex;justify-content:space-between;align-items:baseline;font-size:calc(11px * var(--cm, 1));color:#d4d4d4}
    .cmp-row .label{color:#a3a3a3}
    .cmp-row .val{font-family:'Space Grotesk',monospace;font-size:calc(14px * var(--cm, 1));font-weight:600;color:#fff}
    .cmp-row .delta{font-family:'Space Grotesk',monospace;font-size:calc(10px * var(--cm, 1));margin-left:6px}
    .cmp-row .delta.up{color:#34d399}.cmp-row .delta.down{color:#f87171}
    .money-mini .mline{display:flex;justify-content:space-between;font-size:calc(11px * var(--cm, 1));color:#d4d4d4;padding:2px 0;flex-shrink:0}
    .money-mini .mline b{font-family:'Space Grotesk',monospace;font-weight:600}
    .money-mini .mline b.in{color:#34d399}
    .money-mini .mline b.out{color:#f87171}
    .money-mini .mm-items, .mm-items{list-style:none;display:flex;flex-direction:column;gap:2px;overflow:hidden;flex:1;min-height:0;padding:4px 0;border-top:1px dashed #1c1c1f;border-bottom:1px dashed #1c1c1f;margin:2px 0}
    .money-mini .mm-items li{display:flex;justify-content:space-between;gap:6px;font-size:calc(10px * var(--cm, 1));color:#d4d4d4;padding:1px 0;align-items:center;white-space:nowrap;overflow:hidden}
    .money-mini .mm-items li > span{overflow:hidden;text-overflow:ellipsis;flex:1;min-width:0}
    .money-mini .mm-items li b{font-family:'Space Grotesk',monospace;font-size:calc(10px * var(--cm, 1));font-weight:600;flex-shrink:0}
    .money-mini .mm-items li b.in{color:#34d399}
    .money-mini .mm-items li b.out{color:#f87171}
    .money-mini .mm-items li b.overdue{color:#f87171}
    .money-mini .net{margin-top:auto;padding-top:5px;border-top:1px solid #1c1c1f;font-family:'Space Grotesk',sans-serif;font-size:calc(13px * var(--cm, 1));display:flex;justify-content:space-between;align-items:baseline;flex-shrink:0}

    /* Slideshow card layout — inset:0 + internal padding so the card fills the
       full grid cell with no visible bg-color frame around it. */
    .feed-card,.mini-card{position:absolute;inset:0;padding:8px 10px;opacity:0;transition:opacity .5s;display:flex;flex-direction:column;gap:6px;overflow:hidden}
    .feed-card.show,.mini-card.show{opacity:1;z-index:2}
    .feed-card h3,.mini-card h5{font-size:calc(9px * var(--cm, 1));color:#737373;letter-spacing:.8px;text-transform:uppercase;flex-shrink:0;font-family:'Space Grotesk',sans-serif;font-weight:500}
    .feed-now{display:flex;align-items:center;gap:12px;flex:1;min-height:0}
    .feed-now .icon{font-size:calc(38px * var(--cm, 1));line-height:1}
    .feed-now .big{font-family:'Space Grotesk',sans-serif;font-size:calc(36px * var(--cm, 1));font-weight:600;color:#fff;line-height:1}
    .feed-now .sub{color:#a3a3a3;font-size:calc(10px * var(--cm, 1));margin-top:3px}
    .feed-days{display:flex;gap:4px;flex:1;min-height:0;overflow:hidden}
    /* Wider forecasts (10-day, snow) use a 5×2 grid so cells don't get squished */
    .feed-days.grid{display:grid;grid-template-columns:repeat(5,1fr);grid-template-rows:repeat(2,1fr);gap:4px;flex:1;min-height:0;overflow:hidden}
    .feed-days.grid .feed-day{flex:none;min-height:0}
    .feed-day{background:#141417;border:1px solid #262629;border-radius:4px;padding:4px 5px;flex:1;text-align:center;display:flex;flex-direction:column;justify-content:center;min-width:0;overflow:hidden}
    .feed-day .lbl{font-size:calc(8px * var(--cm, 1));color:#737373;letter-spacing:.3px;text-transform:uppercase}
    .feed-day .ic{font-size:calc(14px * var(--cm, 1));line-height:1.1}
    .feed-day .hi{font-family:'Space Grotesk',sans-serif;font-size:calc(12px * var(--cm, 1));color:#fff;font-weight:600;line-height:1.1}
    .feed-day .lo{font-size:calc(9px * var(--cm, 1));color:#737373;line-height:1}
    .feed-day .snow{color:#7dd3fc;font-size:calc(8px * var(--cm, 1));line-height:1}
    .feed-radar{flex:1;min-height:0;display:flex;align-items:center;justify-content:center;background:#0a0a0c;border:1px solid #1c1c1f;border-radius:4px;overflow:hidden}
    .feed-radar img{max-width:100%;max-height:100%;width:auto;height:auto;object-fit:contain;display:block}
    .flow-list{display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:4px;flex:1;overflow:hidden}
    .flow-card{background:#141417;border:1px solid #262629;border-radius:4px;padding:4px 6px;display:flex;flex-direction:column;justify-content:center;min-width:0;overflow:hidden}
    .flow-card .nm{font-size:calc(8px * var(--cm, 1));color:#737373;letter-spacing:.3px;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .flow-card .cfs{font-family:'Space Grotesk',sans-serif;font-size:calc(14px * var(--cm, 1));color:#7dd3fc;font-weight:600;line-height:1.1}
    .flow-card .ft{font-size:calc(9px * var(--cm, 1));color:#a3a3a3}
    .agent-mini{font-size:calc(11px * var(--cm, 1));color:#d4d4d4;line-height:1.45;flex:1;overflow:hidden}
    .ifeed{list-style:none;display:flex;flex-direction:column;gap:3px;overflow:hidden;flex:1;min-height:0}
    .ifeed li{display:grid;grid-template-columns:auto 1fr auto;gap:6px;font-size:calc(10px * var(--cm, 1));line-height:1.3;padding:2px 0;border-bottom:1px dashed #1c1c1f;align-items:baseline;overflow:hidden}
    .ifeed li:last-child{border-bottom:0}
    .ifeed .src{color:var(--accent);font-weight:600;font-size:calc(9px * var(--cm, 1));text-transform:uppercase;letter-spacing:.3px;white-space:nowrap;max-width:90px;overflow:hidden;text-overflow:ellipsis}
    .ifeed .ttl{color:#d4d4d4;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .ifeed .ago{color:#525252;font-family:'Space Grotesk',monospace;font-size:calc(9px * var(--cm, 1));white-space:nowrap}
    .agent-mini p{margin-bottom:5px}
    .agent-mini ul{list-style:none;padding-left:0;margin:4px 0;display:flex;flex-direction:column;gap:3px}
    .agent-mini li{position:relative;padding-left:14px;line-height:1.4}
    .agent-mini li::before{content:'';position:absolute;left:0;top:7px;width:5px;height:5px;background:var(--accent);border-radius:50%}
    .agent-mini strong{color:#fff;font-weight:600}
    .agent-mini em{color:var(--accent);font-style:normal}

    /* Mini calendar */
    .mini-month{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;flex:1;min-height:0}
    .mini-month .mdow{font-size:calc(8px * var(--cm, 1));color:#404040;text-align:center;text-transform:uppercase}
    .mini-month .mday{background:#141417;border-radius:2px;display:flex;align-items:center;justify-content:center;font-size:calc(9px * var(--cm, 1));color:#a3a3a3;position:relative}
    .mini-month .mday.today{background:var(--accent-bg);color:var(--accent);font-weight:600;border:1px solid var(--accent)}
    .mini-month .mday.dim{opacity:.3}
    .mini-month .mday.has::after{content:'';position:absolute;bottom:2px;width:3px;height:3px;border-radius:50%;background:var(--accent)}

    /* Big month grid (overview's centerpiece) */
    .big-month-grid{display:grid;grid-template-columns:repeat(7,1fr);grid-template-rows:auto repeat(5,1fr);gap:4px;flex:1;min-height:0;overflow:hidden}
    .big-month-grid .dow{font-size:calc(10px * var(--cm, 1));color:#737373;text-align:center;text-transform:uppercase;letter-spacing:.5px;font-weight:500}
    .big-month-grid .bmday{background:#141417;border:1px solid #1f1f22;border-radius:4px;padding:4px 6px;display:flex;flex-direction:column;gap:2px;overflow:hidden;min-height:0}
    .big-month-grid .bmday.today{background:var(--accent-bg);border-color:var(--accent)}
    .big-month-grid .bmday.dim{opacity:.4}
    .big-month-grid .bmday .num{font-family:'Space Grotesk',sans-serif;font-size:calc(13px * var(--cm, 1));font-weight:600;color:#a3a3a3;line-height:1}
    .big-month-grid .bmday.today .num{color:var(--accent)}
    .big-month-grid .bmday .ev{padding:1px 4px;border-radius:2px;background:#1c1c1f;font-size:calc(9px * var(--cm, 1));color:#d4d4d4;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;line-height:1.3}
    .big-month-grid .bmday .ev.work{background:#0f1f15;color:#86efac;border-left:2px solid #34d399}
    .big-month-grid .bmday .ev.book{background:#15101c;color:#d8b4fe;border-left:2px solid #a78bfa}
    .big-month-grid .bmday .ev.meet{background:#0c1a26;color:#7dd3fc;border-left:2px solid #38bdf8}
    .big-month-grid .bmday .ev.event{background:#2a2410;color:var(--accent);border-left:2px solid var(--accent)}
    .mini-week{display:flex;flex-direction:column;gap:3px;flex:1;overflow:hidden}
    .mini-week .mw-day{background:#141417;border-radius:3px;padding:3px 6px;display:flex;justify-content:space-between;font-size:calc(10px * var(--cm, 1))}
    .mini-week .mw-day.today{background:#1a1610;border:1px solid #c9a848;color:#c9a848}
    .mini-week .mw-day .ct{color:#737373;font-family:'Space Grotesk',monospace;font-size:calc(9px * var(--cm, 1))}
    .mini-day{display:flex;flex-direction:column;gap:3px;flex:1;overflow:hidden}
    .mini-day .mdh{font-family:'Space Grotesk',sans-serif;font-size:calc(11px * var(--cm, 1));color:#c9a848;margin-bottom:2px}
    .mini-day .mditem{background:#141417;border-radius:3px;padding:3px 6px;font-size:calc(10px * var(--cm, 1));color:#d4d4d4;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .mini-day .mditem .t{font-family:'Space Grotesk',monospace;font-size:calc(9px * var(--cm, 1));color:#737373;margin-right:4px}

    /* Calendar panel (cycled) */
    .month{display:grid;grid-template-columns:repeat(7,1fr);grid-template-rows:auto repeat(5,1fr);gap:3px;flex:1;min-height:0;overflow:hidden}
    .month .dow{font-size:calc(9px * var(--cm, 1));color:#525252;text-align:center;text-transform:uppercase;letter-spacing:.4px}
    .day-cell{background:#101014;border:1px solid #1f1f22;border-radius:4px;padding:3px 4px;display:flex;flex-direction:column;gap:2px;overflow:hidden;min-height:0}
    .day-cell.today{border-color:#c9a848;background:#15110a}
    .day-cell.dim{opacity:.35}
    .day-cell .num{font-size:calc(10px * var(--cm, 1));font-weight:600;color:#a3a3a3;line-height:1}
    .day-cell.today .num{color:#c9a848}
    .day-cell .ev{padding:1px 4px;border-radius:2px;background:#1c1c1f;font-size:calc(9px * var(--cm, 1));color:#d4d4d4;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;line-height:1.3}
    .day-cell .ev.work{background:#0f1f15;color:#86efac;border-left:2px solid #34d399}
    .day-cell .ev.book{background:#15101c;color:#d8b4fe;border-left:2px solid #a78bfa}
    .day-cell .ev.meet{background:#0c1a26;color:#7dd3fc;border-left:2px solid #38bdf8}
    .day-cell .ev.event{background:#2a2410;color:#c9a848;border-left:2px solid #c9a848}

    /* Money split panel */
    .money-split{display:grid;grid-template-columns:1fr 1fr;gap:6px;flex:1;min-height:0}
    .money-col{background:#0f0f12;border:1px solid #1c1c1f;border-radius:6px;padding:8px 10px;display:flex;flex-direction:column;gap:5px;min-height:0;overflow:hidden}
    .money-col.in{border-color:#1a3f2a}
    .money-col.out{border-color:#3f1a1a}
    .money-head{display:flex;justify-content:space-between;align-items:baseline;flex-shrink:0}
    .money-head span{font-family:'Space Grotesk',sans-serif;font-size:calc(12px * var(--cm, 1));color:#fff;font-weight:500}
    .money-head b{font-family:'Space Grotesk',sans-serif;font-size:calc(18px * var(--cm, 1));font-weight:700}
    .money-sub{font-size:calc(9px * var(--cm, 1));color:#737373;border-bottom:1px solid #1f1f22;padding-bottom:4px;flex-shrink:0}
    .billnav{display:flex;align-items:center;gap:8px;font-size:calc(11px * var(--cm, 1));flex-shrink:0;flex-wrap:wrap}
    .billnav .mtitle{font-family:'Space Grotesk',sans-serif;font-size:calc(13px * var(--cm, 1));color:#fff}
    .billnav .totals{display:flex;gap:10px;font-size:calc(10px * var(--cm, 1));color:#a3a3a3;margin-left:auto}
    .billnav .totals b{font-family:'Space Grotesk',monospace;color:#c9a848;font-weight:600}

    /* Local events (cards) */
    .local-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));grid-auto-rows:minmax(0,1fr);gap:6px;flex:1;min-height:0;overflow:hidden}
    .ecard{background:#101014;border:1px solid #1f1f22;border-radius:6px;overflow:hidden;display:flex;flex-direction:column;min-height:0}
    .ecard .img{flex:1;background:#1a1a1d center/cover no-repeat;min-height:60px}
    .ecard .img.placeholder{display:flex;align-items:center;justify-content:center;font-size:calc(20px * var(--cm, 1));color:#262629}
    .ecard .body{padding:5px 8px;flex-shrink:0}
    .ecard .src{font-size:calc(8px * var(--cm, 1));color:#c9a848;letter-spacing:.5px;text-transform:uppercase}
    .ecard .ttl{font-size:calc(11px * var(--cm, 1));font-weight:600;color:#fff;line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .ecard .when{font-family:'Space Grotesk',monospace;font-size:calc(9px * var(--cm, 1));color:#a3a3a3}

    /* Agent + photo */
    .agent-out{font-size:calc(13px * var(--cm, 1));line-height:1.5;color:#d4d4d4;background:#0f0f12;border:1px solid #1c1c1f;border-radius:6px;padding:14px;flex:1;overflow:auto;white-space:pre-wrap}
    .photo-msg{font-size:calc(14px * var(--cm, 1));color:#c9a848;font-style:italic;text-align:center;padding:40px}
    .photo-stage{position:relative;flex:1;background:#000;border-radius:6px;overflow:hidden;min-height:0}
    .photo-slide{position:absolute;inset:0;background:#000 center/contain no-repeat;opacity:0;transition:opacity 1s}
    .photo-slide.show{opacity:1}
    .photo-caption{position:absolute;bottom:8px;left:12px;right:12px;background:rgba(0,0,0,.55);backdrop-filter:blur(6px);color:#e5e5e5;padding:6px 10px;border-radius:4px;font-size:calc(11px * var(--cm, 1));display:flex;justify-content:space-between;gap:10px}
    .photo-caption .who{color:#c9a848;font-weight:600}

    /* Floating agent bubble (bottom-right overlay) */
    .agent-bubble{position:absolute;right:14px;bottom:14px;max-width:38%;max-height:48%;background:#0f0f12;border:1px solid var(--accent);border-radius:10px;padding:12px 14px;box-shadow:0 4px 24px rgba(0,0,0,.55), 0 0 24px var(--accent-bg);display:flex;flex-direction:column;gap:6px;z-index:10;overflow:hidden;opacity:0;pointer-events:none;transform:translateY(12px);transition:opacity .35s ease, transform .35s ease}
    .agent-bubble.show{opacity:1;pointer-events:auto;transform:none}
    .agent-bubble .ab-head{display:flex;align-items:center;justify-content:space-between;font-family:'Space Grotesk',sans-serif;font-size:calc(10px * var(--cm, 1));text-transform:uppercase;letter-spacing:.8px;color:var(--accent);flex-shrink:0}
    .agent-bubble .ab-close{background:none;border:0;color:#737373;cursor:pointer;font-size:calc(14px * var(--cm, 1));padding:0 4px;line-height:1}
    .agent-bubble .ab-close:hover{color:#f87171}
    .agent-bubble .ab-body{font-size:calc(12px * var(--cm, 1));line-height:1.45;color:#d4d4d4;white-space:pre-wrap;overflow-y:auto;flex:1;min-height:0}
    @keyframes bubbleIn{from{transform:translateY(12px);opacity:0}to{transform:none;opacity:1}}
    @media (min-width:1900px){.agent-bubble{max-width:32%;padding:16px 18px} .agent-bubble .ab-body{font-size:calc(14px * var(--cm, 1))}}
    @media (min-width:2600px){.agent-bubble{max-width:28%;padding:20px 22px} .agent-bubble .ab-body{font-size:calc(16px * var(--cm, 1))}}

    /* ── Topic-background images (SD-generated, cached server-side) ─────
       Each card/panel that opts in sets --topic-bg to a URL; a ::before
       pseudo-element renders it as a soft underlay. Panels stay transparent
       (the original look); cards get a hint of imagery without competing
       with foreground text. */
    /* Cards already have position:absolute — we do NOT add position:relative
       here (that would collapse them to natural size). The ::before anchors
       to the card's own positioning. Children get z-index:1 so they sit on
       top of the underlay. */
    .feed-card.tbg::before, .money-card.tbg::before, .mini-card.tbg::before{
      content:'';position:absolute;inset:0;background-image:var(--topic-bg,none);
      background-size:cover;background-position:center;opacity:.16;
      pointer-events:none;transition:opacity .6s;z-index:0;border-radius:inherit;
    }
    .feed-card.tbg > *, .money-card.tbg > *, .mini-card.tbg > *{position:relative;z-index:1}

    /* Footer */
    footer{padding:0 14px;font-size:calc(10px * var(--cm, 1));color:#525252;border-top:1px solid #1a1a1d;display:flex;justify-content:space-between;align-items:center}
    .msg{font-size:calc(12px * var(--cm, 1));color:#c9a848;font-style:italic}

    /* ── Ultrawide bumps ──────────────────────────────────────────────── */
    @media (min-width:1900px){
      body{font-size:calc(14px * var(--cm, 1))}
      .frame{grid-template-rows:52px 1fr 32px}
      .brand{font-size:calc(15px * var(--cm, 1))}
      .clock{font-size:calc(18px * var(--cm, 1))}
      .miniqr img{width:42px;height:42px}
      h2{font-size:calc(20px * var(--cm, 1))}
      .tile .v{font-size:calc(28px * var(--cm, 1))}
      .feed-now .big{font-size:calc(48px * var(--cm, 1))}
      .feed-now .icon{font-size:calc(48px * var(--cm, 1))}
      .feed-day .hi{font-size:calc(14px * var(--cm, 1))}
      .listbox li{font-size:calc(13px * var(--cm, 1))}
      .listbox li .when{font-size:calc(11px * var(--cm, 1))}
      .day-cell .num{font-size:calc(11px * var(--cm, 1))}
      .day-cell .ev{font-size:calc(10px * var(--cm, 1))}
    }
    @media (min-width:2600px){
      body{font-size:calc(16px * var(--cm, 1))}
      .frame{grid-template-rows:64px 1fr 36px}
      .brand{font-size:calc(18px * var(--cm, 1))}
      .clock{font-size:calc(22px * var(--cm, 1))}
      .miniqr img{width:54px;height:54px}
      h2{font-size:calc(24px * var(--cm, 1))}
      .tile .v{font-size:calc(36px * var(--cm, 1))}
      .feed-now .big{font-size:calc(60px * var(--cm, 1))}
      .feed-now .icon{font-size:calc(60px * var(--cm, 1))}
      .feed-day .hi{font-size:calc(16px * var(--cm, 1))}
      .listbox li{font-size:calc(15px * var(--cm, 1))}
      .day-cell .num{font-size:calc(13px * var(--cm, 1))}
      .day-cell .ev{font-size:calc(11px * var(--cm, 1))}
    }
  </style>
</head>
<body>
  <div class="frame">
    <header>
      <div class="brand">Wallace <span>Mission Control</span></div>
      <a class="miniqr" id="miniqrLink" href="/superadmin/scottsGateway/remote/scan" target="_blank" rel="noopener" title="Click to open remote in a new tab — or scan with a phone" style="text-decoration:none;cursor:pointer">
        <img id="remoteQr" alt="remote">
        <div class="lbl"><b>Remote</b>tap or scan</div>
      </a>
      <div class="clock" id="clock">--:--</div>
      <div class="conn"><span class="dot" id="dot"></span><span id="connTxt">…</span></div>
    </header>

    <main id="stage">
      <!-- OVERVIEW: dense dashboard, everything visible -->
      <section class="panel" data-view="overview" data-topic="overview">
        <div class="ov">
          <div class="row row-stats">
            <div class="tile"><h4 id="ov-income-label">Income · this mo</h4><div class="v green" id="ov-income">—</div><div class="breakdown" id="ov-income-breakdown"></div></div>
            <div class="tile"><h4>Invoices outstanding</h4><div class="v gold" id="ov-invoices">—</div><div class="breakdown" id="ov-inv-breakdown"></div></div>
            <div class="tile"><h4>Chores validated <span style="color:#525252;font-size:calc(8px * var(--cm, 1))">· this mo</span></h4><div class="v" id="ov-chores">—</div><div class="breakdown" id="ov-chores-breakdown"></div></div>
            <div class="tile"><h4 id="ov-bills-label">Bills · this mo</h4><div class="v red" id="ov-bills">—</div><div class="breakdown" id="ov-bills-breakdown"></div></div>
          </div>
          <div class="row row-mid">
            <div class="feed-stage" id="feed-stage">
              <div class="feed-card tbg" data-feed="now"    data-topic="weather-now"></div>
              <div class="feed-card tbg" data-feed="3day"   data-topic="weather-3day"></div>
              <div class="feed-card tbg" data-feed="10day"  data-topic="weather-10day"></div>
              <div class="feed-card"     data-feed="radar-local"    data-topic="weather-radar-local"></div>
              <div class="feed-card"     data-feed="radar-national" data-topic="weather-radar-national"></div>
              <div class="feed-card tbg" data-feed="flows"  data-topic="river-flows"></div>
              <div class="feed-card tbg" data-feed="interests" data-topic="interests"></div>
              <div class="feed-card tbg" data-feed="review" data-topic="review"></div>
              <div class="feed-card tbg" data-feed="agent"  data-topic="agent"></div>
            </div>
            <div class="big-month">
              <h4>Calendar · <b id="bm-title">—</b></h4>
              <div class="big-month-grid" id="bm-grid"></div>
            </div>
            <div class="money-mini" id="money-stage">
              <!-- Cards injected by renderMoneyCards() — rotated by startMoneySlide() -->
            </div>
          </div><!-- /row-mid -->
          <div class="row row-bot">
            <div class="listbox next">
              <h4>Next up</h4>
              <ul id="ov-next"></ul>
            </div>
            <div class="mini-stage" id="mini-stage"></div>
            <div class="listbox tasks-mini">
              <h4>Kids <em style="color:#525252;font-weight:400">· Odin & Violet</em></h4>
              <ul id="ov-tasks"></ul>
            </div>
          </div><!-- /row-bot -->
        </div>
        <div class="agent-bubble" id="agentBubble">
          <div class="ab-head">
            <span>🤖 Wallace</span>
            <button class="ab-close" onclick="hideBubble()" title="dismiss">×</button>
          </div>
          <div class="ab-body" id="agentBubbleBody"></div>
        </div>
      </section>

      <!-- CALENDAR (tap-to-cycle: month / week / day) -->
      <section class="panel" data-view="calendar" data-topic="calendar">
        <h2>Family <em>Calendar</em><span class="modetag" id="cal-modetag">month</span><span id="cal-focus-tag" style="font-size:calc(12px * var(--cm, 1));color:var(--accent);letter-spacing:.4px;font-weight:500;display:none"></span></h2>
        <div id="cal-stage" style="flex:1;min-height:0;display:flex;flex-direction:column"></div>
      </section>

      <!-- MONEY split (Bills out / Invoices in) -->
      <section class="panel" data-view="bills" data-topic="bills">
        <h2>Money <em>· in / out</em><span class="modetag" id="bill-modetag">unpaid only</span></h2>
        <div class="billnav">
          <div class="mtitle" id="bill-mtitle">—</div>
          <div class="totals">
            <span>net: <b id="bill-net">$0</b></span>
          </div>
        </div>
        <div class="money-split">
          <div class="money-col in">
            <div class="money-head"><span>Invoices (in)</span><b class="v green" id="inv-open">$0</b></div>
            <div class="money-sub"><span id="inv-count">0</span> open · month total $<span id="inv-total">0</span></div>
            <div class="listbox" style="border:0;padding:0;flex:1;min-height:0"><ul id="inv-list"></ul></div>
          </div>
          <div class="money-col out">
            <div class="money-head"><span>Household (out)</span><b class="v red" id="bills-open">$0</b></div>
            <div class="money-sub"><span id="bills-count">0</span> open · month total $<span id="bills-total">0</span></div>
            <div class="listbox" style="border:0;padding:0;flex:1;min-height:0"><ul id="bills-list"></ul></div>
          </div>
        </div>
      </section>

      <section class="panel" data-view="tasks" data-topic="tasks">
        <h2>Family <em>Tasks</em></h2>
        <div class="listbox" style="flex:1;min-height:0"><ul id="task-list"><li>Loading…</li></ul></div>
      </section>

      <section class="panel" data-view="meetings" data-topic="meetings">
        <h2>Active <em>Meetings</em></h2>
        <div class="listbox" style="flex:1;min-height:0"><ul id="meet-list"></ul></div>
      </section>

      <section class="panel" data-view="local" data-topic="local">
        <h2>Greeley <em>· UNC · Downtown</em></h2>
        <div class="local-grid" id="local-grid"><div style="color:#525252">Loading…</div></div>
      </section>

      <section class="panel" data-view="agent" data-topic="agent">
        <h2>Agent <em>Reply</em></h2>
        <div class="agent-out" id="agent-out">Ask something from the remote.</div>
      </section>

      <section class="panel" data-view="photo" data-topic="photo">
        <h2>Family <em>Display</em><span class="modetag" id="photo-modetag">mission-control folder</span></h2>
        <div class="photo-stage" id="photo-stage">
          <div class="photo-msg" id="photo-msg" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center">Loading…</div>
        </div>
      </section>
    </main>

    <footer>
      <span>view: <b id="curView">overview</b></span>
      <span class="msg" id="bcastMsg"></span>
      <span>last touch: <b id="curBy">—</b></span>
    </footer>
  </div>

<script>
function escapeHtml(s){ return String(s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function whoChip(w){ const k = (w||'family').toLowerCase(); return `<span class="chip ${k}">${escapeHtml(w||'family')}</span>`; }
function brandChip(brand, brandKey){
  if (!brand) return '';
  const k = (brandKey || brand).toLowerCase().replace(/[^a-z0-9]/g,'');
  return `<span class="chip brand brand-${k}">${escapeHtml(brand)}</span>`;
}
function kindChip(k){ return `<span class="chip ${(k||'task').toLowerCase()}">${escapeHtml(k||'task')}</span>`; }
const fmtFull = (x) => x ? new Date(x).toLocaleString([], {month:'short', day:'numeric', hour:'2-digit', minute:'2-digit'}) : 'no date';
const fmtT = (x) => x ? new Date(x).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) : '';

// Mini QR
(function(){ const url = `${location.protocol}//${location.host}/superadmin/scottsGateway/remote/scan`;
  document.getElementById('remoteQr').src = 'https://api.qrserver.com/v1/create-qr-code/?size=120x120&margin=0&data=' + encodeURIComponent(url);
})();

// Seasonal palette — picks one of 5 themes by month
(function applySeason(){
  const m = new Date().getMonth(); // 0=Jan
  let cls = 's-prewinter';
  if (m === 0 || m === 1) cls = 's-winter';
  else if (m >= 2 && m <= 4) cls = 's-spring';
  else if (m >= 5 && m <= 7) cls = 's-summer';
  else if (m >= 8 && m <= 9) cls = 's-autumn';
  document.body.classList.add(cls);
})();

const clock = document.getElementById('clock');
function tick(){ clock.textContent = new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}); }
tick(); setInterval(tick, 30000);

const dot = document.getElementById('dot');
const connTxt = document.getElementById('connTxt');
const panels = [...document.querySelectorAll('main .panel')];

let calMode = 'month';
let calFocusDate = null;          // 'YYYY-MM-DD' — when remote taps a day
let billsMonth = monthKeyToday();
let billsIncludePaid = false;
let couchMode = false;            // remote toggle — toggles body.couch, which bumps --cm
let bigCalMode = 'month';         // 'month' | 'week' | 'day' — toggled from remote
function applyCouchMode(){ document.body.classList.toggle('couch', !!couchMode); }
function monthKeyToday(){ const x=new Date(); return `${x.getFullYear()}-${String(x.getMonth()+1).padStart(2,'0')}`; }
function prettyMonth(k){ const [y,m]=k.split('-').map(Number); return new Date(y, m-1, 1).toLocaleDateString([], {month:'long', year:'numeric'}); }

function showView(view){
  document.getElementById('curView').textContent = view;
  let matched = false;
  panels.forEach(p => { const on = p.dataset.view === view; p.classList.toggle('show', on); if (on) matched = true; });
  if (!matched) panels[0].classList.add('show');
  if (view === 'calendar') renderCalendar();
  if (view === 'bills') renderBills();
  if (view === 'local') loadLocal();
  if (view === 'photo') loadPhotos();
}

let aggData = null, feedData = null, agentReply = '', tasks = [];

async function loadAggregate(){
  try {
    const r = await fetch('/superadmin/scottsGateway/api/aggregate?days=180&paid=' + (billsIncludePaid?'1':'0'));
    const j = await r.json();
    if (!j.ok) return;
    aggData = j.data;
    renderOverview(); renderCalendar(); renderBills(); renderMeetings(); renderMiniCalendar();
  } catch (e) {}
}
async function loadTasks(){
  try { const r = await fetch('/superadmin/scottsGateway/api/tasks'); const j = await r.json();
    if (j.ok) { tasks = j.tasks; renderTasks(); renderOverviewTasks(); }
  } catch (e) {}
}
async function loadFeeds(){
  try { const r = await fetch('/superadmin/scottsGateway/api/feeds'); const j = await r.json();
    if (j.ok) { feedData = j; renderFeeds(); }
  } catch (e) {}
}

function renderOverview(){
  if (!aggData) return;

  // ── Month bookkeeping (used by tiles) ──
  const now = new Date();
  const monthLabel = now.toLocaleDateString([], { month:'short' });
  const monthKeyNow = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
  const prevDate = new Date(now.getFullYear(), now.getMonth() - 1, 1);
  const monthKeyPrev = `${prevDate.getFullYear()}-${String(prevDate.getMonth()+1).padStart(2,'0')}`;
  const inMonth = (d, key) => {
    if (!d) return false;
    const x = new Date(d);
    return `${x.getFullYear()}-${String(x.getMonth()+1).padStart(2,'0')}` === key;
  };
  const monthRow = (aggData.monthly || []).find(r => r.month === monthKeyNow) || null;
  const prevRow  = (aggData.monthly || []).find(r => r.month === monthKeyPrev) || null;

  // ── Tile 1: this-month income (paid invoices) across brands ──
  const paidThisMonth = (i) => i.status === 'paid' && (inMonth(i.paidAt, monthKeyNow) || (!i.paidAt && inMonth(i.dueDate, monthKeyNow)));
  const incomePaidThis = aggData.invoices
    .filter(paidThisMonth)
    .reduce((s, i) => s + Number(i.total || i.amount || 0), 0);
  const incomeByBrand = {};
  aggData.invoices.filter(paidThisMonth).forEach(i => {
    const key = i.brand || '—';
    if (!incomeByBrand[key]) incomeByBrand[key] = { brand:key, brandKey:i.brandKey, total:0, count:0 };
    incomeByBrand[key].total += Number(i.total||i.amount||0); incomeByBrand[key].count++;
  });
  document.getElementById('ov-income-label').innerHTML = `Income · ${escapeHtml(monthLabel)}`;
  document.getElementById('ov-income').textContent = '$' + Math.round(incomePaidThis).toLocaleString();

  // ── Tile 2: invoices outstanding across all connected brands ──
  const invOpen = (aggData.monthly || []).reduce((s, r) => s + (r.invoiceUnpaidTotal||0), 0);
  document.getElementById('ov-invoices').textContent = '$' + Math.round(invOpen).toLocaleString();

  // ── Tile 4: bills this month vs last month delta ──
  const billsThis = monthRow?.billTotal || 0;
  const billsPrev = prevRow?.billTotal  || 0;
  const billsDelta = billsThis - billsPrev;
  const billsPct = billsPrev ? ((billsDelta / Math.abs(billsPrev)) * 100) : null;
  document.getElementById('ov-bills-label').innerHTML = `Bills · ${escapeHtml(monthLabel)}`;
  document.getElementById('ov-bills').textContent = '$' + Math.round(billsThis).toLocaleString();

  // ── Breakdown of open invoices / open bills + income by brand ──
  const invByBrand = {};
  aggData.invoices.filter(i => i.status !== 'paid').forEach(i => {
    const key = i.brand || '—'; const amt = Number(i.total||i.amount||0);
    if (!invByBrand[key]) invByBrand[key] = { brand: key, brandKey: i.brandKey, total: 0, count: 0 };
    invByBrand[key].total += amt; invByBrand[key].count++;
  });
  const billsByBrand = {};
  aggData.bills.filter(b => inMonth(b.dueDate, monthKeyNow)).forEach(b => {
    const key = b.brand || b.who || 'Household';
    if (!billsByBrand[key]) billsByBrand[key] = { brand: key, brandKey: (key||'household').toLowerCase(), total: 0, count: 0 };
    billsByBrand[key].total += Number(b.amount||0); billsByBrand[key].count++;
  });
  const rowsHtml = (obj) => Object.values(obj).sort((a,b)=> b.total - a.total).slice(0, 4).map(r =>
    `<div class="b-row" title="${escapeHtml(r.brand)} · ${r.count} item${r.count>1?'s':''}">${brandChip(r.brand, r.brandKey)}<b>$${Math.round(r.total).toLocaleString()}</b></div>`
  ).join('') || `<div class="b-row"><span style="color:#525252;font-style:italic">none</span></div>`;
  document.getElementById('ov-income-breakdown').innerHTML = rowsHtml(incomeByBrand);
  document.getElementById('ov-inv-breakdown').innerHTML   = rowsHtml(invByBrand);

  // Bills breakdown shows brand totals AND the +/- vs last month suggestion line
  let billsBreakdownHtml = rowsHtml(billsByBrand);
  if (billsPct !== null && billsPrev > 0) {
    const up = billsDelta > 0;
    const color = up ? '#f87171' : '#34d399';
    const sym = up ? '▲' : '▼';
    const help = up
      ? (billsPct >= 10 ? 'higher than last month — review subscriptions?' : 'a touch higher')
      : (billsPct <= -10 ? 'lower — nice trim' : 'about even');
    billsBreakdownHtml += `<div class="b-row" style="border-top:1px solid #1f1f22;margin-top:3px;padding-top:3px"><span style="color:${color};font-size:calc(9px * var(--cm, 1))">${sym} ${Math.abs(Math.round(billsPct))}% vs ${escapeHtml(prevDate.toLocaleDateString([],{month:'short'}))}</span><b style="color:${color}">${up?'+':'-'}$${Math.abs(Math.round(billsDelta)).toLocaleString()}</b></div>`;
    billsBreakdownHtml += `<div class="b-row" style="color:#525252;font-size:calc(8px * var(--cm, 1));font-style:italic">${escapeHtml(help)}</div>`;
  }
  document.getElementById('ov-bills-breakdown').innerHTML = billsBreakdownHtml;

  // ── Tile 3: chores validated this month (kid tasks completed) ──
  renderChoresTile();

  renderMoneyCards();

  // ── Upcoming-only "Next up" list — drop past items ──
  const cutoff = new Date(now.getFullYear(), now.getMonth(), now.getDate()).getTime();
  const future = (when) => when && new Date(when).getTime() >= cutoff - 60*60*1000;
  const merged = [
    ...aggData.calendar.filter(e => future(e.startsAt||e.date)).map(e=>({ when: e.startsAt||e.date, who: e.who, brand: e.brand, brandKey: e.brandKey, what: e.title||'(event)', kind:'event' })),
    ...aggData.bookings.filter(b => future(b.startAt)).map(b=>({ when: b.startAt, who: b.who, brand: b.brand, brandKey: b.brandKey, what: (b.service||'booking'), kind:'booking' })),
    ...aggData.meetings.filter(m => future(m.scheduledAt || (m.status === 'active' ? m.createdAt : null))).map(m=>({
      when: m.scheduledAt || (m.status === 'active' ? m.createdAt : null) || m.createdAt,
      who: m.who, brand: m.brand, brandKey: m.brandKey,
      what: (m.title||'meeting') +
            (!m.scheduledAt && m.status==='active' ? ' · live now' : '') +
            (m.durationMinutes?` · ${m.durationMinutes}min`:'') +
            (m.participantCount?` · 👥${m.participantCount}`:'') +
            (m.recording?' · 🔴 rec':'') +
            (m.transcribing?' · 📝 transcribing':''),
      kind:'meeting',
    })),
  ].sort((a,b)=> new Date(a.when||0)-new Date(b.when||0)).slice(0, 9);
  document.getElementById('ov-next').innerHTML = merged.map(x =>
    `<li><span>${whoChip(x.who)}${escapeHtml(x.what)}</span><span class="when">${fmtFull(x.when)}</span></li>`
  ).join('') || '<li><span style="color:#525252;font-style:italic">Nothing upcoming.</span></li>';

  renderBigMonth();
}

function renderChoresTile(){
  const now = new Date();
  const monthKeyNow = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
  const KIDS = ['Violet','Odin'];
  const inMonthDate = (d) => {
    if (!d) return false;
    const x = new Date(d);
    return `${x.getFullYear()}-${String(x.getMonth()+1).padStart(2,'0')}` === monthKeyNow;
  };
  // chores = tasks (non-bill) for kids, completed or outcome=attended this month
  const choreList = (tasks || []).filter(t => KIDS.includes(t.who) && t.kind !== 'bill');
  const validated = choreList.filter(t => t.completed && inMonthDate(t.completedAt || t.when || t.createdAt));
  const byKid = { Violet:0, Odin:0 };
  validated.forEach(t => { byKid[t.who] = (byKid[t.who]||0) + 1; });
  document.getElementById('ov-chores').textContent = validated.length;
  document.getElementById('ov-chores-breakdown').innerHTML =
    `<div class="b-row"><span class="chip violet">Violet</span><b>${byKid.Violet}</b></div>` +
    `<div class="b-row"><span class="chip odin">Odin</span><b>${byKid.Odin}</b></div>`;
}

