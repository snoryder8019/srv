// ── Mini calendar slideshow (week → month → day) ───────────────────────
function renderMiniCalendar(){
  if (!aggData) return;
  const dayKey = (d) => { const x=new Date(d); return `${x.getFullYear()}-${String(x.getMonth()+1).padStart(2,'0')}-${String(x.getDate()).padStart(2,'0')}`; };
  const todayKey = dayKey(new Date());
  const byDay = {};
  const slots = [];
  aggData.calendar.forEach(e => slots.push({ when: e.startsAt||e.date, what: e.title||'(event)', who: e.who }));
  aggData.bookings.forEach(b => slots.push({ when: b.startAt, what: b.service||'booking', who: b.who }));
  aggData.meetings.forEach(m => slots.push({ when: m.scheduledAt || m.createdAt, what: m.title||'meeting', who: m.who }));
  aggData.workdays.forEach(w => slots.push({ when: w.date, what: `${w.who} work`, who: w.who }));
  slots.forEach(s => { if (!s.when) return; (byDay[dayKey(s.when)] ||= []).push(s); });

  const stage = document.getElementById('mini-stage');
  let html = '';
  // Mini-slide rotates only week + day; month is now the big centerpiece.
  for (const mode of ['week','day']) {
    if (mode === 'month') {
      const start = new Date(); start.setHours(0,0,0,0); start.setDate(start.getDate()-start.getDay());
      let grid = ['S','M','T','W','T','F','S'].map(l=>`<div class="mdow">${l}</div>`).join('');
      for (let i=0;i<35;i++){ const d=new Date(start); d.setDate(start.getDate()+i); const k=dayKey(d); const has=!!byDay[k]; const isToday=k===todayKey;
        grid += `<div class="mday ${isToday?'today':''} ${d<new Date(new Date().setHours(0,0,0,0))&&!isToday?'dim':''} ${has?'has':''}">${d.getDate()}</div>`; }
      html += `<div class="mini-card" data-mini="month"><h5>Month at a glance</h5><div class="mini-month">${grid}</div></div>`;
    } else if (mode === 'week') {
      const start = new Date(); start.setHours(0,0,0,0); start.setDate(start.getDate()-start.getDay());
      let rows = '';
      for (let i=0;i<7;i++){ const d=new Date(start); d.setDate(start.getDate()+i); const k=dayKey(d); const ev=byDay[k]||[]; const isToday=k===todayKey;
        rows += `<div class="mw-day ${isToday?'today':''}"><span>${d.toLocaleDateString([],{weekday:'short',month:'short',day:'numeric'})}</span><span class="ct">${ev.length||'—'}</span></div>`; }
      html += `<div class="mini-card" data-mini="week"><h5>This week</h5><div class="mini-week">${rows}</div></div>`;
    } else {
      const d=new Date(); const k=dayKey(d); const ev=(byDay[k]||[]).sort((a,b)=> new Date(a.when)-new Date(b.when)).slice(0,6);
      let rows = `<div class="mdh">${d.toLocaleDateString([],{weekday:'long',month:'short',day:'numeric'})}</div>`;
      if (!ev.length) rows += `<div style="color:#525252;font-size:calc(9px * var(--cm, 1));font-style:italic">Open day.</div>`;
      ev.forEach(s => rows += `<div class="mditem"><span class="t">${fmtT(s.when)}</span>${escapeHtml(s.what)}</div>`);
      html += `<div class="mini-card" data-mini="day"><h5>Today</h5><div class="mini-day">${rows}</div></div>`;
    }
  }
  stage.innerHTML = html;
  if (!miniSlideStarted) startMiniSlide();
}
let miniSlideStarted = false, miniIdx = 0;
function startMiniSlide(){
  miniSlideStarted = true;
  (function step(){ const cards=document.querySelectorAll('#mini-stage .mini-card'); cards.forEach((c,i)=> c.classList.toggle('show', i===miniIdx)); miniIdx=(miniIdx+1)%cards.length; setTimeout(step, 9000); })();
}

// ── Calendar panel (cycles month/week/day on repeat-tap) ──────────────
function renderCalendar(){
  if (!aggData) return;
  document.getElementById('cal-modetag').textContent = calMode;
  const slots = [];
  aggData.calendar.forEach(e => slots.push({ when: e.startsAt||e.date, kind:'event', who: e.who, label: e.title||'(event)', loc: e.location||'' }));
  aggData.bookings.forEach(b => slots.push({ when: b.startAt, kind:'book', who: b.who, label: (b.service||'booking') + ' — ' + (b.name||''), loc:'' }));
  aggData.meetings.forEach(m => slots.push({ when: m.scheduledAt || m.createdAt, kind:'meet', who: m.who, label: m.title||'meeting', loc:'' }));
  aggData.workdays.forEach(w => slots.push({ when: w.date, kind:'work', who: w.who, label: `${w.who} work · ${w.start}–${w.end}`, loc:'' }));
  const dayKey = (d) => { const x=new Date(d); return `${x.getFullYear()}-${String(x.getMonth()+1).padStart(2,'0')}-${String(x.getDate()).padStart(2,'0')}`; };
  const byDay = {};
  slots.forEach(s => { if (!s.when) return; (byDay[dayKey(s.when)] ||= []).push(s); });
  Object.values(byDay).forEach(arr => arr.sort((a,b)=> new Date(a.when)-new Date(b.when)));
  const todayKey = dayKey(new Date());
  const stage = document.getElementById('cal-stage');

  if (calMode === 'month') {
    const start = new Date(); start.setHours(0,0,0,0); start.setDate(start.getDate()-start.getDay());
    let html = '<div class="month">';
    ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].forEach(l => html += `<div class="dow">${l}</div>`);
    for (let i=0;i<35;i++){ const d=new Date(start); d.setDate(start.getDate()+i); const k=dayKey(d); const ev=byDay[k]||[]; const isToday=k===todayKey;
      html += `<div class="day-cell ${isToday?'today':''} ${d<new Date(new Date().setHours(0,0,0,0))&&!isToday?'dim':''}"><div class="num">${d.getDate()}</div>`;
      ev.slice(0,3).forEach(s => html += `<div class="ev ${s.kind}">${fmtT(s.when)} ${escapeHtml(s.label)}</div>`);
      if (ev.length>3) html += `<div class="ev" style="background:transparent;color:#525252">+${ev.length-3}</div>`;
      html += '</div>'; }
    html += '</div>';
    stage.innerHTML = html;
  } else if (calMode === 'week') {
    const start = new Date(); start.setHours(0,0,0,0); start.setDate(start.getDate()-start.getDay());
    let html = '<div style="display:grid;grid-template-columns:repeat(7,1fr);gap:4px;flex:1;min-height:0;overflow:hidden">';
    for (let i=0;i<7;i++){ const d=new Date(start); d.setDate(start.getDate()+i); const k=dayKey(d); const ev=byDay[k]||[]; const isToday=k===todayKey;
      html += `<div style="background:#101014;border:1px solid ${isToday?'#c9a848':'#1f1f22'};border-radius:4px;padding:6px;display:flex;flex-direction:column;gap:3px;overflow:hidden;min-height:0">
        <div style="font-family:'Space Grotesk',sans-serif;font-size:calc(11px * var(--cm, 1));color:${isToday?'#c9a848':'#fff'}">${d.toLocaleDateString([],{weekday:'short',day:'numeric'})}</div>`;
      ev.slice(0,8).forEach(s => html += `<div class="ev ${s.kind}" style="padding:2px 4px;border-radius:2px;font-size:calc(9px * var(--cm, 1))">${fmtT(s.when)} ${escapeHtml(s.label)}</div>`);
      html += '</div>'; }
    html += '</div>';
    stage.innerHTML = html;
  } else {
    // Day mode — use focused date from remote if set, else today
    const focusEl = document.getElementById('cal-focus-tag');
    let d; let k;
    if (calFocusDate) {
      const [y,mo,da] = calFocusDate.split('-').map(Number);
      d = new Date(y, mo-1, da);
      k = calFocusDate;
      focusEl.style.display = ''; focusEl.textContent = '· focused from remote';
    } else {
      d = new Date(); d.setHours(0,0,0,0); k = dayKey(d);
      focusEl.style.display = 'none';
    }
    const ev = byDay[k] || [];
    let html = `<div class="listbox" style="flex:1;min-height:0"><h4 style="font-family:'Space Grotesk',sans-serif;font-size:calc(18px * var(--cm, 1));color:var(--accent)">${d.toLocaleDateString([],{weekday:'long',month:'long',day:'numeric',year:'numeric'})}</h4><ul>`;
    if (!ev.length) html += '<li><span style="color:#525252;font-style:italic">nothing scheduled this day</span></li>';
    ev.forEach(s => html += `<li><span>${whoChip(s.who)}<span class="chip ${s.kind==='book'?'reminder':s.kind==='meet'?'appointment':s.kind==='work'?'odin':'event'}">${s.kind}</span>${escapeHtml(s.label)}${s.loc?` <span style="color:#737373">— ${escapeHtml(s.loc)}</span>`:''}</span><span class="when">${fmtT(s.when)}</span></li>`);
    html += '</ul></div>';
    stage.innerHTML = html;
  }
}

