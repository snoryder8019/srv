        <div><div class="big">${Math.round(w.now.tempF)}°</div>
        <div class="sub">${escapeHtml(w.now.label)} · ${Math.round(w.now.wind||0)} mph · ${Math.round(w.now.humidity||0)}%</div></div></div>`;
