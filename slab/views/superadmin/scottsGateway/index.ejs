<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Scott's Gateway — Family Cockpit</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:#08080a;color:#e5e5e5;min-height:100vh;padding:32px}
    .wrap{max-width:1200px;margin:0 auto}
    h1{font-family:'Space Grotesk',sans-serif;font-size:28px;font-weight:600;color:#fff;margin-bottom:6px}
    h1 span{color:#c9a848}
    .sub{color:#737373;font-size:13px;margin-bottom:32px}
    .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:14px}
    .card{background:#141417;border:1px solid #262629;border-radius:10px;padding:20px;text-decoration:none;color:#e5e5e5;transition:border-color .15s,transform .15s}
    .card:hover{border-color:#c9a848;transform:translateY(-2px)}
    .card h3{font-size:15px;font-weight:600;color:#fff;margin-bottom:6px;display:flex;align-items:center;gap:8px}
    .card p{font-size:12px;color:#a3a3a3;line-height:1.5}
    .pill{display:inline-block;padding:3px 8px;font-size:10px;letter-spacing:.5px;text-transform:uppercase;border-radius:4px;background:#2a2410;color:#c9a848;margin-bottom:14px}
    .op{font-size:11px;color:#525252;margin-top:18px}
    .state{margin-top:24px;padding:14px 16px;background:#0f0f12;border:1px solid #1f1f22;border-radius:8px;font-family:'Space Grotesk',monospace;font-size:12px;color:#737373}
    .state b{color:#c9a848}
  </style>
</head>
<body>
  <div class="wrap">
    <span class="pill">Private · Operators Only</span>
    <h1>Scott's <span>Gateway</span></h1>
    <p class="sub">Family + entrepreneurial coordination across MadLadsLab, sLab, w2Marketing.</p>

    <div class="grid">
      <a class="card" href="/superadmin/scottsGateway/mission-control">
        <h3>📺 Mission Control</h3>
        <p>Single TV view. Drives the home displays — pushes updates live from any remote.</p>
      </a>
      <a class="card" href="/superadmin/scottsGateway/remote/<%= encodeURIComponent(operator.split('@')[0]) %>">
        <h3>📱 My Remote</h3>
        <p>Phone-sized controller — switch the TV view, post messages, fire the agent.</p>
      </a>
      <a class="card" href="/superadmin/scottsGateway/calendarConsoldate">
        <h3>📆 Consolidated Calendar</h3>
        <p>Events + bookings + meetings rolled up from every tenant on this Slab.</p>
      </a>
      <a class="card" href="/superadmin/scottsGateway/tasksBillsIncome">
        <h3>💸 Tasks · Bills · Income</h3>
        <p>Unpaid / overdue / draft invoices, plus what's coming due across the family.</p>
      </a>
    </div>

    <div class="state">
      Current TV state — view: <b><%= state.view || 'overview' %></b>
      · last touched: <b><%= state.updatedBy || '—' %></b>
      <% if (state.updatedAt) { %> · <b><%= new Date(state.updatedAt).toLocaleString() %></b><% } %>
    </div>

    <p class="op">Operator: <%= operator %></p>
  </div>
</body>
</html>
