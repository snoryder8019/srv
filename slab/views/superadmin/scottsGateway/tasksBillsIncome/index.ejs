<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tasks · Bills · Income — Gateway</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:#08080a;color:#e5e5e5;padding:28px}
    .wrap{max-width:1200px;margin:0 auto}
    a.back{color:#737373;text-decoration:none;font-size:12px}
    a.back:hover{color:#c9a848}
    h1{font-family:'Space Grotesk',sans-serif;font-size:26px;font-weight:600;color:#fff;margin:12px 0 6px}
    h1 span{color:#c9a848}
    .meta{color:#737373;font-size:13px;margin-bottom:24px}
    .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:24px}
    .stat{background:#101014;border:1px solid #1f1f22;border-radius:10px;padding:16px}
    .stat .lbl{font-size:10px;letter-spacing:1px;text-transform:uppercase;color:#737373;margin-bottom:4px}
    .stat .v{font-size:28px;font-weight:700;font-family:'Space Grotesk',sans-serif;color:#fff}
    .stat .v.gold{color:#c9a848}
    .stat .v.red{color:#f87171}
    section{background:#101014;border:1px solid #1f1f22;border-radius:10px;margin-bottom:18px}
    section h2{font-size:13px;letter-spacing:.6px;text-transform:uppercase;color:#c9a848;padding:14px 18px;border-bottom:1px solid #1f1f22}
    table{width:100%;border-collapse:collapse}
    th{text-align:left;padding:10px 18px;font-size:10px;text-transform:uppercase;color:#737373;background:#0c0c10;letter-spacing:.6px}
    td{padding:10px 18px;font-size:13px;border-top:1px solid #1a1a1d}
    td.brand{color:#c9a848;font-weight:500}
    td.when{font-family:'Space Grotesk',monospace;color:#a3a3a3;white-space:nowrap}
    td.amt{font-family:'Space Grotesk',monospace;font-weight:600;color:#34d399;text-align:right}
    td.amt.overdue{color:#f87171}
    .badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:10px;letter-spacing:.5px;text-transform:uppercase;background:#262629;color:#a3a3a3}
    .badge.overdue{background:#451a1a;color:#f87171}
    .badge.unpaid{background:#2a2410;color:#c9a848}
    .empty{padding:20px;color:#525252;font-style:italic;font-size:13px}
  </style>
</head>
<body>
  <div class="wrap">
    <a class="back" href="/superadmin/scottsGateway">← Gateway</a>
    <h1>Tasks · Bills · <span>Income</span></h1>
    <p class="meta">From <%= data.tenantCount %> tenants · next <%= data.horizonDays %> days</p>

    <% const total = data.invoices.reduce((s,i)=> s + (Number(i.total)||0), 0);
       const overdue = data.invoices.filter(i => i.status==='overdue' || (i.dueDate && new Date(i.dueDate) < new Date()));
       const overdueTotal = overdue.reduce((s,i)=> s + (Number(i.total)||0), 0); %>

    <div class="stats">
      <div class="stat"><div class="lbl">Open Invoices</div><div class="v gold"><%= data.invoices.length %></div></div>
      <div class="stat"><div class="lbl">Outstanding</div><div class="v">$<%= total.toFixed(2) %></div></div>
      <div class="stat"><div class="lbl">Overdue Count</div><div class="v red"><%= overdue.length %></div></div>
      <div class="stat"><div class="lbl">Overdue $</div><div class="v red">$<%= overdueTotal.toFixed(2) %></div></div>
    </div>

    <section>
      <h2>Open Invoices (<%= data.invoices.length %>)</h2>
      <% if (data.invoices.length) { %>
        <table>
          <thead><tr><th>Tenant</th><th>Client</th><th>Status</th><th>Due</th><th style="text-align:right">Total</th></tr></thead>
          <tbody>
          <% data.invoices.forEach(i => {
               const isOverdue = i.status==='overdue' || (i.dueDate && new Date(i.dueDate) < new Date());
               const cls = isOverdue ? 'overdue' : (i.status === 'unpaid' || i.status === 'sent' ? 'unpaid' : '');
          %>
            <tr>
              <td class="brand"><%= i.brand %></td>
              <td><%= i.clientName || '—' %></td>
              <td><span class="badge <%= cls %>"><%= i.status || '?' %></span></td>
              <td class="when"><%= i.dueDate ? new Date(i.dueDate).toLocaleDateString() : '—' %></td>
              <td class="amt <%= isOverdue ? 'overdue' : '' %>">$<%= Number(i.total || 0).toFixed(2) %></td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      <% } else { %><div class="empty">No open invoices.</div><% } %>
    </section>

    <section>
      <h2>Upcoming Bookings → expected income</h2>
      <% if (data.bookings.length) { %>
        <table>
          <thead><tr><th>Tenant</th><th>Service</th><th>Customer</th><th>When</th></tr></thead>
          <tbody>
          <% data.bookings.slice(0, 25).forEach(b => { %>
            <tr>
              <td class="brand"><%= b.brand %></td>
              <td><%= b.service || '—' %></td>
              <td><%= b.name || b.email || '—' %></td>
              <td class="when"><%= b.start ? new Date(b.start).toLocaleString() : '—' %></td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      <% } else { %><div class="empty">No bookings scheduled.</div><% } %>
    </section>
  </div>
</body>
</html>
