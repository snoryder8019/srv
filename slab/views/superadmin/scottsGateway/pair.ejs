<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pair the TV — Scott's Gateway</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    html,body{height:100%}
    body{font-family:'Inter',sans-serif;background:radial-gradient(ellipse at top,#0c0c11,#000);color:#e5e5e5;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:40px}
    .card{text-align:center;max-width:900px;width:100%}
    h1{font-family:'Space Grotesk',sans-serif;font-size:36px;color:#fff;margin-bottom:8px}
    h1 span{color:#c9a848}
    p.sub{color:#a3a3a3;font-size:16px;margin-bottom:36px;line-height:1.5}
    .qrbox{background:#fff;padding:28px;border-radius:24px;display:inline-block;box-shadow:0 0 80px rgba(201,168,72,.15)}
    .qrbox img{display:block;width:420px;height:420px}
    .url{margin-top:24px;font-family:'Space Grotesk',monospace;font-size:14px;color:#737373;word-break:break-all}
    .status{margin-top:32px;display:inline-flex;align-items:center;gap:10px;font-size:15px;color:#a3a3a3}
    .dot{width:10px;height:10px;border-radius:50%;background:#c9a848;animation:pulse 1.5s ease-in-out infinite}
    @keyframes pulse{0%,100%{opacity:.3}50%{opacity:1}}
    .ok{color:#34d399}.ok .dot{animation:none;background:#34d399;box-shadow:0 0 10px #34d399}
    .err{color:#f87171}.err .dot{animation:none;background:#f87171}
    @media (min-width:1900px){
      h1{font-size:54px}
      p.sub{font-size:20px}
      .qrbox img{width:540px;height:540px}
    }
    @media (min-width:2600px){
      h1{font-size:72px}
      p.sub{font-size:24px}
      .qrbox img{width:720px;height:720px}
    }
  </style>
</head>
<body>
  <div class="card">
    <h1>Pair this <span>TV</span></h1>
    <p class="sub">Scan with the phone that's logged in to sLab superadmin.<br>The TV stays signed in for 30 days afterwards.</p>
    <div class="qrbox"><img id="qr" alt="QR code"></div>
    <div class="url" id="url">requesting pair code…</div>
    <div class="status" id="status"><span class="dot"></span><span id="statusTxt">waiting for scan…</span></div>
  </div>

<script>
let code = null;
let pollTimer = null;
let expiresAt = null;

async function request(){
  const r = await fetch('/superadmin/scottsGateway/api/pair/request', { method: 'POST' });
  const j = await r.json();
  if (!j.ok) { setStatus('failed to request code','err'); return; }
  code = j.code;
  expiresAt = new Date(j.expiresAt);
  document.getElementById('qr').src = 'https://api.qrserver.com/v1/create-qr-code/?size=600x600&margin=0&data=' + encodeURIComponent(j.url);
  document.getElementById('url').textContent = j.url;
  setStatus('waiting for scan…','');
  startPoll();
}
function setStatus(msg, cls){
  const el = document.getElementById('status');
  el.classList.remove('ok','err'); if (cls) el.classList.add(cls);
  document.getElementById('statusTxt').textContent = msg;
}
function startPoll(){
  if (pollTimer) clearInterval(pollTimer);
  pollTimer = setInterval(poll, 2500);
}
async function poll(){
  if (!code) return;
  if (expiresAt && new Date() > expiresAt) {
    clearInterval(pollTimer);
    setStatus('expired — refreshing…','err');
    return request();
  }
  try {
    const r = await fetch('/superadmin/scottsGateway/api/pair/poll/' + code);
    const j = await r.json();
    if (j.status === 'authorized') {
      clearInterval(pollTimer);
      setStatus('paired ✓ loading mission control…','ok');
      setTimeout(()=> location.replace('/superadmin/scottsGateway/mission-control'), 600);
    } else if (j.status === 'expired') {
      clearInterval(pollTimer);
      setStatus('expired — refreshing…','err');
      request();
    }
  } catch (e) { /* network blip — keep polling */ }
}

request();
</script>
</body>
</html>
