<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Calendar — Gateway</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:#08080a;color:#e5e5e5;padding:28px}
    .wrap{max-width:1400px;margin:0 auto}
    a.back{color:#737373;text-decoration:none;font-size:12px}
    a.back:hover{color:#c9a848}
    h1{font-family:'Space Grotesk',sans-serif;font-size:26px;font-weight:600;color:#fff;margin:12px 0 6px}
    h1 span{color:#c9a848}
    .meta{color:#737373;font-size:13px;margin-bottom:18px}
    .views{display:flex;gap:6px;margin-bottom:24px}
    .views a{padding:8px 16px;font-size:12px;border-radius:8px;border:1px solid #262629;background:#101014;color:#a3a3a3;text-decoration:none;text-transform:uppercase;letter-spacing:.6px}
    .views a.on{border-color:#c9a848;background:#1a1610;color:#c9a848}
    .views a:hover{color:#c9a848}
    .chip{display:inline-block;padding:2px 8px;font-size:10px;border-radius:4px;letter-spacing:.5px;text-transform:uppercase;margin-right:6px;background:#262629;color:#a3a3a3}
    .chip.scott{background:#1e3a5f;color:#7dd3fc}
    .chip.candace{background:#3f1d3a;color:#f9a8d4}
    .chip.violet{background:#2e1b4d;color:#c4b5fd}
    .chip.odin{background:#1f3a2e;color:#86efac}
    .chip.family{background:#2a2410;color:#c9a848}

    /* Month grid */
    .month{display:grid;grid-template-columns:repeat(7,1fr);gap:6px}
    .month .dow{font-size:10px;letter-spacing:1px;text-transform:uppercase;color:#525252;padding:6px 4px}
    .day{min-height:110px;background:#101014;border:1px solid #1f1f22;border-radius:8px;padding:8px;display:flex;flex-direction:column;gap:4px;font-size:11px}
    .day.dim{opacity:.35}
    .day.today{border-color:#c9a848;background:#15110a}
    .day .num{font-size:13px;font-weight:600;color:#a3a3a3;margin-bottom:2px}
    .day.today .num{color:#c9a848}
    .ev{padding:3px 6px;border-radius:4px;background:#1c1c1f;font-size:10px;line-height:1.3;color:#d4d4d4;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .ev.work{background:#0f1f15;color:#86efac;border-left:2px solid #34d399}
    .ev.book{background:#15101c;color:#d8b4fe;border-left:2px solid #a78bfa}
    .ev.meet{background:#0c1a26;color:#7dd3fc;border-left:2px solid #38bdf8}
    .ev.event{background:#2a2410;color:#c9a848;border-left:2px solid #c9a848}

    /* Week / day timeline */
    .week{display:grid;gap:6px}
    .week.w7{grid-template-columns:repeat(7,1fr)}
    .week.w1{grid-template-columns:1fr}
    .col{background:#101014;border:1px solid #1f1f22;border-radius:8px;min-height:480px;display:flex;flex-direction:column}
    .col h3{font-size:13px;color:#fff;padding:10px 12px;border-bottom:1px solid #1f1f22;font-family:'Space Grotesk',sans-serif;font-weight:500}
    .col h3.today{color:#c9a848}
    .col h3 small{display:block;font-size:10px;color:#525252;letter-spacing:.6px;text-transform:uppercase;margin-top:2px;font-family:'Inter',sans-serif}
    .slots{padding:10px;display:flex;flex-direction:column;gap:5px;flex:1}
    .slot{padding:8px 10px;border-radius:6px;font-size:12px;line-height:1.4}
    .slot .t{font-family:'Space Grotesk',monospace;font-size:10px;color:#737373;text-transform:uppercase;letter-spacing:.5px;margin-bottom:2px}
    .slot.work{background:#0f1f15;color:#86efac;border-left:2px solid #34d399}
    .slot.book{background:#15101c;color:#d8b4fe;border-left:2px solid #a78bfa}
    .slot.meet{background:#0c1a26;color:#7dd3fc;border-left:2px solid #38bdf8}
    .slot.event{background:#2a2410;color:#c9a848;border-left:2px solid #c9a848}
    .slot.empty{background:#0c0c10;color:#404040;font-style:italic;text-align:center;border-left:none;font-size:11px}
  </style>
</head>
<body>
  <div class="wrap">
    <a class="back" href="/superadmin/scottsGateway">← Gateway</a>
    <h1>Family <span>Calendar</span></h1>
    <p class="meta">Pulled across all tenants · viewed as family · <%= data.counts.calendar + data.counts.bookings + data.counts.meetings + data.counts.workdays %> entries in this window</p>

    <div class="views">
      <a href="?view=day"   class="<%= view==='day'?'on':'' %>">Day</a>
      <a href="?view=week"  class="<%= view==='week'?'on':'' %>">Week</a>
      <a href="?view=month" class="<%= view==='month'?'on':'' %>">30 Days</a>
    </div>

<%
  // Build a unified list of slots
  const slots = [];
  data.calendar.forEach(e => slots.push({ when: e.startsAt || e.date, kind:'event', who: e.who, label: e.title || '(event)', loc: e.location || '' }));
  data.bookings.forEach(b => slots.push({ when: b.startAt, kind:'book',  who: b.who, label: (b.service||'booking') + ' — ' + (b.name||''), loc: '' }));
  data.meetings.forEach(m => slots.push({ when: m.scheduledAt, kind:'meet', who: m.who, label: m.title || 'meeting', loc: '' }));
  data.workdays.forEach(w => slots.push({ when: w.date, kind:'work', who: w.who, label: `${w.who} work · ${w.start}–${w.end}`, loc: '' }));
  const dayKey = (d) => { const x=new Date(d); return x.toISOString().slice(0,10); };
  const byDay = {};
  slots.forEach(s => { if (!s.when) return; const k = dayKey(s.when); (byDay[k] ||= []).push(s); });
  Object.values(byDay).forEach(arr => arr.sort((a,b)=> new Date(a.when)-new Date(b.when)));
  const fmtT = (d) => d ? new Date(d).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) : '';
  const fmtD = (d) => d.toLocaleDateString([], {weekday:'short', month:'short', day:'numeric'});
  const todayKey = dayKey(new Date());
  const whoClass = (w) => `chip ${(w||'family').toLowerCase()}`;
%>

<% if (view === 'month') { %>
  <%
    // Build a 5/6-row grid starting on the Sunday on/before today
    const start = new Date(); start.setHours(0,0,0,0);
    start.setDate(start.getDate() - start.getDay()); // back to Sunday
    const cells = [];
    for (let i = 0; i < 35; i++) {
      const d = new Date(start); d.setDate(start.getDate() + i);
      cells.push(d);
    }
  %>
  <div class="month">
    <% ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].forEach(l => { %><div class="dow"><%= l %></div><% }) %>
    <% cells.forEach(d => { const k = dayKey(d); const ev = byDay[k] || []; const isToday = k === todayKey; const past = d < new Date(new Date().setHours(0,0,0,0)); %>
      <div class="day <%= isToday ? 'today' : '' %> <%= past && !isToday ? 'dim' : '' %>">
        <div class="num"><%= d.getDate() %></div>
        <% ev.slice(0, 4).forEach(s => { %>
          <div class="ev <%= s.kind %>" title="<%= s.who %> — <%= s.label %>"><%= fmtT(s.when) %> <%= s.label %></div>
        <% }) %>
        <% if (ev.length > 4) { %><div class="ev" style="background:transparent;color:#525252">+<%= ev.length - 4 %> more</div><% } %>
      </div>
    <% }) %>
  </div>

<% } else if (view === 'week') { %>
  <%
    const start = new Date(); start.setHours(0,0,0,0);
    start.setDate(start.getDate() - start.getDay());
    const cells = []; for (let i = 0; i < 7; i++) { const d = new Date(start); d.setDate(start.getDate()+i); cells.push(d); }
  %>
  <div class="week w7">
    <% cells.forEach(d => { const k = dayKey(d); const ev = byDay[k] || []; const isToday = k === todayKey; %>
      <div class="col">
        <h3 class="<%= isToday ? 'today' : '' %>"><%= fmtD(d) %><small><%= isToday ? 'today' : '' %></small></h3>
        <div class="slots">
          <% if (!ev.length) { %><div class="slot empty">no entries</div><% } %>
          <% ev.forEach(s => { %>
            <div class="slot <%= s.kind %>">
              <div class="t"><%= fmtT(s.when) %> · <span class="<%= whoClass(s.who) %>"><%= s.who %></span></div>
              <%= s.label %><% if (s.loc) { %> <span style="color:#737373">— <%= s.loc %></span><% } %>
            </div>
          <% }) %>
        </div>
      </div>
    <% }) %>
  </div>

<% } else { %>
  <%
    const d = new Date(); d.setHours(0,0,0,0);
    const k = dayKey(d); const ev = byDay[k] || [];
  %>
  <div class="week w1">
    <div class="col">
      <h3 class="today"><%= fmtD(d) %><small>today</small></h3>
      <div class="slots">
        <% if (!ev.length) { %><div class="slot empty">nothing scheduled today</div><% } %>
        <% ev.forEach(s => { %>
          <div class="slot <%= s.kind %>">
            <div class="t"><%= fmtT(s.when) %> · <span class="<%= whoClass(s.who) %>"><%= s.who %></span></div>
            <%= s.label %><% if (s.loc) { %> <span style="color:#737373">— <%= s.loc %></span><% } %>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
<% } %>
  </div>
</body>
</html>
