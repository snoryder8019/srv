<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= tenant.brand?.name || tenant.domain %> — Superadmin</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#0a0a0a; color:#e5e5e5; min-height:100vh; }
    .topbar { background:#141414; border-bottom:1px solid #262626; padding:14px 24px; display:flex; align-items:center; gap:16px; }
    .logo { font-size:20px; font-weight:600; color:#fff; text-decoration:none; } .logo span { color:#c9a848; }
    .breadcrumb { font-size:13px; color:#525252; } .breadcrumb a { color:#737373; text-decoration:none; } .breadcrumb a:hover { color:#c9a848; }
    .container { max-width:800px; margin:0 auto; padding:24px; }
    .card { background:#141414; border:1px solid #262626; border-radius:8px; padding:24px; margin-bottom:20px; }
    h1 { font-size:22px; font-weight:600; margin-bottom:4px; }
    .domain { font-size:14px; color:#c9a848; margin-bottom:16px; }
    .domain a { color:#c9a848; text-decoration:none; } .domain a:hover { text-decoration:underline; }
    .meta-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:20px; }
    .meta-item { font-size:13px; }
    .meta-label { color:#737373; font-size:11px; text-transform:uppercase; letter-spacing:0.8px; margin-bottom:2px; }
    .status { display:inline-block; padding:3px 10px; border-radius:10px; font-size:12px; font-weight:500; }
    .status-active { background:#14532d; color:#86efac; }
    .status-preview { background:#422006; color:#fdba74; }
    .status-suspended { background:#451a1a; color:#fca5a5; }
    h2 { font-size:16px; font-weight:500; margin-bottom:12px; }
    .stats-row { display:flex; gap:16px; flex-wrap:wrap; margin-bottom:20px; }
    .mini-stat { background:#1a1a1a; border-radius:6px; padding:12px 16px; min-width:100px; }
    .mini-stat-val { font-size:20px; font-weight:600; color:#fff; }
    .mini-stat-label { font-size:10px; color:#737373; text-transform:uppercase; letter-spacing:0.8px; }
    .actions { display:flex; gap:10px; flex-wrap:wrap; }
    .btn { padding:10px 20px; border-radius:6px; font-family:'Inter',sans-serif; font-size:13px; font-weight:500; cursor:pointer; border:none; transition:all 0.2s; text-decoration:none; display:inline-block; }
    .btn-gold { background:#c9a848; color:#0a0a0a; } .btn-gold:hover { background:#d4b85c; }
    .btn-green { background:#14532d; color:#86efac; border:1px solid #16a34a; } .btn-green:hover { background:#166534; }
    .btn-red { background:transparent; color:#f87171; border:1px solid #7f1d1d; } .btn-red:hover { background:#451a1a; }
    .btn-ghost { background:transparent; color:#a3a3a3; border:1px solid #333; } .btn-ghost:hover { border-color:#c9a848; color:#c9a848; }
    select { background:#1a1a1a; border:1px solid #333; color:#e5e5e5; padding:8px 12px; border-radius:4px; font-family:'Inter',sans-serif; font-size:13px; }
    .action-form { display:inline-flex; align-items:center; gap:8px; }
    .danger-zone { border-color:#7f1d1d; }
  </style>
</head>
<body>
  <div class="topbar">
    <a href="/superadmin" class="logo"><span>S</span>lab</a>
    <div class="breadcrumb"><a href="/superadmin">Dashboard</a> / <%= tenant.brand?.name || tenant.domain %></div>
  </div>

  <div class="container">
    <div class="card">
      <h1><%= tenant.brand?.name || 'Unnamed' %></h1>
      <div class="domain"><a href="https://<%= tenant.domain %>" target="_blank"><%= tenant.domain %></a></div>

      <div class="meta-grid">
        <div class="meta-item">
          <div class="meta-label">Status</div>
          <span class="status status-<%= tenant.status || 'preview' %>"><%= tenant.status || 'preview' %></span>
        </div>
        <div class="meta-item">
          <div class="meta-label">Plan</div>
          <%= tenant.meta?.plan || 'free' %>
        </div>
        <div class="meta-item">
          <div class="meta-label">Owner</div>
          <%= tenant.meta?.ownerEmail || '—' %>
        </div>
        <div class="meta-item">
          <div class="meta-label">Location</div>
          <%= tenant.brand?.location || '—' %>
        </div>
        <div class="meta-item">
          <div class="meta-label">Database</div>
          <%= tenant.db %>
        </div>
        <div class="meta-item">
          <div class="meta-label">S3 Prefix</div>
          <%= tenant.s3Prefix %>
        </div>
        <div class="meta-item">
          <div class="meta-label">Created</div>
          <%= tenant.createdAt ? new Date(tenant.createdAt).toLocaleString() : '—' %>
        </div>
        <div class="meta-item">
          <div class="meta-label">Expires</div>
          <%= tenant.meta?.expiresAt ? new Date(tenant.meta.expiresAt).toLocaleDateString() : 'Never' %>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>Content Stats</h2>
      <div class="stats-row">
        <div class="mini-stat"><div class="mini-stat-val"><%= dbStats.blogCount %></div><div class="mini-stat-label">Blog Posts</div></div>
        <div class="mini-stat"><div class="mini-stat-val"><%= dbStats.clientCount %></div><div class="mini-stat-label">Clients</div></div>
        <div class="mini-stat"><div class="mini-stat-val"><%= dbStats.pageCount %></div><div class="mini-stat-label">Pages</div></div>
        <div class="mini-stat"><div class="mini-stat-val"><%= dbStats.invoiceCount %></div><div class="mini-stat-label">Invoices</div></div>
      </div>
    </div>

    <div class="card">
      <h2>Actions</h2>
      <div class="actions">
        <a href="https://<%= tenant.domain %>/admin" target="_blank" class="btn btn-ghost">Open Admin Panel</a>

        <% if (tenant.status !== 'active') { %>
        <form method="POST" action="/superadmin/tenants/<%= tenant._id %>/activate" class="action-form">
          <select name="plan">
            <option value="30day">30-Day Trial</option>
            <option value="120day">120-Day Promo</option>
            <option value="monthly">Monthly ($50/mo)</option>
            <option value="annual">Annual</option>
            <option value="lifetime">Lifetime</option>
          </select>
          <button type="submit" class="btn btn-green">Activate</button>
        </form>
        <% } %>

        <% if (tenant.status === 'active') { %>
        <form method="POST" action="/superadmin/tenants/<%= tenant._id %>/change-plan" class="action-form">
          <select name="plan">
            <option value="free" <%= tenant.meta?.plan === 'free' ? 'selected' : '' %>>Free (Preview)</option>
            <option value="30day" <%= tenant.meta?.plan === '30day' ? 'selected' : '' %>>30-Day Trial</option>
            <option value="120day" <%= tenant.meta?.plan === '120day' ? 'selected' : '' %>>120-Day Promo</option>
            <option value="monthly" <%= tenant.meta?.plan === 'monthly' ? 'selected' : '' %>>Monthly ($50/mo)</option>
            <option value="annual" <%= tenant.meta?.plan === 'annual' ? 'selected' : '' %>>Annual</option>
            <option value="lifetime" <%= tenant.meta?.plan === 'lifetime' ? 'selected' : '' %>>Lifetime</option>
          </select>
          <button type="submit" class="btn btn-gold" onclick="return confirm('Change plan to ' + this.form.plan.value + '?')">Change Plan</button>
        </form>

        <form method="POST" action="/superadmin/tenants/<%= tenant._id %>/suspend" style="display:inline;">
          <button type="submit" class="btn btn-red" onclick="return confirm('Suspend this tenant?')">Suspend</button>
        </form>
        <% } %>
      </div>
    </div>

    <div class="card danger-zone">
      <h2 style="color:#f87171;">Danger Zone</h2>
      <form method="POST" action="/superadmin/tenants/<%= tenant._id %>/delete" style="display:inline;">
        <button type="submit" class="btn btn-red" onclick="return confirm('DELETE this tenant and all data? This cannot be undone.')">Delete Tenant</button>
      </form>
    </div>
  </div>
</body>
</html>
