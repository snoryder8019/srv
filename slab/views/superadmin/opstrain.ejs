<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OpsTrain — Superadmin</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#0a0a0a; color:#e5e5e5; min-height:100vh; }
    .topbar { background:#141414; border-bottom:1px solid #262626; padding:14px 24px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:100; }
    .topbar-left { display:flex; align-items:center; gap:16px; }
    .logo { font-size:18px; font-weight:500; color:#fff; font-family:'Space Grotesk',sans-serif; letter-spacing:0.05em; } .logo span { color:#c9a848; }
    .topbar-right { display:flex; align-items:center; gap:16px; font-size:13px; }
    .topbar-right a { color:#a3a3a3; text-decoration:none; font-size:12px; } .topbar-right a:hover { color:#c9a848; }
    .container { max-width:1100px; margin:0 auto; padding:24px; }
    .stats { display:grid; grid-template-columns:repeat(auto-fit, minmax(140px, 1fr)); gap:14px; margin-bottom:24px; }
    .stat { background:#141414; border:1px solid #262626; border-radius:8px; padding:16px; }
    .stat-label { font-size:10px; text-transform:uppercase; letter-spacing:1px; color:#737373; margin-bottom:4px; }
    .stat-value { font-size:24px; font-weight:700; color:#fff; }
    .stat-value.gold { color:#c9a848; } .stat-value.green { color:#34d399; } .stat-value.red { color:#f87171; }
    .brand-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(300px, 1fr)); gap:14px; margin-bottom:28px; }
    .brand-card { background:#141414; border:1px solid #262626; border-radius:8px; padding:18px; transition:border-color 0.2s; }
    .brand-card:hover { border-color:#333; }
    .brand-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; }
    .brand-name { font-size:15px; font-weight:600; color:#fff; display:flex; align-items:center; gap:8px; }
    .brand-dot { width:10px; height:10px; border-radius:50%; display:inline-block; flex-shrink:0; }
    .brand-dot.on { background:#34d399; box-shadow:0 0 6px #34d399; }
    .brand-dot.off { background:#f87171; box-shadow:0 0 6px #f87171; }
    .brand-stats { display:grid; grid-template-columns:repeat(3, 1fr); gap:8px; margin-bottom:12px; }
    .brand-stat { text-align:center; }
    .brand-stat-num { font-size:18px; font-weight:700; color:#c9a848; }
    .brand-stat-lbl { font-size:10px; text-transform:uppercase; letter-spacing:0.8px; color:#525252; }
    .brand-meta { font-size:12px; color:#525252; margin-bottom:12px; }
    .brand-meta span { margin-right:12px; }
    .brand-actions { display:flex; gap:6px; }
    .btn { padding:6px 12px; font-size:12px; border-radius:5px; border:1px solid #333; background:transparent; color:#a3a3a3; cursor:pointer; font-family:'Inter',sans-serif; text-decoration:none; display:inline-flex; align-items:center; gap:4px; }
    .btn:hover { border-color:#c9a848; color:#c9a848; }
    .btn-gold { background:#c9a848; color:#0a0a0a; border-color:#c9a848; font-weight:600; } .btn-gold:hover { background:#b8960b; }
    .btn-sm { padding:4px 10px; font-size:11px; }
    .empty { color:#525252; font-size:13px; padding:40px; text-align:center; }
    .color-swatch { width:14px; height:14px; border-radius:3px; display:inline-block; border:1px solid #333; }
    @media (max-width:768px) {
      .topbar { padding:10px 14px; flex-wrap:wrap; gap:8px; }
      .topbar-left { gap:10px; } .topbar-right { gap:8px; font-size:11px; flex-wrap:wrap; }
      .logo { font-size:17px; }
      .container { padding:14px; }
      .stats { grid-template-columns:repeat(2, 1fr); gap:8px; }
      .stat { padding:10px; } .stat-value { font-size:18px; } .stat-label { font-size:9px; }
      .brand-grid { grid-template-columns:1fr; }
      .brand-card { padding:14px; }
      .brand-stats { grid-template-columns:repeat(3, 1fr); gap:6px; }
      .brand-stat-num { font-size:16px; }
      .brand-meta { font-size:11px; }
    }
    @media (max-width:480px) { .topbar-right a:not(:first-child) { display:none; } }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-left">
      <div class="logo">mad<span>Labs</span>lab</div>
      <span style="color:#737373; font-size:13px;">/ OpsTrain Management</span>
    </div>
    <div class="topbar-right">
      <a href="/superadmin">&larr; Dashboard</a>
      <a href="https://ops-train.madladslab.com" target="_blank">OpsTrain Live</a>
      <span><%= superAdmin.email %></span>
    </div>
  </div>

  <div class="container">
    <div class="stats">
      <div class="stat"><div class="stat-label">Total Brands</div><div class="stat-value gold"><%= stats.totalBrands %></div></div>
      <div class="stat"><div class="stat-label">Active</div><div class="stat-value green"><%= stats.activeBrands %></div></div>
      <div class="stat"><div class="stat-label">Preview</div><div class="stat-value"><%= stats.previewBrands %></div></div>
      <div class="stat"><div class="stat-label">Total Users</div><div class="stat-value"><%= stats.totalUsers %></div></div>
    </div>

    <h2 style="font-size:16px; font-weight:500; margin-bottom:16px;">Brands</h2>

    <% if (brands.length === 0) { %>
      <div class="empty">No brands found.</div>
    <% } else { %>
      <div class="brand-grid">
        <% brands.forEach(b => { %>
          <div class="brand-card">
            <div class="brand-header">
              <div class="brand-name">
                <% if (b.color) { %><span class="color-swatch" style="background:<%= b.color %>;"></span><% } %>
                <%= b.name || '(unnamed)' %>
              </div>
              <span class="brand-dot <%= b.active !== false ? 'on' : 'off' %>"></span>
            </div>

            <div class="brand-stats">
              <div class="brand-stat">
                <div class="brand-stat-num"><%= b.userCount %></div>
                <div class="brand-stat-lbl">Users</div>
              </div>
              <div class="brand-stat">
                <div class="brand-stat-num"><%= b.taskCount %></div>
                <div class="brand-stat-lbl">Tasks</div>
              </div>
              <div class="brand-stat">
                <div class="brand-stat-num"><%= b.qrCount %></div>
                <div class="brand-stat-lbl">QR Codes</div>
              </div>
            </div>

            <div class="brand-meta">
              <% if (b.slug) { %><span>Slug: <strong><%= b.slug %></strong></span><% } %>
              <% if (b.location) { %><span><%= b.location %></span><% } %>
              <% if (b.status) { %><span>Status: <%= b.status %></span><% } %>
            </div>

            <div class="brand-actions">
              <a href="/superadmin/opstrain/brand/<%= b._id %>/enter" class="btn btn-sm btn-gold" target="_blank">Enter as Admin</a>
              <form method="POST" action="/superadmin/opstrain/brand/<%= b._id %>/toggle" style="display:inline;">
                <button type="submit" class="btn btn-sm"><%= b.active !== false ? 'Deactivate' : 'Activate' %></button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>
