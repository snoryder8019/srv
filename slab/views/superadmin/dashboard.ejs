<script>

  // ── Graffiti TV ──────────────────────────────────────────────────────────
  let _gftvData = null;

  async function loadGFTV() {
    if (_gftvData) return renderGFTV(_gftvData);
    try {
      const r = await fetch('/superadmin/gftv/data');
      _gftvData = await r.json();
      renderGFTV(_gftvData);
    } catch(e) { console.error('GFTV load error', e); }
  }

  function renderGFTV(d) {
    const { tenants, leads, mrr, totalSubs, planPrices } = d;
    const active  = tenants.filter(t => t.active && !t.isPromo).length;
    const promos  = tenants.filter(t => t.isPromo).length;
    const newLeads = leads.filter(l => l.status === 'new').length;

    document.getElementById('gftvStats').innerHTML = [
      { label:'Tenants',     val:'$' + mrr,    cls:'gold',  sub:'Est. MRR' },
      { label:'Active',      val:active,        cls:'green', sub:'Paying tenants' },
      { label:'Promo',       val:promos,        cls:'',      sub:'Excluded from MRR' },
      { label:'New Leads',   val:newLeads,      cls:'gold',  sub:'Awaiting contact' },
      { label:'Subscribers', val:totalSubs,     cls:'green', sub:'TV email signups' },
    ].map(s => `<div class="stat">
      <div class="stat-label">${s.label}</div>
      <div class="stat-value ${s.cls}">${s.val}</div>
      <div style="font-size:10px;color:#525252;margin-top:2px;">${s.sub}</div>
    </div>`).join('');

    // Tenants table
    document.getElementById('gftvTenantsTable').innerHTML = tenants.length ? tenants.map(t => {
      const tenantMrr = t.active && !t.isPromo ? (planPrices[t.plan] || 0) : 0;
      const tenantData = {};  // subscriber count loaded server-side in stats
      return `<tr>
        <td>
          <div style="font-weight:500;color:#fff;">${t.name}</div>
          <div style="font-size:11px;color:#525252;">${t.slug}</div>
        </td>
        <td><span class="plan-${t.plan}">${t.plan}</span></td>
        <td style="color:#f5c400;font-weight:600;">${tenantMrr ? '$' + tenantMrr + '/mo' : '<span style=\'color:#525252\'>—</span>'}</td>
        <td style="color:#a3a3a3;">—</td>
        <td>
          ${t.active ? '<span class="badge badge-active">ACTIVE</span>' : '<span class="badge badge-suspended">OFF</span>'}
          ${t.isPromo ? '<span class="gftv-promo-badge">PROMO</span>' : ''}
        </td>
        <td class="gftv-links">
          <a href="https://graffititv.madladslab.com/tv/${t.slug}" target="_blank">📺 Display</a>
          <a href="https://graffititv.madladslab.com/admin/${t.slug}" target="_blank">⚙ Admin</a>
          <a href="/superadmin/gftv/tenants/${t.slug}">🔍 Detail</a>
        </td>
        <td>
          <div style="display:flex;gap:4px;flex-wrap:wrap;">
            <button class="btn-sm" onclick="gftvTogglePromo('${t.slug}', this)">${t.isPromo ? 'Unmark Promo' : 'Mark Promo'}</button>
            <button class="btn-sm" onclick="gftvToggleActive('${t.slug}', ${!t.active})">${t.active ? 'Disable' : 'Enable'}</button>
            <button class="btn-sm" style="color:#f87171;border-color:#451a1a;" onclick="gftvDelete('${t.slug}')">Del</button>
          </div>
        </td>
      </tr>`;
    }).join('') : '<tr><td colspan="7" style="color:#525252;text-align:center;padding:20px;">No tenants yet</td></tr>';

    // Leads table
    document.getElementById('gftvLeadsTable').innerHTML = leads.length ? leads.slice().reverse().map(l => `<tr>
      <td style="font-weight:500;">${l.name || '—'}</td>
      <td>${l.email}</td>
      <td style="color:#a3a3a3;">${l.business || '—'}</td>
      <td><span class="plan-${l.plan || 'starter'}">${l.plan || 'starter'}</span></td>
      <td style="color:#525252;font-size:11px;">${l.source || 'landing'}</td>
      <td class="lead-status">
        <select onchange="gftvUpdateLead(${l.id}, this.value)">
          ${['new','contacted','converted','lost'].map(s => `<option value="${s}" ${l.status===s?'selected':''}>${s}</option>`).join('')}
        </select>
      </td>
      <td style="color:#525252;font-size:11px;">${new Date(l.createdAt).toLocaleDateString()}</td>
    </tr>`).join('') : '<tr><td colspan="7" style="color:#525252;text-align:center;padding:20px;">No leads yet</td></tr>';
  }

  async function gftvAddTenant() {
    const slug = document.getElementById('gt-slug').value.toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'');
    const body = {
      name:     document.getElementById('gt-name').value,
      slug,
      email:    document.getElementById('gt-email').value,
      password: document.getElementById('gt-pass').value,
      plan:     document.getElementById('gt-plan').value,
      location: document.getElementById('gt-loc').value,
      color:    document.getElementById('gt-color').value || '#ff5000',
      isPromo:  String(document.getElementById('gt-promo').checked),
    };
    if (!body.name || !body.slug) { document.getElementById('gt-msg').textContent = 'Name and slug required.'; return; }
    const r = await fetch('/superadmin/gftv/tenants', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
    const d = await r.json();
    if (d.ok) {
      document.getElementById('gt-msg').textContent = '✓ Tenant created — ' + slug;
      _gftvData = null; loadGFTV();
    } else {
      document.getElementById('gt-msg').textContent = 'Error: ' + (d.error || 'Unknown');
    }
  }

  async function gftvTogglePromo(slug, btn) {
    const r = await fetch(`/superadmin/gftv/tenants/${slug}/toggle-promo`, { method:'POST' });
    const d = await r.json();
    if (d.ok) { btn.textContent = d.isPromo ? 'Unmark Promo' : 'Mark Promo'; _gftvData = null; loadGFTV(); }
  }

  async function gftvToggleActive(slug, active) {
    await fetch(`/superadmin/gftv/tenants/${slug}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ active }) });
    _gftvData = null; loadGFTV();
  }

  async function gftvDelete(slug) {
    if (!confirm('Delete GFTV tenant ' + slug + '?')) return;
    await fetch(`/superadmin/gftv/tenants/${slug}`, { method:'DELETE' });
    _gftvData = null; loadGFTV();
  }

  async function gftvUpdateLead(id, status) {
    await fetch(`/superadmin/gftv/leads/${id}/status`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ status }) });
    if (_gftvData) {
      _gftvData.leads = _gftvData.leads.map(l => String(l.id) === String(id) ? {...l, status} : l);
      renderGFTV(_gftvData);
    }
  }

  // Load GFTV data when tab is opened
  const _origShowTab = showTab;

  function showTab(id, el) {
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    const panel = document.getElementById('tab-' + id);
    if (panel) panel.classList.add('active');
    if (el) el.classList.add('active');
    else {
      // Find the tab button by matching the id
      document.querySelectorAll('.tab').forEach(t => {
        if (t.getAttribute('onclick')?.includes("'" + id + "'")) t.classList.add('active');
      });
    }
    window.location.hash = 'tab-' + id;
    if (id === 'tools') loadDeprecationPipeline();
    if (id === 'gftv') loadGFTV();
    if (id === 'tools') { loadClaudeBriefing(); checkOllamaFull(); }
  }

  // Restore tab from URL hash on page load
  (function() {
    const hash = window.location.hash.replace('#tab-', '');
    if (hash && document.getElementById('tab-' + hash)) showTab(hash);
    // Mini Ollama dot in topbar — check on load
    (async function() {
      try {
        const r = await fetch('/superadmin/api/tool/ollama');
        const d = await r.json();
        const dot = document.getElementById('ollamaDotTop');
        if (dot) dot.className = (d.ok || d.models) ? 'svc-dot alive' : 'svc-dot dead';
      } catch(e) {
        const dot = document.getElementById('ollamaDotTop');
        if (dot) dot.className = 'svc-dot dead';
      }
    })();
    // Load Claude briefing if tools tab already active
    if (!window.location.hash || window.location.hash === '#tab-tools') loadClaudeBriefing();
  })();

  async function runTool(tool) {
    const out = document.getElementById('toolOutput');
    out.textContent = 'Running ' + tool + '...';
    try {
      const res = await fetch('/superadmin/api/tool/' + tool);
      const data = await res.json();
      out.textContent = data.output || JSON.stringify(data, null, 2);
    } catch (e) {
      out.textContent = 'Error: ' + e.message;
    }
  }

  async function svcAction(name, action) {
    const out = document.getElementById('toolOutput') || document.getElementById('agentOutput') || document.getElementById('opsOutput') || document.getElementById('gamesOutput');
    if (out) out.textContent = 'Checking ' + name + '...';
    try {
      const res = await fetch('/superadmin/api/service/' + name + '/' + action);
      const data = await res.json();
      if (out) out.textContent = data.output || JSON.stringify(data, null, 2);
    } catch (e) {
      if (out) out.textContent = 'Error: ' + e.message;
    }
  }

  // ── Claude briefing (pulled from Huginn sessions) ──────────────────────────
  const CLAUDE_BRIEFING = {
    sessions: [
      "Connected via MCP server at mcp.madladslab.com — full /srv read/write access.",
      "This session: built GFTV SaaS tenant architecture, 15 display themes, superadmin integration, platform user sync.",
      "Security hardening: mod_evasive, 4 fail2ban jails (HTTP 404, scanner, badbots, recidive), UFW blocks on known Azure scanner ranges, Apache blanket rules blocking .php/.env/.git/wp-* probes.",
      "VSCode watchdog cron installed — auto-kills runaway extension host if RAM > 20%.",
      "Piper TTS migration to ElevenLabs pending. OpenCalw removed from system.",
      "GFTV: 15 themes live, tenant admin panel, super admin tab in slab, platform users synced, QR codes baked into all templates linking to backend routes.",
      "Slab superadmin logo updated to Space Grotesk (madladslab.com typeface) across all 16 superadmin views.",
    ],
    tldr: [
      "🏗️ Built Graffiti TV SaaS — multi-tenant, 15 themes, QR offers, admin panels, landing page ($18/$35 plans)",
      "🔒 Full server hardening — fail2ban HTTP jails, Apache scanner blocks, UFW firewall, VSCode watchdog",
      "📺 GFTV integrated into slab superadmin — Graffiti TV tab, tenant detail views, platform users synced",
      "🎨 Superadmin logo → Space Grotesk across all views",
      "🚧 Piper TTS → ElevenLabs migration queued · OpenCalw removed",
    ]
  };

  function loadClaudeBriefing() {
    const bt = document.getElementById('claudeBriefingText');
    const tt = document.getElementById('claudeTldrText');
    if (!bt || !tt) return;
    bt.innerHTML = CLAUDE_BRIEFING.sessions.map(s => `<div style="margin-bottom:6px;padding-left:10px;border-left:2px solid #6366f1;">• ${s}</div>`).join('');
    tt.innerHTML = CLAUDE_BRIEFING.tldr.map(s => `<div style="margin-bottom:4px;">${s}</div>`).join('');
  }


  // ── Ollama inline health ──────────────────────────────────────────────────
  async function checkOllamaFull() {
    const dot  = document.getElementById('ollamaDot');
    const snip = document.getElementById('ollamaSnip');
    const out  = document.getElementById('agentOutput');
    if (out) out.textContent = 'Checking Ollama...';
    try {
      const res = await fetch('/superadmin/api/tool/ollama');
      const d = await res.json();
      if (d.ok || d.models) {
        if (dot) { dot.className = 'svc-dot alive'; }
        const models = d.models || [];
        if (snip) snip.textContent = models.length ? models.join(' · ') : 'Online — no models listed';
        if (out) out.textContent = JSON.stringify(d, null, 2);
      } else {
        if (dot) dot.className = 'svc-dot dead';
        if (snip) snip.textContent = 'Offline — ' + (d.error || 'no response');
        if (out) out.textContent = 'Ollama offline: ' + (d.error || 'unknown');
      }
    } catch(e) {
      if (dot) dot.className = 'svc-dot dead';
      if (snip) snip.textContent = 'Unreachable';
      if (out) out.textContent = 'Error: ' + e.message;
    }
  }


  async function checkOllama() {
    return checkOllamaFull();
  }
  async function _checkOllamaOld() {
    const out = document.getElementById('agentOutput');
    out.textContent = 'Checking Ollama...';
    try {
      const res = await fetch('/superadmin/api/tool/ollama');
      const data = await res.json();
      out.textContent = data.output || JSON.stringify(data, null, 2);
    } catch (e) {
      out.textContent = 'Error: ' + e.message;
    }
  }

  // ── Deprecation Pipeline ──
  const STAGE_COLORS = { 'new': '#c9a848', 'cleansed': '#38bdf8', 'deconstructed': '#a78bfa', 'deletion-stage': '#f87171' };
  const STAGE_NEXT = { 'new': 'cleanse', 'cleansed': 'deconstruct', 'deconstructed': 'stage-delete' };
  const STAGE_LABELS = { 'new': 'Cleanse', 'cleansed': 'Deconstruct', 'deconstructed': 'Stage for Delete' };

  async function loadDeprecationPipeline() {
    try {
      const res = await fetch('/superadmin/api/deprecation/pipeline');
      const data = await res.json();
      if (!data.ok) return;
      const sel = document.getElementById('deprProjectSelect');
      sel.innerHTML = '<option value="">— select project —</option>';
      data.available.forEach(p => { const opt = document.createElement('option'); opt.value = p; opt.textContent = p; sel.appendChild(opt); });
      document.getElementById('deprCountNew').textContent = data.pipeline['new']?.length || 0;
      document.getElementById('deprCountCleansed').textContent = data.pipeline['cleansed']?.length || 0;
      document.getElementById('deprCountDeconstructed').textContent = data.pipeline['deconstructed']?.length || 0;
      document.getElementById('deprCountDeletion').textContent = data.pipeline['deletion-stage']?.length || 0;
      renderDeprStage('new', data.pipeline['new'] || [], 'deprGridNew');
      renderDeprStage('cleansed', data.pipeline['cleansed'] || [], 'deprGridCleansed');
      renderDeprStage('deconstructed', data.pipeline['deconstructed'] || [], 'deprGridDeconstructed');
      renderDeprStage('deletion-stage', data.pipeline['deletion-stage'] || [], 'deprGridDeletion');
    } catch (e) { document.getElementById('deprOutput').textContent = 'Error: ' + e.message; }
  }

  function renderDeprStage(stage, projects, gridId) {
    const grid = document.getElementById(gridId);
    if (!projects.length) { grid.innerHTML = ''; return; }
    grid.innerHTML = projects.map(p => {
      const color = STAGE_COLORS[stage];
      const nextAction = STAGE_NEXT[stage];
      const nextLabel = STAGE_LABELS[stage];
      const receipt = p.receipt || {};
      const dateStr = receipt.deprecatedAt ? new Date(receipt.deprecatedAt).toLocaleDateString() : '—';
      let manifestHint = '';
      if (p.manifest && p.manifest.totalSensitiveFiles > 0) manifestHint = '<div style="margin-top:6px;font-size:11px;color:#c9a848;">Config manifest: ' + p.manifest.totalSensitiveFiles + ' sensitive file(s)</div>';
      let reviewHint = '';
      if (p.review) {
        const flags = p.review.flags || {}; const ext = p.review.external || {}; const items = [];
        if (flags.apacheConfs?.length) items.push(flags.apacheConfs.length + ' Apache conf(s)');
        if (flags.cronEntries?.length) items.push(flags.cronEntries.length + ' cron ref(s)');
        if (flags.stillInAutostart) items.push('still in autostart!');
        if (flags.inServiceRegistry) items.push('in service registry');
        if (ext.database?.found) { const dbs = ext.database.liveMatches || []; items.push(dbs.length + ' DB(s)'); }
        if (ext.bucket?.found) items.push('bucket refs');
        if (ext.localFiles?.found) items.push(ext.localFiles.totalFiles + ' local file(s)');
        if (items.length) reviewHint = '<div style="margin-top:6px;font-size:11px;color:#f87171;">Flags: ' + items.join(', ') + '</div>';
      }
      let actions = '';
      if (nextAction) actions += '<button class="btn-sm" onclick="deprAdvance(\'' + p.name + '\', \'' + nextAction + '\')" style="border-color:' + color + ';color:' + color + ';">' + nextLabel + '</button>';
      if (p.manifest) actions += ' <button class="btn-sm" onclick="deprViewManifest(\'' + p.name + '\')">Manifest</button>';
      if (p.hasReport) actions += ' <button class="btn-sm" onclick="deprViewReport(\'' + p.name + '\')">Report</button>';
      if (p.review) actions += ' <button class="btn-sm" onclick="deprViewReview(\'' + p.name + '\')" style="border-color:#f87171;color:#f87171;">Review</button>';
      return '<div class="card"><div class="card-header"><span class="card-title">' + p.name + '</span><span style="font-size:11px;color:' + color + ';">' + p.size + '</span></div><div class="card-meta"><span>Deprecated: ' + dateStr + '</span></div>' + manifestHint + reviewHint + '<div class="card-actions" style="margin-top:8px;">' + actions + '</div></div>';
    }).join('');
  }

  async function deprAdvance(project, action) {
    if (!project) return alert('Select a project first');
    const out = document.getElementById('deprOutput');
    out.textContent = 'Running ' + action + ' on ' + project + '...';
    try {
      const res = await fetch('/superadmin/api/deprecation/advance', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ project, action }) });
      const data = await res.json();
      out.textContent = JSON.stringify(data, null, 2);
      loadDeprecationPipeline();
    } catch (e) { out.textContent = 'Error: ' + e.message; }
  }

  async function deprViewManifest(project) {
    const out = document.getElementById('deprOutput');
    out.textContent = 'Loading manifest for ' + project + '...';
    try {
      const res = await fetch('/superadmin/api/deprecation/manifest/' + project);
      const data = await res.json();
      if (data.manifest) {
        let txt = '=== CONFIG MANIFEST: ' + project + ' ===\n\n';
        txt += 'Sensitive files: ' + (data.manifest.totalSensitiveFiles || 0) + '\n\n';
        (data.manifest.sensitiveFiles || []).forEach(f => { txt += '--- ' + f.path + ' (' + f.type + ') ---\n'; if (f.keys?.length) txt += '  Keys: ' + f.keys.join(', ') + '\n'; txt += '\n'; });
        out.textContent = txt;
      } else out.textContent = JSON.stringify(data, null, 2);
    } catch (e) { out.textContent = 'Error: ' + e.message; }
  }

  async function deprViewReport(project) {
    const out = document.getElementById('deprOutput');
    try { const res = await fetch('/superadmin/api/deprecation/report/' + project); const data = await res.json(); out.textContent = data.report || JSON.stringify(data, null, 2); }
    catch (e) { out.textContent = 'Error: ' + e.message; }
  }

  async function deprViewReview(project) {
    const out = document.getElementById('deprOutput');
    out.textContent = 'Loading review...';
    try {
      const res = await fetch('/superadmin/api/deprecation/review/' + project);
      const data = await res.json();
      if (data.review) {
        let txt = '=== DELETION REVIEW: ' + project + ' ===\n\n';
        const flags = data.review.flags || {}; const ext = data.review.external || {};
        txt += '── SYSTEM ──\n';
        if (flags.apacheConfs?.length) txt += 'Apache: ' + flags.apacheConfs.join(', ') + '\n';
        if (flags.cronEntries?.length) txt += 'Cron: ' + flags.cronEntries.join(', ') + '\n';
        if (flags.stillInAutostart) txt += '!! STILL IN AUTOSTART !!\n';
        if (flags.inServiceRegistry) txt += '!! IN SERVICE REGISTRY !!\n';
        txt += '\n── DATABASE ──\n';
        if (ext.database?.found && ext.database.liveMatches?.length) ext.database.liveMatches.forEach(db => { txt += db.name + ' (' + db.sizeMB + ' MB, ' + db.collectionCount + ' cols)\n'; });
        else txt += 'None\n';
        txt += '\n── BUCKET ──\n';
        if (ext.bucket?.found) txt += [...new Set(ext.bucket.references)].join(', ') + '\n'; else txt += 'None\n';
        txt += '\n── LOCAL FILES ──\n';
        if (ext.localFiles?.found) txt += ext.localFiles.totalFiles + ' files (' + ext.localFiles.totalSizeMB + ' MB)\n'; else txt += 'None\n';
        out.textContent = txt;
      } else out.textContent = JSON.stringify(data, null, 2);
    } catch (e) { out.textContent = 'Error: ' + e.message; }
  }
</script>
<span class="badge-overseer">SUPERADMIN</span>
