          <div class="card">
            <div class="card-header">
              <span class="card-title"><%= svc.name %></span>
              <span class="svc-dot <%= svc.alive ? 'alive' : (svc.alive === false ? 'dead' : 'unknown') %>"></span>
            </div>
            <div class="card-desc"><%= svc.description %></div>
            <div class="card-meta">
              <% if (svc.port) { %><span>:<%= svc.port %></span><% } %>
              <% if (svc.domain) { %><span><a href="https://<%= svc.domain %>" target="_blank" class="link" style="font-size:11px;"><%= svc.domain %></a></span><% } %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="section">
      <h2>Tenants</h2>
      <div class="table-wrap">
      <table>
        <thead><tr><th>Domain</th><th>Brand</th><th>Status</th><th>Plan</th><th>Promo</th><th>Owner</th><th>Tags</th><th></th></tr></thead>
        <tbody>
          <% for (const t of tenants) { %>
            <tr>
              <td><a href="https://<%= t.domain %>" class="link" target="_blank"><%= t.domain %></a></td>
              <td><%= t.brand?.name || '—' %></td>
              <td><span class="status status-<%= t.status || 'preview' %>"><%= t.status || 'preview' %></span></td>
              <td><%= t.meta?.plan || 'free' %></td>
              <td>
                <form method="POST" action="/superadmin/tenants/<%= t._id %>/toggle-promo" style="display:inline;">
                  <button type="submit" class="btn-sm" style="<%= t.meta?.isPromo ? 'background:#422006;color:#fdba74;border-color:#422006;' : '' %>" title="<%= t.meta?.isPromo ? 'Promo account — excluded from MRR. Click to unmark.' : 'Click to mark as promo (excludes from MRR)' %>">
                    <%= t.meta?.isPromo ? 'Promo' : '\u2014' %>
                  </button>
                </form>
              </td>
              <td style="color:#737373; font-size:12px;"><%= t.meta?.ownerEmail || '—' %></td>
              <td>
                <% if (t.tags?.length) { t.tags.forEach(tag => {
                  const td = tagDefs[tag];
                  if (td) { %><span class="tag" style="background:<%= td.bg %>; color:<%= td.color %>;"><%= td.label %></span><% }
                }); } %>
              </td>
              <td><a href="/superadmin/tenants/<%= t._id %>" class="btn-sm">Manage</a></td>
            </tr>
          <% } %>
        </tbody>
      </table>
      </div>
    </div>
