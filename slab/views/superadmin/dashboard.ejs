  // ── Ollama Tunnel — health + analytics ───────────────────────────────────
  function fmtBytes(n) {
    if (n == null) return '—';
    const u = ['B','KB','MB','GB','TB']; let i = 0; let v = Number(n);
    while (v >= 1024 && i < u.length - 1) { v /= 1024; i++; }
    return v.toFixed(v >= 100 ? 0 : 1) + ' ' + u[i];
  }
  function fmtNum(n) { return n == null ? '—' : Number(n).toLocaleString(); }
  function fmtMs(n)  { return n == null ? '—' : (n >= 1000 ? (n/1000).toFixed(1)+'s' : Math.round(n)+'ms'); }
  function pct(num, den) { if (!den) return '0%'; return (100 * num / den).toFixed(1) + '%'; }

  async function refreshOllamaTopbar() {
    const dot = document.getElementById('ollamaDotTop');
    try {
      const r = await fetch('/superadmin/api/ollama/health');
      const d = await r.json();
      const up = !!(d?.llm?.ok || d?.sd?.ok);
      if (dot) dot.className = up ? 'svc-dot alive' : 'svc-dot dead';
    } catch { if (dot) dot.className = 'svc-dot dead'; }
  }

  async function loadOllamaAnalytics() {
    const dot   = document.getElementById('ollamaDot');
    const llmP  = document.getElementById('ollamaLlmPill');
    const sdP   = document.getElementById('ollamaSdPill');
    const snip  = document.getElementById('ollamaSnip');
    const days  = parseInt(document.getElementById('ollamaWindow')?.value || '7', 10);
    const since = new Date(Date.now() - days * 86400 * 1000).toISOString();
    const updatedAt = document.getElementById('ollamaUpdatedAt');

    // Health
    try {
      const h = await (await fetch('/superadmin/api/ollama/health')).json();
      const llmOk = !!h?.llm?.ok, sdOk = !!h?.sd?.ok;
      if (dot)  dot.className = (llmOk || sdOk) ? 'svc-dot alive' : 'svc-dot dead';
      if (llmP) { llmP.textContent = 'LLM ' + (llmOk ? '✓' : '✗') + (h?.llm?.status ? ' · ' + h.llm.status : ''); llmP.style.color = llmOk ? '#34d399' : '#f87171'; }
      if (sdP)  { sdP.textContent  = 'SD '  + (sdOk  ? '✓' : '✗') + (h?.sd?.status  ? ' · ' + h.sd.status  : ''); sdP.style.color  = sdOk  ? '#34d399' : '#f87171'; }
      const models = h?.llm?.models || h?.llm?.available || [];
      if (snip) snip.textContent = 'models: ' + (Array.isArray(models) && models.length ? models.slice(0,4).join(' · ') : '—');
    } catch (e) {
      if (dot) dot.className = 'svc-dot dead';
      if (llmP) { llmP.textContent = 'LLM ✗'; llmP.style.color = '#f87171'; }
      if (sdP)  { sdP.textContent  = 'SD ✗';  sdP.style.color  = '#f87171'; }
      if (snip) snip.textContent = 'unreachable';
    }

    // Analytics + live rate + keys (in parallel)
    const [aRes, rRes, kRes] = await Promise.allSettled([
      fetch('/superadmin/api/ollama/analytics?since=' + encodeURIComponent(since)).then(r => r.json()),
      fetch('/superadmin/api/ollama/rate').then(r => r.json()),
      fetch('/superadmin/api/ollama/keys').then(r => r.json()),
    ]);
    const a = aRes.status === 'fulfilled' && aRes.value?.ok ? aRes.value.data : null;
    const rate = rRes.status === 'fulfilled' && rRes.value?.ok ? rRes.value.data : null;
    const ks   = kRes.status === 'fulfilled' && kRes.value?.ok ? kRes.value.data : null;

    renderOllamaStats(a);
    renderOllamaKeys(a, rate, ks);
    renderOllamaTopList('ollamaRoutesTable', extractTop(a, 'routes', 'route'));
    renderOllamaTopList('ollamaModelsTable', extractTop(a, 'models', 'model'));
    renderOllamaFlags(a, rate, ks);
    if (updatedAt) updatedAt.textContent = 'updated ' + new Date().toLocaleTimeString();
  }

  // The cluster's /analytics shape isn't strictly fixed; try common keys.
  function extractTop(a, plural, singular) {
    if (!a) return [];
    const candidates = [a[plural], a['top_' + plural], a['by_' + singular], a['by_' + plural], a.top?.[plural], a.aggregates?.[plural]];
    for (const c of candidates) {
      if (Array.isArray(c)) return c;
      if (c && typeof c === 'object') return Object.entries(c).map(([k,v]) => ({ [singular]: k, ...(typeof v === 'object' ? v : { requests: v }) }));
    }
    return [];
  }

  function sumField(obj, field) {
    if (!obj || typeof obj !== 'object') return null;
    let total = 0, found = false;
    for (const v of Object.values(obj)) {
      if (v && typeof v === 'object' && typeof v[field] === 'number') { total += v[field]; found = true; }
    }
    return found ? total : null;
  }

  function renderOllamaStats(a) {
    const t = a || {};
    const byKey = t.by_key || t.keys || {};
    const req = t.total_requests ?? t.totals?.requests ?? t.requests ?? sumField(byKey, 'requests');
    const err = t.total_errors ?? t.totals?.errors ?? sumField(byKey, 'errors');
    const bytes = t.total_bytes_out ?? t.totals?.bytes_out ?? sumField(byKey, 'bytes_out');
    let dur = t.totals?.avg_duration_ms ?? t.avg_duration_ms ?? null;
    if (dur == null && t.total_duration_ms != null && req) dur = t.total_duration_ms / req;
    const keyCount = byKey ? (Array.isArray(byKey) ? byKey.length : Object.keys(byKey).length) : null;
    document.getElementById('ollamaStatReq').textContent = fmtNum(req);
    document.getElementById('ollamaStatErr').textContent = fmtNum(err);
    document.getElementById('ollamaStatErrRate').textContent = (req && err != null) ? pct(err, req) : '—';
    document.getElementById('ollamaStatBytes').textContent = fmtBytes(bytes);
    document.getElementById('ollamaStatDur').textContent = fmtMs(dur);
    document.getElementById('ollamaStatKeys').textContent = fmtNum(keyCount);
  }

  function renderOllamaKeys(a, rate, ks) {
    const el = document.getElementById('ollamaKeysTable');
    // Build a merged view: per-key totals from analytics + live rpm/rpd/inflight from rate
    const byLabel = {};
    const aKeys = a?.keys || a?.by_key || {};
    if (Array.isArray(aKeys)) aKeys.forEach(k => { if (k?.label) byLabel[k.label] = { ...k }; });
    else if (aKeys && typeof aKeys === 'object') Object.entries(aKeys).forEach(([label, v]) => { byLabel[label] = { label, ...(typeof v === 'object' ? v : {}) }; });

    const rk = rate?.keys || rate?.by_key || rate || {};
    if (rk && typeof rk === 'object') Object.entries(rk).forEach(([label, v]) => {
      if (!v || typeof v !== 'object') return;
      byLabel[label] = { ...(byLabel[label] || { label }), live: v };
    });

    // Limits from keys.json snapshot
    const km = {};
    const kArr = ks?.keys || (Array.isArray(ks) ? ks : []);
    if (Array.isArray(kArr)) kArr.forEach(k => { if (k?.label) km[k.label] = k; });

    const rows = Object.values(byLabel);
    if (!rows.length) { el.textContent = 'No key data.'; return; }
    rows.sort((x, y) => (y.requests || 0) - (x.requests || 0));

    let html = '<table style="width:100%;border-collapse:collapse;font-size:11px;">';
    html += '<tr style="color:#525252;text-align:left;"><th style="padding:4px 6px;">Key</th><th>Req</th><th>Err</th><th>RPM</th><th>RPD</th><th>Inflight</th></tr>';
    rows.slice(0, 10).forEach(k => {
      const lim = km[k.label]?.limits || {};
      const live = k.live || {};
      const rpdUsed = live.last_day ?? live.rpd ?? null;
      const rpdLim  = lim.rpd ?? null;
      const rpmCur  = live.last_minute ?? live.rpm ?? null;
      const inflight = live.inflight ?? null;
      const errRate = (k.requests && k.errors != null) ? (k.errors / k.requests) : 0;
      const errColor = errRate > 0.10 ? '#f87171' : '#a3a3a3';
      const rpdHot = (rpdUsed != null && rpdLim && rpdUsed / rpdLim >= 0.8);
      const rpdColor = rpdHot ? '#f59e0b' : '#a3a3a3';
      html += `<tr style="border-top:1px solid #1a1a1a;">
        <td style="padding:4px 6px;color:#e5e5e5;">${escapeHtml(k.label || '—')}</td>
        <td>${fmtNum(k.requests)}</td>
        <td style="color:${errColor};">${fmtNum(k.errors)}</td>
        <td>${rpmCur == null ? '—' : fmtNum(rpmCur)}${lim.rpm ? ' / ' + fmtNum(lim.rpm) : ''}</td>
        <td style="color:${rpdColor};">${rpdUsed == null ? '—' : fmtNum(rpdUsed)}${rpdLim ? ' / ' + fmtNum(rpdLim) : ''}</td>
        <td>${inflight == null ? '—' : fmtNum(inflight)}${lim.concurrent ? ' / ' + fmtNum(lim.concurrent) : ''}</td>
      </tr>`;
    });
    html += '</table>';
    el.innerHTML = html;
  }

  function renderOllamaTopList(elId, items) {
    const el = document.getElementById(elId);
    if (!items || !items.length) { el.textContent = '—'; return; }
    items.sort((a, b) => (b.requests || b.count || 0) - (a.requests || a.count || 0));
    let html = '<table style="width:100%;border-collapse:collapse;font-size:11px;">';
    items.slice(0, 8).forEach(it => {
      const label = it.route || it.model || it.name || it.label || Object.keys(it)[0];
      const count = it.requests ?? it.count ?? 0;
      html += `<tr style="border-top:1px solid #1a1a1a;"><td style="padding:3px 6px;color:#e5e5e5;">${escapeHtml(String(label))}</td><td style="text-align:right;color:#a3a3a3;">${fmtNum(count)}</td></tr>`;
    });
    html += '</table>';
    el.innerHTML = html;
  }

  function renderOllamaFlags(a, rate, ks) {
    const el = document.getElementById('ollamaFlags');
    const flags = [];
    const aKeys = a?.keys || a?.by_key || {};
    const keyList = Array.isArray(aKeys) ? aKeys : Object.entries(aKeys).map(([label, v]) => ({ label, ...(typeof v === 'object' ? v : {}) }));
    const km = {};
    const kArr = ks?.keys || (Array.isArray(ks) ? ks : []);
    if (Array.isArray(kArr)) kArr.forEach(k => { if (k?.label) km[k.label] = k; });
    const rk = rate?.keys || rate?.by_key || rate || {};

    keyList.forEach(k => {
      const er = k.requests ? (k.errors || 0) / k.requests : 0;
      if (er > 0.10 && (k.requests || 0) >= 20) flags.push(`<span style="color:#f87171;">${escapeHtml(k.label)} error rate ${(er*100).toFixed(1)}%</span>`);
    });
    if (rk && typeof rk === 'object') {
      Object.entries(rk).forEach(([label, v]) => {
        if (!v || typeof v !== 'object') return;
        const rpd = v.last_day ?? v.rpd ?? null;
        const lim = km[label]?.limits?.rpd ?? null;
        if (rpd != null && lim && rpd / lim >= 0.8) flags.push(`<span style="color:#f59e0b;">${escapeHtml(label)} at ${(rpd/lim*100).toFixed(0)}% of rpd quota</span>`);
        const inflight = v.inflight ?? null;
        const conc = km[label]?.limits?.concurrent ?? null;
        if (inflight != null && conc && inflight >= conc) flags.push(`<span style="color:#f59e0b;">${escapeHtml(label)} pinned at concurrency limit</span>`);
      });
    }
    el.innerHTML = flags.length ? '⚑ ' + flags.join(' · ') : '<span style="color:#525252;">no flags</span>';
  }

  function escapeHtml(s) { return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

  // ── Deprecation Pipeline ──
  const STAGE_COLORS = { 'new': '#c9a848', 'cleansed': '#38bdf8', 'deconstructed': '#a78bfa', 'deletion-stage': '#f87171' };
  const STAGE_NEXT = { 'new': 'cleanse', 'cleansed': 'deconstruct', 'deconstructed': 'stage-delete' };
  const STAGE_LABELS = { 'new': 'Cleanse', 'cleansed': 'Deconstruct', 'deconstructed': 'Stage for Delete' };

  async function loadDeprecationPipeline() {
    try {
      const res = await fetch('/superadmin/api/deprecation/pipeline');
      const data = await res.json();
      if (!data.ok) return;
      const sel = document.getElementById('deprProjectSelect');
      sel.innerHTML = '<option value="">— select project —</option>';
      data.available.forEach(p => { const opt = document.createElement('option'); opt.value = p; opt.textContent = p; sel.appendChild(opt); });
      document.getElementById('deprCountNew').textContent = data.pipeline['new']?.length || 0;
      document.getElementById('deprCountCleansed').textContent = data.pipeline['cleansed']?.length || 0;
      document.getElementById('deprCountDeconstructed').textContent = data.pipeline['deconstructed']?.length || 0;
      document.getElementById('deprCountDeletion').textContent = data.pipeline['deletion-stage']?.length || 0;
      renderDeprStage('new', data.pipeline['new'] || [], 'deprGridNew');
      renderDeprStage('cleansed', data.pipeline['cleansed'] || [], 'deprGridCleansed');
      renderDeprStage('deconstructed', data.pipeline['deconstructed'] || [], 'deprGridDeconstructed');
      renderDeprStage('deletion-stage', data.pipeline['deletion-stage'] || [], 'deprGridDeletion');
    } catch (e) { document.getElementById('deprOutput').textContent = 'Error: ' + e.message; }
  }

  function renderDeprStage(stage, projects, gridId) {
    const grid = document.getElementById(gridId);
    if (!projects.length) { grid.innerHTML = ''; return; }
    grid.innerHTML = projects.map(p => {
      const color = STAGE_COLORS[stage];
      const nextAction = STAGE_NEXT[stage];
      const nextLabel = STAGE_LABELS[stage];
      const receipt = p.receipt || {};
      const dateStr = receipt.deprecatedAt ? new Date(receipt.deprecatedAt).toLocaleDateString() : '—';
      let manifestHint = '';
      if (p.manifest && p.manifest.totalSensitiveFiles > 0) manifestHint = '<div style="margin-top:6px;font-size:11px;color:#c9a848;">Config manifest: ' + p.manifest.totalSensitiveFiles + ' sensitive file(s)</div>';
      let reviewHint = '';
      if (p.review) {
        const flags = p.review.flags || {}; const ext = p.review.external || {}; const items = [];
        if (flags.apacheConfs?.length) items.push(flags.apacheConfs.length + ' Apache conf(s)');
        if (flags.cronEntries?.length) items.push(flags.cronEntries.length + ' cron ref(s)');
        if (flags.stillInAutostart) items.push('still in autostart!');
        if (flags.inServiceRegistry) items.push('in service registry');
        if (ext.database?.found) { const dbs = ext.database.liveMatches || []; items.push(dbs.length + ' DB(s)'); }
        if (ext.bucket?.found) items.push('bucket refs');
        if (ext.localFiles?.found) items.push(ext.localFiles.totalFiles + ' local file(s)');
        if (items.length) reviewHint = '<div style="margin-top:6px;font-size:11px;color:#f87171;">Flags: ' + items.join(', ') + '</div>';
      }
      let actions = '';
      if (nextAction) actions += '<button class="btn-sm" onclick="deprAdvance(\'' + p.name + '\', \'' + nextAction + '\')" style="border-color:' + color + ';color:' + color + ';">' + nextLabel + '</button>';
      if (p.manifest) actions += ' <button class="btn-sm" onclick="deprViewManifest(\'' + p.name + '\')">Manifest</button>';
      if (p.hasReport) actions += ' <button class="btn-sm" onclick="deprViewReport(\'' + p.name + '\')">Report</button>';
      if (p.review) actions += ' <button class="btn-sm" onclick="deprViewReview(\'' + p.name + '\')" style="border-color:#f87171;color:#f87171;">Review</button>';
      return '<div class="card"><div class="card-header"><span class="card-title">' + p.name + '</span><span style="font-size:11px;color:' + color + ';">' + p.size + '</span></div><div class="card-meta"><span>Deprecated: ' + dateStr + '</span></div>' + manifestHint + reviewHint + '<div class="card-actions" style="margin-top:8px;">' + actions + '</div></div>';
    }).join('');
  }

  async function deprAdvance(project, action) {
    if (!project) return alert('Select a project first');
    const out = document.getElementById('deprOutput');
    out.textContent = 'Running ' + action + ' on ' + project + '...';
    try {
      const res = await fetch('/superadmin/api/deprecation/advance', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ project, action }) });
      const data = await res.json();
      out.textContent = JSON.stringify(data, null, 2);
      loadDeprecationPipeline();
    } catch (e) { out.textContent = 'Error: ' + e.message; }
  }

  async function deprViewManifest(project) {
    const out = document.getElementById('deprOutput');
    out.textContent = 'Loading manifest for ' + project + '...';
    try {
      const res = await fetch('/superadmin/api/deprecation/manifest/' + project);
      const data = await res.json();
      if (data.manifest) {
        let txt = '=== CONFIG MANIFEST: ' + project + ' ===\n\n';
        txt += 'Sensitive files: ' + (data.manifest.totalSensitiveFiles || 0) + '\n\n';
        (data.manifest.sensitiveFiles || []).forEach(f => { txt += '--- ' + f.path + ' (' + f.type + ') ---\n'; if (f.keys?.length) txt += '  Keys: ' + f.keys.join(', ') + '\n'; txt += '\n'; });
        out.textContent = txt;
      } else out.textContent = JSON.stringify(data, null, 2);
    } catch (e) { out.textContent = 'Error: ' + e.message; }
  }

  async function deprViewReport(project) {
    const out = document.getElementById('deprOutput');
    try { const res = await fetch('/superadmin/api/deprecation/report/' + project); const data = await res.json(); out.textContent = data.report || JSON.stringify(data, null, 2); }
    catch (e) { out.textContent = 'Error: ' + e.message; }
  }

  async function deprViewReview(project) {
    const out = document.getElementById('deprOutput');
    out.textContent = 'Loading review...';
    try {
      const res = await fetch('/superadmin/api/deprecation/review/' + project);
      const data = await res.json();
      if (data.review) {
        let txt = '=== DELETION REVIEW: ' + project + ' ===\n\n';
        const flags = data.review.flags || {}; const ext = data.review.external || {};
        txt += '── SYSTEM ──\n';
        if (flags.apacheConfs?.length) txt += 'Apache: ' + flags.apacheConfs.join(', ') + '\n';
        if (flags.cronEntries?.length) txt += 'Cron: ' + flags.cronEntries.join(', ') + '\n';
        if (flags.stillInAutostart) txt += '!! STILL IN AUTOSTART !!\n';
        if (flags.inServiceRegistry) txt += '!! IN SERVICE REGISTRY !!\n';
        txt += '\n── DATABASE ──\n';
        if (ext.database?.found && ext.database.liveMatches?.length) ext.database.liveMatches.forEach(db => { txt += db.name + ' (' + db.sizeMB + ' MB, ' + db.collectionCount + ' cols)\n'; });
        else txt += 'None\n';
        txt += '\n── BUCKET ──\n';
        if (ext.bucket?.found) txt += [...new Set(ext.bucket.references)].join(', ') + '\n'; else txt += 'None\n';
        txt += '\n── LOCAL FILES ──\n';
        if (ext.localFiles?.found) txt += ext.localFiles.totalFiles + ' files (' + ext.localFiles.totalSizeMB + ' MB)\n'; else txt += 'None\n';
        out.textContent = txt;
      } else out.textContent = JSON.stringify(data, null, 2);
    } catch (e) { out.textContent = 'Error: ' + e.message; }
  }

  // ── Workspace tab ────────────────────────────────────────────────────────
  const WS = {
    services: <%- JSON.stringify(services.map(s => ({ name:s.name, category:s.category, port:s.port, tmux:s.tmux, alive:s.alive===true, description:s.description||'', dir:s.dir||null, domain:s.domain||null }))) %>,
    pulseMap: {},        // name → { conns, idleMs, pulse, alive, unregistered }
    selected: null,
    filter: 'all',
    search: '',
    autoTailTimer: null,
    pollPipe: null,
  };
  function wsEsc(s) { return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
  function wsHumanIdle(ms) {
    if (ms == null) return '—';
    const s = Math.floor(ms/1000); if (s < 60) return s + 's idle';
    const m = Math.floor(s/60); if (m < 60) return m + 'm idle';
    const h = Math.floor(m/60); return h + 'h idle';
  }

  function wsAllServices() {
    // Merge static services list with any unregistered tmux from pulseMap
    const known = new Map(WS.services.map(s => [s.name, s]));
    Object.values(WS.pulseMap).forEach(p => {
      if (!known.has(p.name)) {
        known.set(p.name, { name:p.name, category:p.category || 'unregistered', port:p.port, tmux:p.tmux, alive:!!p.alive, description:'(tmux only)', unregistered:true });
      } else {
        const s = known.get(p.name);
        s.alive = !!p.alive;
        s.conns = p.conns;
        s.idleMs = p.idleMs;
      }
    });
    return [...known.values()];
  }

  function wsApplyFilter(list) {
    const q = WS.search.trim().toLowerCase();
    return list.filter(s => {
      if (q && !`${s.name} ${s.tmux||''} ${s.port||''} ${s.category||''}`.toLowerCase().includes(q)) return false;
      switch (WS.filter) {
        case 'all': return true;
        case 'alive': return !!s.alive;
        case 'dead': return !s.alive;
        case 'unregistered': return !!s.unregistered;
        default: return (s.category || '') === WS.filter;
      }
    });
  }

  function wsRender() {
    const list = wsApplyFilter(wsAllServices()).sort((a, b) => {
      // alive first, then by name
      if (!!b.alive - !!a.alive) return !!b.alive - !!a.alive;
      return (a.name || '').localeCompare(b.name || '');
    });
    document.getElementById('wsSvcCount').textContent = `${list.length} shown · ${list.filter(s => s.alive).length} live`;
    const el = document.getElementById('wsList');
    if (!list.length) { el.innerHTML = '<div style="color:#525252;font-size:11px;padding:8px;">No matches</div>'; return; }
    el.innerHTML = list.map(s => {
      const dot = s.alive ? 'alive' : (s.alive === false ? 'dead' : 'unknown');
      const cls = ['ws-svc-row']; if (!s.alive) cls.push('dead'); if (WS.selected === s.name) cls.push('sel');
      const conns = (s.conns != null) ? ' · ' + s.conns + 'c' : '';
      return `<div class="${cls.join(' ')}" data-name="${wsEsc(s.name)}" onclick="wsSelect('${wsEsc(s.name)}')">
        <span class="svc-dot ${dot}"></span>
        <span class="name">${wsEsc(s.name)}</span>
        <span class="meta">${wsEsc(s.category || '')}${s.port ? ' :' + s.port : ''}${conns}</span>
      </div>`;
    }).join('');
  }

  async function wsSelect(name) {
    WS.selected = name;
    wsRender();
    const svc = wsAllServices().find(s => s.name === name);
    if (!svc) return;
    document.getElementById('wsDetailTitle').innerHTML = wsEsc(svc.name) + (svc.tmux ? ' · <span style="color:#737373;font-weight:400;">' + wsEsc(svc.tmux) + '</span>' : '');
    const strip = document.getElementById('wsDetailStrip');
    strip.innerHTML = [
      `<span class="pill ${svc.alive ? 'alive' : 'dead'}">${svc.alive ? '● live' : '○ down'}</span>`,
      `<span class="pill">${wsEsc(svc.category || '—')}</span>`,
      svc.port ? `<span class="pill">port :${svc.port}</span>` : '',
      svc.domain ? `<span class="pill"><a href="https://${wsEsc(svc.domain)}" target="_blank" style="color:inherit;text-decoration:none;">${wsEsc(svc.domain)} ↗</a></span>` : '',
      svc.dir ? `<span class="pill" title="${wsEsc(svc.dir)}">${wsEsc(svc.dir)}</span>` : '',
      svc.unregistered ? `<span class="pill" style="color:#fff;border-color:#444;">unregistered</span>` : '',
    ].filter(Boolean).join('');
    await wsRefreshTail();
    if (WS.autoTailTimer) clearInterval(WS.autoTailTimer);
    if (document.getElementById('wsAutoTail').checked) {
      WS.autoTailTimer = setInterval(wsRefreshTail, 5000);
    }
  }

  async function wsRefreshTail() {
    const svc = WS.selected && wsAllServices().find(s => s.name === WS.selected);
    if (!svc) return;
    const lines = parseInt(document.getElementById('wsLines').value, 10) || 50;
    const pre = document.getElementById('wsTail');
    if (!svc.tmux) { pre.textContent = '(no tmux session for this service)'; return; }
    try {
      const r = await fetch('/superadmin/api/ops/tail?session=' + encodeURIComponent(svc.tmux) + '&lines=' + lines, { cache: 'no-store' });
      const d = await r.json();
      if (!d.ok) { pre.textContent = 'Error: ' + (d.error || 'tail unavailable'); return; }
      const errRe = /\b[45]\d{2}\b|Error|ECONN[A-Z]+|ENOTFOUND|EACCES|Unhandled|TypeError|RangeError|ReferenceError/i;
      const warnRe = /\bWARN|\bWarning\b|deprecated/i;
      pre.innerHTML = wsEsc(d.tail || '(no output)').split('\n').map(line => {
        if (errRe.test(line)) return '<span class="err">' + line + '</span>';
        if (warnRe.test(line)) return '<span class="warn">' + line + '</span>';
        return line;
      }).join('\n');
      pre.scrollTop = pre.scrollHeight;
      document.getElementById('wsDetailIdle').textContent = `${d.errorCount} err · ${lines} lines`;
    } catch (e) { pre.textContent = 'Error: ' + e.message; }
  }

  async function wsServiceStatus() {
    if (!WS.selected) return;
    const out = document.getElementById('wsToolsOut');
    out.textContent = 'Checking ' + WS.selected + '…';
    try {
      const r = await fetch('/superadmin/api/service/' + encodeURIComponent(WS.selected) + '/status');
      const d = await r.json();
      out.textContent = d.output || JSON.stringify(d, null, 2);
    } catch (e) { out.textContent = 'Error: ' + e.message; }
  }

  async function wsDeprecateSelected() {
    if (!WS.selected) return;
    const name = WS.selected;
    if (!confirm('Send "' + name + '" to the deprecation pipeline?\\n\\nMoves /srv/' + name + ' → /srv/depricated/new/' + name + '\\n(kills its tmux session and removes from auto-start)')) return;

    const tail = document.getElementById('wsTail');
    const tools = document.getElementById('wsToolsOut');
    const actions = document.getElementById('wsDetailActions');
    actions.querySelectorAll('button, select, input').forEach(b => b.disabled = true);

    const banner = `▶ Deprecating "${wsEsc(name)}"…\n  POST /superadmin/api/deprecation/ingest-service\n  body: { name: "${wsEsc(name)}" }\n`;
    tail.textContent = banner;
    tools.textContent = banner;
    try {
      const r = await fetch('/superadmin/api/deprecation/ingest-service', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ name }),
      });
      const d = await r.json();
      const body = JSON.stringify({ ok: d.ok, name: d.name, staged: d.staged, error: d.error }, null, 2);
      const output = (d.output || '').trim();
      tail.textContent = banner
        + (d.ok ? `\n✓ DEPRECATED → ${d.staged}\n` : `\n✗ FAILED — ${d.error || 'unknown'}\n`)
        + '\n── script output ──\n' + (output || '(no output)') + '\n\n── response ──\n' + body;
      tools.textContent = body;
      if (d.ok) {
        wsLoadPipeline();
        // Mark service as deprecated locally so the list updates without a reload
        WS.pulseMap[name] = { ...(WS.pulseMap[name] || {}), name, alive: false, unregistered: false };
        const idx = WS.services.findIndex(s => s.name === name);
        if (idx >= 0) WS.services[idx] = { ...WS.services[idx], alive: false, dir: null, deprecated: true };
        WS.selected = null;
        wsRender();
        document.getElementById('wsDetailTitle').textContent = '✓ Deprecated — pick another';
        document.getElementById('wsDetailStrip').innerHTML = '';
      }
    } catch (e) {
      tail.textContent = banner + '\nERROR: ' + e.message;
      tools.textContent = 'Error: ' + e.message;
    } finally {
      actions.querySelectorAll('button, select, input').forEach(b => b.disabled = false);
    }
  }

  async function wsRunTool(tool) {
    const out = document.getElementById('wsToolsOut');
    out.textContent = 'Running ' + tool + '…';
    try {
      const r = await fetch('/superadmin/api/tool/' + tool);
      const d = await r.json();
      out.textContent = d.output || JSON.stringify(d, null, 2);
    } catch (e) { out.textContent = 'Error: ' + e.message; }
  }

  async function wsLoadPipeline() {
    try {
      const r = await fetch('/superadmin/api/deprecation/pipeline');
      const d = await r.json();
      if (!d.ok) return;
      document.getElementById('wsPipeNew').textContent = d.pipeline['new']?.length || 0;
      document.getElementById('wsPipeCleansed').textContent = d.pipeline['cleansed']?.length || 0;
      document.getElementById('wsPipeDeconstructed').textContent = d.pipeline['deconstructed']?.length || 0;
      document.getElementById('wsPipeDeletion').textContent = d.pipeline['deletion-stage']?.length || 0;
      const stages = ['new', 'cleansed', 'deconstructed', 'deletion-stage'];
      const stageColor = { 'new':'#c9a848', 'cleansed':'#38bdf8', 'deconstructed':'#a78bfa', 'deletion-stage':'#f87171' };
      const rows = [];
      stages.forEach(st => (d.pipeline[st] || []).forEach(p => rows.push({ stage: st, name: p.name || p })));
      document.getElementById('wsPipeList').innerHTML = rows.length
        ? rows.map(r => `<div style="display:flex;justify-content:space-between;padding:3px 0;border-top:1px solid #1a1a1a;"><span style="color:#e5e5e5;">${wsEsc(r.name)}</span><span style="font-size:9px;color:${stageColor[r.stage]};letter-spacing:1px;text-transform:uppercase;">${r.stage}</span></div>`).join('')
        : '<div style="color:#525252;padding:4px 0;">pipeline empty</div>';
    } catch (e) {}
  }

  function wsInit() {
    document.getElementById('wsSearch').addEventListener('input', (e) => { WS.search = e.target.value; wsRender(); });
    document.getElementById('wsFilters').addEventListener('click', (e) => {
      const f = e.target?.dataset?.filter; if (!f) return;
      WS.filter = f;
      document.querySelectorAll('#wsFilters .chip').forEach(c => c.classList.toggle('on', c.dataset.filter === f));
      wsRender();
    });
    document.getElementById('wsAutoTail').addEventListener('change', (e) => {
      if (WS.autoTailTimer) { clearInterval(WS.autoTailTimer); WS.autoTailTimer = null; }
      if (e.target.checked && WS.selected) WS.autoTailTimer = setInterval(wsRefreshTail, 5000);
    });
    document.getElementById('wsLines').addEventListener('change', () => { if (WS.selected) wsRefreshTail(); });
    wsRender();
    wsLoadPipeline();
    if (WS.pollPipe) clearInterval(WS.pollPipe);
    WS.pollPipe = setInterval(wsLoadPipeline, 8000);
  }
  // Init when entering Workspace tab (and once on first load if hash points there)
  let _wsInited = false;
  function wsMaybeInit() { if (_wsInited) return; _wsInited = true; wsInit(); }
</script>

<!-- ═══════ SERVER HARMONY — Three.js constellation + live pulse poller ═══════ -->
<script type="module">
import * as THREE from 'three';

const CATEGORY_COLOR = {
  platform: 0x34d399, client: 0x60a5fa, game: 0xc084fc, media: 0xf59e0b, tool: 0xc9a848, deprecated: 0x737373,
  unregistered: 0xffffff,
};
const DOWN_COLOR = 0xf87171;

// Parse the EJS-injected services list
const servicesData = JSON.parse(document.getElementById('harmonyServicesJson').textContent || '[]');

// ── Three.js scene ──────────────────────────────────────────────────────────
const wrap = document.getElementById('harmonyCanvasWrap');
const scene = new THREE.Scene();
scene.fog = new THREE.FogExp2(0x0a0a0a, 0.018);
const camera = new THREE.PerspectiveCamera(60, wrap.clientWidth / wrap.clientHeight, 0.1, 200);
camera.position.set(0, 8, 28);
camera.lookAt(0, 0, 0);

const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setSize(wrap.clientWidth, wrap.clientHeight);
renderer.setClearColor(0x0a0a0a, 1);
wrap.appendChild(renderer.domElement);

// Subtle starfield
{
  const geom = new THREE.BufferGeometry();
  const N = 400;
  const pos = new Float32Array(N * 3);
  for (let i = 0; i < N; i++) { pos[i*3] = (Math.random()-0.5)*80; pos[i*3+1] = (Math.random()-0.5)*40; pos[i*3+2] = (Math.random()-0.5)*80; }
  geom.setAttribute('position', new THREE.BufferAttribute(pos, 3));
  const mat = new THREE.PointsMaterial({ size: 0.08, color: 0x404040, transparent: true, opacity: 0.6 });
  scene.add(new THREE.Points(geom, mat));
}

// Lights — soft ambient + a center point light that brightens the constellation
scene.add(new THREE.AmbientLight(0x808080, 0.6));
const centerLight = new THREE.PointLight(0xc9a848, 1.2, 60);
centerLight.position.set(0, 2, 0);
scene.add(centerLight);

// Cluster categories on a ring; place nodes in a sub-cluster around each cluster-center.
// clusterCenters grows as new categories arrive (e.g., 'unregistered' from a new tmux).
const clusterCenters = {};
const categoryCounts = {}; // for spread within cluster

// Predefined ring slots for known categories — keeps positions stable as new
// categories arrive (e.g., 'unregistered'). Unknown categories get a free slot.
const FIXED_CATEGORY_ORDER = ['platform', 'client', 'game', 'media', 'tool', 'deprecated', 'unregistered'];
function ensureClusterCenter(cat) {
  if (clusterCenters[cat]) return clusterCenters[cat];
  const total = FIXED_CATEGORY_ORDER.length;
  let i = FIXED_CATEGORY_ORDER.indexOf(cat);
  if (i < 0) i = (Object.keys(clusterCenters).length + 0.5) % total; // fallback
  const ang = (i / total) * Math.PI * 2;
  clusterCenters[cat] = { x: Math.cos(ang) * 11, y: 0, z: Math.sin(ang) * 11, ang };
  return clusterCenters[cat];
}

// Per-service node group
const nodeMap = new Map(); // name -> { group, sphere, halo, baseColor, alive, category, line }
// Raycast targets — declared up here so addServiceNode (called during init) can populate them
const sphereTargets = [];
const sphereToName = new Map();

const sphereGeom = new THREE.SphereGeometry(0.45, 24, 24);
const ringGeom = new THREE.RingGeometry(0.5, 0.55, 48);
ringGeom.rotateX(-Math.PI / 2);

function addServiceNode(svc, animateIn = false) {
  if (nodeMap.has(svc.name)) return nodeMap.get(svc.name);
  const cat = svc.category || 'tool';
  const c = ensureClusterCenter(cat);
  categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;
  const idx = categoryCounts[cat];

  // Sub-position around the cluster center
  const sub = idx % 7;
  const r = 1.6 + (sub * 0.35);
  const phi = idx * 2.4;
  const px = c.x + Math.cos(phi) * r;
  const pz = c.z + Math.sin(phi) * r;
  const py = ((idx % 5) - 2) * 0.5;

  const color = svc.alive ? (CATEGORY_COLOR[cat] || 0xa3a3a3) : DOWN_COLOR;
  const mat = new THREE.MeshStandardMaterial({ color, emissive: color, emissiveIntensity: svc.alive ? 0.6 : 0.2, metalness: 0.4, roughness: 0.4 });
  const sphere = new THREE.Mesh(sphereGeom, mat);

  const group = new THREE.Group();
  group.position.set(px, py, pz);
  group.add(sphere);

  const halo = new THREE.Mesh(ringGeom, new THREE.MeshBasicMaterial({ color, transparent: true, opacity: 0.25, side: THREE.DoubleSide, depthWrite: false }));
  group.add(halo);

  const lineGeom = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(0, 0, 0), new THREE.Vector3(c.x - px, -py, c.z - pz)]);
  const lineMat = new THREE.LineBasicMaterial({ color, transparent: true, opacity: 0.10 });
  const line = new THREE.Line(lineGeom, lineMat);
  group.add(line);

  scene.add(group);
  const entry = { group, sphere, halo, line, baseColor: color, alive: !!svc.alive, category: cat };
  nodeMap.set(svc.name, entry);

  // Add to raycast targets so hover works on initial + dynamically added nodes
  sphereTargets.push(sphere);
  sphereToName.set(sphere.uuid, svc.name);

  if (animateIn) {
    // Pulse a ring at the new node so the user sees "something joined"
    spawnPulse(svc.name, 'session');
  }
  return entry;
}

// Initial population from EJS-injected list
servicesData.forEach(svc => addServiceNode(svc, false));

// Pulse rings — pooled
const pulseRings = [];
function spawnPulse(serviceName, kind) {
  const node = nodeMap.get(serviceName);
  if (!node) return;
  let color = node.baseColor;
  let life = 900;
  let scaleMax = 5;
  if (kind === 'output') { color = 0xa78bfa; life = 1400; }
  else if (kind === 'error') { color = 0xf87171; life = 1800; scaleMax = 7; }
  const ring = new THREE.Mesh(new THREE.RingGeometry(0.5, 0.6, 48), new THREE.MeshBasicMaterial({ color, transparent: true, opacity: 0.95, side: THREE.DoubleSide, depthWrite: false }));
  ring.rotation.x = -Math.PI / 2;
  ring.position.copy(node.group.position);
  scene.add(ring);
  pulseRings.push({ mesh: ring, born: performance.now(), life, scaleMax });
  node.sphere.material.emissiveIntensity = kind === 'error' ? 2.4 : 1.6;
  // For errors, briefly tint the node itself red
  if (kind === 'error') {
    node.sphere.material.color.setHex(0xf87171);
    setTimeout(() => { if (node.alive) node.sphere.material.color.setHex(node.baseColor); }, 1200);
  }
}

// Resize — pass updateStyle=true so canvas.style.width/height get pixel values
const ro = new ResizeObserver(() => {
  const w = wrap.clientWidth, h = wrap.clientHeight;
  if (w === 0 || h === 0) return;
  camera.aspect = w / h; camera.updateProjectionMatrix();
  renderer.setSize(w, h, true);
});
ro.observe(wrap);

// Animate — `frozen` halts camera orbit while tooltip is open
const clock = new THREE.Clock();
let frozen = false;
let camT = 0; // accumulated time for camera orbit (decoupled from elapsedTime so freeze works)
function loop() {
  const dt = clock.getDelta();
  if (!frozen) camT += dt;
  // Slow orbit camera
  const r = 28;
  camera.position.x = Math.sin(camT * 0.05) * r;
  camera.position.z = Math.cos(camT * 0.05) * r;
  camera.position.y = 8 + Math.sin(camT * 0.08) * 1.5;
  camera.lookAt(0, 0, 0);

  // Bob nodes gently + cool emissive back to baseline (frozen halts node spin)
  nodeMap.forEach((n, name) => {
    if (!frozen) {
      n.group.rotation.y += dt * 0.3;
      n.halo.rotation.z += dt * 0.4;
    }
    const m = n.sphere.material;
    const target = n.alive ? 0.6 : 0.2;
    m.emissiveIntensity += (target - m.emissiveIntensity) * Math.min(1, dt * 3);
  });

  // Pulses
  const now = performance.now();
  for (let i = pulseRings.length - 1; i >= 0; i--) {
    const p = pulseRings[i];
    const age = (now - p.born) / p.life;
    if (age >= 1) { scene.remove(p.mesh); p.mesh.geometry.dispose(); p.mesh.material.dispose(); pulseRings.splice(i, 1); continue; }
    const s = 1 + age * (p.scaleMax || 5);
    p.mesh.scale.set(s, s, s);
    p.mesh.material.opacity = (1 - age) * 0.85;
  }

  renderer.render(scene, camera);
  requestAnimationFrame(loop);
}
requestAnimationFrame(loop);

// ── Hover tooltip: raycaster → service node → fetch tmux tail ─────────────
const raycaster = new THREE.Raycaster();
const pointer = new THREE.Vector2(-9999, -9999);
const tooltip = document.getElementById('harmonyTooltip');
// sphereTargets + sphereToName are already declared above and populated by addServiceNode

let hoveredName = null;
let tailCache = {}; // { name: { html, fetchedAt } }
const TAIL_TTL_MS = 3000;

function escapeHtmlSafe(s) { return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function highlightTail(s) {
  const errRe = /\b[45]\d{2}\b|Error|ECONN[A-Z]+|ENOTFOUND|EACCES|Unhandled|TypeError|RangeError|ReferenceError/i;
  const warnRe = /\bWARN|\bWarning\b|deprecated/i;
  return escapeHtmlSafe(s).split('\n').map(line => {
    if (errRe.test(line)) return '<span class="err">' + line + '</span>';
    if (warnRe.test(line)) return '<span class="warn">' + line + '</span>';
    return line;
  }).join('\n');
}

async function fetchTail(name, session) {
  const cached = tailCache[name];
  if (cached && (Date.now() - cached.fetchedAt) < TAIL_TTL_MS) return cached;
  try {
    const r = await fetch('/superadmin/api/ops/tail?session=' + encodeURIComponent(session) + '&lines=50');
    const d = await r.json();
    const c = { tail: d.tail || '', errorCount: d.errorCount || 0, fetchedAt: Date.now() };
    tailCache[name] = c;
    return c;
  } catch { return { tail: 'tail unavailable', errorCount: 0, fetchedAt: Date.now() }; }
}

function updateTooltipHtml(svc, c, isPinned) {
  const errs = c.errorCount ? `<span style="color:#f87171;">${c.errorCount} err</span>` : '<span style="color:#737373;">no err</span>';
  const closeBtn = isPinned ? '<button class="ht-close" style="position:absolute;top:6px;right:8px;background:transparent;border:none;color:#737373;font-size:14px;cursor:pointer;pointer-events:auto;">✕</button>' : '';
  // Show Deprecate button when pinned + service appears dead (so we don't risk it on hover)
  const node = nodeMap.get(svc.name);
  const isDead = node && !node.alive;
  const deprBtn = (isPinned && isDead && !svc.unregistered) ? `
    <button class="ht-depr" style="margin-top:6px;background:transparent;border:1px solid #451a1a;color:#f87171;border-radius:4px;padding:4px 10px;font-size:11px;cursor:pointer;pointer-events:auto;">
      Send to deprecation pipeline →
    </button>` : '';
  tooltip.innerHTML = `
    <div class="ht-head">
      <span class="ht-name">${escapeHtmlSafe(svc.name)}${svc.tmux ? ' · <span style="color:#737373;font-weight:400;">tmux:' + escapeHtmlSafe(svc.tmux) + '</span>' : ''}</span>
      <span class="ht-meta">${escapeHtmlSafe(svc.category || '')} ${svc.port ? '· :' + svc.port : ''} · ${errs}${isPinned ? ' · <span style="color:#c9a848;">pinned</span>' : ''}</span>
    </div>
    <pre>${c.tail ? highlightTail(c.tail) : '(no recent output)'}</pre>${deprBtn}${closeBtn}`;
  tooltip.style.pointerEvents = isPinned ? 'auto' : 'none';
  if (isPinned) {
    tooltip.querySelector('.ht-close')?.addEventListener('click', (e) => { e.stopPropagation(); hideTooltip(); });
    tooltip.querySelector('.ht-depr')?.addEventListener('click', async (e) => {
      e.stopPropagation();
      if (!confirm('Send "' + svc.name + '" to the deprecation pipeline?\\n\\nMoves /srv/' + svc.name + ' → /srv/depricated/new/' + svc.name)) return;
      const btn = e.currentTarget;
      btn.textContent = 'Deprecating…'; btn.disabled = true;
      try {
        const r = await fetch('/superadmin/api/deprecation/ingest-service', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: svc.name }),
        });
        const d = await r.json();
        if (d.ok) { btn.textContent = '✓ moved → ' + d.staged; setTimeout(() => location.reload(), 1200); }
        else { btn.textContent = 'Failed: ' + (d.error || 'unknown'); btn.disabled = false; }
      } catch (err) { btn.textContent = 'Error: ' + err.message; btn.disabled = false; }
    });
  }
}

// `pinned` = mobile long-press selection (sticks until tap-outside / X)
let pinned = false;

function hitAt(clientX, clientY) {
  const rect = wrap.getBoundingClientRect();
  pointer.x = ((clientX - rect.left) / rect.width) * 2 - 1;
  pointer.y = -((clientY - rect.top) / rect.height) * 2 + 1;
  raycaster.setFromCamera(pointer, camera);
  const hits = raycaster.intersectObjects(sphereTargets, false);
  return { hits, rect };
}

function positionTooltip(clientX, clientY, rect) {
  let x = clientX - rect.left + 14;
  let y = clientY - rect.top + 14;
  if (x + 380 > rect.width) x = clientX - rect.left - 390;
  if (y + 240 > rect.height) y = clientY - rect.top - 250;
  tooltip.style.left = Math.max(8, x) + 'px';
  tooltip.style.top  = Math.max(8, y) + 'px';
}

function showTooltipFor(name, clientX, clientY, rect) {
  const svc = servicesData.find(s => s.name === name);
  if (!svc) return;
  tooltip.style.display = 'block';
  positionTooltip(clientX, clientY, rect);
  frozen = true;
  if (hoveredName !== name) {
    hoveredName = name;
    tooltip.innerHTML = '<div class="ht-head"><span class="ht-name">' + escapeHtmlSafe(svc.name) + '</span><span class="ht-meta">loading…</span></div><pre>…</pre>';
    if (svc.tmux) fetchTail(name, svc.tmux).then(c => { if (hoveredName === name) updateTooltipHtml(svc, c, pinned); });
    else updateTooltipHtml(svc, { tail: '(no tmux session)', errorCount: 0, fetchedAt: Date.now() }, pinned);
  } else if (tailCache[name]) {
    updateTooltipHtml(svc, tailCache[name], pinned);
  }
}

function hideTooltip() {
  tooltip.style.display = 'none';
  hoveredName = null;
  pinned = false;
  frozen = false;
}

// Patch updateTooltipHtml to include a close button when pinned
const _origUpdate = updateTooltipHtml;
updateTooltipHtml = function(svc, c, isPinned) {
  _origUpdate(svc, c);
  if (isPinned) {
    const close = document.createElement('button');
    close.textContent = '✕';
    close.style.cssText = 'position:absolute;top:6px;right:8px;background:transparent;border:none;color:#737373;font-size:14px;cursor:pointer;pointer-events:auto;';
    close.addEventListener('click', (e) => { e.stopPropagation(); hideTooltip(); });
    tooltip.style.pointerEvents = 'auto';
    tooltip.appendChild(close);
  } else {
    tooltip.style.pointerEvents = 'none';
  }
};

wrap.addEventListener('pointermove', (e) => {
  if (pinned) return; // pinned tooltip ignores hover
  const { hits, rect } = hitAt(e.clientX, e.clientY);
  if (hits.length) {
    const name = sphereToName.get(hits[0].object.uuid);
    if (name) showTooltipFor(name, e.clientX, e.clientY, rect);
  } else if (hoveredName) {
    hideTooltip();
  }
});
wrap.addEventListener('pointerleave', () => { if (!pinned) hideTooltip(); });

// ── Mobile long-press: pin the tooltip + freeze animation ─────────────────
let pressTimer = null;
let pressStart = null;
const LONG_PRESS_MS = 450;

wrap.addEventListener('pointerdown', (e) => {
  if (e.pointerType !== 'touch') return; // only long-press for touch
  pressStart = { x: e.clientX, y: e.clientY };
  pressTimer = setTimeout(() => {
    const { hits, rect } = hitAt(e.clientX, e.clientY);
    if (hits.length) {
      const name = sphereToName.get(hits[0].object.uuid);
      if (name) {
        pinned = true;
        showTooltipFor(name, e.clientX, e.clientY, rect);
        try { navigator.vibrate && navigator.vibrate(30); } catch {}
      }
    }
    pressTimer = null;
  }, LONG_PRESS_MS);
});
function cancelPress() { if (pressTimer) { clearTimeout(pressTimer); pressTimer = null; } pressStart = null; }
wrap.addEventListener('pointermove', (e) => {
  if (!pressStart) return;
  if (Math.hypot(e.clientX - pressStart.x, e.clientY - pressStart.y) > 10) cancelPress();
});
wrap.addEventListener('pointerup', cancelPress);
wrap.addEventListener('pointercancel', cancelPress);

// Tap outside the tooltip → unpin
document.addEventListener('pointerdown', (e) => {
  if (!pinned) return;
  if (tooltip.contains(e.target)) return;
  if (wrap.contains(e.target)) {
    const { hits } = hitAt(e.clientX, e.clientY);
    if (hits.length) return; // tapping another node will re-fire hover-style flow
  }
  hideTooltip();
});

// Desktop: clicking a node also pins it (so you can move mouse away while reading)
wrap.addEventListener('click', (e) => {
  if (e.detail === 0) return; // ignore keyboard "clicks"
  const { hits, rect } = hitAt(e.clientX, e.clientY);
  if (!hits.length) return;
  const name = sphereToName.get(hits[0].object.uuid);
  if (name) {
    pinned = true;
    showTooltipFor(name, e.clientX, e.clientY, rect);
  }
});

// ── Force-resize hook (called on fullscreen toggle / tab switch / window resize) ──
function forceResize() {
  const w = wrap.clientWidth, h = wrap.clientHeight;
  if (w > 0 && h > 0) {
    camera.aspect = w / h; camera.updateProjectionMatrix();
    renderer.setSize(w, h, false);
  }
}
window.addEventListener('resize', forceResize);
// Initial size retry — if layout wasn't ready at module run, ResizeObserver will catch up,
// but also schedule a few rAF ticks to be safe.
let initRetries = 0;
function initialSizeKick() {
  forceResize();
  if ((wrap.clientWidth === 0 || wrap.clientHeight === 0) && initRetries++ < 30) requestAnimationFrame(initialSizeKick);
}
requestAnimationFrame(initialSizeKick);

// Expose hooks
window.serverHarmony = {
  triggerPulse(name, kind) { spawnPulse(name, kind); },
  resize() { forceResize(); },
  hasNode(name) { return nodeMap.has(name); },
  addService(svc) { return addServiceNode(svc, true); },
  setAlive(name, alive) {
    const n = nodeMap.get(name); if (!n) return;
    n.alive = alive;
    const c = alive ? (CATEGORY_COLOR[n.category] || 0xa3a3a3) : DOWN_COLOR;
    n.baseColor = c;
    n.sphere.material.color.setHex(c);
    n.sphere.material.emissive.setHex(c);
    n.halo.material.color.setHex(c);
  },
};
</script>

<!-- ═══════ PULSE POLLER + System Vitals + Sparkline ═══════ -->
<script>
(function() {
  let spark = null;
  const sparkData = { labels: [], conns: [], cpu: [] };

  function ensureChart() {
    if (spark || typeof Chart === 'undefined') return spark;
    const ctx = document.getElementById('vitalsSpark')?.getContext('2d');
    if (!ctx) return null;
    window.vitalsSparkChart = spark = new Chart(ctx, {
      type: 'line',
      data: {
        labels: sparkData.labels,
        datasets: [
          { label: 'conns', data: sparkData.conns, borderColor: '#60a5fa', backgroundColor: 'rgba(96,165,250,0.10)', tension: 0.3, pointRadius: 0, borderWidth: 1.5, fill: true, yAxisID: 'y' },
          { label: 'cpu%',  data: sparkData.cpu,   borderColor: '#34d399', backgroundColor: 'rgba(52,211,153,0.05)',  tension: 0.3, pointRadius: 0, borderWidth: 1.5, fill: false, yAxisID: 'y2' },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false, animation: false,
        plugins: { legend: { display: false }, tooltip: { enabled: false } },
        scales: {
          x: { display: false },
          y:  { display: false, beginAtZero: true },
          y2: { display: false, beginAtZero: true, max: 100, position: 'right' },
        },
      },
    });
    return spark;
  }

  function fmtBytes(n) {
    if (n == null) return '—';
    const u = ['B','KB','MB','GB','TB']; let i = 0; let v = Number(n);
    while (v >= 1024 && i < u.length - 1) { v /= 1024; i++; }
    return v.toFixed(v >= 100 ? 0 : 1) + ' ' + u[i];
  }
  function fmtUptime(sec) {
    if (sec == null) return '—';
    const d = Math.floor(sec/86400), h = Math.floor((sec%86400)/3600), m = Math.floor((sec%3600)/60);
    if (d) return `${d}d ${h}h`;
    if (h) return `${h}h ${m}m`;
    return `${m}m`;
  }

  function renderVitals(sys) {
    if (!sys) return;
    const cpu = sys.cpuPct == null ? null : sys.cpuPct;
    const mem = sys.mem || {};
    const load = sys.load || {};
    const cores = load.cores || 1;
    const loadPct = Math.min(100, (load.m1 || 0) / cores * 100);
    document.getElementById('vitalsCpuBar').style.width = (cpu == null ? 0 : cpu).toFixed(1) + '%';
    document.getElementById('vitalsCpuVal').textContent = cpu == null ? '—' : cpu.toFixed(1) + '%';
    document.getElementById('vitalsMemBar').style.width = (mem.usedPct || 0).toFixed(1) + '%';
    document.getElementById('vitalsMemVal').textContent = mem.total ? `${fmtBytes(mem.used)} / ${fmtBytes(mem.total)}` : '—';
    document.getElementById('vitalsLoadBar').style.width = loadPct.toFixed(1) + '%';
    document.getElementById('vitalsLoadVal').textContent = (load.m1 != null) ? `${load.m1.toFixed(2)} / ${cores}c` : '—';
    document.getElementById('vitalsUptime').textContent = 'up ' + fmtUptime(sys.uptimeSec);
    document.getElementById('vitalsProcCount').textContent = sys.procs?.total ?? '—';
    const top = sys.procs?.top || [];
    const tbl = document.getElementById('vitalsProcs');
    const head = '<div class="prow"><span>Process</span><span style="text-align:right;">CPU%</span><span style="text-align:right;">MEM%</span></div>';
    const body = top.slice(0, 6).map(p => `<div class="prow"><span style="color:#e5e5e5;text-overflow:ellipsis;overflow:hidden;white-space:nowrap;">${p.name}</span><span style="text-align:right;color:#a3a3a3;">${p.cpu.toFixed(1)}</span><span style="text-align:right;color:#a3a3a3;">${p.mem.toFixed(1)}</span></div>`).join('');
    tbl.innerHTML = head + body;
  }

  function updateSpark(history) {
    ensureChart();
    if (!spark || !history) return;
    sparkData.labels.length = 0; sparkData.conns.length = 0; sparkData.cpu.length = 0;
    history.forEach(p => { sparkData.labels.push(''); sparkData.conns.push(p.conns || 0); sparkData.cpu.push(p.cpu == null ? null : p.cpu); });
    spark.update('none');
  }

  // ── Outbounds poller (lighter cadence: every 4 seconds) ─────────────────
  async function pollOutbounds() {
    try {
      const r = await fetch('/superadmin/api/ops/outbounds');
      const d = await r.json();
      if (!d.ok) return;
      const list = d.hosts || [];
      document.getElementById('outboundsMeta').textContent = `${d.total} sockets · ${list.length} peers`;
      const el = document.getElementById('outboundsList');
      if (!list.length) { el.textContent = 'No outbound connections.'; return; }
      el.innerHTML = list.slice(0, 14).map(h => {
        const label = h.label || h.peerAddr;
        const ports = h.ports.slice(0, 4).join(', ') + (h.ports.length > 4 ? '…' : '');
        return `<div style="padding:5px 0;border-top:1px solid #1a1a1a;display:flex;justify-content:space-between;gap:8px;align-items:center;">
          <div style="min-width:0;overflow:hidden;">
            <div style="color:#e5e5e5;text-overflow:ellipsis;overflow:hidden;white-space:nowrap;">${escapeHtmlSafePage(label)}</div>
            <div style="color:#525252;font-size:10px;">ports: ${ports}</div>
          </div>
          <div style="font-size:13px;color:#c9a848;font-weight:700;font-variant-numeric:tabular-nums;">${h.count}</div>
        </div>`;
      }).join('');
    } catch (e) {}
  }
  function escapeHtmlSafePage(s) { return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
  pollOutbounds();
  setInterval(pollOutbounds, 4000);

  let prevAlive = {};
  async function pollPulse() {
    try {
      const r = await fetch('/superadmin/api/ops/pulse', { cache: 'no-store' });
      if (!r.ok) return;
      const d = await r.json();
      // Update top stats
      const aliveCount = d.services.filter(s => s.alive).length;
      document.getElementById('harmonyStatusServices').textContent = aliveCount + ' up';
      document.getElementById('harmonyStatusConns').textContent = d.totalConns + ' conns';
      const pulsing = d.services.filter(s => s.pulse).length;
      document.getElementById('harmonyStatusPulse').textContent = pulsing + ' active';

      // Feed Workspace's live service map (alive/conns/unregistered/etc.)
      if (typeof WS !== 'undefined') {
        WS.pulseMap = {};
        d.services.forEach(s => { WS.pulseMap[s.name] = s; });
        if (document.body.classList.contains('workspace-active')) wsRender();
      }
      // Drive Three.js
      d.services.forEach(s => {
        // Discover new tmux sessions / services that weren't in the initial render
        if (window.serverHarmony && !window.serverHarmony.hasNode(s.name)) {
          window.serverHarmony.addService(s);
        }
        if (prevAlive[s.name] !== s.alive && window.serverHarmony) window.serverHarmony.setAlive(s.name, s.alive);
        prevAlive[s.name] = s.alive;
        if (s.pulse && window.serverHarmony) window.serverHarmony.triggerPulse(s.name, s.pulseKind);
      });

      document.getElementById('vitalsActiveSvc').textContent = aliveCount;
      renderVitals(d.sys);
      updateSpark(d.history);
    } catch (e) { /* network blip, try again next tick */ }
  }
  pollPulse();
  setInterval(pollPulse, 2000);
})();
</script>
<span class="badge-overseer">SUPERADMIN</span>
</body>
</html>
