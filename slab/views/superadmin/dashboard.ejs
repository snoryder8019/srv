<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Superadmin — MadLabs Platform</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
  <script type="importmap">{ "imports": { "three": "https://unpkg.com/three@0.160.0/build/three.module.js" } }</script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#0a0a0a; color:#e5e5e5; min-height:100vh; }

    /* ── TOPBAR ── */
    .topbar { background:#141414; border-bottom:1px solid #262626; padding:12px 24px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:100; }
    .topbar-left { display:flex; align-items:center; gap:16px; }
    .logo { font-size:18px; font-weight:500; color:#fff; font-family:'Space Grotesk',sans-serif; letter-spacing:0.05em; } .logo span { color:#c9a848; }
    .badge-overseer { background:linear-gradient(135deg, #c9a848 0%, #b8860b 100%); color:#0a0a0a; font-weight:700; position:fixed; bottom:16px; right:16px; z-index:9999; padding:6px 12px; font-size:11px; box-shadow:0 2px 8px rgba(0,0,0,0.4); border-radius:4px; letter-spacing:1px; text-transform:uppercase; }
    .topbar-right { display:flex; align-items:center; gap:14px; font-size:13px; color:#737373; }
    .topbar-right a { color:#a3a3a3; text-decoration:none; font-size:12px; } .topbar-right a:hover { color:#c9a848; }
    .health-dot { width:7px; height:7px; border-radius:50%; display:inline-block; }
    .health-dot.up { background:#34d399; box-shadow:0 0 4px #34d399; } .health-dot.down { background:#f87171; box-shadow:0 0 4px #f87171; }

    /* ── PRODUCT TABS ── */
    .tab-bar { background:#111; border-bottom:1px solid #262626; padding:0 24px; display:flex; gap:0; overflow-x:auto; }
    .tab { padding:12px 20px; font-size:13px; font-weight:500; color:#737373; cursor:pointer; border-bottom:2px solid transparent; transition:all .15s; white-space:nowrap; display:flex; align-items:center; gap:6px; }
    .tab:hover { color:#e5e5e5; background:#1a1a1a; }
    .tab.active { color:#c9a848; border-bottom-color:#c9a848; }
    .tab-icon { font-size:14px; }
    .tab-spacer { flex:1; }
    .tab.tab-util { color:#525252; font-size:12px; }
    .tab.tab-util.active { color:#c9a848; }

    /* ── LAYOUT ── */
    .content { padding:24px 32px; max-width:100%; margin:0 auto; }
    .panel { display:none; } .panel.active { display:block; }

    /* ── STATS ROW ── */
    .stats { display:grid; grid-template-columns:repeat(auto-fit, minmax(140px, 1fr)); gap:12px; margin-bottom:24px; }
    .stat { background:#141414; border:1px solid #262626; border-radius:8px; padding:16px; }
    .stat-label { font-size:10px; text-transform:uppercase; letter-spacing:1px; color:#737373; margin-bottom:4px; }
    .stat-value { font-size:26px; font-weight:700; color:#fff; }
    .stat-value.gold { color:#c9a848; } .stat-value.green { color:#34d399; } .stat-value.red { color:#f87171; } .stat-value.blue { color:#38bdf8; } .stat-value.purple { color:#a78bfa; }

    /* ── CARDS ── */
    .card-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(300px, 1fr)); gap:14px; margin-bottom:24px; }
    .card { background:#141414; border:1px solid #262626; border-radius:8px; padding:18px; transition:border-color .2s; }
    .card:hover { border-color:#333; }
    .card-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; }
    .card-title { font-size:14px; font-weight:600; color:#fff; display:flex; align-items:center; gap:8px; }
    .card-desc { font-size:12px; color:#737373; margin-bottom:10px; line-height:1.4; }
    .card-meta { display:flex; gap:10px; font-size:11px; color:#525252; flex-wrap:wrap; }
    .card-meta span { display:flex; align-items:center; gap:4px; }
    .card-actions { display:flex; gap:6px; margin-top:10px; flex-wrap:wrap; }
    .svc-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
    .svc-dot.alive { background:#34d399; box-shadow:0 0 6px #34d399; }
    .svc-dot.dead { background:#f87171; box-shadow:0 0 6px #f87171; }
    .svc-dot.unknown { background:#525252; }

    /* ── QUICK LINKS ── */
    .quick-links { display:flex; gap:8px; margin-bottom:20px; flex-wrap:wrap; }
    .qlink { padding:6px 14px; font-size:12px; border-radius:6px; border:1px solid #262626; background:#141414; color:#a3a3a3; text-decoration:none; display:inline-flex; align-items:center; gap:6px; transition:all .15s; }
    .qlink:hover { border-color:#c9a848; color:#c9a848; }

    /* ── SECTION ── */
    .section { margin-bottom:24px; }
    h2 { font-size:15px; font-weight:600; margin-bottom:14px; color:#e5e5e5; display:flex; align-items:center; gap:8px; }
    h3 { font-size:13px; font-weight:500; color:#737373; margin-bottom:10px; }
    .section-label { font-size:10px; text-transform:uppercase; letter-spacing:1.2px; color:#525252; margin-bottom:10px; }

    /* ── TABLES ── */
    table { width:100%; border-collapse:collapse; background:#141414; border-radius:8px; overflow:hidden; border:1px solid #262626; }
    th { text-align:left; padding:10px 14px; font-size:10px; text-transform:uppercase; letter-spacing:0.8px; color:#737373; background:#1a1a1a; border-bottom:1px solid #262626; }
    td { padding:10px 14px; font-size:13px; border-bottom:1px solid #1f1f1f; }
    tr:last-child td { border-bottom:0; }
    tr:hover td { background:#1a1a1a; }

    /* ── BUTTONS / BADGES ── */
    .btn { padding:7px 14px; font-size:12px; border-radius:6px; border:1px solid #333; background:transparent; color:#a3a3a3; cursor:pointer; font-family:'Inter',sans-serif; text-decoration:none; display:inline-flex; align-items:center; gap:6px; transition:all .15s; }
    .btn:hover { border-color:#c9a848; color:#c9a848; }
    .btn-gold { background:#c9a848; color:#0a0a0a; border-color:#c9a848; font-weight:600; } .btn-gold:hover { background:#b8960b; }
    .btn-sm { padding:4px 10px; font-size:11px; border-radius:4px; border:1px solid #333; background:transparent; color:#a3a3a3; cursor:pointer; text-decoration:none; display:inline-block; }
    .btn-sm:hover { border-color:#c9a848; color:#c9a848; }
    .link { color:#c9a848; text-decoration:none; } .link:hover { text-decoration:underline; }
    .status { display:inline-block; padding:2px 8px; border-radius:10px; font-size:11px; font-weight:500; }
    .status-active { background:#14532d; color:#86efac; }
    .status-preview { background:#422006; color:#fdba74; }
    .status-suspended { background:#451a1a; color:#fca5a5; }
    .tag { display:inline-block; padding:2px 7px; border-radius:10px; font-size:10px; font-weight:500; margin-right:3px; }
    .empty { color:#525252; font-size:13px; padding:24px; text-align:center; }

    /* ── LOG ROWS ── */
    .log-table { background:#141414; border:1px solid #262626; border-radius:8px; overflow:hidden; max-height:500px; overflow-y:auto; }
    .log-row { display:flex; align-items:flex-start; gap:12px; padding:10px 14px; border-bottom:1px solid #1f1f1f; font-size:13px; }
    .log-row:last-child { border-bottom:0; }
    .log-icon { width:28px; height:28px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:13px; flex-shrink:0; background:#262626; }
    .log-body { flex:1; min-width:0; }
    .log-action { color:#e5e5e5; font-weight:500; }
    .log-tenant { color:#c9a848; font-size:12px; }
    .log-detail { color:#737373; font-size:12px; margin-top:2px; }
    .log-time { color:#525252; font-size:11px; white-space:nowrap; flex-shrink:0; }

    /* ── SERVICE SELECT (kept for compat) ── */
    .service-select { background:#1a1a1a; border:1px solid #333; color:#e5e5e5; padding:6px 12px; border-radius:6px; font-family:'Inter',sans-serif; font-size:12px; cursor:pointer; }
    .service-select:focus { border-color:#c9a848; outline:none; }

    /* ── TOOL OUTPUT ── */
    .tool-output { background:#141414; border:1px solid #262626; border-radius:8px; padding:16px; font-size:12px; color:#a3a3a3; min-height:100px; max-height:400px; overflow-y:auto; white-space:pre-wrap; font-family:monospace; }

    /* ── SERVICE GRID (reused in tool/agent cards) ── */
    .service-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:14px; }

    /* ── TABLE SCROLL WRAPPER ── */
    .table-wrap { overflow-x:auto; -webkit-overflow-scrolling:touch; border-radius:8px; }
    .table-wrap table { min-width:600px; }

    /* ── RESPONSIVE ── */
    @media (max-width:768px) {
      .topbar { padding:10px 14px; flex-wrap:wrap; gap:8px; }
      .topbar-left { gap:10px; }
      .topbar-right { gap:8px; font-size:11px; flex-wrap:wrap; }
      .topbar-right a { font-size:11px; }
      .logo { font-size:17px; }

      .tab-bar { padding:0 8px; gap:0; }
      .tab { padding:10px 12px; font-size:12px; }
      .tab-icon { font-size:12px; }
      .tab-spacer { display:none; }

      .content { padding:14px; }
      .stats { grid-template-columns:repeat(2, 1fr); gap:8px; }
      .stat { padding:12px; }
      .stat-value { font-size:20px; }
      .stat-label { font-size:9px; }

      .card-grid { grid-template-columns:1fr; gap:10px; }
      .service-grid { grid-template-columns:1fr; gap:10px; }
      .quick-links { gap:6px; }
      .qlink { padding:5px 10px; font-size:11px; }

      h2 { font-size:14px; }
      table { font-size:12px; }
      th, td { padding:8px 10px; }

      .log-row { padding:8px 10px; gap:8px; font-size:12px; }
      .log-icon { width:24px; height:24px; font-size:11px; }

      .card { padding:14px; }
      .card-title { font-size:13px; }
      .card-desc { font-size:11px; }
      .card-meta { font-size:10px; }

      .tool-output { font-size:11px; padding:12px; max-height:300px; }
      .badge-overseer { padding:4px 8px; font-size:9px; bottom:10px; right:10px; }
    }

    @media (max-width:480px) {
      .topbar-right span:not(:last-child) { display:none; }
      .stats { grid-template-columns:repeat(2, 1fr); }
      .tab { padding:8px 10px; font-size:11px; }
    }

    /* ── ULTRAWIDE (1800px+) ── */
    @media (min-width:1800px) {
      .content { padding:28px 48px; }
      .stats { grid-template-columns:repeat(auto-fit, minmax(160px, 1fr)); gap:16px; }
      .card-grid { grid-template-columns:repeat(auto-fill, minmax(340px, 1fr)); gap:18px; }
      .service-grid { grid-template-columns:repeat(auto-fill, minmax(320px, 1fr)); gap:18px; }
      .stat-value { font-size:30px; }
      .topbar { padding:14px 48px; }
      .tab-bar { padding:0 48px; }
      .quick-links { gap:10px; }
      .qlink { padding:8px 18px; font-size:13px; }
      .log-table { max-height:600px; }
      .tool-output { max-height:500px; }
      .table-wrap table { min-width:auto; }
    }

    /* ── SUPER ULTRAWIDE (2600px+ / 34" 4K curved) ── */
    @media (min-width:2600px) {
      .content { padding:36px 64px; }
      .stats { grid-template-columns:repeat(auto-fit, minmax(180px, 1fr)); gap:20px; }
      .stat { padding:20px 24px; border-radius:10px; }
      .stat-value { font-size:34px; }
      .stat-label { font-size:11px; letter-spacing:1.5px; }
      .card-grid { grid-template-columns:repeat(auto-fill, minmax(380px, 1fr)); gap:22px; }
      .service-grid { grid-template-columns:repeat(auto-fill, minmax(360px, 1fr)); gap:22px; }
      .card { padding:22px; border-radius:10px; }
      .card-title { font-size:15px; }
      .card-desc { font-size:13px; line-height:1.55; }
      .topbar { padding:16px 64px; }
      .topbar-right { gap:20px; font-size:14px; }
      .topbar-right a { font-size:13px; }
      .logo { font-size:22px; }
      .tab-bar { padding:0 64px; }
      .tab { padding:14px 28px; font-size:14px; }
      .tab-icon { font-size:16px; }
      .quick-links { gap:12px; }
      .qlink { padding:10px 22px; font-size:14px; border-radius:8px; }
      h2 { font-size:17px; }
      h3 { font-size:14px; }
      .section-label { font-size:11px; letter-spacing:1.5px; }
      th { padding:12px 18px; font-size:11px; }
      td { padding:12px 18px; font-size:14px; }
      .log-row { padding:14px 20px; font-size:14px; }
      .log-icon { width:32px; height:32px; font-size:15px; }
      .log-table { max-height:700px; }
      .tool-output { max-height:600px; font-size:13px; }
      .btn { padding:9px 18px; font-size:13px; }
      .btn-sm { padding:6px 14px; font-size:12px; }
      .gftv-form { padding:24px; }
      .gftv-form-grid { gap:14px; }
      .badge-overseer { padding:8px 16px; font-size:12px; bottom:20px; right:20px; border-radius:6px; }
    }

    /* ── DUAL COLUMN PANELS for ultrawide overview ── */
    @media (min-width:2200px) {
      .uw-columns { display:grid; grid-template-columns:1fr 1fr; gap:28px; align-items:start; }
      .uw-columns > .section { margin-bottom:0; }
      .uw-3col { display:grid; grid-template-columns:1fr 1fr 1fr; gap:22px; align-items:start; }
    }

    /* ── DASH GRID — TV-style tiled landing ───────────────────────────────── */
    .dash-grid { display:grid; grid-template-columns:1fr; gap:14px; align-items:start; }
    @media (min-width:1500px) { .dash-grid { grid-template-columns:1fr 1fr; gap:16px; } }
    @media (min-width:2200px) { .dash-grid { grid-template-columns:1fr 1fr 1fr; gap:18px; } }
    @media (min-width:2800px) { .dash-grid { grid-template-columns:1.2fr 1fr 1.2fr 1fr; gap:20px; } }

    .tile { background:#0f0f10; border:1px solid #1f1f22; border-radius:10px; padding:14px 16px; }
    .tile .tile-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; gap:10px; }
    .tile .tile-title { font-size:11px; letter-spacing:2px; color:#737373; text-transform:uppercase; }
    .tile .tile-meta { font-size:11px; color:#525252; }
    .tile .tile-body { font-size:12px; color:#a3a3a3; }

    /* spans for important tiles on wide screens */
    @media (min-width:2200px) { .tile.span-2 { grid-column:span 2; } }
    @media (min-width:2800px) { .tile.span-2 { grid-column:span 2; } .tile.span-3 { grid-column:span 3; } }
    .tile.span-all { grid-column:1 / -1; }

    /* Harmony tile — Three.js canvas is full-bleed inside its tile */
    .tile.harmony { padding:0; overflow:hidden; position:relative; border-color:#1a2030; }
    .tile.harmony .tile-head { position:absolute; top:0; left:0; right:0; padding:10px 14px; background:linear-gradient(to bottom, rgba(10,10,10,0.85), transparent); z-index:5; margin:0; }
    .tile.harmony canvas { display:block; }
    .tile.harmony .legend { position:absolute; bottom:8px; left:14px; right:14px; display:flex; gap:14px; flex-wrap:wrap; font-size:10px; color:#737373; letter-spacing:1px; text-transform:uppercase; z-index:5; pointer-events:none; }
    .harmony-tooltip { position:absolute; z-index:30; background:rgba(10,10,10,0.92); border:1px solid #262626; border-radius:6px; padding:8px 10px; font-size:11px; color:#e5e5e5; max-width:560px; min-width:280px; pointer-events:none; box-shadow:0 4px 18px rgba(0,0,0,0.5); }
    .harmony-tooltip .ht-head { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:6px; gap:10px; }
    .harmony-tooltip .ht-name { font-weight:600; color:#fff; }
    .harmony-tooltip .ht-meta { font-size:10px; color:#737373; letter-spacing:1px; text-transform:uppercase; }
    .harmony-tooltip pre { background:#000; border:1px solid #1a1a1a; border-radius:4px; padding:6px 8px; font-size:10px; line-height:1.4; color:#a3a3a3; max-height:260px; overflow:auto; white-space:pre-wrap; font-family:ui-monospace,Menlo,Consolas,monospace; }
    .harmony-tooltip pre .err { color:#f87171; }
    .harmony-tooltip pre .warn { color:#f59e0b; }
    .tile.harmony .legend .lg-item { display:inline-flex; align-items:center; gap:5px; }
    .tile.harmony .legend .lg-dot { width:7px; height:7px; border-radius:50%; }
    #harmonyCanvasWrap { width:100%; height:380px; position:relative; }
    @media (min-width:2200px) { #harmonyCanvasWrap { height:480px; } }
    @media (min-width:2800px) { #harmonyCanvasWrap { height:560px; } }

    /* ── SINGLE-VIEWPORT (squeeze everything onto one horizontal screen) ── */
    @media (min-width:1500px) {
      body.overview-active { height:100vh; overflow:hidden; }
      body.overview-active .content { height:calc(100vh - 100px); display:flex; flex-direction:column; gap:8px; padding:2vh 2vw !important; overflow:hidden; box-sizing:border-box; }
      body.overview-active.fs .content { height:100vh; padding:2vh 2vw !important; gap:6px; box-sizing:border-box; }

      #tab-overview.active { display:flex; flex-direction:column; flex:1; min-height:0; gap:0; position:relative; }
      /* Stats float as overlay chips on top of all tiles (visible in fullscreen too) */
      body.overview-active #tab-overview > .stats {
        position:absolute; top:6px; right:8px; z-index:50; margin:0;
        display:flex; gap:6px; grid-template-columns:none; flex-wrap:wrap;
        max-width:70%; justify-content:flex-end; pointer-events:none;
      }
      body.overview-active.fs #tab-overview > .stats { top:8px; right:10px; }
      body.overview-active #tab-overview > .stats .stat {
        background:rgba(10,10,10,0.75); backdrop-filter:blur(6px); -webkit-backdrop-filter:blur(6px);
        border:1px solid rgba(255,255,255,0.08); border-radius:6px; padding:4px 10px;
        min-width:auto; display:flex; align-items:baseline; gap:6px; box-shadow:0 2px 8px rgba(0,0,0,0.4);
      }
      body.overview-active #tab-overview > .stats .stat-label { font-size:9px; margin:0; letter-spacing:1px; }
      body.overview-active #tab-overview > .stats .stat-value { font-size:14px; line-height:1; }
      /* Quick links collapse to a tight strip; hidden in fullscreen */
      body.overview-active #tab-overview > .quick-links { margin:0 0 6px 0; flex-shrink:0; gap:4px; }
      body.overview-active #tab-overview > .quick-links .qlink { padding:3px 8px; font-size:10px; }
      body.overview-active.fs #tab-overview > .quick-links { display:none; }

      #tab-overview .dash-grid {
        flex:1; min-height:0; gap:10px;
        grid-template-columns: 1.6fr 1fr 1fr 1fr;
        grid-template-rows: 1.4fr 1fr;
        grid-template-areas:
          "harmony   harmony  vitals   ollama"
          "outbounds tenants  signups  activity";
      }
      #harmonyTile   { grid-area: harmony; }
      #vitalsTile    { grid-area: vitals; }
      #outboundsTile { grid-area: outbounds; }
      #ollamaTile    { grid-area: ollama; }
      #signupsTile   { grid-area: signups; }
      #tenantsTile   { grid-area: tenants; }
      #activityTile  { grid-area: activity; }
      /* Services tile is hidden on the landing in compact mode; moved to Tools tab */
      #tab-overview #servicesTile { display:none; }

      .dash-grid .tile { display:flex; flex-direction:column; min-height:0; overflow:hidden; padding:10px 12px; }
      /* Harmony is block (not flex) so its grid-stretched height is honored even though all children are absolute */
      .dash-grid .tile.harmony { display:block !important; padding:0; position:relative; overflow:hidden; height:100%; min-height:0; }
      .dash-grid .tile > .tile-head { flex-shrink:0; margin-bottom:8px; }
      .dash-grid .tile.harmony > .tile-head { margin-bottom:0; }
      .dash-grid .tile > .tile-body { flex:1; min-height:0; overflow:auto; display:flex; flex-direction:column; }
      /* Absolute wrap so canvas has a definite, clipped size that always matches the tile cell */
      .dash-grid .tile.harmony > #harmonyCanvasWrap { position:absolute; top:0; left:0; right:0; bottom:0; width:auto; height:auto; overflow:hidden; }
      .tile.harmony canvas { max-width:100%; max-height:100%; }

      /* tighten Ollama internals so it fits in one cell */
      #ollamaTile .stat { padding:6px 8px !important; }
      #ollamaTile .stat-value { font-size:16px !important; }
      #ollamaTile .stat-label { font-size:9px; }

      /* services list scrolls inside its cell */
      #servicesTile .svc-mini { grid-template-columns:repeat(auto-fill, minmax(140px, 1fr)); gap:4px; }
      #servicesTile .svc-mini .row { padding:4px 6px; font-size:10px; }

      /* activity feed fills cell */
      #activityTile .feed { max-height:none; }
    }

    /* On 2200+ widen the grid spread slightly */
    @media (min-width:2200px) {
      #tab-overview .dash-grid { grid-template-columns: 1.8fr 1fr 1fr 1fr; }
    }

    /* ── WORKSPACE TAB ─────────────────────────────────────────────────────── */
    body.workspace-active { height:100vh; overflow:hidden; }
    body.workspace-active .content { height:calc(100vh - 100px); display:flex; flex-direction:column; padding:2vh 2vw !important; gap:0; overflow:hidden; box-sizing:border-box; }
    body.workspace-active.fs .content { height:100vh; padding:2vh 2vw !important; }
    body.workspace-active.fs .topbar, body.workspace-active.fs .tab-bar { display:none !important; }

    #tab-workspace.active { display:flex !important; flex-direction:column; flex:1; min-height:0; gap:10px; }
    .ws-grid { flex:1; min-height:0; display:grid; gap:10px;
      grid-template-columns: 320px 1fr;
      grid-template-rows: 1fr auto;
      grid-template-areas: "svcs detail" "pipe  tools";
    }
    @media (min-width:1800px) { .ws-grid { grid-template-columns: 360px 1fr 380px; grid-template-rows: 1fr auto; grid-template-areas: "svcs detail tools" "svcs pipe   tools"; } }
    @media (min-width:2600px) { .ws-grid { grid-template-columns: 420px 1fr 460px; } }

    .ws-pane { background:#0f0f10; border:1px solid #1f1f22; border-radius:8px; padding:12px 14px; display:flex; flex-direction:column; min-height:0; overflow:hidden; }
    .ws-pane > .ws-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; gap:8px; flex-shrink:0; }
    .ws-pane > .ws-head .ws-title { font-size:11px; letter-spacing:2px; color:#737373; text-transform:uppercase; font-weight:600; }
    .ws-pane > .ws-body { flex:1; min-height:0; overflow:auto; }

    #ws-svcs { grid-area: svcs; }
    #ws-detail { grid-area: detail; }
    #ws-pipe { grid-area: pipe; max-height:180px; }
    #ws-tools { grid-area: tools; max-height:180px; }
    @media (min-width:1800px) {
      #ws-tools { max-height:none; }
      #ws-pipe { max-height:none; }
    }

    /* Service list rows */
    .ws-filter { display:flex; gap:4px; flex-wrap:wrap; margin-bottom:8px; flex-shrink:0; }
    .ws-filter .chip { font-size:10px; letter-spacing:1px; text-transform:uppercase; padding:3px 8px; border:1px solid #262626; border-radius:3px; background:transparent; color:#737373; cursor:pointer; }
    .ws-filter .chip.on { color:#c9a848; border-color:#c9a848; }
    .ws-search { width:100%; background:#0a0a0a; border:1px solid #262626; border-radius:4px; padding:6px 8px; font-size:11px; color:#e5e5e5; margin-bottom:8px; flex-shrink:0; }
    .ws-svc-row { padding:6px 8px; border-radius:4px; display:flex; align-items:center; gap:8px; cursor:pointer; border:1px solid transparent; font-size:11px; }
    .ws-svc-row:hover { background:#141414; border-color:#262626; }
    .ws-svc-row.sel { background:#1a1a1a; border-color:#c9a848; }
    .ws-svc-row .name { flex:1; color:#e5e5e5; text-overflow:ellipsis; overflow:hidden; white-space:nowrap; }
    .ws-svc-row .meta { font-size:9px; color:#525252; letter-spacing:1px; text-transform:uppercase; }
    .ws-svc-row.dead .name { color:#a3a3a3; }

    /* Detail pane */
    #ws-detail .ws-stat-strip { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:8px; }
    #ws-detail .ws-stat-strip .pill { font-size:10px; padding:3px 8px; border-radius:3px; background:#141414; border:1px solid #1e1e1e; color:#a3a3a3; }
    #ws-detail .ws-stat-strip .pill.alive { color:#34d399; border-color:#0f3b2a; }
    #ws-detail .ws-stat-strip .pill.dead { color:#f87171; border-color:#451a1a; }
    #ws-detail .ws-actions { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:10px; flex-shrink:0; }
    #ws-detail pre.ws-tail { background:#000; border:1px solid #1a1a1a; border-radius:4px; padding:10px 12px; font-family:ui-monospace,Menlo,Consolas,monospace; font-size:11px; line-height:1.5; color:#a3a3a3; flex:1; min-height:0; overflow:auto; white-space:pre-wrap; }
    #ws-detail pre.ws-tail .err { color:#f87171; }
    #ws-detail pre.ws-tail .warn { color:#f59e0b; }

    /* Pipeline pane: 4 mini-stages */
    .ws-stages { display:grid; grid-template-columns:repeat(4, 1fr); gap:6px; margin-bottom:6px; }
    .ws-stage { background:#0a0a0a; border:1px solid #1e1e1e; border-radius:4px; padding:6px 8px; }
    .ws-stage .lbl { font-size:9px; color:#525252; letter-spacing:1px; text-transform:uppercase; }
    .ws-stage .cnt { font-size:18px; font-weight:700; }
    .ws-stage.new .cnt { color:#c9a848; }
    .ws-stage.cleansed .cnt { color:#38bdf8; }
    .ws-stage.deconstructed .cnt { color:#a78bfa; }
    .ws-stage.deletion-stage .cnt { color:#f87171; }

    /* Tools pane buttons */
    .ws-tool-buttons { display:grid; grid-template-columns:repeat(auto-fill, minmax(110px, 1fr)); gap:6px; }
    .ws-tool-buttons .btn-sm { padding:5px 8px; font-size:11px; }
    #ws-tools pre { background:#000; border:1px solid #1a1a1a; border-radius:4px; padding:8px; font-family:ui-monospace,Menlo,Consolas,monospace; font-size:10px; color:#a3a3a3; margin-top:8px; max-height:120px; overflow:auto; white-space:pre-wrap; }

    /* Bar/Pct meters for system vitals */
    .meter { background:#0a0a0a; border:1px solid #1e1e1e; border-radius:4px; height:8px; overflow:hidden; position:relative; }
    .meter > span { display:block; height:100%; background:linear-gradient(to right, #34d399, #c9a848 70%, #f87171 90%); transition:width .4s ease; }
    .vitals-row { display:flex; justify-content:space-between; align-items:center; gap:10px; font-size:11px; margin-bottom:8px; }
    .vitals-row .lbl { color:#737373; font-size:10px; letter-spacing:1.5px; text-transform:uppercase; min-width:60px; }
    .vitals-row .val { color:#e5e5e5; font-variant-numeric:tabular-nums; font-size:12px; min-width:60px; text-align:right; }
    .vitals-row .meter { flex:1; }
    .procs-table { font-size:11px; }
    .procs-table .prow { display:grid; grid-template-columns:1fr 50px 50px; gap:6px; padding:3px 0; border-top:1px solid #1a1a1a; color:#a3a3a3; font-variant-numeric:tabular-nums; }
    .procs-table .prow:first-child { border-top:0; color:#737373; font-size:10px; letter-spacing:1px; text-transform:uppercase; }

    /* compact services-by-category inside a tile */
    .tile .svc-mini { display:grid; grid-template-columns:repeat(auto-fill, minmax(180px, 1fr)); gap:6px; }
    .tile .svc-mini .row { display:flex; align-items:center; gap:8px; padding:6px 8px; background:#141414; border:1px solid #1e1e1e; border-radius:6px; font-size:11px; }
    .tile .svc-mini .row .name { color:#e5e5e5; font-weight:500; flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .tile .svc-mini .row .port { color:#525252; font-size:10px; }

    /* compact activity feed inside a tile */
    .tile .feed { max-height:520px; overflow:auto; }
    .tile .feed .item { padding:6px 0; border-top:1px solid #1a1a1a; display:flex; gap:8px; font-size:11px; }
    .tile .feed .item:first-child { border-top:0; }
    .tile .feed .item .when { color:#525252; min-width:90px; }
    .tile .feed .item .what { color:#a3a3a3; }

    /* ── FULL-BLEED on TVs: zero gutters; user wants no margin/empty space ── */
    @media (min-width:1800px) { .content { padding:18px 20px; } }
    @media (min-width:2200px) { .content { padding:14px 16px; } }
    @media (min-width:2600px) { .content { padding:10px 12px; } }

    /* ── FULLSCREEN MODE: hides chrome, edge-to-edge ───────────────────── */
    body.fs .topbar,
    body.fs .tab-bar,
    body.fs .badge-overseer { display:none !important; }
    body.fs .content { padding:0 !important; }
    body.fs .tile { border-radius:0; }
    body.fs .panel { padding-bottom:0; }

    .fs-btn { background:transparent; border:1px solid #262626; color:#737373; padding:4px 10px; font-size:11px; border-radius:4px; cursor:pointer; letter-spacing:1px; text-transform:uppercase; }
    .fs-btn:hover { color:#c9a848; border-color:#c9a848; }
    .fs-exit { position:fixed; top:8px; right:8px; z-index:10000; opacity:0; transition:opacity .2s; }
    body.fs:hover .fs-exit, body.fs .fs-exit:focus { opacity:0.7; }
    body.fs .fs-exit:hover { opacity:1; }

    /* ── GFTV ── */
    .gftv-stat-value { font-size:26px; font-weight:700; }
    .gftv-stat-value.gold { color:#f5c400; }
    .gftv-stat-value.green { color:#34d399; }
    .gftv-promo-badge { background:rgba(245,196,0,0.12); color:#f5c400; border:1px solid rgba(245,196,0,0.25); padding:2px 8px; border-radius:4px; font-size:10px; letter-spacing:1px; font-weight:600; }
    .plan-starter { background:rgba(255,255,255,0.05); color:#a3a3a3; border:1px solid #333; padding:2px 8px; border-radius:4px; font-size:10px; }
    .plan-pro { background:rgba(245,196,0,0.1); color:#f5c400; border:1px solid rgba(245,196,0,0.25); padding:2px 8px; border-radius:4px; font-size:10px; }
    .gftv-form { background:#141414; border:1px solid #262626; border-radius:8px; padding:18px; margin-bottom:16px; }
    .gftv-form-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:10px; }
    .gftv-field { display:flex; flex-direction:column; gap:4px; }
    .gftv-field label { font-size:10px; letter-spacing:2px; color:#525252; text-transform:uppercase; }
    .gftv-field input, .gftv-field select { background:#0a0a0a; border:1px solid #262626; color:#e5e5e5; padding:8px 10px; font-family:'Inter',sans-serif; font-size:13px; border-radius:4px; outline:none; }
    .gftv-field input:focus, .gftv-field select:focus { border-color:#444; }
    .btn-gftv { background:#f5c400; color:#0a0a0a; border:none; padding:8px 18px; font-size:12px; font-weight:700; border-radius:4px; cursor:pointer; letter-spacing:1px; }
    .gftv-links a { color:#525252; font-size:11px; text-decoration:none; margin-right:10px; }
    .gftv-links a:hover { color:#f5c400; }
    .lead-status select { background:#0a0a0a; border:1px solid #262626; color:#a3a3a3; font-size:11px; padding:3px 6px; border-radius:4px; }

  </style>
</head>
<body>

<button class="fs-btn fs-exit" onclick="toggleFullscreen()" title="Exit fullscreen (Esc)">✕ Exit</button>

<!-- ── TOPBAR ── -->
<div class="topbar">
  <div class="topbar-left">
    <div class="logo">mad<span>Labs</span>lab</div>
    <span style="font-size:11px; color:#525252; letter-spacing:1px; text-transform:uppercase;">Superadmin</span>
    <span style="font-size:12px; color:#525252;">
      <span class="health-dot up"></span> <%= aliveCount %>
      <span class="health-dot down" style="margin-left:6px;"></span> <%= deadCount %>
    </span>
  </div>
  <div class="topbar-right">
    <a href="#tab-workspace" onclick="showTab('workspace', null); return false;" style="color:#c9a848;font-weight:600;">🛠 Workspace</a>
    <a href="/superadmin/events" style="color:#c9a848;">📡 Events</a>
    <a href="/superadmin/seo" style="color:#c9a848;">🔍 SEO/AEO</a>
    <a href="/superadmin/users">Users</a>
    <a href="/superadmin/security" style="color:#ef4444;">🛡 Security</a>
    <a href="/superadmin/permissions">Permissions</a>
    <a href="/superadmin/control-center" target="_blank">Control Center</a>
    <span style="display:inline-flex;align-items:center;gap:5px;font-size:11px;color:#525252;" title="Ollama AI">
      <span class="svc-dot" id="ollamaDotTop" style="width:6px;height:6px;"></span>Ollama
    </span>
    <button class="fs-btn" onclick="toggleFullscreen()" title="Fullscreen (F)">⛶ Full</button>
    <span><%= user.email %></span>
    <a href="/superadmin/logout">Logout</a>
  </div>
</div>

<!-- ── PRODUCT TAB BAR ── -->
<div class="tab-bar">
  <div class="tab active" onclick="showTab('overview', this)"><span class="tab-icon">&#9632;</span> Overview</div>
  <div class="tab" onclick="showTab('slab', this)"><span class="tab-icon">&#9830;</span> Slab</div>
  <div class="tab" onclick="showTab('madladslab', this)"><span class="tab-icon">&#9733;</span> MadLadsLab</div>
  <div class="tab" onclick="showTab('opstrain', this)"><span class="tab-icon">&#9881;</span> OpsTrain</div>
  <div class="tab" onclick="showTab('games', this)"><span class="tab-icon">&#127918;</span> Games</div>
  <div class="tab" onclick="showTab('stringborn', this)"><span class="tab-icon">&#128640;</span> Stringborn</div>
  <div class="tab" onclick="showTab('webapps', this)"><span class="tab-icon">&#127760;</span> Webapps</div>
  <div class="tab" onclick="showTab('gftv', this)"><span class="tab-icon">📺</span> Graffiti TV</div>
  <div class="tab-spacer"></div>
  <div class="tab tab-util" onclick="showTab('workspace', this)" style="color:#c9a848;"><span class="tab-icon">&#128736;</span> Workspace</div>
  <div class="tab tab-util" onclick="showTab('tools', this)"><span class="tab-icon">&#128295;</span> Tools</div>
  <div class="tab tab-util" onclick="showTab('activity', this)"><span class="tab-icon">&#9998;</span> Activity</div>
</div>

<!-- ── CONTENT ── -->
<div class="content">

  <!-- ═══════ OVERVIEW TAB ═══════ -->
  <div class="panel active" id="tab-overview">
    <div class="stats">
      <div class="stat"><div class="stat-label">Services</div><div class="stat-value"><%= totalServices %></div></div>
      <div class="stat"><div class="stat-label">Running</div><div class="stat-value green"><%= aliveCount %></div></div>
      <div class="stat"><div class="stat-label">Down</div><div class="stat-value red"><%= deadCount %></div></div>
      <div class="stat"><div class="stat-label">Tenants</div><div class="stat-value gold"><%= stats.total %></div></div>
      <div class="stat"><div class="stat-label">Active</div><div class="stat-value green"><%= stats.active %></div></div>
      <div class="stat"><div class="stat-label">Est. MRR</div><div class="stat-value gold">$<%= stats.mrr %></div></div>
    </div>

    <div class="quick-links">
      <a class="qlink" href="/superadmin/scottsGateway" style="border-color:#c9a848;color:#c9a848">&#127968; Scott's Gateway</a>
      <a class="qlink" href="/superadmin/scottsGateway/remote/<%= encodeURIComponent((user?.email || 'me').split('@')[0]) %>" target="_blank" style="border-color:#c9a848;color:#c9a848">&#128241; My Remote</a>
      <a class="qlink" href="/superadmin/scottsGateway/mission-control" target="_blank" style="border-color:#c9a848;color:#c9a848">&#128250; Mission Control</a>
      <a class="qlink" href="/superadmin/users">&#128101; Platform Users</a>
      <a class="qlink" href="/superadmin/all-tickets">&#127991; All Tickets</a>
      <a class="qlink" href="/superadmin/tickets">&#9873; Escalated</a>
      <a class="qlink" href="/superadmin/permissions">&#128274; Permissions</a>
      <a class="qlink" href="/superadmin/subscribers">&#128236; Subscribers</a>
      <a class="qlink" href="/superadmin/signups">&#128200; Signups</a>
      <a class="qlink" href="/superadmin/promos">&#127873; Promos</a>
      <a class="qlink" href="/superadmin/announcements">&#128227; Announcements</a>
    </div>

    <!-- Tiled TV-style dashboard — 1→2→3→4 col by screen width -->
    <div class="dash-grid">

      <!-- Server Harmony — Three.js constellation, live pulses -->
      <div class="tile harmony span-all" id="harmonyTile">
        <div class="tile-head">
          <span class="tile-title" style="color:#a78bfa;">Server Harmony · live pulse</span>
          <span class="tile-meta">
            <a href="#tab-workspace" onclick="showTab('workspace', null); return false;" class="btn-sm" style="padding:3px 10px;color:#c9a848;border-color:#c9a848;margin-right:10px;">🛠 Open Workspace →</a>
            <span id="harmonyStatusServices" style="color:#34d399;"><%= aliveCount %> up</span>
            <span style="margin:0 6px;color:#262626;">·</span>
            <span id="harmonyStatusConns" style="color:#60a5fa;">— conns</span>
            <span style="margin:0 6px;color:#262626;">·</span>
            <span id="harmonyStatusPulse" style="color:#737373;">— /s</span>
          </span>
        </div>
        <div id="harmonyCanvasWrap"></div>
        <div class="harmony-tooltip" id="harmonyTooltip" style="display:none;left:0;top:0;"></div>
        <div class="legend">
          <span class="lg-item"><span class="lg-dot" style="background:#34d399;box-shadow:0 0 6px #34d399;"></span>Platform</span>
          <span class="lg-item"><span class="lg-dot" style="background:#60a5fa;box-shadow:0 0 6px #60a5fa;"></span>Client</span>
          <span class="lg-item"><span class="lg-dot" style="background:#c084fc;box-shadow:0 0 6px #c084fc;"></span>Game</span>
          <span class="lg-item"><span class="lg-dot" style="background:#f59e0b;box-shadow:0 0 6px #f59e0b;"></span>Media</span>
          <span class="lg-item"><span class="lg-dot" style="background:#c9a848;box-shadow:0 0 6px #c9a848;"></span>Tool</span>
          <span class="lg-item"><span class="lg-dot" style="background:#f87171;box-shadow:0 0 6px #f87171;"></span>Down</span>
        </div>
        <script type="application/json" id="harmonyServicesJson"><%- JSON.stringify(services.map(s => ({ name:s.name, category:s.category, port:s.port, tmux:s.tmux, alive:s.alive===true }))) %></script>
      </div>

      <!-- System Vitals — CPU/RAM/load + top processes + sparkline -->
      <div class="tile span-2" id="vitalsTile">
        <div class="tile-head">
          <span class="tile-title" style="color:#34d399;">System Vitals</span>
          <span class="tile-meta" id="vitalsUptime">—</span>
        </div>
        <div class="tile-body">
          <div class="vitals-row">
            <span class="lbl">CPU</span>
            <div class="meter"><span id="vitalsCpuBar" style="width:0%"></span></div>
            <span class="val" id="vitalsCpuVal">—</span>
          </div>
          <div class="vitals-row">
            <span class="lbl">RAM</span>
            <div class="meter"><span id="vitalsMemBar" style="width:0%"></span></div>
            <span class="val" id="vitalsMemVal">—</span>
          </div>
          <div class="vitals-row">
            <span class="lbl">Load</span>
            <div class="meter"><span id="vitalsLoadBar" style="width:0%"></span></div>
            <span class="val" id="vitalsLoadVal">—</span>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:11px;color:#737373;margin:8px 0 6px;">
            <span>Processes: <span id="vitalsProcCount" style="color:#e5e5e5;">—</span></span>
            <span>Active services: <span id="vitalsActiveSvc" style="color:#34d399;"><%= aliveCount %></span> / <%= totalServices %></span>
          </div>
          <div class="procs-table" id="vitalsProcs">
            <div class="prow"><span>Process</span><span style="text-align:right;">CPU%</span><span style="text-align:right;">MEM%</span></div>
          </div>
          <div style="margin-top:10px;">
            <div style="font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:#525252;margin-bottom:4px;">Activity · 2 min</div>
            <div style="height:80px;position:relative;"><canvas id="vitalsSpark"></canvas></div>
          </div>
        </div>
      </div>

<!-- Services tile moved to Tools tab → "Services" section -->

      <!-- Outbound connections — live -->
      <div class="tile" id="outboundsTile">
        <div class="tile-head">
          <span class="tile-title" style="color:#c9a848;">Outbounds · live</span>
          <span class="tile-meta" id="outboundsMeta">— peers</span>
        </div>
        <div class="tile-body">
          <div id="outboundsList" style="font-size:11px;color:#a3a3a3;">Loading…</div>
        </div>
      </div>

      <!-- Ollama Tunnel — analytics + health (primary on landing) -->
      <div class="tile span-2" id="ollamaTile" style="border-color:#1f2a44;">
        <div class="tile-head">
          <span class="tile-title" style="display:flex;align-items:center;gap:8px;color:#60a5fa;">
            <span class="svc-dot" id="ollamaDot"></span> Ollama Tunnel
            <span style="font-size:9px;letter-spacing:2px;color:#525252;text-transform:uppercase;">ollama.madladslab.com</span>
          </span>
          <span class="tile-meta">
            <select id="ollamaWindow" onchange="loadOllamaAnalytics()" class="service-select" style="font-size:11px;padding:2px 6px;">
              <option value="1">24h</option>
              <option value="7" selected>7d</option>
              <option value="30">30d</option>
            </select>
            <button class="btn-sm" onclick="loadOllamaAnalytics()" style="padding:2px 8px;">↻</button>
            <span id="ollamaUpdatedAt" style="margin-left:6px;">—</span>
          </span>
        </div>
        <div class="tile-body">
          <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px;font-size:11px;">
            <span id="ollamaLlmPill"  style="padding:3px 8px;border-radius:3px;background:#1a1a1a;border:1px solid #262626;color:#737373;">LLM —</span>
            <span id="ollamaSdPill"   style="padding:3px 8px;border-radius:3px;background:#1a1a1a;border:1px solid #262626;color:#737373;">SD —</span>
            <span id="ollamaSnip"     style="padding:3px 8px;border-radius:3px;background:#0a0a0a;color:#525252;">models —</span>
          </div>
          <div class="stats" style="grid-template-columns:repeat(auto-fit, minmax(100px, 1fr));margin-bottom:10px;gap:8px;">
            <div class="stat" style="padding:10px 12px;"><div class="stat-label">Requests</div><div class="stat-value" id="ollamaStatReq" style="font-size:22px;">—</div></div>
            <div class="stat" style="padding:10px 12px;"><div class="stat-label">Errors</div><div class="stat-value red" id="ollamaStatErr" style="font-size:22px;">—</div></div>
            <div class="stat" style="padding:10px 12px;"><div class="stat-label">Err%</div><div class="stat-value" id="ollamaStatErrRate" style="font-size:22px;">—</div></div>
            <div class="stat" style="padding:10px 12px;"><div class="stat-label">Bytes Out</div><div class="stat-value gold" id="ollamaStatBytes" style="font-size:22px;">—</div></div>
            <div class="stat" style="padding:10px 12px;"><div class="stat-label">Avg Dur</div><div class="stat-value" id="ollamaStatDur" style="font-size:22px;">—</div></div>
            <div class="stat" style="padding:10px 12px;"><div class="stat-label">Keys</div><div class="stat-value green" id="ollamaStatKeys" style="font-size:22px;">—</div></div>
          </div>
          <div style="display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:10px;">
            <div>
              <div style="font-size:10px;letter-spacing:2px;color:#525252;text-transform:uppercase;margin-bottom:4px;">Keys</div>
              <div id="ollamaKeysTable" style="font-size:11px;color:#a3a3a3;">Loading…</div>
            </div>
            <div>
              <div style="font-size:10px;letter-spacing:2px;color:#525252;text-transform:uppercase;margin-bottom:4px;">Routes</div>
              <div id="ollamaRoutesTable" style="font-size:11px;color:#a3a3a3;">Loading…</div>
            </div>
            <div>
              <div style="font-size:10px;letter-spacing:2px;color:#525252;text-transform:uppercase;margin-bottom:4px;">Models</div>
              <div id="ollamaModelsTable" style="font-size:11px;color:#a3a3a3;">Loading…</div>
            </div>
          </div>
          <div id="ollamaFlags" style="margin-top:8px;font-size:11px;"></div>
        </div>
      </div>

      <!-- Recent Signups -->
      <div class="tile" id="signupsTile">
        <div class="tile-head">
          <span class="tile-title">Recent Signups</span>
          <a class="btn-sm" href="/superadmin/signups" style="padding:2px 8px;">All</a>
        </div>
        <div class="tile-body">
        <% if (recentSignups.length) { %>
          <div style="font-size:11px;">
            <% for (const s of recentSignups.slice(0, 10)) { %>
              <div style="padding:6px 0;border-top:1px solid #1a1a1a;display:flex;justify-content:space-between;gap:8px;">
                <div style="min-width:0;overflow:hidden;">
                  <div style="color:#e5e5e5;text-overflow:ellipsis;overflow:hidden;white-space:nowrap;"><%= s.email %></div>
                  <div style="color:#525252;font-size:10px;"><%= s.brandName || '—' %> · <%= s.subdomain || '—' %></div>
                </div>
                <div style="color:#525252;font-size:10px;white-space:nowrap;"><%= new Date(s.createdAt).toLocaleDateString() %></div>
              </div>
            <% } %>
          </div>
        <% } else { %>
          <div class="empty">No recent signups</div>
        <% } %>
        </div>
      </div>

      <!-- Tenants -->
      <%
        // Activity helper — returns { label, color, live }
        function tenantActivity(t) {
          const seen = t?.meta?.lastSeenAt ? new Date(t.meta.lastSeenAt).getTime() : null;
          if (!seen) return { label: 'never', color: '#525252', live: false };
          const dt = Date.now() - seen;
          if (dt < 90 * 1000)          return { label: 'live now', color: '#34d399', live: true };
          if (dt < 5 * 60 * 1000)      return { label: Math.floor(dt/60000) + 'm ago', color: '#34d399', live: false };
          if (dt < 60 * 60 * 1000)     return { label: Math.floor(dt/60000) + 'm ago', color: '#c9a848', live: false };
          if (dt < 24 * 60 * 60 * 1000) return { label: Math.floor(dt/3600000) + 'h ago', color: '#a3a3a3', live: false };
          if (dt < 30 * 24 * 60 * 60 * 1000) return { label: Math.floor(dt/86400000) + 'd ago', color: '#737373', live: false };
          return { label: 'idle', color: '#525252', live: false };
        }
        // Truly-active count = tenants with activity within the last 24h
        const liveCount = tenants.filter(t => t?.meta?.lastSeenAt && (Date.now() - new Date(t.meta.lastSeenAt).getTime()) < 24*60*60*1000).length;
        const liveNowCount = tenants.filter(t => t?.meta?.lastSeenAt && (Date.now() - new Date(t.meta.lastSeenAt).getTime()) < 90*1000).length;
      %>
      <div class="tile" id="tenantsTile">
        <div class="tile-head">
          <span class="tile-title">Tenants · usage</span>
          <span class="tile-meta"><%= stats.total %> total</span>
        </div>
        <div class="tile-body">
        <div style="display:grid;grid-template-columns:repeat(4, 1fr);gap:6px;margin-bottom:8px;flex-shrink:0;">
          <div style="background:#141414;border:1px solid #1e1e1e;border-radius:6px;padding:8px;text-align:center;" title="Hit a tenant URL in the last 90 seconds">
            <div style="font-size:9px;color:#525252;letter-spacing:1px;text-transform:uppercase;">Live</div>
            <div style="font-size:18px;color:#34d399;font-weight:700;"><%= liveNowCount %></div>
          </div>
          <div style="background:#141414;border:1px solid #1e1e1e;border-radius:6px;padding:8px;text-align:center;" title="Activity in the last 24h">
            <div style="font-size:9px;color:#525252;letter-spacing:1px;text-transform:uppercase;">24h</div>
            <div style="font-size:18px;color:#c9a848;font-weight:700;"><%= liveCount %></div>
          </div>
          <div style="background:#141414;border:1px solid #1e1e1e;border-radius:6px;padding:8px;text-align:center;" title="Status: active">
            <div style="font-size:9px;color:#525252;letter-spacing:1px;text-transform:uppercase;">Active</div>
            <div style="font-size:18px;color:#a3a3a3;font-weight:700;"><%= stats.active %></div>
          </div>
          <div style="background:#141414;border:1px solid #1e1e1e;border-radius:6px;padding:8px;text-align:center;" title="Status: suspended">
            <div style="font-size:9px;color:#525252;letter-spacing:1px;text-transform:uppercase;">Susp</div>
            <div style="font-size:18px;color:#f87171;font-weight:700;"><%= stats.suspended %></div>
          </div>
        </div>
        <% if (tenants.length) { %>
          <div style="font-size:11px;">
            <% for (const t of tenants.slice(0, 12)) { %>
              <% const act = tenantActivity(t); %>
              <%
                const tName = t.brand?.name || t.brandName || t.domain?.split('.')[0] || t.meta?.subdomain || 'unnamed';
                const tSub  = t.meta?.subdomain || t.domain || '';
                const tOwner = t.meta?.ownerEmail || t.brand?.ownerName || t.brand?.email || null;
              %>
              <div style="padding:5px 0;border-top:1px solid #1a1a1a;display:flex;justify-content:space-between;gap:8px;align-items:center;">
                <div style="min-width:0;overflow:hidden;display:flex;align-items:center;gap:6px;">
                  <% if (act.live) { %><span style="width:6px;height:6px;border-radius:50%;background:#34d399;box-shadow:0 0 4px #34d399;flex-shrink:0;"></span><% } %>
                  <div style="min-width:0;overflow:hidden;">
                    <div style="color:#e5e5e5;text-overflow:ellipsis;overflow:hidden;white-space:nowrap;"><%= tName %></div>
                    <div style="color:#525252;font-size:10px;text-overflow:ellipsis;overflow:hidden;white-space:nowrap;">
                      <%= tSub %><% if (tOwner) { %> · <span style="color:#737373;"><%= tOwner %></span><% } %><% if (t.meta?.hitsTotal) { %> · <%= t.meta.hitsTotal %> hits<% } %>
                    </div>
                  </div>
                </div>
                <div style="text-align:right;white-space:nowrap;">
                  <div style="font-size:10px;color:<%= act.color %>;letter-spacing:1px;text-transform:uppercase;"><%= act.label %></div>
                  <div style="font-size:9px;color:<%= t.status === 'active' ? '#34d399' : t.status === 'suspended' ? '#f87171' : '#525252' %>;letter-spacing:1px;text-transform:uppercase;"><%= t.status || 'preview' %></div>
                </div>
              </div>
            <% } %>
          </div>
        <% } else { %>
          <div class="empty">No tenants</div>
        <% } %>
        </div>
      </div>

      <!-- Activity feed -->
      <div class="tile span-2" id="activityTile">
        <div class="tile-head">
          <span class="tile-title">Activity</span>
          <a class="btn-sm" href="/superadmin/activity" style="padding:2px 8px;">Full Log</a>
        </div>
        <div class="tile-body">
          <div class="feed" style="max-height:none;">
            <% if (activityLogs.length) { %>
              <% for (const log of activityLogs) { %>
                <div class="item">
                  <div class="when"><%= new Date(log.timestamp).toLocaleString() %></div>
                  <div class="what">
                    <span style="color:#e5e5e5;"><%= log.action %></span>
                    <% if (log.tenantDomain) { %><span style="color:#c9a848;"> · <%= log.tenantDomain %></span><% } %>
                    <% if (log.actor?.email) { %><span style="color:#525252;"> · <%= log.actor.email %></span><% } %>
                  </div>
                </div>
              <% } %>
            <% } else { %>
              <div class="empty">No activity yet</div>
            <% } %>
          </div>
        </div>
      </div>

    </div><!-- /dash-grid -->
  </div>

