      <% if (opsSvc?.tmux) { %><button class="qlink" style="cursor:pointer;" onclick="svcAction('opsTrain', 'status')">&#128994; Status Check</button><% } %>
    </div>

    <!-- Stats -->
    <div class="stats">
      <div class="stat"><div class="stat-label">Brands</div><div class="stat-value gold"><%= opsData.stats.totalBrands || 0 %></div></div>
      <div class="stat"><div class="stat-label">Active</div><div class="stat-value green"><%= opsData.stats.activeBrands || 0 %></div></div>
      <div class="stat"><div class="stat-label">Total Users</div><div class="stat-value"><%= opsData.stats.totalUsers || 0 %></div></div>
      <div class="stat"><div class="stat-label">Admins</div><div class="stat-value green"><%= opsData.stats.admins || 0 %></div></div>
      <div class="stat"><div class="stat-label">Managers</div><div class="stat-value blue"><%= opsData.stats.managers || 0 %></div></div>
    </div>

    <!-- Brands -->
    <h2>&#127973; Brands</h2>
    <% if (opsData.brands.length === 0) { %>
      <div class="empty">No OpsTrain brands found.</div>
    <% } else { %>
      <div class="card-grid" style="margin-bottom:24px;">
        <% opsData.brands.forEach(b => { %>
          <div class="card">
            <div class="card-header">
              <span class="card-title">
                <% if (b.color) { %><span style="width:12px;height:12px;border-radius:3px;display:inline-block;background:<%= b.color %>;border:1px solid #333;"></span><% } %>
                <%= b.name || '(unnamed)' %>
              </span>
              <span class="svc-dot <%= b.active !== false ? 'alive' : 'dead' %>"></span>
            </div>
            <div class="card-meta" style="margin:8px 0;">
              <span><strong><%= b.userCount %></strong> users</span>
              <span><strong><%= b.taskCount %></strong> tasks</span>
              <span><strong><%= b.qrCount %></strong> QR codes</span>
              <% if (b.status) { %><span>Status: <%= b.status %></span><% } %>
              <% if (b.plan) { %><span>Plan: <%= b.plan %></span><% } %>
            </div>
            <div class="card-actions">
              <form method="POST" action="/superadmin/opstrain/brand/<%= b._id %>/toggle" style="display:inline;">
                <button type="submit" class="btn-sm"><%= b.active !== false ? 'Deactivate' : 'Activate' %></button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- Users -->
    <h2>&#128101; Users <span style="font-size:11px; color:#525252; font-weight:400;">(<%= opsData.users.length %> total)</span></h2>
    <% if (opsData.users.length === 0) { %>
      <div class="empty">No OpsTrain users found.</div>
    <% } else { %>
      <div class="table-wrap" style="margin-bottom:16px;">
        <table>
          <thead><tr>
            <th>User</th>
            <th>Email</th>
            <th>Brand</th>
            <th>Role</th>
            <th>Actions</th>
          </tr></thead>
          <tbody>
            <% opsData.users.forEach(u => { %>
              <%   const uBrand = opsData.brands.find(b => b._id.toString() === (u.brand || '').toString()); %>
              <tr>
                <td><strong><%= u.displayName || u.firstName || '\u2014' %></strong></td>
                <td style="font-size:12px;"><%= u.email || '\u2014' %></td>
                <td style="font-size:12px; color:#c9a848;"><%= uBrand?.name || '\u2014' %></td>
                <td>
                  <form method="POST" action="/superadmin/opstrain/user/<%= u._id %>/role" style="display:inline;">
                    <select name="role" onchange="this.form.submit()" style="background:#1a1a1a;border:1px solid #333;color:#e5e5e5;padding:3px 6px;border-radius:4px;font-size:11px;font-family:'Inter',sans-serif;">
                      <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>user</option>
                      <option value="manager" <%= u.role === 'manager' ? 'selected' : '' %>>manager</option>
                      <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>admin</option>
                      <option value="superadmin" <%= u.role === 'superadmin' ? 'selected' : '' %>>superadmin</option>
                    </select>
                  </form>
                </td>
                <td style="font-size:11px; color:#525252;">
                  Scoped to <%= uBrand?.name || 'no brand' %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
    <pre id="opsOutput" class="tool-output" style="margin-top:16px; display:none;">Run a status check above...</pre>
  </div>

