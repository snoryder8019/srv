<script>

  // ── Fullscreen mode ──────────────────────────────────────────────────────
  function toggleFullscreen() {
    const willEnter = !document.body.classList.contains('fs');
    document.body.classList.toggle('fs', willEnter);
    try {
      if (willEnter && document.documentElement.requestFullscreen) document.documentElement.requestFullscreen().catch(()=>{});
      else if (!willEnter && document.exitFullscreen && document.fullscreenElement) document.exitFullscreen().catch(()=>{});
    } catch(e){}
    try { localStorage.setItem('superadmin.fs', willEnter ? '1' : '0'); } catch(e){}
    // Force canvases to re-measure after the layout settles
    [50, 200, 500].forEach(ms => setTimeout(() => {
      try { window.serverHarmony && window.serverHarmony.resize(); } catch(e){}
      try { window.vitalsSparkChart && window.vitalsSparkChart.resize(); } catch(e){}
      window.dispatchEvent(new Event('resize'));
    }, ms));
  }
  document.addEventListener('keydown', (e) => {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;
    if (e.key === 'f' || e.key === 'F') { toggleFullscreen(); }
    else if (e.key === 'Escape' && document.body.classList.contains('fs') && !document.fullscreenElement) {
      document.body.classList.remove('fs');
    }
  });
  document.addEventListener('fullscreenchange', () => {
    if (!document.fullscreenElement) document.body.classList.remove('fs');
    // Force canvases to re-measure after the fullscreen transition settles
    [50, 200, 500].forEach(ms => setTimeout(() => {
      try { window.serverHarmony && window.serverHarmony.resize(); } catch(e){}
      try { window.vitalsSparkChart && window.vitalsSparkChart.resize(); } catch(e){}
      window.dispatchEvent(new Event('resize'));
    }, ms));
  });
  // Restore last fullscreen preference (visual only — browser fs API requires user gesture)
  try { if (localStorage.getItem('superadmin.fs') === '1') document.body.classList.add('fs'); } catch(e){}

  // ── Graffiti TV ──────────────────────────────────────────────────────────
  let _gftvData = null;

  async function loadGFTV() {
    if (_gftvData) return renderGFTV(_gftvData);
    try {
      const r = await fetch('/superadmin/gftv/data');
      _gftvData = await r.json();
      renderGFTV(_gftvData);
    } catch(e) { console.error('GFTV load error', e); }
  }

  function renderGFTV(d) {
    const { tenants, leads, mrr, totalSubs, planPrices } = d;
    const active  = tenants.filter(t => t.active && !t.isPromo).length;
    const promos  = tenants.filter(t => t.isPromo).length;
    const newLeads = leads.filter(l => l.status === 'new').length;

    document.getElementById('gftvStats').innerHTML = [
      { label:'Tenants',     val:'$' + mrr,    cls:'gold',  sub:'Est. MRR' },
      { label:'Active',      val:active,        cls:'green', sub:'Paying tenants' },
      { label:'Promo',       val:promos,        cls:'',      sub:'Excluded from MRR' },
      { label:'New Leads',   val:newLeads,      cls:'gold',  sub:'Awaiting contact' },
      { label:'Subscribers', val:totalSubs,     cls:'green', sub:'TV email signups' },
    ].map(s => `<div class="stat">
      <div class="stat-label">${s.label}</div>
      <div class="stat-value ${s.cls}">${s.val}</div>
      <div style="font-size:10px;color:#525252;margin-top:2px;">${s.sub}</div>
    </div>`).join('');

    // Tenants table
    document.getElementById('gftvTenantsTable').innerHTML = tenants.length ? tenants.map(t => {
      const tenantMrr = t.active && !t.isPromo ? (planPrices[t.plan] || 0) : 0;
      const tenantData = {};  // subscriber count loaded server-side in stats
      return `<tr>
        <td>
          <div style="font-weight:500;color:#fff;">${t.name}</div>
          <div style="font-size:11px;color:#525252;">${t.slug}</div>
        </td>
        <td><span class="plan-${t.plan}">${t.plan}</span></td>
        <td style="color:#f5c400;font-weight:600;">${tenantMrr ? '$' + tenantMrr + '/mo' : '<span style=\'color:#525252\'>—</span>'}</td>
        <td style="color:#a3a3a3;">—</td>
        <td>
          ${t.active ? '<span class="badge badge-active">ACTIVE</span>' : '<span class="badge badge-suspended">OFF</span>'}
          ${t.isPromo ? '<span class="gftv-promo-badge">PROMO</span>' : ''}
        </td>
        <td class="gftv-links">
          <a href="https://graffititv.madladslab.com/tv/${t.slug}" target="_blank">📺 Display</a>
          <a href="https://graffititv.madladslab.com/admin/${t.slug}" target="_blank">⚙ Admin</a>
          <a href="/superadmin/gftv/tenants/${t.slug}">🔍 Detail</a>
        </td>
        <td>
          <div style="display:flex;gap:4px;flex-wrap:wrap;">
            <button class="btn-sm" onclick="gftvTogglePromo('${t.slug}', this)">${t.isPromo ? 'Unmark Promo' : 'Mark Promo'}</button>
            <button class="btn-sm" onclick="gftvToggleActive('${t.slug}', ${!t.active})">${t.active ? 'Disable' : 'Enable'}</button>
            <button class="btn-sm" style="color:#f87171;border-color:#451a1a;" onclick="gftvDelete('${t.slug}')">Del</button>
          </div>
        </td>
      </tr>`;
    }).join('') : '<tr><td colspan="7" style="color:#525252;text-align:center;padding:20px;">No tenants yet</td></tr>';

    // Leads table
    document.getElementById('gftvLeadsTable').innerHTML = leads.length ? leads.slice().reverse().map(l => `<tr>
      <td style="font-weight:500;">${l.name || '—'}</td>
      <td>${l.email}</td>
      <td style="color:#a3a3a3;">${l.business || '—'}</td>
      <td><span class="plan-${l.plan || 'starter'}">${l.plan || 'starter'}</span></td>
      <td style="color:#525252;font-size:11px;">${l.source || 'landing'}</td>
      <td class="lead-status">
        <select onchange="gftvUpdateLead(${l.id}, this.value)">
          ${['new','contacted','converted','lost'].map(s => `<option value="${s}" ${l.status===s?'selected':''}>${s}</option>`).join('')}
        </select>
      </td>
      <td style="color:#525252;font-size:11px;">${new Date(l.createdAt).toLocaleDateString()}</td>
    </tr>`).join('') : '<tr><td colspan="7" style="color:#525252;text-align:center;padding:20px;">No leads yet</td></tr>';
  }

  async function gftvAddTenant() {
    const slug = document.getElementById('gt-slug').value.toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'');
    const body = {
      name:     document.getElementById('gt-name').value,
      slug,
      email:    document.getElementById('gt-email').value,
      password: document.getElementById('gt-pass').value,
      plan:     document.getElementById('gt-plan').value,
      location: document.getElementById('gt-loc').value,
      color:    document.getElementById('gt-color').value || '#ff5000',
      isPromo:  String(document.getElementById('gt-promo').checked),
    };
    if (!body.name || !body.slug) { document.getElementById('gt-msg').textContent = 'Name and slug required.'; return; }
    const r = await fetch('/superadmin/gftv/tenants', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
    const d = await r.json();
    if (d.ok) {
      document.getElementById('gt-msg').textContent = '✓ Tenant created — ' + slug;
      _gftvData = null; loadGFTV();
    } else {
      document.getElementById('gt-msg').textContent = 'Error: ' + (d.error || 'Unknown');
    }
  }

  async function gftvTogglePromo(slug, btn) {
    const r = await fetch(`/superadmin/gftv/tenants/${slug}/toggle-promo`, { method:'POST' });
    const d = await r.json();
    if (d.ok) { btn.textContent = d.isPromo ? 'Unmark Promo' : 'Mark Promo'; _gftvData = null; loadGFTV(); }
  }

  async function gftvToggleActive(slug, active) {
    await fetch(`/superadmin/gftv/tenants/${slug}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ active }) });
    _gftvData = null; loadGFTV();
  }

  async function gftvDelete(slug) {
    if (!confirm('Delete GFTV tenant ' + slug + '?')) return;
    await fetch(`/superadmin/gftv/tenants/${slug}`, { method:'DELETE' });
    _gftvData = null; loadGFTV();
  }

  async function gftvUpdateLead(id, status) {
    await fetch(`/superadmin/gftv/leads/${id}/status`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ status }) });
    if (_gftvData) {
      _gftvData.leads = _gftvData.leads.map(l => String(l.id) === String(id) ? {...l, status} : l);
      renderGFTV(_gftvData);
    }
  }

  // Load GFTV data when tab is opened
  const _origShowTab = showTab;

  function showTab(id, el) {
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    const panel = document.getElementById('tab-' + id);
    if (panel) panel.classList.add('active');
    if (el) el.classList.add('active');
    else {
      // Find the tab button by matching the id
      document.querySelectorAll('.tab').forEach(t => {
        if (t.getAttribute('onclick')?.includes("'" + id + "'")) t.classList.add('active');
      });
    }
    window.location.hash = 'tab-' + id;
    if (id === 'tools') loadDeprecationPipeline();
    if (id === 'gftv') loadGFTV();
    if (id === 'tools') loadClaudeBriefing();
    if (id === 'overview') loadOllamaAnalytics();
    document.body.classList.toggle('overview-active', id === 'overview');
    document.body.classList.toggle('workspace-active', id === 'workspace');
    if (id === 'workspace') wsMaybeInit();
    // Let layout settle, then force canvases to re-measure
    if (id === 'overview') {
      [50, 250].forEach(ms => setTimeout(() => {
        try { window.serverHarmony && window.serverHarmony.resize(); } catch(e){}
        try { window.vitalsSparkChart && window.vitalsSparkChart.resize(); } catch(e){}
      }, ms));
    }
  }

  // Restore tab from URL hash on page load
  (function() {
    const hash = window.location.hash.replace('#tab-', '');
    if (hash && document.getElementById('tab-' + hash)) showTab(hash);
    // Default-active Overview gets the class on initial load
    if (!hash || hash === 'overview') document.body.classList.add('overview-active');
    if (hash === 'workspace') { document.body.classList.add('workspace-active'); wsMaybeInit(); }
    // Mini Ollama dot in topbar — check on load
    refreshOllamaTopbar();
    // Auto-load analytics on initial Overview landing
    if (!window.location.hash || window.location.hash === '#tab-overview') {
      try { loadOllamaAnalytics(); } catch(e) {}
    }
    // Load Claude briefing if tools tab already active
    if (!window.location.hash || window.location.hash === '#tab-tools') loadClaudeBriefing();
  })();

  async function runTool(tool) {
    const out = document.getElementById('toolOutput');
    out.textContent = 'Running ' + tool + '...';
    try {
      const res = await fetch('/superadmin/api/tool/' + tool);
      const data = await res.json();
      out.textContent = data.output || JSON.stringify(data, null, 2);
    } catch (e) {
      out.textContent = 'Error: ' + e.message;
    }
  }

  async function deprecateService(name) {
    if (!confirm('Deprecate "' + name + '"?\n\nMoves /srv/' + name + ' → /srv/depricated/new/' + name + '\n(kills its tmux session and removes from auto-start)')) return;
    const out = document.getElementById('deprecateOutput');
    if (out) { out.style.display = 'block'; out.textContent = '▶ Deprecating ' + name + '…'; }
    try {
      const res = await fetch('/superadmin/api/deprecation/ingest-service', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name }),
      });
      const d = await res.json();
      const body = JSON.stringify({ ok: d.ok, name: d.name, staged: d.staged, error: d.error }, null, 2);
      const output = (d.output || '').trim();
      if (out) out.textContent = (d.ok ? '✓ DEPRECATED → ' + d.staged : '✗ FAILED — ' + (d.error || 'unknown')) + '\n\n── script output ──\n' + (output || '(no output)') + '\n\n── response ──\n' + body;
      if (d.ok) {
        loadDeprecationPipeline();
        setTimeout(() => location.reload(), 1800);
      }
    } catch (e) { if (out) out.textContent = 'Error: ' + e.message; }
  }

  async function svcAction(name, action) {
    const out = document.getElementById('toolOutput') || document.getElementById('agentOutput') || document.getElementById('opsOutput') || document.getElementById('gamesOutput');
    if (out) out.textContent = 'Checking ' + name + '...';
    try {
      const res = await fetch('/superadmin/api/service/' + name + '/' + action);
      const data = await res.json();
      if (out) out.textContent = data.output || JSON.stringify(data, null, 2);
    } catch (e) {
      if (out) out.textContent = 'Error: ' + e.message;
    }
  }

