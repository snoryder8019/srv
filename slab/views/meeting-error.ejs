<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meeting Unavailable — <%= brand?.name || 'Home' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Jost', sans-serif;
      background: #1C2B4A;
      color: #F5F3EF;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .error-card {
      text-align: center;
      padding: 48px 40px;
      max-width: 460px;
    }
    .error-icon {
      font-size: 3rem;
      margin-bottom: 20px;
      opacity: 0.5;
    }
    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.8rem;
      font-weight: 300;
      margin-bottom: 12px;
      color: #C9A848;
    }
    p {
      font-size: 1rem;
      font-weight: 300;
      color: rgba(245, 243, 239, 0.7);
      line-height: 1.6;
    }
  </style>
</head>
<body>
  <div class="error-card">
    <div class="error-icon">&#9888;</div>
    <h1>Meeting Unavailable</h1>
    <p><%= message %></p>
  </div>
</body>
</html>
