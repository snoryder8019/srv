<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('../partials/seo-head', { seo: { title: (settings.title || 'Book a Meeting') + ' — ' + (brand?.name || '') } }) %>
  <%- include('../partials/font-vars') %>
  <%- include('../partials/landing-styles') %>
  <style>
    /* ── booking page — uses tenant design tokens from landing-styles ── */
    body.booking-page { background: var(--bg, var(--ivory)); color: var(--on-ivory, var(--dark)); padding-top: 96px; }

    .booking-hero { padding: 24px 24px 0; text-align: center; max-width: 720px; margin: 0 auto; }
    .booking-hero h1 { font-family: var(--font-heading), serif; font-size: clamp(1.8rem, 3.4vw, 2.6rem); font-weight: 400; color: var(--on-ivory, var(--dark)); margin-bottom: 10px; line-height: 1.15; }
    .booking-hero p { font-size: 1rem; color: var(--on-ivory-muted, var(--muted)); line-height: 1.6; }

    .alert { max-width: 720px; margin: 16px auto; padding: 12px 18px; border-radius: var(--card-radius, 4px); font-size: 14px; }
    .alert-success { background: color-mix(in srgb, var(--success, #15803d) 12%, transparent); border: 1px solid color-mix(in srgb, var(--success, #15803d) 30%, transparent); color: var(--success, #15803d); }
    .alert-error { background: color-mix(in srgb, var(--crimson, #b91c1c) 10%, transparent); border: 1px solid color-mix(in srgb, var(--crimson, #b91c1c) 30%, transparent); color: var(--crimson, #b91c1c); }

    .booking-layout { display: grid; grid-template-columns: 1fr 380px; gap: 32px; max-width: 1000px; margin: 32px auto; padding: 0 24px 80px; }
    @media (max-width: 820px) { .booking-layout { grid-template-columns: 1fr; } }

    .day-list { }
    .day-btn { width: 100%; text-align: left; padding: 14px 18px; background: var(--surface, #fff); border: 1px solid var(--border, var(--ivory-mid)); border-radius: var(--card-radius, 4px); margin-bottom: 8px; cursor: pointer; display: flex; align-items: center; justify-content: space-between; transition: all .15s; font-family: var(--font-body), sans-serif; color: var(--on-surface, var(--on-ivory)); }
    .day-btn:hover, .day-btn.active { border-color: var(--accent, var(--gold)); background: color-mix(in srgb, var(--accent, var(--gold)) 6%, var(--surface, #fff)); }
    .day-btn.active { box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent, var(--gold)) 25%, transparent); }
    .day-label { font-size: 14px; font-weight: 500; }
    .day-count { font-size: 12px; color: var(--on-surface-muted, var(--muted)); background: color-mix(in srgb, var(--on-surface, var(--dark)) 6%, transparent); padding: 3px 10px; border-radius: 999px; }
    .day-btn.active .day-count { background: color-mix(in srgb, var(--accent, var(--gold)) 18%, transparent); color: var(--accent, var(--gold)); }

    .slots-panel { position: sticky; top: 110px; }
    .slots-header { font-family: var(--font-heading), serif; font-size: 1.05rem; font-weight: 500; color: var(--on-ivory, var(--dark)); margin-bottom: 14px; }
    .slots-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 24px; }
    .slot-btn { padding: 11px; border: 1px solid var(--border, var(--ivory-mid)); border-radius: var(--card-radius, 4px); font-size: 13px; font-weight: 500; color: var(--on-surface, var(--on-ivory)); background: var(--surface, #fff); cursor: pointer; text-align: center; transition: all .15s; font-family: var(--font-body), sans-serif; }
    .slot-btn:hover { border-color: var(--accent, var(--gold)); color: var(--accent, var(--gold)); }
    .slot-btn.selected { background: var(--accent, var(--gold)); color: var(--on-gold, var(--white)); border-color: var(--accent, var(--gold)); }
    .slot-placeholder { font-size: 13px; color: var(--on-surface-muted, var(--muted)); text-align: center; padding: 24px; background: var(--surface, #fff); border: 1px dashed var(--border, var(--ivory-mid)); border-radius: var(--card-radius, 4px); }

    .booking-form { background: var(--surface, #fff); border: 1px solid var(--border, var(--ivory-mid)); border-radius: var(--card-radius, 4px); padding: 24px; margin-top: 16px; display: none; }
    .booking-form.show { display: block; }
    .selected-slot-display { background: color-mix(in srgb, var(--accent, var(--gold)) 8%, var(--surface, #fff)); border: 1px solid color-mix(in srgb, var(--accent, var(--gold)) 30%, transparent); border-radius: var(--card-radius, 4px); padding: 12px 14px; margin-bottom: 20px; font-size: 13px; font-weight: 500; color: var(--on-surface, var(--on-ivory)); }
    .form-field { margin-bottom: 14px; }
    .form-field label { display: block; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; color: var(--on-surface-muted, var(--muted)); margin-bottom: 6px; }
    .form-field input, .form-field textarea { width: 100%; border: 1px solid var(--border, var(--ivory-mid)); border-radius: var(--card-radius, 4px); padding: 10px 12px; font-size: 14px; font-family: var(--font-body), sans-serif; color: var(--on-surface, var(--on-ivory)); background: var(--surface, #fff); }
    .form-field input:focus, .form-field textarea:focus { outline: none; border-color: var(--accent, var(--gold)); }
    .form-field textarea { resize: vertical; min-height: 80px; }
    .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .btn-book { width: 100%; background: var(--primary, var(--navy)); color: var(--on-navy, var(--white)); border: none; border-radius: var(--card-radius, 4px); padding: 13px; font-size: 14px; font-weight: 600; cursor: pointer; font-family: var(--font-body), sans-serif; letter-spacing: .08em; text-transform: uppercase; transition: opacity .15s, transform .15s; margin-top: 8px; }
    .btn-book:hover { opacity: .92; transform: translateY(-1px); }
    .btn-book:disabled { opacity: .5; cursor: not-allowed; transform: none; }
  </style>
</head>
<body class="booking-page" data-layout="<%= design.landing_layout || 'classic' %>">

<% if (visibility.header !== false) { %>
<%- include('../partials/header', { activePage: 'book' }) %>
<% } %>

<% if (success) { %>
<div class="alert alert-success">✓ Your meeting request has been submitted! Check your email for a confirmation.</div>
<% } %>
<% if (error) { %>
<div class="alert alert-error">
  <% if (error === 'taken') { %>That time slot was just booked — please choose another.
  <% } else if (error === 'missing') { %>Please fill in all required fields.
  <% } else { %>Something went wrong. Please try again.<% } %>
</div>
<% } %>

<div class="booking-hero">
  <h1><%= settings.title || 'Book a Meeting' %></h1>
  <p><%= settings.subtitle || 'Choose a time that works for you.' %></p>
</div>

<div class="booking-layout">

  <div>
    <div class="day-list" id="dayList">
      <% days.forEach((day, i) => { %>
      <button class="day-btn <%= i === 0 ? 'active' : '' %>" data-day="<%= i %>" onclick="selectDay(<%= i %>, this)">
        <span class="day-label"><%= day.label %></span>
        <span class="day-count"><%= day.slots.length %> slot<%= day.slots.length !== 1 ? 's' : '' %></span>
      </button>
      <% }); %>
      <% if (!days.length) { %>
      <div style="text-align:center;padding:40px;color:var(--on-surface-muted, var(--muted));font-size:14px">No available slots in the next <%= settings.advanceDays || 14 %> days.</div>
      <% } %>
    </div>
  </div>

  <div class="slots-panel">
    <div class="slots-header" id="slotsHeader">
      <% if (days.length) { %><%= days[0]?.label %><% } else { %>No availability<% } %>
    </div>

    <div class="slots-grid" id="slotsGrid">
      <% if (days.length && days[0]) { %>
        <% days[0].slots.forEach(slot => { %>
        <button class="slot-btn" data-iso="<%= slot.iso %>" data-label="<%= days[0].label %> at <%= slot.label %>" onclick="selectSlot(this)"><%= slot.label %></button>
        <% }); %>
      <% } else { %>
      <div class="slot-placeholder" style="grid-column:span 2">Select a date</div>
      <% } %>
    </div>

    <div class="booking-form" id="bookingForm">
      <div class="selected-slot-display" id="selectedSlotDisplay">📅 —</div>
      <form method="POST" action="/book" id="theForm">
        <input type="hidden" name="slotIso" id="slotIso">
        <div class="form-row-2">
          <div class="form-field"><label>First Name *</label><input name="firstName" required></div>
          <div class="form-field"><label>Last Name</label><input name="lastName"></div>
        </div>
        <div class="form-field"><label>Email *</label><input type="email" name="email" required></div>
        <div class="form-row-2">
          <div class="form-field"><label>Phone</label><input type="tel" name="phone"></div>
          <div class="form-field"><label>Company</label><input name="company"></div>
        </div>
        <div class="form-field"><label>Message</label><textarea name="message" placeholder="Anything we should know before the meeting?"></textarea></div>
        <input type="hidden" name="name" id="fullNameHidden">
        <button type="submit" class="btn-book" id="bookBtn">Request Meeting</button>
      </form>
    </div>

  </div>
</div>

<% if (visibility.footer !== false) { %>
<%- include('../partials/footer') %>
<% } %>

<script>
const DAYS = <%- JSON.stringify(days.map(d => ({ label: d.label, iso: d.iso, slots: d.slots }))) %>;
let selectedSlotIso = null;

function selectDay(idx, btn) {
  document.querySelectorAll('.day-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const day = DAYS[idx];
  if (!day) return;
  document.getElementById('slotsHeader').textContent = day.label;
  const grid = document.getElementById('slotsGrid');
  if (!day.slots.length) {
    grid.innerHTML = '<div class="slot-placeholder" style="grid-column:span 2">No slots this day</div>';
    return;
  }
  grid.innerHTML = day.slots.map(s =>
    `<button class="slot-btn" data-iso="${s.iso}" data-label="${day.label} at ${s.label}" onclick="selectSlot(this)">${s.label}</button>`
  ).join('');
  selectedSlotIso = null;
  document.getElementById('bookingForm').classList.remove('show');
}

function selectSlot(btn) {
  document.querySelectorAll('.slot-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  selectedSlotIso = btn.dataset.iso;
  document.getElementById('slotIso').value = selectedSlotIso;
  document.getElementById('selectedSlotDisplay').textContent = '📅 ' + btn.dataset.label;
  document.getElementById('bookingForm').classList.add('show');
  document.getElementById('bookingForm').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

document.getElementById('theForm').addEventListener('submit', function(e) {
  const fn = document.querySelector('[name=firstName]').value.trim();
  const ln = document.querySelector('[name=lastName]').value.trim();
  document.getElementById('fullNameHidden').value = [fn, ln].filter(Boolean).join(' ');
  document.getElementById('bookBtn').disabled = true;
  document.getElementById('bookBtn').textContent = 'Submitting…';
});

if (DAYS.length === 1) selectDay(0, document.querySelector('.day-btn'));
</script>

</body>
</html>
