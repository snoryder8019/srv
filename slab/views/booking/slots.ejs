<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('../partials/seo-head', { seo: { title: (settings.title || 'Book a Service') + ' — ' + (brand?.name || '') } }) %>
  <%- include('../partials/font-vars') %>
  <%- include('../partials/landing-styles') %>
  <style>
    body.booking-page { background: var(--bg, var(--ivory)); color: var(--on-ivory, var(--dark)); padding-top: 96px; line-height: 1.5; }

    .booking-hero { padding: 24px 24px 0; text-align: center; max-width: 720px; margin: 0 auto; }
    .booking-hero h1 { font-family: var(--font-heading), serif; font-size: clamp(1.8rem, 3.4vw, 2.6rem); font-weight: 400; color: var(--on-ivory, var(--dark)); margin-bottom: 10px; line-height: 1.15; }
    .booking-hero p { font-size: 1rem; color: var(--on-ivory-muted, var(--muted)); }

    .alert { max-width: 720px; margin: 16px auto; padding: 12px 18px; border-radius: var(--card-radius, 4px); font-size: 14px; }
    .alert-success { background: color-mix(in srgb, var(--success, #15803d) 12%, transparent); border: 1px solid color-mix(in srgb, var(--success, #15803d) 30%, transparent); color: var(--success, #15803d); }
    .alert-error { background: color-mix(in srgb, var(--crimson, #b91c1c) 10%, transparent); border: 1px solid color-mix(in srgb, var(--crimson, #b91c1c) 30%, transparent); color: var(--crimson, #b91c1c); }

    .service-pills { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; max-width: 720px; margin: 24px auto 0; padding: 0 16px; }
    .pill { padding: 8px 16px; background: var(--surface, #fff); border: 1px solid var(--border, var(--ivory-mid)); border-radius: 999px; font-size: 13px; font-weight: 500; color: var(--on-surface, var(--on-ivory)); text-decoration: none; transition: all .15s; font-family: var(--font-body), sans-serif; }
    .pill:hover { border-color: var(--accent, var(--gold)); }
    .pill.active { background: var(--accent, var(--gold)); color: var(--on-gold, var(--white)); border-color: var(--accent, var(--gold)); }

    .layout { max-width: 900px; margin: 32px auto; padding: 0 16px 80px; }
    .empty-state { background: var(--surface, #fff); border: 1px solid var(--border, var(--ivory-mid)); border-radius: var(--card-radius, 4px); padding: 48px 24px; text-align: center; color: var(--on-surface-muted, var(--muted)); }
    .empty-state h3 { color: var(--on-surface, var(--on-ivory)); margin-bottom: 8px; font-weight: 600; font-family: var(--font-heading), serif; }

    .day-block { background: var(--surface, #fff); border: 1px solid var(--border, var(--ivory-mid)); border-radius: var(--card-radius, 4px); margin-bottom: 16px; overflow: hidden; }
    .day-header { padding: 14px 18px; background: color-mix(in srgb, var(--on-surface, var(--dark)) 4%, var(--surface, #fff)); border-bottom: 1px solid var(--border, var(--ivory-mid)); font-weight: 600; font-size: 15px; font-family: var(--font-heading), serif; color: var(--on-surface, var(--on-ivory)); }
    .slot-list { padding: 8px; }
    .slot-row { display: flex; flex-wrap: wrap; gap: 14px; align-items: center; padding: 14px 12px; border-bottom: 1px solid color-mix(in srgb, var(--border, var(--ivory-mid)) 60%, transparent); cursor: pointer; transition: background .15s; border-radius: var(--card-radius, 4px); }
    .slot-row:last-child { border-bottom: none; }
    .slot-row:hover { background: color-mix(in srgb, var(--accent, var(--gold)) 6%, var(--surface, #fff)); }
    .slot-row.selected { background: color-mix(in srgb, var(--accent, var(--gold)) 12%, var(--surface, #fff)); outline: 2px solid var(--accent, var(--gold)); outline-offset: -2px; }
    .slot-time { font-weight: 700; color: var(--accent, var(--gold)); min-width: 120px; font-size: 14px; }
    .slot-svc { font-size: 14px; font-weight: 500; color: var(--on-surface, var(--on-ivory)); flex: 1; min-width: 140px; }
    .slot-loc { font-size: 12px; color: var(--on-surface-muted, var(--muted)); margin-top: 2px; }
    .slot-cap { font-size: 11px; color: var(--on-surface-muted, var(--muted)); margin-left: auto; }

    .form-panel { background: var(--surface, #fff); border: 1px solid var(--border, var(--ivory-mid)); border-radius: var(--card-radius, 4px); margin-top: 24px; padding: 24px; display: none; }
    .form-panel.visible { display: block; }
    .form-panel h3 { font-size: 1.05rem; margin-bottom: 6px; font-family: var(--font-heading), serif; font-weight: 500; color: var(--on-surface, var(--on-ivory)); }
    .form-summary { background: color-mix(in srgb, var(--accent, var(--gold)) 8%, var(--surface, #fff)); border-radius: var(--card-radius, 4px); padding: 12px 14px; font-size: 13px; margin-bottom: 16px; border-left: 3px solid var(--accent, var(--gold)); color: var(--on-surface, var(--on-ivory)); }
    .form-row { margin-bottom: 14px; }
    .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    @media (max-width: 520px) { .form-grid-2 { grid-template-columns: 1fr; } }
    .form-panel label { display: block; font-size: 11px; font-weight: 600; color: var(--on-surface-muted, var(--muted)); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 5px; }
    .form-panel input, .form-panel textarea { width: 100%; padding: 10px 12px; font-size: 14px; border: 1px solid var(--border, var(--ivory-mid)); border-radius: var(--card-radius, 4px); font-family: var(--font-body), sans-serif; background: var(--surface, #fff); color: var(--on-surface, var(--on-ivory)); }
    .form-panel input:focus, .form-panel textarea:focus { outline: none; border-color: var(--accent, var(--gold)); }
    .form-panel textarea { min-height: 80px; resize: vertical; }
    .vehicle-block { background: color-mix(in srgb, var(--on-surface, var(--dark)) 3%, var(--surface, #fff)); border: 1px solid var(--border, var(--ivory-mid)); border-radius: var(--card-radius, 4px); padding: 14px; margin-bottom: 14px; display: none; }
    .vehicle-block.visible { display: block; }
    .vehicle-block h4 { font-size: 12px; font-weight: 600; color: var(--on-surface-muted, var(--muted)); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 10px; }
    .submit-btn { background: var(--primary, var(--navy)); color: var(--on-navy, var(--white)); border: none; border-radius: var(--card-radius, 4px); padding: 13px 32px; font-size: 14px; font-weight: 600; cursor: pointer; width: 100%; font-family: var(--font-body), sans-serif; letter-spacing: .08em; text-transform: uppercase; transition: opacity .15s, transform .15s; }
    .submit-btn:hover { opacity: .92; transform: translateY(-1px); }
    .submit-btn:disabled { opacity: .5; cursor: not-allowed; transform: none; }
  </style>
</head>
<body class="booking-page" data-layout="<%= design.landing_layout || 'classic' %>">

<% if (visibility.header !== false) { %>
<%- include('../partials/header', { activePage: 'book' }) %>
<% } %>

<section class="booking-hero">
  <h1><%= settings.title || 'Book a Service' %></h1>
  <% if (settings.subtitle) { %><p><%= settings.subtitle %></p><% } %>
</section>

<% if (success) { %>
  <div class="alert alert-success">✓ Your booking request was received. We'll be in touch shortly.</div>
<% } %>
<% if (error) { %>
  <div class="alert alert-error">
    <% if (error === 'taken') { %>That slot was just claimed. Please pick another.
    <% } else if (error === 'missing') { %>Please fill in all required fields.
    <% } else { %>Something went wrong. Please try again.<% } %>
  </div>
<% } %>

<% if (serviceTypes && serviceTypes.length > 1) { %>
<nav class="service-pills">
  <a href="/book" class="pill <%= !requestedService ? 'active' : '' %>">All Services</a>
  <% serviceTypes.forEach(st => { %>
  <a href="/book?service=<%= st.slug %>" class="pill <%= requestedService === st.slug ? 'active' : '' %>"><%= st.label %></a>
  <% }) %>
</nav>
<% } %>

<div class="layout">
  <% if (!days.length) { %>
    <div class="empty-state">
      <h3>No availability right now</h3>
      <p>Please check back soon — new slots are added regularly.</p>
    </div>
  <% } else { %>
    <% days.forEach(day => { %>
    <div class="day-block">
      <div class="day-header"><%= day.label %></div>
      <div class="slot-list">
        <% day.slots.forEach(s => { %>
        <div class="slot-row" data-slot-id="<%= s._id %>" data-service="<%= s.serviceType %>" data-service-label="<%= s.serviceLabel %>" data-requires-vehicle="<%= s.requiresVehicle ? '1' : '' %>" data-time="<%= s.startTime %>–<%= s.endTime %>" data-day="<%= day.label %>" data-location="<%= (s.location && (s.location.label || s.location.address)) || '' %>">
          <div class="slot-time"><%= s.startTime %> – <%= s.endTime %></div>
          <div class="slot-svc">
            <%= s.serviceLabel %>
            <% if (s.location && (s.location.label || s.location.address)) { %>
            <div class="slot-loc">📍 <%= s.location.label || s.location.address %></div>
            <% } %>
          </div>
          <div class="slot-cap"><%= (s.maxBookings || 1) - (s.currentBookings || 0) %> open</div>
        </div>
        <% }) %>
      </div>
    </div>
    <% }) %>
  <% } %>

  <form id="bookingForm" method="POST" action="/book" class="form-panel">
    <h3>Confirm your booking</h3>
    <div class="form-summary" id="formSummary"></div>
    <input type="hidden" name="slotId" id="slotIdInput">

    <div class="form-grid-2">
      <div class="form-row">
        <label>Name *</label>
        <input type="text" name="name" required>
      </div>
      <div class="form-row">
        <label>Email *</label>
        <input type="email" name="email" required>
      </div>
    </div>
    <div class="form-row">
      <label>Phone</label>
      <input type="tel" name="phone" placeholder="Optional but recommended">
    </div>

    <div class="vehicle-block" id="vehicleBlock">
      <h4>Vehicle Info</h4>
      <div class="form-grid-2">
        <div class="form-row">
          <label>Year</label>
          <input type="text" name="vehicleYear" placeholder="2018">
        </div>
        <div class="form-row">
          <label>Make</label>
          <input type="text" name="vehicleMake" placeholder="Forest River">
        </div>
        <div class="form-row">
          <label>Model</label>
          <input type="text" name="vehicleModel" placeholder="Cherokee 274RK">
        </div>
        <div class="form-row">
          <label>Length (ft)</label>
          <input type="text" name="vehicleLength" placeholder="32">
        </div>
      </div>
      <div class="form-row" style="margin-bottom:0">
        <label>Issue / What needs service?</label>
        <textarea name="issueDescription" placeholder="Briefly describe the issue or service needed."></textarea>
      </div>
    </div>

    <div class="form-row">
      <label>Notes (optional)</label>
      <textarea name="message" placeholder="Anything else we should know?"></textarea>
    </div>

    <button type="submit" class="submit-btn">Request Booking</button>
  </form>
</div>

<% if (visibility.footer !== false) { %>
<%- include('../partials/footer') %>
<% } %>

<script>
  const form        = document.getElementById('bookingForm');
  const slotInput   = document.getElementById('slotIdInput');
  const summary     = document.getElementById('formSummary');
  const vehicleBlk  = document.getElementById('vehicleBlock');
  let selectedRow = null;

  document.querySelectorAll('.slot-row').forEach(row => {
    row.addEventListener('click', () => {
      if (selectedRow) selectedRow.classList.remove('selected');
      row.classList.add('selected');
      selectedRow = row;

      slotInput.value = row.dataset.slotId;
      const loc = row.dataset.location ? ` at ${row.dataset.location}` : '';
      summary.innerHTML = `<strong>${row.dataset.serviceLabel}</strong> — ${row.dataset.day}, ${row.dataset.time}${loc}`;

      vehicleBlk.classList.toggle('visible', row.dataset.requiresVehicle === '1');
      form.classList.add('visible');
      form.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>

</body>
</html>
