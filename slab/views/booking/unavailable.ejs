<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Booking Unavailable — <%= brand.name || '' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    body{font-family:'Inter',sans-serif;background:#FAFAF8;color:#0F1B30;min-height:100vh;display:flex;flex-direction:column}
    .header{background:#fff;border-bottom:1px solid #E6E1D6;padding:16px 24px}
    .logo{font-size:18px;font-weight:700;color:#0F1B30;text-decoration:none}
    .center{flex:1;display:flex;align-items:center;justify-content:center;text-align:center;padding:40px}
    .box{max-width:400px}
    .icon{font-size:48px;margin-bottom:16px}
    h1{font-size:22px;font-weight:600;margin-bottom:8px}
    p{color:#6B7380;font-size:14px;line-height:1.6}
    a{color:<%= design.color_primary || '#C9A848' %>;text-decoration:none}
  </style>
</head>
<body>
  <div class="header"><a href="/" class="logo"><%= brand.name || 'Back' %></a></div>
  <div class="center">
    <div class="box">
      <div class="icon">📅</div>
      <h1>Booking Not Available</h1>
      <p>Online booking isn't available right now.<br>Please <a href="/#contact">contact us directly</a> to schedule a meeting.</p>
    </div>
  </div>
</body>
</html>
