<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%- include('../partials/seo-head', { seo: { title: 'Booking Unavailable — ' + (brand?.name || '') } }) %>
  <%- include('../partials/font-vars') %>
  <%- include('../partials/landing-styles') %>
  <style>
    body.booking-page { background: var(--bg, var(--ivory)); color: var(--on-ivory, var(--dark)); min-height: 100vh; display: flex; flex-direction: column; padding-top: 96px; }
    .center { flex: 1; display: flex; align-items: center; justify-content: center; text-align: center; padding: 40px 24px 80px; }
    .box { max-width: 440px; }
    .icon { font-size: 48px; margin-bottom: 16px; }
    .box h1 { font-family: var(--font-heading), serif; font-size: clamp(1.6rem, 3vw, 2rem); font-weight: 400; color: var(--on-ivory, var(--dark)); margin-bottom: 10px; line-height: 1.2; }
    .box p { color: var(--on-ivory-muted, var(--muted)); font-size: 1rem; line-height: 1.6; }
    .box a { color: var(--accent, var(--gold)); text-decoration: none; font-weight: 500; }
    .box a:hover { text-decoration: underline; }
  </style>
</head>
<body class="booking-page" data-layout="<%= design.landing_layout || 'classic' %>">

<% if (visibility.header !== false) { %>
<%- include('../partials/header', { activePage: 'book' }) %>
<% } %>

<div class="center">
  <div class="box">
    <div class="icon">📅</div>
    <h1>Booking Not Available</h1>
    <p>Online booking isn't available right now.<br>Please <a href="/#contact">contact us directly</a> to schedule a meeting.</p>
  </div>
</div>

<% if (visibility.footer !== false) { %>
<%- include('../partials/footer') %>
<% } %>

</body>
</html>
