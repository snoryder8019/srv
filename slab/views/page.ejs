<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pg.metaTitle || pg.title %> — <%= brand?.name || 'Home' %></title>
  <% if (pg.metaDescription) { %><meta name="description" content="<%= pg.metaDescription %>"><% } %>
  <meta name="robots" content="<%= pg.robotsMeta || 'index,follow' %>">
  <% if (pg.canonicalUrl) { %><link rel="canonical" href="<%= pg.canonicalUrl %>"><% } %>
  <% if (pg.ogImage) { %><meta property="og:image" content="<%= pg.ogImage %>"><% } %>
  <meta property="og:title" content="<%= pg.metaTitle || pg.title %> — <%= brand?.name || 'Home' %>">
  <% if (pg.metaDescription) { %><meta property="og:description" content="<%= pg.metaDescription %>"><% } %>
  <%
    const FONT_MAP = {
      'Cormorant Garamond': 'Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400',
      'Playfair Display': 'Playfair+Display:ital,wght@0,400;0,600;1,400',
      'Lora': 'Lora:ital,wght@0,400;0,600;1,400',
      'Merriweather': 'Merriweather:ital,wght@0,300;0,400;0,700;1,300',
      'Libre Baskerville': 'Libre+Baskerville:ital,wght@0,400;0,700;1,400',
      'Jost': 'Jost:wght@300;400;500;600',
      'Inter': 'Inter:wght@300;400;500;600',
      'Poppins': 'Poppins:wght@300;400;500;600',
      'Raleway': 'Raleway:wght@300;400;500;600',
      'Nunito': 'Nunito:wght@300;400;500;600',
      'DM Sans': 'DM+Sans:wght@300;400;500;600',
    };
    const hF = FONT_MAP[design.font_heading] || FONT_MAP['Cormorant Garamond'];
    const bF = FONT_MAP[design.font_body] || FONT_MAP['Jost'];
    const fontsParam = design.font_heading === design.font_body ? hF : hF + '&family=' + bF;
  %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=<%= fontsParam %>&display=swap" rel="stylesheet">
<style>
  :root {
    --primary:      <%= design.color_primary %>;
    --primary-deep: <%= design.color_primary_deep %>;
    --primary-mid:  <%= design.color_primary_mid %>;
    --accent:       <%= design.color_accent %>;
    --accent-light: <%= design.color_accent_light %>;
    --bg:           <%= design.color_bg %>;
    --ivory-mid: #E6E1D6; --slate: #6B7380; --dark: #0F1B30; --white: #FDFCFA;
    --font-heading: '<%= design.font_heading %>', serif;
    --font-body:    '<%= design.font_body %>', sans-serif;
    --section-pad: 80px 52px;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior:smooth; }
  body { font-family:var(--font-body); background:var(--white); color:var(--dark); }
  .reveal { opacity:0; transform:translateY(20px); transition:opacity 0.5s ease, transform 0.5s ease; }
  .reveal.visible { opacity:1; transform:translateY(0); }
  nav.scrolled { box-shadow:0 2px 24px rgba(28,43,74,0.1); }

  /* ── NAV ── */
  nav { position:fixed;top:0;width:100%;z-index:1000;display:flex;justify-content:space-between;align-items:center;padding:20px 52px;background:rgba(253,252,250,0.95);backdrop-filter:blur(10px);border-bottom:1px solid var(--ivory-mid); }
  .nav-wordmark { text-decoration:none; }
  .nav-wordmark-top { font-family:var(--font-heading);font-size:1.4rem;font-weight:400;color:var(--dark);letter-spacing:0.04em;display:block; }
  .nav-wordmark-sub { font-size:0.58rem;font-weight:600;letter-spacing:0.28em;text-transform:uppercase;color:var(--primary);margin-top:2px;display:block; }
  .nav-links { display:flex;gap:2rem;list-style:none;align-items:center; }
  .nav-links a { font-size:0.82rem;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--slate);text-decoration:none;transition:color 0.2s; }
  .nav-links a:hover { color:var(--primary); }

  /* ── PAGE HERO ── */
  .page-hero { padding:140px 52px 64px;background:var(--bg);border-bottom:1px solid var(--ivory-mid); }
  .page-hero-inner { max-width:860px;margin:0 auto; }
  .back-link { font-size:0.75rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--slate);text-decoration:none;display:inline-flex;align-items:center;gap:6px;margin-bottom:32px; }
  .back-link:hover { color:var(--primary); }
  .page-title { font-family:var(--font-heading);font-size:clamp(2rem,4.5vw,3.6rem);font-weight:300;line-height:1.1;color:var(--dark); }

  /* ── CONTENT PAGE ── */
  .page-content-wrap { max-width:800px;margin:0 auto;padding:60px 52px 100px; }
  .page-content { font-size:1rem;font-weight:300;line-height:1.9;color:var(--dark); }
  .page-content h2 { font-family:var(--font-heading);font-size:1.8rem;font-weight:400;color:var(--dark);margin:48px 0 16px; }
  .page-content h3 { font-family:var(--font-heading);font-size:1.4rem;font-weight:400;color:var(--dark);margin:36px 0 12px; }
  .page-content p { margin-bottom:20px; }
  .page-content ul, .page-content ol { margin:0 0 20px 24px; }
  .page-content li { margin-bottom:8px;line-height:1.7; }
  .page-content strong { font-weight:600; }
  .page-content em { font-style:italic; }
  .page-content a { color:var(--primary); }
  .page-content a:hover { color:var(--accent); }
  .page-content img { max-width:100%;border-radius:2px;margin:24px 0; }
  .page-content blockquote { border-left:3px solid var(--accent);padding:16px 24px;margin:32px 0;background:var(--bg);font-style:italic;color:var(--slate); }

  /* ── DATA LIST PAGE ── */
  .data-list-wrap { max-width:1100px;margin:0 auto;padding:60px 52px 100px; }
  .data-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:28px; }
  .data-card { background:var(--bg);border:1px solid var(--ivory-mid);border-radius:2px;overflow:hidden;text-decoration:none;color:inherit;display:flex;flex-direction:column;transition:box-shadow 0.2s; }
  .data-card:hover { box-shadow:0 4px 24px rgba(15,27,48,0.1); }
  .data-card-img { width:100%;aspect-ratio:16/9;object-fit:cover; }
  .data-card-img-placeholder { width:100%;aspect-ratio:16/9;background:var(--ivory-mid); }
  .data-card-body { padding:20px;flex:1;display:flex;flex-direction:column; }
  .data-card-date { font-size:0.68rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--slate);margin-bottom:8px; }
  .data-card-title { font-family:var(--font-heading);font-size:1.2rem;font-weight:400;color:var(--dark);margin-bottom:10px;line-height:1.3; }
  .data-card-excerpt { font-size:0.88rem;font-weight:300;color:var(--slate);line-height:1.6;flex:1; }
  .data-card-cta { margin-top:16px;font-size:0.72rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--primary); }
  .data-pagination { display:flex;gap:8px;justify-content:center;margin-top:52px;flex-wrap:wrap; }
  .data-page-btn { padding:8px 16px;border:1px solid var(--ivory-mid);border-radius:2px;font-size:0.8rem;font-weight:500;color:var(--dark);text-decoration:none;transition:all 0.15s; }
  .data-page-btn:hover { border-color:var(--primary);color:var(--primary); }
  .data-page-btn.active { background:var(--primary);color:#fff;border-color:var(--primary); }
  .data-page-btn.disabled { color:var(--slate);pointer-events:none;opacity:0.4; }

  /* ── LANDING PAGE BLOCKS ── */
  /* text */
  .lb-text { background:var(--white);padding:var(--section-pad); }
  .lb-text-inner { max-width:780px;margin:0 auto; }
  /* split */
  .lb-split { background:var(--bg);padding:var(--section-pad); }
  .lb-split-inner { max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center; }
  .lb-split-img { width:100%;aspect-ratio:4/3;object-fit:cover;border-radius:2px; }
  .lb-split-img-ph { width:100%;aspect-ratio:4/3;background:var(--ivory-mid);border-radius:2px; }
  /* cta */
  .lb-cta { background:var(--primary-deep);padding:80px 52px;text-align:center; }
  .lb-cta-inner { max-width:700px;margin:0 auto; }
  /* cards */
  .lb-cards { background:var(--white);padding:var(--section-pad); }
  .lb-cards-inner { max-width:1100px;margin:0 auto; }
  .lb-cards-intro { text-align:center;max-width:640px;margin:0 auto 48px; }
  .lb-cards-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:24px; }
  .lb-card { background:var(--bg);padding:28px;border:1px solid var(--ivory-mid); }
  /* faq */
  .lb-faq { background:var(--bg);padding:var(--section-pad); }
  .lb-faq-inner { max-width:780px;margin:0 auto; }
  .lb-faq-list { margin-top:40px;display:flex;flex-direction:column; }
  .lb-faq-item { border-bottom:1px solid var(--ivory-mid); }
  .lb-faq-q { display:flex;justify-content:space-between;align-items:center;padding:18px 0;cursor:pointer;font-weight:500;color:var(--dark);gap:16px; }
  .lb-faq-q::after { content:'+';font-size:1.2rem;color:var(--accent);flex-shrink:0;transition:transform 0.2s; }
  .lb-faq-item.open .lb-faq-q::after { transform:rotate(45deg); }
  .lb-faq-a { display:none;padding:0 0 18px;color:var(--slate);line-height:1.8;font-size:0.95rem; }
  .lb-faq-item.open .lb-faq-a { display:block; }
  /* hero block */
  .lb-hero { background:var(--primary-deep);padding:100px 52px;text-align:center; }
  .lb-hero-inner { max-width:800px;margin:0 auto; }
  /* shared block typography */
  .lb-eyebrow { font-size:0.7rem;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:var(--accent);margin-bottom:14px; }
  .lb-heading { font-family:var(--font-heading);font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:300;line-height:1.15;margin-bottom:16px; }
  .lb-body { font-size:1rem;font-weight:300;line-height:1.8;color:var(--slate); }
  .lb-body p { margin-bottom:1em; }
  .lb-btn { display:inline-block;margin-top:28px;padding:14px 32px;background:var(--accent);color:var(--dark);font-family:var(--font-body);font-size:0.8rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;transition:background 0.2s; }
  .lb-btn:hover { background:var(--accent-light); }
  .lb-btn-outline { background:transparent;color:#fff;border:2px solid rgba(255,255,255,0.4); }
  .lb-btn-outline:hover { background:rgba(255,255,255,0.08); }
  .lb-card-title { font-family:var(--font-heading);font-size:1.15rem;font-weight:400;color:var(--dark);margin-bottom:8px; }
  .lb-card-body { font-size:0.9rem;line-height:1.7;color:var(--slate); }

  /* ── FOOTER ── */
  footer { background:var(--primary-deep);padding:48px 52px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:24px; }
  .footer-brand { font-family:var(--font-heading);font-size:1.3rem;font-weight:300;color:rgba(255,255,255,0.6); }
  .footer-links { list-style:none;display:flex;gap:24px; }
  .footer-links a { font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.35);text-decoration:none;transition:color 0.2s; }
  .footer-links a:hover { color:var(--accent-light); }

  @media (max-width:768px) {
    nav { padding:16px 20px; }
    .page-hero { padding:100px 20px 48px; }
    .page-content-wrap { padding:40px 20px 80px; }
    .data-list-wrap { padding:40px 20px 80px; }
    .data-grid { grid-template-columns:1fr; }
    .lb-split-inner { grid-template-columns:1fr; gap:36px; }
    .lb-cards-grid { grid-template-columns:1fr; }
    footer { padding:36px 20px; flex-direction:column; text-align:center; }
    .footer-links { flex-wrap:wrap; justify-content:center; gap:16px; }
    .nav-links { display:none; }
  }
</style>
</head>
<body>
<%- include("partials/preview-banner") %>
<%- include('partials/maintenance-banner') %>
<nav>
  <a href="/" class="nav-wordmark">
    <% if (logos && logos.logo_primary && (design.nav_logo_display === 'image' || design.nav_logo_display === 'both')) { %>
      <img src="<%= logos.logo_primary %>" alt="<%= brand?.name || 'Home' %>" style="height:42px;width:auto;object-fit:contain;">
    <% } %>
    <% if (!logos || !logos.logo_primary || design.nav_logo_display !== 'image') { %>
      <span class="nav-wordmark-top"><%- brand?.name || '' %></span>
      <span class="nav-wordmark-sub"><%= brand?.location || '' %></span>
    <% } %>
  </a>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <% if (typeof navPages !== 'undefined' && navPages.length) { %>
      <% navPages.forEach(function(p) { %>
        <li><a href="/<%= p.slug %>" <%= pg && pg.slug === p.slug ? 'class="active"' : '' %>><%- p.title %></a></li>
      <% }); %>
    <% } %>
    <li><a href="/blog">Blog</a></li>
    <li><a href="/#contact">Get Started</a></li>
  </ul>
</nav>

<% if (pg.pageType !== 'landing') { %>
<div class="page-hero reveal">
  <div class="page-hero-inner">
    <a href="/" class="back-link">← Home</a>
    <h1 class="page-title"><%= pg.title %></h1>
  </div>
</div>
<% } %>

<!-- ── CONTENT PAGE ───────────────────────────────────────────── -->
<% if (!pg.pageType || pg.pageType === 'content') { %>
<div class="page-content-wrap reveal">
  <div class="page-content"><%- pg.content %></div>
</div>

<!-- ── DATA LIST PAGE ─────────────────────────────────────────── -->
<% } else if (pg.pageType === 'data-list') { %>
<div class="data-list-wrap">
  <% if (!items || items.length === 0) { %>
    <p style="color:var(--slate);text-align:center;padding:60px 0;">No items to display yet.</p>
  <% } else { %>
    <div class="data-grid">
      <% items.forEach(function(item) { %>
        <%
          const isPost = pg.col === 'blog' || (!pg.col && item.slug);
          const href   = isPost ? '/blog/' + item.slug : '#';
          const img    = item.featuredImageUrl || item.imageUrl || '';
          const desc   = item.excerpt || item.description || '';
          const dateVal = item.publishedAt || item.createdAt;
        %>
        <a href="<%= href %>" class="data-card" <%= href === '#' ? 'onclick="return false"' : '' %>>
          <% if (img) { %>
            <img src="<%= img %>" alt="<%= item.title %>" class="data-card-img">
          <% } else { %>
            <div class="data-card-img-placeholder"></div>
          <% } %>
          <div class="data-card-body">
            <% if (dateVal) { %>
              <div class="data-card-date"><%= new Date(dateVal).toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'}) %></div>
            <% } %>
            <div class="data-card-title"><%= item.title %></div>
            <% if (desc) { %><div class="data-card-excerpt"><%= desc.slice(0, 120) %><%= desc.length > 120 ? '…' : '' %></div><% } %>
            <% if (isPost) { %><div class="data-card-cta">Read More →</div><% } %>
          </div>
        </a>
      <% }); %>
    </div>

    <% if (totalPages > 1) { %>
    <nav class="data-pagination" aria-label="Pagination">
      <a href="?p=<%= p - 1 %>" class="data-page-btn <%= p <= 1 ? 'disabled' : '' %>">← Prev</a>
      <% for (let i = 1; i <= totalPages; i++) { %>
        <a href="?p=<%= i %>" class="data-page-btn <%= i === p ? 'active' : '' %>"><%= i %></a>
      <% } %>
      <a href="?p=<%= p + 1 %>" class="data-page-btn <%= p >= totalPages ? 'disabled' : '' %>">Next →</a>
    </nav>
    <% } %>
  <% } %>
</div>

<!-- ── LANDING PAGE ───────────────────────────────────────────── -->
<% } else if (pg.pageType === 'landing') { %>
<div style="padding-top:72px;"><!-- nav offset -->

<% (pg.blocks || []).forEach(function(block) { %>
  <% const f = block.fields || {}; %>

  <% if (block.type === 'hero') { %>
  <section class="lb-hero">
    <div class="lb-hero-inner">
      <% if (f.heading) { %><h1 class="lb-heading" style="color:#fff;"><%- f.heading %></h1><% } %>
      <% if (f.subheading) { %><p class="lb-body" style="color:rgba(255,255,255,0.7);max-width:600px;margin:0 auto 8px;"><%- f.subheading %></p><% } %>
      <% if (f.cta_text && f.cta_link) { %><a href="<%= f.cta_link %>" class="lb-btn"><%- f.cta_text %></a><% } %>
    </div>
  </section>

  <% } else if (block.type === 'text') { %>
  <section class="lb-text">
    <div class="lb-text-inner">
      <% if (f.subheading) { %><div class="lb-eyebrow"><%- f.subheading %></div><% } %>
      <% if (f.heading) { %><h2 class="lb-heading" style="color:var(--dark);"><%- f.heading %></h2><% } %>
      <% if (f.body) { %><div class="lb-body"><%- f.body %></div><% } %>
    </div>
  </section>

  <% } else if (block.type === 'split') { %>
  <section class="lb-split">
    <div class="lb-split-inner">
      <div>
        <% if (f.heading) { %><h2 class="lb-heading" style="color:var(--dark);"><%- f.heading %></h2><% } %>
        <% if (f.body) { %><div class="lb-body"><%- f.body %></div><% } %>
        <% if (f.cta_text && f.cta_link) { %><a href="<%= f.cta_link %>" class="lb-btn" style="margin-top:24px;"><%- f.cta_text %></a><% } %>
      </div>
      <div>
        <% if (block.images && block.images.main_image) { %>
          <img src="<%= block.images.main_image %>" alt="" class="lb-split-img">
        <% } else { %>
          <div class="lb-split-img-ph"></div>
        <% } %>
      </div>
    </div>
  </section>

  <% } else if (block.type === 'cta') { %>
  <section class="lb-cta">
    <div class="lb-cta-inner">
      <% if (f.heading) { %><h2 class="lb-heading" style="color:#fff;"><%- f.heading %></h2><% } %>
      <% if (f.subtext) { %><div class="lb-body" style="color:rgba(255,255,255,0.7);"><%- f.subtext %></div><% } %>
      <% if (f.btn_text && f.btn_link) { %><a href="<%= f.btn_link %>" class="lb-btn"><%- f.btn_text %></a><% } %>
    </div>
  </section>

  <% } else if (block.type === 'cards') { %>
  <section class="lb-cards">
    <div class="lb-cards-inner">
      <% if (f.heading || f.subtext) { %>
        <div class="lb-cards-intro">
          <% if (f.heading) { %><h2 class="lb-heading" style="color:var(--dark);"><%- f.heading %></h2><% } %>
          <% if (f.subtext) { %><p class="lb-body"><%- f.subtext %></p><% } %>
        </div>
      <% } %>
      <div class="lb-cards-grid">
        <% [1,2,3,4].forEach(function(n) { %>
          <% if (f['card'+n+'_title'] || f['card'+n+'_body']) { %>
          <div class="lb-card">
            <% if (f['card'+n+'_title']) { %><div class="lb-card-title"><%- f['card'+n+'_title'] %></div><% } %>
            <% if (f['card'+n+'_body']) { %><div class="lb-card-body"><%- f['card'+n+'_body'] %></div><% } %>
          </div>
          <% } %>
        <% }); %>
      </div>
    </div>
  </section>

  <% } else if (block.type === 'faq') { %>
  <section class="lb-faq">
    <div class="lb-faq-inner">
      <% if (f.heading) { %><h2 class="lb-heading" style="color:var(--dark);"><%- f.heading %></h2><% } %>
      <div class="lb-faq-list">
        <% [1,2,3,4,5].forEach(function(n) { %>
          <% if (f['q'+n] && f['a'+n]) { %>
          <div class="lb-faq-item">
            <div class="lb-faq-q"><%- f['q'+n] %></div>
            <div class="lb-faq-a"><%- f['a'+n] %></div>
          </div>
          <% } %>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

<% }); %>
</div>
<% } %>

<footer>
  <div class="footer-brand"><%- brand?.name || '' %></div>
  <ul class="footer-links">
    <li><a href="/">Home</a></li>
    <li><a href="/#services">Services</a></li>
    <li><a href="/blog">Blog</a></li>
    <li><a href="/#contact">Contact</a></li>
  </ul>
</footer>

<script>
// FAQ accordion
document.querySelectorAll('.lb-faq-q').forEach(q => {
  q.addEventListener('click', () => q.closest('.lb-faq-item').classList.toggle('open'));
});

// Nav scroll + reveal
(function() {
  var nav = document.querySelector('nav');
  if (nav) window.addEventListener('scroll', function() { nav.classList.toggle('scrolled', window.scrollY > 60); });
  var els = document.querySelectorAll('.reveal');
  if (els.length && 'IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
    }, { threshold: 0.1 });
    els.forEach(function(el) { obs.observe(el); });
  } else { els.forEach(function(el) { el.classList.add('visible'); }); }
})();
</script>
</body>
</html>
