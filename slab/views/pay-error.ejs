<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Invoice Error — <%= brand?.name || 'Home' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: <%= design.color_primary %>;
      --primary-deep: <%= design.color_primary_deep %>;
      --accent: <%= design.color_accent %>;
      --bg: <%= design.color_bg %>;
      --slate: #6B7380;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'<%= design.font_body || 'Jost' %>',sans-serif; background:var(--bg); color:var(--primary-deep); min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px; }
    .card { background:#FDFCFA; max-width:480px; width:100%; border-radius:6px; overflow:hidden; box-shadow:0 2px 20px rgba(0,0,0,.07); text-align:center; }
    .card-header { background:var(--primary); padding:28px 32px; }
    .brand { font-family:'<%= design.font_heading || 'Cormorant Garamond' %>',serif; font-size:22px; color:#FDFCFA; font-weight:300; }
    .gold-bar { height:3px; background:var(--accent); }
    .card-body { padding:40px 32px; }
    .icon { font-size:48px; margin-bottom:16px; }
    h1 { font-family:'<%= design.font_heading || 'Cormorant Garamond' %>',serif; font-size:24px; font-weight:300; margin-bottom:12px; }
    p { font-size:14px; color:var(--slate); line-height:1.6; }
    .footer { background:var(--bg); padding:16px 32px; text-align:center; font-size:12px; color:var(--slate); }
  </style>
</head>
<body>
<div class="card">
  <div class="card-header"><div class="brand"><%- brand?.name || '' %></div></div>
  <div class="gold-bar"></div>
  <div class="card-body">
    <div class="icon">!</div>
    <h1>Unable to Process</h1>
    <p><%= message %></p>
  </div>
  <div class="footer"><%= brand?.name || '' %> &middot; <%= brand?.location || '' %></div>
</div>
</body>
</html>
