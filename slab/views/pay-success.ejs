<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Payment Received — <%= brand?.name || 'Home' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Jost',sans-serif; background:#F5F3EF; color:#0F1B30; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px; }
    .card { background:#FDFCFA; max-width:480px; width:100%; border-radius:6px; overflow:hidden; box-shadow:0 2px 20px rgba(0,0,0,.07); text-align:center; }
    .card-header { background:#1C2B4A; padding:28px 32px; }
    .brand { font-family:'Cormorant Garamond',serif; font-size:22px; color:#FDFCFA; font-weight:300; }
    .gold-bar { height:3px; background:#C9A848; }
    .card-body { padding:40px 32px; }
    .check { width:64px; height:64px; background:#15803D; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; }
    .check svg { width:32px; height:32px; }
    h1 { font-family:'Cormorant Garamond',serif; font-size:28px; font-weight:300; margin-bottom:8px; color:#0F1B30; }
    .amount { font-family:'Cormorant Garamond',serif; font-size:36px; color:#C9A848; margin:12px 0; }
    .invoice-num { font-size:13px; color:#6B7380; margin-bottom:16px; }
    p { font-size:14px; color:#6B7380; line-height:1.6; }
    .footer { background:#F5F3EF; padding:16px 32px; text-align:center; font-size:12px; color:#6B7380; }
  </style>
</head>
<body>
<div class="card">
  <div class="card-header"><div class="brand"><%- brand?.name || '' %></div></div>
  <div class="gold-bar"></div>
  <div class="card-body">
    <div class="check"><svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg></div>
    <h1>Payment Received</h1>
    <div class="invoice-num">Invoice <%= inv.invoiceNumber || '' %></div>
    <div class="amount">$<%= inv.amount.toFixed(2) %></div>
    <p>Thank you for your payment<%= cl?.name ? ', ' + cl.name : '' %>. A receipt has been sent to your email.</p>
  </div>
  <div class="footer"><%= brand?.name || '' %> &middot; <%= brand?.location || '' %></div>
</div>
</body>
</html>
