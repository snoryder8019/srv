<%
  /**
   * Shared font map + Google Fonts URL builder.
   * Expects `design` in scope with font_heading / font_body.
   * Sets: _hFont, _bFont, _fontsParam (for Google Fonts link)
   */
  const _FONT_MAP = {
    'Cormorant Garamond': 'Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400',
    'Playfair Display': 'Playfair+Display:ital,wght@0,400;0,600;1,400',
    'Lora': 'Lora:ital,wght@0,400;0,600;1,400',
    'Merriweather': 'Merriweather:ital,wght@0,300;0,400;0,700;1,300',
    'Libre Baskerville': 'Libre+Baskerville:ital,wght@0,400;0,700;1,400',
    'Jost': 'Jost:wght@300;400;500;600',
    'Inter': 'Inter:wght@300;400;500;600',
    'Poppins': 'Poppins:wght@300;400;500;600',
    'Raleway': 'Raleway:wght@300;400;500;600',
    'Nunito': 'Nunito:wght@300;400;500;600',
    'DM Sans': 'DM+Sans:wght@300;400;500;600',
  };
  const _hFont = design.font_heading || 'Cormorant Garamond';
  const _bFont = design.font_body || 'Jost';
  const _hFontUrl = _FONT_MAP[_hFont] || _FONT_MAP['Cormorant Garamond'];
  const _bFontUrl = _FONT_MAP[_bFont] || _FONT_MAP['Jost'];
  const _fontsParam = _hFont === _bFont ? _hFontUrl : _hFontUrl + '&family=' + _bFontUrl;
%>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=<%= _fontsParam %>&display=swap" rel="stylesheet">
