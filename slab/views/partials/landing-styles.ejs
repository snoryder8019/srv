<style>
  :root {
    --navy:       <%= design.color_primary %>;
    --navy-deep:  <%= design.color_primary_deep %>;
    --navy-mid:   <%= design.color_primary_mid %>;
    --gold:       <%= design.color_accent %>;
    --gold-light: <%= design.color_accent_light %>;
    --crimson:    <%= design.color_danger %>;
    --ivory:      <%= design.color_bg %>;
    --ivory-mid:  <%= design.color_border || 'color-mix(in srgb, ' + design.color_bg + ' 85%, gray)' %>;
    --dark:       <%= design._on_bg || design.color_dark %>;
    --white:      <%= design.color_white %>;
    --muted:      <%= design.color_muted || design._on_bg_muted || '#6B7380' %>;
    --success:    <%= design.color_success %>;
    --section-pad: 100px 52px;
    --font-heading: '<%= design.font_heading %>', serif;
    --font-body:    '<%= design.font_body %>', sans-serif;
    --on-ivory:       <%= design._on_bg || '#0F1B30' %>;
    --on-ivory-muted: <%= design._on_bg_muted || '#6B7380' %>;
    --on-navy:        <%= design._on_primary || '#FDFCFA' %>;
    --on-navy-deep:   <%= design._on_primary_deep || '#FDFCFA' %>;
    --on-navy-mid:    <%= design._on_primary_mid || '#FDFCFA' %>;
    --on-gold:        <%= design._on_accent || '#0F1B30' %>;
    --on-gold-light:  <%= design._on_accent_light || '#0F1B30' %>;
    --accent-2:     <%= design.color_accent_2 || design.color_accent %>;
    --accent-3:     <%= design.color_accent_3 || design.color_accent %>;
    --hero-overlay: <%= design.hero_overlay_color || design.color_primary_deep %>;
    --hero-overlay-alpha: <%= (design.hero_overlay_opacity || '55') / 100 %>;
    --gradient-angle: <%= design.gradient_angle || '135' %>deg;
    --card-radius:  <%= design.card_border_radius || '2' %>px;
    --hero-text-align:   <%= design.hero_text_align || 'left' %>;
    --hero-min-height:   <%= design.hero_height || '100vh' %>;
    --contact-bg:         <%= design.contact_bg || 'var(--navy-deep)' %>;
    --contact-heading:    <%= design.contact_heading_color || '#FFFFFF' %>;
    --contact-eyebrow:    <%= design.contact_eyebrow_color || 'var(--gold-light)' %>;
    --contact-text:       <%= design.contact_text_color || 'rgba(253,252,250,0.55)' %>;
    --contact-label:      <%= design.contact_label_color || 'var(--gold)' %>;
    --contact-value:      <%= design.contact_value_color || 'rgba(253,252,250,0.7)' %>;
    --contact-form-bg:    <%= design.contact_form_bg || 'var(--ivory)' %>;
    --contact-form-label: <%= design.contact_form_label_color || 'var(--on-ivory-muted)' %>;
    --contact-btn-bg:     <%= design.contact_btn_bg || 'var(--navy)' %>;
    --contact-btn-color:  <%= design.contact_btn_color || 'var(--on-navy)' %>;
    --ticker-bg:            <%= design.ticker_bg || 'var(--navy)' %>;
    --ticker-text:          <%= design.ticker_text_color || 'var(--gold-light)' %>;
    --ticker-dot:           <%= design.ticker_dot_color || 'var(--accent-2)' %>;
    --ticker-speed:         <%= design.ticker_speed || '22' %>s;
    --ticker-font-size:     <%= design.ticker_font_size || '0.72' %>rem;
    --ticker-padding:       <%= design.ticker_padding || '14' %>px;
    --ticker-letter-spacing:<%= design.ticker_letter_spacing || '0.2' %>em;
    --ticker-item-gap:      <%= design.ticker_item_gap || '32' %>px;
    --ticker-text-transform:<%= design.ticker_uppercase !== 'false' ? 'uppercase' : 'none' %>;
    --surface:          <%= design._surface || '#FFFFFF' %>;
    --on-surface:       <%= design._on_surface || '#0F1B30' %>;
    --on-surface-muted: <%= design._on_surface_muted || '#6B7380' %>;
    --border:           <%= design._border || '#CBD5E1' %>;
    --border-focus:     <%= design._border_focus || '#1C2B4A' %>;
    --placeholder:      <%= design._placeholder || '#9CA3AF' %>;
    --primary: var(--navy); --primary-deep: var(--navy-deep); --primary-mid: var(--navy-mid);
    --accent: var(--gold); --accent-light: var(--gold-light); --bg: var(--ivory);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--font-body), sans-serif; background: var(--surface); color: var(--on-surface); overflow-x: hidden; }

  .hero-right[style*="background-image"]::before { content: ''; position: absolute; inset: 0; background: var(--hero-overlay, var(--navy-deep)); opacity: var(--hero-overlay-alpha, 0.55); z-index: 0; }
  .hero-right[style*="background-image"] .hero-right-content { position: relative; z-index: 1; }
  .service-card, .portfolio-card, .review-card, .theme-card { border-radius: var(--card-radius, 2px); }
  body[data-gradient="true"] .services { background: linear-gradient(var(--gradient-angle, 135deg), var(--ivory) 0%, var(--bg) 100%); }
  body[data-gradient="true"] .advisor-section { background: linear-gradient(var(--gradient-angle, 135deg), var(--navy-deep) 0%, var(--navy) 60%, var(--navy-mid) 100%); }
  body[data-gradient="true"] #process { background: linear-gradient(var(--gradient-angle, 135deg), var(--navy) 0%, var(--navy-deep) 100%); }
  body[data-card-hover-accent="true"] .service-card:hover { border-top: 2px solid var(--gold); }
  body[data-hero-pattern="grid"] .hero-right::after, body[data-hero-pattern="diagonal"] .hero-right::after, body[data-hero-pattern="dots"] .hero-right::after { content: ''; position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  body[data-hero-pattern="grid"] .hero-right::after { background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,0.04) 39px, rgba(255,255,255,0.04) 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,0.04) 39px, rgba(255,255,255,0.04) 40px); }
  body[data-hero-pattern="diagonal"] .hero-right::after { background-image: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(255,255,255,0.03) 10px, rgba(255,255,255,0.03) 11px); }
  body[data-hero-pattern="dots"] .hero-right::after { background-image: radial-gradient(circle, rgba(255,255,255,0.12) 1px, transparent 1px); background-size: 24px 24px; }
  .marquee-dot { color: var(--accent-2, var(--gold)); }

  /* ── HERO ── */
  .hero { min-height: var(--hero-min-height, 100vh); display: grid; grid-template-columns: 1fr 1fr; overflow: hidden; }
  .hero-left { background: var(--ivory); display: flex; align-items: center; padding: 120px 64px 80px; }
  .hero-text { max-width: 500px; text-align: var(--hero-text-align, left); }
  .hero-eyebrow { display: inline-flex; align-items: center; gap: 12px; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: var(--navy); margin-bottom: 28px; }
  .hero-eyebrow::before { content: ''; display: block; width: 32px; height: 1px; background: var(--navy); }
  .hero-heading { font-family: var(--font-heading), serif; font-size: clamp(3rem, 5.5vw, 5rem); font-weight: 300; line-height: 1.08; color: var(--on-ivory); margin-bottom: 28px; }
  .hero-heading em { font-style: italic; color: var(--navy); }
  .hero-sub { font-size: 1rem; font-weight: 300; color: var(--on-ivory-muted); line-height: 1.85; margin-bottom: 44px; max-width: 400px; }
  .hero-btns { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-primary { background: var(--navy); color: var(--white); padding: 15px 36px; border-radius: 2px; text-decoration: none; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; transition: background 0.2s, transform 0.2s; display: inline-block; }
  .btn-primary:hover { background: var(--navy-deep); transform: translateY(-2px); }
  .btn-ghost { border: 1.5px solid var(--navy-mid); color: var(--navy); padding: 14px 36px; border-radius: 2px; text-decoration: none; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; transition: border-color 0.2s, color 0.2s, transform 0.2s; display: inline-block; }
  .btn-ghost:hover { border-color: var(--navy-deep); color: var(--navy-deep); transform: translateY(-2px); }
  .hero-right { background: var(--navy-deep); position: relative; display: flex; align-items: flex-end; overflow: hidden; }
  .hero-right::before { content: ''; position: absolute; top: 60px; right: 60px; width: 220px; height: 280px; border: 1px solid rgba(201,168,72,0.15); border-radius: 2px; }
  .hero-right::after { content: ''; position: absolute; top: 80px; right: 80px; width: 220px; height: 280px; border: 1px solid rgba(201,168,72,0.07); border-radius: 2px; }
  .hero-right-content { position: relative; z-index: 2; padding: 64px; width: 100%; color: var(--on-navy-deep); }
  .hero-name-large { font-family: var(--font-heading), serif; font-size: clamp(4rem, 7vw, 8rem); font-weight: 300; font-style: italic; color: rgba(201,168,72,0.12); line-height: 0.9; user-select: none; letter-spacing: -0.02em; }
  .hero-badge { display: inline-flex; align-items: center; gap: 12px; background: rgba(201,168,72,0.12); border: 1px solid rgba(201,168,72,0.3); border-radius: 2px; padding: 12px 20px; margin-top: 32px; }
  .hero-badge-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--gold); }
  .hero-badge-text { font-size: 0.75rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--on-navy-deep); }
  .hero-circle { position: absolute; top: -80px; left: -80px; width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(46,66,112,0.35) 0%, transparent 70%); }

  /* ── MARQUEE / TICKER ── */
  .marquee-bar { background: var(--ticker-bg); padding: var(--ticker-padding) 0; overflow: hidden; white-space: nowrap; }
  .marquee-track { display: inline-flex; gap: 0; animation: marqueeScroll var(--ticker-speed) linear infinite; }
  .marquee-bar[data-direction="right"] .marquee-track { animation-direction: reverse; }
  @keyframes marqueeScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  .marquee-item { display: inline-flex; align-items: center; gap: 20px; padding: 0 var(--ticker-item-gap); font-size: var(--ticker-font-size); font-weight: 600; letter-spacing: var(--ticker-letter-spacing); text-transform: var(--ticker-text-transform); color: var(--ticker-text); }
  .marquee-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--ticker-dot); flex-shrink: 0; }

  /* ── SERVICES ── */
  .services { padding: var(--section-pad); background: var(--surface); }
  .section-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 64px; flex-wrap: wrap; gap: 24px; max-width: 1100px; margin-left: auto; margin-right: auto; }
  .section-eyebrow { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: var(--navy); margin-bottom: 12px; }
  .section-heading { font-family: var(--font-heading), serif; font-size: clamp(2.4rem, 4vw, 3.6rem); font-weight: 300; color: var(--on-surface); line-height: 1.1; }
  .section-heading em { font-style: italic; color: var(--navy); }
  .section-sub { font-size: 0.92rem; font-weight: 300; color: var(--on-surface-muted); line-height: 1.8; max-width: 340px; text-align: right; }
  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; max-width: 1100px; margin: 0 auto; background: var(--border); }
  .service-card { background: var(--surface); padding: 52px 40px; position: relative; transition: background 0.3s; overflow: hidden; border-radius: var(--card-radius, 2px); }
  .service-card::after { content: ''; position: absolute; bottom: 0; left: 40px; right: 40px; height: 2px; background: var(--gold); transform: scaleX(0); transform-origin: left; transition: transform 0.4s ease; }
  .service-card:hover { background: var(--ivory); }
  .service-card:hover::after { transform: scaleX(1); }
  .service-num { font-family: var(--font-heading), serif; font-size: 4rem; font-weight: 300; color: var(--border); line-height: 1; margin-bottom: 24px; transition: color 0.3s; }
  .service-card:hover .service-num { color: var(--gold-light); }
  .service-title { font-family: var(--font-heading), serif; font-size: 1.9rem; font-weight: 400; color: var(--on-surface); line-height: 1.15; margin-bottom: 16px; }
  .service-desc { font-size: 0.88rem; font-weight: 300; color: var(--on-surface-muted); line-height: 1.85; }

  /* ── ABOUT ── */
  .advisor-section { display: grid; grid-template-columns: 1fr 1fr; min-height: 600px; }
  .advisor-left { background: var(--ivory); padding: 100px 64px; display: flex; align-items: center; }
  .advisor-text { max-width: 480px; }
  .advisor-quote { font-family: var(--font-heading), serif; font-size: clamp(1.6rem, 3vw, 2.4rem); font-style: italic; font-weight: 300; color: var(--on-ivory); line-height: 1.5; margin-bottom: 32px; position: relative; padding-left: 28px; }
  .advisor-quote::before { content: ''; position: absolute; left: 0; top: 8px; bottom: 8px; width: 3px; background: var(--gold); }
  .advisor-desc { font-size: 0.92rem; font-weight: 300; color: var(--on-ivory-muted); line-height: 1.9; margin-bottom: 36px; }
  .advisor-sig { font-family: var(--font-heading), serif; font-size: 1.8rem; font-style: italic; color: var(--navy); }
  .advisor-right { background: var(--on-surface); display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
  .advisor-right-inner { position: relative; z-index: 2; text-align: center; padding: 64px; width: 100%; }
  .advisor-initial { font-family: var(--font-heading), serif; font-size: 18rem; font-weight: 300; font-style: italic; color: color-mix(in srgb, var(--navy) 35%, transparent); line-height: 1; user-select: none; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); }
  .advisor-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; background: rgba(201,168,72,0.12); position: relative; z-index: 3; }
  .stat-box { background: var(--navy-deep); padding: 36px 32px; text-align: center; }
  .stat-num { font-family: var(--font-heading), serif; font-size: 3.2rem; font-weight: 300; color: var(--gold); line-height: 1; }
  .stat-label { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(253,252,250,0.55); margin-top: 8px; }

  /* ── PROCESS ── */
  .process { padding: var(--section-pad); background: var(--ivory); }
  .process-inner { max-width: 1100px; margin: 0 auto; }
  .process-list { margin-top: 64px; display: flex; flex-direction: column; border-top: 1px solid var(--border); }
  .process-item { display: grid; grid-template-columns: 80px 1fr auto; align-items: center; gap: 40px; padding: 36px 0; border-bottom: 1px solid var(--border); transition: background 0.2s; }
  .process-item:hover { background: color-mix(in srgb, var(--navy) 4%, transparent); margin: 0 -20px; padding: 36px 20px; }
  .process-num { font-family: var(--font-heading), serif; font-size: 2.4rem; font-weight: 300; color: var(--gold-light); line-height: 1; }
  .process-title { font-family: var(--font-heading), serif; font-size: 1.6rem; font-weight: 400; color: var(--on-surface); margin-bottom: 6px; }
  .process-desc { font-size: 0.86rem; font-weight: 300; color: var(--on-surface-muted); line-height: 1.7; }
  .process-arrow { font-size: 1.2rem; color: var(--gold); opacity: 0; transition: opacity 0.2s, transform 0.2s; transform: translateX(-8px); }
  .process-item:hover .process-arrow { opacity: 1; transform: translateX(0); }

  /* ── CONTACT ── */
  .contact { display: grid; grid-template-columns: 1fr 1fr; min-height: 700px; }
  .contact-left { background: var(--contact-bg); padding: 100px 64px; display: flex; flex-direction: column; justify-content: center; }
  .contact-left .section-eyebrow { color: var(--contact-eyebrow); }
  .contact-left .section-heading { color: var(--contact-heading); margin-bottom: 24px; }
  .contact-sub { font-size: 0.92rem; font-weight: 300; color: var(--contact-text); line-height: 1.9; margin-bottom: 52px; max-width: 380px; }
  .contact-detail { display: flex; flex-direction: column; gap: 20px; }
  .contact-detail-item { display: flex; align-items: flex-start; gap: 16px; }
  .detail-label { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--contact-label); min-width: 72px; padding-top: 2px; }
  .detail-value { font-size: 0.92rem; font-weight: 300; color: var(--contact-value); line-height: 1.6; }
  .contact-right { background: var(--contact-form-bg); padding: 100px 64px; display: flex; flex-direction: column; justify-content: center; }
  .contact-form { display: flex; flex-direction: column; gap: 20px; max-width: 440px; }
  .form-row { display: flex; gap: 20px; }
  .form-field { flex: 1; display: flex; flex-direction: column; gap: 8px; }
  .form-field label { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--contact-form-label); }
  .form-field input, .form-field textarea, .form-field select { background: var(--surface); border: 1px solid var(--border); border-radius: 2px; padding: 14px 16px; font-family: var(--font-body), sans-serif; font-size: 0.9rem; font-weight: 300; color: var(--on-surface); outline: none; transition: border-color 0.2s; -webkit-appearance: none; appearance: none; }
  .form-field input::placeholder, .form-field textarea::placeholder { color: var(--on-ivory-muted); opacity: 0.5; }
  .form-field input:focus, .form-field textarea:focus, .form-field select:focus { border-color: var(--navy); }
  .form-field textarea { resize: vertical; min-height: 110px; }
  .btn-submit { background: var(--contact-btn-bg); color: var(--contact-btn-color); border: none; padding: 16px 40px; border-radius: 2px; font-family: var(--font-body), sans-serif; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; cursor: pointer; transition: background 0.2s, transform 0.2s; align-self: flex-start; }
  .btn-submit:hover { background: var(--navy-deep); transform: translateY(-2px); }
  #form-msg { display: none; font-size: 0.85rem; color: var(--navy); }

  /* ── CUSTOM SECTIONS ── */
  .cs-wrap { padding: var(--section-pad); max-width: 1100px; margin: 0 auto; }
  .cs-eyebrow { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); margin-bottom: 14px; }
  .cs-heading { font-family: var(--font-heading); font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; color: var(--navy-deep); margin-bottom: 16px; }
  .cs-body { font-size: 1.05rem; line-height: 1.8; color: var(--on-surface-muted); }
  .cs-body p { margin-bottom: 1em; }
  .cs-text { background: var(--surface); }
  .cs-text .cs-wrap { max-width: 780px; }
  .cs-split { background: var(--ivory); }
  .cs-split .cs-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }
  .cs-split-img { width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: 4px; }
  .cs-split-img-placeholder { width: 100%; aspect-ratio: 4/3; background: var(--border); border-radius: 4px; }
  .cs-btn { display: inline-block; margin-top: 28px; padding: 14px 32px; background: var(--navy); color: var(--white); font-family: var(--font-body); font-size: 0.82rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; transition: background 0.2s; }
  .cs-btn:hover { background: var(--gold); color: var(--on-surface); }
  .cs-cta { background: var(--navy-deep); color: var(--white); text-align: center; }
  .cs-cta .cs-wrap { padding: 80px 52px; }
  .cs-cta .cs-heading { color: var(--white); }
  .cs-cta .cs-body { color: rgba(253,252,250,0.75); }
  .cs-cta-bg { position: relative; }
  .cs-cta-bg::before { content: ''; position: absolute; inset: 0; background: rgba(10,20,50,0.72); }
  .cs-cta-bg > * { position: relative; }
  .cs-cta .cs-btn { background: var(--gold); color: var(--on-surface); margin-top: 32px; }
  .cs-cards { background: var(--surface); }
  .cs-cards-intro { text-align: center; max-width: 640px; margin: 0 auto 52px; }
  .cs-cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 28px; }
  .cs-card { background: var(--ivory); padding: 36px 28px; }
  .cs-card-img { width: 100%; aspect-ratio: 3/2; object-fit: cover; margin-bottom: 20px; }
  .cs-card-title { font-family: var(--font-heading); font-size: 1.25rem; color: var(--navy-deep); margin-bottom: 10px; }
  .cs-card-body { font-size: 0.92rem; line-height: 1.7; color: var(--on-surface-muted); }
  .cs-faq { background: var(--ivory); }
  .cs-faq .cs-wrap { max-width: 780px; }
  .cs-faq-list { display: flex; flex-direction: column; gap: 4px; margin-top: 40px; }
  .cs-faq-item { border-bottom: 1px solid var(--border); }
  .cs-faq-q { display: flex; justify-content: space-between; align-items: center; padding: 20px 0; cursor: pointer; font-weight: 500; font-size: 1rem; color: var(--navy-deep); gap: 16px; }
  .cs-faq-q::after { content: '+'; font-size: 1.3rem; color: var(--gold); flex-shrink: 0; transition: transform 0.2s; }
  .cs-faq-item.open .cs-faq-q::after { transform: rotate(45deg); }
  .cs-faq-a { display: none; padding: 0 0 20px; color: var(--on-surface-muted); line-height: 1.8; font-size: 0.95rem; }
  .cs-faq-item.open .cs-faq-a { display: block; }

  /* ── FOOTER ── */
  footer { background: var(--on-surface); padding: 64px 52px 36px; }
  .footer-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 52px; flex-wrap: wrap; gap: 40px; max-width: 1100px; margin-left: auto; margin-right: auto; }
  .footer-brand-name { font-family: var(--font-heading), serif; font-size: 2.4rem; font-weight: 300; color: var(--white); line-height: 1.1; }
  .footer-brand-sub { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); margin-top: 6px; }
  .footer-logo { height: 56px; width: auto; object-fit: contain; }
  .footer-links { display: flex; gap: 36px; list-style: none; align-items: center; flex-wrap: wrap; }
