<% if (typeof maintenanceCooldown !== 'undefined' && maintenanceCooldown > 0) { %>
<div id="maintenance-banner" style="
  position:fixed; top:0; left:0; right:0; z-index:9999;
  background:#1a1a2e; color:#e0e0e0; font-family:sans-serif;
  padding:14px 52px; text-align:center; font-size:14px; line-height:1.5;
  box-shadow:0 2px 12px rgba(0,0,0,0.3); border-bottom:2px solid #e2b340;
">
  <strong style="color:#e2b340;">Server Update in Progress</strong>
  &mdash; The site was recently restarted for updates and maintenance.
  You may experience unusual behavior or lost work on open pages.
  <strong>Save your work frequently</strong> and avoid large tasks until this notice is gone.
  <span id="maintenance-timer" style="display:inline-block;margin-left:8px;color:#e2b340;font-weight:600;"></span>
  <button onclick="document.getElementById('maintenance-banner').remove()" style="
    background:none; border:1px solid #666; color:#ccc; margin-left:16px;
    padding:2px 10px; border-radius:4px; cursor:pointer; font-size:13px;
  " aria-label="Dismiss">&times;</button>
</div>
<div style="height:52px;"></div>
<script>
(function(){
  var left = <%= maintenanceCooldown %>;
  var el = document.getElementById('maintenance-timer');
  var banner = document.getElementById('maintenance-banner');
  function pad(n){ return n < 10 ? '0'+n : n; }
  function tick(){
    if(left <= 0){ banner.remove(); return; }
    var m = Math.floor(left/60), s = left%60;
    el.textContent = pad(m)+':'+pad(s);
    left--;
    setTimeout(tick, 1000);
  }
  tick();
})();
</script>
<% } %>
