<% if (typeof tenant !== 'undefined' && tenant?.isPreview) { %>
<div id="slab-preview-banner" style="
  position:fixed; top:0; left:0; right:0; z-index:9999;
  background:linear-gradient(90deg, #1C2B4A 0%, #2E4270 100%);
  color:#F5F3EF; font-family:'Inter',system-ui,sans-serif;
  padding:10px 20px; display:flex; align-items:center; justify-content:center; gap:16px;
  font-size:13px; box-shadow:0 2px 12px rgba(0,0,0,0.3);
">
  <span style="opacity:0.7;">This site is in <strong style="color:#c9a848;">preview mode</strong></span>
  <span style="opacity:0.4;">|</span>
  <a href="/admin" style="color:#c9a848; text-decoration:none; font-weight:600;">Open Admin</a>
  <span style="opacity:0.4;">|</span>
  <a href="/admin?golive=1" style="
    background:#c9a848; color:#0a0a0a; padding:5px 14px; border-radius:4px;
    font-weight:600; font-size:12px; text-decoration:none; letter-spacing:0.3px;
  ">Go Live — $50/mo</a>
  <button onclick="this.parentElement.style.display='none'" style="
    background:none; border:none; color:rgba(245,243,239,0.4); cursor:pointer;
    font-size:18px; padding:0 4px; margin-left:8px; line-height:1;
  ">&times;</button>
</div>
<style>#slab-preview-banner ~ * { margin-top: 0; } body { padding-top: 42px; }</style>
<% } %>
