<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Invoice <%= inv.invoiceNumber %> — <%= brand?.name || 'Home' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    :root { --navy:#1C2B4A; --gold:#C9A848; --ivory:#F5F3EF; --slate:#6B7380; --dark:#0F1B30; --white:#FDFCFA; --ivory-mid:#E6E1D6; }
    body { font-family:'Jost',sans-serif; background:var(--ivory); color:var(--dark); min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px; }
    .invoice-card { background:var(--white); max-width:640px; width:100%; border-radius:6px; overflow:hidden; box-shadow:0 2px 20px rgba(0,0,0,.07); }
    .inv-header { background:var(--navy); padding:28px 32px; display:flex; justify-content:space-between; align-items:center; }
    .inv-brand { font-family:'Cormorant Garamond',serif; font-size:22px; color:var(--white); font-weight:300; }
    .inv-label { font-size:11px; color:var(--gold); text-transform:uppercase; letter-spacing:2px; }
    .gold-bar { height:3px; background:var(--gold); }
    .inv-body { padding:32px; }
    .inv-meta { display:flex; gap:32px; flex-wrap:wrap; margin-bottom:24px; }
    .inv-meta-item { }
    .inv-meta-label { font-size:11px; color:var(--slate); text-transform:uppercase; letter-spacing:1.5px; margin-bottom:2px; }
    .inv-meta-value { font-size:15px; color:var(--dark); font-weight:500; }
    table { width:100%; border-collapse:collapse; margin-bottom:20px; }
    thead th { text-align:left; font-size:11px; color:var(--slate); text-transform:uppercase; letter-spacing:1px; padding:10px 12px; border-bottom:2px solid var(--ivory-mid); background:var(--ivory); }
    thead th:last-child, thead th:nth-child(3) { text-align:right; }
    thead th:nth-child(2) { text-align:center; }
    tbody td { padding:10px 12px; border-bottom:1px solid var(--ivory-mid); font-size:14px; }
    tbody td:last-child, tbody td:nth-child(3) { text-align:right; }
    tbody td:nth-child(2) { text-align:center; color:var(--slate); }
    .total-row { display:flex; justify-content:flex-end; margin-bottom:28px; }
    .total-box { background:var(--navy); border-radius:4px; padding:16px 24px; text-align:right; min-width:180px; }
    .total-label { font-size:11px; color:var(--gold); text-transform:uppercase; letter-spacing:1.5px; margin-bottom:4px; }
    .total-amount { font-family:'Cormorant Garamond',serif; font-size:32px; color:var(--white); }
    .pay-buttons { display:flex; gap:12px; flex-wrap:wrap; justify-content:center; margin-top:8px; }
    .pay-buttons form { flex:1; min-width:180px; }
    .btn-stripe { width:100%; padding:14px 24px; background:var(--gold); color:var(--navy); border:none; font-family:'Jost',sans-serif; font-size:15px; font-weight:600; border-radius:3px; cursor:pointer; letter-spacing:.5px; }
    .btn-stripe:hover { background:#b8972e; }
    .btn-paypal { width:100%; padding:14px 24px; background:#0070ba; color:#fff; border:none; font-family:'Jost',sans-serif; font-size:15px; font-weight:600; border-radius:3px; cursor:pointer; letter-spacing:.5px; }
    .btn-paypal:hover { background:#005c99; }
    .inv-notes { margin-top:24px; padding-top:16px; border-top:1px solid var(--ivory-mid); font-size:13px; color:var(--slate); line-height:1.6; }
    .inv-notes strong { color:var(--dark); }
    .inv-footer { background:var(--ivory); padding:16px 32px; text-align:center; font-size:12px; color:var(--slate); }
    .paid-badge { display:inline-block; background:#15803D; color:#fff; font-size:13px; font-weight:600; padding:8px 24px; border-radius:3px; letter-spacing:1px; text-transform:uppercase; margin:20px 0; }
    .cancelled-notice { background:#FEF3C7; border:1px solid #F59E0B; border-radius:4px; padding:12px 16px; font-size:13px; color:#92400E; margin-bottom:20px; text-align:center; }
    @media(max-width:480px) { .inv-body { padding:20px; } .inv-meta { gap:16px; } .pay-buttons { flex-direction:column; } }
  </style>
</head>
<body>
<div class="invoice-card">
  <div class="inv-header">
    <div class="inv-brand"><%- brand?.name || '' %></div>
    <div class="inv-label">Invoice</div>
  </div>
  <div class="gold-bar"></div>

  <div class="inv-body">
    <% if (typeof cancelled !== 'undefined' || (typeof req !== 'undefined' && req?.query?.cancelled)) { %>
    <% } %>

    <div class="inv-meta">
      <div class="inv-meta-item">
        <div class="inv-meta-label">Invoice #</div>
        <div class="inv-meta-value"><%= inv.invoiceNumber || '—' %></div>
      </div>
      <div class="inv-meta-item">
        <div class="inv-meta-label">Client</div>
        <div class="inv-meta-value"><%= cl?.name || '—' %></div>
      </div>
      <div class="inv-meta-item">
        <div class="inv-meta-label">Due Date</div>
        <div class="inv-meta-value"><%= inv.dueDate ? new Date(inv.dueDate).toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'}) : 'Upon receipt' %></div>
      </div>
    </div>

    <!-- Line items -->
    <table>
      <thead><tr><th>Description</th><th>Qty</th><th>Rate</th><th>Amount</th></tr></thead>
      <tbody>
        <% if (inv.lineItems?.length) { %>
          <% for (const li of inv.lineItems) { %>
          <tr>
            <td><%= li.description %></td>
            <td><%= li.quantity %></td>
            <td>$<%= parseFloat(li.unitPrice).toFixed(2) %></td>
            <td style="font-weight:500;">$<%= (li.quantity * li.unitPrice).toFixed(2) %></td>
          </tr>
          <% } %>
        <% } else { %>
          <tr>
            <td colspan="3"><%= inv.title %></td>
            <td style="font-weight:500;">$<%= inv.amount.toFixed(2) %></td>
          </tr>
        <% } %>
      </tbody>
    </table>

    <div class="total-row">
      <div class="total-box">
        <div class="total-label">Total Due</div>
        <div class="total-amount">$<%= inv.amount.toFixed(2) %></div>
      </div>
    </div>

    <% if (paid) { %>
      <div style="text-align:center;">
        <div class="paid-badge">Paid</div>
        <p style="font-size:13px;color:var(--slate);">This invoice has been paid. Thank you!</p>
      </div>
    <% } else { %>
      <div class="pay-buttons">
        <% if (stripeKey) { %>
        <form method="POST" action="/pay/<%= inv.paymentToken %>/stripe">
          <button type="submit" class="btn-stripe">Pay with Card</button>
        </form>
        <% } %>
        <% if (paypalId) { %>
        <form method="POST" action="/pay/<%= inv.paymentToken %>/paypal">
          <button type="submit" class="btn-paypal">Pay with PayPal</button>
        </form>
        <% } %>
        <% if (!stripeKey && !paypalId) { %>
          <p style="text-align:center;color:var(--slate);font-size:14px;">Online payment is not available yet. Please contact us to arrange payment.</p>
        <% } %>
      </div>
    <% } %>

    <% if (inv.notes) { %>
    <div class="inv-notes"><strong>Notes:</strong> <%= inv.notes %></div>
    <% } %>
  </div>

  <div class="inv-footer"><%= brand?.name || '' %> &middot; <%= brand?.location || '' %></div>
</div>
</body>
</html>
