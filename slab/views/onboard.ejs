<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Get Started — <%= brand?.name || 'Home' %></title>
  <%
    const _FM = { 'Cormorant Garamond':'Cormorant+Garamond:wght@300;400;600','Playfair Display':'Playfair+Display:wght@400;600;700','Lora':'Lora:wght@400;600;700','Merriweather':'Merriweather:wght@300;400;700','Libre Baskerville':'Libre+Baskerville:wght@400;700','Jost':'Jost:wght@300;400;500;600','Inter':'Inter:wght@300;400;500;600','Poppins':'Poppins:wght@300;400;500;600','Raleway':'Raleway:wght@300;400;500;600','Nunito':'Nunito:wght@300;400;500;600','DM Sans':'DM+Sans:wght@300;400;500;600' };
    const _hF = _FM[design.font_heading] || _FM['Cormorant Garamond'];
    const _bF = _FM[design.font_body] || _FM['Jost'];
    const _fp = _hF === _bF ? _hF : _hF + '&family=' + _bF;
  %>
  <link href="https://fonts.googleapis.com/css2?family=<%= _fp %>&display=swap" rel="stylesheet">
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior:smooth; }
  :root {
    --navy: <%= design.color_primary || '#1C2B4A' %>;
    --navy-deep: <%= design.color_primary_deep || '#0F1B30' %>;
    --gold: <%= design.color_accent || '#C9A848' %>;
    --gold-light: <%= design.color_accent_light || '#E8D08A' %>;
    --ivory: <%= design.color_bg || '#F5F3EF' %>;
    --ivory-mid: #E6E1D6;
    --slate: #6B7380;
    --dark: <%= design.color_primary_deep || '#0F1B30' %>;
    --white: #FDFCFA;
  }
  body { font-family: '<%= design.font_body || 'Jost' %>', sans-serif; background: var(--ivory); color: var(--on-surface); min-height: 100vh; }

  /* ── Header ── */
  .ob-header {
    background: var(--navy-deep); padding: 20px 32px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .ob-brand { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: var(--white); text-decoration: none; }
  .ob-brand-sub { font-size: 0.55rem; font-weight: 600; letter-spacing: .22em; text-transform: uppercase; color: var(--gold); margin-top: 2px; }
  .ob-back { font-size: 0.78rem; color: rgba(255,255,255,0.5); text-decoration: none; transition: color .2s; }
  .ob-back:hover { color: var(--gold); }

  /* ── Hero ── */
  .ob-hero {
    background: var(--navy); color: var(--white); text-align: center;
    padding: 48px 24px 40px;
  }
  .ob-hero h1 { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 400; margin-bottom: 8px; }
  .ob-hero h1 em { color: var(--gold); font-style: normal; }
  .ob-hero p { font-size: 0.92rem; color: rgba(255,255,255,0.65); max-width: 520px; margin: 0 auto; line-height: 1.6; }

  /* ── Form ── */
  .ob-wrap { max-width: 680px; margin: -24px auto 40px; padding: 0 20px; position: relative; z-index: 1; }
  .ob-card {
    background: var(--surface); border-radius: 6px; padding: 32px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  }
  .ob-card + .ob-card { margin-top: 16px; }
  .ob-card-title {
    font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 600;
    color: var(--navy); padding-bottom: 12px; margin-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .ob-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .ob-field { display: flex; flex-direction: column; gap: 4px; }
  .ob-field.span-2 { grid-column: span 2; }
  .ob-field label { font-size: 0.72rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--slate); }
  .ob-field label .req { color: var(--gold); }
  .ob-field input, .ob-field select, .ob-field textarea {
    padding: 10px 14px; border: 1px solid var(--border); border-radius: 4px;
    font-family: inherit; font-size: 0.88rem; color: var(--on-surface);
    transition: border-color .15s;
  }
  .ob-field input:focus, .ob-field select:focus, .ob-field textarea:focus { outline: none; border-color: var(--navy); }
  .ob-field textarea { resize: vertical; min-height: 80px; }
  .ob-hint { font-size: 0.72rem; color: var(--slate); margin-top: 2px; }

  /* ── Optional toggle ── */
  .ob-toggle-row {
    display: flex; align-items: center; gap: 10px; cursor: pointer;
    padding: 14px 0 4px; color: var(--gold); font-size: 0.82rem; font-weight: 500;
    user-select: none;
  }
  .ob-toggle-row:hover { color: var(--navy); }
  .ob-toggle-arrow { transition: transform .25s; display: inline-block; }
  .ob-toggle-arrow.open { transform: rotate(90deg); }
  .ob-optional { display: none; }
  .ob-optional.show { display: block; }

  /* ── Submit ── */
  .ob-submit {
    display: block; width: 100%; margin-top: 20px; padding: 14px;
    background: var(--gold); color: var(--navy-deep); border: none; border-radius: 4px;
    font-family: inherit; font-size: 0.88rem; font-weight: 600;
    letter-spacing: .06em; cursor: pointer; transition: background .2s;
  }
  .ob-submit:hover { background: var(--gold-light); }
  .ob-submit:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ── Alerts ── */
  .ob-alert { padding: 12px 16px; border-radius: 4px; font-size: 0.85rem; margin-bottom: 16px; }
  .ob-alert-error { background: #FEE2E2; color: #991B1B; }

  /* ── Footer ── */
  .ob-footer { text-align: center; padding: 24px; font-size: 0.75rem; color: var(--slate); }
  .ob-footer a { color: var(--gold); text-decoration: none; }

  @media (max-width: 600px) {
    .ob-hero h1 { font-size: 1.6rem; }
    .ob-hero { padding: 32px 20px 28px; }
    .ob-card { padding: 20px 16px; }
    .ob-grid { grid-template-columns: 1fr; }
    .ob-field.span-2 { grid-column: span 1; }
    .ob-wrap { margin-top: -16px; padding: 0 12px; }
  }
</style>
</head>
<body>
<%- include("partials/preview-banner") %>

<div class="ob-header">
  <div>
    <a href="/" class="ob-brand"><%- brand?.name || '' %></a>
    <div class="ob-brand-sub">Client Onboarding</div>
  </div>
  <a href="/" class="ob-back">← Back to site</a>
</div>

<div class="ob-hero">
  <h1>Let's <em>get started.</em></h1>
  <p>Tell us about your business and what you're looking for. We'll be in touch within one business day.</p>
</div>

<div class="ob-wrap">
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="ob-alert ob-alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="/onboard" id="onboard-form">
    <div class="ob-card">
      <div class="ob-card-title">Your Information</div>
      <div class="ob-grid">
        <div class="ob-field">
          <label>Full Name <span class="req">*</span></label>
          <input type="text" name="name" required placeholder="Jane Smith" value="<%= typeof formData !== 'undefined' ? (formData.name || '') : '' %>">
        </div>
        <div class="ob-field">
          <label>Company / Business</label>
          <input type="text" name="company" placeholder="Your Business LLC" value="<%= typeof formData !== 'undefined' ? (formData.company || '') : '' %>">
        </div>
        <div class="ob-field">
          <label>Email <span class="req">*</span></label>
          <input type="email" name="email" required placeholder="jane@business.com" value="<%= typeof formData !== 'undefined' ? (formData.email || '') : '' %>">
        </div>
        <div class="ob-field">
          <label>Phone</label>
          <input type="tel" name="phone" placeholder="(970) 555-1234" value="<%= typeof formData !== 'undefined' ? (formData.phone || '') : '' %>">
        </div>
        <div class="ob-field">
          <label>Website</label>
          <input type="url" name="website" placeholder="https://yourbusiness.com" value="<%= typeof formData !== 'undefined' ? (formData.website || '') : '' %>">
        </div>
        <div class="ob-field">
          <label>Location</label>
          <input type="text" name="address" placeholder="<%= brand?.location || '' %>" value="<%= typeof formData !== 'undefined' ? (formData.address || '') : '' %>">
        </div>
      </div>
    </div>

    <div class="ob-card">
      <div class="ob-card-title">What Are You Looking For?</div>
      <div class="ob-grid">
        <div class="ob-field">
          <label>Business Type</label>
          <input type="text" name="businessType" placeholder="Restaurant, Retail, Real Estate…" value="<%= typeof formData !== 'undefined' ? (formData.businessType || '') : '' %>">
        </div>
        <div class="ob-field">
          <label>Budget Range</label>
          <select name="budget">
            <option value="">Select…</option>
            <option value="under500">Under $500/mo</option>
            <option value="500-1000">$500 – $1,000/mo</option>
            <option value="1000-2500">$1,000 – $2,500/mo</option>
            <option value="2500+">$2,500+/mo</option>
          </select>
        </div>
        <div class="ob-field">
          <label>Timeline</label>
          <select name="timeline">
            <option value="">Select…</option>
            <option value="asap">ASAP</option>
            <option value="1month">Within 1 month</option>
            <option value="3months">1–3 months</option>
            <option value="flexible">Flexible</option>
          </select>
        </div>
        <div class="ob-field">
          <label>Social Platforms</label>
          <input type="text" name="socialPlatforms" placeholder="Instagram, Facebook, TikTok…" value="<%= typeof formData !== 'undefined' ? (formData.socialPlatforms || '') : '' %>">
        </div>
        <div class="ob-field span-2">
          <label>What are your main goals?</label>
          <textarea name="goals" rows="3" placeholder="More customers, better social presence, website redesign…"><%= typeof formData !== 'undefined' ? (formData.goals || '') : '' %></textarea>
        </div>
      </div>

      <!-- Optional extra fields -->
      <div class="ob-toggle-row" onclick="obToggle()">
        <span class="ob-toggle-arrow" id="ob-arrow">▸</span> Additional details (optional)
      </div>
      <div class="ob-optional" id="ob-optional">
        <div class="ob-grid" style="margin-top:12px;">
          <div class="ob-field span-2">
            <label>Current Website URL</label>
            <input type="url" name="currentWebsite" placeholder="https://current-site.com" value="<%= typeof formData !== 'undefined' ? (formData.currentWebsite || '') : '' %>">
          </div>
          <div class="ob-field span-2">
            <label>Brand Notes</label>
            <textarea name="brandNotes" rows="3" placeholder="Brand colors, style preferences, tone of voice, inspiration sites…"><%= typeof formData !== 'undefined' ? (formData.brandNotes || '') : '' %></textarea>
          </div>
          <div class="ob-field span-2">
            <label>Anything else we should know?</label>
            <textarea name="notes" rows="2" placeholder="Additional context, special requirements…"><%= typeof formData !== 'undefined' ? (formData.notes || '') : '' %></textarea>
          </div>
        </div>
      </div>
    </div>

    <button type="submit" class="ob-submit" id="ob-submit-btn">Submit & Get Started</button>
  </form>
</div>

<div class="ob-footer">
  &copy; <%= new Date().getFullYear() %> <a href="/"><%- brand?.name || '' %></a> &mdash; <%= brand?.location || '' %>
</div>

<script>
function obToggle() {
  const el = document.getElementById('ob-optional');
  const arrow = document.getElementById('ob-arrow');
  el.classList.toggle('show');
  arrow.classList.toggle('open');
}
document.getElementById('onboard-form').addEventListener('submit', function() {
  const btn = document.getElementById('ob-submit-btn');
  btn.disabled = true;
  btn.textContent = 'Submitting…';
});
</script>
</body>
</html>
