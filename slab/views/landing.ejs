<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%
    /* ── Safe variable access (works for platform landing & tenant startup layout) ── */
    const b  = typeof brand  !== 'undefined' && brand  ? brand  : {};
    const d  = typeof design !== 'undefined' && design ? design : {};
    const c  = typeof copy   !== 'undefined' && copy   ? copy   : {};
    const _vis = typeof visibility !== 'undefined' ? visibility : {};
    const _posts = typeof latestPosts !== 'undefined' ? latestPosts : [];
    const _portfolio = typeof portfolio !== 'undefined' ? portfolio : [];
    const _reviews = typeof reviews !== 'undefined' && reviews ? reviews : null;
    const _customSections = typeof customSections !== 'undefined' ? customSections : [];
    const lg = typeof logos  !== 'undefined' && logos  ? logos  : {};

    const siteName    = b.name     || '';
    const siteTagline = b.tagline  || '';

    /* ── Design tokens (from design panel) ── */
    const accent      = d.color_accent       || '#c9a848';
    const accentHover = d.color_accent_light  || '#d4b85c';
    const bgDark      = d.color_primary_deep  || '#0a0a0a';
    const cardBg      = d.color_primary_mid   || '#141414';
    const fontFamily  = d.font_body || 'Inter';

    /* ── Copy (from copy panel, matching existing keys) ── */
    const heroBadge   = c.hero_badge       || siteTagline;
    const heroHeading = c.hero_heading     || '';
    const heroEm      = c.hero_heading_em  || '';
    const heroSub     = c.hero_sub         || '';
    const heroCta     = c.hero_cta         || 'Get Started';

    const featLabel   = c.services_label   || '';
    const featHeading = c.services_heading || '';
    const features = [1,2,3,4,5,6].map(n => ({
      title: c['service'+n+'_title'] || '',
      desc:  c['service'+n+'_desc']  || c['service'+n+'_description'] || '',
      link:  c['service'+n+'_link']  || '',
    })).filter(f => f.title);

    const stepsLabel   = c.process_label      || '';
    const stepsHeading = c.process_heading    || '';
    const steps = [1,2,3,4].map(n => ({
      title: c['process'+n+'_title'] || '',
      desc:  c['process'+n+'_desc']  || c['process'+n+'_description'] || '',
    })).filter(s => s.title);

    const priceAmount  = c.startup_price_amount  || '';
    const priceUnit    = c.startup_price_unit    || '';
    const priceLabel   = c.startup_price_label   || '';
    const priceHeading = c.startup_price_heading || '';
    const priceDesc    = c.startup_price_desc    || '';
    const priceCta     = c.startup_price_cta     || heroCta;
    const priceNote    = c.startup_price_note    || '';
    const priceFeats   = c.startup_price_features ? c.startup_price_features.split(',') : [];

    const ctaHeading = c.contact_heading    || '';
    const ctaSub     = c.contact_subheading || c.contact_sub || '';
    const ctaBtn     = c.hero_cta           || 'Get Started';

    /* Logo display */
    const logoImg    = lg.logo_primary || lg.logo_white || null;
    const navDisplay = d.nav_logo_display || 'text';
    const showLogoImg  = logoImg && (navDisplay === 'image' || navDisplay === 'both');
    const showLogoText = (navDisplay === 'text' || navDisplay === 'both' || !logoImg);

    /* Logo color split — split position (0 = off, 1 = first char, 2 = first two, etc.) */
    const splitAt = parseInt(d.nav_logo_split) || 0;
    const logoPre  = splitAt > 0 ? siteName.slice(0, splitAt) : '';
    const logoPost = splitAt > 0 ? siteName.slice(splitAt)    : siteName;

    /* Google font URL */
    const _FM = {
      'Inter': 'Inter:wght@300;400;500;600;700;800',
      'Jost': 'Jost:wght@300;400;500;600;700;800',
      'Poppins': 'Poppins:wght@300;400;500;600;700;800',
      'Raleway': 'Raleway:wght@300;400;500;600;700;800',
      'Nunito': 'Nunito:wght@300;400;500;600;700;800',
      'DM Sans': 'DM+Sans:wght@300;400;500;600;700;800',
      'Cormorant Garamond': 'Cormorant+Garamond:wght@300;400;600;700',
      'Playfair Display': 'Playfair+Display:wght@400;600;700',
      'Lora': 'Lora:wght@400;600;700',
      'Merriweather': 'Merriweather:wght@300;400;700',
      'Libre Baskerville': 'Libre+Baskerville:wght@400;700',
    };
    const fontUrl = _FM[fontFamily] || _FM['Inter'];
  %>
  <title><%= siteName %><% if (heroBadge) { %> — <%= heroBadge %><% } %></title>
  <% if (heroSub) { %><meta name="description" content="<%= heroSub %>"><% } %>
  <link href="https://fonts.googleapis.com/css2?family=<%= fontUrl %>&display=swap" rel="stylesheet">
  <style>
    :root {
      --accent: <%= accent %>;
      --accent-hover: <%= accentHover %>;
      --bg: <%= bgDark %>;
      --card: <%= cardBg %>;
      --border: #262626;
      --muted: #737373;
      --light: #e5e5e5;
      --subtle: #a3a3a3;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body { font-family:'<%= fontFamily %>',sans-serif; background:var(--bg); color:var(--light); overflow-x:hidden; }
    a { color:var(--accent); text-decoration:none; }

    /* ── Scroll reveal ── */
    .reveal { opacity:0; transform:translateY(24px); transition:opacity 0.6s ease, transform 0.6s ease; }
    .reveal.visible { opacity:1; transform:translateY(0); }

    /* ── Nav ── */
    .nav { position:fixed; top:0; left:0; right:0; z-index:100; padding:16px 32px; display:flex; align-items:center; justify-content:space-between; background:rgba(10,10,10,0.85); backdrop-filter:blur(12px); border-bottom:1px solid transparent; transition:border-color 0.3s, box-shadow 0.3s; }
    .nav.scrolled { border-color:rgba(255,255,255,0.08); box-shadow:0 2px 20px rgba(0,0,0,0.4); }
    .nav-logo { font-size:28px; font-weight:600; color:#fff; display:flex; align-items:center; letter-spacing:-0.5px; }
    .nav-logo span { color:var(--accent); }
    .nav-logo-img { height:36px; width:auto; object-fit:contain; margin-right:10px; }
    .nav-links { display:flex; gap:28px; align-items:center; }
    .nav-links a { font-size:13px; color:var(--subtle); transition:color 0.2s; } .nav-links a:hover { color:#fff; }
    .nav-cta { background:var(--accent); color:#0a0a0a; padding:8px 20px; border-radius:6px; font-weight:600; font-size:13px; }
    .nav-cta:hover { background:var(--accent-hover); }

    /* ── Hero ── */
    .hero { min-height:100vh; display:flex; align-items:center; justify-content:center; text-align:center; padding:120px 24px 80px; position:relative; }
    .hero::before { content:''; position:absolute; top:0; left:50%; transform:translateX(-50%); width:600px; height:600px; background:radial-gradient(circle, rgba(201,168,72,0.08) 0%, transparent 70%); pointer-events:none; }
    .hero-content { max-width:720px; position:relative; }
    .hero-badge { display:inline-block; font-size:11px; text-transform:uppercase; letter-spacing:2px; color:var(--accent); background:rgba(201,168,72,0.1); border:1px solid rgba(201,168,72,0.2); padding:6px 16px; border-radius:20px; margin-bottom:24px; }
    .hero h1 { font-size:clamp(36px, 6vw, 64px); font-weight:800; line-height:1.1; letter-spacing:-1.5px; color:#fff; margin-bottom:20px; }
    .hero h1 em { font-style:normal; color:var(--accent); }
    .hero p { font-size:18px; color:var(--subtle); line-height:1.7; max-width:540px; margin:0 auto 36px; }
    .hero-actions { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; }
    .btn-lg { padding:16px 36px; border-radius:6px; font-family:'<%= fontFamily %>',sans-serif; font-size:15px; font-weight:600; border:none; cursor:pointer; transition:all 0.2s; text-decoration:none; display:inline-block; letter-spacing:0.3px; }
    .btn-primary { background:var(--accent); color:var(--bg); } .btn-primary:hover { background:var(--accent-hover); transform:translateY(-1px); }
    .btn-outline { background:transparent; color:#fff; border:1px solid #333; } .btn-outline:hover { border-color:var(--accent); }

    /* ── Features ── */
    .features { padding:80px 24px; }
    .features-inner { max-width:1000px; margin:0 auto; }
    .section-label { font-size:11px; text-transform:uppercase; letter-spacing:2px; color:var(--accent); text-align:center; margin-bottom:8px; }
    .section-title { font-size:32px; font-weight:700; text-align:center; color:#fff; margin-bottom:48px; letter-spacing:-0.5px; }
    .feature-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:20px; }
    .feature-card { background:var(--card); border:1px solid var(--border); border-radius:10px; padding:28px; transition:border-color 0.3s; }
    .feature-card:hover { border-color:var(--accent); }
    .feature-card h3 { font-size:16px; font-weight:600; margin-bottom:8px; color:#fff; }
    .feature-card p { font-size:13px; color:var(--subtle); line-height:1.6; }
    .feature-dot { width:8px; height:8px; border-radius:50%; background:var(--accent); margin-bottom:14px; }

    /* ── How it works ── */
    .how { padding:80px 24px; background:var(--card); border-top:1px solid var(--border); border-bottom:1px solid var(--border); }
    .how-inner { max-width:800px; margin:0 auto; }
    .steps { display:grid; gap:32px; margin-top:48px; }
    .step { display:flex; gap:20px; align-items:flex-start; }
    .step-num { width:40px; height:40px; border-radius:50%; background:rgba(201,168,72,0.1); border:1px solid rgba(201,168,72,0.3); display:flex; align-items:center; justify-content:center; font-size:16px; font-weight:700; color:var(--accent); flex-shrink:0; }
    .step-text h3 { font-size:16px; font-weight:600; color:#fff; margin-bottom:4px; }
    .step-text p { font-size:13px; color:var(--subtle); line-height:1.6; }

    /* ── Pricing ── */
    .pricing { padding:80px 24px; }
    .pricing-inner { max-width:500px; margin:0 auto; text-align:center; }
    .price-card { background:var(--card); border:1px solid var(--border); border-radius:12px; padding:40px; margin-top:40px; }
    .price-amount { font-size:56px; font-weight:800; color:#fff; line-height:1; }
    .price-amount span { font-size:18px; font-weight:400; color:var(--muted); }
    .price-desc { font-size:14px; color:var(--subtle); margin:12px 0 24px; }
    .price-features { list-style:none; text-align:left; margin-bottom:28px; }
    .price-features li { font-size:13px; color:#d4d4d4; padding:8px 0; border-bottom:1px solid #1f1f1f; display:flex; align-items:center; gap:10px; }
    .price-features li::before { content:''; width:6px; height:6px; border-radius:50%; background:var(--accent); flex-shrink:0; }
    .free-note { font-size:12px; color:var(--muted); margin-top:12px; }

    /* ── CTA ── */
    .cta { padding:80px 24px; text-align:center; }
    .cta h2 { font-size:32px; font-weight:700; color:#fff; margin-bottom:12px; }
    .cta p { font-size:16px; color:var(--subtle); margin-bottom:28px; }

    /* ── Footer ── */
    .footer { padding:32px 24px; border-top:1px solid var(--border); text-align:center; font-size:12px; color:#525252; }

    @media (max-width:640px) {
      .nav { padding:12px 16px; }
      .nav-links a:not(.nav-cta) { display:none; }
      .hero { padding:100px 16px 60px; }
      .feature-grid { grid-template-columns:1fr; }
    }
  </style>
</head>
<body>

<nav class="nav">
  <div class="nav-logo">
    <% if (d.model_logo_enabled === 'true') { %>
      <div class="gltf-viewer" <%= (typeof brandModels !== 'undefined' && brandModels.model_logo) ? 'data-model-url="' + brandModels.model_logo + '"' : '' %> data-brand-name="<%= siteName %>" data-mode="logo" data-bg-color="transparent" data-accent-color="<%= accent %>" data-primary-color="<%= d.color_primary || '' %>" style="width:40px;height:40px;display:inline-block;vertical-align:middle;margin-right:8px;"></div>
    <% } else if (showLogoImg) { %><img src="<%= logoImg %>" alt="<%= siteName %>" class="nav-logo-img"><% } %>
    <% if (showLogoText) { %><% if (logoPre) { %><span><%= logoPre %></span><% } %><%= logoPost %><% } %>
  </div>
  <div class="nav-links">
    <% if (features.length) { %><a href="#features">Services</a><% } %>
    <% if (steps.length) { %><a href="#how">How It Works</a><% } %>
    <% if (_vis.portfolio && _portfolio.length) { %><a href="#portfolio">Work</a><% } %>
    <% if (_vis.about && (c.about_quote || c.about_desc)) { %><a href="#about">About</a><% } %>
    <% if (_vis.blog && _posts.length) { %><a href="#blog">Blog</a><% } %>
    <% if (_vis.contact) { %><a href="#contact" class="nav-cta">Contact</a>
    <% } else { %><a href="/start" class="nav-cta"><%= heroCta %></a><% } %>
  </div>
</nav>

<section class="hero" style="position:relative;">
  <% if (d.model_header_enabled === 'true') { %>
    <div class="gltf-viewer" <%= (typeof brandModels !== 'undefined' && brandModels.model_header) ? 'data-model-url="' + brandModels.model_header + '"' : '' %> data-brand-name="<%= siteName %>" data-mode="header" data-bg-color="<%= bgDark %>" data-accent-color="<%= accent %>" data-primary-color="<%= d.color_primary || '' %>" <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>data-debug="true"<% } %> style="position:absolute;inset:0;width:100%;height:100%;z-index:0;"></div>
  <% } %>
  <div class="hero-content" style="position:relative;z-index:1;">
    <% if (heroBadge) { %><div class="hero-badge"><%= heroBadge %></div><% } %>
    <% if (heroHeading) { %><h1><%= heroHeading %> <% if (heroEm) { %><em><%= heroEm %></em><% } %></h1><% } %>
    <% if (heroSub) { %><p><%= heroSub %></p><% } %>
    <div class="hero-actions">
      <a href="/start" class="btn-lg btn-primary"><%= heroCta %></a>
      <% if (steps.length) { %><a href="#how" class="btn-lg btn-outline">See How It Works</a><% } %>
    </div>
  </div>
</section>

<% if (features.length) { %>
<section class="features" id="features">
  <div class="features-inner">
    <% if (featLabel) { %><div class="section-label"><%= featLabel %></div><% } %>
    <% if (featHeading) { %><div class="section-title"><%= featHeading %></div><% } %>
    <div class="feature-grid">
      <% features.forEach(f => { %>
      <% if (f.link) { %>
      <a href="<%= f.link %>" class="feature-card" style="text-decoration:none;color:inherit;display:block;">
      <% } else { %>
      <div class="feature-card reveal">
      <% } %>
        <div class="feature-dot"></div>
        <h3><%= f.title %></h3>
        <% if (f.desc) { %><p><%= f.desc %></p><% } %>
      <% if (f.link) { %></a><% } else { %></div><% } %>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<% if (steps.length) { %>
<section class="how" id="how">
  <div class="how-inner">
    <% if (stepsLabel) { %><div class="section-label"><%= stepsLabel %></div><% } %>
    <% if (stepsHeading) { %><div class="section-title"><%= stepsHeading %></div><% } %>
    <div class="steps">
      <% steps.forEach((s, i) => { %>
      <div class="step reveal">
        <div class="step-num"><%= i + 1 %></div>
        <div class="step-text">
          <h3><%= s.title %></h3>
          <% if (s.desc) { %><p><%= s.desc %></p><% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<% if (priceAmount) { %>
<section class="pricing" id="pricing">
  <div class="pricing-inner">
    <% if (priceLabel) { %><div class="section-label"><%= priceLabel %></div><% } %>
    <% if (priceHeading) { %><div class="section-title"><%= priceHeading %></div><% } %>
    <div class="price-card">
      <div class="price-amount"><%= priceAmount %><span><%= priceUnit %></span></div>
      <% if (priceDesc) { %><p class="price-desc"><%= priceDesc %></p><% } %>
      <% if (priceFeats.length) { %>
      <ul class="price-features">
        <% priceFeats.forEach(f => { %>
        <li><%= f.trim() %></li>
        <% }) %>
      </ul>
      <% } %>
      <a href="/start" class="btn-lg btn-primary" style="width:100%;text-align:center;"><%= priceCta %></a>
      <% if (priceNote) { %><p class="free-note"><%= priceNote %></p><% } %>
    </div>
  </div>
</section>
<% } %>

<!-- PORTFOLIO -->
<% if (_vis.portfolio && _portfolio.length) { %>
<section id="portfolio" style="padding:80px 24px;">
  <div style="max-width:1000px;margin:0 auto;">
    <div class="section-label">Our Work</div>
    <div class="section-title">Portfolio</div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px;">
      <% _portfolio.forEach(p => { %>
      <div style="background:var(--card);border:1px solid var(--border);border-radius:10px;overflow:hidden;transition:border-color 0.3s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
        <% if (p.imageUrl) { %><img src="<%= p.imageUrl %>" alt="<%= p.title %>" style="width:100%;height:200px;object-fit:cover;display:block;"><% } %>
        <div style="padding:24px;">
          <% if (p.category) { %><div style="font-size:11px;color:var(--accent);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;"><%= p.category %></div><% } %>
          <h3 style="font-size:16px;font-weight:600;color:#fff;margin-bottom:6px;"><%= p.title %></h3>
          <% if (p.description) { %><p style="font-size:13px;color:var(--subtle);line-height:1.6;"><%= p.description.substring(0,120) %><%= p.description.length > 120 ? '…' : '' %></p><% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- ABOUT -->
<% if (_vis.about && (c.about_quote || c.about_desc)) { %>
<section id="about" style="padding:80px 24px;background:var(--card);border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
  <div style="max-width:720px;margin:0 auto;text-align:center;">
    <div class="section-label">About</div>
    <% if (c.about_quote) { %><blockquote style="font-size:22px;font-weight:300;font-style:italic;color:#fff;line-height:1.6;margin:24px 0;border:none;padding:0;">"<%= c.about_quote %>"</blockquote><% } %>
    <% if (c.about_desc) { %><p style="font-size:14px;color:var(--subtle);line-height:1.8;margin-bottom:16px;"><%= c.about_desc %></p><% } %>
    <% if (c.about_sig) { %><p style="font-size:13px;font-weight:600;color:var(--accent);letter-spacing:0.5px;">— <%= c.about_sig %></p><% } %>
  </div>
</section>
<% } %>

<!-- REVIEWS -->
<% if (_vis.reviews && _reviews && _reviews.reviews && _reviews.reviews.length) { %>
<section id="reviews" style="padding:80px 24px;">
  <div style="max-width:1000px;margin:0 auto;">
    <div class="section-label">Reviews</div>
    <div class="section-title"><%= _reviews.rating ? _reviews.rating + ' ★' : 'What People Say' %></div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px;">
      <% _reviews.reviews.slice(0,6).forEach(rv => { %>
      <div style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:24px;">
        <div style="color:var(--accent);font-size:14px;margin-bottom:10px;"><%= '★'.repeat(rv.rating || 5) %></div>
        <p style="font-size:13px;color:var(--subtle);line-height:1.6;margin-bottom:12px;"><%= rv.text ? rv.text.substring(0,180) : '' %><%= rv.text && rv.text.length > 180 ? '…' : '' %></p>
        <div style="font-size:12px;font-weight:600;color:#fff;"><%= rv.author_name || 'Anonymous' %></div>
      </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- CUSTOM SECTIONS -->
<% _customSections.forEach(sec => { %>
<section style="padding:80px 24px;<%= sec.type === 'cta' ? 'text-align:center;' : '' %>">
  <div style="max-width:1000px;margin:0 auto;">
    <% if (sec.fields?.heading) { %><div class="section-title"><%= sec.fields.heading %></div><% } %>
    <% if (sec.type === 'text') { %>
      <% if (sec.fields?.subheading) { %><p style="font-size:14px;color:var(--subtle);text-align:center;margin-bottom:24px;"><%= sec.fields.subheading %></p><% } %>
      <% if (sec.fields?.body) { %><div style="font-size:14px;color:var(--light);line-height:1.8;max-width:720px;margin:0 auto;"><%- sec.fields.body %></div><% } %>
    <% } else if (sec.type === 'split') { %>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;">
        <div>
          <% if (sec.fields?.body) { %><p style="font-size:14px;color:var(--subtle);line-height:1.8;"><%- sec.fields.body %></p><% } %>
          <% if (sec.fields?.cta_text && sec.fields?.cta_link) { %><a href="<%= sec.fields.cta_link %>" class="btn-lg btn-primary" style="margin-top:20px;display:inline-block;"><%= sec.fields.cta_text %></a><% } %>
        </div>
        <% if (sec.images?.split_image) { %><img src="<%= sec.images.split_image %>" alt="" style="width:100%;border-radius:10px;"><% } %>
      </div>
    <% } else if (sec.type === 'cta') { %>
      <% if (sec.fields?.subtext) { %><p style="font-size:16px;color:var(--subtle);margin-bottom:24px;"><%= sec.fields.subtext %></p><% } %>
      <% if (sec.fields?.btn_text && sec.fields?.btn_link) { %><a href="<%= sec.fields.btn_link %>" class="btn-lg btn-primary"><%= sec.fields.btn_text %></a><% } %>
    <% } else if (sec.type === 'cards') { %>
      <% if (sec.fields?.subtext) { %><p style="font-size:14px;color:var(--subtle);text-align:center;margin-bottom:32px;"><%= sec.fields.subtext %></p><% } %>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:20px;">
        <% [1,2,3,4].forEach(n => { if (sec.fields?.['card'+n+'_title']) { %>
        <div style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:24px;">
          <h3 style="font-size:15px;font-weight:600;color:#fff;margin-bottom:8px;"><%= sec.fields['card'+n+'_title'] %></h3>
          <% if (sec.fields['card'+n+'_body']) { %><p style="font-size:13px;color:var(--subtle);line-height:1.6;"><%= sec.fields['card'+n+'_body'] %></p><% } %>
        </div>
        <% } }) %>
      </div>
    <% } else if (sec.type === 'faq') { %>
      <div style="max-width:720px;margin:0 auto;">
        <% [1,2,3,4,5].forEach(n => { if (sec.fields?.['q'+n]) { %>
        <details style="border-bottom:1px solid var(--border);padding:16px 0;">
          <summary style="font-size:15px;font-weight:600;color:#fff;cursor:pointer;"><%= sec.fields['q'+n] %></summary>
          <p style="font-size:13px;color:var(--subtle);line-height:1.7;margin-top:10px;padding-left:4px;"><%= sec.fields['a'+n] || '' %></p>
        </details>
        <% } }) %>
      </div>
    <% } %>
  </div>
</section>
<% }) %>
<% if (_vis.blog && _posts.length) { %>
<section id="blog" style="padding:80px 24px;">
  <div style="max-width:1000px;margin:0 auto;">
    <div class="section-label">From The Blog</div>
    <div class="section-title">Latest Insights</div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px;">
      <% _posts.forEach(bp => { %>
      <a href="/blog/<%= bp.slug %>" style="background:var(--card);border:1px solid var(--border);border-radius:10px;overflow:hidden;transition:border-color 0.3s;text-decoration:none;display:block;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
        <% if (bp.featuredImageUrl) { %>
          <img src="<%= bp.featuredImageUrl %>" alt="<%= bp.title %>" style="width:100%;height:180px;object-fit:cover;display:block;">
        <% } %>
        <div style="padding:24px;">
          <div style="font-size:12px;color:var(--accent);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;"><%= bp.category || 'Blog' %></div>
          <h3 style="font-size:16px;font-weight:600;color:#fff;margin-bottom:8px;line-height:1.4;"><%= bp.title %></h3>
          <% if (bp.excerpt) { %><p style="font-size:13px;color:var(--subtle);line-height:1.6;"><%= bp.excerpt.substring(0,120) %><%= bp.excerpt.length > 120 ? '…' : '' %></p><% } %>
        </div>
      </a>
      <% }) %>
    </div>
    <div style="text-align:center;margin-top:32px;">
      <a href="/blog" style="font-size:13px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--accent);border-bottom:1px solid var(--accent);padding-bottom:2px;">View All Posts</a>
    </div>
  </div>
</section>
<% } %>

<% if (ctaHeading) { %>
<section class="cta">
  <h2><%= ctaHeading %></h2>
  <% if (ctaSub) { %><p><%= ctaSub %></p><% } %>
  <a href="/start" class="btn-lg btn-primary"><%= ctaBtn %></a>
</section>
<% } %>

<!-- CONTACT -->
<% if (_vis.contact) { %>
<section id="contact" style="padding:80px 24px;background:var(--card);border-top:1px solid var(--border);">
  <div style="max-width:600px;margin:0 auto;text-align:center;">
    <div class="section-label"><%= c.contact_eyebrow || 'Get In Touch' %></div>
    <div class="section-title"><%= c.contact_heading || "Let's Work" %> <em style="font-style:italic;color:var(--accent);"><%= c.contact_heading_em || 'Together' %></em></div>
    <% if (c.contact_sub) { %><p style="font-size:14px;color:var(--subtle);margin-bottom:32px;line-height:1.7;"><%= c.contact_sub %></p><% } %>
    <% if (typeof contacted !== 'undefined' && contacted) { %>
      <div style="padding:20px;background:rgba(76,175,80,0.15);border:1px solid rgba(76,175,80,0.4);border-radius:8px;color:#4caf50;font-size:14px;margin-bottom:16px;">
        ✓ Message received! We'll be in touch within 1 business day.
      </div>
    <% } %>
    <form method="POST" action="/contact" style="text-align:left;display:grid;gap:16px;">
      <input type="text" name="name" placeholder="Your Name" required style="padding:14px 16px;background:var(--bg);border:1px solid var(--border);border-radius:6px;color:#fff;font-family:inherit;font-size:14px;outline:none;" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'">
      <input type="email" name="email" placeholder="Email Address" required style="padding:14px 16px;background:var(--bg);border:1px solid var(--border);border-radius:6px;color:#fff;font-family:inherit;font-size:14px;outline:none;" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'">
      <textarea name="message" rows="4" placeholder="Tell us about your project…" required style="padding:14px 16px;background:var(--bg);border:1px solid var(--border);border-radius:6px;color:#fff;font-family:inherit;font-size:14px;outline:none;resize:vertical;" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'"></textarea>
      <button type="submit" class="btn-lg btn-primary" style="border:none;cursor:pointer;width:100%;text-align:center;">Send Message</button>
    </form>
    <% if (c.contact_location || c.contact_serving) { %>
    <div style="margin-top:24px;font-size:12px;color:var(--muted);">
      <% if (c.contact_location) { %><span><%= c.contact_location %></span><% } %>
      <% if (c.contact_location && c.contact_serving) { %> · <% } %>
      <% if (c.contact_serving) { %><span>Serving <%= c.contact_serving %></span><% } %>
    </div>
    <% } %>
  </div>
</section>
<% } %>

<footer class="footer">
  &copy; <%= new Date().getFullYear() %> <% if (logoPre) { %><span style="color:var(--accent)"><%= logoPre %></span><% } %><%= logoPost %>
</footer>

<% if (d.model_header_enabled === 'true' || d.model_logo_enabled === 'true') { %>
<script src="/js/gltfViewer.js"></script>
<% } %>
<script>
(function() {
  // Nav scroll effect
  var nav = document.querySelector('.nav');
  if (nav) {
    window.addEventListener('scroll', function() {
      nav.classList.toggle('scrolled', window.scrollY > 60);
    });
  }

  // IntersectionObserver reveal
  var els = document.querySelectorAll('.reveal');
  if (els.length && 'IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.1 });
    els.forEach(function(el) { obs.observe(el); });
  } else {
    els.forEach(function(el) { el.classList.add('visible'); });
  }

  // FAQ accordion
  document.querySelectorAll('details summary').forEach(function(s) {
    s.style.cursor = 'pointer';
  });
})();
</script>
</body>
</html>
