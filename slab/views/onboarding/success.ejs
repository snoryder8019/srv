<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>You're Live — Slab</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#0a0a0a; color:#e5e5e5; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px; }
    .card { background:#141414; max-width:520px; width:100%; border-radius:12px; overflow:hidden; border:1px solid #262626; text-align:center; padding:48px 32px; }
    .check { width:64px; height:64px; border-radius:50%; background:#16a34a; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; }
    .check svg { width:32px; height:32px; }
    h1 { font-size:24px; font-weight:600; margin-bottom:8px; }
    .sub { font-size:14px; color:#737373; margin-bottom:28px; }
    .site-url { background:#1a1a1a; border:1px solid #333; border-radius:8px; padding:16px; margin-bottom:24px; }
    .site-url a { color:#c9a848; font-size:16px; font-weight:500; text-decoration:none; }
    .site-url a:hover { text-decoration:underline; }
    .site-url p { font-size:12px; color:#737373; margin-top:6px; }
    .actions { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; }
    .btn { padding:12px 24px; border-radius:6px; font-family:'Inter',sans-serif; font-size:14px; font-weight:500; text-decoration:none; cursor:pointer; border:none; transition:background 0.2s; }
    .btn-primary { background:#c9a848; color:#0a0a0a; }
    .btn-primary:hover { background:#d4b85c; }
    .btn-ghost { background:transparent; border:1px solid #333; color:#a3a3a3; }
    .btn-ghost:hover { border-color:#c9a848; color:#c9a848; }
    .note { margin-top:24px; font-size:12px; color:#525252; line-height:1.6; }
  </style>
</head>
<body>
  <div class="card">
    <div class="check">
      <svg fill="none" viewBox="0 0 24 24" stroke="#fff" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
    </div>
    <h1>You're live!</h1>
    <p class="sub">Your site is being set up. It'll be ready in about 30 seconds.</p>

    <% if (tenant) { %>
    <div class="site-url">
      <a href="https://<%= tenant.domain %>" target="_blank"><%= tenant.domain %></a>
      <p>Your site is live at this address</p>
    </div>
    <div class="actions">
      <a href="https://<%= tenant.domain %>/admin" class="btn btn-primary">Open Admin Panel</a>
      <a href="https://<%= tenant.domain %>" class="btn btn-ghost">View Site</a>
    </div>
    <% } else { %>
    <div class="site-url">
      <p>Setting things up... check your email for your site link.</p>
    </div>
    <% } %>

    <p class="note">
      Sign in to your admin panel with the email you signed up with.
      You can add a custom domain anytime from the admin settings.
    </p>
  </div>
</body>
</html>
