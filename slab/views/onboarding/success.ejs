<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Site Created — sLab</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#0a0a0a; color:#e5e5e5; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px; }
    .card { background:#141414; max-width:520px; width:100%; border-radius:12px; overflow:hidden; border:1px solid #262626; text-align:center; padding:48px 32px; }
    .check { width:64px; height:64px; border-radius:50%; background:#16a34a; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; }
    .check svg { width:32px; height:32px; }
    h1 { font-size:24px; font-weight:600; margin-bottom:8px; }
    .sub { font-size:14px; color:#737373; margin-bottom:28px; line-height:1.6; }
    .site-url { background:#1a1a1a; border:1px solid #333; border-radius:8px; padding:16px; margin-bottom:24px; }
    .site-url a { color:#c9a848; font-size:16px; font-weight:500; text-decoration:none; }
    .site-url a:hover { text-decoration:underline; }
    .site-url p { font-size:12px; color:#737373; margin-top:6px; }
    .actions { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; }
    .btn { padding:12px 24px; border-radius:6px; font-family:'Inter',sans-serif; font-size:14px; font-weight:500; text-decoration:none; cursor:pointer; border:none; transition:background 0.2s; display:inline-block; }
    .btn-primary { background:#c9a848; color:#0a0a0a; }
    .btn-primary:hover { background:#d4b85c; }
    .btn-ghost { background:transparent; border:1px solid #333; color:#a3a3a3; }
    .btn-ghost:hover { border-color:#c9a848; color:#c9a848; }
    .note { margin-top:24px; font-size:12px; color:#525252; line-height:1.6; }
    .login-box { background:#1a1a1a; border:1px solid #262626; border-radius:8px; padding:16px; margin:20px 0; text-align:left; }
    .login-box-label { font-size:11px; color:#525252; text-transform:uppercase; letter-spacing:0.8px; margin-bottom:8px; }
    .login-box-row { font-size:13px; color:#a3a3a3; margin-bottom:4px; }
    .login-box-row strong { color:#c9a848; }
  </style>
</head>
<body>
  <div class="card">
    <div class="check">
      <svg fill="none" viewBox="0 0 24 24" stroke="#fff" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
    </div>
    <h1>Your site is ready!</h1>
    <p class="sub">We've sent a welcome email with your login details.<br>Sign in to start building.</p>

    <% const domain = typeof req !== 'undefined' ? req.query.domain : ''; %>
    <% if (domain) { %>
    <div class="site-url">
      <a href="https://<%= domain %>" target="_blank"><%= domain %></a>
      <p>Your preview site is live at this address</p>
    </div>

    <div class="login-box">
      <div class="login-box-label">Your Login</div>
      <div class="login-box-row">Admin panel: <strong><%= domain %>/admin/login</strong></div>
      <div class="login-box-row">Sign in with the email &amp; password you just created</div>
    </div>

    <div class="actions">
      <a href="https://<%= domain %>/admin/login" class="btn btn-primary">Sign In to Admin</a>
      <a href="https://<%= domain %>" class="btn btn-ghost" target="_blank">View Site</a>
    </div>
    <% } else { %>
    <div class="site-url">
      <p>Check your email for your site link and login details.</p>
    </div>
    <% } %>

    <p class="note">
      Your site is in preview mode — only you can see it until you go live.<br>
      Build your content, customize your design, and activate when ready.
    </p>
  </div>
</body>
</html>
