<%
  // Mobile Meadows — RV & Motorhome repair landing
  // Mobile-first: hero on first viewport, dual service boxes fill next viewport
  // Layout is bespoke; colors/fonts pull from the standard design namespace
  // (so the /admin/design panel drives the brand palette).
  const brandName = (brand && brand.name) || 'Mobile Meadows';
  const brandLocation = (brand && brand.location) || 'Branson, MO';
  const brandTagline = (brand && brand.tagline) || 'RV & Motorhome Repair · Branson, MO';

  // Pull editable content from the slab `copy` collection (mm_* keys)
  const heroHeading = copy.mm_hero_heading || brandName;
  const heroSub     = copy.mm_hero_sub     || brandTagline;
  const heroCta     = copy.mm_hero_cta     || 'Book a Service';

  const mobileTitle = copy.mm_mobile_title || 'Mobile RV & Motorhome Repair';
  const mobileBody  = copy.mm_mobile_body  || 'On-site repair and service for RVs and motorhomes. We come to you anywhere in the Branson, MO area.';
  const mobileCta   = copy.mm_mobile_cta   || 'View Availability';

  const roofTitle = copy.mm_roof_title || 'RV Roof Repair';
  const roofBody  = copy.mm_roof_body  || 'Specialized RV rooftop repair at our garage facility. Inspection, patching, coating, and full replacement.';
  const roofCta   = copy.mm_roof_cta   || 'Book Roof Service';

  const aboutTitle = copy.mm_about_title || 'About Mobile Meadows';
  const aboutBody  = copy.mm_about_body  || 'Serving Branson, Missouri and the surrounding areas with reliable, professional RV and motorhome repair services — mobile and in-shop.';

  const IMG = '/tenants/mobilemeadows/images';
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= brandName %> — <%= brandLocation %></title>
  <meta name="description" content="<%= brandTagline %>">
  <%- include('../../partials/font-vars') %>
  <style>
    /* ── Design tokens (pulled from /admin/design namespace) ── */
    :root {
      --navy:        <%= design.color_primary %>;
      --navy-deep:   <%= design.color_primary_deep %>;
      --navy-mid:    <%= design.color_primary_mid %>;
      --gold:        <%= design.color_accent %>;
      --gold-light:  <%= design.color_accent_light %>;
      --ivory:       <%= design.color_bg %>;
      --dark:        <%= design.color_dark || '#0F1B30' %>;
      --white:       <%= design.color_white || '#FDFCFA' %>;
      --muted:       <%= design.color_muted || '#6B7380' %>;
      --on-navy:     <%= design._on_primary || '#FDFCFA' %>;
      --on-gold:     <%= design._on_accent || '#0F1B30' %>;
      --font-heading: '<%= design.font_heading %>', serif;
      --font-body:    '<%= design.font_body %>', sans-serif;
      /* Aliases matching the rest of the platform */
      --primary: var(--navy); --primary-deep: var(--navy-deep); --primary-mid: var(--navy-mid);
      --accent: var(--gold); --accent-light: var(--gold-light); --bg: var(--ivory);
      /* Wordmark / nav typography (controlled by /admin/design > Header & Footer) */
      --nav-brand-size:      <%= design.nav_brand_size      || '1.4' %>rem;
      --nav-brand-weight:    <%= design.nav_brand_weight    || '600' %>;
      --nav-brand-style:     <%= design.nav_brand_italic === 'true' ? 'italic' : 'normal' %>;
      --nav-brand-spacing:   <%= design.nav_brand_spacing   || '0.02' %>em;
      --nav-brand-transform: <%= design.nav_brand_transform || 'none' %>;
      --nav-brand-color:     <%= design.nav_brand_color || design.nav_text_color || 'var(--on-navy)' %>;
    }
    *,*::before,*::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: var(--font-body);
      color: var(--dark);
      background: var(--ivory);
      line-height: 1.5;
    }
    a { color: inherit; }

    /* Top nav */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 50;
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 20px;
      background: color-mix(in srgb, var(--navy-deep) 70%, transparent);
      backdrop-filter: blur(8px);
      color: var(--on-navy);
    }
    .nav-brand {
      font-family: var(--font-heading);
      font-size: var(--nav-brand-size);
      font-weight: var(--nav-brand-weight);
      font-style: var(--nav-brand-style);
      letter-spacing: var(--nav-brand-spacing);
      text-transform: var(--nav-brand-transform);
      color: var(--nav-brand-color);
      text-decoration: none;
    }
    .nav-links { display: flex; gap: 18px; font-size: 14px; }
    .nav-links a { text-decoration: none; opacity: .85; }
    .nav-links a:hover { opacity: 1; }

    /* Section: Hero — fills first viewport on mobile */
    .hero {
      min-height: 100svh;
      background: var(--navy) url('<%= IMG %>/hero-rv-highway.jpg') center/cover no-repeat;
      position: relative;
      display: flex; align-items: center; justify-content: center;
      text-align: center; color: var(--on-navy);
      padding: 80px 24px 40px;
    }
    .hero::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(180deg,
        color-mix(in srgb, var(--navy-deep) 35%, transparent),
        color-mix(in srgb, var(--navy-deep) 65%, transparent));
    }
    .hero-inner { position: relative; max-width: 720px; }
    .hero h1 {
      font-family: var(--font-heading);
      font-size: clamp(2rem, 7vw, 3.5rem);
      margin: 0 0 12px;
      font-weight: 700;
      letter-spacing: -.01em;
      text-shadow: 0 2px 16px rgba(0,0,0,.4);
    }
    .hero p {
      font-size: clamp(1rem, 3.5vw, 1.25rem);
      margin: 0 0 28px;
      opacity: .95;
    }
    .btn {
      display: inline-block;
      padding: 14px 28px;
      background: var(--gold);
      color: var(--on-gold);
      text-decoration: none;
      font-weight: 700;
      border-radius: 6px;
      border: 0;
      cursor: pointer;
      transition: transform .15s ease, background .15s ease;
      font-size: 1rem;
      font-family: var(--font-body);
    }
    .btn:hover { background: var(--gold-light); transform: translateY(-1px); }
    .btn-light { background: var(--white); color: var(--navy); }
    .btn-light:hover { background: color-mix(in srgb, var(--white) 92%, var(--navy)); }

    /* Section: Dual service boxes — stacked on mobile, side-by-side on tablet+ */
    .services {
      display: grid;
      grid-template-columns: 1fr;
      min-height: 100svh;
    }
    @media (min-width: 768px) {
      .services { grid-template-columns: 1fr 1fr; }
    }
    .service-box {
      position: relative;
      min-height: 50svh;
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: 32px 24px;
      color: var(--on-navy);
      background-size: cover;
      background-position: center;
      overflow: hidden;
    }
    .service-box::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(180deg,
        color-mix(in srgb, var(--navy-deep) 20%, transparent) 0%,
        color-mix(in srgb, var(--navy-deep) 75%, transparent) 100%);
    }
    .service-box-content { position: relative; max-width: 460px; }
    .service-box h2 {
      font-family: var(--font-heading);
      font-size: clamp(1.5rem, 4vw, 2rem);
      margin: 0 0 12px;
      font-weight: 700;
    }
    .service-box p {
      margin: 0 0 20px;
      opacity: .92;
      font-size: .98rem;
    }

    /* Section: About */
    .about {
      position: relative;
      padding: 64px 24px;
      background: var(--navy) url('<%= IMG %>/about-landscape.jpg') center/cover no-repeat;
      color: var(--on-navy);
      text-align: center;
    }
    .about::before {
      content: ''; position: absolute; inset: 0;
      background: color-mix(in srgb, var(--navy) 75%, transparent);
    }
    .about-inner { position: relative; max-width: 720px; margin: 0 auto; }
    .about h2 {
      font-family: var(--font-heading);
      font-size: clamp(1.5rem, 4vw, 2.2rem);
      margin: 0 0 16px;
    }
    .about p { font-size: 1.05rem; opacity: .92; margin: 0; }

    /* Footer */
    .footer {
      background: var(--navy-deep);
      color: color-mix(in srgb, var(--on-navy) 60%, transparent);
      padding: 28px 24px;
      text-align: center;
      font-size: .9rem;
    }
    .footer a { color: var(--gold); text-decoration: none; }
  </style>
</head>
<body>
  <header class="nav">
    <a href="/" class="nav-brand"><%= brandName %></a>
    <nav class="nav-links">
      <a href="/book">Book</a>
    </nav>
  </header>

  <section class="hero">
    <div class="hero-inner">
      <h1><%= heroHeading %></h1>
      <p><%= heroSub %></p>
      <a href="/book" class="btn"><%= heroCta %></a>
    </div>
  </section>

  <section class="services">
    <div class="service-box" style="background-image: url('<%= IMG %>/service-mobile-repair.jpg');">
      <div class="service-box-content">
        <h2><%= mobileTitle %></h2>
        <p><%= mobileBody %></p>
        <a href="/book?service=mobile-repair" class="btn"><%= mobileCta %></a>
      </div>
    </div>

    <div class="service-box" style="background-image: url('<%= IMG %>/service-roof-repair.jpg');">
      <div class="service-box-content">
        <h2><%= roofTitle %></h2>
        <p><%= roofBody %></p>
        <slab-calculator data-slug="roof-cost" style="display:block;margin:14px 0;
          --slab-calc-accent:var(--gold);
          --slab-calc-bg:color-mix(in srgb, var(--navy-deep) 55%, transparent);
          --slab-calc-ink:var(--on-navy);
          --slab-calc-muted:color-mix(in srgb, var(--on-navy) 70%, transparent);
          --slab-calc-border:color-mix(in srgb, var(--on-navy) 18%, transparent);"></slab-calculator>
      </div>
    </div>
  </section>

  <section class="about">
    <div class="about-inner">
      <h2><%= aboutTitle %></h2>
      <p><%- aboutBody %></p>
    </div>
  </section>

  <footer class="footer">
    &copy; <%= new Date().getFullYear() %> <%= brandName %> · <%= brandLocation %> · <a href="/book">Book a Service</a>
  </footer>

  <script src="/js/slab-calculator.js" defer></script>
</body>
</html>
