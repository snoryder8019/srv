<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In — Slab</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <% if (oauthCid) { %>
  <script src="https://accounts.google.com/gsi/client" async defer></script>
  <% } %>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    :root { --navy:#1C2B4A; --navy-deep:#0F1B30; --gold:#C9A848; --gold-light:#E8D08A; --ivory:#F5F3EF; --ivory-mid:#E6E1D6; --dark:#0F1B30; --white:#FDFCFA; --on-ivory:#0F1B30; --on-ivory-muted:#6B7380; --font-heading:'Cormorant Garamond',serif; --font-body:'Jost',sans-serif; }
    body { font-family:var(--font-body); background:var(--navy-deep); min-height:100vh; display:flex; align-items:center; justify-content:center; }
    .auth-backdrop { position:fixed; inset:0; background:rgba(15,27,48,0.85); backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); z-index:999; display:flex; align-items:center; justify-content:center; }
    .auth-modal { background:var(--ivory); max-width:420px; width:100%; margin:24px; border-radius:4px; box-shadow:0 32px 80px rgba(0,0,0,0.5); overflow:hidden; position:relative; z-index:1000; animation:authSlideIn 0.3s ease; }
    @keyframes authSlideIn { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
    .auth-header { padding:32px 32px 0; text-align:center; }
    .auth-brand { font-family:var(--font-heading); font-size:1.8rem; font-weight:300; color:var(--on-ivory); margin-bottom:2px; }
    .auth-sub { font-size:0.62rem; font-weight:600; letter-spacing:0.22em; text-transform:uppercase; color:var(--on-ivory-muted); margin-bottom:20px; }
    .auth-body { padding:24px 32px 32px; }
    #oneTapWrap { display:flex; justify-content:center; margin-bottom:16px; }
    .divider { display:flex; align-items:center; gap:14px; margin:18px 0; font-size:0.62rem; color:var(--on-ivory-muted); letter-spacing:0.1em; text-transform:uppercase; }
    .divider::before, .divider::after { content:''; flex:1; height:1px; background:var(--border); }
    .btn-google { display:flex; align-items:center; justify-content:center; gap:10px; width:100%; background:var(--surface); color:var(--on-ivory); text-decoration:none; padding:12px; font-size:0.78rem; font-weight:500; letter-spacing:0.04em; transition:all 0.15s; border-radius:2px; border:1.5px solid var(--border); cursor:pointer; font-family:var(--font-body); }
    .btn-google:hover { border-color:var(--navy); background:var(--ivory); }
    .btn-google svg { width:18px; height:18px; flex-shrink:0; }
    .msg-error { background:rgba(185,28,28,0.07); border:1px solid rgba(185,28,28,0.2); color:#B91C1C; padding:10px 12px; font-size:0.78rem; margin-bottom:14px; border-radius:2px; }
    .msg-info { font-size:0.72rem; color:var(--on-ivory-muted); text-align:center; margin-top:18px; line-height:1.6; }
    .msg-info a { color:var(--navy); text-decoration:none; }
    .auth-footer { padding:0 32px 24px; text-align:center; }
    .auth-footer a { font-size:0.72rem; color:var(--on-ivory-muted); text-decoration:none; }
    .auth-footer a:hover { color:var(--navy); }

    /* Tabs */
    .auth-tabs { display:flex; border-bottom:1px solid var(--border); margin:0 32px; }
    .auth-tab { flex:1; padding:10px 0; text-align:center; font-size:0.7rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:var(--on-ivory-muted); cursor:pointer; border-bottom:2px solid transparent; transition:all 0.15s; background:none; border-top:none; border-left:none; border-right:none; font-family:var(--font-body); }
    .auth-tab:hover { color:var(--on-surface); }
    .auth-tab.active { color:var(--navy); border-bottom-color:var(--gold); }
    .auth-panel { display:none; } .auth-panel.active { display:block; }

    /* Form fields */
    .field { margin-bottom:14px; }
    .field label { display:block; font-size:0.62rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:var(--on-ivory-muted); margin-bottom:5px; }
    .field input { width:100%; padding:11px 14px; border:1.5px solid var(--border); border-radius:2px; font-family:var(--font-body); font-size:0.85rem; font-weight:300; color:var(--on-surface); background:var(--surface); outline:none; }
    .field input:focus { border-color:var(--navy); }
    .btn-submit { width:100%; padding:13px; background:var(--navy); color:var(--white); border:none; border-radius:2px; font-family:var(--font-body); font-size:0.78rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; transition:background 0.15s; margin-top:6px; }
    .btn-submit:hover { background:var(--navy-deep); }
    .btn-submit:disabled { background:var(--border); color:var(--on-ivory-muted); cursor:not-allowed; }

    /* Slab picker items */
    .slab-pick-item { display:flex; align-items:center; gap:10px; padding:10px 12px; border:1.5px solid var(--border); border-radius:2px; margin-bottom:6px; cursor:pointer; transition:all 0.15s; }
    .slab-pick-item:hover { border-color:var(--navy); background:rgba(28,43,74,0.04); }
    .slab-pick-icon { width:32px; height:32px; border-radius:4px; background:var(--navy); color:var(--white); display:flex; align-items:center; justify-content:center; font-family:var(--font-heading); font-size:0.85rem; font-weight:600; flex-shrink:0; }
    .slab-pick-info { flex:1; min-width:0; }
    .slab-pick-name { font-size:0.82rem; font-weight:500; color:var(--on-surface); }
    .slab-pick-domain { font-size:0.62rem; color:var(--on-ivory-muted); }

    @media (max-width:480px) { .auth-modal { margin:12px; } .auth-body { padding:20px 20px 24px; } .auth-header { padding:24px 20px 0; } .auth-footer { padding:0 20px 20px; } .auth-tabs { margin:0 20px; } }
  </style>
</head>
<body>

<div class="auth-backdrop">
<div class="auth-modal">
  <div class="auth-header">
    <div class="auth-brand">Slab</div>
    <div class="auth-sub">Sign in to your workspace</div>
  </div>

  <!-- Auth method tabs -->
  <div class="auth-tabs">
    <button class="auth-tab active" data-tab="google" onclick="switchTab('google')">Google</button>
    <button class="auth-tab" data-tab="email" onclick="switchTab('email')">Email</button>
  </div>

  <div class="auth-body">
    <% if (typeof errorMsg !== 'undefined' && errorMsg) { %><div class="msg-error"><%= errorMsg %></div><% } %>
    <div id="loginError" class="msg-error" style="display:none;"></div>

    <!-- GOOGLE panel -->
    <div class="auth-panel active" id="panel-google">
      <% if (oauthCid) { %>
      <div id="oneTapWrap"></div>
      <% } %>

      <!-- Fallback if Google SDK doesn't load or oauthCid is missing -->
      <a href="/auth/google/central" class="btn-google" id="googleFallbackBtn" style="display:none;">
        <svg viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        Sign in with Google
      </a>

      <p class="msg-info">
        Sign in with your Google account to access your workspace.<br>
        If you belong to multiple workspaces, you'll be able to choose.
      </p>
    </div>

    <!-- EMAIL panel -->
    <div class="auth-panel" id="panel-email">
      <form id="emailLoginForm" onsubmit="return handleEmailLogin(event)">
        <div class="field">
          <label>Email</label>
          <input type="email" id="loginEmail" placeholder="you@business.com" required autocomplete="email">
        </div>
        <div class="field">
          <label>Password</label>
          <input type="password" id="loginPassword" placeholder="Your password" required autocomplete="current-password">
        </div>
        <button type="submit" class="btn-submit" id="emailLoginBtn">Sign In</button>
      </form>

      <!-- Multi-slab picker (hidden until needed) -->
      <div id="slabPicker" style="display:none;margin-top:16px;">
        <p style="font-size:0.78rem;color:var(--on-ivory-muted);margin-bottom:10px;">You belong to multiple workspaces. Choose one:</p>
        <div id="slabPickerList"></div>
      </div>

      <p class="msg-info">
        Don't have an account? <a href="/start">Create one</a>
      </p>
    </div>
  </div>

  <div class="auth-footer">
    <a href="/">← Back to Slab</a>
  </div>
</div>
</div>

<script>
// Tab switching
function switchTab(tab) {
  document.querySelectorAll('.auth-tab').forEach(function(t) { t.classList.toggle('active', t.dataset.tab === tab); });
  document.querySelectorAll('.auth-panel').forEach(function(p) { p.classList.remove('active'); });
  var panel = document.getElementById('panel-' + tab);
  if (panel) panel.classList.add('active');
}

// Email/password login
var _loginEmail = '', _loginPassword = '';
async function handleEmailLogin(e) {
  e.preventDefault();
  var email = document.getElementById('loginEmail').value.trim();
  var pw = document.getElementById('loginPassword').value;
  var btn = document.getElementById('emailLoginBtn');
  var errDiv = document.getElementById('loginError');

  if (!email || !pw) return;
  _loginEmail = email; _loginPassword = pw;
  btn.disabled = true; btn.textContent = 'Signing in...';
  errDiv.style.display = 'none';

  try {
    var res = await fetch('/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email, password: pw }),
    });
    var data = await res.json();

    if (data.ok && data.multiple) {
      // Show slab picker
      showSlabPicker(data.slabs);
      btn.disabled = false; btn.textContent = 'Sign In';
    } else if (data.ok && data.redirect) {
      window.location.href = data.redirect;
    } else {
      errDiv.textContent = data.error || 'Login failed';
      errDiv.style.display = 'block';
      btn.disabled = false; btn.textContent = 'Sign In';
    }
  } catch(err) {
    errDiv.textContent = 'Network error. Please try again.';
    errDiv.style.display = 'block';
    btn.disabled = false; btn.textContent = 'Sign In';
  }
  return false;
}

function showSlabPicker(slabs) {
  var picker = document.getElementById('slabPicker');
  var list = document.getElementById('slabPickerList');
  list.innerHTML = '';
  slabs.forEach(function(s) {
    var item = document.createElement('div');
    item.className = 'slab-pick-item';
    item.innerHTML = '<div class="slab-pick-icon">' + (s.brandName || '?')[0].toUpperCase() + '</div>'
      + '<div class="slab-pick-info"><div class="slab-pick-name">' + esc(s.brandName) + '</div><div class="slab-pick-domain">' + esc(s.domain) + '</div></div>';
    item.onclick = function() { pickSlab(s.tenantDb); };
    list.appendChild(item);
  });
  picker.style.display = 'block';
}

async function pickSlab(tenantDb) {
  var errDiv = document.getElementById('loginError');
  errDiv.style.display = 'none';
  try {
    var res = await fetch('/auth/login/pick-slab', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: _loginEmail, password: _loginPassword, tenantDb: tenantDb }),
    });
    var data = await res.json();
    if (data.ok && data.redirect) {
      window.location.href = data.redirect;
    } else {
      errDiv.textContent = data.error || 'Login failed';
      errDiv.style.display = 'block';
    }
  } catch(err) {
    errDiv.textContent = 'Network error.';
    errDiv.style.display = 'block';
  }
}

function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

<% if (oauthCid) { %>
window.onload = function() {
  if (typeof google !== 'undefined' && google.accounts) {
    google.accounts.id.initialize({
      client_id: '<%= oauthCid %>',
      callback: handleOneTap,
      auto_select: true,
    });
    google.accounts.id.renderButton(document.getElementById('oneTapWrap'), {
      theme: 'outline', size: 'large', width: 356, text: 'signin_with',
    });
    google.accounts.id.prompt();
  } else {
    // Google SDK didn't load — show fallback redirect button
    var fb = document.getElementById('googleFallbackBtn');
    if (fb) fb.style.display = '';
  }
};

async function handleOneTap(response) {
  try {
    var res = await fetch('/auth/google/one-tap-central', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ credential: response.credential }),
    });
    var data = await res.json();
    if (data.ok && data.redirect) {
      window.location.href = data.redirect;
    } else if (data.error) {
      var body = document.querySelector('.auth-body');
      var existing = body.querySelector('.msg-error');
      if (existing) existing.remove();
      var err = document.createElement('div');
      err.className = 'msg-error';
      err.textContent = data.error;
      body.prepend(err);
    }
  } catch(e) {
    console.error('One Tap error:', e);
  }
}
<% } else { %>
// No oauthCid — show fallback redirect button
window.onload = function() {
  var fb = document.getElementById('googleFallbackBtn');
  if (fb) fb.style.display = '';
};
<% } %>
</script>
</body>
</html>
