<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — <%= brand?.name || 'sLab' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#0a0a0a; color:#d4d4d4; min-height:100vh; padding:40px 24px; }
    .wrap { max-width:720px; margin:0 auto; }
    .logo { text-align:center; margin-bottom:32px; }
    .logo a { font-size:24px; font-weight:600; color:#fff; text-decoration:none; }
    h1 { font-size:28px; font-weight:700; color:#fff; margin-bottom:24px; }
    .content { font-size:14px; line-height:1.9; color:#a3a3a3; white-space:pre-wrap; word-break:break-word; }
    a { color:#c9a848; }
    .back { display:inline-block; margin-top:32px; font-size:13px; color:#737373; text-decoration:none; }
    .back:hover { color:#c9a848; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="logo"><a href="/"><%= brand?.name || 'Home' %></a></div>
    <h1><%= title %></h1>
    <div class="content"><%= content %></div>
    <a href="/" class="back">&larr; Back to home</a>
  </div>
</body>
</html>
