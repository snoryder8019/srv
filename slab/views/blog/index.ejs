<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog — <%= brand?.name || 'Home' %> | <%= brand?.location || '' %></title>
  <meta name="description" content="Marketing tips, social media insights, and digital strategy from <%= brand?.name || 'our team' %>.">
  <%
    const _sp = parseInt(design.nav_logo_split) || 0;
    const _brandPre = _sp > 0 ? (brand?.name||'').slice(0,_sp) : '';
    const _brandPost = _sp > 0 ? (brand?.name||'').slice(_sp) : (brand?.name||'');
  %>
  <%- include('../partials/font-vars') %>
  <style>
    :root {
      --primary:      <%= design.color_primary %>;
      --primary-deep: <%= design.color_primary_deep %>;
      --primary-mid:  <%= design.color_primary_mid %>;
      --accent:       <%= design.color_accent %>;
      --accent-light: <%= design.color_accent_light %>;
      --bg:           <%= design.color_bg %>;
      --navy: var(--primary); --navy-deep: var(--primary-deep); --navy-mid: var(--primary-mid);
      --gold: var(--accent); --gold-light: var(--accent-light); --ivory: var(--bg);
      --ivory-mid: #E6E1D6; --dark: <%= design.color_primary_deep %>; --white: #FDFCFA;
      --on-primary: <%= design._on_primary || '#FDFCFA' %>; --on-primary-deep: <%= design._on_primary_deep || '#FDFCFA' %>;
      --on-primary-mid: <%= design._on_primary_mid || '#FDFCFA' %>;
      --on-bg: <%= design._on_bg || '#0F1B30' %>; --on-bg-muted: <%= design._on_bg_muted || '#6B7380' %>;
      --on-accent: <%= design._on_accent || '#0F1B30' %>; --on-accent-light: <%= design._on_accent_light || '#0F1B30' %>;
      --slate: var(--on-bg-muted);
      --font-heading: '<%= design.font_heading %>', serif;
      --font-body: '<%= design.font_body %>', sans-serif;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body { font-family: var(--font-body); background:var(--white); color:var(--dark); }
    .reveal { opacity:0; transform:translateY(20px); transition:opacity 0.5s ease, transform 0.5s ease; }
    .reveal.visible { opacity:1; transform:translateY(0); }
    /* nav styles provided by partials/header.ejs */
    .blog-hero { padding:140px 52px 80px; background:var(--bg); }
    .blog-hero-inner { max-width:800px; margin:0 auto; }
    .eyebrow { font-size:0.72rem; font-weight:600; letter-spacing:0.22em; text-transform:uppercase; color:var(--primary); margin-bottom:16px; }
    .blog-hero h1 { font-family:var(--font-heading); font-size:clamp(2.4rem,5vw,4rem); font-weight:300; line-height:1.1; color:var(--dark); margin-bottom:16px; }
    .blog-hero p { font-size:1rem; font-weight:300; color:var(--slate); line-height:1.8; }
    .posts-grid { max-width:1100px; margin:0 auto; padding:60px 52px 100px; display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:32px; }
    .post-card { background:var(--white); border:1px solid var(--ivory-mid); border-radius:2px; overflow:hidden; transition:box-shadow 0.2s, transform 0.2s; display:flex; flex-direction:column; }
    .post-card:hover { box-shadow:0 8px 32px color-mix(in srgb, var(--primary) 12%, transparent); transform:translateY(-3px); }
    .post-img { width:100%; height:200px; object-fit:cover; background:var(--bg); }
    .post-img-placeholder { width:100%; height:200px; background:linear-gradient(135deg,var(--primary-deep),var(--primary-mid)); display:flex; align-items:center; justify-content:center; }
    .post-img-placeholder span { font-family:var(--font-heading); font-size:3rem; font-weight:300; font-style:italic; color:color-mix(in srgb, var(--accent) 30%, transparent); }
    .post-body { padding:24px; flex:1; display:flex; flex-direction:column; }
    .post-meta { display:flex; gap:12px; align-items:center; margin-bottom:12px; flex-wrap:wrap; }
    .post-category { font-size:0.65rem; font-weight:600; letter-spacing:0.18em; text-transform:uppercase; color:var(--accent); }
    .post-date { font-size:0.72rem; color:var(--slate); font-weight:300; }
    .post-title { font-family:var(--font-heading); font-size:1.3rem; font-weight:400; color:var(--dark); line-height:1.3; margin-bottom:12px; text-decoration:none; display:block; }
    .post-title:hover { color:var(--primary); }
    .post-excerpt { font-size:0.88rem; font-weight:300; color:var(--slate); line-height:1.7; flex:1; margin-bottom:20px; }
    .read-more { font-size:0.75rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:var(--primary); text-decoration:none; display:inline-flex; align-items:center; gap:6px; margin-top:auto; }
    .read-more:hover { color:var(--accent); }
    .no-posts { text-align:center; padding:80px 24px; color:var(--slate); }
    .no-posts p { font-size:1rem; font-weight:300; }
    footer { background:var(--primary-deep); padding:48px 52px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:24px; }
    .footer-brand { font-family:var(--font-heading); font-size:1.3rem; font-weight:300; color:color-mix(in srgb, var(--on-primary-deep) 60%, transparent); }
    .footer-links { list-style:none; display:flex; gap:24px; }
    .footer-links a { font-size:0.75rem; letter-spacing:0.1em; text-transform:uppercase; color:color-mix(in srgb, var(--on-primary-deep) 35%, transparent); text-decoration:none; transition:color 0.2s; }
    .footer-links a:hover { color:var(--accent-light); }
  </style>
</head>
<body>
<%- include("../partials/header", { activePage: 'blog' }) %>

<div class="blog-hero">
  <div class="blog-hero-inner">
    <p class="eyebrow"><%= brand?.name || 'Blog' %> Blog</p>
    <h1>Insights &amp; <em>Resources</em></h1>
    <p>Marketing tips, social media strategies, and digital growth advice for local businesses.</p>
  </div>
</div>

<% if (!posts || posts.length === 0) { %>
  <div class="no-posts">
    <p>No posts published yet. Check back soon!</p>
    <div style="margin-top:24px;"><a href="/" style="font-size:0.82rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--primary);text-decoration:none;">← Back to Home</a></div>
  </div>
<% } else { %>
  <div class="posts-grid">
    <% posts.forEach(post => { %>
      <div class="post-card reveal">
        <% if (post.featuredImageUrl) { %>
          <img src="<%= post.featuredImageUrl %>" alt="<%= post.title %>" class="post-img">
        <% } else { %>
          <div class="post-img-placeholder"><span><%= (brand?.name || '?').charAt(0) %></span></div>
        <% } %>
        <div class="post-body">
          <div class="post-meta">
            <% if (post.category) { %><span class="post-category"><%= post.category %></span><% } %>
            <span class="post-date"><%= new Date(post.publishedAt).toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'}) %></span>
          </div>
          <a href="/blog/<%= post.slug %>" class="post-title"><%= post.title %></a>
          <% if (post.excerpt) { %>
            <p class="post-excerpt"><%= post.excerpt %></p>
          <% } %>
          <a href="/blog/<%= post.slug %>" class="read-more">Read Article →</a>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<footer>
  <div class="footer-brand"><% if (_brandPre) { %><span style="color:var(--accent-light)"><%= _brandPre %></span><% } %><%- _brandPost %></div>
  <ul class="footer-links">
    <li><a href="/">Home</a></li>
    <li><a href="/#services">Services</a></li>
    <li><a href="/blog">Blog</a></li>
    <li><a href="/#contact">Contact</a></li>
  </ul>
  <div style="margin-top:16px;text-align:center;"><a href="/admin/login" style="color:rgba(253,252,250,0.12);text-decoration:none;font-size:0.6rem;letter-spacing:0.04em;transition:color 0.2s;" onmouseover="this.style.color='rgba(253,252,250,0.3)'" onmouseout="this.style.color='rgba(253,252,250,0.12)'">Admin</a></div>
</footer>
<script>
(function() {
  var els = document.querySelectorAll('.reveal');
  if (els.length && 'IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
    }, { threshold: 0.1 });
    els.forEach(function(el) { obs.observe(el); });
  } else { els.forEach(function(el) { el.classList.add('visible'); }); }
})();
</script>
</body>
</html>
