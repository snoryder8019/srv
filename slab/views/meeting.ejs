<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — <%= brand?.name || 'Home' %></title>
  <%
    const _FM = {
      'Cormorant Garamond': 'Cormorant+Garamond:wght@300;400;600',
      'Playfair Display': 'Playfair+Display:wght@400;600;700',
      'Lora': 'Lora:wght@400;600;700', 'Merriweather': 'Merriweather:wght@300;400;700',
      'Libre Baskerville': 'Libre+Baskerville:wght@400;700',
      'Jost': 'Jost:wght@300;400;500;600', 'Inter': 'Inter:wght@300;400;500;600',
      'Poppins': 'Poppins:wght@300;400;500;600', 'Raleway': 'Raleway:wght@300;400;500;600',
      'Nunito': 'Nunito:wght@300;400;500;600', 'DM Sans': 'DM+Sans:wght@300;400;500;600',
    };
    const _hF = _FM[design.font_heading] || _FM['Cormorant Garamond'];
    const _bF = _FM[design.font_body] || _FM['Jost'];
    const _fp = _hF === _bF ? _hF : _hF + '&family=' + _bF;
  %>
  <link href="https://fonts.googleapis.com/css2?family=<%= _fp %>&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/meeting.css">
  <style>
    :root {
      --navy: <%= design.color_primary %>;
      --navy-deep: <%= design.color_primary_deep %>;
      --navy-mid: <%= design.color_primary_mid %>;
      --gold: <%= design.color_accent %>;
      --gold-light: <%= design.color_accent_light %>;
      --ivory: <%= design.color_bg %>;
      --dark: <%= design._on_bg || '#0F1B30' %>;
      --on-primary: <%= design._on_primary || '#FDFCFA' %>;
      --on-primary-deep: <%= design._on_primary_deep || '#FDFCFA' %>;
      --surface: <%= design._surface || '#FFFFFF' %>; --on-surface: <%= design._on_surface || '#0F1B30' %>;
      --border: <%= design._border || '#CBD5E1' %>; --placeholder: <%= design._placeholder || '#9CA3AF' %>;
      --font-heading: '<%= design.font_heading || 'Cormorant Garamond' %>', serif;
      --font-body: '<%= design.font_body || 'Jost' %>', sans-serif;
    }
    body { font-family: var(--font-body); }
  </style>
</head>
<body data-token="<%= token %>" data-db="<%= tenantDb %>"
      data-consent-recording="<%= consent.recordingNotice ? '1' : '' %>"
      data-consent-transcription="<%= consent.transcriptionDisclaimer ? '1' : '' %>"
      data-consent-custom="<%= (consent.customText || '').replace(/\"/g, '&quot;') %>">
  <div id="error-toast" class="toast"></div>
  <div id="success-toast" class="toast"></div>

  <!-- SHARE PANEL -->
  <div id="share-panel">
    <div class="share-card">
      <h2>Invite Others <button class="share-close" id="share-close">&times;</button></h2>

      <div class="share-section">
        <div class="share-section-label">Scan to Join</div>
        <div id="qr-container">
          <div id="qr-loading">Loading QR code...</div>
        </div>
      </div>

      <div class="share-section">
        <div class="share-section-label">Meeting Link</div>
        <div class="share-link-row">
          <input type="text" class="share-link-input" id="share-link" readonly value="<%= domain %>/meeting/<%= token %>">
          <button class="share-btn" id="share-copy">Copy</button>
        </div>
      </div>

      <div class="share-section">
        <div class="share-section-label">Email Invite</div>
        <div class="invite-form">
          <div class="invite-row">
            <input type="text" id="invite-name" placeholder="Name (optional)">
            <input type="email" id="invite-email" placeholder="Email address" required>
          </div>
          <button class="share-btn gold" id="invite-send">Send Invite</button>
          <div class="invite-status" id="invite-status"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- PRE-JOIN -->
  <div id="prejoin">
    <div class="prejoin-card">
      <h1><%= title %></h1>
      <div class="subtitle"><%- brand?.name || '' %></div>

      <div id="preview-container">
        <video id="preview-video" autoplay playsinline muted style="display:none;"></video>
        <div id="preview-placeholder">&#9673;</div>
      </div>

      <div class="prejoin-toggles">
        <button class="toggle-btn" id="pre-mic" title="Toggle microphone">&#9834;</button>
        <button class="toggle-btn" id="pre-cam" title="Toggle camera">&#9673;</button>
      </div>

      <input type="text" class="prejoin-input" id="name-input" placeholder="Enter your name" maxlength="40" autofocus>
      <button class="btn-join" id="join-btn">Join Meeting</button>
    </div>
  </div>

  <!-- CONSENT MODAL -->
  <div id="consent-modal" style="display:none;position:fixed;inset:0;z-index:600;background:rgba(15,27,48,0.7);backdrop-filter:blur(4px);align-items:center;justify-content:center;">
    <div style="background:var(--ivory,#F5F3EF);border-radius:6px;padding:32px 28px;max-width:420px;width:92vw;box-shadow:0 12px 40px rgba(0,0,0,0.25);font-family:var(--font-body);">
      <h2 style="font-family:var(--font-heading);font-weight:400;font-size:1.4rem;color:var(--navy-deep);margin:0 0 6px;">Before You Join</h2>
      <p style="font-size:0.78rem;color:var(--slate,#6b7280);margin:0 0 18px;">Please review and acknowledge the following:</p>
      <div id="consent-items" style="display:flex;flex-direction:column;gap:12px;margin-bottom:20px;"></div>
      <label style="display:flex;align-items:center;gap:10px;font-size:0.84rem;cursor:pointer;margin-bottom:20px;color:var(--navy-deep);">
        <input type="checkbox" id="consent-agree" style="accent-color:var(--gold,#C9A848);width:16px;height:16px;">
        I acknowledge and agree to the above
      </label>
      <div style="display:flex;gap:10px;">
        <button id="consent-accept" disabled class="btn-join" style="flex:1;opacity:0.5;cursor:not-allowed;">Continue to Meeting</button>
        <button id="consent-decline" style="flex:0 0 auto;padding:12px 20px;background:transparent;border:1px solid var(--navy-mid,#3a4d6b);color:var(--navy-mid);border-radius:3px;font-family:var(--font-body);font-size:0.82rem;cursor:pointer;">Decline</button>
      </div>
    </div>
  </div>

  <!-- NOTES / ASSETS SIDEBAR -->
  <div id="sidebar-panel">
    <button class="sidebar-close" id="sidebar-close">&times;</button>
    <div class="sidebar-tabs">
      <button class="sidebar-tab active" data-tab="notes">Notes</button>
      <button class="sidebar-tab" data-tab="assets">Assets</button>
    </div>

    <!-- Notes Tab -->
    <div class="sidebar-body active" data-tab="notes" id="notes-body">
      <div id="notes-list">
        <div class="notes-empty" id="notes-empty">No notes yet. Add one below.</div>
      </div>
      <textarea id="note-input" placeholder="Type a note..." maxlength="5000"></textarea>
      <div class="note-actions">
        <button class="share-btn gold" id="note-send" style="padding:8px 16px;font-size:0.72rem;">Add Note</button>
      </div>
    </div>

    <!-- Assets Tab -->
    <div class="sidebar-body" data-tab="assets" id="assets-body">
      <div id="assets-list">
        <div class="assets-empty" id="assets-empty">No files shared yet.</div>
      </div>
      <div id="upload-zone">
        <div class="upload-icon">&#8682;</div>
        <p>Click or drag a file to upload</p>
        <input type="file" id="upload-input" style="display:none;">
      </div>
      <div id="upload-progress">Uploading...</div>
    </div>
  </div>

  <!-- IN-CALL -->
  <div id="incall">
    <div class="call-header">
      <div>
        <div class="call-title"><%= title %></div>
        <div class="call-status" id="call-status">connecting...</div>
      </div>
      <div class="call-duration" id="call-duration">00:00</div>
    </div>

    <div id="peers-grid"></div>

    <div id="local-pip" style="display:none;">
      <video id="local-video" autoplay playsinline muted></video>
    </div>

    <!-- LIVE TRANSCRIPT PANEL -->
    <div id="transcript-panel">
      <div class="transcript-header">
        <span class="transcript-title">Live Transcript</span>
        <span>
          <button class="notetaker-flush-btn" id="notetaker-flush" title="Summarize now">TLDR Now</button>
          <span class="transcript-status" id="transcript-status">ready</span>
        </span>
      </div>
      <div id="transcript-lines"></div>
    </div>

    <div class="controls">
      <button class="ctrl-btn" id="ctrl-mic" title="Mute / Unmute">&#9834;</button>
      <button class="ctrl-btn" id="ctrl-cam" title="Camera On / Off">&#9673;</button>
      <button class="ctrl-btn" id="ctrl-screen" title="Share Screen">&#9635;</button>
      <button class="ctrl-btn" id="ctrl-notetaker" title="AI Notetaker">&#9041;</button>
      <button class="ctrl-btn" id="ctrl-notes" title="Notes &amp; Assets">&#9998;</button>
      <button class="ctrl-btn" id="ctrl-share" title="Invite Others">&#9993;</button>
      <button class="ctrl-btn leave" id="ctrl-leave" title="Leave Meeting">&#9587;</button>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/meeting-rtc.js"></script>
  <script src="/js/meeting-ui.js"></script>
</body>
</html>
