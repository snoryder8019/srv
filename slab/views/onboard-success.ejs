<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Welcome — <%= brand?.name || 'Home' %></title>
  <%
    const _FM = { 'Cormorant Garamond':'Cormorant+Garamond:wght@300;400;600','Playfair Display':'Playfair+Display:wght@400;600;700','Lora':'Lora:wght@400;600;700','Merriweather':'Merriweather:wght@300;400;700','Libre Baskerville':'Libre+Baskerville:wght@400;700','Jost':'Jost:wght@300;400;500;600','Inter':'Inter:wght@300;400;500;600','Poppins':'Poppins:wght@300;400;500;600','Raleway':'Raleway:wght@300;400;500;600','Nunito':'Nunito:wght@300;400;500;600','DM Sans':'DM+Sans:wght@300;400;500;600' };
    const _hF = _FM[design.font_heading] || _FM['Cormorant Garamond'];
    const _bF = _FM[design.font_body] || _FM['Jost'];
    const _fp = _hF === _bF ? _hF : _hF + '&family=' + _bF;
  %>
  <link href="https://fonts.googleapis.com/css2?family=<%= _fp %>&display=swap" rel="stylesheet">
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  :root {
    --navy: <%= design.color_primary || '#1C2B4A' %>;
    --navy-deep: <%= design.color_primary_deep || '#0F1B30' %>;
    --gold: <%= design.color_accent || '#C9A848' %>;
    --gold-light: <%= design.color_accent_light || '#E8D08A' %>;
    --ivory: <%= design.color_bg || '#F5F3EF' %>;
    --slate: #6B7380;
    --dark: <%= design.color_primary_deep || '#0F1B30' %>;
    --white: #FDFCFA;
  }
  body { font-family: '<%= design.font_body || 'Jost' %>', sans-serif; background: var(--ivory); color: var(--on-surface); min-height: 100vh; display: flex; flex-direction: column; }

  .ob-header {
    background: var(--navy-deep); padding: 20px 32px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .ob-brand { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: var(--white); text-decoration: none; }
  .ob-brand-sub { font-size: 0.55rem; font-weight: 600; letter-spacing: .22em; text-transform: uppercase; color: var(--gold); margin-top: 2px; }

  .ob-center { flex: 1; display: flex; align-items: center; justify-content: center; padding: 40px 20px; }
  .ob-success-card {
    background: var(--surface); border-radius: 6px; padding: 40px 36px; text-align: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08); max-width: 500px; width: 100%;
  }
  .ob-check { font-size: 2.4rem; color: var(--gold); margin-bottom: 12px; }
  .ob-success-card h1 {
    font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; font-weight: 400;
    color: var(--navy); margin-bottom: 8px;
  }
  .ob-success-card p { font-size: 0.88rem; color: var(--slate); line-height: 1.6; margin-bottom: 20px; }
  .ob-success-card hr { border: none; border-top: 1px solid var(--ivory-mid, #E6E1D6); margin: 20px 0; }

  .ob-google-section h2 {
    font-size: 0.68rem; font-weight: 600; letter-spacing: .16em; text-transform: uppercase;
    color: var(--slate); margin-bottom: 12px;
  }
  .ob-google-section p { font-size: 0.82rem; margin-bottom: 16px; }

  .ob-google-btn {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--surface); border: 1px solid #ddd; border-radius: 4px;
    padding: 12px 24px; font-family: inherit; font-size: 0.88rem; font-weight: 500;
    color: var(--on-surface); cursor: pointer; text-decoration: none; transition: all .2s;
  }
  .ob-google-btn:hover { border-color: var(--navy); box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
  .ob-google-btn svg { width: 20px; height: 20px; }

  .ob-skip { display: block; margin-top: 14px; font-size: 0.78rem; color: var(--slate); text-decoration: none; }
  .ob-skip:hover { color: var(--gold); }

  .ob-footer { text-align: center; padding: 24px; font-size: 0.75rem; color: var(--slate); }
  .ob-footer a { color: var(--gold); text-decoration: none; }

  @media (max-width: 520px) {
    .ob-success-card { padding: 28px 20px; }
    .ob-success-card h1 { font-size: 1.4rem; }
  }
</style>
</head>
<body>
<%- include("partials/preview-banner") %>

<div class="ob-header">
  <div>
    <a href="/" class="ob-brand"><%- brand?.name || '' %></a>
    <div class="ob-brand-sub">Client Onboarding</div>
  </div>
</div>

<div class="ob-center">
  <div class="ob-success-card">
    <div class="ob-check">&#10003;</div>
    <h1>Welcome aboard<%= clientName ? ', ' + clientName.split(' ')[0] : '' %>!</h1>
    <p>We've received your information and will be in touch within one business day to discuss next steps.</p>

    <hr>

    <div class="ob-google-section">
      <h2>Create Your Account</h2>
      <p>Sign in with Google to access your client portal — view invoices, share files, and collaborate with our team.</p>

      <a href="https://slab.madladslab.com/auth/google/client?cid=<%= clientId %>&return=<%= typeof tenant !== 'undefined' && tenant?.domain ? tenant.domain : '' %>" class="ob-google-btn">
        <svg viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
        Continue with Google
      </a>

      <a href="/" class="ob-skip">Skip for now — I'll create an account later</a>
    </div>
  </div>
</div>

<div class="ob-footer">
  &copy; <%= new Date().getFullYear() %> <a href="/"><%- brand?.name || '' %></a> &mdash; <%= brand?.location || '' %>
</div>

</body>
</html>
