<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta property="og:title" content="<%= brand?.name || 'Home' %> | <%= brand?.location || '' %>" />
  <meta property="og:description" content="Social media management, website design, and content creation for local businesses in <%= brand?.location || '' %>." />
  <title><%= brand?.name || 'Home' %> | <%= brand?.location || '' %></title>
  <%
    const _BI_auto = (brand?.name || '').split(/\s+/).map(w => w[0]).join('').toUpperCase();
    const _BI = (design.hero_name_large && design.hero_name_large.trim()) || _BI_auto;
    const _sp = (brand?.name || '').indexOf(' ') > 0 ? (brand.name.indexOf(' ')) : 0;
  %>
  <%- include('partials/font-vars') %>
<style>
  /* ── PALETTE (dynamic from admin) ── */
  :root {
    --navy:       <%= design.color_primary %>;
    --navy-deep:  <%= design.color_primary_deep %>;
    --navy-mid:   <%= design.color_primary_mid %>;
    --gold:       <%= design.color_accent %>;
    --gold-light: <%= design.color_accent_light %>;
    --crimson:    #8B1C1C;
    --ivory:      <%= design.color_bg %>;
    --ivory-mid:  #E6E1D6;
    --dark:       #0F1B30;
    --white:      #FDFCFA;
    --section-pad: 100px 52px;
    --font-heading: '<%= design.font_heading %>', serif;
    --font-body:    '<%= design.font_body %>', sans-serif;
    /* ── contrast-safe text colors (computed by enrichDesignContrast) ── */
    --on-ivory:       <%= design._on_bg || '#0F1B30' %>;
    --on-ivory-muted: <%= design._on_bg_muted || '#6B7380' %>;
    --on-navy:        <%= design._on_primary || '#FDFCFA' %>;
    --on-navy-deep:   <%= design._on_primary_deep || '#FDFCFA' %>;
    --on-navy-mid:    <%= design._on_primary_mid || '#FDFCFA' %>;
    --on-gold:        <%= design._on_accent || '#0F1B30' %>;
    --on-gold-light:  <%= design._on_accent_light || '#0F1B30' %>;
    /* aliases for shared header partial */
    --primary:      var(--navy);
    --primary-deep: var(--navy-deep);
    --primary-mid:  var(--navy-mid);
    --accent:       var(--gold);
    --accent-light: var(--gold-light);
    --bg:           var(--ivory);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body), sans-serif;
    background: var(--white);
    color: var(--dark);
    overflow-x: hidden;
  }

  /* nav styles provided by partials/header.ejs */

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }

  .hero-left {
    background: var(--ivory);
    display: flex;
    align-items: center;
    padding: 120px 64px 80px;
  }

  .hero-text { max-width: 500px; }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 28px;
  }

  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--navy);
  }

  .hero-heading {
    font-family: var(--font-heading), serif;
    font-size: clamp(3rem, 5.5vw, 5rem);
    font-weight: 300;
    line-height: 1.08;
    color: var(--on-ivory);
    margin-bottom: 28px;
  }

  .hero-heading em {
    font-style: italic;
    color: var(--navy);
  }

  .hero-sub {
    font-size: 1rem;
    font-weight: 300;
    color: var(--on-ivory-muted);
    line-height: 1.85;
    margin-bottom: 44px;
    max-width: 400px;
  }

  .hero-btns {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--navy);
    color: var(--white);
    padding: 15px 36px;
    border-radius: 2px;
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: background 0.2s, transform 0.2s;
    display: inline-block;
  }

  .btn-primary:hover { background: var(--navy-deep); transform: translateY(-2px); }

  .btn-ghost {
    border: 1.5px solid var(--navy-mid);
    color: var(--navy);
    padding: 14px 36px;
    border-radius: 2px;
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
    display: inline-block;
  }

  .btn-ghost:hover { border-color: var(--navy-deep); color: var(--navy-deep); transform: translateY(-2px); }

  .hero-right {
    background: var(--navy-deep);
    position: relative;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-right::before {
    content: '';
    position: absolute;
    top: 60px; right: 60px;
    width: 220px; height: 280px;
    border: 1px solid rgba(201,168,72,0.15);
    border-radius: 2px;
  }

  .hero-right::after {
    content: '';
    position: absolute;
    top: 80px; right: 80px;
    width: 220px; height: 280px;
    border: 1px solid rgba(201,168,72,0.07);
    border-radius: 2px;
  }

  .hero-right-content {
    position: relative;
    z-index: 2;
    padding: 64px;
    width: 100%;
  }

  .hero-name-large {
    font-family: var(--font-heading), serif;
    font-size: clamp(4rem, 7vw, 8rem);
    font-weight: 300;
    font-style: italic;
    color: rgba(201,168,72,0.12);
    line-height: 0.9;
    user-select: none;
    letter-spacing: -0.02em;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: rgba(201,168,72,0.12);
    border: 1px solid rgba(201,168,72,0.3);
    border-radius: 2px;
    padding: 12px 20px;
    margin-top: 32px;
  }

  .hero-badge-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--gold);
  }

  .hero-badge-text {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-light);
  }

  .hero-circle {
    position: absolute;
    top: -80px; left: -80px;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(46,66,112,0.35) 0%, transparent 70%);
  }

  /* ── MARQUEE ── */
  .marquee-bar {
    background: var(--navy);
    padding: 14px 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .marquee-track {
    display: inline-flex;
    gap: 0;
    animation: marqueeScroll 22s linear infinite;
  }

  @keyframes marqueeScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    padding: 0 32px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(232,208,138,0.8);
  }

  .marquee-dot {
    width: 4px; height: 4px;
    border-radius: 50%;
    background: rgba(201,168,72,0.4);
    flex-shrink: 0;
  }

  /* ── SERVICES ── */
  .services {
    padding: var(--section-pad);
    background: var(--white);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 64px;
    flex-wrap: wrap;
    gap: 24px;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 12px;
  }

  .section-heading {
    font-family: var(--font-heading), serif;
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    font-weight: 300;
    color: var(--dark);
    line-height: 1.1;
  }

  .section-heading em {
    font-style: italic;
    color: var(--navy);
  }

  .section-sub {
    font-size: 0.92rem;
    font-weight: 300;
    color: var(--slate);
    line-height: 1.8;
    max-width: 340px;
    text-align: right;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    max-width: 1100px;
    margin: 0 auto;
    background: var(--ivory-mid);
  }

  .service-card {
    background: var(--white);
    padding: 52px 40px;
    position: relative;
    transition: background 0.3s;
    overflow: hidden;
  }

  .service-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 40px; right: 40px;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .service-card:hover { background: var(--ivory); }
  .service-card:hover::after { transform: scaleX(1); }

  .service-num {
    font-family: var(--font-heading), serif;
    font-size: 4rem;
    font-weight: 300;
    color: var(--ivory-mid);
    line-height: 1;
    margin-bottom: 24px;
    transition: color 0.3s;
  }

  .service-card:hover .service-num { color: var(--gold-light); }

  .service-title {
    font-family: var(--font-heading), serif;
    font-size: 1.9rem;
    font-weight: 400;
    color: var(--dark);
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .service-desc {
    font-size: 0.88rem;
    font-weight: 300;
    color: var(--slate);
    line-height: 1.85;
  }

  /* ── ABOUT STRIP ── */
  .advisor-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
  }

  .advisor-left {
    background: var(--ivory);
    padding: 100px 64px;
    display: flex;
    align-items: center;
  }

  .advisor-text { max-width: 480px; }

  .advisor-quote {
    font-family: var(--font-heading), serif;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-style: italic;
    font-weight: 300;
    color: var(--on-ivory);
    line-height: 1.5;
    margin-bottom: 32px;
    position: relative;
    padding-left: 28px;
  }

  .advisor-quote::before {
    content: '';
    position: absolute;
    left: 0; top: 8px; bottom: 8px;
    width: 3px;
    background: var(--gold);
  }

  .advisor-desc {
    font-size: 0.92rem;
    font-weight: 300;
    color: var(--on-ivory-muted);
    line-height: 1.9;
    margin-bottom: 36px;
  }

  .advisor-sig {
    font-family: var(--font-heading), serif;
    font-size: 1.8rem;
    font-style: italic;
    color: var(--navy);
  }

  .advisor-right {
    background: var(--dark);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .advisor-right-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 64px;
    width: 100%;
  }

  .advisor-initial {
    font-family: var(--font-heading), serif;
    font-size: 18rem;
    font-weight: 300;
    font-style: italic;
    color: color-mix(in srgb, var(--navy) 35%, transparent);
    line-height: 1;
    user-select: none;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .advisor-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: rgba(201,168,72,0.12);
    position: relative;
    z-index: 3;
  }

  .stat-box {
    background: rgba(15,27,48,0.8);
    padding: 36px 32px;
    text-align: center;
  }

  .stat-num {
    font-family: var(--font-heading), serif;
    font-size: 3.2rem;
    font-weight: 300;
    color: var(--gold);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(253,252,250,0.35);
    margin-top: 8px;
  }

  /* ── PROCESS ── */
  .process {
    padding: var(--section-pad);
    background: var(--ivory);
  }

  .process-inner { max-width: 1100px; margin: 0 auto; }

  .process-list {
    margin-top: 64px;
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--ivory-mid);
  }

  .process-item {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    align-items: center;
    gap: 40px;
    padding: 36px 0;
    border-bottom: 1px solid var(--ivory-mid);
    cursor: default;
    transition: background 0.2s;
  }

  .process-item:hover { background: color-mix(in srgb, var(--navy) 4%, transparent); margin: 0 -20px; padding: 36px 20px; }

  .process-num {
    font-family: var(--font-heading), serif;
    font-size: 2.4rem;
    font-weight: 300;
    color: var(--gold-light);
    line-height: 1;
  }

  .process-title {
    font-family: var(--font-heading), serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--dark);
    margin-bottom: 6px;
  }

  .process-desc {
    font-size: 0.86rem;
    font-weight: 300;
    color: var(--slate);
    line-height: 1.7;
  }

  .process-arrow {
    font-size: 1.2rem;
    color: var(--gold);
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
    transform: translateX(-8px);
  }

  .process-item:hover .process-arrow { opacity: 1; transform: translateX(0); }

  /* ── CONTACT ── */
  .contact {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 700px;
  }

  .contact-left {
    background: var(--navy-deep);
    padding: 100px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-left .section-eyebrow { color: var(--gold-light); }
  .contact-left .section-heading { color: var(--white); margin-bottom: 24px; }

  .contact-sub {
    font-size: 0.92rem;
    font-weight: 300;
    color: rgba(253,252,250,0.55);
    line-height: 1.9;
    margin-bottom: 52px;
    max-width: 380px;
  }

  .contact-detail { display: flex; flex-direction: column; gap: 20px; }
  .contact-detail-item { display: flex; align-items: flex-start; gap: 16px; }

  .detail-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    min-width: 72px;
    padding-top: 2px;
  }

  .detail-value {
    font-size: 0.92rem;
    font-weight: 300;
    color: rgba(253,252,250,0.7);
    line-height: 1.6;
  }

  .contact-right {
    background: var(--ivory);
    padding: 100px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-form { display: flex; flex-direction: column; gap: 20px; max-width: 440px; }

  .form-row { display: flex; gap: 20px; }

  .form-field { flex: 1; display: flex; flex-direction: column; gap: 8px; }

  .form-field label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--on-ivory-muted);
  }

  .form-field input,
  .form-field textarea,
  .form-field select {
    background: var(--white);
    border: 1px solid var(--ivory-mid);
    border-radius: 2px;
    padding: 14px 16px;
    font-family: var(--font-body), sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--dark);
    outline: none;
    transition: border-color 0.2s;
    -webkit-appearance: none;
    appearance: none;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder { color: var(--ivory-mid); }

  .form-field input:focus,
  .form-field textarea:focus,
  .form-field select:focus { border-color: var(--navy); }

  .form-field textarea { resize: vertical; min-height: 110px; }
  .form-field select option { background: var(--white); }

  .btn-submit {
    background: var(--navy);
    color: var(--white);
    border: none;
    padding: 16px 40px;
    border-radius: 2px;
    font-family: var(--font-body), sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    align-self: flex-start;
  }

  .btn-submit:hover { background: var(--navy-deep); transform: translateY(-2px); }

  #form-msg { display: none; font-size: 0.85rem; color: var(--navy); }

  /* ── CUSTOM SECTIONS ── */
  .cs-wrap { padding: var(--section-pad); max-width: 1100px; margin: 0 auto; }
  .cs-eyebrow { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); margin-bottom: 14px; }
  .cs-heading { font-family: var(--font-heading); font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; color: var(--navy-deep); margin-bottom: 16px; }
  .cs-body { font-size: 1.05rem; line-height: 1.8; color: var(--slate); }
  .cs-body p { margin-bottom: 1em; }

  /* text */
  .cs-text { background: var(--white); }
  .cs-text .cs-wrap { max-width: 780px; }

  /* split */
  .cs-split { background: var(--ivory); }
  .cs-split .cs-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }
  .cs-split-img { width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: 4px; }
  .cs-split-img-placeholder { width: 100%; aspect-ratio: 4/3; background: var(--ivory-mid); border-radius: 4px; }
  .cs-btn { display: inline-block; margin-top: 28px; padding: 14px 32px; background: var(--navy); color: var(--white); font-family: var(--font-body); font-size: 0.82rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; transition: background 0.2s; }
  .cs-btn:hover { background: var(--gold); color: var(--dark); }

  /* cta banner */
  .cs-cta { background: var(--navy-deep); color: var(--white); text-align: center; }
  .cs-cta .cs-wrap { padding: 80px 52px; }
  .cs-cta .cs-heading { color: var(--white); }
  .cs-cta .cs-body { color: rgba(253,252,250,0.75); }
  .cs-cta-bg { position: relative; }
  .cs-cta-bg::before { content: ''; position: absolute; inset: 0; background: rgba(10,20,50,0.72); }
  .cs-cta-bg > * { position: relative; }
  .cs-cta .cs-btn { background: var(--gold); color: var(--dark); margin-top: 32px; }
  .cs-cta .cs-btn:hover { background: var(--white); }

  /* cards */
  .cs-cards { background: var(--white); }
  .cs-cards-intro { text-align: center; max-width: 640px; margin: 0 auto 52px; }
  .cs-cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 28px; }
  .cs-card { background: var(--ivory); padding: 36px 28px; }
  .cs-card-img { width: 100%; aspect-ratio: 3/2; object-fit: cover; margin-bottom: 20px; }
  .cs-card-title { font-family: var(--font-heading); font-size: 1.25rem; color: var(--navy-deep); margin-bottom: 10px; }
  .cs-card-body { font-size: 0.92rem; line-height: 1.7; color: var(--slate); }

  /* faq */
  .cs-faq { background: var(--ivory); }
  .cs-faq .cs-wrap { max-width: 780px; }
  .cs-faq-list { display: flex; flex-direction: column; gap: 4px; margin-top: 40px; }
  .cs-faq-item { border-bottom: 1px solid var(--ivory-mid); }
  .cs-faq-q { display: flex; justify-content: space-between; align-items: center; padding: 20px 0; cursor: pointer; font-weight: 500; font-size: 1rem; color: var(--navy-deep); gap: 16px; }
  .cs-faq-q::after { content: '+'; font-size: 1.3rem; color: var(--gold); flex-shrink: 0; transition: transform 0.2s; }
  .cs-faq-item.open .cs-faq-q::after { transform: rotate(45deg); }
  .cs-faq-a { display: none; padding: 0 0 20px; color: var(--slate); line-height: 1.8; font-size: 0.95rem; }
  .cs-faq-item.open .cs-faq-a { display: block; }

  @media (max-width: 768px) {
    .cs-split .cs-wrap { grid-template-columns: 1fr; gap: 36px; }
    .cs-cards-grid { grid-template-columns: 1fr; }
  }

  /* ── FOOTER ── */
  footer {
    background: var(--dark);
    padding: 64px 52px 36px;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 52px;
    flex-wrap: wrap;
    gap: 40px;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
  }

  .footer-brand-name {
    font-family: var(--font-heading), serif;
    font-size: 2.4rem;
    font-weight: 300;
    color: var(--white);
    line-height: 1.1;
  }

  .footer-brand-sub {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 6px;
  }

  .footer-logo {
    height: 56px;
    width: auto;
    object-fit: contain;
  }

  .footer-links { display: flex; gap: 36px; list-style: none; align-items: center; flex-wrap: wrap; }

  .footer-links a {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(253,252,250,0.35);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--gold-light); }

  .footer-divider { max-width: 1100px; margin: 0 auto 28px; height: 1px; background: rgba(253,252,250,0.07); }

  .footer-copy {
    max-width: 1100px;
    margin: 0 auto;
    font-size: 0.72rem;
    color: rgba(253,252,250,0.2);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; }
    .hero-right { min-height: 380px; }
    .hero-left { padding: 120px 32px 60px; }
    .services-grid { grid-template-columns: 1fr; }
    .advisor-section { grid-template-columns: 1fr; }
    .advisor-left { padding: 72px 32px; }
    .contact { grid-template-columns: 1fr; }
    .contact-left { padding: 72px 32px; }
    .contact-right { padding: 72px 32px 96px; }
    .services { padding: 72px 24px; }
    .process { padding: 72px 24px; }
    .section-header { flex-direction: column; align-items: flex-start; }
    .section-sub { text-align: left; }
    .footer-top { flex-direction: column; }
    .hero-right-content { padding: 40px 32px; }
    .form-row { flex-direction: column; }
    .btn-submit { align-self: stretch; width: 100%; padding: 18px 24px; font-size: 0.9rem; }
    .contact-form { max-width: 100%; }
  }
  /* ── FONT OVERRIDES (dynamic) ── */
  body { font-family: var(--font-body); }
  h1, h2, h3, h4,
  .hero-heading, .section-heading, .advisor-quote,
  .hero-name-large, .footer-brand-name,
  .nav-wordmark-top { font-family: var(--font-heading); }

  /* ═══════════════════════════════════════════════════════════════════════════
     LAYOUT: BOLD — full-width hero overlay, large cards
     ═══════════════════════════════════════════════════════════════════════════ */
  [data-layout="bold"] .hero {
    grid-template-columns: 1fr;
    min-height: 100vh;
    position: relative;
  }
  [data-layout="bold"] .hero-left {
    position: absolute; inset: 0; z-index: 2;
    background: rgba(15,27,48,0.55);
    display: flex; align-items: center; justify-content: center;
    padding: 120px 52px 80px; text-align: center;
  }
  [data-layout="bold"] .hero-text { max-width: 700px; }
  [data-layout="bold"] .hero-heading { color: var(--white); font-size: clamp(3.5rem,7vw,6rem); }
  [data-layout="bold"] .hero-heading em { color: var(--gold-light); }
  [data-layout="bold"] .hero-sub { color: rgba(253,252,250,0.75); margin-left: auto; margin-right: auto; }
  [data-layout="bold"] .hero-btns { justify-content: center; }
  [data-layout="bold"] .hero-right {
    grid-column: 1; grid-row: 1;
    min-height: 100vh;
  }
  [data-layout="bold"] .hero-right-content { display: none; }
  [data-layout="bold"] .hero-eyebrow { color: var(--gold-light); }
  [data-layout="bold"] .hero-eyebrow::before { background: var(--gold); }
  [data-layout="bold"] .btn-ghost { border-color: rgba(253,252,250,0.4); color: var(--white); }
  [data-layout="bold"] .btn-ghost:hover { border-color: var(--white); color: var(--white); }

  [data-layout="bold"] .services-grid { gap: 24px; background: transparent; }
  [data-layout="bold"] .service-card {
    border: 2px solid var(--ivory-mid); border-radius: 2px;
    text-align: center; padding: 56px 36px;
  }
  [data-layout="bold"] .service-card:hover { border-color: var(--gold); }
  [data-layout="bold"] .service-num { font-size: 5rem; color: var(--gold); }

  /* ═══════════════════════════════════════════════════════════════════════════
     LAYOUT: MINIMAL — centered hero, airy whitespace, clean lines
     ═══════════════════════════════════════════════════════════════════════════ */
  [data-layout="minimal"] .hero {
    grid-template-columns: 1fr;
    min-height: 90vh;
  }
  [data-layout="minimal"] .hero-left {
    justify-content: center; text-align: center;
    padding: 160px 52px 100px; background: var(--white);
  }
  [data-layout="minimal"] .hero-text { max-width: 640px; margin: 0 auto; }
  [data-layout="minimal"] .hero-heading { font-size: clamp(3rem,5vw,4.5rem); margin-bottom: 20px; }
  [data-layout="minimal"] .hero-sub { margin-left: auto; margin-right: auto; max-width: 480px; }
  [data-layout="minimal"] .hero-btns { justify-content: center; }
  [data-layout="minimal"] .hero-right { display: none; }
  [data-layout="minimal"] .hero-eyebrow { justify-content: center; }
  [data-layout="minimal"] .marquee-bar { display: none; }

  [data-layout="minimal"] .services { padding: 80px 52px; }
  [data-layout="minimal"] .section-header { flex-direction: column; align-items: center; text-align: center; }
  [data-layout="minimal"] .section-sub { text-align: center; max-width: 480px; }
  [data-layout="minimal"] .services-grid { gap: 0; background: transparent; border-top: 1px solid var(--ivory-mid); }
  [data-layout="minimal"] .service-card {
    border-bottom: 1px solid var(--ivory-mid);
    padding: 40px 32px;
    display: grid; grid-template-columns: 80px 1fr; gap: 24px; align-items: start;
  }
  [data-layout="minimal"] .service-card::after { display: none; }
  [data-layout="minimal"] .service-num { font-size: 2rem; margin-bottom: 0; }

  [data-layout="minimal"] .advisor-section { grid-template-columns: 1fr; }
  [data-layout="minimal"] .advisor-right { min-height: 300px; }
  [data-layout="minimal"] .advisor-left { justify-content: center; text-align: center; }
  [data-layout="minimal"] .advisor-quote { padding-left: 0; }
  [data-layout="minimal"] .advisor-quote::before { display: none; }

  [data-layout="minimal"] .process-item { gap: 24px; }
  [data-layout="minimal"] .contact { grid-template-columns: 1fr; }
  [data-layout="minimal"] .contact-left { text-align: center; align-items: center; padding: 72px 52px; }
  [data-layout="minimal"] .contact-right { padding: 0 52px 100px; }
  [data-layout="minimal"] .contact-form { margin: 0 auto; }

  /* ═══════════════════════════════════════════════════════════════════════════
     LAYOUT: MAGAZINE — full bg hero, overlapping content card, editorial
     ═══════════════════════════════════════════════════════════════════════════ */
  [data-layout="magazine"] .hero {
    grid-template-columns: 1fr;
    min-height: 100vh;
    position: relative;
  }
  [data-layout="magazine"] .hero-right {
    grid-column: 1; grid-row: 1;
    min-height: 100vh;
  }
  [data-layout="magazine"] .hero-right-content { display: none; }
  [data-layout="magazine"] .hero-left {
    position: absolute; bottom: -60px; left: 52px; right: 40%;
    z-index: 3; background: var(--white);
    padding: 52px 48px; box-shadow: 0 12px 48px rgba(15,27,48,0.15);
    border-radius: 2px;
  }
  [data-layout="magazine"] .hero-text { max-width: 100%; }
  [data-layout="magazine"] .hero-heading { font-size: clamp(2.2rem,4vw,3.8rem); }
  [data-layout="magazine"] .marquee-bar { margin-top: 80px; }

  [data-layout="magazine"] .section-header {
    flex-direction: column; align-items: flex-start; margin-bottom: 48px;
  }
  [data-layout="magazine"] .section-sub { text-align: left; }
  [data-layout="magazine"] .services-grid {
    grid-template-columns: 1fr 1fr; gap: 2px;
  }
  [data-layout="magazine"] .service-card:last-child {
    grid-column: 1 / -1;
    display: grid; grid-template-columns: 120px 1fr; gap: 24px; align-items: center;
  }

  [data-layout="magazine"] .advisor-section {
    grid-template-columns: 2fr 1fr;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     LAYOUT: DARK — dark-themed throughout with accent highlights
     ═══════════════════════════════════════════════════════════════════════════ */
  [data-layout="dark"] { background: var(--navy-deep); color: rgba(253,252,250,0.85); }
  /* dark nav overrides provided by partials/header.ejs */

  [data-layout="dark"] .hero-left { background: var(--navy-deep); }
  [data-layout="dark"] .hero-heading { color: var(--white); }
  [data-layout="dark"] .hero-heading em { color: var(--gold-light); }
  [data-layout="dark"] .hero-sub { color: rgba(253,252,250,0.5); }
  [data-layout="dark"] .btn-primary { background: var(--gold); color: var(--dark); }
  [data-layout="dark"] .btn-primary:hover { background: var(--gold-light); }
  [data-layout="dark"] .btn-ghost { border-color: var(--gold); color: var(--gold-light); }
  [data-layout="dark"] .hero-eyebrow { color: var(--gold); }
  [data-layout="dark"] .hero-eyebrow::before { background: var(--gold); }

  [data-layout="dark"] .services { background: var(--dark); }
  [data-layout="dark"] .services-grid { background: rgba(201,168,72,0.08); }
  [data-layout="dark"] .service-card { background: var(--navy-deep); }
  [data-layout="dark"] .service-card:hover { background: var(--navy); }
  [data-layout="dark"] .service-title { color: var(--white); }
  [data-layout="dark"] .service-desc { color: rgba(253,252,250,0.5); }
  [data-layout="dark"] .section-eyebrow { color: var(--gold); }
  [data-layout="dark"] .section-heading { color: var(--white); }
  [data-layout="dark"] .section-heading em { color: var(--gold-light); }
  [data-layout="dark"] .section-sub { color: rgba(253,252,250,0.45); }

  [data-layout="dark"] .advisor-left { background: var(--navy); }
  [data-layout="dark"] .advisor-quote { color: var(--white); }
  [data-layout="dark"] .advisor-desc { color: rgba(253,252,250,0.5); }
  [data-layout="dark"] .advisor-sig { color: var(--gold-light); }
  [data-layout="dark"] .advisor-right { background: var(--navy-deep); }

  [data-layout="dark"] .process { background: var(--dark); }
  [data-layout="dark"] .process-item { border-color: rgba(201,168,72,0.12); }
  [data-layout="dark"] .process-list { border-color: rgba(201,168,72,0.12); }
  [data-layout="dark"] .process-item:hover { background: rgba(201,168,72,0.04); }
  [data-layout="dark"] .process-title { color: var(--white); }
  [data-layout="dark"] .process-desc { color: rgba(253,252,250,0.45); }

  [data-layout="dark"] .contact-right { background: var(--navy); }
  [data-layout="dark"] .contact-right .form-field input,
  [data-layout="dark"] .contact-right .form-field textarea,
  [data-layout="dark"] .contact-right .form-field select {
    background: var(--navy-deep); border-color: rgba(201,168,72,0.15);
    color: var(--white);
  }
  [data-layout="dark"] .contact-right .form-field label { color: var(--gold); }
  [data-layout="dark"] .btn-submit { background: var(--gold); color: var(--dark); }
  [data-layout="dark"] .btn-submit:hover { background: var(--gold-light); }

  [data-layout="dark"] footer { background: #070D18; }

  /* ── DARK layout custom section overrides ── */
  [data-layout="dark"] .cs-text { background: var(--dark); }
  [data-layout="dark"] .cs-split { background: var(--navy-deep); }
  [data-layout="dark"] .cs-heading { color: var(--white); }
  [data-layout="dark"] .cs-body { color: rgba(253,252,250,0.6); }
  [data-layout="dark"] .cs-cards { background: var(--dark); }
  [data-layout="dark"] .cs-card { background: var(--navy-deep); }
  [data-layout="dark"] .cs-card-title { color: var(--white); }
  [data-layout="dark"] .cs-faq { background: var(--navy); }
  [data-layout="dark"] .cs-faq-q { color: var(--white); }
  [data-layout="dark"] .cs-faq-a { color: rgba(253,252,250,0.6); }
  [data-layout="dark"] .cs-faq-item { border-color: rgba(201,168,72,0.12); }

  /* ═══════════════════════════════════════════════════════════════════════════
     LAYOUT RESPONSIVE OVERRIDES
     ═══════════════════════════════════════════════════════════════════════════ */
  @media (max-width: 900px) {
    [data-layout="bold"] .hero-left { padding: 120px 24px 80px; }
    [data-layout="magazine"] .hero-left {
      position: relative; bottom: auto; left: auto; right: auto;
      margin: -40px 16px 0; box-shadow: 0 8px 32px rgba(15,27,48,0.12);
    }
    [data-layout="magazine"] .marquee-bar { margin-top: 24px; }
    [data-layout="magazine"] .services-grid { grid-template-columns: 1fr; }
    [data-layout="magazine"] .service-card:last-child { grid-column: auto; display: block; }
    [data-layout="magazine"] .advisor-section { grid-template-columns: 1fr; }
    [data-layout="minimal"] .hero-left { padding: 140px 24px 80px; }
    [data-layout="minimal"] .service-card { grid-template-columns: 1fr; }
  }
</style>
</head>
<body data-layout="<%= design.landing_layout || 'classic' %>">
<!-- NAV -->
<%- include('partials/header', { activePage: 'home' }) %>

<!-- HERO -->
<% if (visibility.hero) { %>
<section class="hero">
  <div class="hero-left">
    <div class="hero-text">
      <h1 class="hero-heading"><%= copy.hero_heading %></h1>
      <div class="hero-btns">
        <a href="<%= copy.hero_cta_primary_link || '#contact' %>" class="btn-primary"><%= copy.hero_cta_primary || 'Start a Project' %></a>
        <a href="<%= copy.hero_cta_secondary_link || '#services' %>" class="btn-ghost"><%= copy.hero_cta_secondary || 'Our Services' %></a>
      </div>
    </div>
  </div>
  <div class="hero-right"<% if (media.hero_image && design.model_header_enabled !== 'true') { %> style="background-image:url('<%= media.hero_image %>');background-size:cover;background-position:center;"<% } %>>
    <% if (design.model_header_enabled === 'true') { %>
      <div class="gltf-viewer" <%= (typeof brandModels !== 'undefined' && brandModels.model_header) ? 'data-model-url="' + brandModels.model_header + '"' : '' %> data-brand-name="<%= brand?.name || '' %>" data-mode="header" data-bg-color="<%= design.color_primary_deep %>" data-accent-color="<%= design.color_accent %>" data-primary-color="<%= design.color_primary %>" <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>data-debug="true"<% } %> style="width:100%;height:100%;position:absolute;inset:0;"></div>
    <% } else { %>
      <% if (!media.hero_image) { %><div class="hero-circle"></div><% } %>
    <% } %>
    <div class="hero-right-content" style="position:relative;z-index:1;">
      <% if (!media.hero_image && design.model_header_enabled !== 'true') { %><div class="hero-name-large"><%= _BI %></div><% } %>
      <div class="hero-badge">
        <div class="hero-badge-dot"></div>
        <span class="hero-badge-text"><%= copy.hero_badge %></span>
      </div>
    </div>
  </div>
</section>
<% } %>

<!-- MARQUEE -->
<% if (visibility.hero) { %>
<%
  // Build marquee items from brand services, falling back to generic
  const _marqueeItems = [];
  if (brand?.services && brand.services.length) {
    brand.services.forEach(s => _marqueeItems.push(s));
  } else {
    _marqueeItems.push('Our Services');
  }
  if (brand?.location) _marqueeItems.push(brand.location);
  if (brand?.tagline) _marqueeItems.push(brand.tagline);
  // Pad to at least 6 items for a smooth loop
  if (_marqueeItems.length < 4) {
    const fillers = ['Quality Service', 'Trusted Partner', 'Get Started Today', 'Contact Us'];
    fillers.forEach(f => { if (_marqueeItems.length < 6) _marqueeItems.push(f); });
  }
%>
<div class="marquee-bar" aria-hidden="true">
  <div class="marquee-track">
    <% for (let _r = 0; _r < 2; _r++) { %>
      <% _marqueeItems.forEach(function(item) { %>
        <span class="marquee-item"><%- item %><span class="marquee-dot"></span></span>
      <% }); %>
    <% } %>
  </div>
</div>
<% } %>

<!-- SERVICES -->
<% if (visibility.services) { %>
<section class="services" id="services">
  <div class="section-header">
    <div>
      <p class="section-eyebrow"><%= copy.services_label %></p>
      <h2 class="section-heading"><%= copy.services_heading %> <em><%= copy.services_heading_em %></em></h2>
    </div>
    <p class="section-sub"><%= copy.services_sub %></p>
  </div>

  <div class="services-grid">
    <% [[1, copy.service1_title, copy.service1_desc, copy.service1_link],
        [2, copy.service2_title, copy.service2_desc, copy.service2_link],
        [3, copy.service3_title, copy.service3_desc, copy.service3_link]].forEach(([n, title, desc, link]) => { %>
      <% if (link) { %>
      <a href="<%= link %>" class="service-card" style="text-decoration:none;color:inherit;cursor:pointer;">
      <% } else { %>
      <div class="service-card">
      <% } %>
        <div class="service-num">0<%= n %></div>
        <h3 class="service-title"><%= title %></h3>
        <p class="service-desc"><%= desc %></p>
      <% if (link) { %></a><% } else { %></div><% } %>
    <% }) %>
  </div>
</section>
<% } %>

<!-- PORTFOLIO -->
<% if (visibility.portfolio && portfolio && portfolio.length) { %>
<section id="portfolio" style="padding:100px 52px;background:var(--navy-deep);">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:64px;flex-wrap:wrap;gap:24px;">
      <div>
        <p style="font-size:0.72rem;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:var(--gold);margin-bottom:12px;">Our Work</p>
        <h2 style="font-family:var(--font-heading),serif;font-size:clamp(2.4rem,4vw,3.6rem);font-weight:300;color:var(--white);line-height:1.1;">Recent <em style="font-style:italic;color:var(--gold-light);">Projects</em></h2>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:2px;background:rgba(201,168,72,0.08);">
      <% for (const item of portfolio) { %>
      <div style="background:var(--navy);position:relative;overflow:hidden;group;">
        <% if (item.imageUrl) { %>
          <div style="aspect-ratio:16/10;overflow:hidden;">
            <img src="<%= item.imageUrl %>" alt="<%= item.title %>" style="width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.5s ease;" onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'">
          </div>
        <% } else { %>
          <div style="aspect-ratio:16/10;background:color-mix(in srgb, var(--navy) 60%, transparent);display:flex;align-items:center;justify-content:center;">
            <span style="font-family:var(--font-heading);font-size:3rem;font-weight:300;font-style:italic;color:color-mix(in srgb, var(--gold) 20%, transparent);"><%= item.title.charAt(0) %></span>
          </div>
        <% } %>
        <div style="padding:28px 28px 32px;">
          <% if (item.category) { %>
            <p style="font-size:0.62rem;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:var(--gold);margin-bottom:8px;"><%= item.category %></p>
          <% } %>
          <h3 style="font-family:var(--font-heading),serif;font-size:1.5rem;font-weight:400;color:var(--white);line-height:1.2;margin-bottom:10px;"><%= item.title %></h3>
          <% if (item.description) { %>
            <p style="font-size:0.85rem;font-weight:300;color:rgba(253,252,250,0.55);line-height:1.7;"><%= item.description.length > 120 ? item.description.slice(0,120).trim() + '…' : item.description %></p>
          <% } %>
          <% if (item.clientName) { %>
            <p style="font-size:0.68rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(201,168,72,0.5);margin-top:16px;"><%= item.clientName %></p>
          <% } %>
        </div>
        <div style="position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--gold),var(--gold-light));"></div>
      </div>
      <% } %>
    </div>
  </div>
</section>
<% } %>

<!-- ABOUT -->
<% if (visibility.about) { %>
<section class="advisor-section" id="about">
  <div class="advisor-left">
    <div class="advisor-text">
      <p class="section-eyebrow"><%= copy.about_eyebrow %></p>
      <blockquote class="advisor-quote">
        <%= copy.about_quote %>
      </blockquote>
      <p class="advisor-desc"><%= copy.about_desc %></p>
      <div class="advisor-sig"><%= copy.about_sig %></div>
    </div>
  </div>
  <div class="advisor-right">
    <% if (copy.about_initial) { %><div class="advisor-initial"><%= copy.about_initial %></div><% } %>
    <div class="advisor-right-inner">
      <div class="advisor-stats">
        <% if (copy.about_stat1_num) { %>
        <div class="stat-box">
          <div class="stat-num"><%= copy.about_stat1_num %></div>
          <div class="stat-label"><%= copy.about_stat1_label %></div>
        </div>
        <% } %>
        <% if (copy.about_stat2_num) { %>
        <div class="stat-box">
          <div class="stat-num"><%= copy.about_stat2_num %></div>
          <div class="stat-label"><%= copy.about_stat2_label %></div>
        </div>
        <% } %>
        <% if (copy.about_stat3_num) { %>
        <div class="stat-box">
          <div class="stat-num"><%= copy.about_stat3_num %></div>
          <div class="stat-label"><%= copy.about_stat3_label %></div>
        </div>
        <% } %>
        <% if (copy.about_stat4_num) { %>
        <div class="stat-box">
          <div class="stat-num"><%= copy.about_stat4_num %></div>
          <div class="stat-label"><%= copy.about_stat4_label %></div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
<% } %>

<!-- PROCESS -->
<% if (visibility.process) { %>
<section class="process" id="process">
  <div class="process-inner">
    <div>
      <p class="section-eyebrow"><%= copy.process_label %></p>
      <h2 class="section-heading"><%= copy.process_heading %> <em><%= copy.process_heading_em %></em></h2>
    </div>
    <div class="process-list">
      <% [[copy.process1_title, copy.process1_desc], [copy.process2_title, copy.process2_desc], [copy.process3_title, copy.process3_desc], [copy.process4_title, copy.process4_desc]].forEach(function(step, i) { %>
        <% if (step[0]) { %>
        <div class="process-item">
          <div class="process-num"><%= String(i + 1).padStart(2, '0') %></div>
          <div>
            <div class="process-title"><%- step[0] %></div>
            <div class="process-desc"><%- step[1] || '' %></div>
          </div>
          <div class="process-arrow">→</div>
        </div>
        <% } %>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- REVIEWS -->
<% if (visibility.reviews && reviews && reviews.reviews && reviews.reviews.length) { %>
<section style="padding:100px 52px;background:var(--ivory);">
