      <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
        <a href="/superadmin" style="color:rgba(253,252,250,0.15);text-decoration:none;font-size:0.7rem;letter-spacing:0.04em;margin-left:12px;transition:color 0.2s;" onmouseover="this.style.color='rgba(253,252,250,0.35)'" onmouseout="this.style.color='rgba(253,252,250,0.15)'">&loz;</a>
      <% } %>
