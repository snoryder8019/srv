<!-- BLOG TEASER -->
<% if (visibility.blog && latestPosts && latestPosts.length) { %>
<section style="padding:100px 52px;background:var(--ivory);">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:64px;flex-wrap:wrap;gap:24px;">
      <div>
        <p style="font-size:0.72rem;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:var(--navy);margin-bottom:12px;">From The Blog</p>
        <h2 style="font-family:var(--font-heading);font-size:clamp(2.4rem,4vw,3.6rem);font-weight:300;color:var(--dark);line-height:1.1;">Latest <em style="font-style:italic;color:var(--navy);">Insights</em></h2>
