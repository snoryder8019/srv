  });
  document.addEventListener('click', function() {
    if (open) { open = false; popup.style.opacity = '0'; popup.style.transform = 'translateY(10px)'; setTimeout(function() { popup.style.display = 'none'; }, 260); }
  });
  popup.addEventListener('click', function(e) { e.stopPropagation(); });
})();
