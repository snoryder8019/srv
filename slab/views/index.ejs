      <div class="form-field">
        <label><%= copy.contact_email_label %></label>
        <input type="email" name="email" placeholder="<%= copy.contact_email_placeholder %>" required>
      </div>
      <div class="form-field">
        <label><%= copy.contact_company_label %></label>
        <input type="text" name="company" placeholder="<%= copy.contact_company_placeholder %>">
      </div>
      <div class="form-field">
        <label><%= copy.contact_service_label %></label>
        <select name="service">
          <option value=""><%= copy.contact_service_placeholder %></option>
          <% if (brand?.services?.length) { %>
            <% brand.services.forEach(function(svc) { %>
              <option><%- svc %></option>
            <% }); %>
