<!-- SCROLL-DOT NAVIGATION (snap/showcase layouts) -->
<% if (design.snap_enabled === 'true') { %>
<nav class="scroll-dots" id="scrollDots" aria-label="Page sections"></nav>
<script>
(function() {
  var dotsNav = document.getElementById('scrollDots');
  if (!dotsNav) return;

  var isShowcase = document.body.dataset.layout === 'showcase';

  // ── Collect sections ──
  var sections = [];
  var hero = document.querySelector('.hero');
  if (hero) sections.push(hero);

  if (isShowcase) {
    document.querySelectorAll('.service-card').forEach(function(c) { sections.push(c); });
  } else {
    var svc = document.querySelector('.services');
    if (svc) sections.push(svc);
  }
  ['.advisor', '.portfolio', '.process', '.reviews-section', '.contact'].forEach(function(sel) {
    var el = document.querySelector(sel);
    if (el) sections.push(el);
  });
  document.querySelectorAll('.custom-section').forEach(function(el) { sections.push(el); });

  if (sections.length < 2) { dotsNav.style.display = 'none'; return; }

  // ── Wrap sections into a snap container ──
  document.documentElement.classList.add('snap-active');
  var container = document.createElement('div');
  container.className = 'snap-container';

  // Move all body children into the container
  while (document.body.firstChild) {
    container.appendChild(document.body.firstChild);
  }
  document.body.appendChild(container);
  // Re-append dots on top
  document.body.appendChild(dotsNav);

  // Tag each section
  sections.forEach(function(s) { s.classList.add('snap-section'); });

  // ── State ──
  var current = 0;
  var locked = false;
  var totalSections = sections.length;

  function goTo(idx) {
    if (idx < 0 || idx >= totalSections || idx === current || locked) return;
    locked = true;
    current = idx;
    container.style.transform = 'translateY(-' + (current * 100) + 'vh)';
    dots.forEach(function(d, j) { d.classList.toggle('active', j === current); });

    // Last section: allow internal scroll
    if (current === totalSections - 1) {
      sections[current].style.overflow = 'auto';
    } else {
      sections.forEach(function(s) { s.style.overflow = 'hidden'; });
    }

    setTimeout(function() { locked = false; }, 850);
  }

  // ── Build dots ──
  var dots = [];
  sections.forEach(function(sec, i) {
    var dot = document.createElement('div');
    dot.className = 'scroll-dot' + (i === 0 ? ' active' : '');
    dot.addEventListener('click', function() { goTo(i); });
    dotsNav.appendChild(dot);
    dots.push(dot);
  });

  // ── Wheel handler ──
  document.addEventListener('wheel', function(e) {
    if (locked) { e.preventDefault(); return; }

    // On last section: let it scroll naturally inside
    // Only snap back up when scrolled to the very top of that section
    if (current === totalSections - 1) {
      var sec = sections[current];
      if (e.deltaY < 0 && sec.scrollTop <= 0) {
        e.preventDefault();
        goTo(current - 1);
      }
      // deltaY > 0 = scrolling down — let it flow naturally inside the section
      return;
    }

    e.preventDefault();
    if (e.deltaY > 0) goTo(current + 1);
    else if (e.deltaY < 0) goTo(current - 1);
  }, { passive: false });

  // ── Touch support ──
  var touchStartY = 0;
  document.addEventListener('touchstart', function(e) {
    touchStartY = e.touches[0].clientY;
  }, { passive: true });
  document.addEventListener('touchend', function(e) {
    var diff = touchStartY - e.changedTouches[0].clientY;
    if (Math.abs(diff) > 50) {
      if (diff > 0) goTo(current + 1);
      else goTo(current - 1);
    }
  }, { passive: true });

  // ── Keyboard ──
  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowDown' || e.key === 'PageDown') { e.preventDefault(); goTo(current + 1); }
    if (e.key === 'ArrowUp' || e.key === 'PageUp') { e.preventDefault(); goTo(current - 1); }
    if (e.key === 'Home') { e.preventDefault(); goTo(0); }
    if (e.key === 'End') { e.preventDefault(); goTo(totalSections - 1); }
  });
})();
</script>
<% } %>

<script>
  // Show success message if redirected back after contact form submission
  if (new URLSearchParams(window.location.search).get('contacted')) {
    const msg = document.getElementById('form-msg');
    if (msg) {
      msg.style.display = 'block';
      msg.style.color = 'var(--navy)';
      msg.style.fontSize = '0.85rem';
      msg.style.marginTop = '8px';
      msg.textContent = '✓ Message received! We\'ll be in touch within 1 business day.';
    }
  }

  <% if (design.section_animation !== 'none') { %>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.service-card, .process-item, .stat-box').forEach(el => {
    el.classList.add('reveal');
    observer.observe(el);
  });
  <% } %>

  // FAQ accordion
  document.querySelectorAll('.cs-faq-q').forEach(q => {
    q.addEventListener('click', () => {
      q.closest('.cs-faq-item').classList.toggle('open');
    });
  });

  // Mobile keyboard: scroll send button into view when keyboard opens
  if (window.visualViewport && /Mobi|Android|iPhone|iPad/i.test(navigator.userAgent)) {
    const submitBtn = document.querySelector('.btn-submit');
    const contactForm = document.getElementById('contact-form');
    let keyboardOpen = false;
    const initialVH = window.visualViewport.height;

    window.visualViewport.addEventListener('resize', () => {
      const shrunk = window.visualViewport.height < initialVH * 0.75;
      if (shrunk && !keyboardOpen) {
        keyboardOpen = true;
        setTimeout(() => submitBtn.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 120);
      } else if (!shrunk) {
        keyboardOpen = false;
      }
    });

    contactForm.querySelectorAll('input, textarea, select').forEach(field => {
      field.addEventListener('focus', () => {
        setTimeout(() => {
          if (window.visualViewport.height < initialVH * 0.75) {
            submitBtn.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          }
        }, 400);
      });
    });
  }
</script>

