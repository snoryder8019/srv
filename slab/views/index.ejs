          <% } %>
          <div style="padding:24px;">
            <% if (bp.category) { %><div style="font-size:0.62rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;"><%= bp.category %></div><% } %>
            <div style="font-family:var(--font-heading);font-size:1.2rem;font-weight:400;color:var(--dark);line-height:1.3;margin-bottom:10px;"><%= bp.title %></div>
            <% if (bp.excerpt) { %><div style="font-size:0.85rem;font-weight:300;color:var(--slate);line-height:1.7;"><%= bp.excerpt.substring(0,120) %><%= bp.excerpt.length > 120 ? '…' : '' %></div><% } %>
