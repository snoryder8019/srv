<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta property="og:title" content="<%= brand?.name || 'Home' %> | <%= brand?.location || '' %>" />
  <meta property="og:description" content="<%= brand?.tagline || '' %>" />
  <title><%= brand?.name || 'Home' %> | <%= brand?.location || '' %></title>
  <%
    const _BI_auto = (brand?.name || '').split(/\s+/).map(w => w[0]).join('').toUpperCase();
    const _BI = (design.hero_name_large && design.hero_name_large.trim()) || _BI_auto;
    const _sp = (brand?.name || '').indexOf(' ') > 0 ? (brand.name.indexOf(' ')) : 0;
  %>
  <%- include('partials/font-vars') %>
  <%- include('partials/landing-styles') %>
</head>
<body data-layout="<%= design.landing_layout || 'classic' %>" data-gradient="<%= design.gradient_enabled || 'false' %>" data-card-hover-accent="<%= design.card_hover_accent || 'true' %>" data-hero-pattern="<%= design.hero_bg_pattern || 'none' %>">

<% if (visibility.header !== false) { %>
<%- include('partials/header', { activePage: 'home' }) %>
<% } %>

<!-- HERO -->
<% if (visibility.hero) { %>
<section class="hero">
  <div class="hero-left">
    <div class="hero-text">
      <% if (logos.logo_primary && (design.landing_layout === 'showcase' || design.landing_layout === 'industrial')) { %>
        <img src="<%= logos.logo_primary %>" alt="<%= brand?.name || '' %>" style="max-width:min(280px,60vw);margin:0 auto 2rem;display:block;filter:brightness(1.1);">
      <% } %>
      <% if (copy.hero_eyebrow) { %><p class="hero-eyebrow"><%= copy.hero_eyebrow %></p><% } %>
      <h1 class="hero-heading"><%= copy.hero_heading %><% if (copy.hero_heading_em) { %> <em><%= copy.hero_heading_em %></em><% } %></h1>
      <% if (copy.hero_sub) { %><p class="hero-sub"><%= copy.hero_sub %></p><% } %>
      <div class="hero-btns">
        <% if (copy.hero_cta_primary) { %><a href="<%= copy.hero_cta_primary_link || '#contact' %>" class="btn-primary"><%= copy.hero_cta_primary %></a><% } %>
        <% if (copy.hero_cta_secondary) { %><a href="<%= copy.hero_cta_secondary_link || '#services' %>" class="btn-ghost"><%= copy.hero_cta_secondary %></a><% } %>
      </div>
    </div>
  </div>
  <div class="hero-right"<% if (media.hero_image) { %> style="background-image:url('<%= media.hero_image %>');background-size:cover;background-position:center;"<% } %>>
    <% if (!media.hero_image) { %><div class="hero-circle"></div><% } %>
    <div class="hero-right-content" style="position:relative;z-index:1;">
      <% if (!media.hero_image) { %><div class="hero-name-large"><%= _BI %></div><% } %>
      <% if (copy.hero_badge) { %>
      <div class="hero-badge">
        <div class="hero-badge-dot"></div>
        <span class="hero-badge-text"><%= copy.hero_badge %></span>
      </div>
      <% } %>
    </div>
  </div>
</section>
<% } %>

<!-- MARQUEE / TICKER -->
<% if (visibility.hero && visibility.marquee !== false) { %>
<%
  let _marqueeItems = [];
  const _customTicker = (design.ticker_items || '').trim();
  if (_customTicker) {
    _marqueeItems = _customTicker.split('|').map(s => s.trim()).filter(Boolean);
  } else {
    if (brand?.services && brand.services.length) {
      brand.services.forEach(s => _marqueeItems.push(s));
    } else {
      _marqueeItems.push('Our Services');
    }
    if (brand?.location) _marqueeItems.push(brand.location);
    if (brand?.tagline) _marqueeItems.push(brand.tagline);
    if (_marqueeItems.length < 4) {
      ['Quality Service', 'Trusted Partner', 'Get Started Today', 'Contact Us'].forEach(f => { if (_marqueeItems.length < 6) _marqueeItems.push(f); });
    }
  }
  while (_marqueeItems.length > 0 && _marqueeItems.length < 4) _marqueeItems = _marqueeItems.concat(_marqueeItems);
%>
<% if (_marqueeItems.length) { %>
<div class="marquee-bar" data-direction="<%= design.ticker_direction || 'left' %>" aria-hidden="true">
  <div class="marquee-track">
    <% for (let _r = 0; _r < 2; _r++) { %>
      <% _marqueeItems.forEach(function(item) { %>
        <span class="marquee-item"><%- item %><span class="marquee-dot"></span></span>
      <% }); %>
    <% } %>
  </div>
</div>
<% } %>
<% } %>

<!-- SERVICES -->
<% if (visibility.services) { %>
<section class="services" id="services">
  <div class="section-header">
    <div>
      <p class="section-eyebrow"><%= copy.services_label %></p>
      <h2 class="section-heading"><%= copy.services_heading %> <em><%= copy.services_heading_em %></em></h2>
    </div>
    <p class="section-sub"><%= copy.services_sub %></p>
  </div>
  <div class="services-grid">
    <% [[1, copy.service1_title, copy.service1_desc, copy.service1_link, copy.service1_image],
        [2, copy.service2_title, copy.service2_desc, copy.service2_link, copy.service2_image],
        [3, copy.service3_title, copy.service3_desc, copy.service3_link, copy.service3_image]].forEach(([n, title, desc, link, image]) => { %>
      <% if (link) { %><a href="<%= link %>" class="service-card" style="text-decoration:none;color:inherit;"><% } else { %><div class="service-card"><% } %>
        <% if (image) { %><img src="<%= image %>" alt="<%= title %>" style="max-width:min(320px,70vw);max-height:120px;object-fit:contain;margin-bottom:24px;"><% } %>
        <div class="service-num">0<%= n %></div>
        <h3 class="service-title"><%= title %></h3>
        <p class="service-desc"><%= desc %></p>
        <% if (link) { %><span class="service-link">Visit →</span></a><% } else { %></div><% } %>
    <% }) %>
  </div>
</section>
<% } %>

<!-- PORTFOLIO -->
<% if (visibility.portfolio && portfolio && portfolio.length) { %>
<section id="portfolio" style="padding:100px 52px;background:var(--navy-deep);">
  <div style="max-width:1100px;margin:0 auto;">
    <div class="section-header">
      <div>
        <p class="section-eyebrow" style="color:var(--gold);">Our Work</p>
        <h2 class="section-heading" style="color:var(--white);">Recent <em style="color:var(--gold-light);">Projects</em></h2>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:2px;background:rgba(201,168,72,0.08);">
      <% for (const item of portfolio) { %>
      <div style="background:var(--navy);position:relative;overflow:hidden;">
        <% if (item.imageUrl) { %>
          <div style="aspect-ratio:16/10;overflow:hidden;"><img src="<%= item.imageUrl %>" alt="<%= item.title %>" style="width:100%;height:100%;object-fit:cover;display:block;"></div>
        <% } %>
        <div style="padding:28px 28px 32px;">
          <% if (item.category) { %><p style="font-size:0.62rem;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:var(--gold);margin-bottom:8px;"><%= item.category %></p><% } %>
          <h3 style="font-family:var(--font-heading),serif;font-size:1.5rem;font-weight:400;color:var(--white);margin-bottom:10px;"><%= item.title %></h3>
          <% if (item.description) { %><p style="font-size:0.85rem;color:rgba(253,252,250,0.55);line-height:1.7;"><%= item.description.length > 120 ? item.description.slice(0,120).trim() + '…' : item.description %></p><% } %>
          <% if (item.clientName) { %><p style="font-size:0.68rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(201,168,72,0.5);margin-top:16px;"><%= item.clientName %></p><% } %>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</section>
<% } %>

<!-- ABOUT -->
<% if (visibility.about) { %>
<section class="advisor-section" id="about">
  <div class="advisor-left">
    <div class="advisor-text">
      <p class="section-eyebrow"><%= copy.about_eyebrow %></p>
      <blockquote class="advisor-quote"><%= copy.about_quote %></blockquote>
      <p class="advisor-desc"><%= copy.about_desc %></p>
      <div class="advisor-sig"><%= copy.about_sig %></div>
    </div>
  </div>
  <div class="advisor-right">
    <% if (copy.about_initial) { %><div class="advisor-initial"><%= copy.about_initial %></div><% } %>
    <div class="advisor-right-inner">
      <div class="advisor-stats">
        <% [1,2,3,4].forEach(function(n) { %>
          <% if (copy['about_stat'+n+'_num']) { %>
          <div class="stat-box">
            <div class="stat-num"><%= copy['about_stat'+n+'_num'] %></div>
            <div class="stat-label"><%= copy['about_stat'+n+'_label'] %></div>
          </div>
          <% } %>
        <% }); %>
      </div>
    </div>
  </div>
</section>
<% } %>

<!-- PROCESS -->
<% if (visibility.process) { %>
<section class="process" id="process">
  <div class="process-inner">
    <div>
      <p class="section-eyebrow"><%= copy.process_label %></p>
      <h2 class="section-heading"><%= copy.process_heading %> <em><%= copy.process_heading_em %></em></h2>
    </div>
    <div class="process-list">
      <% [[copy.process1_title, copy.process1_desc], [copy.process2_title, copy.process2_desc], [copy.process3_title, copy.process3_desc], [copy.process4_title, copy.process4_desc]].forEach(function(step, i) { %>
        <% if (step[0]) { %>
        <div class="process-item">
          <div class="process-num"><%= String(i + 1).padStart(2, '0') %></div>
          <div>
            <div class="process-title"><%- step[0] %></div>
            <div class="process-desc"><%- step[1] || '' %></div>
          </div>
          <div class="process-arrow">→</div>
        </div>
        <% } %>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- REVIEWS -->
<% if (visibility.reviews && reviews && reviews.reviews && reviews.reviews.length) { %>
<section style="padding:100px 52px;background:var(--ivory);">
  <div style="max-width:1100px;margin:0 auto;">
    <div class="section-header">
      <div>
        <p class="section-eyebrow">Google Reviews</p>
        <h2 class="section-heading">What our <em>clients say</em></h2>
      </div>
      <div style="text-align:right;">
        <div style="font-family:var(--font-heading);font-size:3.6rem;font-weight:300;color:var(--navy);line-height:1;"><%= reviews.rating.toFixed(1) %></div>
        <div style="display:flex;gap:3px;justify-content:flex-end;margin:6px 0;">
          <% for (let i=1;i<=5;i++) { %><span style="color:<%= i<=Math.round(reviews.rating)?'var(--gold)':'var(--border)' %>;">★</span><% } %>
        </div>
        <div style="font-size:0.72rem;color:var(--on-ivory-muted);"><%= reviews.user_ratings_total %> Reviews</div>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:2px;background:var(--border);">
      <% for (const r of reviews.reviews) { %>
      <div style="background:var(--surface);padding:40px 36px;">
        <div style="display:flex;gap:3px;margin-bottom:18px;"><% for (let i=1;i<=5;i++) { %><span style="color:<%= i<=r.rating?'var(--gold)':'var(--border)' %>;">★</span><% } %></div>
        <p style="font-family:var(--font-heading);font-style:italic;color:var(--on-surface);line-height:1.7;margin-bottom:24px;">"<%= r.text.length > 220 ? r.text.slice(0,220).trim() + '…' : r.text %>"</p>
        <div style="font-size:0.82rem;font-weight:600;color:var(--on-surface);"><%= r.author_name %></div>
        <div style="font-size:0.7rem;color:var(--on-surface-muted);"><%= r.relative_time_description %></div>
      </div>
      <% } %>
    </div>
  </div>
</section>
<% } %>

<!-- BLOG TEASER -->
<% if (visibility.blog && latestPosts && latestPosts.length) { %>
<section style="padding:100px 52px;background:var(--ivory);">
  <div style="max-width:1100px;margin:0 auto;">
    <div class="section-header">
      <div>
        <p class="section-eyebrow">From The Blog</p>
        <h2 class="section-heading">Latest <em>Insights</em></h2>
      </div>
      <a href="/blog" style="font-size:0.78rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--navy);text-decoration:none;border-bottom:1px solid var(--gold);padding-bottom:2px;">View All</a>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:32px;">
      <% latestPosts.forEach(bp => { %>
        <a href="/blog/<%= bp.slug %>" style="display:block;background:var(--surface);border:1px solid var(--border);border-radius:2px;overflow:hidden;text-decoration:none;">
          <% if (bp.featuredImageUrl) { %><img src="<%= bp.featuredImageUrl %>" alt="<%= bp.title %>" style="width:100%;height:180px;object-fit:cover;"><% } %>
          <div style="padding:24px;">
            <% if (bp.category) { %><div style="font-size:0.62rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;"><%= bp.category %></div><% } %>
            <div style="font-family:var(--font-heading);font-size:1.2rem;color:var(--on-surface);margin-bottom:10px;"><%= bp.title %></div>
            <% if (bp.excerpt) { %><div style="font-size:0.85rem;color:var(--on-surface-muted);line-height:1.7;"><%= bp.excerpt.substring(0,120) %><%= bp.excerpt.length > 120 ? '…' : '' %></div><% } %>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- CONTACT -->
<% if (visibility.contact) { %>
<section class="contact" id="contact">
  <div class="contact-left">
    <p class="section-eyebrow"><%= copy.contact_eyebrow || 'Get In Touch' %></p>
    <h2 class="section-heading"><%= copy.contact_heading || "Let's Work" %><br><em><%= copy.contact_heading_em || 'Together' %></em></h2>
    <p class="contact-sub"><%= copy.contact_sub %></p>
    <div class="contact-detail">
      <div class="contact-detail-item"><span class="detail-label"><%= copy.contact_location_label || 'Location' %></span><span class="detail-value"><%= copy.contact_location %></span></div>
      <div class="contact-detail-item"><span class="detail-label"><%= copy.contact_serving_label || 'Serving' %></span><span class="detail-value"><%= copy.contact_serving %></span></div>
      <% if (brand?.services?.length || copy.contact_services) { %>
      <div class="contact-detail-item"><span class="detail-label"><%= copy.contact_services_label || 'Services' %></span><span class="detail-value"><%= copy.contact_services || (brand?.services || []).join(' · ') %></span></div>
      <% } %>
    </div>
  </div>
  <div class="contact-right">
    <form class="contact-form" id="contact-form" method="POST" action="/contact">
      <div class="form-row">
        <div class="form-field"><label><%= copy.contact_fname_label %></label><input type="text" name="firstName" placeholder="<%= copy.contact_fname_placeholder %>" required></div>
        <div class="form-field"><label><%= copy.contact_lname_label %></label><input type="text" name="lastName" placeholder="<%= copy.contact_lname_placeholder %>" required></div>
      </div>
      <div class="form-field"><label><%= copy.contact_email_label %></label><input type="email" name="email" placeholder="<%= copy.contact_email_placeholder %>" required></div>
      <div class="form-field showcase-hide"><label><%= copy.contact_company_label %></label><input type="text" name="company" placeholder="<%= copy.contact_company_placeholder %>"></div>
      <div class="form-field showcase-hide">
        <label><%= copy.contact_service_label %></label>
        <select name="service">
          <option value=""><%= copy.contact_service_placeholder %></option>
          <% if (brand?.services?.length) { %>
            <% brand.services.forEach(function(svc) { %><option><%- svc %></option><% }); %>
            <option><%= copy.contact_service_extra %></option>
          <% } else { %>
            <option><%= copy.contact_service_fallback %></option>
          <% } %>
        </select>
      </div>
      <div class="form-field"><label><%= copy.contact_message_label %></label><textarea name="message" placeholder="<%= copy.contact_message_placeholder %>"></textarea></div>
      <button type="submit" class="btn-submit"><%= copy.contact_btn %></button>
      <div id="form-msg"></div>
    </form>
  </div>
</section>
<% } %>

<!-- CUSTOM SECTIONS -->
<% if (customSections && customSections.length) { %>
<% customSections.forEach(function(sec) { %>
  <% const f = sec.fields || {}; const imgs = sec.images || {}; %>
  <% if (sec.type === 'text') { %>
  <section class="cs-text"><div class="cs-wrap">
    <% if (f.heading) { %><h2 class="cs-heading"><%- f.heading %></h2><% } %>
    <% if (f.subheading) { %><p class="cs-eyebrow"><%- f.subheading %></p><% } %>
    <% if (f.body) { %><div class="cs-body"><%- f.body %></div><% } %>
  </div></section>
  <% } else if (sec.type === 'split') { %>
  <section class="cs-split"><div class="cs-wrap">
    <div>
      <% if (f.heading) { %><h2 class="cs-heading"><%- f.heading %></h2><% } %>
      <% if (f.body) { %><div class="cs-body"><%- f.body %></div><% } %>
      <% if (f.cta_text && f.cta_link) { %><a href="<%- f.cta_link %>" class="cs-btn"><%- f.cta_text %></a><% } %>
    </div>
    <div>
      <% if (imgs.main_image) { %><img src="<%- imgs.main_image %>" alt="" class="cs-split-img"><% } else { %><div class="cs-split-img-placeholder"></div><% } %>
    </div>
  </div></section>
  <% } else if (sec.type === 'cta') { %>
  <section class="cs-cta<% if (imgs.bg_image) { %> cs-cta-bg<% } %>"<% if (imgs.bg_image) { %> style="background-image:url('<%- imgs.bg_image %>');background-size:cover;background-position:center"<% } %>>
    <div class="cs-wrap">
      <% if (f.heading) { %><h2 class="cs-heading"><%- f.heading %></h2><% } %>
      <% if (f.subtext) { %><div class="cs-body"><%- f.subtext %></div><% } %>
      <% if (f.btn_text && f.btn_link) { %><a href="<%- f.btn_link %>" class="cs-btn"><%- f.btn_text %></a><% } %>
    </div>
  </section>
  <% } else if (sec.type === 'cards') { %>
  <section class="cs-cards"><div class="cs-wrap">
    <div class="cs-cards-intro">
      <% if (f.heading) { %><h2 class="cs-heading"><%- f.heading %></h2><% } %>
      <% if (f.subtext) { %><p class="cs-body"><%- f.subtext %></p><% } %>
    </div>
    <div class="cs-cards-grid">
      <% [1,2,3,4].forEach(function(n) { %>
        <% if (f['card'+n+'_title'] || f['card'+n+'_body']) { %>
        <div class="cs-card">
          <% if (imgs['card'+n+'_image']) { %><img src="<%- imgs['card'+n+'_image'] %>" alt="" class="cs-card-img"><% } %>
          <% if (f['card'+n+'_title']) { %><div class="cs-card-title"><%- f['card'+n+'_title'] %></div><% } %>
          <% if (f['card'+n+'_body']) { %><div class="cs-card-body"><%- f['card'+n+'_body'] %></div><% } %>
        </div>
        <% } %>
      <% }); %>
    </div>
  </div></section>
  <% } else if (sec.type === 'faq') { %>
  <section class="cs-faq"><div class="cs-wrap">
    <% if (f.heading) { %><h2 class="cs-heading"><%- f.heading %></h2><% } %>
    <div class="cs-faq-list">
      <% [1,2,3,4,5].forEach(function(n) { %>
        <% if (f['q'+n] && f['a'+n]) { %>
        <div class="cs-faq-item">
          <div class="cs-faq-q"><%- f['q'+n] %></div>
          <div class="cs-faq-a"><%- f['a'+n] %></div>
        </div>
        <% } %>
      <% }); %>
    </div>
  </div></section>
  <% } %>
<% }); %>
<% } %>

<!-- FOOTER -->
<% if (visibility.footer !== false) { %>
<footer>
  <div class="footer-top">
    <div>
      <% const footerLogo = logos.logo_white || logos.logo_primary; %>
      <% if (footerLogo && (design.nav_logo_display === 'image' || design.nav_logo_display === 'both')) { %>
        <img src="<%= footerLogo %>" alt="<%= brand?.name || '' %>" class="footer-logo">
      <% } %>
      <% if (design.nav_logo_display !== 'image' || !footerLogo) { %>
        <div class="footer-brand-name"><% if (_sp > 0) { %><span style="color:var(--gold-light);"><%- (brand?.name||'').slice(0,_sp) %></span><%- (brand?.name||'').slice(_sp) %><% } else { %><%- brand?.name || '' %><% } %></div>
      <% } %>
      <div class="footer-brand-sub"><%= brand?.services?.length ? brand.services.slice(0,3).join(' • ') : (brand?.businessType || '') %><%= brand?.location ? ' • ' + brand.location : '' %></div>
    </div>
    <ul class="footer-links">
      <li><a href="#services">Services</a></li>
      <li><a href="#about">About</a></li>
      <% if (typeof navPages !== 'undefined' && navPages.length) { %>
        <% navPages.forEach(function(pg) { %><li><a href="/<%= pg.slug %>"><%- pg.title %></a></li><% }); %>
      <% } %>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </div>
  <div class="footer-divider"></div>
  <div class="footer-copy">
    <span>&copy; <%= new Date().getFullYear() %> <%= brand?.name || '' %> — <%= brand?.location || '' %>. All rights reserved.</span>
    <span>
      <% if (visibility.admin_link !== false) { %>
        <a href="<%= typeof centralAuthUrl !== 'undefined' && centralAuthUrl ? centralAuthUrl : '/admin/login' %>" style="color:rgba(253,252,250,0.15);text-decoration:none;font-size:0.7rem;">Admin</a>
      <% } %>
    </span>
  </div>
</footer>
<% } %>

<script>
  if (new URLSearchParams(window.location.search).get('contacted')) {
    const msg = document.getElementById('form-msg');
    if (msg) { msg.style.display = 'block'; msg.textContent = '✓ Message received! We\'ll be in touch soon.'; }
  }
  <% if (design.section_animation && design.section_animation !== 'none') { %>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.service-card, .process-item, .stat-box').forEach(el => { el.classList.add('reveal'); observer.observe(el); });
  <% } %>
  document.querySelectorAll('.cs-faq-q').forEach(q => {
    q.addEventListener('click', () => q.closest('.cs-faq-item').classList.toggle('open'));
  });
</script>

<script>
(function(){
  if (window === window.top) return;
  window.addEventListener('message', function(e) {
    if (!e.data || e.data.type !== 'slab-live-preview') return;
    var d = e.data;
    if (d.cssVars) {
      var s = document.getElementById('slab-live-vars');
      if (!s) { s = document.createElement('style'); s.id = 'slab-live-vars'; document.head.appendChild(s); }
      var css = ':root{';
      var keys = Object.keys(d.cssVars);
      for (var i = 0; i < keys.length; i++) css += keys[i] + ':' + d.cssVars[keys[i]] + ' !important;';
      css += '}';
      if (d.extraCss) css += d.extraCss;
      s.textContent = css;
    }
    if (d.layout) document.body.setAttribute('data-layout', d.layout);
    if (d.bodyAttrs) {
      var aKeys = Object.keys(d.bodyAttrs);
      for (var ai = 0; ai < aKeys.length; ai++) document.body.setAttribute('data-' + aKeys[ai], d.bodyAttrs[aKeys[ai]]);
    }
    if (d.copy) {
      d.copy.forEach(function(c) {
        var el = document.querySelector(c.sel); if (!el) return;
        if (c.prop === 'textContent') el.textContent = c.val;
        else if (c.prop === 'innerHTML') el.innerHTML = c.val;
        else if (c.prop === 'href') el.setAttribute('href', c.val || '#');
        else if (c.prop === 'placeholder') el.setAttribute('placeholder', c.val);
      });
    }
    if (d.fonts && d.fonts.length) {
      d.fonts.forEach(function(url) {
        var id = 'slab-font-' + url.replace(/[^a-z0-9]/gi, '').substring(0, 40);
        if (!document.getElementById(id)) {
          var link = document.createElement('link');
          link.id = id; link.rel = 'stylesheet'; link.href = url;
          document.head.appendChild(link);
        }
      });
    }
    if (d.visibility) {
      var vKeys = Object.keys(d.visibility);
      for (var v = 0; v < vKeys.length; v++) {
        var selectorStr = vKeys[v];
        var show = d.visibility[selectorStr];
        var parts = selectorStr.split(',');
        for (var p = 0; p < parts.length; p++) {
          var els = document.querySelectorAll(parts[p].trim());
          for (var ee = 0; ee < els.length; ee++) els[ee].style.display = show ? '' : 'none';
        }
      }
    }
  });
})();
</script>
</body>
</html>
