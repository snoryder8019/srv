    <button id="w2-cookie-accept" style="background:var(--gold);border:none;color:var(--dark);padding:10px 26px;font-family:var(--font-body),sans-serif;font-size:0.76rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;border-radius:2px;transition:background 0.2s;">Accept</button>
