<!-- CUSTOM SECTIONS -->
<% if (customSections && customSections.length) { %>
<% customSections.forEach(function(sec) { %>
  <% const f = sec.fields || {}; const imgs = sec.images || {}; %>

  <% if (sec.type === 'text') { %>
  <section class="cs-text">
    <div class="cs-wrap">
      <% if (f.heading) { %><h2 class="cs-heading"><%- f.heading %></h2><% } %>
      <% if (f.subheading) { %><p class="cs-eyebrow"><%- f.subheading %></p><% } %>
      <% if (f.body) { %><div class="cs-body"><%- f.body %></div><% } %>
    </div>
  </section>

  <% } else if (sec.type === 'split') { %>
  <section class="cs-split">
    <div class="cs-wrap">
      <div>
        <% if (f.heading) { %><h2 class="cs-heading"><%- f.heading %></h2><% } %>
        <% if (f.body) { %><div class="cs-body"><%- f.body %></div><% } %>
        <% if (f.cta_text && f.cta_link) { %><a href="<%- f.cta_link %>" class="cs-btn"><%- f.cta_text %></a><% } %>
      </div>
      <div>
        <% if (imgs.main_image) { %>
          <img src="<%- imgs.main_image %>" alt="" class="cs-split-img">
        <% } else { %>
          <div class="cs-split-img-placeholder"></div>
        <% } %>
      </div>
    </div>
  </section>

  <% } else if (sec.type === 'cta') { %>
  <section class="cs-cta<% if (imgs.bg_image) { %> cs-cta-bg<% } %>"<% if (imgs.bg_image) { %> style="background-image:url('<%- imgs.bg_image %>');background-size:cover;background-position:center"<% } %>>
    <div class="cs-wrap">
      <% if (f.heading) { %><h2 class="cs-heading"><%- f.heading %></h2><% } %>
      <% if (f.subtext) { %><div class="cs-body"><%- f.subtext %></div><% } %>
      <% if (f.btn_text && f.btn_link) { %><a href="<%- f.btn_link %>" class="cs-btn"><%- f.btn_text %></a><% } %>
    </div>
  </section>

  <% } else if (sec.type === 'cards') { %>
  <section class="cs-cards">
    <div class="cs-wrap">
      <div class="cs-cards-intro">
        <% if (f.heading) { %><h2 class="cs-heading"><%- f.heading %></h2><% } %>
        <% if (f.subtext) { %><p class="cs-body"><%- f.subtext %></p><% } %>
      </div>
      <div class="cs-cards-grid">
        <% [1,2,3,4].forEach(function(n) { %>
          <% if (f['card'+n+'_title'] || f['card'+n+'_body']) { %>
          <div class="cs-card">
            <% if (imgs['card'+n+'_image']) { %><img src="<%- imgs['card'+n+'_image'] %>" alt="" class="cs-card-img"><% } %>
            <% if (f['card'+n+'_title']) { %><div class="cs-card-title"><%- f['card'+n+'_title'] %></div><% } %>
            <% if (f['card'+n+'_body']) { %><div class="cs-card-body"><%- f['card'+n+'_body'] %></div><% } %>
          </div>
          <% } %>
        <% }); %>
      </div>
    </div>
  </section>

  <% } else if (sec.type === 'faq') { %>
  <section class="cs-faq">
    <div class="cs-wrap">
      <% if (f.heading) { %><h2 class="cs-heading"><%- f.heading %></h2><% } %>
      <div class="cs-faq-list">
        <% [1,2,3,4,5].forEach(function(n) { %>
          <% if (f['q'+n] && f['a'+n]) { %>
          <div class="cs-faq-item">
            <div class="cs-faq-q"><%- f['q'+n] %></div>
            <div class="cs-faq-a"><%- f['a'+n] %></div>
          </div>
          <% } %>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

<% }); %>
<% } %>

<!-- FOOTER -->
<% if (visibility.qr) { %>
<!-- QR CODE SHARE WIDGET -->
<div id="qr-share-widget" style="position:fixed;bottom:24px;left:24px;z-index:7500;">
  <button id="qr-toggle-btn" aria-label="Show QR Code" style="width:48px;height:48px;border-radius:50%;background:var(--navy);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(0,0,0,0.25);transition:transform 0.2s,background 0.2s;" onmouseover="this.style.transform='scale(1.08)'" onmouseout="this.style.transform='scale(1)'">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--white)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="8" height="8" rx="1"/><rect x="14" y="2" width="8" height="8" rx="1"/><rect x="2" y="14" width="8" height="8" rx="1"/><rect x="14" y="14" width="2" height="2"/><rect x="20" y="14" width="2" height="2"/><rect x="14" y="20" width="2" height="2"/><rect x="20" y="20" width="2" height="2"/><rect x="17" y="17" width="2" height="2"/></svg>
  </button>
  <div id="qr-popup" style="display:none;position:absolute;bottom:60px;left:0;background:var(--white);border:1px solid var(--ivory-mid);border-radius:6px;padding:20px;box-shadow:0 8px 40px rgba(0,0,0,0.18);min-width:200px;text-align:center;transform:translateY(10px);opacity:0;transition:transform 0.25s ease,opacity 0.25s ease;">
    <div style="font-family:var(--font-heading),serif;font-size:0.9rem;font-weight:600;color:var(--dark);margin-bottom:12px;">Share This Page</div>
    <div id="qr-canvas" style="display:inline-block;padding:8px;background:#fff;border-radius:4px;"></div>
    <div style="font-size:0.68rem;color:var(--on-ivory-muted);margin-top:10px;font-weight:300;"><%= brand?.name || '' %></div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
<script>
(function() {
  var btn = document.getElementById('qr-toggle-btn');
  var popup = document.getElementById('qr-popup');
  var canvas = document.getElementById('qr-canvas');
  var open = false, generated = false;
  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    open = !open;
    if (open) {
      if (!generated) {
        new QRCode(canvas, { text: window.location.origin, width: 160, height: 160, colorDark: '<%= design.color_primary %>', colorLight: '#ffffff', correctLevel: QRCode.CorrectLevel.M });
        generated = true;
      }
      popup.style.display = 'block';
      requestAnimationFrame(function() { popup.style.opacity = '1'; popup.style.transform = 'translateY(0)'; });
    } else {
      popup.style.opacity = '0'; popup.style.transform = 'translateY(10px)';
      setTimeout(function() { popup.style.display = 'none'; }, 260);
    }
  });
  document.addEventListener('click', function() {
    if (open) { open = false; popup.style.opacity = '0'; popup.style.transform = 'translateY(10px)'; setTimeout(function() { popup.style.display = 'none'; }, 260); }
  });
  popup.addEventListener('click', function(e) { e.stopPropagation(); });
})();
</script>
<% } %>

