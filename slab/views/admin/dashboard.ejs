<%- include('partials/head', { title: 'Dashboard' }) %>
<%- include('partials/sidebar', { page: 'dashboard', user: user }) %>

<% if (typeof tenant !== 'undefined') { %>
<script>
  const _urlP = new URLSearchParams(window.location.search);
  if (_urlP.get('setup') === 'complete') {
    setTimeout(() => {
      const d = document.createElement('div');
      d.style.cssText = 'position:fixed;top:16px;left:50%;transform:translateX(-50%);z-index:10001;background:#14532d;color:#86efac;padding:14px 24px;border-radius:8px;font-family:Inter,sans-serif;font-size:14px;font-weight:500;box-shadow:0 4px 20px rgba(0,0,0,0.3);';
      d.textContent = 'Brand profile saved! Your site is taking shape.';
      document.body.appendChild(d);
      setTimeout(() => d.remove(), 5000);
      const url = new URL(window.location); url.searchParams.delete('setup'); history.replaceState({}, '', url);
    }, 300);
  }
</script>
<% } %>
<% if (typeof tenant !== 'undefined' && !tenant?.isPreview) { %>
<script>
  if (new URLSearchParams(window.location.search).get('activated') === '1') {
    setTimeout(() => {
      const d = document.createElement('div');
      d.style.cssText = 'position:fixed;top:16px;left:50%;transform:translateX(-50%);z-index:10001;background:#14532d;color:#86efac;padding:14px 24px;border-radius:8px;font-family:Inter,sans-serif;font-size:14px;font-weight:500;box-shadow:0 4px 20px rgba(0,0,0,0.3);';
      d.textContent = 'Your site is live! Visitors can now see your website.';
      document.body.appendChild(d);
      setTimeout(() => d.remove(), 5000);
      const url = new URL(window.location); url.searchParams.delete('activated'); history.replaceState({}, '', url);
    }, 300);
  }
</script>
<% } %>

<style>
/* ── Dashboard-specific responsive styles ── */
.dash-two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 16px;
}

/* Agent panel */
.agent-card { margin-top: 24px; }
.agent-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}
.agent-name-row {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.ai-badge {
  font-size: 0.63rem; font-weight: 700; letter-spacing: .14em;
  text-transform: uppercase; background: var(--navy); color: #fff;
  padding: 2px 8px; border-radius: 2px; white-space: nowrap;
}

/* Chat messages */
#ma-messages {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 14px;
  max-height: 380px;
  overflow-y: auto;
  padding-right: 4px;
}
.ma-msg { display: flex; }
.ma-msg-user  { justify-content: flex-end; }
.ma-msg-agent { justify-content: flex-start; }
.ma-bubble {
  max-width: 82%;
  padding: 10px 14px;
  border-radius: 6px;
  font-size: 0.88rem;
  line-height: 1.55;
  word-break: break-word;
}
.ma-msg-agent .ma-bubble { background: var(--ivory); color: var(--dark); }
.ma-msg-user  .ma-bubble { background: var(--navy); color: #fff; }
.ma-bubble a { color: var(--gold); }

/* Quick prompts */
#ma-quick {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
}
#ma-cycle-btn {
  color: var(--gold);
  font-size: 1rem;
  transition: transform 0.55s cubic-bezier(.2,.8,.3,1.1), color 0.2s;
  cursor: pointer;
}
#ma-cycle-btn:hover { color: var(--navy); transform: scale(1.15); }
#ma-cycle-btn:active { transition-duration: 0.15s; }

/* Chip enter animation */
.ma-quick-btn { transition: opacity 0.35s ease, transform 0.35s cubic-bezier(.4,0,.2,1); }
.ma-chip-enter { opacity: 0; transform: translateY(6px) scale(0.92); }
.ma-chip-visible { opacity: 1; transform: translateY(0) scale(1); }

/* Input row */
.ma-input-row {
  display: flex;
  gap: 8px;
  align-items: flex-end;
}
.ma-input-row input {
  flex: 1;
  min-width: 0;
  padding: 10px 14px;
  border: 1px solid var(--ivory-mid);
  border-radius: 4px;
  font-size: 0.9rem;
  font-family: inherit;
}
.ma-input-row input:focus { outline: none; border-color: var(--navy); }

/* Result card */
#ma-result {
  display: none;
  margin-top: 16px;
  border: 1px solid var(--ivory-mid);
  border-radius: 4px;
  overflow: hidden;
}
.ma-result-header {
  padding: 12px 14px;
  background: var(--ivory);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  flex-wrap: wrap;
}
.ma-result-meta { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; min-width: 0; }
.ma-result-actions { display: flex; gap: 7px; flex-shrink: 0; flex-wrap: wrap; }
#ma-result-dept {
  font-size: 0.65rem; font-weight: 700; letter-spacing: .14em;
  text-transform: uppercase; color: #fff;
  padding: 2px 8px; border-radius: 2px; white-space: nowrap;
}
#ma-result-msg {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--dark);
  word-break: break-word;
}
#ma-result-fields {
  padding: 0 14px 14px;
  display: flex;
  flex-direction: column;
  gap: 5px;
  max-height: 240px;
  overflow-y: auto;
}
.ma-field-row {
  display: flex;
  gap: 8px;
  align-items: flex-start;
  padding: 6px 0;
  border-bottom: 1px solid var(--ivory-mid);
  font-size: 0.82rem;
}
.ma-field-key {
  flex-shrink: 0;
  width: 120px;
  font-weight: 600;
  color: var(--slate);
  text-transform: uppercase;
  letter-spacing: .05em;
  font-size: 0.65rem;
  padding-top: 2px;
}
.ma-field-val { color: var(--dark); line-height: 1.4; word-break: break-word; flex: 1; }

/* TTS / STT controls */
.ma-speak-btn {
  background: none; border: none; cursor: pointer;
  color: var(--slate); font-size: 0.85rem; padding: 2px 5px;
  border-radius: 3px; line-height: 1; opacity: 0.6;
  transition: opacity .15s, color .15s;
  vertical-align: middle; margin-left: 6px; flex-shrink: 0;
}
.ma-speak-btn:hover { opacity: 1; color: var(--navy); }
.ma-speak-btn.speaking { opacity: 1; color: var(--gold); animation: ma-pulse 1s infinite; }
@keyframes ma-pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

.ma-mic-btn {
  padding: 10px 12px; font-size: 1rem; line-height: 1;
  border-radius: 4px; border: 1px solid var(--ivory-mid);
  background: #fff; cursor: pointer; color: var(--slate);
  transition: background .15s, color .15s, border-color .15s;
  flex-shrink: 0;
}
.ma-mic-btn:hover { border-color: var(--navy); color: var(--navy); }
.ma-mic-btn.recording { background: #fee; border-color: #c33; color: #c33; animation: ma-pulse 0.8s infinite; }

#ma-voice-select {
  padding: 6px 8px; font-size: 0.78rem; font-family: inherit;
  border: 1px solid var(--ivory-mid); border-radius: 4px;
  background: #fff; color: var(--dark); cursor: pointer;
  flex-shrink: 0;
}
#ma-voice-select:focus { outline: none; border-color: var(--navy); }

/* ── Workflow Checklist ── */
#ma-workflow {
  margin-top: 14px;
  border: 1px solid var(--ivory-mid);
  border-radius: 4px;
  overflow: hidden;
}
.wf-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10px 14px; background: var(--ivory); gap: 8px; flex-wrap: wrap;
}
.wf-title-row { display: flex; align-items: center; gap: 8px; min-width: 0; }
.wf-icon { font-size: 0.85rem; color: var(--gold); }
.wf-title { font-weight: 600; font-size: 0.85rem; color: var(--dark); }
.wf-progress { font-size: 0.7rem; color: var(--slate); font-weight: 500; white-space: nowrap; }
.wf-actions { display: flex; gap: 6px; flex-shrink: 0; }
.wf-tasks { display: flex; flex-direction: column; }
.wf-task {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 14px; border-top: 1px solid var(--ivory-mid);
  font-size: 0.82rem; transition: background 0.15s;
}
.wf-task:hover { background: rgba(201,168,72,0.04); }
.wf-task-status {
  flex-shrink: 0; width: 20px; text-align: center;
  font-size: 0.9rem; line-height: 1;
}
.wf-task[data-status="pending"] .wf-task-status { color: #bbb; }
.wf-task[data-status="running"] .wf-task-status { color: var(--gold); }
.wf-task[data-status="running"] .wf-task-status span { animation: ma-pulse 1s infinite; display: inline-block; }
.wf-task[data-status="done"] .wf-task-status { color: #2E7D32; }
.wf-task[data-status="failed"] .wf-task-status { color: #c33; }
.wf-task[data-status="applied"] .wf-task-status { color: #2E7D32; }
.wf-task-info { display: flex; align-items: center; gap: 8px; flex: 1; min-width: 0; }
.wf-task-dept {
  font-size: 0.55rem; font-weight: 700; letter-spacing: .12em;
  text-transform: uppercase; color: #fff; padding: 1px 6px;
  border-radius: 2px; white-space: nowrap; flex-shrink: 0;
}
.wf-task-label {
  color: var(--dark); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.wf-task[data-status="done"] .wf-task-label,
.wf-task[data-status="applied"] .wf-task-label { text-decoration: line-through; color: var(--slate); }
.wf-task-actions { display: flex; gap: 4px; flex-shrink: 0; }
.wf-task-actions .btn-xs {
  padding: 3px 8px; font-size: 0.62rem; border-radius: 3px; line-height: 1.3;
}
.wf-task-msg {
  font-size: 0.72rem; color: var(--slate); padding: 2px 14px 6px 44px;
  word-break: break-word;
}

/* Mobile overrides */
@media (max-width: 820px) {
  .dash-two-col { grid-template-columns: 1fr !important; }
  .agent-header { flex-direction: column; align-items: flex-start; }
  #ma-messages { max-height: 260px; }
  .ma-bubble { max-width: 92%; font-size: 0.85rem; }
  .ma-result-header { flex-direction: column; align-items: flex-start; gap: 10px; }
  .ma-result-actions { width: 100%; }
  .ma-result-actions .btn { flex: 1; justify-content: center; }
  .ma-field-key { width: 90px; }
  .wf-header { padding: 8px 12px; }
  .wf-task { padding: 7px 12px; gap: 8px; font-size: 0.78rem; }
}
@media (max-width: 520px) {
  /* Tighten overall content */
  .content { padding: 14px 12px; }
  .agent-card { margin-top: 14px; }
  .card { padding: 14px 12px; }
  .card + .card { margin-top: 10px; }

  /* Topbar: hide Edit Copy to reduce crowding, keep + Portfolio */
  .topbar-hide-mobile { display: none !important; }

  /* Stat grid: horizontal scroll strip */
  .stat-grid {
    display: flex !important;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    gap: 8px;
    margin-bottom: 14px;
    padding-bottom: 4px;
    scrollbar-width: none;
  }
  .stat-grid::-webkit-scrollbar { display: none; }
  .stat-card {
    flex: 0 0 auto;
    min-width: 96px;
    padding: 10px 12px;
  }
  .stat-label { font-size: 0.55rem; }
  .stat-value { font-size: 1.7rem; }

  /* Agent header */
  .agent-header { margin-bottom: 10px; }
  .agent-header p { display: none; }
  .agent-header a.btn { padding: 5px 10px; font-size: 0.62rem; }

  /* Chat area */
  #ma-messages { max-height: 200px; margin-bottom: 10px; }
  .ma-bubble { max-width: 96%; font-size: 0.82rem; padding: 8px 10px; }

  /* Quick chips — horizontal scroll */
  #ma-quick { flex-wrap: nowrap; overflow-x: auto; padding-bottom: 4px; -webkit-overflow-scrolling: touch; gap: 5px; margin-bottom: 8px; }
  #ma-quick .btn { font-size: 0.6rem; padding: 5px 10px; white-space: nowrap; flex-shrink: 0; }

  /* Input row:
     Row 1: [voice select ──────] [mic]
     Row 2: [input ──────────────] [send] */
  .ma-input-row { flex-wrap: wrap; gap: 6px; }
  #ma-voice-select { order: 1; flex: 1 1 0; min-width: 0; font-size: 0.73rem; padding: 7px 8px; }
  .ma-mic-btn { order: 2; flex-shrink: 0; padding: 8px 11px; font-size: 0.95rem; }
  .ma-input-row input { order: 3; flex: 1 1 0; min-width: 0; font-size: 0.85rem; padding: 9px 12px; }
  .ma-input-row .btn { order: 4; flex-shrink: 0; padding: 9px 14px; font-size: 0.72rem; }

  /* Result card */
  #ma-result { margin-top: 12px; }
  .ma-result-header { padding: 10px 12px; }
  .ma-result-actions { flex-direction: row; flex-wrap: wrap; gap: 6px; }
  .ma-result-actions .btn { flex: 1 1 auto; min-width: 0; justify-content: center; font-size: 0.65rem; padding: 7px 10px; }
  .ma-result-actions .btn:last-child { flex: 0 0 auto; }
  .ma-field-key { width: 64px; font-size: 0.57rem; }
  #ma-result-fields { padding: 0 12px 12px; max-height: 180px; }
  .ma-field-row { font-size: 0.78rem; }

  /* Workflow checklist phone tweaks */
  #ma-workflow { margin-top: 10px; }
  .wf-header { padding: 8px 10px; }
  .wf-task { padding: 6px 10px; gap: 6px; font-size: 0.75rem; }
  .wf-task-dept { font-size: 0.5rem; padding: 1px 5px; }
  .wf-task-actions .btn-xs { padding: 2px 6px; font-size: 0.58rem; }
  .wf-task-msg { padding: 2px 10px 4px 36px; font-size: 0.68rem; }

  /* Quick Actions: 2-col grid on phone */
  .quick-actions-grid {
    display: grid !important;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .quick-actions-grid .btn { padding: 9px 10px; font-size: 0.65rem; justify-content: center; }

  /* Account table tighten */
  tbody td { padding: 10px 12px; font-size: 0.82rem; }
  thead th { padding: 9px 12px; }
}
</style>

<div class="topbar">
  <div class="topbar-title">Dashboard</div>
</div>

<div class="content">
  <%- include('partials/advisory', { needs: 'ai' }) %>

  <% if (typeof tenant !== 'undefined' && tenant?.isPreview) { %>
  <%
    const _pvExp = tenant.previewExpiresAt ? new Date(tenant.previewExpiresAt) : null;
    const _pvDays = _pvExp ? Math.max(0, Math.ceil((_pvExp.getTime() - Date.now()) / 86400000)) : null;
    const _pvExpired = _pvDays !== null && _pvDays <= 0;
    const _pvUrgent = _pvDays !== null && _pvDays <= 2;
  %>
  <div class="card" style="margin-bottom:16px;padding:18px 22px;border-left:4px solid <%= _pvExpired ? 'var(--danger)' : _pvUrgent ? 'var(--warn)' : 'var(--gold)' %>;background:<%= _pvExpired ? 'rgba(185,28,28,0.04)' : 'rgba(201,168,72,0.04)' %>;">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <div>
        <div style="font-size:0.85rem;font-weight:600;color:<%= _pvExpired ? 'var(--danger)' : 'var(--dark)' %>;">
          <% if (_pvExpired) { %>
            Preview Expired — Go Live to Keep Your Site
          <% } else { %>
            Preview Mode — <%= _pvDays %> day<%= _pvDays !== 1 ? 's' : '' %> remaining
          <% } %>
        </div>
        <div style="font-size:0.72rem;color:var(--slate);margin-top:4px;">
          <% if (_pvExpired) { %>
            Your preview period has ended. Your site is not visible to the public. Activate a plan to go live.
          <% } else { %>
            Your site is in preview mode. Visitors can see it, but you need to activate a plan to keep it live after your trial.
          <% } %>
        </div>
      </div>
      <a href="#" onclick="document.getElementById('goLiveModal')?.showModal();return false;" class="btn <%= _pvExpired || _pvUrgent ? 'btn-gold' : 'btn-navy' %>" style="white-space:nowrap;">
        Go Live
      </a>
    </div>
  </div>
  <% } %>

  <% if (typeof tenant !== 'undefined' && tenant?.status === 'suspended') { %>
  <div class="card" style="margin-bottom:16px;padding:18px 22px;border-left:4px solid var(--danger);background:rgba(185,28,28,0.04);">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <div>
        <div style="font-size:0.85rem;font-weight:600;color:var(--danger);">Site Suspended</div>
        <div style="font-size:0.72rem;color:var(--slate);margin-top:4px;">Your preview period has ended and your site is no longer visible. Activate a plan to restore access.</div>
      </div>
      <a href="#" onclick="document.getElementById('goLiveModal')?.showModal();return false;" class="btn btn-gold" style="white-space:nowrap;">Activate Now</a>
    </div>
  </div>
  <% } %>

  <!-- STORAGE METER -->
  <div class="card" style="margin-bottom:16px;padding:16px 20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
      <span style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--slate);">Storage</span>
      <span style="font-size:0.72rem;color:var(--dark);font-weight:500;"><%= storage.used %> / <%= storage.quota %></span>
    </div>
    <div style="background:var(--ivory-mid);border-radius:2px;height:8px;overflow:hidden;">
      <div style="height:100%;border-radius:2px;width:<%= storage.pct %>%;background:<%= storage.pct >= 90 ? 'var(--danger)' : storage.pct >= 70 ? 'var(--gold)' : 'var(--navy)' %>;transition:width 0.3s;"></div>
    </div>
    <div style="display:flex;justify-content:space-between;margin-top:6px;">
      <span style="font-size:0.62rem;color:var(--slate);"><%= storage.plan %> plan</span>
      <% if (storage.pct >= 80) { %>
        <span style="font-size:0.62rem;color:<%= storage.pct >= 90 ? 'var(--danger)' : 'var(--gold)' %>;font-weight:600;">
          <%= storage.pct >= 90 ? 'Almost full — upgrade for more space' : 'Running low' %>
        </span>
      <% } %>
    </div>
  </div>

  <!-- STATS -->
  <div class="stat-grid">
    <div class="stat-card">
      <div class="stat-label">Portfolio</div>
      <div class="stat-value"><%= stats.portfolioCount %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Clients</div>
      <div class="stat-value"><%= stats.clientCount %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Open Invoices</div>
      <div class="stat-value gold"><%= stats.invoiceCount %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Blog Posts</div>
      <div class="stat-value"><%= stats.blogCount %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Pages</div>
      <div class="stat-value"><%= stats.pageCount %></div>
    </div>
  </div>

  <!-- MASTER AGENT -->
  <div class="card agent-card">
    <div class="agent-header">
      <div>
        <div class="agent-name-row">
          <span style="color:var(--gold);font-size:1.05rem;">✦</span>
          <span class="card-title" style="margin:0;padding:0;border:none;" id="agent-display-name"><%= agentName %></span>
          <span class="ai-badge">AI</span>
        </div>
        <p style="font-size:0.8rem;color:var(--slate);margin-top:4px;">I coordinate your blog, copy, sections, pages, design, and assets agents. Give me a goal and I'll plan the workflow.</p>
      </div>
      <a href="/admin/design" class="btn btn-ghost btn-sm" style="white-space:nowrap;">Configure ↗</a>
    </div>

    <!-- Chat thread -->
    <div id="ma-messages">
      <div class="ma-msg ma-msg-agent">
        <div class="ma-bubble" id="ma-greeting">
          <%= agentName %> is ready — what would you like to create or update today?
        </div>
      </div>
    </div>

    <!-- Quick prompts — cycling suggestions -->
    <div id="ma-quick-wrap" style="display:flex;align-items:center;gap:6px;margin-bottom:12px;">
      <div id="ma-quick" style="display:flex;flex-wrap:wrap;gap:7px;flex:1;"></div>
      <button class="btn btn-ghost btn-sm" id="ma-cycle-btn" onclick="maCycleSuggestions()" title="New suggestions" style="flex-shrink:0;padding:6px 10px;font-size:0.85rem;line-height:1;">&#x267B;</button>
    </div>

    <!-- Input -->
    <div class="ma-input-row">
      <select id="ma-voice-select" title="TTS voice" onchange="maSetVoice(this.value)">
        <option value="lessac">Lessac (F)</option>
        <option value="ryan">Ryan (M)</option>
        <option value="slt">SLT (F)</option>
      </select>
      <button class="ma-mic-btn" id="ma-mic-btn" title="Speak" onclick="maToggleMic()">🎤</button>
      <input id="ma-input" type="text" placeholder="Ask <%= agentName %>…" autocomplete="off">
      <button class="btn btn-navy" id="ma-send" onclick="maSend()">Send</button>
      <span id="ai-status"></span>
    </div>

    <!-- Workflow Checklist -->
    <div id="ma-workflow" style="display:none;">
      <div class="wf-header">
        <div class="wf-title-row">
          <span class="wf-icon">✦</span>
          <span id="wf-title" class="wf-title">Workflow</span>
          <span id="wf-progress" class="wf-progress"></span>
        </div>
        <div class="wf-actions">
          <button class="btn btn-gold btn-sm" id="wf-run-btn" onclick="wfRunAll()">Run All</button>
          <button class="btn btn-ghost btn-sm" onclick="wfClear()">Clear</button>
        </div>
      </div>
      <div id="wf-tasks" class="wf-tasks"></div>
    </div>

    <!-- Result card -->
    <div id="ma-result">
      <div class="ma-result-header">
        <div class="ma-result-meta">
          <span id="ma-result-dept"></span>
          <span id="ma-result-msg"></span>
        </div>
        <div class="ma-result-actions">
          <button id="ma-execute-btn" class="btn btn-gold btn-sm" onclick="maExecute()">Apply Now</button>
          <button id="ma-editor-btn" class="btn btn-ghost btn-sm" onclick="maOpenEditor()">Open in Editor</button>
          <button class="btn btn-ghost btn-sm" onclick="document.getElementById('ma-result').style.display='none'">✕</button>
        </div>
      </div>
      <div id="ma-result-fields"></div>
    </div>
  </div>

  <!-- ACCOUNT + QUICK ACTIONS -->
  <div class="dash-two-col">
    <div class="card">
      <div class="card-title">Account</div>
      <table>
        <tbody>
          <tr>
