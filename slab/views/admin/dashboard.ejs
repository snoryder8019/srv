<div id="w2tut-overlay" style="display:none;"></div>
<div id="w2tut-spot" style="display:none;"></div>
<div id="w2tut-tip" style="display:none;"><div id="w2tut-step-label"></div><div id="w2tut-msg"></div></div>
<div id="w2tut-dots" style="display:none;"></div>
<button id="w2tut-exit" style="display:none;">✕ Skip Tour</button>
<button id="w2tut-next" style="display:none;">Next →</button>
<div id="w2tut-final"></div>

<script>
(function() {
  if (localStorage.getItem('slab_admin_tour_done')) return;

  const STEPS = [
    {
      targetId: 'sidebarToggle',
      shape: 'circle', pad: 18,
      label: 'Step 1 of 5',
      msg: 'Welcome! This button opens your <strong>admin navigation menu</strong>. Let\'s explore it together.',
      onNext() {
        const s = document.getElementById('sidebar');
        const o = document.getElementById('sidebarOverlay');
        const t = document.getElementById('sidebarToggle');
        s.classList.add('open');
        if (o) { o.style.display = 'block'; o.classList.add('active'); }
        t.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
    },
    {
      targetSel: 'a[href="/admin/sections"]',
      shape: 'rect', pad: 8,
      label: 'Step 2 of 5',
      msg: 'Here\'s <strong>Sections</strong> — build and manage custom content blocks like CTAs, cards, FAQs, and image splits for your site.',
      onNext() {
        const s = document.getElementById('sidebar');
        const o = document.getElementById('sidebarOverlay');
        const t = document.getElementById('sidebarToggle');
        s.classList.remove('open');
        if (o) { o.classList.remove('active'); o.style.display = ''; }
        t.classList.remove('open');
        document.body.style.overflow = '';
      }
    },
    {
      targetSel: '.agent-card',
      shape: 'rect', pad: 0,
      label: 'Step 3 of 5',
      msg: 'Here you can fill out your site content manually — or try your <strong>AI suggestion</strong>. Your agent can write copy, blog posts, and build new sections.',
      onNext() {
        const el = document.querySelector('.ma-input-row');
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    },
    {
      targetSel: '#ma-quick',
      targetSel2: '.ma-input-row',
      shape: 'rect', pad: 10,
      label: 'Step 4 of 5',
      msg: 'Choose a <strong>preset suggestion</strong> to get started quickly, or type any request in the chat bar. Your agent works best with clear, specific instructions.',
      onNext() {}
    },
    {
      final: true,
      label: 'Step 5 of 5',
      msg: 'All your admin tools let you update <strong>copy, images, layout, and page views</strong> of your site. We recommend spending a little time with your agents before using the dashboard AI assistant — it helps you understand exactly what changes are possible.<br><br>Thank you for using the platform! ✦'
    }
  ];

  let step = 0;

  // Show tour UI
  document.body.classList.add('w2tut-active');
  document.getElementById('w2tut-overlay').style.display = 'block';
  document.getElementById('w2tut-dots').style.display = 'flex';
  document.getElementById('w2tut-exit').style.display = 'block';
  document.getElementById('w2tut-next').style.display = 'block';

  showStep(0);

  function showStep(n) {
    step = n;
    const s = STEPS[n];

    // Dots
    document.getElementById('w2tut-dots').innerHTML =
      STEPS.map((_, i) => `<div class="w2tut-dot${i === n ? ' active' : ''}"></div>`).join('');

    // Next button label
    document.getElementById('w2tut-next').textContent = n === STEPS.length - 1 ? 'Done ✓' : 'Next →';

    if (s.final) {
      document.getElementById('w2tut-spot').style.display = 'none';
      document.getElementById('w2tut-tip').style.display = 'none';
      const fin = document.getElementById('w2tut-final');
      fin.style.display = 'block';
      fin.innerHTML = `<span class="tut-final-icon">✦</span><strong style="font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:400;display:block;margin-bottom:10px;">You\'re all set!</strong>${s.msg}`;
      return;
    }

    document.getElementById('w2tut-final').style.display = 'none';
    document.getElementById('w2tut-step-label').textContent = s.label;
    document.getElementById('w2tut-msg').innerHTML = s.msg;

    // Resolve target element
    let el;
    if (s.targetId) {
      el = document.getElementById(s.targetId);
    } else {
      el = document.querySelector(s.targetSel);
    }
    if (!el) return;

    // Scroll element into view first (for agent card on scrolled page)
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });

    setTimeout(function() {
      const rect = el.getBoundingClientRect();
      const spot = document.getElementById('w2tut-spot');
      spot.style.display = 'block';
      const tip  = document.getElementById('w2tut-tip');
      tip.style.display = 'block';
      const pad = s.pad || 0;

      if (s.shape === 'circle') {
        const size = Math.max(rect.width, rect.height) + pad * 2;
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        spot.style.width  = size + 'px';
        spot.style.height = size + 'px';
        spot.style.borderRadius = '50%';
        spot.style.left = (cx - size / 2) + 'px';
        spot.style.top  = (cy - size / 2) + 'px';
      } else {
        let top    = rect.top    - pad;
        let left   = rect.left   - pad;
        let right  = rect.right  + pad;
        let bottom = rect.bottom + pad;
        // Union with optional second target
        if (s.targetSel2) {
          const el2 = document.querySelector(s.targetSel2);
          if (el2) {
            const r2 = el2.getBoundingClientRect();
            top    = Math.min(top,    r2.top    - pad);
            left   = Math.min(left,   r2.left   - pad);
            right  = Math.max(right,  r2.right  + pad);
            bottom = Math.max(bottom, r2.bottom + pad);
          }
        }
        spot.style.left   = left + 'px';
        spot.style.top    = top  + 'px';
        spot.style.width  = (right - left) + 'px';
        spot.style.height = (bottom - top) + 'px';
        spot.style.borderRadius = '6px';
      }

      // Position tooltip
      const spotR = spot.getBoundingClientRect();
      const vw = window.innerWidth, vh = window.innerHeight;
      const tipW = 360, tipH = 140, margin = 18;

      // Prefer below spotlight
      let tipTop = spotR.bottom + margin;
      if (tipTop + tipH > vh - 80) tipTop = spotR.top - tipH - margin;
      tipTop = Math.max(10, Math.min(tipTop, vh - tipH - 80));

      let tipLeft = spotR.left;
      if (tipLeft + tipW > vw - 20) tipLeft = vw - tipW - 20;
      tipLeft = Math.max(16, tipLeft);

      tip.style.left = tipLeft + 'px';
      tip.style.top  = tipTop  + 'px';
    }, n === 0 ? 60 : 80);
  }

  function endTour() {
    localStorage.setItem('slab_admin_tour_done', '1');
    document.body.classList.remove('w2tut-active');
    ['w2tut-overlay','w2tut-spot','w2tut-tip','w2tut-dots',
     'w2tut-exit','w2tut-next','w2tut-final'].forEach(function(id) {
      const el = document.getElementById(id);
      if (el) el.style.display = 'none';
    });
    // Ensure sidebar closed & hamburger reset
    document.getElementById('sidebar').classList.remove('open');
    const o = document.getElementById('sidebarOverlay');
    if (o) { o.classList.remove('active'); o.style.display = ''; }
    document.getElementById('sidebarToggle').classList.remove('open');
    document.body.style.overflow = '';
  }

  document.getElementById('w2tut-next').addEventListener('click', function() {
    if (step < STEPS.length - 1) {
      if (STEPS[step].onNext) STEPS[step].onNext();
      const delay = (step === 0) ? 320 : 60;
      setTimeout(function() { showStep(step + 1); }, delay);
    } else {
      endTour();
    }
  });

  document.getElementById('w2tut-exit').addEventListener('click', endTour);
})();
</script>

