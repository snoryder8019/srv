      <div class="card-title">Quick Actions</div>
      <div class="quick-actions-grid" style="display:flex;flex-direction:column;gap:10px;">
        <a href="/admin/blog/new" class="btn btn-navy">+ New Blog Post</a>
        <a href="/admin/pages/new" class="btn btn-navy">+ New Page</a>
        <a href="/admin/portfolio/new" class="btn btn-ghost">+ Portfolio Item</a>
        <a href="/admin/copy" class="btn btn-ghost">Edit Site Copy</a>
        <a href="/admin/design" class="btn btn-ghost">Design &amp; Settings</a>
        <a href="/" target="_blank" class="btn btn-ghost">View Live Site ↗</a>
      </div>
    </div>
  </div>

</div>
</div></div>

<script>
const AGENT_NAME = '<%= agentName.replace(/\\/g,"\\\\").replace(/'/g,"\\'") %>';
const DEPT_COLORS = { blog: '#2E4270', copy: '#1C2B4A', section: '#5B3E2B', page: '#2E5B3E', design: '#6B3FA0', asset: '#C9A848', email: '#D4563A', invoice: '#2B7A5B', outreach: '#4A6FA5', navigate: '#555' };

// Conversation history (multi-turn)
let maHistory = [];
let maLastResult = null;
let maExecuting = false;

// Workflow state
let wf = { title: '', tasks: [], running: false, runAllMode: false };

// ── Cycling Suggestions Pool ──────────────────────────────────────────────────
const SUGGESTION_POOL = [
  // Single actions — Copy
  'Rewrite the hero section with a fresh compelling headline',
  'Update our services descriptions with current offerings',
  'Refresh the about section with a new brand story',
  // Single actions — Blog
  'Write a blog post about local SEO tips for local businesses',
  'Write a post about social media trends for small businesses',
  'Draft a blog about content marketing strategies',
  // Single actions — Sections
  'Create an FAQ section about our services and pricing',
  'Add a CTA banner for free consultation bookings',
  'Add a feature cards section showcasing key services',
  // Single actions — Pages
  'Create a landing page for our SEO services',
  'Build a content page about our marketing process',
  // Single actions — Design
  'Switch to a modern dark blue and coral color palette',
  'Try a warm earthy tone with serif headings',
  'Toggle blog section visibility on the homepage',
  // Single actions — Assets
  'Design an Instagram post promoting our services',
  'Create a Facebook cover with our brand colors',
  'Make a YouTube thumbnail for a marketing tips video',
  // Single actions — Email Marketing
  'Draft a monthly newsletter for our subscribers',
  'Create a re-engagement campaign for inactive leads',
  'Write a promotional email blast for a seasonal offer',
  'Draft a welcome email for new subscribers',
  // Single actions — Invoicing
  'Create a quick invoice for web design services',
  'Draft an invoice for a monthly SEO retainer',
  // Single actions — Client Outreach
  'Draft a project kickoff email for a new client',
  'Write a follow-up email checking in on deliverables',
  'Draft a proposal email for social media management',
  'Email a client with a project status update',
  // Navigation
  'Go to email marketing',
  'Open the meetings page',
  'Show me the client list',
  'Open bookkeeping',
  'Go to the asset center',
  'Open the blog editor',
  // Workflows
  'Build a spring promotion — update hero, blog, CTA, and social graphic',
  'Launch a new service — copy, blog, landing page, and email blast',
  'Client onboarding — welcome email, invoice, and kickoff email',
];
let _suggestionIdx = 0;

// ── TTS / STT ─────────────────────────────────────────────────────────────────
let _maVoice = 'lessac';
let _maCurrentAudio = null;

function maSetVoice(v) { _maVoice = v; }

function _ttsClean(text, maxChars = 0) {
  let clean = text
    .replace(/```[\s\S]*?```/g, 'code block.')
    .replace(/`[^`]+`/g, '')
    .replace(/\*\*([^*]+)\*\*/g, '$1')
    .replace(/\*([^*]+)\*/g, '$1')
    .replace(/#+\s/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/https?:\/\/\S+/g, 'link.')
    .replace(/\n+/g, ' ')
    .trim();
  if (maxChars > 0 && clean.length > maxChars) {
    const cut = clean.search(/[.!?](?:\s|$)/);
    clean = cut > 0 && cut < maxChars ? clean.slice(0, cut + 1) : clean.slice(0, maxChars);
  }
  return clean;
}

function _ttsSentences(text) {
  return text.match(/[^.!?]+[.!?]+\s*/g)?.map(s => s.trim()).filter(Boolean) || [text];
}

async function _ttsFetch(sentence) {
  const res = await fetch('/admin/tts', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ text: sentence, voice: _maVoice }),
  });
  const ct = res.headers.get('content-type') || '';
  if (!res.ok || !ct.includes('audio')) throw new Error(`TTS ${res.status}`);
  return URL.createObjectURL(await res.blob());
}

function _ttsPlayUrl(url) {
  return new Promise((resolve, reject) => {
    const audio = new Audio(url);
    _maCurrentAudio = audio;
    audio.onended = () => { URL.revokeObjectURL(url); resolve(); };
    audio.onerror = (e) => { URL.revokeObjectURL(url); reject(e); };
    audio.play().catch(reject);
  });
}

function maStopSpeaking() {
  if (_maCurrentAudio) { _maCurrentAudio.pause(); _maCurrentAudio = null; }
  document.querySelectorAll('.ma-speak-btn.speaking').forEach(b => b.classList.remove('speaking'));
}

async function maSpeak(text, btn, autoSpeak = false) {
  const clean = _ttsClean(text, autoSpeak ? 300 : 0);
  if (!clean) return;
  maStopSpeaking();
  if (btn) btn.classList.add('speaking');
  const sentences = _ttsSentences(clean);
  try {
    let nextFetch = _ttsFetch(sentences[0]);
    for (let i = 0; i < sentences.length; i++) {
      const prefetchNext = sentences[i + 1] ? _ttsFetch(sentences[i + 1]) : null;
      const url = await nextFetch;
      if (!btn || btn.classList.contains('speaking')) {
        await _ttsPlayUrl(url);
      } else {
        URL.revokeObjectURL(url); break;
      }
      nextFetch = prefetchNext;
    }
    _maCurrentAudio = null;
    if (btn) btn.classList.remove('speaking');
  } catch (err) {
    console.warn('[TTS] Piper failed, falling back to Web Speech:', err.message);
    _maCurrentAudio = null;
    if (window.speechSynthesis) {
      const utt = new SpeechSynthesisUtterance(clean);
      utt.rate = 1.0; utt.pitch = 0.95;
      utt.onend = () => { if (btn) btn.classList.remove('speaking'); };
      window.speechSynthesis.speak(utt);
    } else {
      if (btn) btn.classList.remove('speaking');
    }
  }
}

function maSpeakBtn(btn) {
  if (btn.classList.contains('speaking')) { maStopSpeaking(); return; }
  const content = btn.closest('.ma-msg')?.querySelector('.ma-bubble');
  if (!content) return;
  maSpeak(content.innerText || content.textContent, btn);
}

// ── STT (Web Speech API) ──────────────────────────────────────────────────────
let _maRecognition = null;
let _maIsRecording = false;

(function initMaSpeech() {
  const SpeechRec = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRec) return;
  _maRecognition = new SpeechRec();
  _maRecognition.continuous = false;
  _maRecognition.interimResults = false;
  _maRecognition.lang = 'en-US';
  _maRecognition.onresult = (e) => {
    const transcript = e.results[0][0].transcript;
    const input = document.getElementById('ma-input');
    if (input) { input.value = transcript; maSend(); }
    maStopMic();
  };
  _maRecognition.onerror = (e) => {
    if (e.error !== 'no-speech') console.warn('[STT]', e.error);
    maStopMic();
  };
  _maRecognition.onend = () => maStopMic();
})();

function maToggleMic() {
  if (_maIsRecording) { maStopMic(); return; }
  if (!_maRecognition) return;
  _maIsRecording = true;
  document.getElementById('ma-mic-btn')?.classList.add('recording');
  try { _maRecognition.start(); } catch(e) { maStopMic(); }
}

function maStopMic() {
  _maIsRecording = false;
  document.getElementById('ma-mic-btn')?.classList.remove('recording');
  try { if (_maRecognition) _maRecognition.stop(); } catch(e) { /* already stopped */ }
}

// ── Chat helpers ─────────────────────────────────────────────────────────────
function maAddMsg(role, html, isHtml) {
  const box = document.getElementById('ma-messages');
  const row = document.createElement('div');
  row.className = `ma-msg ma-msg-${role}`;
  const bub = document.createElement('div');
  bub.className = 'ma-bubble';
  if (isHtml) bub.innerHTML = html;
  else bub.textContent = html;
  row.appendChild(bub);
  if (role === 'agent') {
    const speakBtn = document.createElement('button');
    speakBtn.className = 'ma-speak-btn';
    speakBtn.title = 'Read aloud';
    speakBtn.textContent = '🔊';
    speakBtn.onclick = () => maSpeakBtn(speakBtn);
    row.appendChild(speakBtn);
  }
  box.appendChild(row);
  box.scrollTop = box.scrollHeight;
  return bub;
}

function maSetLoading(on) {
  const btn = document.getElementById('ma-send');
  btn.disabled = on;
  btn.textContent = on ? '…' : 'Send';
}

// ── Workflow: render checklist ─────────────────────────────────────────────────
function wfRender() {
  const panel = document.getElementById('ma-workflow');
  const tasksEl = document.getElementById('wf-tasks');
  const titleEl = document.getElementById('wf-title');
  const progEl = document.getElementById('wf-progress');
  const runBtn = document.getElementById('wf-run-btn');

  if (!wf.tasks.length) { panel.style.display = 'none'; return; }

  panel.style.display = 'block';
  titleEl.textContent = wf.title || 'Workflow';
  const done = wf.tasks.filter(t => t.status === 'done' || t.status === 'applied').length;
  const total = wf.tasks.length;
  progEl.textContent = `${done} / ${total}`;

  const hasPending = wf.tasks.some(t => t.status === 'pending');
  runBtn.style.display = hasPending ? '' : 'none';
  runBtn.disabled = wf.running;
  runBtn.textContent = wf.running ? 'Running…' : (done > 0 && hasPending ? 'Run Next' : 'Run All');

  const STATUS_ICONS = { pending: '○', running: '◉', done: '✓', failed: '✕', applied: '✓' };
  tasksEl.innerHTML = '';

  wf.tasks.forEach(t => {
    const row = document.createElement('div');
    row.className = 'wf-task';
    row.dataset.id = t.id;
    row.dataset.status = t.status;

    const deptColor = DEPT_COLORS[t.department] || '#1C2B4A';
    let actionsHtml = '';
    if (t.status === 'pending') {
      actionsHtml = `<button class="btn btn-ghost btn-xs" onclick="wfRunTask(${t.id})" ${wf.running ? 'disabled' : ''}>▶</button>`;
    } else if (t.status === 'done' && t.result) {
      actionsHtml = `<button class="btn btn-gold btn-xs" onclick="wfApply(${t.id})">Apply</button><button class="btn btn-ghost btn-xs" onclick="wfShowResult(${t.id})">View</button>`;
    } else if (t.status === 'applied') {
      actionsHtml = '<span style="font-size:0.62rem;color:#2E7D32;font-weight:600;">Saved</span>';
    } else if (t.status === 'failed') {
      actionsHtml = `<button class="btn btn-ghost btn-xs" onclick="wfRetry(${t.id})">Retry</button>`;
    }

    row.innerHTML = `
      <div class="wf-task-status"><span>${STATUS_ICONS[t.status] || '○'}</span></div>
      <div class="wf-task-info">
        <span class="wf-task-dept" style="background:${deptColor}">${t.department}</span>
        <span class="wf-task-label" title="${(t.task||'').replace(/"/g,'&quot;')}">${t.label}</span>
      </div>
      <div class="wf-task-actions">${actionsHtml}</div>
    `;
    tasksEl.appendChild(row);

    if ((t.status === 'done' || t.status === 'failed') && t.result?.message) {
      const msgRow = document.createElement('div');
      msgRow.className = 'wf-task-msg';
      msgRow.textContent = t.result.message;
      tasksEl.appendChild(msgRow);
    }
  });
}

// ── Workflow: run a single task ────────────────────────────────────────────────
async function wfRunTask(id) {
  const task = wf.tasks.find(t => t.id === id);
  if (!task || task.status !== 'pending') return;

  wf.running = true;
  task.status = 'running';
  wfRender();

  try {
    const r = await fetch('/admin/master-agent/run-task', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        department: task.department,
        task: task.task,
        section_type: task.section_type,
        page_type: task.page_type,
        nav_target: task.nav_target,
      }),
    });
    const data = await r.json();

    // Navigate — auto-redirect immediately
    if (data.navigate) {
      task.status = 'done';
      task.result = data;
      wf.running = false;
      wfRender();
      window.location.href = data.navigate;
      return;
    }

    if (data.error) {
      task.status = 'failed';
      task.result = { message: data.error };
      maAddMsg('agent', `✕ ${task.label}: ${data.error}`);
    } else {
      task.status = 'done';
      task.result = data;
      maHistory.push({ role: 'assistant', content: `✓ ${task.label}: ${data.message}` });
      maAddMsg('agent', `✓ <strong>${task.label}</strong> — ${data.message}`, true);

      // Single-task workflow: auto-show result card
      if (wf.tasks.length === 1) {
        maLastResult = data;
        maShowResult(data);
      }

      // Update suggestion chips with latest
      if (data.suggestions?.length) {
        _renderChips(data.suggestions);
      }
    }
  } catch (e) {
    task.status = 'failed';
    task.result = { message: 'Connection error' };
    maAddMsg('agent', `✕ ${task.label}: Connection error`);
  }

  wf.running = false;
  wfRender();

  // Continue if running all
  if (wf.runAllMode) wfRunNext();
}

function wfRunNext() {
  const next = wf.tasks.find(t => t.status === 'pending');
  if (next) {
    wfRunTask(next.id);
  } else {
    wf.runAllMode = false;
    const done = wf.tasks.filter(t => t.status === 'done' || t.status === 'applied').length;
    const failed = wf.tasks.filter(t => t.status === 'failed').length;
    if (done + failed === wf.tasks.length) {
      const msg = failed
        ? `✦ Workflow done — ${done} completed, ${failed} failed. Review and apply below.`
        : `✦ All ${done} tasks complete! Review and apply each one below.`;
      maAddMsg('agent', msg, true);
    }
  }
}

function wfRunAll() {
  wf.runAllMode = true;
  wfRunNext();
}

function wfRetry(id) {
  const task = wf.tasks.find(t => t.id === id);
  if (task) { task.status = 'pending'; task.result = null; wfRender(); wfRunTask(id); }
}

// ── Workflow: apply a task result to DB ────────────────────────────────────────
async function wfApply(id) {
  const task = wf.tasks.find(t => t.id === id);
  if (!task || !task.result || task.status !== 'done') return;

  try {
    const r = await fetch('/admin/master-agent/execute', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        department: task.result.department,
        fill: task.result.fill,
        section_type: task.result.section_type,
        page_type: task.result.page_type,
        label: task.result.fill?.heading || task.result.fill?.title,
      }),
    });
    const data = await r.json();

    if (data.ok) {
      task.status = 'applied';
      const linkHtml = data.editUrl ? ` <a href="${data.editUrl}" style="color:var(--gold);">View →</a>` : '';
      maAddMsg('agent', `✓ Applied: ${data.message}${linkHtml}`, true);
    } else {
      maAddMsg('agent', 'Could not apply: ' + (data.message || data.error));
    }
  } catch (e) {
    maAddMsg('agent', 'Save failed — please try again.');
  }
  wfRender();
}

function wfShowResult(id) {
  const task = wf.tasks.find(t => t.id === id);
  if (!task || !task.result) return;
  maLastResult = task.result;
  maShowResult(task.result);
}

function wfClear() {
  wf = { title: '', tasks: [], running: false, runAllMode: false };
  wfRender();
  document.getElementById('ma-result').style.display = 'none';
}

// ── Send (plan → workflow or single-task) ─────────────────────────────────────
async function maSend() {
  const input = document.getElementById('ma-input');
  const text = input.value.trim();
  if (!text || wf.running) return;
  input.value = '';
  document.getElementById('ma-quick-wrap').style.display = 'none';
  document.getElementById('ma-result').style.display = 'none';

  maHistory.push({ role: 'user', content: text });
  maAddMsg('user', text);
  maSetLoading(true);

  // Step 1 — Plan: classify as single task or multi-step workflow
  const planBub = maAddMsg('agent', '✦ Planning…');
  planBub.style.opacity = '0.55';
  planBub.style.fontSize = '0.8rem';

  try {
    const pr = await fetch('/admin/master-agent/plan', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: text }),
    });
    const plan = await pr.json();
    const taskCount = plan.tasks?.length || 1;

    if (taskCount > 1) {
      // ── Multi-step workflow ──
      planBub.innerHTML = `✦ Planned <strong>${taskCount} tasks</strong>: <em>${plan.title}</em>`;
      maHistory.push({ role: 'assistant', content: `Planned workflow: ${plan.title} (${taskCount} tasks)` });

      wf = {
        title: plan.title || 'Workflow',
        tasks: plan.tasks.map((t, i) => ({
          id: i + 1,
          department: t.department || 'copy',
          task: t.task || text,
          label: t.label || (t.task || '').slice(0, 40),
          section_type: t.section_type || null,
          page_type: t.page_type || null,
          nav_target: t.nav_target || null,
          status: 'pending',
          result: null,
        })),
        running: false,
        runAllMode: false,
      };
      wfRender();
      maSetLoading(false);
      return;
    }

    // ── Navigate — instant redirect, no LLM needed ──
    const singleTask = plan.tasks?.[0];
    if (singleTask?.department === 'navigate') {
      planBub.closest('.ma-msg').remove();
      maSetLoading(false);
      try {
        const nr = await fetch('/admin/master-agent/run-task', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ department: 'navigate', task: text, nav_target: singleTask.nav_target }),
        });
        const navData = await nr.json();
        if (navData.navigate) { window.location.href = navData.navigate; return; }
      } catch { /* fall through */ }
    }

    // ── Single task — run immediately via research → generate ──
    planBub.closest('.ma-msg').remove();

    const searchBub = maAddMsg('agent', '🔍 Researching…');
    searchBub.style.opacity = '0.55';
    searchBub.style.fontSize = '0.8rem';

    let research = null;
    try {
      const rr = await fetch('/admin/master-agent/research', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: maHistory }),
      });
      research = await rr.json();
      if (research?.searchQuery) {
        searchBub.innerHTML = `🔍 Searched: <em>${research.searchQuery}</em>`;
      }
    } catch { searchBub.textContent = '🔍 Researching…'; }

    const typingBub = maAddMsg('agent', '✦ Writing…');
    typingBub.style.opacity = '0.5';

    try {
      const r = await fetch('/admin/master-agent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: maHistory, research }),
      });
      const data = await r.json();
      typingBub.closest('.ma-msg').remove();

      if (data.error) {
        maHistory.pop();
        maAddMsg('agent', 'Error: ' + data.error);
        return;
      }

      maLastResult = data;
      maHistory.push({ role: 'assistant', content: data.message });

      // Show as single-item workflow for consistency
      wf = {
        title: plan.title || data.message?.slice(0, 40) || 'Task',
        tasks: [{
          id: 1, department: data.department, task: text,
          label: plan.tasks?.[0]?.label || data.message?.slice(0, 40) || text.slice(0, 40),
          section_type: data.section_type, page_type: data.page_type,
          status: 'done', result: data,
        }],
        running: false, runAllMode: false,
      };
      wfRender();

      const agentBub = maAddMsg('agent', data.message + ' <span style="font-size:0.75rem;color:var(--slate);">See workflow below ↓</span>', true);
      maShowResult(data);
      const speakBtn = agentBub.closest('.ma-msg')?.querySelector('.ma-speak-btn');
      maSpeak(data.message, speakBtn, true);
    } catch (e) {
      typingBub.closest('.ma-msg').remove();
      maHistory.pop();
      maAddMsg('agent', 'Connection error — please try again.');
    }
  } catch (e) {
    planBub.closest('.ma-msg').remove();
    maHistory.pop();
    maAddMsg('agent', 'Connection error — please try again.');
  } finally {
    maSetLoading(false);
  }
}

// ── Quick send (used by prompt chips) ────────────────────────────────────────
function maQuickSend(prompt) {
  document.getElementById('ma-input').value = prompt;
  maSend();
}

// ── Result card ──────────────────────────────────────────────────────────────
function maShowResult(data) {
  const res      = document.getElementById('ma-result');
  const deptEl   = document.getElementById('ma-result-dept');
  const msgEl    = document.getElementById('ma-result-msg');
  const fieldsEl = document.getElementById('ma-result-fields');
  const execBtn  = document.getElementById('ma-execute-btn');
  const editorBtn = document.getElementById('ma-editor-btn');

  deptEl.textContent = data.department;
  deptEl.style.background = DEPT_COLORS[data.department] || '#1C2B4A';
  msgEl.textContent = data.message;

  fieldsEl.innerHTML = '';
  const entries = Object.entries(data.fill || {}).filter(([, v]) => v && String(v).trim());
  entries.forEach(([k, v]) => {
    const row = document.createElement('div');
    row.className = 'ma-field-row';
    const preview = String(v).replace(/<[^>]+>/g, ' ').trim().slice(0, 160);
    row.innerHTML = `<span class="ma-field-key">${k.replace(/_/g,' ')}</span><span class="ma-field-val">${preview}${String(v).length > 160 ? '…' : ''}</span>`;
    fieldsEl.appendChild(row);
  });

  execBtn.textContent = 'Apply Now';
  execBtn.disabled = false;
  editorBtn.textContent = data.action?.label || 'Open in Editor';
  res.style.display = 'block';

  // Update quick chips with contextual follow-up suggestions
  const quick = document.getElementById('ma-quick');
  quick.innerHTML = '';
  if (Array.isArray(data.suggestions) && data.suggestions.length) {
    data.suggestions.forEach(s => {
      const btn = document.createElement('button');
      btn.className = 'btn btn-ghost btn-sm ma-quick-btn';
      btn.textContent = s;
      btn.onclick = () => maQuickSend(s);
      quick.appendChild(btn);
    });
    document.getElementById('ma-quick-wrap').style.display = 'flex';
  }
}

// ── Apply Now ─────────────────────────────────────────────────────────────────
async function maExecute() {
  if (!maLastResult || maExecuting) return;
  maExecuting = true;
  const btn = document.getElementById('ma-execute-btn');
  btn.textContent = 'Saving…';
  btn.disabled = true;

  try {
    const r = await fetch('/admin/master-agent/execute', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        department: maLastResult.department,
        fill: maLastResult.fill,
        section_type: maLastResult.section_type,
        page_type: maLastResult.page_type,
        label: maLastResult.fill?.heading || maLastResult.fill?.title,
      }),
    });
    const data = await r.json();

    if (data.ok) {
      document.getElementById('ma-result').style.display = 'none';
      const linkHtml = data.editUrl
        ? ` <a href="${data.editUrl}" style="color:var(--gold);text-decoration:underline;">View →</a>`
        : '';
      maHistory.push({ role: 'assistant', content: '✓ ' + data.message });
      maAddMsg('agent', `✓ ${data.message}${linkHtml}`, true);
      // Sync workflow checklist
      const wfTask = wf.tasks.find(t => t.result === maLastResult);
      if (wfTask) { wfTask.status = 'applied'; wfRender(); }
    } else {
      maAddMsg('agent', 'Could not apply: ' + (data.message || data.error));
    }
  } catch (e) {
    maAddMsg('agent', 'Save failed — please try again.');
  } finally {
    maExecuting = false;
    btn.textContent = 'Apply Now';
    btn.disabled = false;
  }
}

// ── Open in Editor ───────────────────────────────────────────────────────────
function maOpenEditor() {
  if (!maLastResult) return;
  try { sessionStorage.setItem('slab_agent_fill', JSON.stringify(maLastResult)); } catch {}
  window.location.href = maLastResult.action?.url || '/admin';
}

// ── Cycling Suggestions ───────────────────────────────────────────────────────
let _cycleSpinDeg = 0;

function _renderChips(picks) {
  const quick = document.getElementById('ma-quick');
  quick.innerHTML = '';
  picks.forEach((s, idx) => {
    const btn = document.createElement('button');
    btn.className = 'btn btn-ghost btn-sm ma-quick-btn ma-chip-enter';
    const label = s.length <= 40 ? s : (s.match(/^[^—,]+/)?.[0]?.trim() || s.slice(0, 35)) + '…';
    btn.textContent = label;
    btn.title = s;
    btn.onclick = () => maQuickSend(s);
    quick.appendChild(btn);
    setTimeout(() => btn.classList.replace('ma-chip-enter', 'ma-chip-visible'), 40 + idx * 70);
  });
  document.getElementById('ma-quick-wrap').style.display = 'flex';
}

async function maCycleSuggestions() {
  const quick = document.getElementById('ma-quick');

  // Fade out old chips
  const oldBtns = quick.querySelectorAll('.ma-quick-btn');
  oldBtns.forEach(b => { b.classList.remove('ma-chip-visible'); b.classList.add('ma-chip-enter'); });

  // Spin the recycle icon
  _cycleSpinDeg += 360;
  const cycleBtn = document.getElementById('ma-cycle-btn');
  if (cycleBtn) cycleBtn.style.transform = `rotate(${_cycleSpinDeg}deg)`;

  const delay = oldBtns.length ? 180 : 0;

  // Try server first for fresh randoms, fall back to local pool
  let picks;
  try {
    const r = await fetch('/admin/master-agent/suggestions');
    const data = await r.json();
    if (data.suggestions?.length) picks = data.suggestions;
  } catch { /* fall back to local */ }

  if (!picks) {
    picks = [];
    for (let i = 0; i < 4; i++) {
      picks.push(SUGGESTION_POOL[(_suggestionIdx + i) % SUGGESTION_POOL.length]);
    }
    _suggestionIdx = (_suggestionIdx + 4) % SUGGESTION_POOL.length;
  }

  setTimeout(() => _renderChips(picks), delay);
}

// Shuffle pool on load so each session feels fresh
(function shufflePool() {
  for (let i = SUGGESTION_POOL.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [SUGGESTION_POOL[i], SUGGESTION_POOL[j]] = [SUGGESTION_POOL[j], SUGGESTION_POOL[i]];
  }
  maCycleSuggestions();
})();

// ── Enter key ────────────────────────────────────────────────────────────────
document.getElementById('ma-input').addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); maSend(); }
});
</script>

