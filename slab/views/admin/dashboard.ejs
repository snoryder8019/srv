  function hideModal() {
    overlay.style.display = 'none';
    // Remove golive param from URL
    const url = new URL(window.location);
    url.searchParams.delete('golive');
    history.replaceState({}, '', url);
  }

  // Show modal if ?golive=1 in URL
  if (new URLSearchParams(window.location.search).get('golive') === '1') {
    showModal();
  }

  // Also wire up any Go Live buttons on the page
  document.querySelectorAll('[href*="golive=1"]').forEach(el => {
