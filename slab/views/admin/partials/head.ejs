<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — <%= (typeof brand !== 'undefined' && brand?.name) ? brand.name + ' Admin' : 'Admin' %></title>
  <%
    const _bd = typeof brandDesign !== 'undefined' ? brandDesign : {};
    const _hFont = _bd.font_heading || 'Cormorant Garamond';
    const _bFont = _bd.font_body    || 'Jost';
    const _fontMap = {
      'Cormorant Garamond': 'Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400',
      'Playfair Display': 'Playfair+Display:wght@400;600;700',
      'Lora': 'Lora:wght@400;600;700',
      'Merriweather': 'Merriweather:wght@300;400;700',
      'Libre Baskerville': 'Libre+Baskerville:wght@400;700',
      'Jost': 'Jost:wght@300;400;500;600',
      'Inter': 'Inter:wght@300;400;500;600;700',
      'Poppins': 'Poppins:wght@300;400;500;600;700',
      'Raleway': 'Raleway:wght@300;400;500;600;700',
      'Nunito': 'Nunito:wght@300;400;500;600;700',
      'DM Sans': 'DM+Sans:wght@300;400;500;600;700',
    };
    const _hFontUrl = _fontMap[_hFont] || _fontMap['Cormorant Garamond'];
    const _bFontUrl = _fontMap[_bFont] || _fontMap['Jost'];
    const _fontsParam = _hFontUrl === _bFontUrl ? _hFontUrl : _hFontUrl + '&family=' + _bFontUrl;
  %>
  <link href="https://fonts.googleapis.com/css2?family=<%= _fontsParam %>&display=swap" rel="stylesheet">
  <style>
    /* --- RESET & BASE --- */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --navy: <%= _bd.color_primary || '#1C2B4A' %>; --navy-deep: <%= _bd.color_primary_deep || '#0F1B30' %>; --navy-mid: <%= _bd.color_primary_mid || '#2E4270' %>;
      --gold: <%= _bd.color_accent || '#C9A848' %>; --gold-light: <%= _bd.color_accent_light || '#E8D08A' %>;
      --ivory: <%= _bd.color_bg || '#F5F3EF' %>; --ivory-mid: #E6E1D6;
      --dark: <%= _bd.color_primary_deep || '#0F1B30' %>; --white: #FDFCFA;
      --on-ivory: <%= _bd._on_bg || '#0F1B30' %>; --on-ivory-muted: <%= _bd._on_bg_muted || '#6B7380' %>;
      --on-navy: <%= _bd._on_primary || '#FDFCFA' %>; --on-navy-deep: <%= _bd._on_primary_deep || '#FDFCFA' %>; --on-navy-mid: <%= _bd._on_primary_mid || '#FDFCFA' %>;
      --on-gold: <%= _bd._on_accent || '#0F1B30' %>; --on-gold-light: <%= _bd._on_accent_light || '#0F1B30' %>;
      --slate: var(--on-ivory-muted);
      --danger: #B91C1C; --success: #15803D; --warn: #B45309;
      --font-heading: '<%= _hFont %>', serif;
      --font-body: '<%= _bFont %>', sans-serif;
    }
    body { font-family: var(--font-body); background: var(--ivory); color: var(--dark); min-height: 100vh; overflow-x: hidden; }
    .layout { display: flex; min-height: 100vh; overflow-x: hidden; }
    .main { overflow-x: hidden; }

    /* --- SIDEBAR --- */
    .sidebar {
      width: 240px; flex-shrink: 0;
      background: var(--navy-deep);
      display: flex; flex-direction: column;
      position: fixed; top: 0; left: 0; bottom: 0;
      z-index: 100;
    }
    /* ── Slab Switcher ── */
    .slab-switcher { padding: 12px 14px 0; position: relative; }
    .slab-switcher-btn { display:flex; align-items:center; gap:10px; width:100%; padding:9px 12px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:6px; cursor:pointer; transition:all 0.15s; color:var(--white); font-family:var(--font-body); }
    .slab-switcher-btn:hover, .slab-switcher-btn.open { background:rgba(255,255,255,0.08); border-color:rgba(201,168,72,0.3); }
    .slab-switcher-icon { width:28px; height:28px; border-radius:4px; background:var(--gold); color:var(--navy-deep); display:flex; align-items:center; justify-content:center; font-family:var(--font-heading); font-size:0.9rem; font-weight:600; flex-shrink:0; }
    .slab-switcher-name { flex:1; text-align:left; font-size:0.75rem; font-weight:500; letter-spacing:0.02em; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .slab-switcher-arrow { font-size:0.55rem; color:rgba(255,255,255,0.35); transition:transform 0.15s; }
    .slab-switcher-btn.open .slab-switcher-arrow { transform:rotate(180deg); }
    .slab-switcher-dropdown { display:none; position:absolute; left:14px; right:14px; top:100%; margin-top:4px; background:var(--navy); border:1px solid rgba(255,255,255,0.1); border-radius:6px; box-shadow:0 12px 40px rgba(0,0,0,0.5); z-index:200; max-height:320px; overflow-y:auto; }
    .slab-switcher-dropdown.open { display:block; }
    .slab-switcher-loading { padding:16px; text-align:center; font-size:0.72rem; color:rgba(255,255,255,0.4); }
    .slab-dd-item { display:flex; align-items:center; gap:10px; padding:10px 14px; text-decoration:none; color:var(--white); transition:background 0.1s; cursor:pointer; }
    .slab-dd-item:hover { background:rgba(255,255,255,0.06); }
    .slab-dd-item.current { background:rgba(201,168,72,0.08); }
    .slab-dd-icon { width:32px; height:32px; border-radius:4px; background:rgba(255,255,255,0.08); color:rgba(255,255,255,0.6); display:flex; align-items:center; justify-content:center; font-family:var(--font-heading); font-size:0.85rem; font-weight:600; flex-shrink:0; }
    .slab-dd-item.current .slab-dd-icon { background:var(--gold); color:var(--navy-deep); }
    .slab-dd-info { flex:1; min-width:0; }
    .slab-dd-name { display:block; font-size:0.78rem; font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .slab-dd-domain { display:block; font-size:0.6rem; color:rgba(255,255,255,0.35); margin-top:1px; }
    .slab-dd-check { color:var(--gold); font-size:0.85rem; flex-shrink:0; }
    .slab-dd-divider { height:1px; background:rgba(255,255,255,0.08); margin:4px 0; }
    .slab-dd-plus { background:rgba(201,168,72,0.15); color:var(--gold); font-size:1.1rem; font-weight:400; }
    .slab-dd-add .slab-dd-domain { color:var(--gold); opacity:0.7; }

    .sidebar-brand { padding: 24px 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .sidebar-brand-name { font-family: var(--font-heading); font-size: 1.5rem; font-weight: 400; color: var(--white); letter-spacing: 0.02em; text-decoration: none; display: block; }
    .sidebar-brand-sub { font-size: 0.56rem; font-weight: 600; letter-spacing: 0.26em; text-transform: uppercase; color: var(--gold); margin-top: 3px; }
    .sidebar-nav { flex: 1; padding: 16px 0; overflow-y: auto; }
    .sidebar-section { font-size: 0.56rem; font-weight: 600; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(255,255,255,0.2); padding: 16px 24px 6px; }
    .sidebar-nav a {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 24px; font-size: 0.8rem; font-weight: 500;
      letter-spacing: 0.04em; color: rgba(255,255,255,0.45);
      text-decoration: none; transition: all 0.15s;
      border-left: 2px solid transparent;
    }
    .sidebar-nav a:hover { color: var(--white); background: rgba(255,255,255,0.04); }
    .sidebar-nav a.active { color: var(--gold-light); border-left-color: var(--gold); background: rgba(201,168,72,0.06); }
    .sidebar-nav a .icon { font-size: 1rem; width: 18px; text-align: center; flex-shrink: 0; }
    .sidebar-footer { padding: 20px 24px; border-top: 1px solid rgba(255,255,255,0.06); }
    .sidebar-user { font-size: 0.75rem; font-weight: 500; color: rgba(255,255,255,0.45); margin-bottom: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .btn-logout { display: block; text-align: center; padding: 8px; border: 1px solid rgba(255,255,255,0.1); border-radius: 2px; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.35); text-decoration: none; transition: all 0.15s; }
    .btn-logout:hover { border-color: rgba(185,28,28,0.5); color: #FCA5A5; background: rgba(185,28,28,0.08); }

    /* --- MAIN --- */
    .main { flex: 1; margin-left: 240px; display: flex; flex-direction: column; min-height: 100vh; }

    /* --- TOPBAR --- */
    .topbar { background: var(--white); border-bottom: 1px solid var(--ivory-mid); padding: 16px 36px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
    .topbar-title { font-family: var(--font-heading); font-size: 1.6rem; font-weight: 300; color: var(--dark); }
    .topbar-actions { display: flex; gap: 12px; align-items: center; }

    /* --- CONTENT --- */
    .content { padding: 32px 36px; flex: 1; }

    /* --- BUTTONS --- */
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 22px; border-radius: 2px; font-family: var(--font-body); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; border: none; cursor: pointer; transition: all 0.15s; }
    .btn-navy { background: var(--navy); color: var(--on-navy); }
    .btn-navy:hover { background: var(--navy-deep); color: var(--on-navy-deep); }
    .btn-gold { background: var(--gold); color: var(--dark); }
    .btn-gold:hover { background: var(--gold-light); }
    .btn-ghost { background: transparent; color: var(--navy); border: 1.5px solid var(--navy-mid); }
    .btn-ghost:hover { border-color: var(--navy-deep); }
    .btn-danger { background: transparent; color: var(--danger); border: 1.5px solid rgba(185,28,28,0.3); }
    .btn-danger:hover { background: rgba(185,28,28,0.06); }
    .btn-sm { padding: 6px 14px; font-size: 0.7rem; }

    /* --- CARDS --- */
    .card { background: var(--white); border: 1px solid var(--ivory-mid); border-radius: 2px; padding: 24px; }
    .card + .card { margin-top: 16px; }
    .card-title { font-family: var(--font-heading); font-size: 1.2rem; font-weight: 400; color: var(--dark); margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid var(--ivory-mid); }

    /* --- STAT CARDS --- */
    .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px; margin-bottom: 32px; }
    .stat-card { background: var(--white); border: 1px solid var(--ivory-mid); padding: 20px; }
    .stat-label { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--slate); margin-bottom: 8px; }
    .stat-value { font-family: var(--font-heading); font-size: 2.8rem; font-weight: 300; color: var(--navy); line-height: 1; }
    .stat-value.gold { color: var(--gold); }

    /* --- TABLE --- */
    .table-wrap { background: var(--white); border: 1px solid var(--ivory-mid); border-radius: 2px; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
    thead th { background: var(--ivory); font-size: 0.68rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--slate); padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--ivory-mid); }
    tbody td { padding: 14px 16px; border-bottom: 1px solid var(--ivory); color: var(--dark); vertical-align: middle; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover { background: rgba(245,243,239,0.6); }

    /* --- BADGES --- */
    .badge { display: inline-flex; align-items: center; padding: 3px 10px; border-radius: 2px; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; }
    .badge-active { background: rgba(21,128,61,0.14); color: var(--success); }
    .badge-draft { background: rgba(107,115,128,0.15); color: var(--slate); }
    .badge-prospect { background: rgba(201,168,72,0.18); color: var(--on-gold); }
    .badge-inactive { background: rgba(185,28,28,0.12); color: var(--danger); }
    .badge-paid { background: rgba(21,128,61,0.14); color: var(--success); }
    .badge-unpaid { background: rgba(185,28,28,0.12); color: var(--danger); }
    .badge-featured { background: rgba(201,168,72,0.20); color: var(--on-gold); }

    /* --- FORMS --- */
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .form-grid.cols-1 { grid-template-columns: 1fr; }
    .form-grid.cols-3 { grid-template-columns: 1fr 1fr 1fr; }
    .form-field { display: flex; flex-direction: column; gap: 6px; }
    .form-field.span-2 { grid-column: span 2; }
    .form-field.span-3 { grid-column: span 3; }
    label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--slate); }
    input[type=text], input[type=email], input[type=tel], input[type=date], input[type=number], input[type=url], textarea, select {
      background: var(--white); border: 1px solid var(--ivory-mid);
      padding: 11px 14px; border-radius: 2px;
      font-family: var(--font-body); font-size: 0.9rem; font-weight: 300; color: var(--dark);
      outline: none; transition: border-color 0.15s;
      -webkit-appearance: none; appearance: none;
    }
    input:focus, textarea:focus, select:focus { border-color: var(--navy); }
    input::placeholder, textarea::placeholder { color: var(--ivory-mid); }
    textarea { resize: vertical; min-height: 100px; }
    .form-check { display: flex; align-items: center; gap: 10px; }
    .form-check input[type=checkbox] { width: 16px; height: 16px; accent-color: var(--navy); appearance: auto; -webkit-appearance: auto; }
    .form-check label { text-transform: none; letter-spacing: 0.02em; font-size: 0.88rem; color: var(--dark); }

    /* --- TABS --- */
    .tabs { display: flex; border-bottom: 1px solid var(--ivory-mid); margin-bottom: 24px; gap: 0; }
    .tab-link { padding: 12px 20px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--slate); text-decoration: none; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all 0.15s; }
    .tab-link:hover { color: var(--navy); }
    .tab-link.active { color: var(--navy); border-bottom-color: var(--navy); }

    /* --- ALERTS --- */
    .alert { padding: 12px 16px; border-radius: 2px; font-size: 0.85rem; margin-bottom: 20px; }
    .alert-success { background: rgba(21,128,61,0.08); border: 1px solid rgba(21,128,61,0.2); color: var(--success); }
    .alert-error { background: rgba(185,28,28,0.07); border: 1px solid rgba(185,28,28,0.2); color: var(--danger); }

    /* --- EMPTY STATE --- */
    .empty { text-align: center; padding: 64px 24px; color: var(--slate); }
    .empty-icon { font-size: 2.4rem; margin-bottom: 12px; opacity: 0.4; }
    .empty p { font-size: 0.9rem; font-weight: 300; }

    /* --- MISC --- */
    .text-gold { color: var(--gold); }
    .text-slate { color: var(--slate); font-weight: 300; }
    .mt-24 { margin-top: 24px; }
    .flex-between { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }

    /* --- MOBILE TOGGLE BUTTON (hidden on desktop) --- */
    .sidebar-toggle {
      display: none;
      position: fixed;
      top: 14px; left: 14px;
      z-index: 300;
      background: var(--navy-deep);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 4px;
      width: 40px; height: 40px;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 5px;
      cursor: pointer;
      padding: 0;
    }
    .sidebar-toggle span {
      display: block;
      width: 18px; height: 2px;
      background: rgba(255,255,255,0.7);
      border-radius: 2px;
      transition: all 0.2s;
    }
    .sidebar-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .sidebar-toggle.open span:nth-child(2) { opacity: 0; }
    .sidebar-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* --- SIDEBAR OVERLAY --- */
    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(15,27,48,0.55);
      z-index: 99;
      backdrop-filter: blur(3px);
      -webkit-backdrop-filter: blur(3px);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 820px) {
      /* show hamburger */
      .sidebar-toggle { display: flex; }
      .sidebar-overlay.active { display: block; }

      /* sidebar slides in from left */
      .sidebar {
        transform: translateX(-260px);
        transition: transform 0.25s cubic-bezier(0.4,0,0.2,1);
        z-index: 200;
        box-shadow: none;
      }
      .sidebar.open {
        transform: translateX(0);
        box-shadow: 4px 0 32px rgba(15,27,48,0.4);
      }

      /* main takes full width */
      .main { margin-left: 0 !important; }

      /* topbar: indent past hamburger */
      .topbar { padding: 12px 16px 12px 62px; flex-wrap: wrap; gap: 8px; }
      .topbar-title { font-size: 1.25rem; }
      .topbar-actions { gap: 6px; flex-wrap: wrap; }
      .topbar-actions .btn { padding: 8px 14px; font-size: 0.7rem; }

      /* content padding */
      .content { padding: 20px 16px; }

      /* forms go single column */
      .form-grid,
      .form-grid.cols-3 { grid-template-columns: 1fr !important; }
      .form-field.span-2,
      .form-field.span-3 { grid-column: span 1 !important; }

      /* tables scroll horizontally — only data tables inside .table-wrap get min-width */
      .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
      .table-wrap table { min-width: 560px; }

      /* stat grid: 2 columns */
      .stat-grid { grid-template-columns: repeat(2, 1fr) !important; }

      /* flex-between stacks */
      .flex-between { flex-direction: column; align-items: flex-start; gap: 10px; }

      /* tabs scroll */
      .tabs { overflow-x: auto; -webkit-overflow-scrolling: touch; white-space: nowrap; padding-bottom: 0; }
      .tab-link { white-space: nowrap; }

      /* cards */
      .card { padding: 16px; }
    }

    /* Agent panel — shrinks to fit viewport on tablets, full-width on phones */
    @media (max-width: 820px) {
      #agentPanel {
        width: min(420px, 100vw) !important;
        max-width: 100vw !important;
      }
    }
    @media (max-width: 520px) {
      .topbar { padding: 10px 12px; }
      .topbar-title { font-size: 1rem; }
      .topbar-actions { flex-wrap: wrap; justify-content: flex-end; gap: 4px; }
      .topbar-actions .btn { font-size: 0.65rem; padding: 5px 8px; }
      .stat-grid { grid-template-columns: 1fr 1fr !important; }
      .stat-value { font-size: 2.2rem; }

      /* Agent slide-in panel — full width on phones */
      #agentPanel {
        width: 100vw !important;
        right: -100vw !important;
        height: 100vh !important;
        height: 100dvh !important;
      }
      #agentPanel.open {
        right: 0 !important;
      }

      /* Form action button rows — wrap on small screens */
      .form-actions {
        flex-wrap: wrap !important;
      }
      .form-actions .btn {
        flex: 1 1 auto;
        justify-content: center;
        min-width: 120px;
      }
    }
  </style>
  <!-- Driver.js Tour -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css">
  <link rel="stylesheet" href="/css/adminTour.css">
  <script src="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.js.iife.js"></script>
  <script src="/js/adminTour.js"></script>
  <script src="/js/bugButton.js" defer></script>
</head>
<body>
<%- include('../../partials/maintenance-banner') %>
<% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
<div style="position:fixed;top:8px;right:8px;z-index:9999;background:linear-gradient(135deg,#6B3FA0,#8B5FC0);color:#E8D08A;font-size:9px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;padding:4px 10px;border-radius:2px;box-shadow:0 2px 8px rgba(107,63,160,0.3);pointer-events:none;">Superadmin</div>
<% } else { %>
<div style="position:fixed;top:8px;right:8px;z-index:9999;background:linear-gradient(135deg,#C9A848,#E8D08A);color:#1C2B4A;font-size:9px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;padding:4px 10px;border-radius:2px;box-shadow:0 2px 8px rgba(201,168,72,0.3);pointer-events:none;">Admin</div>
<% } %>
<div class="layout">
