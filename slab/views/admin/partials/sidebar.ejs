<!-- Mobile hamburger -->
<button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle menu">
  <span></span><span></span><span></span>
</button>

<!-- Sidebar overlay (mobile tap-to-close) -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<aside class="sidebar" id="sidebar">
  <!-- Slab Switcher -->
  <div class="slab-switcher" id="slabSwitcher">
    <button class="slab-switcher-btn" id="slabSwitcherBtn" title="Switch workspace">
      <span class="slab-switcher-icon"><%= (brand?.name || '?')[0].toUpperCase() %></span>
      <span class="slab-switcher-name"><%= brand?.name || 'Workspace' %></span>
      <span class="slab-switcher-arrow">&#9662;</span>
    </button>
    <div class="slab-switcher-dropdown" id="slabDropdown">
      <div class="slab-switcher-loading">Loading workspaces...</div>
    </div>
  </div>

  <div class="sidebar-brand">
    <a href="/admin" class="sidebar-brand-name"><% const _bsp = parseInt((typeof brandDesign !== 'undefined' ? brandDesign : {}).nav_logo_split) || 0; if (_bsp > 0) { %><span style="color:var(--gold)"><%- (brand?.name||'').slice(0,_bsp) %></span><%- (brand?.name||'').slice(_bsp) %><% } else { %><%- brand?.name || '' %><% } %></a>
    <div class="sidebar-brand-sub">Admin Portal</div>
  </div>
  <nav class="sidebar-nav">
    <span class="sidebar-section">Overview</span>
    <a href="/admin" class="<%= page === 'dashboard' ? 'active' : '' %>">
      <span class="icon">▦</span> Dashboard
    </a>
    <span class="sidebar-section">Content</span>
    <a href="/admin/portfolio" class="<%= page === 'portfolio' ? 'active' : '' %>">
      <span class="icon">◈</span> Portfolio
    </a>
    <a href="/admin/blog" class="<%= page === 'blog' ? 'active' : '' %>">
      <span class="icon">✍</span> Blog
    </a>
    <a href="/admin/pages" class="<%= page === 'pages' ? 'active' : '' %>">
      <span class="icon">◻</span> Pages
    </a>
    <a href="/admin/sections" class="<%= page === 'sections' ? 'active' : '' %>">
      <span class="icon">⊞</span> Sections
    </a>
    <a href="/admin/copy" class="<%= page === 'copy' ? 'active' : '' %>">
      <span class="icon">✎</span> Site Copy
    </a>
    <a href="/admin/design" class="<%= page === 'design' ? 'active' : '' %>">
      <span class="icon">◑</span> Design & Settings
    </a>
    <a href="/admin/assets" class="<%= page === 'assets' ? 'active' : '' %>">
      <span class="icon">◈</span> Assets
    </a>
    <span class="sidebar-section">Business</span>
    <a href="/admin/clients" class="<%= page === 'clients' ? 'active' : '' %>">
      <span class="icon">◉</span> Clients
    </a>
    <a href="/admin/onboarding" class="<%= page === 'onboarding' ? 'active' : '' %>">
      <span class="icon">&#9638;</span> Onboarding
    </a>
    <a href="/admin/meetings" class="<%= page === 'meetings' ? 'active' : '' %>">
      <span class="icon">◫</span> Meetings
    </a>
    <a href="/admin/bookkeeping" class="<%= page === 'bookkeeping' ? 'active' : '' %>">
      <span class="icon">$</span> Bookkeeping
    </a>
    <a href="/admin/email-marketing" class="<%= page === 'email-marketing' ? 'active' : '' %>">
      <span class="icon">@</span> Email Marketing
    </a>
    <a href="/admin/tickets" class="<%= page === 'tickets' ? 'active' : '' %>">
      <span class="icon">&#9888;</span> Support Tickets
    </a>
    <span class="sidebar-section">Admin</span>
    <a href="/admin/users" class="<%= page === 'users' ? 'active' : '' %>">
      <span class="icon">◈</span> Users & Permissions
    </a>
    <a href="/admin/settings" class="<%= page === 'settings' ? 'active' : '' %>">
      <span class="icon">⚙</span> Settings & Keys
    </a>
    <a href="/admin/docs" class="<%= page === 'docs' ? 'active' : '' %>">
      <span class="icon">☰</span> Docs & Guides
    </a>
    <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
    <span class="sidebar-section">Superadmin</span>
    <a href="/admin/huginn" class="<%= page === 'huginn' ? 'active' : '' %>">
      <span class="icon">&#x16B6;</span> Huginn
    </a>
    <a href="/admin/super/tenants" class="<%= page === 'super-tenants' ? 'active' : '' %>">
      <span class="icon">◎</span> Tenants
    </a>
    <a href="/admin/super/tickets" class="<%= page === 'super-tickets' ? 'active' : '' %>">
      <span class="icon">&#9873;</span> Escalated Tickets
    </a>
    <a href="/admin/scanner" class="<%= page === 'scanner' ? 'active' : '' %>">
      <span class="icon">&#9211;</span> Site Scanner
    </a>
    <% } %>
    <span class="sidebar-section">Site</span>
    <a href="/" target="_blank">
      <span class="icon">↗</span> View Site
    </a>
    <% if (typeof tenant !== 'undefined' && tenant?.isPreview) { %>
    <div style="margin:16px 0 8px; padding:16px; background:rgba(201,168,72,0.08); border:1px solid rgba(201,168,72,0.2); border-radius:6px;">
      <div style="font-size:11px; text-transform:uppercase; letter-spacing:1px; color:rgba(201,168,72,0.7); margin-bottom:6px;">Preview Mode</div>
      <div style="font-size:12px; color:rgba(255,255,255,0.6); line-height:1.5; margin-bottom:10px;">Your site is not public yet. Go live to make it accessible to visitors.</div>
      <a href="/admin?golive=1" id="goLiveBtn" style="display:block; text-align:center; padding:10px; background:#c9a848; color:#0F1B30; border-radius:4px; font-size:13px; font-weight:600; text-decoration:none; letter-spacing:0.3px;">Go Live — from $1</a>
    </div>
    <% } %>
  </nav>
  <div class="sidebar-footer">
    <a href="/admin/profile" class="<%= page === 'profile' ? 'active' : '' %>" style="display:flex;align-items:center;gap:10px;padding:8px 0 12px;font-size:0.78rem;font-weight:500;letter-spacing:0.04em;color:rgba(255,255,255,0.45);text-decoration:none;transition:all 0.15s;<%= page === 'profile' ? 'color:var(--gold-light);' : '' %>">
      <span class="icon" style="font-size:1rem;width:18px;text-align:center;">&#9881;</span> Profile & Settings
    </a>
    <div class="sidebar-user"><%= user.displayName %></div>
    <a href="/auth/logout" class="btn-logout">Sign Out</a>
  </div>
</aside>

<div class="main">

<script>
(function() {
  const toggle   = document.getElementById('sidebarToggle');
  const sidebar  = document.getElementById('sidebar');
  const overlay  = document.getElementById('sidebarOverlay');

  function open() {
    sidebar.classList.add('open');
    overlay.classList.add('active');
    toggle.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function close() {
    sidebar.classList.remove('open');
    overlay.classList.remove('active');
    toggle.classList.remove('open');
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', function() {
    sidebar.classList.contains('open') ? close() : open();
  });
  overlay.addEventListener('click', close);

  // Close when a nav link is clicked on mobile
  sidebar.querySelectorAll('.sidebar-nav a').forEach(function(a) {
    a.addEventListener('click', function() {
      if (window.innerWidth <= 820) close();
    });
  });

  // ── Slab Switcher ──
  var switcherBtn = document.getElementById('slabSwitcherBtn');
  var dropdown = document.getElementById('slabDropdown');
  var loaded = false;

  switcherBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    var isOpen = dropdown.classList.toggle('open');
    switcherBtn.classList.toggle('open', isOpen);
    if (isOpen && !loaded) loadSlabs();
  });

  document.addEventListener('click', function(e) {
    if (!e.target.closest('.slab-switcher')) {
      dropdown.classList.remove('open');
      switcherBtn.classList.remove('open');
    }
  });

  function loadSlabs() {
    fetch('/admin/api/my-slabs')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        loaded = true;
        var slabs = data.slabs || [];
        var html = '';

        slabs.forEach(function(s) {
          var cls = 'slab-dd-item' + (s.isCurrent ? ' current' : '');
          var url = 'https://' + s.domain + '/admin';
          html += '<a href="' + url + '" class="' + cls + '">'
            + '<span class="slab-dd-icon">' + (s.brandName || '?')[0].toUpperCase() + '</span>'
            + '<span class="slab-dd-info">'
            +   '<span class="slab-dd-name">' + (s.brandName || s.domain) + '</span>'
            +   '<span class="slab-dd-domain">' + s.domain + '</span>'
            + '</span>'
            + (s.isCurrent ? '<span class="slab-dd-check">&#10003;</span>' : '')
            + '</a>';
        });

        // "+ Create New Slab" button
        html += '<div class="slab-dd-divider"></div>';
        html += '<a href="/start?add=1" class="slab-dd-item slab-dd-add">'
          + '<span class="slab-dd-icon slab-dd-plus">+</span>'
          + '<span class="slab-dd-info">'
          +   '<span class="slab-dd-name">Create New Slab</span>'
          +   '<span class="slab-dd-domain">' + discountLabel(slabs.length) + '</span>'
          + '</span>'
          + '</a>';

        dropdown.innerHTML = html;
      })
      .catch(function() {
        dropdown.innerHTML = '<div class="slab-switcher-loading">Failed to load</div>';
      });
  }

  function discountLabel(count) {
    if (count === 0) return 'Full price';
    if (count === 1) return '15% off your second slab';
    return '18% off additional slabs';
  }
})();
</script>
