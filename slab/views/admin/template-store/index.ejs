<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar', { user, page }) %>

<style>
.store-filters { display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:24px; }
.store-pills { display:flex;gap:6px; }
.store-pill { padding:6px 14px;font-size:0.72rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;border:1px solid var(--ivory-mid);border-radius:2px;cursor:pointer;color:var(--slate);background:var(--white);text-decoration:none;transition:all 0.15s; }
.store-pill:hover { border-color:var(--navy-mid); }
.store-pill.active { background:var(--navy);color:var(--on-navy);border-color:var(--navy); }
.store-search { flex:1;min-width:200px; }
.store-search input { width:100%;padding:8px 12px;border:1px solid var(--ivory-mid);border-radius:2px;font-family:var(--font-body);font-size:0.88rem; }
.store-sort select { padding:8px 12px;border:1px solid var(--ivory-mid);border-radius:2px;font-family:var(--font-body);font-size:0.82rem;background:var(--white); }

.store-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px; }
.store-card { border:1px solid var(--ivory-mid);border-radius:4px;overflow:hidden;background:var(--white);transition:border-color 0.15s,box-shadow 0.15s; }
.store-card:hover { border-color:var(--navy-mid);box-shadow:0 4px 20px rgba(15,27,48,0.06); }
.store-thumb { height:180px;background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));display:flex;align-items:center;justify-content:center; }
.store-thumb-ph { font-size:2.5rem;color:rgba(201,168,72,0.3); }
.store-thumb img { width:100%;height:100%;object-fit:cover; }
.store-info { padding:16px; }
.store-name { font-family:var(--font-heading);font-size:1.1rem;font-weight:600;color:var(--dark);margin-bottom:2px; }
.store-author { font-size:0.72rem;color:var(--slate);margin-bottom:8px; }
.store-desc { font-size:0.82rem;color:var(--slate);line-height:1.5;margin-bottom:10px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden; }
.store-meta { display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:12px; }
.store-tag { font-size:0.62rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;background:rgba(46,66,112,0.08);color:var(--navy-mid);padding:2px 8px;border-radius:2px; }
.store-stats { display:flex;gap:12px;font-size:0.75rem;color:var(--slate); }

.store-actions { display:flex;align-items:center;gap:8px;border-top:1px solid var(--ivory-mid);padding:12px 16px; }
.vote-btn { display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border:1px solid var(--ivory-mid);border-radius:2px;background:var(--white);cursor:pointer;font-size:0.78rem;color:var(--slate);transition:all 0.15s; }
.vote-btn:hover { border-color:var(--navy-mid); }
.vote-btn.voted-up { background:rgba(21,128,61,0.08);border-color:rgba(21,128,61,0.3);color:#15803D; }
.vote-btn.voted-down { background:rgba(139,28,28,0.08);border-color:rgba(139,28,28,0.3);color:#8B1C1C; }
.vote-score { font-weight:600;font-size:0.82rem;color:var(--dark);min-width:24px;text-align:center; }
</style>

<div class="topbar">
  <div class="topbar-title">Template Store</div>
  <div class="topbar-actions">
    <a href="/admin/templates" class="btn btn-ghost btn-sm">← My Templates</a>
  </div>
</div>

<div class="content">

  <div style="padding:14px 18px;background:rgba(201,168,72,0.08);border:1px solid rgba(201,168,72,0.3);border-radius:2px;margin-bottom:20px;font-size:0.82rem;color:#92660F;">
    <strong>Template Store:</strong> Browse community templates. Vote for your favorites and install any template to customize with your own content and design.
  </div>

  <!-- Filters -->
  <div class="store-filters">
    <div class="store-pills">
      <a href="/admin/template-store?sort=<%= sort %>" class="store-pill <%= category === 'all' ? 'active' : '' %>">All</a>
      <a href="/admin/template-store?category=landing&sort=<%= sort %>" class="store-pill <%= category === 'landing' ? 'active' : '' %>">Landing</a>
      <a href="/admin/template-store?category=page&sort=<%= sort %>" class="store-pill <%= category === 'page' ? 'active' : '' %>">Page</a>
    </div>
    <div class="store-search">
      <form method="GET" action="/admin/template-store" style="display:flex;gap:8px;">
        <input type="hidden" name="category" value="<%= category %>">
        <input type="hidden" name="sort" value="<%= sort %>">
        <input type="text" name="q" value="<%= q %>" placeholder="Search templates...">
      </form>
    </div>
    <div class="store-sort">
      <select onchange="window.location='/admin/template-store?category=<%= category %>&sort='+this.value+'&q=<%= encodeURIComponent(q) %>'">
        <option value="popular" <%= sort === 'popular' ? 'selected' : '' %>>Most Popular</option>
        <option value="downloads" <%= sort === 'downloads' ? 'selected' : '' %>>Most Downloaded</option>
        <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Newest</option>
        <option value="alpha" <%= sort === 'alpha' ? 'selected' : '' %>>Alphabetical</option>
      </select>
    </div>
  </div>

  <% if (!templates || templates.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">◈</div>
      <p>No templates in the store yet. Be the first to publish!</p>
      <div style="margin-top:20px;">
        <a href="/admin/templates" class="btn btn-navy">Go to My Templates</a>
      </div>
    </div>
  <% } else { %>
    <div class="store-grid">
      <% templates.forEach(tpl => {
        const tid = tpl._id.toString();
        const uv = userVotes[tid] || 0;
      %>
        <div class="store-card" id="card-<%= tid %>">
          <a href="/admin/template-store/<%= tid %>" style="text-decoration:none;color:inherit;">
            <div class="store-thumb">
              <% if (tpl.thumbnail) { %>
                <img src="<%= tpl.thumbnail %>" alt="<%= tpl.name %>">
              <% } else { %>
                <span class="store-thumb-ph">◈</span>
              <% } %>
            </div>
            <div class="store-info">
              <div class="store-name"><%= tpl.name %></div>
              <div class="store-author">by <%= tpl.authorName || tpl.sourceTenantName || 'Anonymous' %></div>
              <div class="store-desc"><%= tpl.description || '' %></div>
              <div class="store-meta">
                <span class="store-tag"><%= tpl.category || 'landing' %></span>
                <% (tpl.tags || []).slice(0, 3).forEach(tag => { %>
                  <span class="store-tag"><%= tag %></span>
                <% }); %>
              </div>
              <div class="store-stats">
                <span><%= (tpl.blocks || []).length %> blocks</span>
                <span><%= tpl.downloads || 0 %> downloads</span>
              </div>
            </div>
          </a>
          <div class="store-actions">
            <button class="vote-btn<%= uv === 1 ? ' voted-up' : '' %>" onclick="vote('<%= tid %>', 1, this)" title="Upvote">
              ▲
            </button>
            <span class="vote-score" id="score-<%= tid %>"><%= tpl.score || 0 %></span>
            <button class="vote-btn<%= uv === -1 ? ' voted-down' : '' %>" onclick="vote('<%= tid %>', -1, this)" title="Downvote">
              ▼
            </button>
            <div style="flex:1;"></div>
            <form method="POST" action="/admin/template-store/<%= tid %>/download">
              <button type="submit" class="btn btn-navy btn-sm">Install</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

</div>

<script>
async function vote(id, val, btn) {
  try {
    const res = await fetch('/admin/template-store/' + id + '/vote', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ vote: val }),
    });
    const data = await res.json();
    if (data.error) return;

    // Update UI
    const card = document.getElementById('card-' + id);
    const scoreEl = document.getElementById('score-' + id);
    const btns = card.querySelectorAll('.vote-btn');
    btns.forEach(b => b.classList.remove('voted-up', 'voted-down'));

    if (data.userVote === 1) btns[0].classList.add('voted-up');
    else if (data.userVote === -1) btns[1].classList.add('voted-down');

    // Recalculate score display from the response
    const oldScore = parseInt(scoreEl.textContent) || 0;
    // We don't have exact new score from server, so just refetch would be ideal
    // For now, adjust locally based on the vote change
    location.reload();
  } catch (err) {
    console.error('Vote failed:', err);
  }
}
</script>
</div></body></html>
