<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar', { user, page }) %>

<style>
.detail-layout { display:grid;grid-template-columns:1fr 340px;gap:24px;min-height:calc(100vh - 120px); }
.detail-preview { border:1px solid var(--border);border-radius:4px;overflow:hidden;background:var(--surface); }
.detail-preview iframe { width:100%;height:600px;border:none; }
.detail-sidebar { display:flex;flex-direction:column;gap:16px; }
.detail-card { border:1px solid var(--border);border-radius:4px;padding:20px;background:var(--surface); }
.detail-name { font-family:var(--font-heading);font-size:1.4rem;font-weight:600;color:var(--on-surface);margin-bottom:4px; }
.detail-author { font-size:0.78rem;color:var(--slate);margin-bottom:12px; }
.detail-desc { font-size:0.88rem;color:var(--on-surface);line-height:1.6;margin-bottom:16px; }
.detail-meta { display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px; }
.detail-tag { font-size:0.62rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;background:rgba(46,66,112,0.08);color:var(--navy-mid);padding:3px 10px;border-radius:2px; }
.detail-stats { display:flex;gap:16px;margin-bottom:16px; }
.detail-stat { text-align:center; }
.detail-stat-num { font-size:1.2rem;font-weight:700;color:var(--on-surface); }
.detail-stat-label { font-size:0.68rem;color:var(--slate);text-transform:uppercase;letter-spacing:0.08em; }
.detail-vote { display:flex;align-items:center;gap:12px;margin-bottom:16px;padding:12px 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border); }
.vote-lg { padding:8px 14px;font-size:1rem;border:1px solid var(--border);border-radius:2px;background:var(--surface);cursor:pointer;transition:all 0.15s; }
.vote-lg:hover { border-color:var(--navy-mid); }
.vote-lg.voted-up { background:rgba(21,128,61,0.1);border-color:rgba(21,128,61,0.4);color:#15803D; }
.vote-lg.voted-down { background:rgba(139,28,28,0.1);border-color:rgba(139,28,28,0.4);color:#8B1C1C; }
.vote-lg-score { font-size:1.3rem;font-weight:700;color:var(--on-surface);min-width:32px;text-align:center; }

.detail-blocks { margin-top:8px; }
.detail-block-item { display:flex;align-items:center;gap:8px;padding:6px 0;font-size:0.82rem;color:var(--on-surface); }
.detail-block-badge { font-size:0.58rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;background:var(--navy);color:#fff;padding:2px 6px;border-radius:2px; }

@media (max-width: 960px) {
  .detail-layout { grid-template-columns:1fr; }
  .detail-preview iframe { height:400px; }
}
</style>

<div class="topbar">
  <div class="topbar-title"><%= template.name %></div>
  <div class="topbar-actions">
    <a href="/admin/template-store" class="btn btn-ghost btn-sm">← Store</a>
    <form method="POST" action="/admin/template-store/<%= template._id %>/download" style="display:inline;">
      <button type="submit" class="btn btn-navy">Install to My Templates</button>
    </form>
  </div>
</div>

<div class="content">
  <div class="detail-layout">
    <!-- Preview -->
    <div class="detail-preview">
      <iframe src="/admin/template-store/<%= template._id %>/preview" id="detail-frame"></iframe>
    </div>

    <!-- Sidebar -->
    <div class="detail-sidebar">
      <div class="detail-card">
        <div class="detail-name"><%= template.name %></div>
        <div class="detail-author">by <%= template.authorName || template.sourceTenantName || 'Anonymous' %></div>
        <div class="detail-desc"><%= template.description || 'No description provided.' %></div>

        <div class="detail-meta">
          <span class="detail-tag"><%= template.category || 'landing' %></span>
          <% (template.tags || []).forEach(tag => { %>
            <span class="detail-tag"><%= tag %></span>
          <% }); %>
        </div>

        <div class="detail-stats">
          <div class="detail-stat">
            <div class="detail-stat-num"><%= template.score || 0 %></div>
            <div class="detail-stat-label">Score</div>
          </div>
          <div class="detail-stat">
            <div class="detail-stat-num"><%= template.downloads || 0 %></div>
            <div class="detail-stat-label">Downloads</div>
          </div>
          <div class="detail-stat">
            <div class="detail-stat-num"><%= (template.blocks || []).length %></div>
            <div class="detail-stat-label">Blocks</div>
          </div>
        </div>

        <!-- Vote -->
        <div class="detail-vote">
          <button class="vote-lg<%= userVote === 1 ? ' voted-up' : '' %>" id="vote-up" onclick="vote(1)">▲</button>
          <span class="vote-lg-score" id="vote-score"><%= template.score || 0 %></span>
          <button class="vote-lg<%= userVote === -1 ? ' voted-down' : '' %>" id="vote-down" onclick="vote(-1)">▼</button>
        </div>

        <!-- Install -->
        <form method="POST" action="/admin/template-store/<%= template._id %>/download" style="margin-bottom:12px;">
          <button type="submit" class="btn btn-navy" style="width:100%;">Install to My Templates</button>
        </form>
        <p style="font-size:0.72rem;color:var(--slate);line-height:1.5;">
          Installing creates a copy in your templates. Your current design tokens (colors, fonts) will be applied automatically.
        </p>
      </div>

      <!-- Block list -->
      <div class="detail-card">
        <div style="font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--slate);margin-bottom:8px;">Blocks in Template</div>
        <div class="detail-blocks">
          <% (template.blocks || []).forEach(function(block, i) { %>
            <div class="detail-block-item">
              <span class="detail-block-badge"><%= block.type %></span>
              <span><%= block.fields?.heading || block.fields?.q1 || 'Block ' + (i+1) %></span>
            </div>
          <% }); %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
async function vote(val) {
  try {
    const res = await fetch('/admin/template-store/<%= template._id %>/vote', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ vote: val }),
    });
    const data = await res.json();
    if (data.error) return;

    const upBtn = document.getElementById('vote-up');
    const downBtn = document.getElementById('vote-down');
    upBtn.classList.remove('voted-up');
    downBtn.classList.remove('voted-down');
    if (data.userVote === 1) upBtn.classList.add('voted-up');
    else if (data.userVote === -1) downBtn.classList.add('voted-down');

    // Reload to get accurate score
    location.reload();
  } catch (err) {
    console.error('Vote failed:', err);
  }
}
</script>
</div></body></html>
