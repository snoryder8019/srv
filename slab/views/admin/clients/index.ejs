<%- include('../partials/head', { title: 'Clients' }) %>
<%- include('../partials/sidebar', { page: 'clients', user: user }) %>

<div class="topbar">
  <div class="topbar-title">Clients</div>
  <div class="topbar-actions">
    <a href="/admin/clients/new" class="btn btn-navy">+ New Client</a>
  </div>
</div>

<div class="content">
  <% if (!clients.length) { %>
    <div class="empty">
      <div class="empty-icon">◉</div>
      <p>No clients yet. <a href="/admin/clients/new" style="color:var(--navy)">Add your first client.</a></p>
    </div>
  <% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Company</th>
          <th>Email</th>
          <th>Status</th>
          <th>Onboarding</th>
          <th>Added</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for (const c of clients) { %>
        <tr>
          <td style="font-weight:500;"><a href="/admin/clients/<%= c._id %>" style="color:var(--navy);text-decoration:none;"><%= c.name %></a></td>
          <td class="text-slate"><%= c.company || '—' %></td>
          <td class="text-slate"><%= c.email || '—' %></td>
          <td>
            <select class="status-toggle" data-id="<%= c._id %>" style="padding:4px 8px;font-size:0.72rem;border:1px solid var(--ivory-mid);border-radius:2px;background:var(--white);font-family:'Jost',sans-serif;cursor:pointer;">
              <option value="prospect" <%= c.status === 'prospect' ? 'selected' : '' %>>Prospect</option>
              <option value="active" <%= c.status === 'active' ? 'selected' : '' %>>Active</option>
              <option value="inactive" <%= c.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
            </select>
          </td>
          <td>
            <% if (c.onboarding?.complete) { %>
              <span class="badge badge-active">Done</span>
            <% } else { %>
              <span class="text-slate" style="font-size:0.8rem;">Step <%= c.onboarding?.step || 0 %></span>
            <% } %>
          </td>
          <td class="text-slate"><%= new Date(c.createdAt).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) %></td>
          <td>
            <a href="/admin/clients/<%= c._id %>" class="btn btn-ghost btn-sm">View</a>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<script>
document.querySelectorAll('.status-toggle').forEach(sel => {
  sel.addEventListener('change', async function() {
    const id = this.dataset.id;
    const status = this.value;
    try {
      const r = await fetch(`/admin/clients/${id}/status`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status }),
      });
      const data = await r.json();
      if (!data.success) alert('Error: ' + (data.error || 'Failed'));
    } catch (err) { alert('Error: ' + err.message); }
  });
});
</script>
<script src="/js/tours/clients.js"></script>
</div></div>
</body>
</html>
