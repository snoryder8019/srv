<%- include('../partials/head', { title: c ? 'Edit Client' : 'New Client' }) %>
<%- include('../partials/sidebar', { page: 'clients', user: user }) %>

<div class="topbar">
  <div class="topbar-title"><%= c ? 'Edit Client' : 'New Client' %></div>
  <div class="topbar-actions">
    <a href="/admin/clients" class="btn btn-ghost btn-sm">← Back</a>
  </div>
</div>

<div class="content">
  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="<%= c ? `/admin/clients/${c._id}` : '/admin/clients' %>">
    <div class="card">
      <div class="card-title">Client Information</div>
      <div class="form-grid">
        <div class="form-field">
          <label>Full Name *</label>
          <input type="text" name="name" value="<%= c?.name || '' %>" placeholder="Jane Smith" required>
        </div>
        <div class="form-field">
          <label>Company</label>
          <input type="text" name="company" value="<%= c?.company || '' %>" placeholder="Business LLC">
        </div>
        <div class="form-field">
          <label>Email</label>
          <input type="email" name="email" value="<%= c?.email || '' %>" placeholder="jane@business.com">
        </div>
        <div class="form-field">
          <label>Phone</label>
          <input type="tel" name="phone" value="<%= c?.phone || '' %>" placeholder="(970) 555-1234">
        </div>
        <div class="form-field">
          <label>Website</label>
          <input type="url" name="website" value="<%= c?.website || '' %>" placeholder="https://yourbusiness.com">
        </div>
        <div class="form-field">
          <label>Status</label>
          <select name="status">
            <option value="prospect" <%= (c?.status === 'prospect' || !c) ? 'selected' : '' %>>Prospect</option>
            <option value="active" <%= c?.status === 'active' ? 'selected' : '' %>>Active</option>
            <option value="inactive" <%= c?.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
          </select>
        </div>
        <div class="form-field span-2">
          <label>Address</label>
          <input type="text" name="address" value="<%= c?.address || '' %>" placeholder="City, State">
        </div>
        <div class="form-field span-2">
          <label>Notes</label>
          <textarea name="notes" placeholder="Internal notes about this client..."><%= c?.notes || '' %></textarea>
        </div>
      </div>
    </div>

    <div class="form-actions" style="margin-top:24px;display:flex;gap:12px;flex-wrap:wrap;">
      <button type="submit" class="btn btn-navy"><%= c ? 'Save Changes' : 'Add Client' %></button>
      <a href="/admin/clients<%= c ? `/${c._id}` : '' %>" class="btn btn-ghost">Cancel</a>
    </div>
  </form>
</div>

</div></div>
</body>
</html>
