<%- include('../partials/head', { title: 'Profile & Settings' }) %>
<%- include('../partials/sidebar', { page: 'profile', user: user }) %>

<style>
  .profile-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .profile-avatar {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: var(--navy);
    color: var(--white);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem; font-weight: 400;
    flex-shrink: 0;
  }
  .profile-header {
    display: flex; align-items: center; gap: 20px;
    margin-bottom: 20px;
  }
  .profile-meta {
    font-size: 0.82rem; color: var(--slate); font-weight: 300;
  }
  .profile-meta strong {
    color: var(--dark); font-weight: 500;
  }

  /* Tutorial list */
  .tutorial-list {
    display: flex; flex-direction: column; gap: 0;
  }
  .tutorial-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 0;
    border-bottom: 1px solid var(--ivory-mid);
    gap: 12px;
    flex-wrap: wrap;
  }
  .tutorial-row:last-child { border-bottom: none; }
  .tutorial-info {
    display: flex; flex-direction: column; gap: 2px; min-width: 160px;
  }
  .tutorial-name {
    font-size: 0.88rem; font-weight: 500; color: var(--dark);
  }
  .tutorial-desc {
    font-size: 0.75rem; color: var(--slate); font-weight: 300;
  }
  .tutorial-status {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
  }
  .tutorial-actions {
    display: flex; gap: 6px; flex-wrap: wrap;
  }

  /* Progress bar */
  .progress-wrap {
    margin-bottom: 20px;
  }
  .progress-bar-outer {
    background: var(--ivory-mid);
    border-radius: 2px;
    height: 8px;
    overflow: hidden;
    margin-top: 8px;
  }
  .progress-bar-inner {
    height: 100%;
    background: var(--gold);
    border-radius: 2px;
    transition: width 0.3s ease;
  }
  .progress-label {
    display: flex; justify-content: space-between; align-items: baseline;
  }
  .progress-label span {
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--slate);
  }
  .progress-label strong {
    font-size: 0.88rem; color: var(--dark);
  }

  /* Reset section */
  .reset-section {
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--ivory-mid);
  }
  .reset-section p {
    font-size: 0.85rem; color: var(--slate); font-weight: 300; margin-bottom: 12px;
  }

  /* Confirm overlay */
  .confirm-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(15,27,48,0.55);
    z-index: 1000;
    align-items: center; justify-content: center;
    backdrop-filter: blur(3px);
  }
  .confirm-overlay.active { display: flex; }
  .confirm-dialog {
    background: var(--white);
    border: 1px solid var(--ivory-mid);
    padding: 32px;
    max-width: 420px;
    width: 90%;
  }
  .confirm-dialog h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem; font-weight: 400;
    margin-bottom: 12px;
  }
  .confirm-dialog p {
    font-size: 0.88rem; color: var(--slate); font-weight: 300;
    margin-bottom: 20px;
  }
  .confirm-actions {
    display: flex; gap: 10px; justify-content: flex-end;
  }

  @media (max-width: 820px) {
    .profile-grid { grid-template-columns: 1fr; }
    .tutorial-row { flex-direction: column; align-items: flex-start; gap: 8px; }
    .tutorial-actions { width: 100%; }
    .tutorial-actions form { flex: 1; }
    .tutorial-actions .btn { width: 100%; justify-content: center; }
  }
</style>

<div class="topbar">
  <div class="topbar-title">Profile & Settings</div>
</div>

<div class="content">
  <% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <div class="profile-grid">
    <!-- Left column: Profile Info -->
    <div>
      <div class="card">
        <div class="card-title">Profile Information</div>

        <div class="profile-header">
          <div class="profile-avatar">
            <%= (dbUser.displayName || 'U').charAt(0).toUpperCase() %>
          </div>
          <div>
            <div style="font-size:1.1rem; font-weight:500; color:var(--dark);"><%= dbUser.displayName || 'Admin User' %></div>
            <div class="profile-meta"><%= dbUser.email %></div>
            <div style="margin-top:6px;">
              <span class="badge badge-active"><%= dbUser.isAdmin ? 'Admin' : (dbUser.role || 'User') %></span>
            </div>
          </div>
        </div>

        <form method="POST" action="/admin/profile/update">
          <div class="form-grid cols-1" style="gap:16px;">
            <div class="form-field">
              <label for="displayName">Display Name</label>
              <input type="text" id="displayName" name="displayName" value="<%= dbUser.displayName || '' %>" placeholder="Your display name">
            </div>
            <div class="form-field">
              <label>Email</label>
              <input type="email" value="<%= dbUser.email %>" disabled style="background:var(--ivory); color:var(--slate);">
              <span style="font-size:0.72rem; color:var(--slate); font-weight:300;">Managed by Google OAuth</span>
            </div>
            <% if (dbUser.createdAt) { %>
            <div class="form-field">
              <label>Account Created</label>
              <div class="profile-meta"><strong><%= new Date(dbUser.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></strong></div>
            </div>
            <% } %>
          </div>

          <div style="border-top:1px solid var(--ivory-mid); margin-top:20px; padding-top:20px;">
            <div class="card-title" style="font-size:1rem;">Tutorial Preferences</div>
            <div class="form-check" style="margin-top:8px;">
              <input type="checkbox" id="tutorialAutoPlay" name="tutorialAutoPlay" <%= tutorials.autoPlay !== false ? 'checked' : '' %>>
              <label for="tutorialAutoPlay">Auto-play tutorials on new pages</label>
            </div>
            <span style="font-size:0.72rem; color:var(--slate); font-weight:300; margin-top:4px; display:block;">When enabled, tutorials will automatically start when you visit an admin page for the first time.</span>
            <div class="form-check" style="margin-top:12px;">
              <input type="checkbox" id="tutorialCollapsed" name="tutorialCollapsed" <%= tutorials.collapsed ? 'checked' : '' %>>
              <label for="tutorialCollapsed">Collapse tutorials</label>
            </div>
            <span style="font-size:0.72rem; color:var(--slate); font-weight:300; margin-top:4px; display:block;">Hides the floating help button on all pages. Tutorials won't auto-play or show any UI.</span>
          </div>

          <div style="margin-top:20px;">
            <button type="submit" class="btn btn-navy">Save Changes</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Right column: Tutorial Progress -->
    <script src="/js/tours/profile.js"></script>
    <div>
      <div class="card">
        <div class="card-title">Tutorial Progress</div>

        <%
          const seen = tutorials.seen || {};
          const dismissed = tutorials.dismissed || {};
          let completedCount = 0;
          let dismissedCount = 0;
          tutorialPages.forEach(function(t) {
            if (seen[t.key]) completedCount++;
            else if (dismissed[t.key]) dismissedCount++;
          });
          const totalPages = tutorialPages.length;
          const pct = totalPages > 0 ? Math.round((completedCount / totalPages) * 100) : 0;
        %>

        <div class="progress-wrap">
          <div class="progress-label">
            <span>Overall Completion</span>
            <strong><%= pct %>%</strong>
          </div>
          <div class="progress-bar-outer">
            <div class="progress-bar-inner" style="width:<%= pct %>%"></div>
          </div>
          <div style="margin-top:6px; font-size:0.75rem; color:var(--slate); font-weight:300;">
            <%= completedCount %> completed, <%= dismissedCount %> dismissed, <%= totalPages - completedCount - dismissedCount %> not started
          </div>
        </div>

        <div style="margin-bottom:12px;">
          <button type="button" id="toggleTutorials" style="background:none;border:1px solid var(--ivory-mid);padding:8px 14px;border-radius:3px;font-family:'Jost',sans-serif;font-size:0.78rem;font-weight:500;color:var(--navy);cursor:pointer;display:flex;align-items:center;gap:6px;width:100%;">
            <span id="toggleArrow" style="transition:transform 0.2s;">&#9654;</span> Show All Tutorials (<%= totalPages %>)
          </button>
        </div>
        <div class="tutorial-list" id="tutorialAccordion" style="display:none;">
          <% tutorialPages.forEach(function(t) { %>
            <div class="tutorial-row">
              <div class="tutorial-info">
                <div class="tutorial-name"><%= t.label %></div>
                <div class="tutorial-desc"><%= t.desc %></div>
              </div>
              <div class="tutorial-status">
                <% if (seen[t.key]) { %>
                  <span class="badge badge-active">Completed</span>
                <% } else if (dismissed[t.key]) { %>
                  <span class="badge badge-draft">Dismissed</span>
                <% } else { %>
                  <span class="badge badge-prospect">Not Started</span>
                <% } %>
                <div class="tutorial-actions">
                  <% if (seen[t.key] || dismissed[t.key]) { %>
                    <form method="POST" action="/admin/profile/reset-tutorial/<%= t.key %>" style="margin:0;">
                      <button type="submit" class="btn btn-ghost btn-sm">Replay</button>
                    </form>
                  <% } %>
                  <% if (!seen[t.key]) { %>
                    <form method="POST" action="/admin/profile/complete-tutorial/<%= t.key %>" style="margin:0;">
                      <button type="submit" class="btn btn-ghost btn-sm">Mark Complete</button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          <% }); %>
        </div>

        <div class="reset-section">
          <p>Reset all tutorial progress to replay every tutorial from the beginning.</p>
          <button type="button" class="btn btn-danger btn-sm" id="resetAllBtn">Reset All Tutorials</button>
          <% if (tutorials.lastReset) { %>
            <div style="margin-top:8px; font-size:0.72rem; color:var(--slate); font-weight:300;">
              Last reset: <%= new Date(tutorials.lastReset).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
            </div>
          <% } %>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Reset All confirmation dialog -->
<div class="confirm-overlay" id="confirmOverlay">
  <div class="confirm-dialog">
    <h3>Reset All Tutorials?</h3>
    <p>This will clear all tutorial progress. Every tutorial will show again when you visit each admin page.</p>
    <div class="confirm-actions">
      <button type="button" class="btn btn-ghost btn-sm" id="confirmCancel">Cancel</button>
      <form method="POST" action="/admin/profile/reset-tutorials" style="margin:0;">
        <button type="submit" class="btn btn-danger btn-sm">Reset All</button>
      </form>
    </div>
  </div>
</div>

<script>
(function() {
  var overlay = document.getElementById('confirmOverlay');
  var resetBtn = document.getElementById('resetAllBtn');
  var cancelBtn = document.getElementById('confirmCancel');

  resetBtn.addEventListener('click', function() {
    overlay.classList.add('active');
  });
  cancelBtn.addEventListener('click', function() {
    overlay.classList.remove('active');
  });
  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) overlay.classList.remove('active');
  });

  // Tutorial accordion
  var toggleBtn = document.getElementById('toggleTutorials');
  var accordion = document.getElementById('tutorialAccordion');
  var arrow = document.getElementById('toggleArrow');
  if (toggleBtn && accordion) {
    toggleBtn.addEventListener('click', function() {
      var isOpen = accordion.style.display !== 'none';
      accordion.style.display = isOpen ? 'none' : '';
      arrow.style.transform = isOpen ? '' : 'rotate(90deg)';
    });
  }
})();
</script>

</div></div>
</body>
</html>
