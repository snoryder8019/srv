<%- include('../partials/head', { title: 'New Ticket' }) %>
<div class="layout">
<%- include('../partials/sidebar', { page: 'tickets', user, brand: typeof brand !== 'undefined' ? brand : null, tenant: typeof tenant !== 'undefined' ? tenant : null, isSuperAdmin: typeof isSuperAdmin !== 'undefined' ? isSuperAdmin : false, brandDesign: typeof brandDesign !== 'undefined' ? brandDesign : {} }) %>

<div class="topbar">
  <div class="topbar-title">New Support Ticket</div>
  <div class="topbar-actions">
    <a href="/admin/tickets" class="btn btn-ghost btn-sm">Back</a>
  </div>
</div>

<div class="content">
  <% if (error) { %>
    <div class="alert alert-error" style="margin-bottom:20px;"><%= error %></div>
  <% } %>

  <div class="card">
    <form method="POST" action="/admin/tickets" enctype="multipart/form-data">
      <div class="form-grid" style="margin-bottom:20px;">
        <div class="form-field span-2">
          <label>Subject *</label>
          <input type="text" name="subject" required placeholder="Brief summary of the issue">
        </div>

        <div class="form-field span-2">
          <label>Description</label>
          <textarea name="description" rows="5" placeholder="Detailed description of the issue or request..."></textarea>
        </div>

        <div class="form-field">
          <label>Category</label>
          <select name="category">
            <option value="bug">Bug</option>
            <option value="question">Question</option>
            <option value="feature">Feature Request</option>
            <option value="billing">Billing</option>
            <option value="other" selected>Other</option>
          </select>
        </div>

        <div class="form-field">
          <label>Priority</label>
          <select name="priority">
            <option value="low">Low</option>
            <option value="medium" selected>Medium</option>
            <option value="high">High</option>
            <option value="critical">Critical</option>
          </select>
        </div>

        <div class="form-field">
          <label>Assign To</label>
          <select name="assignedTo">
            <option value="">Unassigned</option>
            <% for (const a of admins) { %>
              <option value="<%= a.email %>"><%= a.displayName || a.email %></option>
            <% } %>
          </select>
        </div>

        <div class="form-field">
          <label>Screenshot / Attachment</label>
          <input type="file" name="screenshot" accept="image/*,.pdf,.txt,.log,.json">
        </div>
      </div>

      <div style="display:flex;gap:12px;">
        <button type="submit" class="btn btn-navy">Create Ticket</button>
        <a href="/admin/tickets" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>

</div><!-- layout -->
</body>
</html>
