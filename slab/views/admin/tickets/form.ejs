<%- include('../partials/head', { title: 'New Help Request' }) %>
<div class="layout">
<%- include('../partials/sidebar', { page: 'tickets', user, brand: typeof brand !== 'undefined' ? brand : null, tenant: typeof tenant !== 'undefined' ? tenant : null, isSuperAdmin: typeof isSuperAdmin !== 'undefined' ? isSuperAdmin : false, brandDesign: typeof brandDesign !== 'undefined' ? brandDesign : {} }) %>

<div class="topbar">
  <div class="topbar-title">New Help Request</div>
  <div class="topbar-actions">
    <a href="/admin/tickets" class="btn btn-ghost btn-sm">Back</a>
  </div>
</div>

<div class="content">
  <% if (error) { %>
    <div class="alert alert-error" style="margin-bottom:20px;"><%= error %></div>
  <% } %>

  <div class="card">
    <p style="font-size:0.85rem;color:var(--slate);margin-bottom:20px;line-height:1.6;">Describe your issue or request below. Our platform team will review it and get back to you.</p>
    <form method="POST" action="/admin/tickets" enctype="multipart/form-data">
      <div class="form-grid" style="margin-bottom:20px;">
        <div class="form-field span-2">
          <label>Subject *</label>
          <input type="text" name="subject" required placeholder="Brief summary of your issue or request">
        </div>

        <div class="form-field span-2">
          <label>Description</label>
          <textarea name="description" rows="5" placeholder="Detailed description — what happened, what you expected, steps to reproduce..."></textarea>
        </div>

        <div class="form-field">
          <label>Category</label>
          <select name="category">
            <option value="bug">Bug / Something Broken</option>
            <option value="question">Question / How To</option>
            <option value="feature">Feature Request</option>
            <option value="billing">Billing</option>
            <option value="other" selected>Other</option>
          </select>
        </div>

        <div class="form-field">
          <label>Priority</label>
          <select name="priority">
            <option value="low">Low — no rush</option>
            <option value="medium" selected>Medium</option>
            <option value="high">High — affecting my business</option>
            <option value="critical">Critical — site is down</option>
          </select>
        </div>

        <div class="form-field span-2">
          <label>Screenshot / Attachment</label>
          <input type="file" name="screenshot" accept="image/*,.pdf,.txt,.log,.json">
        </div>
      </div>

      <div style="display:flex;gap:12px;">
        <button type="submit" class="btn btn-navy">Submit Request</button>
        <a href="/admin/tickets" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>

</div><!-- layout -->
</body>
</html>
