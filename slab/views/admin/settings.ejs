<%- include('partials/head', { title: 'Settings' }) %>
<%- include('partials/sidebar', { page: 'settings', user: user }) %>

<style>
  .settings-grid { max-width: 720px; }
  .settings-section { background: var(--white); border: 1px solid var(--ivory-mid); border-radius: 4px; padding: 24px; margin-bottom: 20px; }
  .settings-section h2 { font-size: 0.88rem; font-weight: 600; letter-spacing: 0.06em; color: var(--navy); margin-bottom: 4px; display: flex; align-items: center; gap: 10px; }
  .settings-section .desc { font-size: 0.75rem; color: var(--slate); margin-bottom: 16px; line-height: 1.5; }
  .field-row { margin-bottom: 14px; }
  .field-row label { display: block; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--slate); margin-bottom: 4px; }
  .field-row input, .field-row select {
    width: 100%; padding: 10px 12px; border: 1px solid var(--ivory-mid); border-radius: 3px;
    font-family: 'Jost', sans-serif; font-size: 0.82rem; color: var(--dark); background: var(--ivory);
    outline: none; transition: border 0.15s;
  }
  .field-row input:focus { border-color: var(--gold); }
  .field-row input[type=password] { font-family: monospace; letter-spacing: 0.1em; }
  .field-hint { font-size: 0.68rem; color: var(--slate); margin-top: 3px; }
  .field-set { color: #16a34a; font-size: 0.68rem; font-weight: 500; }
  .field-row .inline { display: flex; gap: 8px; align-items: center; }
  .inline input { flex: 1; }
  .btn-test { padding: 8px 16px; background: var(--navy); color: var(--white); border: none; border-radius: 3px; font-family: 'Jost', sans-serif; font-size: 0.72rem; font-weight: 500; cursor: pointer; white-space: nowrap; }
  .btn-test:hover { background: var(--navy-deep); }
  .test-result { font-size: 0.72rem; margin-top: 4px; min-height: 18px; }
  .test-ok { color: #16a34a; } .test-fail { color: #dc2626; }
  .status-bar { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 4px; margin-bottom: 20px; font-size: 0.78rem; flex-wrap: wrap; }
  .status-preview { background: rgba(251,191,36,0.08); border: 1px solid rgba(251,191,36,0.2); color: #92400e; }
  .status-active { background: rgba(22,163,74,0.08); border: 1px solid rgba(22,163,74,0.2); color: #166534; }
  .saved-toast { background: #14532d; color: #86efac; padding: 10px 16px; border-radius: 4px; margin-bottom: 16px; font-size: 0.78rem; }
  .error-toast { background: #7f1d1d; color: #fca5a5; padding: 10px 16px; border-radius: 4px; margin-bottom: 16px; font-size: 0.78rem; }

  /* Guide toggle */
  .guide-toggle {
    display: inline-flex; align-items: center; gap: 5px; cursor: pointer;
    font-size: 0.68rem; font-weight: 500; color: var(--gold); background: none;
    border: 1px solid rgba(201,168,72,0.3); padding: 4px 10px; border-radius: 3px;
    font-family: 'Jost', sans-serif; transition: all 0.15s; margin-left: auto;
  }
  .guide-toggle:hover { background: rgba(201,168,72,0.08); border-color: var(--gold); }
  .guide-panel {
    display: none; margin-top: 12px; padding: 16px; border-radius: 4px;
    background: linear-gradient(135deg, rgba(201,168,72,0.04), rgba(28,43,74,0.03));
    border: 1px solid rgba(201,168,72,0.15);
  }
  .guide-panel.open { display: block; }
  .guide-panel ol { margin: 0; padding-left: 20px; font-size: 0.75rem; color: var(--dark); line-height: 1.9; }
  .guide-panel li { margin-bottom: 4px; }
  .guide-panel code { background: var(--ivory); padding: 1px 6px; border-radius: 2px; font-size: 0.72rem; }
  .guide-panel a { color: var(--gold); font-weight: 500; }
  .guide-panel .guide-tip { font-size: 0.68rem; color: var(--slate); font-style: italic; margin-top: 8px; }

  /* Setup CTA */
  .setup-cta {
    background: linear-gradient(135deg, #0F1B30 0%, #1C2B4A 50%, #2E4270 100%);
    border: 1px solid rgba(201,168,72,0.2); border-radius: 4px;
    padding: 28px; margin-bottom: 24px; position: relative; overflow: hidden;
  }
  .setup-cta::before {
    content: ''; position: absolute; top: -40px; right: -40px;
    width: 160px; height: 160px; border-radius: 50%;
    background: radial-gradient(circle, rgba(201,168,72,0.12) 0%, transparent 70%);
  }
</style>

<div class="settings-grid">
  <h1 style="font-size:1.2rem;font-weight:600;margin-bottom:16px;">Settings</h1>

  <% if (saved) { %><div class="saved-toast">Settings saved.</div><% } %>
  <% if (error) { %><div class="error-toast">Failed to save settings.</div><% } %>

  <div class="status-bar status-<%= settings.status || 'preview' %>">
    <strong><%= settings.status === 'active' ? 'Live' : 'Preview Mode' %></strong>
    <span>|</span>
    <span>Plan: <%= settings.plan %></span>
    <span>|</span>
    <span>Domain: <%= settings.domain %></span>
    <% if (settings.status !== 'active') { %>
      <a href="/admin?golive=1" style="margin-left:auto;font-weight:600;color:#92400e;">Go Live &rarr;</a>
    <% } %>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- TUTORIALS SETTINGS                                                      -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <div class="settings-section">
    <h2>Tutorials
      <span style="font-size:0.65rem;font-weight:400;color:var(--slate);margin-left:auto;" id="tutProgress"></span>
    </h2>
    <div class="desc">Control guided tours and onboarding walkthroughs across the admin panel.</div>

    <div style="display:flex;gap:16px;flex-wrap:wrap;align-items:center;margin-bottom:14px;">
      <label style="display:flex;align-items:center;gap:8px;font-size:0.82rem;cursor:pointer;">
        <input type="checkbox" id="tutAutoPlay" style="accent-color:var(--navy);"> Auto-play on first visit
      </label>
      <label style="display:flex;align-items:center;gap:8px;font-size:0.82rem;cursor:pointer;">
        <input type="checkbox" id="tutCollapsed" style="accent-color:var(--navy);"> Collapse tutorials <span style="font-size:0.68rem;color:var(--slate);">(hide help button)</span>
      </label>
    </div>

    <div style="display:flex;gap:8px;flex-wrap:wrap;">
      <button type="button" class="btn-test" onclick="resetAllTutorials()">Reset All Tutorials</button>
      <button type="button" class="btn-test" style="background:var(--slate);" onclick="window.location='/admin/profile'">View Tutorial Progress</button>
    </div>
    <div id="tutResult" class="test-result"></div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- WHAT'S NEW / CHANGELOG                                                  -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <div class="settings-section">
    <h2>What's New
      <span style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;background:var(--navy);color:var(--gold);padding:2px 8px;border-radius:2px;margin-left:8px;">v<%= typeof platformVersion !== 'undefined' ? platformVersion : '1.0.0' %></span>
      <span style="font-size:0.62rem;font-weight:500;padding:2px 8px;border-radius:2px;margin-left:4px;<%= typeof platformEnv !== 'undefined' && platformEnv === 'production' ? 'background:rgba(22,163,74,0.1);color:#16a34a;' : 'background:rgba(234,88,12,0.1);color:#ea580c;' %>"><%= typeof platformEnv !== 'undefined' ? platformEnv : 'development' %></span>
    </h2>
    <div class="desc">Platform version history and environment status. Helps coordinate prod/dev deployments.</div>

    <div style="display:flex;gap:16px;margin-bottom:16px;font-size:0.78rem;">
      <div style="flex:1;padding:12px;background:var(--ivory);border-radius:4px;">
        <div style="font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--slate);margin-bottom:4px;">Environment</div>
        <strong><%= typeof platformEnv !== 'undefined' ? platformEnv : 'development' %></strong>
      </div>
      <div style="flex:1;padding:12px;background:var(--ivory);border-radius:4px;">
        <div style="font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--slate);margin-bottom:4px;">Version</div>
        <strong><%= typeof platformVersion !== 'undefined' ? platformVersion : '1.0.0' %></strong>
      </div>
      <div style="flex:1;padding:12px;background:var(--ivory);border-radius:4px;">
        <div style="font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--slate);margin-bottom:4px;">Node</div>
        <strong><%= typeof nodeVersion !== 'undefined' ? nodeVersion : process.version %></strong>
      </div>
    </div>

    <div id="changelogList" style="border:1px solid var(--ivory-mid);border-radius:4px;overflow:hidden;max-height:500px;overflow-y:auto;">
      <% const commits = typeof whatsNew !== 'undefined' ? whatsNew : []; %>
      <% const notes = typeof pinnedNotes !== 'undefined' ? pinnedNotes : {}; %>
      <% if (commits.length === 0) { %>
        <div style="padding:16px;text-align:center;font-size:0.82rem;color:var(--slate);">No git history available.</div>
      <% } %>
      <% for (const c of commits) { %>
        <div style="padding:10px 16px;border-bottom:1px solid var(--ivory-mid);<%= c.version ? 'background:rgba(201,168,72,0.04);' : '' %>" data-hash="<%= c.hash %>">
          <div style="display:flex;align-items:center;gap:8px;">
            <code style="font-size:0.68rem;color:var(--gold);background:var(--ivory);padding:1px 6px;border-radius:2px;"><%= c.short %></code>
            <% if (c.version) { %>
              <span style="font-size:0.62rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;background:var(--navy);color:var(--gold);padding:1px 6px;border-radius:2px;"><%= c.version %></span>
            <% } %>
            <span style="font-size:0.82rem;font-weight:500;color:var(--dark);flex:1;"><%= c.message %></span>
            <span style="font-size:0.65rem;color:var(--slate);white-space:nowrap;"><%= c.date %></span>
          </div>
          <div style="display:flex;align-items:center;gap:8px;margin-top:2px;">
            <span style="font-size:0.65rem;color:var(--slate);"><%= c.author %></span>
            <span style="font-size:0.65rem;color:var(--slate);"><%= c.time %></span>
          </div>
          <% if (notes[c.hash]) { %>
            <div style="margin-top:6px;padding:8px 10px;background:rgba(201,168,72,0.06);border-radius:3px;font-size:0.75rem;line-height:1.5;color:var(--dark);"><%- notes[c.hash] %></div>
          <% } %>
        </div>
      <% } %>
    </div>

    <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
    <div style="margin-top:14px;padding-top:14px;border-top:1px solid var(--ivory-mid);">
      <div style="font-weight:600;font-size:0.78rem;margin-bottom:8px;">Pin a Note to a Commit (Superadmin)</div>
      <div style="display:flex;gap:8px;margin-bottom:8px;">
        <input type="text" id="clHash" placeholder="commit hash (click a row above)" style="flex:1;padding:8px;border:1px solid var(--ivory-mid);border-radius:3px;font-size:0.78rem;font-family:monospace;">
      </div>
      <textarea id="clNotes" rows="2" placeholder="Pinned note for this commit (supports HTML)" style="width:100%;padding:8px;border:1px solid var(--ivory-mid);border-radius:3px;font-size:0.78rem;font-family:'Jost',sans-serif;resize:vertical;"></textarea>
      <button type="button" class="btn-test" style="margin-top:8px;" onclick="addChangelog()">Pin Note</button>
      <div id="clResult" class="test-result"></div>
    </div>
    <% } %>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- DONE-FOR-YOU SETUP OFFER                                               -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <div class="setup-cta">
    <div style="position:relative;z-index:1;">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
        <span style="font-size:1.4rem;">&#9889;</span>
        <span style="font-size:0.65rem;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:rgba(201,168,72,0.8);">Done-For-You Setup</span>
      </div>
      <div style="font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:300;color:#FDFCFA;line-height:1.3;margin-bottom:10px;">
        Skip the technical stuff &mdash; we'll set it all up for you.
      </div>
      <p style="font-size:0.82rem;font-weight:300;color:rgba(253,252,250,0.55);line-height:1.7;margin-bottom:20px;max-width:520px;">
        <span style="text-decoration:line-through;color:rgba(253,252,250,0.35);">$500 value</span> &mdash; yours for a one-time <strong style="color:rgba(201,168,72,0.9);">$299</strong>. Our team will configure every integration below:
        Stripe &amp; PayPal payments, Zoho email with full DNS (SPF, DKIM, DMARC), Google Reviews,
        Google OAuth login, custom domain with SSL, and a deliverability test to make sure everything works.
      </p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;">
        <a href="mailto:<%= brand?.name ? '' : '' %>support@madladslab.com?subject=Done-For-You%20Setup%20—%20<%= settings.domain %>&body=Hi%2C%20I'd%20like%20to%20purchase%20the%20Done-For-You%20setup%20for%20my%20site%20(<%= settings.domain %>).%0A%0APlease%20send%20me%20the%20next%20steps!"
           style="display:inline-block;padding:12px 28px;background:rgba(201,168,72,0.9);color:#0F1B30;font-family:'Jost',sans-serif;font-size:0.78rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;border-radius:3px;transition:background 0.2s;">
          Request Setup — $299
        </a>
        <span style="font-size:0.7rem;color:rgba(253,252,250,0.35);">One-time &bull; Usually completed within 24 hours</span>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:16px;margin-top:20px;">
        <div style="font-size:0.68rem;color:rgba(253,252,250,0.4);display:flex;align-items:center;gap:5px;"><span style="color:rgba(201,168,72,0.6);">&#10003;</span> Stripe &amp; PayPal</div>
        <div style="font-size:0.68rem;color:rgba(253,252,250,0.4);display:flex;align-items:center;gap:5px;"><span style="color:rgba(201,168,72,0.6);">&#10003;</span> Zoho Email + DNS</div>
        <div style="font-size:0.68rem;color:rgba(253,252,250,0.4);display:flex;align-items:center;gap:5px;"><span style="color:rgba(201,168,72,0.6);">&#10003;</span> SPF / DKIM / DMARC</div>
        <div style="font-size:0.68rem;color:rgba(253,252,250,0.4);display:flex;align-items:center;gap:5px;"><span style="color:rgba(201,168,72,0.6);">&#10003;</span> Google Reviews</div>
        <div style="font-size:0.68rem;color:rgba(253,252,250,0.4);display:flex;align-items:center;gap:5px;"><span style="color:rgba(201,168,72,0.6);">&#10003;</span> Google OAuth</div>
        <div style="font-size:0.68rem;color:rgba(253,252,250,0.4);display:flex;align-items:center;gap:5px;"><span style="color:rgba(201,168,72,0.6);">&#10003;</span> Custom Domain + SSL</div>
        <div style="font-size:0.68rem;color:rgba(253,252,250,0.4);display:flex;align-items:center;gap:5px;"><span style="color:rgba(201,168,72,0.6);">&#10003;</span> Deliverability Test</div>
      </div>
    </div>
  </div>

  <form method="POST" action="/admin/settings">

    <!-- ═══════════ BUSINESS PROFILE ═══════════ -->
    <div class="settings-section">
      <h2>&#9672; Business Profile</h2>
      <p class="desc">This information powers all AI agent prompts across your site. The more you fill in, the better your agents will understand your business.</p>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0 16px;">
        <div class="field-row">
          <label>Business Name</label>
          <input type="text" name="brand_name" value="<%= brandProfile.name %>" placeholder="Acme Marketing">
        </div>
        <div class="field-row">
          <label>Business Type</label>
          <input type="text" name="brand_businessType" value="<%= brandProfile.businessType %>" placeholder="Digital Marketing Agency">
          <div class="field-hint">e.g. Restaurant, Law Firm, SaaS, Retail, Consulting</div>
        </div>
        <div class="field-row">
          <label>Industry</label>
          <input type="text" name="brand_industry" value="<%= brandProfile.industry %>" placeholder="Marketing & Advertising">
        </div>
        <div class="field-row">
          <label>Owner / Contact Name</label>
          <input type="text" name="brand_ownerName" value="<%= brandProfile.ownerName %>" placeholder="Jane Smith">
        </div>
        <div class="field-row">
          <label>Location</label>
          <input type="text" name="brand_location" value="<%= brandProfile.location %>" placeholder="Denver, CO">
        </div>
        <div class="field-row">
          <label>Service Area</label>
          <input type="text" name="brand_serviceArea" value="<%= brandProfile.serviceArea %>" placeholder="Denver metro & surrounding areas">
        </div>
        <div class="field-row">
          <label>Phone</label>
          <input type="text" name="brand_phone" value="<%= brandProfile.phone %>" placeholder="(555) 123-4567">
        </div>
        <div class="field-row">
          <label>Contact Email</label>
          <input type="text" name="brand_email" value="<%= brandProfile.email %>" placeholder="hello@yourbusiness.com">
        </div>
      </div>

      <div class="field-row">
        <label>Tagline</label>
        <input type="text" name="brand_tagline" value="<%= brandProfile.tagline %>" placeholder="Growing brands that matter.">
      </div>
      <div class="field-row">
        <label>Business Description</label>
        <textarea name="brand_description" rows="3" style="width:100%;padding:10px 12px;border:1px solid var(--ivory-mid);border-radius:3px;font-family:'Jost',sans-serif;font-size:0.82rem;color:var(--dark);background:var(--ivory);outline:none;resize:vertical;" placeholder="Brief description of what your business does, who you serve, and what makes you unique."><%= brandProfile.description %></textarea>
      </div>
      <div class="field-row">
        <label>Services Offered</label>
        <input type="text" name="brand_services" value="<%= brandProfile.services %>" placeholder="Web Design, SEO, Social Media Management, Email Marketing">
        <div class="field-hint">Comma-separated list of your services</div>
      </div>
      <div class="field-row">
        <label>Pricing Guide</label>
        <input type="text" name="brand_pricingNotes" value="<%= brandProfile.pricingNotes %>" placeholder="Web design $1500-5000, SEO $500-1500/mo, Social media $400-1200/mo">
        <div class="field-hint">Approximate pricing ranges for agent-generated invoices and proposals</div>
      </div>
      <div class="field-row">
        <label>Target Audience</label>
        <input type="text" name="brand_targetAudience" value="<%= brandProfile.targetAudience %>" placeholder="Small to mid-size local businesses">
      </div>
      <div class="field-row">
        <label>Brand Voice / Tone</label>
        <input type="text" name="brand_brandVoice" value="<%= brandProfile.brandVoice %>" placeholder="Professional but warm, local, trustworthy">
        <div class="field-hint">How should your AI agents sound? e.g. Casual & friendly, Corporate & formal, Bold & edgy</div>
      </div>

      <div style="margin-top:16px;">
        <label style="display:block;font-size:0.7rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--slate);margin-bottom:8px;">Social Media Links</label>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0 16px;">
          <div class="field-row"><label>Facebook</label><input type="text" name="brand_social_facebook" value="<%= brandProfile.social_facebook %>" placeholder="https://facebook.com/yourbusiness"></div>
          <div class="field-row"><label>Instagram</label><input type="text" name="brand_social_instagram" value="<%= brandProfile.social_instagram %>" placeholder="https://instagram.com/yourbusiness"></div>
          <div class="field-row"><label>Twitter / X</label><input type="text" name="brand_social_twitter" value="<%= brandProfile.social_twitter %>" placeholder="https://twitter.com/yourbusiness"></div>
          <div class="field-row"><label>LinkedIn</label><input type="text" name="brand_social_linkedin" value="<%= brandProfile.social_linkedin %>" placeholder="https://linkedin.com/company/yourbusiness"></div>
          <div class="field-row"><label>YouTube</label><input type="text" name="brand_social_youtube" value="<%= brandProfile.social_youtube %>" placeholder="https://youtube.com/@yourbusiness"></div>
          <div class="field-row"><label>TikTok</label><input type="text" name="brand_social_tiktok" value="<%= brandProfile.social_tiktok %>" placeholder="https://tiktok.com/@yourbusiness"></div>
        </div>
      </div>

      <button type="submit" style="margin-top:12px;padding:10px 24px;background:var(--gold);color:var(--dark);border:none;border-radius:3px;font-family:'Jost',sans-serif;font-size:0.8rem;font-weight:600;cursor:pointer;letter-spacing:0.04em;">Save Profile</button>
    </div>

    <!-- ═══════════ CUSTOM DOMAIN ═══════════ -->
    <div class="settings-section">
      <h2>
        &#9672; Custom Domain
        <button type="button" class="guide-toggle" onclick="toggleGuide('domain')">&#9432; Setup Guide</button>
      </h2>
      <p class="desc">Connect your own domain name instead of using <code><%= settings.domain %></code>.</p>

      <div class="guide-panel" id="guide-domain">
        <ol>
          <li>Purchase a domain from any registrar (Namecheap, GoDaddy, Cloudflare, Google Domains, etc.).</li>
          <li>In your registrar's DNS settings, add an <strong>A Record</strong>:
            <table style="width:100%;font-size:0.72rem;border-collapse:collapse;margin:8px 0;">
              <tr style="background:var(--ivory);"><td style="padding:4px 8px;font-weight:600;">Type</td><td style="padding:4px 8px;font-weight:600;">Name</td><td style="padding:4px 8px;font-weight:600;">Value</td></tr>
              <tr><td style="padding:4px 8px;font-family:monospace;">A</td><td style="padding:4px 8px;font-family:monospace;">@</td><td style="padding:4px 8px;font-family:monospace;">104.237.138.28</td></tr>
              <tr><td style="padding:4px 8px;font-family:monospace;">A</td><td style="padding:4px 8px;font-family:monospace;">www</td><td style="padding:4px 8px;font-family:monospace;">104.237.138.28</td></tr>
            </table>
          </li>
          <li>Wait for DNS propagation (usually 5&ndash;30 minutes, can take up to 48 hours).</li>
          <li>Enter your domain below and save. SSL certificate will be provisioned automatically.</li>
          <li>After saving, your site will be live at both <code><%= settings.domain %></code> and your custom domain.</li>
        </ol>
        <div class="guide-tip">If you use Cloudflare: set the proxy status to "DNS only" (grey cloud) for the A records, otherwise SSL provisioning may fail.</div>
      </div>

      <div class="field-row">
        <label>Custom Domain</label>
        <input type="text" name="customDomain" value="<%= settings.customDomain %>" placeholder="yourbusiness.com">
        <div class="field-hint">Point A records for <code>@</code> and <code>www</code> to <code style="user-select:all;">104.237.138.28</code> first. SSL is provisioned automatically.</div>
      </div>

      <% if (!settings.customDomain) { %>
      <button type="submit" style="margin-top:12px;padding:10px 24px;background:var(--gold);color:var(--dark);border:none;border-radius:3px;font-family:'Jost',sans-serif;font-size:0.8rem;font-weight:600;cursor:pointer;letter-spacing:0.04em;">Save Domain</button>
      <% } %>
    </div>

