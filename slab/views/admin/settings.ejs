        <input type="password" name="stripeWebhookSecret" value="<%= settings.stripeWebhookSecret %>" placeholder="whsec_...">
        <div class="field-hint">From Stripe Dashboard &rarr; Webhooks &rarr; your endpoint &rarr; Signing secret</div>
      </div>
    </div>

    <!-- ═══════════ PAYPAL ═══════════ -->
    <div class="settings-section">
      <h2>
        &#9672; Payments &mdash; PayPal
        <button type="button" class="guide-toggle" onclick="toggleGuide('paypal')">&#9432; Setup Guide</button>
      </h2>
      <p class="desc">Accept PayPal payments alongside or instead of Stripe.</p>

      <div class="guide-panel" id="guide-paypal">
        <ol>
          <li>Go to <a href="https://developer.paypal.com/dashboard/applications" target="_blank">PayPal Developer Dashboard</a> and log in with your PayPal Business account.</li>
