    <!-- ═══════════ EMAIL (ZOHO) ═══════════ -->
    <div class="settings-section">
      <h2>
        &#9672; Email (Zoho SMTP)
        <button type="button" class="guide-toggle" onclick="toggleGuide('zoho')">&#9432; Setup Guide</button>
      </h2>
      <p class="desc">Send invoices, campaigns, and client emails from your own domain. Requires a Zoho Mail account.</p>

      <div class="guide-panel" id="guide-zoho">
        <ol>
          <li>Go to <a href="https://www.zoho.com/mail/zohomail-pricing.html" target="_blank">Zoho Mail</a> and sign up for a plan (Mail Lite works — free plan does NOT include SMTP).</li>
          <li>During setup, add your domain (e.g., <code><%= settings.domain %></code>) and verify ownership via a TXT record.</li>
          <li>Create your email address (e.g., <code>hello@<%= settings.domain %></code>).</li>
          <li>Enable SMTP access: go to <a href="https://accounts.zoho.com/home#security/security_pwd" target="_blank">Zoho Account &rarr; Security</a>.</li>
          <li>Scroll to <strong>App Passwords</strong> and click <strong>Generate New Password</strong>.</li>
          <li>Name it (e.g., "sLab Platform") and copy the generated password.</li>
          <li>Paste your Zoho email address and the app password below.</li>
          <li>Hit <strong>Test</strong> to verify the SMTP connection works.</li>
        </ol>
        <div class="guide-tip">Important: Regular Zoho passwords won't work for SMTP. You must use an App Password. After setup, configure the DNS records in the section below.</div>
      </div>

      <div class="field-row">
        <label>Zoho Email Address</label>
        <input type="email" name="zohoUser" value="<%= settings.zohoUser %>" placeholder="you@yourdomain.com">
        <div class="field-hint">The "from" address for all outgoing emails (invoices, campaigns, notifications)</div>
      </div>
      <div class="field-row">
        <label>Zoho App Password <% if (settings.zohoPass_set) { %><span class="field-set">&#9679; configured</span><% } %></label>
        <div class="inline">
          <input type="password" name="zohoPass" value="<%= settings.zohoPass %>" placeholder="App-specific password">
          <button type="button" class="btn-test" onclick="testEmail()">Test</button>
        </div>
        <div class="test-result" id="emailResult"></div>
        <div class="field-hint">App password from Zoho Account &rarr; Security &rarr; App Passwords. Not your login password.</div>
      </div>
    </div>

    <!-- ═══════════ EMAIL DNS ═══════════ -->
    <div class="settings-section">
      <h2>
        &#9672; Email DNS Records
        <button type="button" class="guide-toggle" onclick="toggleGuide('dns')">&#9432; What are these?</button>
      </h2>
      <p class="desc">These DNS records are <strong>required</strong> for email deliverability. Without them, your emails will land in spam or be rejected.</p>

      <div class="guide-panel" id="guide-dns">
        <ol>
          <li><strong>SPF</strong> (Sender Policy Framework) &mdash; Tells receiving mail servers "these IP addresses are allowed to send email for my domain." Without it, servers assume your emails might be forged.</li>
          <li><strong>DKIM</strong> (DomainKeys Identified Mail) &mdash; Adds a cryptographic signature to every email you send. The receiving server checks it against a public key in your DNS to prove the email wasn't tampered with.</li>
          <li><strong>DMARC</strong> (Domain-based Message Authentication) &mdash; Ties SPF and DKIM together with a policy. It tells receivers what to do when emails fail authentication (monitor, quarantine, or reject).</li>
          <li><strong>MX Records</strong> &mdash; Only needed if you receive email on this domain via Zoho. Tells other mail servers where to deliver incoming mail.</li>
          <li><strong>Return-Path CNAME</strong> &mdash; Handles bounce messages. Zoho manages this, but the CNAME record lets them process bounces for your domain.</li>
        </ol>
        <div class="guide-tip">Where to add these: Log in to wherever you bought your domain (GoDaddy, Namecheap, Cloudflare, Google Domains, etc.) and find "DNS Settings" or "DNS Records". Add each record as shown below.</div>
      </div>

      <%
        const emailDomain = settings.zohoUser ? settings.zohoUser.split('@')[1] : settings.domain;
        const isSubdomain = settings.domain.endsWith('.madladslab.com');
      %>

      <div style="background:var(--ivory);padding:16px;border-radius:4px;margin-bottom:16px;">
        <div style="font-size:0.7rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--slate);margin-bottom:8px;">Sending Domain</div>
        <div style="font-size:0.95rem;font-weight:500;color:var(--navy);"><%= emailDomain || 'Set your Zoho email above' %></div>
      </div>

      <% if (emailDomain) { %>

      <!-- SPF -->
      <div style="margin-bottom:16px;padding:16px;border:1px solid var(--ivory-mid);border-radius:4px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
          <div style="font-size:0.78rem;font-weight:600;color:var(--dark);">SPF Record</div>
          <div class="dns-status" id="spf-status" style="font-size:0.68rem;font-weight:500;">&mdash;</div>
        </div>
        <div style="font-size:0.68rem;color:var(--slate);margin-bottom:8px;">Authorizes Zoho's servers to send email on behalf of your domain.</div>
        <table style="width:100%;font-size:0.75rem;border-collapse:collapse;">
          <tr style="background:var(--ivory);">
            <td style="padding:6px 10px;font-weight:600;width:60px;">Type</td>
            <td style="padding:6px 10px;font-weight:600;width:120px;">Name</td>
            <td style="padding:6px 10px;font-weight:600;">Value</td>
          </tr>
          <tr>
            <td style="padding:6px 10px;font-family:monospace;">TXT</td>
            <td style="padding:6px 10px;font-family:monospace;">@</td>
            <td style="padding:6px 10px;font-family:monospace;word-break:break-all;">v=spf1 include:zoho.com ~all</td>
          </tr>
        </table>
        <div style="font-size:0.65rem;color:var(--slate);margin-top:6px;">If you already have an SPF record, add <code>include:zoho.com</code> before the <code>~all</code></div>
      </div>

      <!-- DKIM -->
      <div style="margin-bottom:16px;padding:16px;border:1px solid var(--ivory-mid);border-radius:4px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
          <div style="font-size:0.78rem;font-weight:600;color:var(--dark);">DKIM Record</div>
          <div class="dns-status" id="dkim-status" style="font-size:0.68rem;font-weight:500;">&mdash;</div>
        </div>
        <div style="font-size:0.68rem;color:var(--slate);margin-bottom:8px;">Cryptographic signature proving your emails are authentic.</div>
        <table style="width:100%;font-size:0.75rem;border-collapse:collapse;">
          <tr style="background:var(--ivory);">
            <td style="padding:6px 10px;font-weight:600;width:60px;">Type</td>
            <td style="padding:6px 10px;font-weight:600;width:120px;">Name</td>
            <td style="padding:6px 10px;font-weight:600;">Value</td>
          </tr>
          <tr>
            <td style="padding:6px 10px;font-family:monospace;">TXT</td>
            <td style="padding:6px 10px;font-family:monospace;">zmail._domainkey</td>
            <td style="padding:6px 10px;font-size:0.68rem;color:var(--slate);font-style:italic;">Unique per domain &mdash; get from Zoho (see steps below)</td>
          </tr>
        </table>
        <div style="font-size:0.65rem;color:var(--slate);margin-top:6px;line-height:1.6;">
          <strong>How to get your DKIM key:</strong><br>
          1. Log in to <a href="https://mailadmin.zoho.com" target="_blank" style="color:var(--gold);">Zoho Mail Admin Console</a><br>
          2. Go to <strong>Domains</strong> &rarr; click <strong><%= emailDomain %></strong><br>
          3. Click <strong>Email Authentication</strong> &rarr; <strong>DKIM</strong><br>
          4. Click <strong>Add Selector</strong> (use "zmail" as the selector name)<br>
          5. Copy the generated TXT record value and add it to your DNS
        </div>
      </div>

      <!-- DMARC -->
      <div style="margin-bottom:16px;padding:16px;border:1px solid var(--ivory-mid);border-radius:4px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
          <div style="font-size:0.78rem;font-weight:600;color:var(--dark);">DMARC Record</div>
          <div class="dns-status" id="dmarc-status" style="font-size:0.68rem;font-weight:500;">&mdash;</div>
        </div>
        <div style="font-size:0.68rem;color:var(--slate);margin-bottom:8px;">Tells mail servers what to do when SPF/DKIM fail. Start with "none" then tighten over time.</div>
        <table style="width:100%;font-size:0.75rem;border-collapse:collapse;">
          <tr style="background:var(--ivory);">
            <td style="padding:6px 10px;font-weight:600;width:60px;">Type</td>
            <td style="padding:6px 10px;font-weight:600;width:120px;">Name</td>
            <td style="padding:6px 10px;font-weight:600;">Value</td>
          </tr>
          <tr>
            <td style="padding:6px 10px;font-family:monospace;">TXT</td>
            <td style="padding:6px 10px;font-family:monospace;">_dmarc</td>
            <td style="padding:6px 10px;font-family:monospace;word-break:break-all;">v=DMARC1; p=none; rua=mailto:dmarc@<%= emailDomain %></td>
          </tr>
        </table>
        <div style="font-size:0.65rem;color:var(--slate);margin-top:6px;">
          <strong>DMARC policy progression:</strong>
          <code>p=none</code> (monitor only, start here) &rarr;
          <code>p=quarantine</code> (send failures to spam) &rarr;
          <code>p=reject</code> (block failures entirely)
        </div>
      </div>

      <!-- MX -->
      <div style="margin-bottom:16px;padding:16px;border:1px solid var(--ivory-mid);border-radius:4px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
          <div style="font-size:0.78rem;font-weight:600;color:var(--dark);">MX Records <span style="font-size:0.65rem;font-weight:400;color:var(--slate);">(for receiving email via Zoho)</span></div>
          <div class="dns-status" id="mx-status" style="font-size:0.68rem;font-weight:500;">&mdash;</div>
        </div>
        <div style="font-size:0.68rem;color:var(--slate);margin-bottom:8px;">Required only if you receive email on this domain through Zoho. Skip if you use Gmail/Outlook for incoming.</div>
        <table style="width:100%;font-size:0.75rem;border-collapse:collapse;">
          <tr style="background:var(--ivory);">
            <td style="padding:6px 10px;font-weight:600;width:60px;">Type</td>
            <td style="padding:6px 10px;font-weight:600;width:60px;">Priority</td>
            <td style="padding:6px 10px;font-weight:600;width:80px;">Name</td>
            <td style="padding:6px 10px;font-weight:600;">Value</td>
          </tr>
          <tr><td style="padding:4px 10px;font-family:monospace;">MX</td><td style="padding:4px 10px;">10</td><td style="padding:4px 10px;font-family:monospace;">@</td><td style="padding:4px 10px;font-family:monospace;">mx.zoho.com</td></tr>
          <tr><td style="padding:4px 10px;font-family:monospace;">MX</td><td style="padding:4px 10px;">20</td><td style="padding:4px 10px;font-family:monospace;">@</td><td style="padding:4px 10px;font-family:monospace;">mx2.zoho.com</td></tr>
          <tr><td style="padding:4px 10px;font-family:monospace;">MX</td><td style="padding:4px 10px;">50</td><td style="padding:4px 10px;font-family:monospace;">@</td><td style="padding:4px 10px;font-family:monospace;">mx3.zoho.com</td></tr>
        </table>
      </div>

      <!-- Return-Path -->
      <div style="margin-bottom:16px;padding:16px;border:1px solid var(--ivory-mid);border-radius:4px;">
        <div style="font-size:0.78rem;font-weight:600;color:var(--dark);margin-bottom:8px;">Return-Path (Bounce Handling)</div>
        <div style="font-size:0.68rem;color:var(--slate);margin-bottom:8px;">Lets Zoho process bounced emails for your domain.</div>
        <table style="width:100%;font-size:0.75rem;border-collapse:collapse;">
          <tr style="background:var(--ivory);">
            <td style="padding:6px 10px;font-weight:600;width:60px;">Type</td>
            <td style="padding:6px 10px;font-weight:600;width:120px;">Name</td>
            <td style="padding:6px 10px;font-weight:600;">Value</td>
          </tr>
          <tr>
            <td style="padding:6px 10px;font-family:monospace;">CNAME</td>
            <td style="padding:6px 10px;font-family:monospace;">zb._domainkey</td>
            <td style="padding:6px 10px;font-family:monospace;">zb._domainkey.zoho.com</td>
          </tr>
        </table>
      </div>

      <!-- Check DNS / Auto-create -->
      <button type="button" class="btn-test" onclick="checkDns()" style="padding:10px 24px;font-size:0.78rem;">
        Check DNS Records
      </button>
      <div id="dnsOverall" style="font-size:0.75rem;margin-top:8px;min-height:20px;"></div>

      <% if (isSubdomain) { %>
      <div style="margin-top:12px;padding:12px 16px;background:rgba(22,163,74,0.06);border:1px solid rgba(22,163,74,0.15);border-radius:4px;">
        <div style="font-size:0.72rem;color:#166534;">
          <strong>Subdomain tenant:</strong> SPF and DMARC records for <code><%= emailDomain %></code> can be auto-created.
          <button type="button" class="btn-test" onclick="autoCreateDns()" style="margin-left:8px;padding:6px 14px;font-size:0.68rem;background:#166534;">Auto-Create DNS</button>
          <span id="autoCreateResult" style="margin-left:8px;"></span>
        </div>
      </div>
      <% } %>

      <% } else { %>
        <div style="padding:16px;background:rgba(251,191,36,0.06);border:1px solid rgba(251,191,36,0.2);border-radius:4px;font-size:0.78rem;color:#92400e;">
          Set your Zoho email address above to see the required DNS records for your sending domain.
        </div>
      <% } %>
    </div>

    <!-- ═══════════ GOOGLE REVIEWS ═══════════ -->
    <div class="settings-section">
      <h2>
        &#9672; Google Reviews
        <button type="button" class="guide-toggle" onclick="toggleGuide('places')">&#9432; Setup Guide</button>
      </h2>
      <p class="desc">Display your Google Business reviews on your landing page. Requires a Google Cloud API key.</p>

      <div class="guide-panel" id="guide-places">
        <ol>
          <li>Go to <a href="https://console.cloud.google.com/" target="_blank">Google Cloud Console</a> and create a project (or select an existing one).</li>
          <li>Enable the <strong>Places API</strong>: search "Places API" in the API Library and click <strong>Enable</strong>.</li>
          <li>Go to <a href="https://console.cloud.google.com/apis/credentials" target="_blank">APIs &amp; Services &rarr; Credentials</a>.</li>
          <li>Click <strong>Create Credentials &rarr; API Key</strong>. Copy the key (<code>AIzaSy...</code>).</li>
          <li><strong>Restrict the key</strong> (recommended): click the key &rarr; under "API restrictions" select "Restrict key" &rarr; choose "Places API" only.</li>
          <li>Find your <strong>Place ID</strong>: go to <a href="https://developers.google.com/maps/documentation/places/web-service/place-id" target="_blank">Place ID Finder</a>, search your business, and copy the ID (<code>ChIJ...</code>).</li>
          <li>Paste both values below and save. Reviews will appear on your landing page within a few minutes.</li>
        </ol>
        <div class="guide-tip">Tip: Google gives $200/month in free API credits, which covers ~40,000 reviews lookups. More than enough for any site.</div>
      </div>

      <div class="field-row">
        <label>Google Places API Key</label>
        <input type="text" name="googlePlacesKey" value="<%= settings.googlePlacesKey %>" placeholder="AIzaSy...">
        <div class="field-hint">From Google Cloud Console &rarr; Credentials &rarr; API Keys</div>
      </div>
      <div class="field-row">
        <label>Google Place ID</label>
        <input type="text" name="googlePlaceId" value="<%= settings.googlePlaceId %>" placeholder="ChIJ...">
        <div class="field-hint">Your business Place ID. Find it at <a href="https://developers.google.com/maps/documentation/places/web-service/place-id" target="_blank" style="color:var(--gold);">Place ID Finder</a></div>
      </div>
    </div>

    <!-- ═══════════ GOOGLE OAUTH ═══════════ -->
    <div class="settings-section">
      <h2>
        &#9672; Google OAuth (Login)
        <button type="button" class="guide-toggle" onclick="toggleGuide('oauth')">&#9432; Setup Guide</button>
      </h2>
      <p class="desc">Let admins and clients log in with their Google account. Optional but recommended for easier access.</p>

      <div class="guide-panel" id="guide-oauth">
        <ol>
          <li>Go to <a href="https://console.cloud.google.com/apis/credentials" target="_blank">Google Cloud Console &rarr; Credentials</a> (same project as Places API).</li>
          <li>Click <strong>Create Credentials &rarr; OAuth client ID</strong>.</li>
          <li>If prompted, configure the <strong>OAuth consent screen</strong> first:
            <ul style="margin:4px 0 4px 16px;font-size:0.72rem;">
              <li>User Type: <strong>External</strong></li>
              <li>App name: <strong><%= brand?.name || 'Your Brand' %></strong></li>
              <li>Support email: your Zoho email</li>
              <li>Authorized domains: <code><%= settings.domain %></code></li>
            </ul>
          </li>
          <li>Back in Credentials, create the OAuth Client ID:
            <ul style="margin:4px 0 4px 16px;font-size:0.72rem;">
              <li>Application type: <strong>Web application</strong></li>
              <li>Authorized redirect URI: <code>https://<%= settings.domain %>/auth/google/callback</code></li>
            </ul>
          </li>
          <li>Copy the <strong>Client ID</strong> and <strong>Client Secret</strong> and paste them below.</li>
        </ol>
        <div class="guide-tip">Tip: Add both your subdomain and custom domain as authorized redirect URIs if you use both.</div>
      </div>

      <div class="field-row">
        <label>OAuth Client ID</label>
        <input type="text" name="googleOAuthClientId" value="<%= settings.googleOAuthClientId || '' %>" placeholder="123456789-abc.apps.googleusercontent.com">
        <div class="field-hint">From Google Cloud Console &rarr; Credentials &rarr; OAuth 2.0 Client IDs</div>
      </div>
      <div class="field-row">
        <label>OAuth Client Secret <% if (settings.googleOAuthSecret_set) { %><span class="field-set">&#9679; configured</span><% } %></label>
        <input type="password" name="googleOAuthSecret" value="<%= settings.googleOAuthSecret || '' %>" placeholder="GOCSPX-...">
        <div class="field-hint">Secret key — encrypted at rest. Found next to your Client ID in Google Cloud.</div>
      </div>
    </div>

    <button type="submit" style="padding:12px 32px;background:var(--gold);color:var(--dark);border:none;border-radius:3px;font-family:'Jost',sans-serif;font-size:0.85rem;font-weight:600;cursor:pointer;letter-spacing:0.04em;">Save Settings</button>
  </form>
</div>

</div><!-- close .main from sidebar -->

<script>
function toggleGuide(id) {
  const panel = document.getElementById('guide-' + id);
  if (panel) panel.classList.toggle('open');
}

async function testStripe() {
  const el = document.getElementById('stripeResult');
  el.textContent = 'Testing...'; el.className = 'test-result';
  try {
    const r = await fetch('/admin/settings/test-stripe', { method: 'POST' });
    const d = await r.json();
    if (d.ok) { el.textContent = 'Connected (' + d.currency + ')'; el.className = 'test-result test-ok'; }
    else { el.textContent = d.error; el.className = 'test-result test-fail'; }
  } catch { el.textContent = 'Network error'; el.className = 'test-result test-fail'; }
}

async function testEmail() {
  const el = document.getElementById('emailResult');
  el.textContent = 'Testing...'; el.className = 'test-result';
  try {
    const r = await fetch('/admin/settings/test-email', { method: 'POST' });
    const d = await r.json();
    if (d.ok) { el.textContent = 'SMTP connection verified'; el.className = 'test-result test-ok'; }
    else { el.textContent = d.error; el.className = 'test-result test-fail'; }
  } catch { el.textContent = 'Network error'; el.className = 'test-result test-fail'; }
}

async function checkDns() {
  const overall = document.getElementById('dnsOverall');
  overall.textContent = 'Checking DNS records...';
  overall.style.color = 'var(--slate)';
  ['spf','dkim','dmarc','mx'].forEach(k => {
    const el = document.getElementById(k + '-status');
    if (el) { el.textContent = '...'; el.style.color = 'var(--slate)'; }
  });
  try {
    const r = await fetch('/admin/settings/check-dns', { method: 'POST' });
    const d = await r.json();
    if (!d.ok) { overall.textContent = d.error; overall.style.color = '#dc2626'; return; }
    const res = d.results;
    let allGood = true;
    ['spf','dkim','dmarc','mx'].forEach(k => {
      const el = document.getElementById(k + '-status');
      if (!el || !res[k]) return;
      if (res[k].valid) {
        el.textContent = '\u2713 ' + res[k].message;
        el.style.color = '#16a34a';
      } else if (res[k].found) {
        el.textContent = '\u26A0 ' + res[k].message;
        el.style.color = '#d97706';
        allGood = false;
      } else {
        el.textContent = '\u2717 ' + res[k].message;
        el.style.color = '#dc2626';
        allGood = false;
      }
    });
    if (allGood) {
      overall.textContent = 'All email DNS records look good!';
      overall.style.color = '#16a34a';
    } else {
      overall.textContent = 'Some records need attention \u2014 see above.';
      overall.style.color = '#d97706';
    }
  } catch { overall.textContent = 'Network error'; overall.style.color = '#dc2626'; }
}

async function autoCreateDns() {
  const el = document.getElementById('autoCreateResult');
  el.textContent = 'Creating records...';
  el.style.color = 'var(--slate)';
  try {
    const r = await fetch('/admin/settings/auto-create-dns', { method: 'POST' });
    const d = await r.json();
    if (!d.ok) { el.textContent = d.error; el.style.color = '#dc2626'; return; }
    let msg = '';
    if (d.created.length) msg += 'Created: ' + d.created.join(', ') + '. ';
    if (d.errors.length) msg += 'Failed: ' + d.errors.join(', ') + '. ';
    if (d.note) msg += d.note;
    el.textContent = msg;
    el.style.color = d.errors.length ? '#d97706' : '#16a34a';
  } catch { el.textContent = 'Network error'; el.style.color = '#dc2626'; }
}
</script>
<script>
// ── Tutorial settings ────────────────────────────────────────────────────────
(async function() {
  try {
    const r = await fetch('/admin/tutorials/status');
    if (!r.ok) return;
    const d = await r.json();
    const t = d.tutorials || {};
    document.getElementById('tutAutoPlay').checked = t.autoPlay !== false;
    document.getElementById('tutCollapsed').checked = !!t.collapsed;
  } catch {}

  // Fetch progress
  try {
    const r = await fetch('/admin/tutorials/progress');
    if (r.ok) {
      const d = await r.json();
      document.getElementById('tutProgress').textContent = d.completed + '/' + d.total + ' completed (' + d.percentage + '%)';
    }
  } catch {}

  // Toggle handlers
  document.getElementById('tutAutoPlay').addEventListener('change', async function() {
    await fetch('/admin/tutorials/preferences', {
      method: 'PUT', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ autoPlay: this.checked })
    });
    if (this.checked && typeof AdminTour !== 'undefined') AdminTour.resumeAll();
  });

  document.getElementById('tutCollapsed').addEventListener('change', async function() {
    await fetch('/admin/tutorials/preferences', {
      method: 'PUT', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ collapsed: this.checked })
    });
    if (typeof AdminTour !== 'undefined') {
      if (this.checked) AdminTour.collapseAll();
      else AdminTour.expandAll();
    }
  });
})();

async function resetAllTutorials() {
  const el = document.getElementById('tutResult');
  try {
    const r = await fetch('/admin/tutorials/reset', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}'
    });
    const d = await r.json();
    if (d.success) {
      el.textContent = 'All tutorials reset — they will auto-play again on each page.';
      el.className = 'test-result test-ok';
      document.getElementById('tutProgress').textContent = '0/' + (document.getElementById('tutProgress').textContent.split('/')[1] || '27');
    }
  } catch(e) { el.textContent = 'Error: ' + e.message; el.className = 'test-result test-fail'; }
}

// ── Changelog ────────────────────────────────────────────────────────────────
// Click commit row to select its hash
document.querySelectorAll('#changelogList [data-hash]').forEach(function(row) {
  row.style.cursor = 'pointer';
  row.addEventListener('click', function() {
    var hashInput = document.getElementById('clHash');
    if (hashInput) {
      hashInput.value = row.dataset.hash;
      hashInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });
});

async function addChangelog() {
  var el = document.getElementById('clResult');
  var commitHash = document.getElementById('clHash').value.trim();
  var notes = document.getElementById('clNotes').value.trim();
  if (!notes) { el.textContent = 'Notes required'; el.className = 'test-result test-fail'; return; }

  try {
    var r = await fetch('/admin/settings/changelog', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ commitHash: commitHash, notes: notes })
    });
    var d = await r.json();
    if (d.ok) {
      el.textContent = 'Pinned!'; el.className = 'test-result test-ok';
      setTimeout(function() { location.reload(); }, 800);
    } else {
      el.textContent = d.error || 'Failed'; el.className = 'test-result test-fail';
    }
  } catch(e) { el.textContent = e.message; el.className = 'test-result test-fail'; }
}
</script>
<script src="/js/tours/settings.js"></script>
