<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — <%= brand?.name || 'Home' %></title>
  <%
    const _bd = typeof brandDesign !== 'undefined' ? brandDesign : {};
    const _hFont = _bd.font_heading || 'Cormorant Garamond';
    const _bFont = _bd.font_body || 'Jost';
    const _fontMap = {
      'Cormorant Garamond': 'Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400',
      'Playfair Display': 'Playfair+Display:wght@400;600;700',
      'Lora': 'Lora:wght@400;600;700',
      'Merriweather': 'Merriweather:wght@300;400;700',
      'Libre Baskerville': 'Libre+Baskerville:wght@400;700',
      'Jost': 'Jost:wght@300;400;500;600',
      'Inter': 'Inter:wght@300;400;500;600;700',
      'Poppins': 'Poppins:wght@300;400;500;600;700',
      'Raleway': 'Raleway:wght@300;400;500;600;700',
      'Nunito': 'Nunito:wght@300;400;500;600;700',
      'DM Sans': 'DM+Sans:wght@300;400;500;600;700',
    };
    const _hFU = _fontMap[_hFont] || _fontMap['Cormorant Garamond'];
    const _bFU = _fontMap[_bFont] || _fontMap['Jost'];
    const _fp = _hFU === _bFU ? _hFU : _hFU + '&family=' + _bFU;
    const oauthCid = (typeof tenant !== 'undefined' && tenant?.public?.googleOAuthClientId)
      || (typeof platformGoogleCid !== 'undefined' && platformGoogleCid)
      || '';
    const _centralAuthUrl = typeof centralAuthUrl !== 'undefined' ? centralAuthUrl : '';
  %>
  <link href="https://fonts.googleapis.com/css2?family=<%= _fp %>&display=swap" rel="stylesheet">
  <% /* Google One-Tap only loads on slab.madladslab.com (central auth page handles it) */ %>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    :root { --navy: <%= _bd.color_primary || '#1C2B4A' %>; --navy-deep: <%= _bd.color_primary_deep || '#0F1B30' %>; --gold: <%= _bd.color_accent || '#C9A848' %>; --gold-light: <%= _bd.color_accent_light || '#E8D08A' %>; --ivory: <%= _bd.color_bg || '#F5F3EF' %>; --ivory-mid: #E6E1D6; --dark: #0F1B30; --white: #FDFCFA; --on-ivory: <%= _bd._on_bg || '#0F1B30' %>; --on-ivory-muted: <%= _bd._on_bg_muted || '#6B7380' %>; --font-heading: '<%= _hFont %>', serif; --font-body: '<%= _bFont %>', sans-serif; }
    body { font-family:var(--font-body); background:transparent; min-height:100vh; display:flex; align-items:center; justify-content:center; }

    /* ── Floating backdrop ── */
    .auth-backdrop { position:fixed; inset:0; background:rgba(15,27,48,0.65); backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); z-index:999; display:flex; align-items:center; justify-content:center; }

    /* ── Modal card ── */
    .auth-modal { background:var(--ivory); max-width:420px; width:100%; margin:24px; border-radius:4px; box-shadow:0 32px 80px rgba(0,0,0,0.5); overflow:hidden; position:relative; z-index:1000; animation:authSlideIn 0.3s ease; }
    @keyframes authSlideIn { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
    .auth-header { padding:32px 32px 0; text-align:center; }
    .auth-brand { font-family:var(--font-heading); font-size:1.8rem; font-weight:300; color:var(--on-ivory); margin-bottom:2px; }
    .auth-sub { font-size:0.62rem; font-weight:600; letter-spacing:0.22em; text-transform:uppercase; color:var(--on-ivory-muted); margin-bottom:20px; }

    /* ── Tabs ── */
    .auth-tabs { display:flex; border-bottom:1px solid var(--ivory-mid); margin:0 32px; }
    .auth-tab { flex:1; padding:10px 0; text-align:center; font-size:0.7rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:var(--on-ivory-muted); cursor:pointer; border-bottom:2px solid transparent; transition:all 0.15s; background:none; border-top:none; border-left:none; border-right:none; font-family:var(--font-body); }
    .auth-tab:hover { color:var(--dark); }
    .auth-tab.active { color:var(--navy); border-bottom-color:var(--gold); }

    /* ── Panels ── */
    .auth-body { padding:24px 32px 32px; }
    .auth-panel { display:none; }
    .auth-panel.active { display:block; }

    /* ── Form elements ── */
    .field { margin-bottom:14px; }
    .field label { display:block; font-size:0.62rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:var(--on-ivory-muted); margin-bottom:5px; }
    .field input { width:100%; padding:11px 14px; border:1.5px solid var(--ivory-mid); border-radius:2px; font-family:var(--font-body); font-size:0.85rem; font-weight:300; color:var(--dark); background:var(--white); outline:none; }
    .field input:focus { border-color:var(--navy); }
    .hint { font-size:0.62rem; color:var(--on-ivory-muted); margin-top:3px; }
    .btn-submit { width:100%; padding:13px; background:var(--navy); color:var(--white); border:none; border-radius:2px; font-family:var(--font-body); font-size:0.78rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; transition:background 0.15s; margin-top:6px; }
    .btn-submit:hover { background:var(--navy-deep); }
    .btn-submit:disabled { background:var(--ivory-mid); color:var(--on-ivory-muted); cursor:not-allowed; }

    /* ── Divider ── */
    .divider { display:flex; align-items:center; gap:14px; margin:18px 0; font-size:0.62rem; color:var(--on-ivory-muted); letter-spacing:0.1em; text-transform:uppercase; }
    .divider::before, .divider::after { content:''; flex:1; height:1px; background:var(--ivory-mid); }

    /* ── Google button ── */
    .btn-google { display:flex; align-items:center; justify-content:center; gap:10px; width:100%; background:var(--white); color:var(--on-ivory); text-decoration:none; padding:12px; font-size:0.78rem; font-weight:500; letter-spacing:0.04em; transition:all 0.15s; border-radius:2px; border:1.5px solid var(--ivory-mid); cursor:pointer; font-family:var(--font-body); }
    .btn-google:hover { border-color:var(--navy); background:var(--ivory); }
    .btn-google svg { width:18px; height:18px; flex-shrink:0; }

    /* ── Messages ── */
    .msg-error { background:rgba(185,28,28,0.07); border:1px solid rgba(185,28,28,0.2); color:#B91C1C; padding:10px 12px; font-size:0.78rem; margin-bottom:14px; border-radius:2px; }
    .msg-success { background:rgba(21,128,61,0.07); border:1px solid rgba(21,128,61,0.2); color:#15803D; padding:10px 12px; font-size:0.78rem; margin-bottom:14px; border-radius:2px; }
    .msg-info { font-size:0.72rem; color:var(--on-ivory-muted); text-align:center; margin-top:14px; line-height:1.6; }
    .msg-info a { color:var(--navy); text-decoration:none; }

    .auth-footer { padding:0 32px 24px; text-align:center; }
    .auth-footer a { font-size:0.72rem; color:var(--on-ivory-muted); text-decoration:none; }
    .auth-footer a:hover { color:var(--navy); }

    /* One Tap container */
    #oneTapWrap { display:flex; justify-content:center; margin-bottom:12px; }

    @media (max-width:480px) { .auth-modal { margin:12px; } .auth-body { padding:20px 20px 24px; } .auth-tabs { margin:0 20px; } .auth-header { padding:24px 20px 0; } .auth-footer { padding:0 20px 20px; } }
  </style>
</head>
<body>
<%- include('../partials/maintenance-banner') %>

<div class="auth-backdrop" id="authBackdrop">
<div class="auth-modal">
  <div class="auth-header">
    <div class="auth-brand"><%- brand?.name || 'Admin' %></div>
    <div class="auth-sub">Admin Portal</div>
  </div>

  <div class="auth-tabs">
    <button class="auth-tab active" data-tab="login">Sign In</button>
    <button class="auth-tab" data-tab="register">Register</button>
    <button class="auth-tab" data-tab="recover">Recover</button>
  </div>

  <div class="auth-body">
    <% if (errorMsg) { %><div class="msg-error"><%= errorMsg %></div><% } %>
    <% if (typeof successMsg !== 'undefined' && successMsg) { %><div class="msg-success"><%= successMsg %></div><% } %>

    <!-- ═══ SIGN IN ═══ -->
    <div class="auth-panel active" id="panel-login">
      <% if (oauthCid) { %>
      <!-- Google One Tap inline (posts to /auth/google/one-tap) -->
      <div id="oneTapContainer" style="display:flex;justify-content:center;margin-bottom:8px;"></div>
      <a href="<%= _centralAuthUrl || '/auth/google' %>" class="btn-google" id="googleLoginBtn">
        <svg viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        Sign in with Google
      </a>
      <div class="divider">or sign in with email</div>
      <% } %>

      <form method="POST" action="/admin/login">
        <div class="field">
          <label>Email</label>
          <input type="email" name="email" placeholder="you@business.com" required autocomplete="email">
        </div>
        <div class="field">
          <label>Password</label>
          <input type="password" name="password" placeholder="Your password" required autocomplete="current-password">
        </div>
        <button type="submit" class="btn-submit">Sign In</button>
      </form>

      <%/* Google button is now at the top, pointing to central auth */%>

      <p class="msg-info">
        Don't have an account? <a href="#" onclick="switchTab('register');return false;">Register</a>
        &middot; <a href="#" onclick="switchTab('recover');return false;">Forgot password?</a>
      </p>
    </div>

    <!-- ═══ REGISTER ═══ -->
    <div class="auth-panel" id="panel-register">
      <form method="POST" action="/admin/register">
        <div class="field">
          <label>Display Name</label>
          <input type="text" name="displayName" placeholder="Your name">
        </div>
        <div class="field">
          <label>Email</label>
          <input type="email" name="email" placeholder="you@business.com" required>
        </div>
        <div class="field">
          <label>Password</label>
          <input type="password" name="password" placeholder="Create a password" required minlength="8">
          <div class="hint">Min 8 characters, one uppercase, one number</div>
        </div>
        <div class="field">
          <label>Confirm Password</label>
          <input type="password" name="password_confirm" placeholder="Confirm password" required>
        </div>
        <button type="submit" class="btn-submit">Create Account</button>
      </form>

      <% if (oauthCid && _centralAuthUrl) { %>
      <div class="divider">or</div>
      <a href="<%= _centralAuthUrl %>" class="btn-google">
        <svg viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        Register with Google
      </a>
      <% } %>

      <p class="msg-info">Already have an account? <a href="#" onclick="switchTab('login');return false;">Sign in</a></p>
    </div>

    <!-- ═══ RECOVER ═══ -->
    <div class="auth-panel" id="panel-recover">
      <p style="font-size:0.82rem;color:var(--on-ivory-muted);margin-bottom:16px;line-height:1.6;">Enter your email and we'll send you a link to reset your password.</p>
      <form id="recoverForm">
        <div class="field">
          <label>Email</label>
          <input type="email" name="email" placeholder="you@business.com" required id="recoverEmail">
        </div>
        <button type="submit" class="btn-submit" id="recoverBtn">Send Recovery Link</button>
      </form>
      <div id="recoverMsg" style="display:none;margin-top:12px;"></div>
      <p class="msg-info"><a href="#" onclick="switchTab('login');return false;">Back to sign in</a></p>
    </div>
  </div>

  <div class="auth-footer">
    <a href="/" id="backToSite">← Back to site</a>
  </div>
</div>
</div><!-- /auth-backdrop -->

<script>
// Click backdrop (outside modal) to go back to site
document.getElementById('authBackdrop').addEventListener('click', function(e) {
  if (e.target === this) window.location.href = '/';
});

// Tab switching
function switchTab(tab) {
  document.querySelectorAll('.auth-tab').forEach(function(t) { t.classList.toggle('active', t.dataset.tab === tab); });
  document.querySelectorAll('.auth-panel').forEach(function(p) { p.classList.toggle('active', p.id === 'panel-' + tab); });
}
document.querySelectorAll('.auth-tab').forEach(function(t) {
  t.addEventListener('click', function() { switchTab(t.dataset.tab); });
});

// Password recovery
var recoverForm = document.getElementById('recoverForm');
if (recoverForm) {
  recoverForm.addEventListener('submit', async function(e) {
    e.preventDefault();
    var email = document.getElementById('recoverEmail').value.trim();
    var btn = document.getElementById('recoverBtn');
    var msg = document.getElementById('recoverMsg');
    btn.disabled = true; btn.textContent = 'Sending...';
    try {
      var res = await fetch('/admin/recover', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: email }) });
      var data = await res.json();
      msg.style.display = 'block';
      msg.className = data.ok ? 'msg-success' : 'msg-error';
      msg.textContent = data.ok ? 'Recovery email sent. Check your inbox.' : (data.error || 'Error sending recovery email.');
    } catch(err) {
      msg.style.display = 'block'; msg.className = 'msg-error'; msg.textContent = 'Network error.';
    }
    btn.disabled = false; btn.textContent = 'Send Recovery Link';
  });
}

// Google One Tap for tenant login pages
<% if (oauthCid) { %>
(function() {
  var script = document.createElement('script');
  script.src = 'https://accounts.google.com/gsi/client';
  script.async = true;
  script.onload = function() {
    if (typeof google === 'undefined' || !google.accounts) return;
    google.accounts.id.initialize({
      client_id: '<%= oauthCid %>',
      callback: handleOneTapLogin,
      auto_select: true,
    });
    google.accounts.id.renderButton(document.getElementById('oneTapContainer'), {
      theme: 'outline', size: 'large', width: 356, text: 'signin_with',
    });
    google.accounts.id.prompt();
  };
  document.head.appendChild(script);

  window.handleOneTapLogin = async function(response) {
    try {
      var res = await fetch('/auth/google/one-tap', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ credential: response.credential }),
      });
      var data = await res.json();
      if (data.ok && data.redirect) {
        window.location.href = data.redirect;
      } else if (data.error) {
        // Fall back to central auth for non-admin users
        var centralUrl = '<%= _centralAuthUrl || "" %>';
        if (centralUrl) window.location.href = centralUrl;
        else alert(data.error);
      }
    } catch(e) {
      console.error('One Tap login error:', e);
    }
  };
})();
<% } %>
</script>
</body>
</html>
