<%- include('partials/head', { title: 'Documentation' }) %>
<%- include('partials/sidebar', { page: 'docs', user: user }) %>

<style>
  .docs-layout { display: flex; gap: 0; min-height: calc(100vh - 60px); }

  /* ── Sidebar TOC ── */
  .docs-toc {
    width: 240px; flex-shrink: 0;
    background: var(--surface); border-right: 1px solid var(--border);
    padding: 24px 0; overflow-y: auto; max-height: calc(100vh - 60px);
    position: sticky; top: 60px;
  }
  .docs-toc-section {
    font-size: 0.58rem; font-weight: 600; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--slate); padding: 14px 20px 6px;
  }
  .docs-toc-section:first-child { padding-top: 0; }
  .docs-toc a {
    display: block; padding: 7px 20px; font-size: 0.78rem; font-weight: 400;
    color: var(--on-surface); text-decoration: none; transition: all 0.12s;
    border-left: 2px solid transparent;
  }
  .docs-toc a:hover { color: var(--navy); background: rgba(28,43,74,0.03); }
  .docs-toc a.active {
    color: var(--gold); font-weight: 500;
    border-left-color: var(--gold); background: rgba(201,168,72,0.05);
  }

  /* ── Doc content ── */
  .docs-body {
    flex: 1; padding: 32px 40px; max-width: 820px; overflow-x: hidden;
  }
  .docs-body h1 {
    font-family: var(--font-heading); font-size: 1.8rem; font-weight: 400;
    color: var(--on-surface); margin-bottom: 8px; padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .docs-body h2 {
    font-family: var(--font-heading); font-size: 1.25rem; font-weight: 400;
    color: var(--navy); margin: 28px 0 12px;
    padding-bottom: 6px; border-bottom: 1px solid rgba(230,225,214,0.6);
  }
  .docs-body h3 {
    font-size: 0.95rem; font-weight: 600; color: var(--on-surface);
    margin: 22px 0 8px; letter-spacing: 0.02em;
  }
  .docs-body h4 {
    font-size: 0.85rem; font-weight: 600; color: var(--slate);
    margin: 16px 0 6px; text-transform: uppercase; letter-spacing: 0.08em;
  }
  .docs-body p {
    font-size: 0.88rem; line-height: 1.7; color: var(--on-surface);
    margin-bottom: 12px; font-weight: 300;
  }
  .docs-body ul, .docs-body ol {
    margin: 8px 0 16px 20px; font-size: 0.86rem; line-height: 1.8; font-weight: 300;
  }
  .docs-body li { margin-bottom: 4px; }
  .docs-body strong { font-weight: 600; color: var(--on-surface); }
  .docs-body em { font-style: italic; color: var(--slate); }
  .docs-body code {
    background: var(--ivory); padding: 2px 7px; border-radius: 3px;
    font-size: 0.8rem; font-family: 'SF Mono', 'Consolas', monospace; color: var(--navy);
  }
  .docs-body pre {
    background: var(--navy-deep); color: #e2e8f0; padding: 16px 20px;
    border-radius: 4px; overflow-x: auto; margin: 12px 0 20px;
    font-size: 0.8rem; line-height: 1.6;
  }
  .docs-body pre code {
    background: none; padding: 0; color: inherit; font-size: inherit;
  }
  .docs-body table {
    width: 100%; border-collapse: collapse; margin: 12px 0 20px;
    font-size: 0.82rem;
  }
  .docs-body thead th {
    background: var(--ivory); font-size: 0.68rem; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--slate);
    padding: 10px 14px; text-align: left; border-bottom: 1px solid var(--border);
  }
  .docs-body tbody td {
    padding: 10px 14px; border-bottom: 1px solid var(--ivory);
    color: var(--on-surface); font-weight: 300; vertical-align: top;
  }
  .docs-body tbody tr:hover { background: rgba(245,243,239,0.5); }
  .docs-body a { color: var(--gold); font-weight: 500; text-decoration: none; }
  .docs-body a:hover { text-decoration: underline; }
  .docs-body hr {
    border: none; border-top: 1px solid var(--border); margin: 24px 0;
  }

  /* ── Search ── */
  .docs-search {
    padding: 12px 20px 8px;
  }
  .docs-search input {
    width: 100%; padding: 8px 12px; border: 1px solid var(--border);
    border-radius: 3px; font-family: var(--font-body); font-size: 0.78rem;
    color: var(--on-surface); background: var(--ivory); outline: none;
  }
  .docs-search input:focus { border-color: var(--gold); }
  .docs-search input::placeholder { color: var(--slate); }

  /* ── Welcome state ── */
  .docs-welcome {
    text-align: center; padding: 60px 20px; color: var(--slate);
  }
  .docs-welcome-icon { font-size: 3rem; margin-bottom: 16px; opacity: 0.3; }
  .docs-welcome h2 {
    font-family: var(--font-heading); font-size: 1.5rem; font-weight: 400;
    color: var(--on-surface); margin-bottom: 8px; border: none; padding: 0;
  }
  .docs-welcome p { font-size: 0.88rem; font-weight: 300; max-width: 400px; margin: 0 auto; }

  /* ── Mobile ── */
  @media (max-width: 820px) {
    .docs-layout { flex-direction: column; }
    .docs-toc {
      width: 100%; max-height: none; position: relative; top: 0;
      border-right: none; border-bottom: 1px solid var(--border);
      padding: 12px 0;
    }
    .docs-toc.collapsed .docs-toc-section,
    .docs-toc.collapsed a { display: none; }
    .docs-toc.collapsed .docs-toc-toggle { display: block; }
    .docs-body { padding: 20px 16px; }
  }
</style>

<div class="topbar">
  <div class="topbar-title">Documentation</div>
</div>

<div class="content" style="padding:0;">
  <div class="docs-layout">

    <!-- Table of Contents -->
    <div class="docs-toc" id="docsToc">
      <div class="docs-search">
        <input type="text" id="docsSearch" placeholder="Search docs..." autocomplete="off">
      </div>
      <% for (const cat of categories) { %>
        <div class="docs-toc-section"><%= cat.label %></div>
        <% for (const f of cat.files) {
          const slug = f.replace(/\//g, '--');
          const doc = docs[slug];
          if (!doc) continue;
        %>
          <a href="#" class="doc-nav" data-slug="<%= slug %>"><%= doc.title %></a>
        <% } %>
      <% } %>
    </div>

    <!-- Doc content area -->
    <div class="docs-body" id="docsBody">
      <div class="docs-welcome">
        <div class="docs-welcome-icon">&#9776;</div>
        <h2>Platform Documentation</h2>
        <p>Select a topic from the sidebar to get started. These guides cover every feature of your admin panel.</p>
      </div>
    </div>

  </div>
</div>

<script>
(function() {
  const body   = document.getElementById('docsBody');
  const links  = document.querySelectorAll('.doc-nav');
  const search = document.getElementById('docsSearch');

  // Pre-loaded docs from server
  const preloaded = <%- JSON.stringify(
    Object.fromEntries(
      Object.entries(docs).map(([slug, d]) => [slug, { title: d.title, html: d.html }])
    )
  ) %>;

  let activeSlug = null;

  function show(slug) {
    const doc = preloaded[slug];
    if (!doc) return;
    body.innerHTML = doc.html;
    activeSlug = slug;

    // Update active nav
    links.forEach(a => a.classList.toggle('active', a.dataset.slug === slug));

    // Wire up internal doc links
    body.querySelectorAll('.doc-link').forEach(a => {
      a.addEventListener('click', function(e) {
        e.preventDefault();
        show(this.dataset.slug);
      });
    });

    // Scroll body to top
    body.scrollTop = 0;
    window.scrollTo(0, 0);

    // Update URL hash
    history.replaceState(null, '', '/admin/docs#' + slug);
  }

  // Nav clicks
  links.forEach(a => {
    a.addEventListener('click', function(e) {
      e.preventDefault();
      show(this.dataset.slug);

      // On mobile, collapse TOC after selection
      if (window.innerWidth <= 820) {
        document.getElementById('docsToc').classList.add('collapsed');
      }
    });
  });

  // Search filter
  search.addEventListener('input', function() {
    const q = this.value.toLowerCase().trim();
    links.forEach(a => {
      const title = a.textContent.toLowerCase();
      const doc = preloaded[a.dataset.slug];
      // Search title + content
      const match = !q || title.includes(q) || (doc && doc.html.toLowerCase().includes(q));
      a.style.display = match ? '' : 'none';
    });
  });

  // Load from hash
  if (location.hash) {
    const slug = location.hash.slice(1);
    if (preloaded[slug]) show(slug);
  }

  // Auto-load first doc (overview) if no hash
  if (!activeSlug && links.length) {
    show(links[0].dataset.slug);
  }
})();
</script>

