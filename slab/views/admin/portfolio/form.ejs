<%- include('../partials/head', { title: item ? 'Edit Portfolio Item' : 'New Portfolio Item' }) %>
<%- include('../partials/sidebar', { page: 'portfolio', user: user }) %>

<div class="topbar">
  <div class="topbar-title"><%= item ? 'Edit Portfolio Item' : 'New Portfolio Item' %></div>
  <div class="topbar-actions">
    <a href="/admin/portfolio" class="btn btn-ghost btn-sm">← Back</a>
  </div>
</div>

<div class="content">
  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="<%= item ? `/admin/portfolio/${item._id}` : '/admin/portfolio' %>" enctype="multipart/form-data">
    <div class="card">
      <div class="card-title">Project Details</div>
      <div class="form-grid">
        <div class="form-field">
          <label>Title *</label>
          <input type="text" name="title" value="<%= item?.title || '' %>" placeholder="Project name" required>
        </div>
        <div class="form-field">
          <label>Category</label>
          <input type="text" name="category" value="<%= item?.category || '' %>" placeholder="e.g. Web Design, Social Media">
        </div>
        <div class="form-field">
          <label>Client Name</label>
          <input type="text" name="clientName" value="<%= item?.clientName || '' %>" placeholder="Client or business name">
        </div>
        <div class="form-field">
          <label>Project Date</label>
          <input type="date" name="projectDate" value="<%= item?.projectDate ? item.projectDate.toString().slice(0,10) : '' %>">
        </div>
        <div class="form-field span-2">
          <label>Description</label>
          <textarea name="description" placeholder="Describe the project..."><%= item?.description || '' %></textarea>
        </div>
        <div class="form-field">
          <label>Group</label>
          <input type="text" name="group" value="<%= item?.group || '' %>" placeholder="e.g. web-design, photography">
          <span style="font-size:0.72rem;color:var(--slate);margin-top:4px;display:block;">Used to filter portfolio items on data-list pages.</span>
        </div>
        <div class="form-field">
          <label>Tags (comma separated)</label>
          <input type="text" name="tags" value="<%= item?.tags?.join(', ') || '' %>" placeholder="social, branding, logo">
        </div>
        <div class="form-field">
          <label>Display Order</label>
          <input type="number" name="order" value="<%= item?.order ?? 0 %>" min="0">
        </div>
      </div>
    </div>

    <div class="card mt-24">
      <div class="card-title">Image</div>
      <div class="form-grid">
        <div class="form-field">
          <label>Upload Image (Linode Bucket)</label>
          <input type="file" name="image" accept="image/*">
          <input type="hidden" name="removeImage" id="removeImage" value="0">
          <div id="portfolioImgWrap" style="margin-top:8px;<%= item?.imageUrl ? '' : 'display:none;' %>">
            <img id="portfolioImgPreview" src="<%= item?.imageUrl || '' %>" style="max-width:200px;max-height:140px;object-fit:cover;border-radius:2px;border:1px solid var(--border);display:block;">
            <button type="button" id="removeImageBtn" class="btn btn-ghost btn-sm" style="margin-top:6px;color:var(--danger,#a32a2a);">✕ Remove image</button>
          </div>
        </div>
        <div class="form-field">
          <label>Image URL</label>
          <input type="url" id="imageUrlManual" name="imageUrlManual" value="<%= item?.imageUrl || '' %>" placeholder="https://...">
          <span style="font-size:0.72rem;color:var(--slate);margin-top:4px;display:block;">Upload takes priority over URL if both provided.</span>
          <div style="margin-top:8px;">
            <button type="button" class="btn btn-ghost btn-sm asset-pick-btn"
                    data-target="imageUrlManual" data-folder="portfolio" data-type="image" data-preview="portfolioImgPreview">
              ◈ Pick from Assets
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="card mt-24">
      <div class="card-title">Gallery (Slideshow + Modal)</div>
      <div style="font-size:0.78rem;color:var(--slate);margin-bottom:12px;">
        Add multiple images for the modal slideshow. Cards on the public site show the first image as the thumbnail; clicking the card opens a modal with a slideshow of every image plus the project info.
      </div>
      <input type="hidden" name="gallery" id="galleryJson" value='<%- JSON.stringify((item?.gallery)||[]) %>'>
      <div id="galleryList" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;margin-bottom:12px;"></div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button type="button" class="btn btn-ghost btn-sm" id="galleryAddBtn">◈ Add Image from Assets</button>
        <button type="button" class="btn btn-ghost btn-sm" id="galleryAddUrlBtn">+ Add by URL</button>
      </div>
    </div>

    <div class="card mt-24">
      <div class="card-title">Display Options</div>
      <div class="form-grid">
        <div class="form-field">
          <label>Portfolio Layout</label>
          <select name="displayLayout" style="width:100%;padding:8px 10px;border:1.5px solid var(--border);border-radius:2px;font-family:'Jost',sans-serif;font-size:0.82rem;background:var(--ivory);color:var(--on-surface);">
            <option value="grid" <%= (item?.displayLayout||'grid')==='grid' ? 'selected' : '' %>>Grid (default)</option>
            <option value="masonry" <%= item?.displayLayout==='masonry' ? 'selected' : '' %>>Masonry</option>
            <option value="carousel" <%= item?.displayLayout==='carousel' ? 'selected' : '' %>>Carousel</option>
            <option value="text-left" <%= item?.displayLayout==='text-left' ? 'selected' : '' %>>Text Wrap — Image Left</option>
            <option value="text-right" <%= item?.displayLayout==='text-right' ? 'selected' : '' %>>Text Wrap — Image Right</option>
          </select>
          <span style="font-size:0.72rem;color:var(--slate);margin-top:4px;display:block;">Controls how this item is rendered in the portfolio section.</span>
        </div>
        <div class="form-field" style="display:flex;flex-direction:column;justify-content:flex-end;gap:12px;">
          <div class="form-check">
            <input type="checkbox" name="featured" id="featured" <%= item?.featured ? 'checked' : '' %>>
            <label for="featured">Feature this item on the public portfolio</label>
          </div>
          <div class="form-check">
            <input type="checkbox" name="showDate" id="showDate" <%= item?.showDate ? 'checked' : '' %>>
            <label for="showDate">Show project date on public portfolio</label>
          </div>
        </div>
      </div>
    </div>

    <div class="form-actions" style="margin-top:24px;display:flex;gap:12px;flex-wrap:wrap;">
      <button type="submit" class="btn btn-navy"><%= item ? 'Save Changes' : 'Create Item' %></button>
      <a href="/admin/portfolio" class="btn btn-ghost">Cancel</a>
    </div>
  </form>
</div>

<script src="/js/assetPicker.js"></script>
<script src="/js/tours/portfolio.js"></script>
<script>
(function() {
  'use strict';
  const itemId = <%- item?._id ? `'${item._id}'` : 'null' %>;
  const removeBtn = document.getElementById('removeImageBtn');
  const removeFlag = document.getElementById('removeImage');
  const imgWrap = document.getElementById('portfolioImgWrap');
  const imgPreview = document.getElementById('portfolioImgPreview');
  const urlInput = document.getElementById('imageUrlManual');
  if (removeBtn) {
    removeBtn.addEventListener('click', async () => {
      if (!confirm('Remove this image? This will delete the uploaded file from storage.')) return;
      if (itemId) {
        try {
          const res = await fetch(`/admin/portfolio/${itemId}/image/delete`, { method: 'POST' });
          const data = await res.json();
          if (!data.ok) { alert(data.error || 'Delete failed'); return; }
        } catch (e) { alert('Delete failed: ' + e.message); return; }
      }
      removeFlag.value = '1';
      imgWrap.style.display = 'none';
      imgPreview.removeAttribute('src');
      if (urlInput) urlInput.value = '';
    });
  }

  const hidden = document.getElementById('galleryJson');
  const listEl = document.getElementById('galleryList');
  const addBtn = document.getElementById('galleryAddBtn');
  const addUrlBtn = document.getElementById('galleryAddUrlBtn');
  let gallery = [];
  try { gallery = JSON.parse(hidden.value || '[]') || []; } catch { gallery = []; }

  function save() { hidden.value = JSON.stringify(gallery); }

  function render() {
    listEl.innerHTML = '';
    if (!gallery.length) {
      listEl.innerHTML = '<div style="grid-column:1/-1;padding:18px;text-align:center;color:var(--slate);font-size:0.78rem;border:1px dashed var(--border);background:var(--ivory);">No gallery images yet. Add one above.</div>';
      return;
    }
    gallery.forEach((g, i) => {
      const tile = document.createElement('div');
      tile.style.cssText = 'border:1px solid var(--border);background:var(--ivory);border-radius:2px;overflow:hidden;display:flex;flex-direction:column;';
      tile.innerHTML = `
        <div style="aspect-ratio:4/3;background:#f0eee8;overflow:hidden;display:flex;align-items:center;justify-content:center;">
          <img src="${g.url}" alt="" style="width:100%;height:100%;object-fit:cover;display:block;">
        </div>
        <input type="text" data-idx="${i}" class="gallery-cap" value="${(g.caption||'').replace(/"/g,'&quot;')}" placeholder="Caption (optional)" style="border:none;border-top:1px solid var(--border);padding:6px 8px;font-size:0.74rem;background:#fff;">
        <div style="display:flex;border-top:1px solid var(--border);">
          <button type="button" data-act="up" data-idx="${i}" class="btn btn-ghost btn-sm" style="flex:1;border-radius:0;border:none;${i===0?'opacity:0.3;pointer-events:none;':''}">←</button>
          <button type="button" data-act="down" data-idx="${i}" class="btn btn-ghost btn-sm" style="flex:1;border-radius:0;border:none;border-left:1px solid var(--border);${i===gallery.length-1?'opacity:0.3;pointer-events:none;':''}">→</button>
          <button type="button" data-act="del" data-idx="${i}" class="btn btn-ghost btn-sm" style="flex:1;border-radius:0;border:none;border-left:1px solid var(--border);color:var(--danger,#a32a2a);">✕</button>
        </div>`;
      listEl.appendChild(tile);
    });
  }

  listEl.addEventListener('click', async (e) => {
    const btn = e.target.closest('button[data-act]');
    if (!btn) return;
    const idx = +btn.dataset.idx;
    const act = btn.dataset.act;
    if (act === 'del') {
      const target = gallery[idx];
      if (!confirm('Remove this image from the gallery?')) return;
      if (itemId && target?.url) {
        try {
          const res = await fetch(`/admin/portfolio/${itemId}/gallery/delete`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ url: target.url })
          });
          const data = await res.json();
          if (!data.ok) { alert(data.error || 'Delete failed'); return; }
        } catch (e) { alert('Delete failed: ' + e.message); return; }
      }
      gallery.splice(idx, 1);
    }
    else if (act === 'up' && idx > 0) [gallery[idx-1], gallery[idx]] = [gallery[idx], gallery[idx-1]];
    else if (act === 'down' && idx < gallery.length - 1) [gallery[idx], gallery[idx+1]] = [gallery[idx+1], gallery[idx]];
    save(); render();
  });

  listEl.addEventListener('input', (e) => {
    if (!e.target.classList.contains('gallery-cap')) return;
    const idx = +e.target.dataset.idx;
    if (gallery[idx]) { gallery[idx].caption = e.target.value; save(); }
  });

  addBtn.addEventListener('click', () => {
    if (typeof window.openAssetPicker !== 'function') return;
    window.openAssetPicker({
      folder: 'portfolio', type: 'image',
      onSelect: (asset) => {
        if (asset && asset.publicUrl) {
          gallery.push({ url: asset.publicUrl, caption: asset.title || '' });
          save(); render();
        }
      }
    });
  });

  addUrlBtn.addEventListener('click', () => {
    const url = prompt('Image URL:');
    if (url && url.trim()) {
      gallery.push({ url: url.trim(), caption: '' });
      save(); render();
    }
  });

  render();
})();
</script>
</div></div>
</body>
</html>
