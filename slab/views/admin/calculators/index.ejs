<%- include('../partials/head', { title: 'Calculators' }) %>
<%- include('../partials/sidebar', { page: 'calculators', user }) %>

<div class="topbar">
  <div class="topbar-title">Calculators</div>
  <div class="topbar-actions">
    <a href="/admin/calculators/new" class="btn btn-gold">+ New Calculator</a>
  </div>
</div>

<style>
  .panel { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
  .calc-row { display: grid; grid-template-columns: 1fr auto auto; gap: 14px; align-items: center; padding: 14px 18px; border-bottom: 1px solid #f3f1ea; }
  .calc-row:last-child { border-bottom: none; }
  .calc-title { font-weight: 600; color: var(--ink); }
  .calc-meta  { font-size: 12px; color: var(--ink-muted); margin-top: 3px; }
  .calc-slug  { font-family: monospace; font-size: 12px; color: var(--ink-muted); background: var(--ivory-light); padding: 2px 8px; border-radius: 3px; }
  .calc-status { font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 10px; }
  .status-on  { background: #f0fdf4; color: #15803d; }
  .status-off { background: #fef2f2; color: #b91c1c; }
  .empty { padding: 48px; text-align: center; color: var(--ink-muted); }
  .saved-banner { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 5px; padding: 10px 16px; color: #15803d; font-size: 13px; margin-bottom: 16px; }
  .deleted-banner { background: #fef9e7; border: 1px solid #fde68a; border-radius: 5px; padding: 10px 16px; color: #92400e; font-size: 13px; margin-bottom: 16px; }
  .btn-edit { font-size: 12px; padding: 5px 12px; background: var(--ivory-light); border: 1px solid var(--border); border-radius: 4px; color: var(--ink); text-decoration: none; }
  .btn-edit:hover { border-color: var(--gold); color: var(--gold); }
  .embed-snippet { font-family: monospace; font-size: 11px; color: var(--ink-muted); background: var(--ivory-light); padding: 4px 8px; border-radius: 3px; cursor: pointer; }
</style>

<div class="content">
  <% if (typeof saved !== 'undefined' && saved) { %>
  <div class="saved-banner">✓ Saved.</div>
  <% } %>
  <% if (typeof deleted !== 'undefined' && deleted) { %>
  <div class="deleted-banner">Calculator deleted.</div>
  <% } %>

  <div class="panel">
    <% if (!calcs.length) { %>
    <div class="empty">
      <p>No calculators yet.</p>
      <p style="margin-top:12px"><a href="/admin/calculators/new" style="color:var(--gold);text-decoration:none">+ Create your first calculator</a></p>
    </div>
    <% } else { %>
    <% calcs.forEach(c => { %>
    <div class="calc-row">
      <div>
        <div class="calc-title"><%= c.title %></div>
        <div class="calc-meta">
          <span class="calc-slug"><%= c.slug %></span>
          <span style="margin-left:8px">
            <%= (c.baseFields||[]).length %> base · <%= (c.multiplierFields||[]).length %> multiplier · <%= (c.addOns||[]).length %> add-ons
          </span>
          <% if (c.description) { %><span style="margin-left:8px">— <%= c.description.slice(0, 80) %><%= c.description.length > 80 ? '…' : '' %></span><% } %>
        </div>
        <div class="calc-meta" style="margin-top:6px">
          Embed: <code class="embed-snippet" onclick="navigator.clipboard.writeText(this.textContent);this.textContent='copied';setTimeout(()=>this.textContent='&lt;slab-calculator data-slug=\&quot;<%= c.slug %>\&quot;&gt;&lt;/slab-calculator&gt;',1500)">&lt;slab-calculator data-slug="<%= c.slug %>"&gt;&lt;/slab-calculator&gt;</code>
        </div>
      </div>
      <span class="calc-status <%= c.enabled ? 'status-on' : 'status-off' %>"><%= c.enabled ? 'ON' : 'OFF' %></span>
      <a href="/admin/calculators/<%= c._id %>" class="btn-edit">Edit</a>
    </div>
    <% }) %>
    <% } %>
  </div>
</div>

</div><!-- .main -->
</div><!-- .layout -->
</body>
</html>
