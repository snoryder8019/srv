<%- include('../partials/head', { title: 'Email Marketing' }) %>
<%- include('../partials/sidebar', { page: 'email-marketing', user: user }) %>

<style>
  .agent-btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 8px 16px; border-radius: 2px;
    background: linear-gradient(135deg, #1C2B4A, #2E4270);
    color: #E8D08A; border: 1px solid rgba(201,168,72,0.3);
    font-family: 'Jost', sans-serif; font-size: 0.72rem;
    font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
    cursor: pointer; transition: all 0.2s;
  }
  .agent-btn:hover { border-color: rgba(201,168,72,0.65); }

  #agentPanel {
    position: fixed; top: 0; right: -440px; width: 420px;
    height: 100vh; height: 100dvh;
    background: var(--white); border-left: 1px solid var(--ivory-mid);
    box-shadow: -8px 0 40px rgba(15,27,48,0.12);
    z-index: 500; display: flex; flex-direction: column;
    transition: right 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  #agentPanel.open { right: 0; }

  .ap-header {
    padding: 18px 20px; border-bottom: 1px solid var(--ivory-mid);
    background: linear-gradient(135deg, var(--navy-deep), var(--navy));
    display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
  }
  .ap-title {
    font-family: 'Cormorant Garamond', serif; font-size: 1.2rem;
    font-weight: 400; color: var(--white); display: flex; align-items: center; gap: 10px;
  }
  .ap-dot { width: 8px; height: 8px; border-radius: 50%; background: #4ADE80; animation: apPulse 2s infinite; }
  @keyframes apPulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
  .ap-close { background: none; border: none; color: rgba(255,255,255,0.5); font-size: 1.3rem; cursor: pointer; padding: 4px; transition: color 0.15s; }
  .ap-close:hover { color: var(--white); }

  .ap-sub {
    padding: 8px 20px; background: rgba(201,168,72,0.07);
    border-bottom: 1px solid rgba(201,168,72,0.15); flex-shrink: 0;
    font-size: 0.7rem; color: #92660F; letter-spacing: 0.04em;
    display: flex; align-items: center; gap: 6px;
  }
  .ap-sub-dot { width: 5px; height: 5px; border-radius: 50%; background: #4ADE80; }

  .ap-msgs { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; padding: 16px 20px; display: flex; flex-direction: column; gap: 12px; }

  .ap-msg { display: flex; flex-direction: column; gap: 4px; }
  .ap-msg.user { align-items: flex-end; }
  .ap-msg.assistant { align-items: flex-start; }
  .ap-bubble {
    max-width: 88%; padding: 10px 14px; border-radius: 4px;
    font-size: 0.84rem; line-height: 1.5; font-weight: 300;
  }
  .ap-msg.user .ap-bubble { background: var(--navy); color: var(--white); border-radius: 4px 4px 1px 4px; }
  .ap-msg.assistant .ap-bubble { background: var(--ivory); color: var(--dark); border: 1px solid var(--ivory-mid); border-radius: 4px 4px 4px 1px; }
  .ap-fill-notice { font-size: 0.68rem; color: var(--success,#15803D); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; }

  .ap-footer {
    padding: 14px 20px;
    padding-bottom: max(14px, env(safe-area-inset-bottom, 14px));
    border-top: 1px solid var(--ivory-mid); flex-shrink: 0;
  }
  .ap-quick {
    display: flex; gap: 6px; margin-bottom: 10px;
    overflow-x: auto; -webkit-overflow-scrolling: touch;
    scrollbar-width: none; flex-wrap: nowrap; padding-bottom: 2px;
  }
  .ap-quick::-webkit-scrollbar { display: none; }
  .ap-quick-btn {
    font-size: 0.67rem; padding: 5px 10px; border-radius: 2px;
    border: 1px solid var(--ivory-mid); background: var(--white);
    color: var(--slate); cursor: pointer; font-family: 'Jost', sans-serif;
    font-weight: 500; letter-spacing: 0.04em; transition: all 0.15s; white-space: nowrap;
    flex-shrink: 0;
  }
  .ap-quick-btn:hover { border-color: var(--navy-mid); color: var(--navy); }
  .ap-input-row { display: flex; gap: 8px; }
  .ap-input {
    flex: 1; padding: 10px 14px; border: 1px solid var(--ivory-mid);
    border-radius: 2px; font-family: 'Jost', sans-serif; font-size: 0.88rem;
    font-weight: 300; color: var(--dark); outline: none; resize: none;
    transition: border-color 0.15s; min-height: 42px; max-height: 120px;
  }
  .ap-input:focus { border-color: var(--navy); }
  .ap-send {
    padding: 10px 16px; background: var(--navy); color: var(--white);
    border: none; border-radius: 2px; cursor: pointer; font-size: 0.9rem;
    transition: background 0.15s; flex-shrink: 0; align-self: flex-end;
  }
  .ap-send:hover { background: var(--navy-deep); }
  .ap-send:disabled { opacity: 0.4; cursor: not-allowed; }

  .ap-typing { display: flex; gap: 4px; padding: 10px 14px; background: var(--ivory); border: 1px solid var(--ivory-mid); border-radius: 4px 4px 4px 1px; align-self: flex-start; }
  .ap-typing-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--slate); animation: apBounce 1.2s infinite; }
  .ap-typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .ap-typing-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes apBounce { 0%,60%,100%{transform:translateY(0);opacity:0.4;} 30%{transform:translateY(-5px);opacity:1;} }

  #agentOverlay { display: none; position: fixed; inset: 0; background: rgba(15,27,48,0.15); z-index: 499; }
  #agentOverlay.active { display: block; }

  .ai-filled { background: rgba(21,128,61,0.07) !important; border-color: rgba(21,128,61,0.45) !important; transition: background 0.4s, border-color 0.4s; }
</style>

<div class="topbar">
  <div class="topbar-title">Email Marketing</div>
  <% if (tab === 'campaigns') { %>
  <div class="topbar-actions">
    <button class="agent-btn" id="agentToggle"><span style="font-size:1rem;">✦</span> Marketing Agent</button>
  </div>
  <% } %>
</div>

<div class="content">
  <%- include('../partials/advisory', { needs: 'zoho' }) %>
  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:14px;margin-bottom:24px;">
    <div class="card" style="text-align:center;padding:18px;">
      <div style="font-size:0.6rem;text-transform:uppercase;letter-spacing:.12em;color:var(--slate);margin-bottom:4px;">Contacts</div>
      <div style="font-family:'Cormorant Garamond',serif;font-size:1.6rem;color:var(--navy);"><%= stats.totalContacts %></div>
      <div style="font-size:0.7rem;color:var(--success);"><%= stats.subscribedContacts %> subscribed</div>
    </div>
    <div class="card" style="text-align:center;padding:18px;">
      <div style="font-size:0.6rem;text-transform:uppercase;letter-spacing:.12em;color:var(--slate);margin-bottom:4px;">Campaigns</div>
      <div style="font-family:'Cormorant Garamond',serif;font-size:1.6rem;color:var(--navy);"><%= stats.totalCampaigns %></div>
      <div style="font-size:0.7rem;color:var(--slate);"><%= stats.sentCampaigns %> sent</div>
    </div>
    <div class="card" style="text-align:center;padding:18px;">
      <div style="font-size:0.6rem;text-transform:uppercase;letter-spacing:.12em;color:var(--slate);margin-bottom:4px;">Funnel</div>
      <div style="display:flex;gap:6px;justify-content:center;margin-top:6px;flex-wrap:wrap;">
        <span style="font-size:0.65rem;padding:2px 6px;border-radius:2px;background:rgba(201,168,72,0.12);color:#92660F;" title="Leads"><%= funnelCounts.lead %> leads</span>
        <span style="font-size:0.65rem;padding:2px 6px;border-radius:2px;background:rgba(28,43,74,0.08);color:var(--navy);" title="Prospects"><%= funnelCounts.prospect %> prospects</span>
        <span style="font-size:0.65rem;padding:2px 6px;border-radius:2px;background:rgba(21,128,61,0.1);color:var(--success);" title="Customers"><%= funnelCounts.customer %> customers</span>
      </div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="tabs" style="margin-bottom:20px;">
    <a href="?tab=contacts" class="tab-link <%= tab === 'contacts' ? 'active' : '' %>">Contacts (<%= contacts.length %>)</a>
    <a href="?tab=campaigns" class="tab-link <%= tab === 'campaigns' ? 'active' : '' %>">Campaigns (<%= campaigns.length %>)</a>
  </div>

  <!-- Flash messages -->
  <% if (qs.success) { %>
  <div style="background:rgba(21,128,61,0.08);border:1px solid rgba(21,128,61,0.2);border-radius:3px;padding:10px 16px;margin-bottom:16px;font-size:0.82rem;color:var(--success);"><%= qs.success %></div>
  <% } %>
  <% if (qs.error) { %>
  <div style="background:rgba(185,28,28,0.08);border:1px solid rgba(185,28,28,0.2);border-radius:3px;padding:10px 16px;margin-bottom:16px;font-size:0.82rem;color:var(--danger);"><%= qs.error %></div>
  <% } %>

  <!-- ═══════════ CONTACTS TAB ═══════════ -->
  <% if (tab === 'contacts') { %>

    <!-- Actions row -->
    <div class="card" style="margin-bottom:16px;padding:16px 20px;">
      <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
        <button class="btn btn-navy btn-sm" onclick="document.getElementById('addContactCard').style.display=document.getElementById('addContactCard').style.display==='none'?'block':'none'">+ Add Contact</button>
        <button class="btn btn-ghost btn-sm" onclick="document.getElementById('csvUploadCard').style.display=document.getElementById('csvUploadCard').style.display==='none'?'block':'none'">Upload CSV</button>
        <form method="POST" action="/admin/email-marketing/contacts/import-clients" style="display:inline;" onsubmit="return confirm('Import all clients with emails as contacts?')">
          <button class="btn btn-ghost btn-sm">Import Clients</button>
        </form>
        <div style="margin-left:auto;font-size:0.75rem;color:var(--slate);">
          <%= contacts.filter(c=>c.status==='subscribed').length %> / <%= contacts.length %> subscribed
        </div>
      </div>
    </div>

    <!-- Add contact form (hidden by default) -->
    <div id="addContactCard" class="card" style="margin-bottom:16px;display:none;">
      <div class="card-title">Add Contact</div>
      <form method="POST" action="/admin/email-marketing/contacts">
        <div class="form-grid" style="grid-template-columns:1fr 1fr 1fr 1fr;">
          <div class="form-field">
            <label>Email *</label>
            <input type="email" name="email" required placeholder="name@example.com">
          </div>
          <div class="form-field">
            <label>Name</label>
            <input type="text" name="name" placeholder="Full name">
          </div>
          <div class="form-field">
            <label>Funnel Stage</label>
            <select name="funnel">
              <option value="lead">Lead</option>
              <option value="prospect">Prospect</option>
              <option value="customer">Customer</option>
            </select>
          </div>
          <div class="form-field">
            <label>Tags</label>
            <input type="text" name="tags" placeholder="newsletter, promo (comma sep)">
          </div>
        </div>
        <div style="margin-top:12px;"><button type="submit" class="btn btn-navy btn-sm">Add Contact</button></div>
      </form>
    </div>

    <!-- CSV upload form (hidden by default) -->
    <div id="csvUploadCard" class="card" style="margin-bottom:16px;display:none;">
      <div class="card-title">Upload CSV</div>
      <p style="font-size:0.78rem;color:var(--slate);margin-bottom:12px;">CSV must have an <strong>email</strong> column. Optional columns: <strong>name</strong>, <strong>tags</strong> (semicolon-separated within cell).</p>
      <form method="POST" action="/admin/email-marketing/contacts/upload" enctype="multipart/form-data">
        <div class="form-grid" style="grid-template-columns:1fr 1fr 1fr;">
          <div class="form-field">
            <label>CSV File *</label>
            <input type="file" name="csv" accept=".csv" required>
          </div>
          <div class="form-field">
            <label>Assign Funnel Stage</label>
            <select name="funnel">
              <option value="lead" selected>Lead</option>
              <option value="prospect">Prospect</option>
              <option value="customer">Customer</option>
            </select>
          </div>
          <div class="form-field">
            <label>Source Label</label>
            <input type="text" name="source" placeholder="e.g. tradeshow-2026" value="csv-upload">
          </div>
        </div>
        <div style="margin-top:12px;"><button type="submit" class="btn btn-navy btn-sm">Upload & Import</button></div>
      </form>
    </div>

    <!-- Contacts table -->
    <% if (!contacts.length) { %>
      <div class="empty"><div class="empty-icon">@</div><p>No contacts yet. Add one, upload a CSV, or import your clients.</p></div>
    <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Email</th>
            <th>Name</th>
            <th>Funnel</th>
            <th>Status</th>
            <th>Source</th>
            <th>Tags</th>
            <th>Added</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% for (const ct of contacts) { %>
          <tr>
            <td style="font-size:0.82rem;font-weight:500;color:var(--navy);"><%= ct.email %></td>
            <td style="font-size:0.82rem;"><%= ct.name || '---' %></td>
            <td>
              <form method="POST" action="/admin/email-marketing/contacts/<%= ct._id %>/update" style="display:inline;">
                <%
                  const funnelColors = { lead:'background:rgba(201,168,72,0.12);color:#92660F;', prospect:'background:rgba(28,43,74,0.08);color:var(--navy);', customer:'background:rgba(21,128,61,0.1);color:var(--success);', churned:'background:rgba(185,28,28,0.08);color:var(--danger);' };
                %>
                <select name="funnel" onchange="this.form.submit()" style="padding:2px 6px;font-size:0.7rem;border:1px solid var(--ivory-mid);border-radius:2px;font-family:'Jost',sans-serif;cursor:pointer;">
                  <option value="lead" <%= ct.funnel === 'lead' ? 'selected' : '' %>>Lead</option>
                  <option value="prospect" <%= ct.funnel === 'prospect' ? 'selected' : '' %>>Prospect</option>
                  <option value="customer" <%= ct.funnel === 'customer' ? 'selected' : '' %>>Customer</option>
                  <option value="churned" <%= ct.funnel === 'churned' ? 'selected' : '' %>>Churned</option>
                </select>
              </form>
            </td>
            <td>
              <form method="POST" action="/admin/email-marketing/contacts/<%= ct._id %>/update" style="display:inline;">
                <select name="status" onchange="this.form.submit()" style="padding:2px 6px;font-size:0.7rem;border:1px solid var(--ivory-mid);border-radius:2px;font-family:'Jost',sans-serif;cursor:pointer;">
                  <option value="subscribed" <%= ct.status === 'subscribed' ? 'selected' : '' %>>Subscribed</option>
                  <option value="unsubscribed" <%= ct.status === 'unsubscribed' ? 'selected' : '' %>>Unsubscribed</option>
                  <option value="bounced" <%= ct.status === 'bounced' ? 'selected' : '' %>>Bounced</option>
                </select>
              </form>
            </td>
            <td style="font-size:0.72rem;color:var(--slate);"><%= ct.source || '---' %></td>
            <td style="font-size:0.72rem;">
              <% if (ct.tags?.length) { %>
                <% for (const t of ct.tags) { %>
                <span style="display:inline-block;padding:1px 5px;border-radius:2px;font-size:0.6rem;font-weight:600;letter-spacing:.04em;background:rgba(28,43,74,0.06);color:var(--slate);margin:1px 2px;"><%= t %></span>
                <% } %>
              <% } else { %>---<% } %>
            </td>
            <td style="font-size:0.72rem;color:var(--slate);"><%= new Date(ct.createdAt).toLocaleDateString('en-US', {month:'short', day:'numeric'}) %></td>
            <td>
              <form method="POST" action="/admin/email-marketing/contacts/<%= ct._id %>/delete" onsubmit="return confirm('Remove this contact?')" style="display:inline;">
                <button class="btn btn-danger btn-sm" style="font-size:0.65rem;">Del</button>
              </form>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>

  <% } %>

  <!-- ═══════════ CAMPAIGNS TAB ═══════════ -->
  <% if (tab === 'campaigns') { %>

    <!-- New campaign form -->
    <div class="card" style="margin-bottom:20px;">
      <div class="card-title">New Campaign</div>
      <form method="POST" action="/admin/email-marketing/campaigns">
        <div class="form-grid">
          <div class="form-field">
            <label>Subject Line *</label>
            <input type="text" name="subject" id="campSubject" required placeholder="e.g. Spring Marketing Deals">
          </div>
          <div class="form-field">
            <label>Preheader <span style="font-weight:400;color:var(--slate);font-size:0.75rem;">(preview text)</span></label>
            <input type="text" name="preheader" id="campPreheader" placeholder="Short preview shown in inbox">
          </div>
        </div>
        <div class="form-grid" style="margin-top:12px;">
          <div class="form-field">
            <label>Target Funnel Stage</label>
            <select name="targetFunnel" id="campTargetFunnel">
              <option value="all">All Subscribed</option>
              <option value="lead">Leads Only</option>
              <option value="prospect">Prospects Only</option>
              <option value="customer">Customers Only</option>
            </select>
          </div>
          <div class="form-field">
            <label>Target Tags <span style="font-weight:400;color:var(--slate);font-size:0.75rem;">(comma sep, optional)</span></label>
            <input type="text" name="targetTags" placeholder="e.g. newsletter, promo">
          </div>
        </div>
        <div class="form-field" style="margin-top:12px;">
          <label>Email Body * <span style="font-weight:400;color:var(--slate);font-size:0.75rem;">(HTML supported &mdash; use {name} to personalize)</span></label>
          <!-- Toolbar -->
          <div style="display:flex;gap:6px;margin-bottom:6px;flex-wrap:wrap;align-items:center;">
            <button type="button" class="btn btn-ghost btn-sm" style="font-size:0.68rem;" onclick="openImagePicker()">Insert Image</button>
            <button type="button" class="btn btn-ghost btn-sm" style="font-size:0.68rem;" onclick="insertAtCursor(campBody, '&lt;h2&gt;Heading&lt;/h2&gt;')">H2</button>
            <button type="button" class="btn btn-ghost btn-sm" style="font-size:0.68rem;" onclick="insertAtCursor(campBody, '&lt;strong&gt;&lt;/strong&gt;')">Bold</button>
            <button type="button" class="btn btn-ghost btn-sm" style="font-size:0.68rem;" onclick="insertAtCursor(campBody, '&lt;a href=&quot;<%= brand?.domain ? 'https://' + (typeof tenant !== 'undefined' ? tenant.domain : '' ) : '#' %>&quot; style=&quot;display:inline-block;padding:12px 28px;background:#C9A848;color:#1C2B4A;text-decoration:none;font-weight:600;border-radius:3px;&quot;&gt;Button Text&lt;/a&gt;')">CTA Button</button>
            <button type="button" class="btn btn-ghost btn-sm" style="font-size:0.68rem;" onclick="insertAtCursor(campBody, '&lt;hr style=&quot;border:none;border-top:1px solid #E6E1D6;margin:20px 0;&quot;&gt;')">Divider</button>
            <span style="font-size:0.65rem;color:var(--slate);margin-left:auto;">Vars: {name}, {email}</span>
          </div>
          <textarea name="body" id="campBody" rows="12" required placeholder="Write your email content here. HTML tags are supported.&#10;&#10;Use the toolbar above to insert images from your brand library." style="font-family:'Jost',sans-serif;font-size:0.85rem;line-height:1.6;"></textarea>
        </div>
        <div style="margin-top:16px;display:flex;gap:8px;">
          <button type="submit" class="btn btn-navy btn-sm">Save as Draft</button>
        </div>
      </form>
    </div>

    <!-- Campaigns list -->
    <% if (!campaigns.length) { %>
      <div class="empty"><div class="empty-icon">@</div><p>No campaigns yet. Create one above.</p></div>
    <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Subject</th>
            <th>Target</th>
            <th>Status</th>
            <th>Sent</th>
            <th>Opens</th>
            <th>Clicks</th>
            <th>Date</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% for (const camp of campaigns) { %>
          <tr>
            <td style="font-weight:500;max-width:250px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              <a href="/admin/email-marketing/campaigns/<%= camp._id %>" style="color:var(--navy);text-decoration:none;"><%= camp.subject %></a>
              <% if (camp.parentSegment) { %>
              <div style="font-size:0.6rem;color:var(--warn);margin-top:2px;">follow-up: <%= camp.parentSegment %></div>
              <% } %>
            </td>
            <td style="font-size:0.78rem;color:var(--slate);">
              <%= camp.targetFunnel === 'all' ? 'All' : camp.targetFunnel %>
              <% if (camp.targetTags?.length) { %>
                <% for (const t of camp.targetTags) { %>
                <span style="display:inline-block;padding:1px 4px;border-radius:2px;font-size:0.6rem;background:rgba(28,43,74,0.06);color:var(--slate);margin-left:2px;"><%= t %></span>
                <% } %>
              <% } %>
            </td>
            <td>
              <%
                const campStatusColors = { draft:'var(--slate)', sent:'var(--success)', sending:'var(--warn)' };
                const csc = campStatusColors[camp.status] || 'var(--slate)';
              %>
              <span style="display:inline-block;padding:2px 8px;border-radius:2px;font-size:0.68rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;background:color-mix(in srgb, <%= csc %> 10%, transparent);color:<%= csc %>;"><%= camp.status %></span>
            </td>
            <td style="font-size:0.82rem;">
              <% if (camp.status === 'sent') { %>
                <%= camp.sentCount %><% if (camp.failedCount) { %> <span style="color:var(--danger);font-size:0.72rem;">(<%= camp.failedCount %> failed)</span><% } %>
              <% } else { %>
                ---
              <% } %>
            </td>
            <%
              const ca = analyticsMap[camp._id.toString()] || {};
              const opens = ca.open || { total: 0, unique: 0 };
              const clicks = ca.click || { total: 0, unique: 0 };
              const openRate = camp.sentCount ? Math.round(opens.unique / camp.sentCount * 100) : 0;
              const clickRate = camp.sentCount ? Math.round(clicks.unique / camp.sentCount * 100) : 0;
            %>
            <td style="font-size:0.78rem;">
              <% if (camp.status === 'sent') { %>
                <strong><%= opens.unique %></strong>
                <span style="color:var(--slate);font-size:0.65rem;">(<%= openRate %>%)</span>
                <% if (opens.total > opens.unique) { %>
                <div style="font-size:0.6rem;color:var(--slate);"><%= opens.total %> total</div>
                <% } %>
              <% } else { %>---<% } %>
            </td>
            <td style="font-size:0.78rem;">
              <% if (camp.status === 'sent') { %>
                <strong><%= clicks.unique %></strong>
                <span style="color:var(--slate);font-size:0.65rem;">(<%= clickRate %>%)</span>
                <% if (clicks.total > clicks.unique) { %>
                <div style="font-size:0.6rem;color:var(--slate);"><%= clicks.total %> total</div>
                <% } %>
              <% } else { %>---<% } %>
            </td>
            <td style="font-size:0.78rem;color:var(--slate);">
              <%= camp.sentAt ? new Date(camp.sentAt).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) : new Date(camp.createdAt).toLocaleDateString('en-US', {month:'short', day:'numeric'}) %>
            </td>
            <td style="white-space:nowrap;">
              <div style="display:flex;gap:4px;align-items:center;">
                <% if (camp.status === 'draft') { %>
                <form method="POST" action="/admin/email-marketing/campaigns/<%= camp._id %>/send" style="display:inline;" onsubmit="return confirm('Send this campaign to all matching contacts? This cannot be undone.')">
                  <button class="btn btn-gold btn-sm" style="font-size:0.68rem;">Send</button>
                </form>
                <% } %>
                <form method="POST" action="/admin/email-marketing/campaigns/<%= camp._id %>/delete" onsubmit="return confirm('Delete this campaign?')" style="display:inline;">
                  <button class="btn btn-danger btn-sm" style="font-size:0.68rem;">Del</button>
                </form>
              </div>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>

  <% } %>
</div>

<!-- Image Picker Modal -->
<div id="imgPickerModal" style="display:none;position:fixed;inset:0;background:rgba(15,27,48,0.5);z-index:500;align-items:center;justify-content:center;">
  <div style="background:var(--white);border-radius:6px;padding:28px;max-width:640px;width:90%;max-height:80vh;overflow-y:auto;box-shadow:0 8px 32px rgba(0,0,0,0.15);">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
      <div style="font-family:'Cormorant Garamond',serif;font-size:1.3rem;">Insert Image</div>
      <button type="button" onclick="closeImgPicker()" style="background:none;border:none;font-size:1.3rem;cursor:pointer;color:var(--slate);">&times;</button>
    </div>
    <div id="imgPickerGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:10px;">
      <div style="text-align:center;color:var(--slate);font-size:0.82rem;grid-column:1/-1;padding:20px;">Loading images...</div>
    </div>
    <div style="margin-top:16px;border-top:1px solid var(--ivory-mid);padding-top:12px;">
      <div style="font-size:0.72rem;color:var(--slate);margin-bottom:6px;">Or paste an external image URL:</div>
      <div style="display:flex;gap:6px;">
        <input type="url" id="extImgUrl" placeholder="https://..." style="flex:1;padding:6px 10px;border:1px solid var(--ivory-mid);border-radius:2px;font-family:'Jost',sans-serif;font-size:0.82rem;">
        <button type="button" class="btn btn-navy btn-sm" style="font-size:0.68rem;" onclick="insertExtImage()">Insert</button>
      </div>
    </div>
  </div>
</div>

<script>
const campBody = document.getElementById('campBody');

function insertAtCursor(textarea, text) {
  if (!textarea) return;
  const start = textarea.selectionStart;
  const end = textarea.selectionEnd;
  textarea.value = textarea.value.substring(0, start) + text + textarea.value.substring(end);
  textarea.selectionStart = textarea.selectionEnd = start + text.length;
  textarea.focus();
}

function openImagePicker() {
  const modal = document.getElementById('imgPickerModal');
  modal.style.display = 'flex';
  const grid = document.getElementById('imgPickerGrid');
  grid.innerHTML = '<div style="text-align:center;color:var(--slate);font-size:0.82rem;grid-column:1/-1;padding:20px;">Loading...</div>';

  fetch('/admin/design/images/api')
    .then(r => r.json())
    .then(data => {
      if (!data.images?.length) {
        grid.innerHTML = '<div style="text-align:center;color:var(--slate);font-size:0.82rem;grid-column:1/-1;padding:20px;">No brand images uploaded yet.<br><a href="/admin/design#brand-images" style="color:var(--navy);">Upload in Design & Settings</a></div>';
        return;
      }
      grid.innerHTML = '';
      for (const img of data.images) {
        const card = document.createElement('div');
        card.style.cssText = 'border:1px solid var(--ivory-mid);border-radius:2px;overflow:hidden;cursor:pointer;transition:border-color 0.15s;';
        card.onmouseover = () => card.style.borderColor = 'var(--gold)';
        card.onmouseout = () => card.style.borderColor = 'var(--ivory-mid)';
        card.innerHTML = `
          <div style="aspect-ratio:1/1;background:var(--ivory);display:flex;align-items:center;justify-content:center;overflow:hidden;">
            <img src="${img.url}" alt="${img.label}" style="max-width:100%;max-height:100%;object-fit:cover;">
          </div>
          <div style="padding:6px 8px;font-size:0.65rem;color:var(--slate);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${img.label || img.slot}</div>
        `;
        card.onclick = () => {
          const tag = `<img src="${img.url}" alt="${img.label || ''}" style="max-width:100%;height:auto;display:block;margin:16px 0;">`;
          insertAtCursor(campBody, tag);
          closeImgPicker();
        };
        grid.appendChild(card);
      }
    })
    .catch(() => {
      grid.innerHTML = '<div style="text-align:center;color:var(--danger);font-size:0.82rem;grid-column:1/-1;padding:20px;">Failed to load images.</div>';
    });
}

function closeImgPicker() {
  document.getElementById('imgPickerModal').style.display = 'none';
}

function insertExtImage() {
  const url = document.getElementById('extImgUrl').value.trim();
  if (!url) return;
  const tag = `<img src="${url}" alt="" style="max-width:100%;height:auto;display:block;margin:16px 0;">`;
  insertAtCursor(campBody, tag);
  closeImgPicker();
}

document.getElementById('imgPickerModal')?.addEventListener('click', function(e) {
  if (e.target === this) closeImgPicker();
});
</script>

</div></div>

<!-- Agent Overlay + Panel (campaigns tab only) -->
<% if (tab === 'campaigns') { %>
<div id="agentOverlay"></div>
<div id="agentPanel">
  <div class="ap-header">
    <div class="ap-title"><span class="ap-dot"></span> Marketing Agent</div>
    <button class="ap-close" id="agentClose">&#10005;</button>
  </div>
  <div class="ap-sub">
    <span class="ap-sub-dot"></span>
    Qwen 2.5 &middot; Web search enabled &middot; Auto-fills campaign fields
  </div>
  <div class="ap-msgs" id="agentMsgs">
    <div class="ap-msg assistant">
      <div class="ap-bubble">
        Hi! I'm your email marketing assistant. I can research topics and write campaign emails &mdash; subject lines, preview text, and full HTML body.<br><br>
        Try: <em>"Write a spring promotion email for our marketing services"</em> or <em>"Create a newsletter about social media tips"</em>
      </div>
    </div>
  </div>
  <div class="ap-footer">
    <div class="ap-quick" id="apQuick"></div>
    <script>
    (function(){
      const brand = <%- JSON.stringify({ name: brand?.name||'', location: brand?.location||'', services: brand?.services||[], targetAudience: brand?.targetAudience||'' }) %>;
      const biz = brand.name || 'the business';
      const svc = brand.services.length ? brand.services[0] : 'our services';
      const audience = brand.targetAudience || 'subscribers';
      const loc = brand.location ? ` in ${brand.location}` : '';
      const pool = [
        { label: 'Write from Subject', prompt: 'Based on the current subject line, write a compelling email body' },
        { label: 'Promo Email', prompt: `Write a promotional email about ${svc} for ${audience}${loc}` },
        { label: 'Newsletter', prompt: `Write a newsletter email with helpful tips for ${audience}` },
        { label: 'Discount Offer', prompt: `Write an email announcing a limited-time discount on ${brand.services.length>1 ? brand.services.slice(0,2).join(' and ') : svc}` },
        { label: 'Re-engagement', prompt: "Write a re-engagement email for contacts who haven't opened recent campaigns" },
        { label: 'Welcome Email', prompt: `Write a welcome email for new ${biz} subscribers introducing the team and services` },
        { label: 'Monthly Update', prompt: `Write a monthly update email highlighting recent work and upcoming offers from ${biz}` },
        { label: 'Event Invite', prompt: `Write an email inviting ${audience} to a free consultation or event` },
      ];
      for(let i=pool.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[pool[i],pool[j]]=[pool[j],pool[i]];}
      const el=document.getElementById('apQuick');
      let idx=0;
      function render(){
        el.innerHTML='';
        const batch=[pool.find(p=>p.label==='Write from Subject')];
        for(let i=0;i<4;i++){idx=(idx+1)%pool.length; if(pool[idx].label!=='Write from Subject') batch.push(pool[idx]);}
        batch.slice(0,5).forEach(s=>{
          const b=document.createElement('button');b.className='ap-quick-btn';b.dataset.prompt=s.prompt;b.textContent=s.label;
          b.onclick=()=>{document.getElementById('agentInput').value=s.prompt;document.getElementById('agentSend').click();};
          el.appendChild(b);
        });
        const cyc=document.createElement('button');cyc.className='ap-cycle-btn';cyc.style.cssText='opacity:0.5;font-size:0.7rem;padding:5px 8px;border:1px solid var(--ivory-mid);background:var(--white);color:var(--slate);cursor:pointer;border-radius:2px;';cyc.textContent='\u267B';cyc.title='More suggestions';
        cyc.onclick=(e)=>{e.stopPropagation();idx=(idx+2)%pool.length;render();};
        el.appendChild(cyc);
      }
      render();
    })();
    </script>
    <div class="ap-input-row">
      <textarea class="ap-input" id="agentInput" placeholder="Ask the agent to write an email campaign..." rows="1"></textarea>
      <button class="ap-send" id="agentSend">&uarr;</button>
    </div>
    <span id="ai-status"></span>
  </div>
</div>

<script>
(function() {
  const panel = document.getElementById('agentPanel');
  const overlay = document.getElementById('agentOverlay');
  if (!panel || !overlay) return;

  document.getElementById('agentToggle').addEventListener('click', openPanel);
  document.getElementById('agentClose').addEventListener('click', closePanel);
  overlay.addEventListener('click', closePanel);

  function openPanel() {
    panel.classList.add('open');
    overlay.classList.add('active');
  }
  function closePanel() {
    panel.classList.remove('open');
    overlay.classList.remove('active');
  }

  // Mobile keyboard: keep footer pinned
  if (window.visualViewport) {
    window.visualViewport.addEventListener('resize', () => {
      if (panel.classList.contains('open')) {
        panel.style.height = window.visualViewport.height + 'px';
        panel.style.top = window.visualViewport.offsetTop + 'px';
        document.getElementById('agentMsgs').scrollTop = document.getElementById('agentMsgs').scrollHeight;
      }
    });
  }

  // Quick prompt buttons
  document.getElementById('apQuick').querySelectorAll('.ap-quick-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('agentInput').value = this.dataset.prompt;
      sendAgent();
    });
  });

  const agentInput = document.getElementById('agentInput');
  agentInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendAgent(); }
  });
  agentInput.addEventListener('input', function() {
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 120) + 'px';
  });
  document.getElementById('agentSend').addEventListener('click', sendAgent);

  // Field helpers
  function getField(id) { return document.getElementById(id); }

  function fillField(fieldId, value) {
    const el = getField(fieldId);
    if (!el) return;
    el.value = value;
    el.classList.add('ai-filled');
  }

  function getCurrentCampaign() {
    return {
      subject: (getField('campSubject') || {}).value || '',
      preheader: (getField('campPreheader') || {}).value || '',
      body: (getField('campBody') || {}).value || '',
      targetFunnel: (getField('campTargetFunnel') || {}).value || 'all',
    };
  }

  // Messages
  const agentMessages = [];

  function appendMsg(role, text, extra) {
    const msgs = document.getElementById('agentMsgs');
    const el = document.createElement('div');
    el.className = 'ap-msg ' + role;
    el.innerHTML = '<div class="ap-bubble">' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</div>';
    if (extra) el.innerHTML += extra;
    msgs.appendChild(el);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function showTyping() {
    const msgs = document.getElementById('agentMsgs');
    const el = document.createElement('div');
    el.id = 'apTyping';
    el.className = 'ap-msg assistant';
    el.innerHTML = '<div class="ap-typing"><div class="ap-typing-dot"></div><div class="ap-typing-dot"></div><div class="ap-typing-dot"></div></div>';
    msgs.appendChild(el);
    msgs.scrollTop = msgs.scrollHeight;
  }
  function hideTyping() { document.getElementById('apTyping')?.remove(); }

  async function sendAgent() {
    const text = agentInput.value.trim();
    if (!text) return;
    agentInput.value = '';
    agentInput.style.height = 'auto';
    document.getElementById('agentSend').disabled = true;

    agentMessages.push({ role: 'user', content: text });
    appendMsg('user', text);
    showTyping();

    try {
      const res = await fetch('/admin/email-marketing/campaigns/agent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: agentMessages, currentCampaign: getCurrentCampaign() }),
      });
      const data = await res.json();
      hideTyping();

      if (data.error) {
        appendMsg('assistant', 'Error: ' + data.error);
      } else {
        const fill = data.fill || {};
        const fillCount = Object.keys(fill).length;

        if (fill.subject) fillField('campSubject', fill.subject);
        if (fill.preheader) fillField('campPreheader', fill.preheader);
        if (fill.body) fillField('campBody', fill.body);

        agentMessages.push({ role: 'assistant', content: data.message });

        let extra = '';
        if (fillCount) extra = '<div class="ap-fill-notice" style="margin-top:4px;">&#10003; ' + fillCount + ' field' + (fillCount > 1 ? 's' : '') + ' filled</div>';
        appendMsg('assistant', data.message, extra);
      }
    } catch(e) {
      hideTyping();
      appendMsg('assistant', 'Connection error. Please try again.');
    } finally {
      document.getElementById('agentSend').disabled = false;
      agentInput.focus();
    }
  }
})();
</script>
<% } %>
<script src="/js/agentHealth.js"></script>
<script src="/js/tours/email-marketing.js"></script>

</body>
</html>
