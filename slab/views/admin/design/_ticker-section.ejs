<%# ─── TICKER / MARQUEE ─── %>
<div class="editor-section">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Ticker / Marquee <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">
    <div class="ep-hint" style="margin-bottom:10px;">Configure the scrolling bar under the hero. Toggle on/off under Section Visibility &rsaquo; Marquee.</div>

    <div class="ep-field">
      <label>Ticker Items (pipe-separated)</label>
      <textarea name="ticker_items" rows="3" placeholder="Free Shipping | 24/7 Support | Same-Day Install"><%= design.ticker_items || '' %></textarea>
      <div class="ep-hint">Leave empty to auto-use brand services, location, and tagline.</div>
    </div>

    <div class="ep-row">
      <div class="ep-field">
        <label>Direction</label>
        <select name="ticker_direction">
          <option value="left"  <%= (design.ticker_direction || 'left') === 'left'  ? 'selected' : '' %>>Left (default)</option>
          <option value="right" <%= design.ticker_direction === 'right' ? 'selected' : '' %>>Right</option>
        </select>
      </div>
      <div class="ep-field">
        <label>Speed (<%= design.ticker_speed || '22' %>s per loop)</label>
        <input type="range" name="ticker_speed" min="6" max="80" value="<%= design.ticker_speed || '22' %>" style="width:100%;">
        <div class="ep-hint">Lower = faster</div>
      </div>
    </div>

    <div class="ep-row">
      <div class="ep-field">
        <label>Background</label>
        <div class="color-row">
          <input type="color" value="<%= design.ticker_bg || design.color_primary %>" onchange="this.nextElementSibling.value=this.value" oninput="this.nextElementSibling.value=this.value">
          <input type="text" name="ticker_bg" value="<%= design.ticker_bg || '' %>" placeholder="(primary)">
        </div>
      </div>
      <div class="ep-field">
        <label>Text Color</label>
        <div class="color-row">
          <input type="color" value="<%= design.ticker_text_color || design.color_accent_light %>" onchange="this.nextElementSibling.value=this.value" oninput="this.nextElementSibling.value=this.value">
          <input type="text" name="ticker_text_color" value="<%= design.ticker_text_color || '' %>" placeholder="(accent light)">
        </div>
      </div>
    </div>

    <div class="ep-field">
      <label>Dot Color</label>
      <div class="color-row">
        <input type="color" value="<%= design.ticker_dot_color || design.color_accent_2 || design.color_accent %>" onchange="this.nextElementSibling.value=this.value" oninput="this.nextElementSibling.value=this.value">
        <input type="text" name="ticker_dot_color" value="<%= design.ticker_dot_color || '' %>" placeholder="(accent-2)">
      </div>
    </div>

    <div class="ep-row-3">
      <div class="ep-field">
        <label>Font Size (<%= design.ticker_font_size || '0.72' %>rem)</label>
        <input type="range" name="ticker_font_size" min="0.5" max="1.6" step="0.02" value="<%= design.ticker_font_size || '0.72' %>" style="width:100%;">
      </div>
      <div class="ep-field">
        <label>Padding (<%= design.ticker_padding || '14' %>px)</label>
        <input type="range" name="ticker_padding" min="4" max="40" value="<%= design.ticker_padding || '14' %>" style="width:100%;">
      </div>
      <div class="ep-field">
        <label>Item Gap (<%= design.ticker_item_gap || '32' %>px)</label>
        <input type="range" name="ticker_item_gap" min="8" max="80" value="<%= design.ticker_item_gap || '32' %>" style="width:100%;">
      </div>
    </div>

    <div class="ep-row">
      <div class="ep-field">
        <label>Letter Spacing (<%= design.ticker_letter_spacing || '0.2' %>em)</label>
        <input type="range" name="ticker_letter_spacing" min="0" max="0.5" step="0.02" value="<%= design.ticker_letter_spacing || '0.2' %>" style="width:100%;">
      </div>
      <div class="ep-field">
        <label style="margin-bottom:10px;">&nbsp;</label>
        <label style="font-size:0.75rem;text-transform:none;letter-spacing:0;display:flex;align-items:center;gap:6px;cursor:pointer;">
          <input type="checkbox" name="ticker_uppercase" value="true" <%= design.ticker_uppercase !== 'false' ? 'checked' : '' %> style="width:14px;height:14px;accent-color:var(--navy);"> Uppercase
        </label>
      </div>
    </div>
  </div>
</div>
