<script>
// ── Accordion toggle ──
function toggleSection(btn) {
  var section = btn.closest('.editor-section');
  section.classList.toggle('open');
}

// ── Preview ──
function previewReload() {
  var f = document.getElementById('previewFrame');
  f.src = f.src;
}

function setViewport(mode) {
  var vp = document.getElementById('previewViewport');
  var frame = document.getElementById('previewFrame');
  frame.style.maxWidth = mode === 'tablet' ? '768px' : mode === 'mobile' ? '375px' : '100%';
  ['Desktop','Tablet','Mobile'].forEach(function(m) {
    var btn = document.getElementById('vp' + m);
    if (btn) btn.style.borderColor = m.toLowerCase() === mode ? 'var(--navy)' : '';
  });
}

// ── Reload preview after save ──
<% if (saved) { %>
(function() {
  var f = document.getElementById('previewFrame');
  f.onload = function() {}; // already loaded, just ensure fresh
  f.src = '/?t=' + Date.now();
})();
<% } %>

// ── Live preview engine ──
// Maps design field → CSS variable names (covers both index.ejs and landing.ejs)
var cssVarMap = {
  color_primary:      ['--navy'],
  color_primary_deep: ['--navy-deep', '--bg'],
  color_primary_mid:  ['--navy-mid', '--card'],
  color_accent:       ['--gold', '--accent'],
  color_accent_light: ['--gold-light', '--accent-hover'],
  color_bg:           ['--ivory', '--surface'],
  color_accent_2:     ['--accent-2'],
  color_accent_3:     ['--accent-3'],
  color_dark:         ['--dark', '--on-surface'],
  color_white:        ['--white'],
  color_muted:        ['--muted', '--on-surface-muted'],
  color_border:       ['--ivory-mid', '--border'],
  color_success:      ['--success'],
  color_danger:       ['--crimson'],
  hero_overlay_color:      ['--hero-overlay'],
  contact_bg:              ['--contact-bg'],
  contact_heading_color:   ['--contact-heading'],
  contact_eyebrow_color:   ['--contact-eyebrow'],
  contact_text_color:      ['--contact-text'],
  contact_label_color:     ['--contact-label'],
  contact_value_color:     ['--contact-value'],
  contact_form_bg:         ['--contact-form-bg'],
  contact_form_label_color:['--contact-form-label'],
  contact_btn_bg:          ['--contact-btn-bg'],
  contact_btn_color:       ['--contact-btn-color'],
};
// Range/select inputs that map to CSS vars but need special transforms
var cssVarTransform = {
