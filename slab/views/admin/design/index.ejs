        </div>
        <div class="ep-field">
          <label>Body Text</label>
          <div class="color-row">
            <input type="color" value="<%= d.footer_text_color || d.color_white %>" onchange="this.nextElementSibling.value=this.value;previewReload()" oninput="this.nextElementSibling.value=this.value">
            <input type="text" name="footer_text_color" value="<%= d.footer_text_color || '' %>" placeholder="auto" onchange="previewReload()">
          </div>
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Column Heading</label>
          <div class="color-row">
            <input type="color" value="<%= d.footer_heading_color || d.color_accent %>" onchange="this.nextElementSibling.value=this.value;previewReload()" oninput="this.nextElementSibling.value=this.value">
            <input type="text" name="footer_heading_color" value="<%= d.footer_heading_color || '' %>" placeholder="auto" onchange="previewReload()">
          </div>
        </div>
        <div class="ep-field">
          <label>Border / Divider</label>
          <div class="color-row">
            <input type="color" value="<%= d.footer_border_color || d.color_border || '#2E4270' %>" onchange="this.nextElementSibling.value=this.value;previewReload()" oninput="this.nextElementSibling.value=this.value">
            <input type="text" name="footer_border_color" value="<%= d.footer_border_color || '' %>" placeholder="auto" onchange="previewReload()">
          </div>
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Link Resting</label>
          <div class="color-row">
            <input type="color" value="<%= d.footer_link_color || d.footer_text_color || d.color_white %>" onchange="this.nextElementSibling.value=this.value;previewReload()" oninput="this.nextElementSibling.value=this.value">
            <input type="text" name="footer_link_color" value="<%= d.footer_link_color || '' %>" placeholder="auto" onchange="previewReload()">
          </div>
        </div>
        <div class="ep-field">
          <label>Link Hover</label>
          <div class="color-row">
            <input type="color" value="<%= d.footer_link_hover_color || d.color_accent %>" onchange="this.nextElementSibling.value=this.value;previewReload()" oninput="this.nextElementSibling.value=this.value">
            <input type="text" name="footer_link_hover_color" value="<%= d.footer_link_hover_color || '' %>" placeholder="auto" onchange="previewReload()">
          </div>
