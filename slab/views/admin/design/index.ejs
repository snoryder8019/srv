<%- include('../partials/head', { title }) %>
</div><!-- close .layout from head.ejs -->

<style>
/* ── Editor split layout ── */
.layout { display: none !important; }
.editor-layout { display: flex; height: 100vh; position: fixed; inset: 0; z-index: 60; }
.editor-panel { width: 340px; flex-shrink: 0; overflow-y: auto; background: var(--surface); border-right: 1px solid var(--border); padding: 0; }
.editor-preview { flex: 1; min-width: 320px; background: var(--ivory); display: flex; flex-direction: column; }
.editor-preview iframe { flex: 1; border: none; width: 100%; }

/* ── Accordion sections ── */
.editor-section { border-bottom: 1px solid var(--border); }
.editor-section-toggle {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 20px; cursor: pointer; font-size: 0.72rem; font-weight: 600;
  letter-spacing: 0.14em; text-transform: uppercase; color: var(--slate);
  background: none; border: none; width: 100%; text-align: left;
  font-family: var(--font-body); transition: color 0.15s;
}
.editor-section-toggle:hover { color: var(--on-surface); }
.editor-section-body { display: none; padding: 0 20px 20px; }
.editor-section.open .editor-section-body { display: block; }
.editor-section.open .editor-section-toggle .arrow { transform: rotate(90deg); }
.arrow { transition: transform 0.2s; font-size: 0.6rem; }

/* ── Compact form controls ── */
.ep-field { margin-bottom: 10px; }
.ep-field label { display: block; font-size: 0.68rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--slate); margin-bottom: 4px; }
.ep-field input[type=text], .ep-field input[type=number], .ep-field textarea, .ep-field select {
  width: 100%; padding: 7px 8px; border: 1px solid var(--border); border-radius: 2px;
  font-family: var(--font-body); font-size: 0.78rem; color: var(--on-surface); background: var(--ivory);
  box-sizing: border-box;
}
.ep-field textarea { resize: vertical; min-height: 52px; }
.ep-field select { appearance: auto; -webkit-appearance: auto; }
.ep-hint { font-size: 0.62rem; color: var(--slate); margin-top: 2px; }
.ep-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.ep-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }

/* ── Color picker compact ── */
.color-row { display: flex; gap: 6px; align-items: center; }
.color-row input[type=color] { width: 36px; height: 30px; flex-shrink: 0; padding: 1px; border: 1px solid var(--border); border-radius: 2px; cursor: pointer; }
.color-row input[type=text] { flex: 1; min-width: 0; padding: 6px 8px; font-size: 0.75rem; border: 1px solid var(--border); border-radius: 2px; color: var(--slate); background: var(--ivory); }

/* ── Swatch preview ── */
.swatch-row { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 10px; }
.swatch { width: 40px; height: 26px; border-radius: 2px; flex-shrink: 0; }

/* ── Visibility grid ── */
.vis-grid-compact { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
.vis-item { display: flex; align-items: center; gap: 6px; padding: 6px 8px; background: var(--ivory); border: 1px solid var(--border); border-radius: 2px; cursor: pointer; font-size: 0.72rem; color: var(--on-surface); }
.vis-item input { width: 14px; height: 14px; accent-color: var(--navy); flex-shrink: 0; }

/* ── Theme cards ── */
.theme-card { border: 1px solid var(--border); border-radius: 2px; overflow: hidden; background: var(--surface); margin-bottom: 8px; }
.theme-card-swatches { display: flex; height: 20px; }
.theme-card-swatches div { flex: 1; }
.theme-card-body { padding: 8px 10px; }
.theme-card-name { font-size: 0.75rem; font-weight: 600; color: var(--on-surface); }
.theme-card-meta { font-size: 0.6rem; color: var(--slate); margin-bottom: 6px; }
.theme-card-actions { display: flex; gap: 4px; }

/* ── Preview toolbar ── */
.preview-bar { padding: 8px 16px; background: var(--surface); border-bottom: 1px solid var(--border); display: flex; gap: 8px; align-items: center; }
.preview-bar .btn { padding: 4px 10px; font-size: 0.65rem; }

/* ── Success/error banners ── */
.save-banner { padding: 10px 20px; font-size: 0.78rem; font-weight: 500; }
.save-banner.success { background: rgba(21,128,61,0.08); color: var(--success, #15803D); border-bottom: 1px solid rgba(21,128,61,0.2); }
.save-banner.error { background: rgba(185,28,28,0.08); color: #B91C1C; border-bottom: 1px solid rgba(185,28,28,0.2); }

/* ── Agent btn ── */
.agent-btn {
  display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; border-radius: 2px;
  background: linear-gradient(135deg, #6B3FA0, #8B5FC0); color: var(--gold-light);
  border: 1px solid color-mix(in srgb, var(--gold) 30%, transparent);
  font-family: var(--font-body); font-size: 0.65rem; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer;
}
.agent-btn:hover { background: linear-gradient(135deg, #8B5FC0, #6B3FA0); }

/* ── Agent chat panel (matches blog/pages pattern) ── */
#agentPanel { position: fixed; top: 0; right: -440px; width: 420px; height: 100vh; height: 100dvh; background: var(--surface); border-left: 1px solid var(--border); box-shadow: -8px 0 40px rgba(15,27,48,0.12); z-index: 500; display: flex; flex-direction: column; transition: right 0.3s cubic-bezier(0.4,0,0.2,1); }
#agentPanel.open { right: 0; }
#agentOverlay { display: none; position: fixed; inset: 0; background: rgba(15,27,48,0.15); z-index: 499; }
#agentOverlay.active { display: block; }
.ap-header { padding: 18px 20px; border-bottom: 1px solid var(--border); background: linear-gradient(135deg, var(--navy-deep), var(--navy)); display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
.ap-title { font-family: var(--font-heading); font-size: 1.2rem; font-weight: 400; color: var(--gold-light); display: flex; align-items: center; gap: 10px; }
.ap-dot { width: 8px; height: 8px; border-radius: 50%; background: #4ADE80; animation: apPulse 2s infinite; }
@keyframes apPulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
.ap-close { background: none; border: none; color: rgba(253,252,250,0.5); font-size: 1.3rem; cursor: pointer; padding: 4px; transition: color 0.15s; }
.ap-close:hover { color: var(--gold-light); }
.ap-sub { padding: 8px 20px; background: rgba(201,168,72,0.07); border-bottom: 1px solid rgba(201,168,72,0.15); flex-shrink: 0; font-size: 0.7rem; color: var(--slate); letter-spacing: 0.04em; display: flex; align-items: center; gap: 6px; }
.ap-sub-dot { width: 5px; height: 5px; border-radius: 50%; background: #4ADE80; }
.ap-msgs { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; padding: 16px 20px; display: flex; flex-direction: column; gap: 12px; }
.ap-msg { display: flex; flex-direction: column; gap: 4px; }
.ap-msg.user { align-items: flex-end; }
.ap-msg.assistant { align-items: flex-start; }
.ap-bubble { max-width: 88%; padding: 10px 14px; border-radius: 4px; font-size: 0.84rem; line-height: 1.5; font-weight: 300; }
.ap-msg.user .ap-bubble { background: var(--navy); color: var(--gold-light); border-radius: 4px 4px 1px 4px; }
.ap-msg.assistant .ap-bubble { background: var(--ivory); color: var(--on-surface); border: 1px solid var(--border); border-radius: 4px 4px 4px 1px; }
.ap-typing { display: flex; gap: 4px; padding: 10px 14px; background: var(--ivory); border: 1px solid var(--border); border-radius: 4px 4px 4px 1px; align-self: flex-start; }
.ap-typing-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--slate); animation: apBounce 1.2s infinite; }
.ap-typing-dot:nth-child(2) { animation-delay: 0.2s; }
.ap-typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes apBounce { 0%,60%,100%{transform:translateY(0);opacity:0.4;} 30%{transform:translateY(-5px);opacity:1;} }
.ap-fill-notice { font-size: 0.68rem; color: #15803D; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; margin-top: 4px; }
.ap-search-notice { font-size: 0.68rem; color: var(--slate); font-style: italic; }
.ap-footer { padding: 14px 20px; padding-bottom: max(14px, env(safe-area-inset-bottom, 14px)); border-top: 1px solid var(--border); flex-shrink: 0; }
.ap-quick { display: flex; gap: 6px; margin-bottom: 10px; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; flex-wrap: nowrap; padding-bottom: 2px; }
.ap-quick::-webkit-scrollbar { display: none; }
.ap-quick-btn { font-size: 0.67rem; padding: 5px 10px; border-radius: 2px; border: 1px solid var(--border); background: var(--surface); color: var(--slate); cursor: pointer; font-family: var(--font-body); font-weight: 500; letter-spacing: 0.04em; transition: all 0.15s; white-space: nowrap; flex-shrink: 0; }
.ap-quick-btn:hover { border-color: var(--navy-mid); color: var(--navy); }
.ap-input-row { display: flex; gap: 8px; }
.ap-input { flex: 1; padding: 10px 14px; border: 1px solid var(--border); border-radius: 2px; font-family: var(--font-body); font-size: 0.88rem; font-weight: 300; color: var(--on-surface); outline: none; resize: none; transition: border-color 0.15s; min-height: 42px; max-height: 120px; }
.ap-input:focus { border-color: var(--navy); }
.ap-send { padding: 10px 16px; background: var(--navy); color: var(--gold-light); border: none; border-radius: 2px; cursor: pointer; font-size: 0.9rem; transition: background 0.15s; flex-shrink: 0; align-self: flex-end; }
.ap-send:hover { background: var(--navy-deep); }
.ap-send:disabled { opacity: 0.4; cursor: not-allowed; }
.ai-filled { background: rgba(21,128,61,0.07) !important; border-color: rgba(21,128,61,0.45) !important; transition: background 0.4s, border-color 0.4s; }

/* ── Brand image compact ── */
.brand-img-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.brand-img-slot { border: 1px solid var(--border); border-radius: 2px; overflow: hidden; }
.brand-img-slot img { width: 100%; height: 60px; object-fit: contain; background: var(--ivory); }
.brand-img-slot .lbl { padding: 4px 6px; font-size: 0.62rem; color: var(--slate); }

/* ── Repeater (add/remove rows in lists) ── */
.dp-repeater { display:flex; flex-direction:column; gap:10px; }
.dp-rep-item { padding:10px; border:1px solid var(--border); border-radius:3px; background:color-mix(in srgb, var(--ivory) 60%, white); position:relative; }
.dp-rep-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; font-size:0.62rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--slate); }
.dp-rep-actions { display:flex; gap:4px; }
.dp-rep-actions button { background:none; border:1px solid var(--border); width:24px; height:24px; border-radius:2px; cursor:pointer; font-size:0.78rem; color:var(--slate); padding:0; }
.dp-rep-actions button:hover:not(:disabled) { background:var(--ivory); color:var(--on-surface); }
.dp-rep-actions button:disabled { opacity:0.3; cursor:not-allowed; }
.dp-rep-remove { background:none; border:1px solid var(--border); width:24px; height:24px; border-radius:2px; cursor:pointer; font-size:0.85rem; color:#8B1C1C; padding:0; }
.dp-rep-remove:hover { background:rgba(139,28,28,0.08); }
.dp-rep-add { padding:7px 14px; font-size:0.65rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; background:var(--ivory); color:var(--navy); border:1px dashed var(--navy-mid); border-radius:2px; cursor:pointer; transition:background 0.15s; align-self:flex-start; font-family:var(--font-body); }
.dp-rep-add:hover { background:color-mix(in srgb, var(--navy) 6%, white); }

/* ── Tab nav (top of left panel) ── */
.dp-tabs { display:flex; border-bottom:1px solid var(--border); background:var(--surface); position:sticky; top:0; z-index:5; overflow-x:auto; scrollbar-width:none; }
.dp-tabs::-webkit-scrollbar { display:none; }
.dp-tab { flex:1; min-width:fit-content; padding:10px 12px; font-size:0.62rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:var(--slate); background:none; border:none; border-bottom:2px solid transparent; cursor:pointer; transition:color 0.15s, border-color 0.15s; font-family:var(--font-body); white-space:nowrap; }
.dp-tab:hover { color:var(--on-surface); }
.dp-tab.active { color:var(--navy); border-bottom-color:var(--gold); }
.dp-tab .ico { display:inline-block; margin-right:5px; font-size:0.78rem; }
/* hide accordion sections not matching the active tab */
.editor-section[data-tab]:not(.dp-show) { display:none; }

/* ── Mobile gate ── */
.mobile-gate { display: none; }
@media (max-width: 820px) {
  .editor-layout { display: none !important; }
  .mobile-gate {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    min-height: 80vh; padding: 40px 24px; text-align: center; color: var(--slate);
  }
  .mobile-gate .icon { font-size: 2.4rem; margin-bottom: 16px; }
  .mobile-gate h2 { font-size: 1.1rem; font-weight: 600; color: var(--on-surface); margin: 0 0 8px; }
  .mobile-gate p { font-size: 0.82rem; line-height: 1.5; max-width: 320px; margin: 0 0 20px; }
}
</style>

<div class="mobile-gate">
  <div class="icon">&#128421;</div>
  <h2>Desktop Only</h2>
  <p>The Design Editor requires a larger screen with the side-by-side preview. Please switch to a desktop or tablet in landscape mode.</p>
  <a href="/admin" class="btn btn-navy" style="font-size:0.75rem;padding:8px 20px;">&larr; Back to Admin</a>
</div>

<div class="editor-layout">

<%# ═══════════ LEFT PANEL — FORM ═══════════ %>
<div class="editor-panel">
<form method="POST" action="/admin/design" id="designForm">

<div style="padding:10px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:8px;">
  <a href="/admin" style="font-size:0.72rem;color:var(--slate);text-decoration:none;">&larr; Admin</a>
  <span style="font-size:0.72rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--on-surface);flex:1;text-align:center;">Design & Content</span>
  <button type="submit" class="btn btn-navy" style="font-size:0.62rem;padding:6px 14px;letter-spacing:0.08em;white-space:nowrap;border-radius:2px;">Save All</button>
</div>
<% if (saved) { %><div class="save-banner success">Settings saved.</div><% } %>
<% if (error) { %><div class="save-banner error">Failed to save.</div><% } %>

<%# ─── Tab nav (consolidates Design / Sections / Templates / Brand) ─── %>
<div class="dp-tabs" id="dpTabs">
  <button type="button" class="dp-tab" data-tab="source"    onclick="dpSwitch('source')"><span class="ico">◐</span>Source</button>
  <button type="button" class="dp-tab" data-tab="design"    onclick="dpSwitch('design')"><span class="ico">◑</span>Design</button>
  <button type="button" class="dp-tab" data-tab="copy"      onclick="dpSwitch('copy')"><span class="ico">¶</span>Copy</button>
  <button type="button" class="dp-tab" data-tab="sections"  onclick="dpSwitch('sections')"><span class="ico">▦</span>Sections</button>
  <button type="button" class="dp-tab" data-tab="templates" onclick="dpSwitch('templates')"><span class="ico">◈</span>Templates</button>
  <button type="button" class="dp-tab" data-tab="brand"     onclick="dpSwitch('brand')"><span class="ico">⛌</span>Brand</button>
</div>

<%# ─── Shared state used across multiple tabs ─── %>
<%
  const _sectionTemplates = typeof sectionTemplates !== 'undefined' ? sectionTemplates : {};
  const _validSections = (customSections || []).filter(s => s && s.type && _sectionTemplates[s.type]);
%>

<%# ─── 1. HOMEPAGE SOURCE — top-level switch ─── %>
<%
  const _src = design.home_source || 'auto';
  const _activeTpl = (templates || []).find(t => activeTemplateId && t._id.toString() === activeTemplateId);
  // Effective renderer — what actually displays at "/", accounting for fallbacks
  // when the configured source has no resource (e.g. template mode with no active template).
  let _effective;
  if (_src === 'layout') _effective = 'layout';
  else if (_src === 'template') _effective = _activeTpl ? 'template' : 'layout';
  else if (_src === 'custom')   _effective = hasCustomEjs ? 'custom' : 'layout';
  else /* auto */               _effective = hasCustomEjs ? 'custom' : (_activeTpl ? 'template' : 'layout');
%>
<div class="editor-section open" data-tab="source">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Homepage Source <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">
    <%
      const _effLabel = _effective === 'layout' ? 'Standard Layout'
                      : _effective === 'template' ? ('Slab Template — ' + (_activeTpl ? _activeTpl.name : 'unknown'))
                      : _effective === 'custom' ? 'Custom EJS' : 'Standard Layout';
      const _srcLabel = _src === 'auto' ? 'Auto'
                      : _src === 'layout' ? 'Standard Layout'
                      : _src === 'template' ? 'Slab Template'
                      : _src === 'custom' ? 'Custom Layout' : _src;
    %>
    <div style="margin-bottom:12px;padding:10px 14px;background:rgba(28,43,74,0.05);border-left:3px solid var(--navy);border-radius:2px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
      <div style="font-size:0.82rem;color:var(--on-surface);">
        <span style="font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--slate);">Currently rendering at /</span><br>
        <strong style="color:var(--navy);"><%= _effLabel %></strong>
      </div>
      <div style="font-size:0.7rem;color:var(--slate);text-align:right;">
        Source setting: <strong style="color:var(--on-surface);"><%= _srcLabel %></strong>
        <% if (_src !== _effective) { %><br><span style="color:#8B1C1C;">(fallback — configured source has no resource)</span><% } %>
      </div>
    </div>
    <div class="ep-hint" style="margin-bottom:10px;">
      Pick what renders at <code style="font-size:0.7rem;background:var(--ivory);padding:1px 5px;border-radius:2px;">/</code>. The matching configuration section opens below.
    </div>

    <div style="display:flex;flex-direction:column;gap:6px;">
      <%
        const _options = [
          { val: 'auto',     title: 'Auto',            desc: hasCustomEjs ? 'Use custom EJS if present, else active template, else standard layout' : 'Use active template if set, else standard layout' },
          { val: 'layout',   title: 'Standard Layout', desc: 'Use the landing layout below (Classic, Bold, Minimal&hellip;) driven by the design panel' },
          { val: 'template', title: 'Slab Template',   desc: _activeTpl ? ('Render the activated template: <strong>' + _activeTpl.name + '</strong>') : 'Render the active template (none activated yet — pick one below)' },
          { val: 'custom',   title: 'Custom Layout',   desc: hasCustomEjs ? ('Use the bespoke EJS at <code>views/tenants/' + tenantSubdomain + '/home.ejs</code>') : 'Bespoke EJS file (not present for this tenant — falls back to layout)' },
        ];
      %>
      <% _options.forEach(o => { const checked = _src === o.val; %>
      <label class="vis-item" style="align-items:flex-start;padding:10px 12px;<%= checked ? 'border-color:var(--gold);box-shadow:0 0 0 1px var(--gold);' : '' %>">
        <input type="radio" name="home_source" value="<%= o.val %>" <%= checked ? 'checked' : '' %> style="margin-top:3px;flex-shrink:0;">
        <span style="display:flex;flex-direction:column;gap:2px;">
          <span style="font-weight:600;font-size:0.78rem;color:var(--on-surface);"><%= o.title %><% if (o.val === 'auto') { %> <span style="font-size:0.55rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);">DEFAULT</span><% } %></span>
          <span style="font-size:0.68rem;color:var(--slate);line-height:1.4;font-weight:400;text-transform:none;letter-spacing:0;"><%- o.desc %></span>
        </span>
      </label>
      <% }) %>
    </div>

    <% if (_src !== _effective) { %>
    <div class="ep-hint" style="margin-top:10px;padding:8px 12px;background:rgba(139,28,28,0.06);border-left:3px solid #8B1C1C;border-radius:2px;color:#7A1818;">
      <strong>Fallback active:</strong> you selected <strong><%= _src %></strong> but it has no resource, so <strong><%= _effective %></strong> is actually rendering at <code style="font-size:0.7rem;background:rgba(255,255,255,0.6);padding:1px 5px;border-radius:2px;">/</code>.
      <% if (_src === 'template' && !_activeTpl) { %> Activate a template below to make template mode take effect.<% } %>
      <% if (_src === 'custom' && !hasCustomEjs) { %> Create <code style="font-size:0.7rem;">views/tenants/<%= tenantSubdomain %>/home.ejs</code> to use a bespoke layout.<% } %>
    </div>
    <% } %>
    <div class="ep-hint" style="margin-top:10px;">
      <strong>Tip:</strong> &ldquo;Custom Layout&rdquo; uses CSS variables from this panel, so colors &amp; fonts you set here still apply to bespoke EJS files.
    </div>
  </div>
</div>

<%# ─── 1a. LAYOUT & TEMPLATE ─── %>
<div class="editor-section<%= (_src === 'layout' || _src === 'auto') ? ' open' : '' %>" data-tab="source">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Standard Layout
    <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">
    <div class="ep-field">
      <label>Landing Layout</label>
      <select name="landing_layout" id="field-landing_layout">
        <option value="classic"    <%= design.landing_layout === 'classic'    ? 'selected' : '' %>>Classic</option>
        <option value="bold"       <%= design.landing_layout === 'bold'       ? 'selected' : '' %>>Bold</option>
        <option value="minimal"    <%= design.landing_layout === 'minimal'    ? 'selected' : '' %>>Minimal</option>
        <option value="magazine"   <%= design.landing_layout === 'magazine'   ? 'selected' : '' %>>Magazine</option>
        <option value="dark"       <%= design.landing_layout === 'dark'       ? 'selected' : '' %>>Dark</option>
        <option value="startup"    <%= design.landing_layout === 'startup'    ? 'selected' : '' %>>Startup</option>
        <option value="showcase"   <%= design.landing_layout === 'showcase'   ? 'selected' : '' %>>Showcase</option>
        <option value="industrial" <%= design.landing_layout === 'industrial' ? 'selected' : '' %>>Industrial</option>
        <option value="split"      <%= design.landing_layout === 'split'      ? 'selected' : '' %>>Split</option>
        <option value="editorial"  <%= design.landing_layout === 'editorial'  ? 'selected' : '' %>>Editorial</option>
        <option value="agency"     <%= design.landing_layout === 'agency'     ? 'selected' : '' %>>Agency</option>
        <option value="clean"      <%= design.landing_layout === 'clean'      ? 'selected' : '' %>>Clean</option>
        <option value="brutalist"  <%= design.landing_layout === 'brutalist'  ? 'selected' : '' %>>Brutalist</option>
      </select>
    </div>
    <div class="ep-row">
      <div class="ep-field">
        <label>Animation</label>
        <select name="section_animation" id="field-section_animation">
          <option value="none" <%= design.section_animation === 'none' ? 'selected' : '' %>>None</option>
          <option value="fade" <%= design.section_animation === 'fade' ? 'selected' : '' %>>Fade up</option>
          <option value="slide" <%= design.section_animation === 'slide' ? 'selected' : '' %>>Slide in</option>
          <option value="zoom" <%= design.section_animation === 'zoom' ? 'selected' : '' %>>Zoom in</option>
          <option value="flip" <%= design.section_animation === 'flip' ? 'selected' : '' %>>Flip in</option>
          <option value="stagger" <%= design.section_animation === 'stagger' ? 'selected' : '' %>>Stagger</option>
          <option value="blur" <%= design.section_animation === 'blur' ? 'selected' : '' %>>Blur in</option>
        </select>
      </div>
      <div class="ep-field">
        <label style="margin-bottom:10px;">&nbsp;</label>
        <label style="font-size:0.75rem;text-transform:none;letter-spacing:0;display:flex;align-items:center;gap:6px;cursor:pointer;">
          <input type="checkbox" name="snap_enabled" id="field-snap_enabled" <%= design.snap_enabled === 'true' ? 'checked' : '' %> style="width:14px;height:14px;accent-color:var(--navy);"> Scroll snap
        </label>
      </div>
    </div>
  </div>
</div>

<%# ─── 1b. TEMPLATE LIBRARY ─── %>
<div class="editor-section<%= _src === 'template' ? ' open' : '' %>" data-tab="templates">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Template Library
    <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">
    <div class="ep-hint" style="margin-bottom:10px;">
      <% if (_activeTpl) { %>
        Currently active: <strong style="color:var(--on-surface);"><%= _activeTpl.name %></strong>.
        Active templates override the landing layout above.
      <% } else { %>
        No template active &mdash; using the landing layout above. Activate a template to swap your homepage to a fully custom layout.
      <% } %>
    </div>

    <% if (!templates || templates.length === 0) { %>
      <div style="padding:14px;border:1px dashed var(--border);border-radius:2px;text-align:center;">
        <div style="font-size:0.78rem;color:var(--slate);margin-bottom:8px;">No templates yet.</div>
        <a href="/admin/templates/new" class="btn btn-navy" style="font-size:0.65rem;padding:5px 12px;">+ Build Template</a>
        <a href="/admin/template-store" class="btn btn-ghost" style="font-size:0.65rem;padding:5px 12px;margin-left:4px;">Browse Store</a>
      </div>
    <% } else { %>
      <div style="display:flex;flex-direction:column;gap:6px;">
        <% templates.forEach(tpl => {
             const isActive = activeTemplateId && tpl._id.toString() === activeTemplateId;
             const blocksCount = (tpl.blocks || []).length;
             const cat = tpl.category || 'landing';
        %>
          <div class="theme-card" style="<%= isActive ? 'border-color:var(--gold);box-shadow:0 0 0 1px var(--gold);' : '' %>">
            <div class="theme-card-body" style="display:flex;align-items:center;gap:8px;">
              <div style="flex:1;min-width:0;">
                <div class="theme-card-name" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                  <%= tpl.name %>
                  <% if (isActive) { %><span style="font-size:0.55rem;font-weight:700;letter-spacing:0.12em;background:var(--gold);color:var(--navy-deep);padding:1px 5px;border-radius:2px;margin-left:4px;vertical-align:middle;">ACTIVE</span><% } %>
                </div>
                <div class="theme-card-meta">
                  <%= cat %> &middot; <%= blocksCount %> block<%= blocksCount === 1 ? '' : 's' %>
                  <% if (tpl.source === 'store') { %> &middot; from store<% } %>
                  <% if (tpl.source === 'migration') { %> &middot; built-in<% } %>
                </div>
              </div>
              <div class="theme-card-actions" style="gap:4px;">
                <a href="/admin/templates/<%= tpl._id %>/preview" target="_blank" class="btn btn-ghost" style="font-size:0.6rem;padding:3px 8px;letter-spacing:0.06em;">Preview</a>
                <a href="/admin/templates/<%= tpl._id %>/edit" class="btn btn-ghost" style="font-size:0.6rem;padding:3px 8px;letter-spacing:0.06em;">Edit</a>
                <% if (isActive) { %>
                  <button type="submit" form="tpl-deact-<%= tpl._id %>" class="btn btn-ghost" style="font-size:0.6rem;padding:3px 8px;letter-spacing:0.06em;color:var(--gold);">Deactivate</button>
                <% } else { %>
                  <button type="submit" form="tpl-act-<%= tpl._id %>" class="btn btn-navy" style="font-size:0.6rem;padding:3px 8px;letter-spacing:0.06em;">Activate</button>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <div style="margin-top:10px;display:flex;gap:6px;">
        <a href="/admin/templates" class="btn btn-ghost" style="font-size:0.62rem;padding:5px 10px;letter-spacing:0.08em;">Manage All</a>
        <a href="/admin/templates/new" class="btn btn-ghost" style="font-size:0.62rem;padding:5px 10px;letter-spacing:0.08em;">+ New</a>
        <a href="/admin/template-store" class="btn btn-ghost" style="font-size:0.62rem;padding:5px 10px;letter-spacing:0.08em;">Store</a>
      </div>
    <% } %>
  </div>
</div>

<%# ─── 1c. CUSTOM LAYOUT (only when relevant) ─── %>
<% if (hasCustomEjs || _src === 'custom') { %>
<div class="editor-section<%= _src === 'custom' ? ' open' : '' %>" data-tab="source">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Custom Layout
    <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">
    <% if (hasCustomEjs) { %>
      <div class="ep-hint" style="margin-bottom:8px;">
        Bespoke EJS file detected for this tenant:
        <code style="display:block;margin-top:4px;padding:6px 8px;background:var(--ivory);border:1px solid var(--border);border-radius:2px;font-size:0.7rem;color:var(--on-surface);">views/tenants/<%= tenantSubdomain %>/home.ejs</code>
      </div>
      <div class="ep-hint">
        Files in the tenant namespace pull colors &amp; fonts from this design panel via the <code>design.*</code> variables and shared CSS tokens (<code>--primary</code>, <code>--accent</code>, <code>--font-heading</code>&hellip;). To switch off the bespoke layout, change <strong>Homepage Source</strong> above.
      </div>
    <% } else { %>
      <div class="ep-hint">
        No bespoke EJS file present for <code><%= tenantSubdomain || '(no subdomain)' %></code>. Custom layouts require a developer to drop a file at <code>views/tenants/&lt;sub&gt;/home.ejs</code> &mdash; until then this option falls back to the standard layout.
      </div>
    <% } %>
  </div>
</div>
<% } %>

<%# ─── 2. COLORS ─── %>
<%
  // Essentials drive 95% of the look. Everything else is derived or rarely tweaked.
  const colorEssentials = [
    { name: 'color_primary', label: 'Primary',    hint: 'Brand color &mdash; nav, headings, buttons' },
    { name: 'color_accent',  label: 'Accent',     hint: 'CTAs, highlights, badges' },
    { name: 'color_bg',      label: 'Background', hint: 'Section backgrounds, page bg' },
  ];
  const colorAdvanced = [
    { name: 'color_primary_deep', label: 'Primary Deep',  hint: 'Hero bg, footer, deepest shade' },
    { name: 'color_primary_mid',  label: 'Primary Mid',   hint: 'Borders, hover states' },
    { name: 'color_accent_light', label: 'Accent Light',  hint: 'Text on dark bg' },
    { name: 'color_accent_2',     label: 'Accent 2',      hint: 'Secondary accent (multi-brand)' },
    { name: 'color_accent_3',     label: 'Accent 3',      hint: 'Tertiary accent (multi-brand)' },
    { name: 'color_dark',         label: 'Text Dark',     hint: 'Body text on light bg' },
    { name: 'color_white',        label: 'White / Surface', hint: 'Cards, page surface' },
    { name: 'color_muted',        label: 'Muted Text',    hint: 'Secondary text (auto if empty)' },
    { name: 'color_border',       label: 'Border',        hint: 'Dividers, card borders (auto if empty)' },
    { name: 'color_success',      label: 'Success',       hint: 'Success state' },
    { name: 'color_danger',       label: 'Danger',        hint: 'Error / danger state' },
  ];
  // For palette preview we want all six "primary" tokens in one row
  const palettePreview = ['color_primary','color_primary_deep','color_primary_mid','color_accent','color_accent_light','color_bg'];
%>
<div class="editor-section" data-tab="design">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Colors <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">
    <div class="ep-hint" style="margin-bottom:10px;">Three colors set the brand. Shades and contrast colors are auto-derived &mdash; tweak them under <em>Advanced</em> only if needed.</div>

    <% colorEssentials.forEach(cf => { %>
    <div class="ep-field">
      <label><%= cf.label %></label>
      <div class="color-row">
        <input type="color" name="<%= cf.name %>" id="field-<%= cf.name %>" value="<%= design[cf.name] %>">
        <input type="text" value="<%= design[cf.name] %>" readonly>
      </div>
      <% if (cf.hint) { %><div class="ep-hint"><%- cf.hint %></div><% } %>
    </div>
    <% }) %>

    <%# Palette preview swatch row %>
    <div style="font-size:0.6rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--slate);margin-top:12px;margin-bottom:6px;">Palette Preview</div>
    <div class="swatch-row" id="swatch-preview">
      <% palettePreview.forEach(k => { %>
      <div class="swatch" style="background:<%= design[k] %>;<%= k === 'color_bg' ? 'border:1px solid var(--border);' : '' %>" title="<%= k %>"></div>
      <% }) %>
    </div>

    <%# Advanced collapsible %>
    <details style="margin-top:14px;border-top:1px solid var(--border);padding-top:10px;">
      <summary style="cursor:pointer;font-size:0.62rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--slate);user-select:none;">Advanced shades &amp; states</summary>
      <div style="margin-top:10px;">
        <div class="ep-row">
        <% colorAdvanced.forEach((cf, i) => { %>
          <div class="ep-field">
            <label><%= cf.label %></label>
            <div class="color-row">
              <input type="color" name="<%= cf.name %>" id="field-<%= cf.name %>" value="<%= design[cf.name] || (cf.name === 'color_accent_2' || cf.name === 'color_accent_3' ? design.color_accent : (cf.name === 'color_muted' ? '#6B7380' : (cf.name === 'color_border' ? '#E5E7EB' : ''))) %>">
              <input type="text" value="<%= design[cf.name] || '' %>" placeholder="<%= cf.name === 'color_muted' || cf.name === 'color_border' ? '(auto)' : (cf.name.startsWith('color_accent_') ? '(primary)' : '') %>" readonly>
            </div>
          </div>
        <% }) %>
        </div>
      </div>
    </details>
  </div>
</div>

<%# ─── 3. TYPOGRAPHY ─── %>
<div class="editor-section" data-tab="design">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Typography <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">
    <div class="ep-field">
      <label>Heading Font</label>
      <select name="font_heading" id="field-font_heading">
        <% ['Cormorant Garamond','Playfair Display','Lora','Merriweather','Libre Baskerville','DM Serif Display','Fraunces','Sora','Space Grotesk','Outfit','Bebas Neue','Oswald'].forEach(f => { %>
        <option value="<%= f %>" <%= design.font_heading === f ? 'selected' : '' %>><%= f %></option>
        <% }) %>
      </select>
    </div>
    <div class="ep-field">
      <label>Body Font</label>
      <select name="font_body" id="field-font_body">
        <% ['Jost','Inter','Poppins','Raleway','Nunito','DM Sans','Work Sans','Source Sans 3','IBM Plex Sans','Manrope','Figtree','Outfit','Sora','Karla','Rubik','Cabin','Barlow','Lexend','Geist'].forEach(f => { %>
        <option value="<%= f %>" <%= design.font_body === f ? 'selected' : '' %>><%= f %></option>
        <% }) %>
      </select>
    </div>
  </div>
</div>

<%# ─── 4. SECTION VISIBILITY ─── %>
<div class="editor-section" data-tab="sections">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Section Visibility <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">
    <%
      // vis_header + vis_footer live in the consolidated Header & Footer section
      const visSections = [
        { key: 'vis_hero',      label: 'Hero' },
        { key: 'vis_marquee',   label: 'Ticker / Marquee' },
        { key: 'vis_services',  label: 'Services' },
        { key: 'vis_portfolio', label: 'Portfolio' },
        { key: 'vis_about',     label: 'About' },
        { key: 'vis_process',   label: 'Process' },
        { key: 'vis_pricing',   label: 'Pricing' },
        { key: 'vis_reviews',   label: 'Reviews' },
        { key: 'vis_contact',   label: 'Contact' },
        { key: 'vis_blog',      label: 'Blog' },
        { key: 'vis_admin_link',label: 'Admin Login Link' },
        { key: 'vis_qr',        label: 'QR Code' },
      ];
    %>
    <div class="vis-grid-compact">
      <% visSections.forEach(s => { %>
      <label class="vis-item">
        <input type="checkbox" name="<%= s.key %>" id="field-<%= s.key %>"
          <%= (s.key === 'vis_blog' || s.key === 'vis_qr') ? (design[s.key] === 'true' ? 'checked' : '') : (design[s.key] !== 'false' ? 'checked' : '') %>>
        <%= s.label %>
      </label>
      <% }) %>
    </div>

    <% if (_validSections.length) { %>
    <div style="margin-top:16px;padding-top:12px;border-top:1px solid var(--border);">
      <div style="font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--slate);margin-bottom:8px;">Custom Sections · Order &amp; Visibility</div>
      <div class="ep-hint" style="margin-bottom:8px;">Drag arrows to reorder. Toggle the eye to hide a section from the homepage.</div>
      <div id="cs-order-list" style="display:flex;flex-direction:column;gap:4px;">
        <% _validSections.forEach(function(sec, i) { %>
          <div class="cs-row" data-cs-id="<%= sec._id %>" style="display:flex;align-items:center;gap:6px;padding:6px 8px;border:1px solid var(--border);border-radius:2px;background:var(--surface);">
            <span style="font-size:0.7rem;color:var(--slate);min-width:16px;text-align:center;" data-cs-index="<%= i + 1 %>"><%= i + 1 %></span>
            <span style="flex:1;min-width:0;font-size:0.78rem;color:var(--on-surface);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= sec.label || 'Untitled' %></span>
            <button type="button" title="Move up" onclick="csMove('<%= sec._id %>', -1)" style="background:none;border:1px solid var(--border);width:22px;height:22px;border-radius:2px;cursor:pointer;font-size:0.7rem;color:var(--slate);"<%= i === 0 ? ' disabled' : '' %>>↑</button>
            <button type="button" title="Move down" onclick="csMove('<%= sec._id %>', 1)" style="background:none;border:1px solid var(--border);width:22px;height:22px;border-radius:2px;cursor:pointer;font-size:0.7rem;color:var(--slate);"<%= i === _validSections.length - 1 ? ' disabled' : '' %>>↓</button>
            <button type="button" class="cs-vis-toggle" data-cs-id="<%= sec._id %>" data-visible="<%= sec.visible !== false ? 'true' : 'false' %>" onclick="csToggleVisible('<%= sec._id %>', this)" title="<%= sec.visible !== false ? 'Hide section' : 'Show section' %>" style="background:none;border:1px solid var(--border);width:30px;height:22px;border-radius:2px;cursor:pointer;font-size:0.72rem;color:<%= sec.visible !== false ? 'var(--navy)' : 'var(--slate)' %>;"><%= sec.visible !== false ? '◉' : '○' %></button>
          </div>
        <% }); %>
      </div>
    </div>
    <% } %>
  </div>
</div>

<%- include('_ticker-section') %>

<%# ─── 4b. HEADER & FOOTER (consolidated) ─── %>
<%# All header & footer settings live here: visibility, logo, CTA, nav colors, custom links. %>
<%# Link create/edit/delete use HTML5 form-attribute references to standalone forms declared outside designForm. %>
<% const d = design; %>
<div class="editor-section" id="links" data-tab="sections">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Header &amp; Footer <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">

    <%# Sub-tabs — Header / Footer / Colors / Links %>
    <div class="ep-hint" style="margin-bottom:6px;font-style:italic;">Switch between Header, Footer, Colors, and Links settings using the tabs below.</div>
    <div class="hf-tabs" style="display:flex;gap:4px;border-bottom:1px solid var(--border);margin-bottom:14px;flex-wrap:wrap;">
      <button type="button" class="hf-tab is-active" data-tab="header"  onclick="hfTab(this)" style="background:none;border:none;padding:10px 16px;font-size:0.78rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--on-surface);font-weight:700;cursor:pointer;border-bottom:3px solid var(--gold);font-family:var(--font-body);">Header</button>
      <button type="button" class="hf-tab"           data-tab="footer"  onclick="hfTab(this)" style="background:none;border:none;padding:10px 16px;font-size:0.78rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--slate);font-weight:700;cursor:pointer;border-bottom:3px solid transparent;font-family:var(--font-body);">Footer</button>
      <button type="button" class="hf-tab"           data-tab="colors"  onclick="hfTab(this)" style="background:none;border:none;padding:10px 16px;font-size:0.78rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--slate);font-weight:700;cursor:pointer;border-bottom:3px solid transparent;font-family:var(--font-body);">Colors</button>
      <button type="button" class="hf-tab"           data-tab="links"   onclick="hfTab(this)" style="background:none;border:none;padding:10px 16px;font-size:0.78rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--slate);font-weight:700;cursor:pointer;border-bottom:3px solid transparent;font-family:var(--font-body);">Links</button>
    </div>

    <%# ── TAB: Header (layout + typography + CTA) ── %>
    <div class="hf-pane" data-pane="header">
      <div class="ep-row">
        <label class="vis-item"><input type="checkbox" name="vis_header" <%= d.vis_header !== 'false' ? 'checked' : '' %>> Show Header</label>
        <label class="vis-item"><input type="checkbox" name="vis_footer" <%= d.vis_footer !== 'false' ? 'checked' : '' %>> Show Footer</label>
      </div>

      <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);margin:14px 0 6px;">STRUCTURE</div>
      <div class="ep-hint" style="margin-bottom:8px;">Picks the overall header arrangement &mdash; independent of the page&rsquo;s landing layout.</div>
      <div class="ep-row-3">
        <div class="ep-field">
          <label>Header Layout</label>
          <select name="header_layout" onchange="previewReload()">
            <option value="standard" <%= (d.header_layout || 'standard') === 'standard' ? 'selected' : '' %>>Standard &mdash; brand left, links right</option>
            <option value="compact"  <%= d.header_layout === 'compact'  ? 'selected' : '' %>>Compact &mdash; reduced padding</option>
            <option value="spacious" <%= d.header_layout === 'spacious' ? 'selected' : '' %>>Spacious &mdash; tall &amp; airy</option>
            <option value="centered" <%= d.header_layout === 'centered' ? 'selected' : '' %>>Centered &mdash; brand top, links below</option>
            <option value="split"    <%= d.header_layout === 'split'    ? 'selected' : '' %>>Split &mdash; links flank centered brand</option>
          </select>
        </div>
        <div class="ep-field">
          <label>Vertical Padding (px) <span class="ep-hint" style="display:inline;font-style:italic;"><%= d.header_padding_y || '20' %></span></label>
          <input type="range" name="header_padding_y" min="6" max="60" step="1" value="<%= d.header_padding_y || '20' %>" oninput="this.previousElementSibling.querySelector('span').textContent=this.value" onchange="previewReload()">
        </div>
        <div class="ep-field">
          <label>Horizontal Padding (px) <span class="ep-hint" style="display:inline;font-style:italic;"><%= d.header_padding_x || '52' %></span></label>
          <input type="range" name="header_padding_x" min="8" max="96" step="2" value="<%= d.header_padding_x || '52' %>" oninput="this.previousElementSibling.querySelector('span').textContent=this.value" onchange="previewReload()">
        </div>
      </div>
      <div class="ep-row-3">
        <div class="ep-field">
          <label>Sticky</label>
          <select name="header_sticky" onchange="previewReload()">
            <option value="true"  <%= d.header_sticky !== 'false' ? 'selected' : '' %>>Yes &mdash; fixed to top</option>
            <option value="false" <%= d.header_sticky === 'false' ? 'selected' : '' %>>No &mdash; scrolls with page</option>
          </select>
        </div>
        <div class="ep-field">
          <label>Backdrop Blur</label>
          <select name="header_blur" onchange="previewReload()">
            <option value="true"  <%= d.header_blur !== 'false' ? 'selected' : '' %>>Yes</option>
            <option value="false" <%= d.header_blur === 'false' ? 'selected' : '' %>>No</option>
          </select>
        </div>
        <div class="ep-field">
          <label>Shadow on Scroll</label>
          <select name="header_shadow" onchange="previewReload()">
            <option value="true"  <%= d.header_shadow !== 'false' ? 'selected' : '' %>>Yes</option>
            <option value="false" <%= d.header_shadow === 'false' ? 'selected' : '' %>>No</option>
          </select>
        </div>
      </div>

      <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);margin:14px 0 6px;">LOGO</div>
      <div class="ep-hint" style="margin-bottom:6px;">Upload or replace logo images on the <a href="#" onclick="dpSwitch('brand');document.getElementById('brand-images')?.scrollIntoView({behavior:'smooth'});return false;" style="color:var(--navy);font-weight:600;">Brand tab →</a></div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Logo Display</label>
          <select name="nav_logo_display" onchange="previewReload()">
            <option value="text"  <%= d.nav_logo_display === 'text'  ? 'selected' : '' %>>Text Only</option>
            <option value="image" <%= d.nav_logo_display === 'image' ? 'selected' : '' %>>Image Only</option>
            <option value="both"  <%= d.nav_logo_display === 'both'  ? 'selected' : '' %>>Both</option>
          </select>
        </div>
        <div class="ep-field">
          <label>Show Tagline</label>
          <select name="nav_tagline_display" onchange="previewReload()">
            <option value="true"  <%= d.nav_tagline_display !== 'false' ? 'selected' : '' %>>Yes</option>
            <option value="false" <%= d.nav_tagline_display === 'false' ? 'selected' : '' %>>No</option>
          </select>
