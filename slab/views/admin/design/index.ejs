      </div>

      <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);margin:14px 0 6px;">BRAND TEXT STYLE</div>
      <div class="ep-row-3">
        <div class="ep-field">
          <label>Size (rem) <span class="ep-hint" style="display:inline;font-style:italic;"><%= d.nav_brand_size || '1.4' %></span></label>
          <input type="range" name="nav_brand_size" min="0.8" max="3" step="0.05" value="<%= d.nav_brand_size || '1.4' %>" oninput="this.previousElementSibling.querySelector('span').textContent=this.value" onchange="previewReload()">
        </div>
        <div class="ep-field">
          <label>Weight</label>
          <select name="nav_brand_weight" onchange="previewReload()">
            <% ['300','400','500','600','700','800'].forEach(w => { %>
              <option value="<%= w %>" <%= (d.nav_brand_weight || '400') === w ? 'selected' : '' %>><%= w %></option>
            <% }) %>
          </select>
        </div>
        <div class="ep-field">
          <label>Letter Spacing (em) <span class="ep-hint" style="display:inline;font-style:italic;"><%= d.nav_brand_spacing || '0.04' %></span></label>
          <input type="range" name="nav_brand_spacing" min="-0.1" max="0.5" step="0.01" value="<%= d.nav_brand_spacing || '0.04' %>" oninput="this.previousElementSibling.querySelector('span').textContent=this.value" onchange="previewReload()">
        </div>
      </div>
      <div class="ep-row-3">
        <div class="ep-field">
          <label>Transform</label>
          <select name="nav_brand_transform" onchange="previewReload()">
            <option value="none"      <%= (d.nav_brand_transform || 'none') === 'none' ? 'selected' : '' %>>As typed</option>
            <option value="uppercase" <%= d.nav_brand_transform === 'uppercase' ? 'selected' : '' %>>UPPERCASE</option>
            <option value="lowercase" <%= d.nav_brand_transform === 'lowercase' ? 'selected' : '' %>>lowercase</option>
          </select>
        </div>
        <div class="ep-field">
          <label>Italic</label>
          <select name="nav_brand_italic" onchange="previewReload()">
            <option value="false" <%= d.nav_brand_italic !== 'true' ? 'selected' : '' %>>No</option>
            <option value="true"  <%= d.nav_brand_italic === 'true' ? 'selected' : '' %>>Yes</option>
          </select>
        </div>
        <div class="ep-field">
          <label>Color</label>
          <div class="color-row">
            <input type="color" value="<%= d.nav_brand_color || d.nav_text_color || d.color_dark %>" onchange="this.nextElementSibling.value=this.value;previewReload()" oninput="this.nextElementSibling.value=this.value">
            <input type="text" name="nav_brand_color" value="<%= d.nav_brand_color || '' %>" placeholder="auto" onchange="previewReload()">
          </div>
        </div>
      </div>

      <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);margin:14px 0 6px;">LOGO TEXT ACCENT</div>
      <div class="ep-hint" style="margin-bottom:8px;">Color a range of characters in your brand name. Char positions are 1-based.</div>
      <div class="ep-row-3">
        <div class="ep-field">
          <label>Char Start</label>
          <input type="number" name="nav_logo_split"     value="<%= d.nav_logo_split     || '0' %>" min="0" max="50" onchange="previewReload()">
        </div>
        <div class="ep-field">
          <label>Char End</label>
          <input type="number" name="nav_logo_split_end" value="<%= d.nav_logo_split_end || '0' %>" min="0" max="50" onchange="previewReload()">
        </div>
        <div class="ep-field">
          <label>Accent Color</label>
          <div class="color-row">
            <input type="color" value="<%= d.nav_logo_accent_color || d.color_accent %>" onchange="this.nextElementSibling.value=this.value;previewReload()" oninput="this.nextElementSibling.value=this.value">
            <input type="text" name="nav_logo_accent_color" value="<%= d.nav_logo_accent_color || '' %>" placeholder="auto" onchange="previewReload()">
          </div>
        </div>
      </div>
      <div class="ep-row-3">
        <div class="ep-field">
          <label>Accent Weight</label>
          <select name="nav_accent_weight" onchange="previewReload()">
            <option value="" <%= !d.nav_accent_weight ? 'selected' : '' %>>(inherit brand)</option>
            <% ['300','400','500','600','700','800','900'].forEach(w => { %>
              <option value="<%= w %>" <%= d.nav_accent_weight === w ? 'selected' : '' %>><%= w %></option>
            <% }) %>
          </select>
        </div>
        <div class="ep-field">
          <label>Accent Italic</label>
          <select name="nav_accent_italic" onchange="previewReload()">
            <option value="false" <%= d.nav_accent_italic !== 'true' ? 'selected' : '' %>>No</option>
            <option value="true"  <%= d.nav_accent_italic === 'true' ? 'selected' : '' %>>Yes</option>
          </select>
        </div>
        <div class="ep-field">&nbsp;</div>
      </div>

      <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);margin:14px 0 6px;">TAGLINE / WORDMARK SUB</div>
      <div class="ep-hint" style="margin-bottom:8px;">Renders the small tagline + location line under the brand name (when &ldquo;Show Tagline&rdquo; above is Yes).</div>
      <div class="ep-row-3">
        <div class="ep-field">
          <label>Size (rem) <span class="ep-hint" style="display:inline;font-style:italic;"><%= d.nav_tagline_size || '0.58' %></span></label>
          <input type="range" name="nav_tagline_size" min="0.5" max="1.4" step="0.02" value="<%= d.nav_tagline_size || '0.58' %>" oninput="this.previousElementSibling.querySelector('span').textContent=this.value" onchange="previewReload()">
        </div>
        <div class="ep-field">
          <label>Weight</label>
          <select name="nav_tagline_weight" onchange="previewReload()">
            <% ['300','400','500','600','700','800'].forEach(w => { %>
              <option value="<%= w %>" <%= (d.nav_tagline_weight || '600') === w ? 'selected' : '' %>><%= w %></option>
            <% }) %>
          </select>
        </div>
        <div class="ep-field">
          <label>Letter Spacing (em) <span class="ep-hint" style="display:inline;font-style:italic;"><%= d.nav_tagline_spacing || '0.28' %></span></label>
          <input type="range" name="nav_tagline_spacing" min="0" max="0.6" step="0.01" value="<%= d.nav_tagline_spacing || '0.28' %>" oninput="this.previousElementSibling.querySelector('span').textContent=this.value" onchange="previewReload()">
        </div>
      </div>
      <div class="ep-row-3">
        <div class="ep-field">
          <label>Transform</label>
          <select name="nav_tagline_transform" onchange="previewReload()">
            <option value="none"      <%= d.nav_tagline_transform === 'none' ? 'selected' : '' %>>As typed</option>
            <option value="uppercase" <%= (d.nav_tagline_transform || 'uppercase') === 'uppercase' ? 'selected' : '' %>>UPPERCASE</option>
            <option value="lowercase" <%= d.nav_tagline_transform === 'lowercase' ? 'selected' : '' %>>lowercase</option>
          </select>
        </div>
        <div class="ep-field">
          <label>Italic</label>
          <select name="nav_tagline_italic" onchange="previewReload()">
            <option value="false" <%= d.nav_tagline_italic !== 'true' ? 'selected' : '' %>>No</option>
            <option value="true"  <%= d.nav_tagline_italic === 'true' ? 'selected' : '' %>>Yes</option>
          </select>
        </div>
        <div class="ep-field">
          <label>Color</label>
          <div class="color-row">
            <input type="color" value="<%= d.nav_tagline_color || d.color_primary %>" onchange="this.nextElementSibling.value=this.value;previewReload()" oninput="this.nextElementSibling.value=this.value">
            <input type="text" name="nav_tagline_color" value="<%= d.nav_tagline_color || '' %>" placeholder="auto" onchange="previewReload()">
          </div>
        </div>
      </div>

      <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);margin:14px 0 6px;">CTA BUTTON</div>
      <div class="ep-row">
        <div class="ep-field">
          <label>CTA Text</label>
          <input type="text" name="nav_cta_text" value="<%= d.nav_cta_text || '' %>" placeholder="Get Started" onchange="previewReload()">
        </div>
        <div class="ep-field">
          <label>CTA Link</label>
          <input type="text" name="nav_cta_link" value="<%= d.nav_cta_link || '' %>" placeholder="/#contact" onchange="previewReload()">
        </div>
      </div>
    </div>

    <%# ── TAB: Footer ── %>
    <div class="hf-pane" data-pane="footer" style="display:none;">
      <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);margin:0 0 6px;">STRUCTURE</div>
      <div class="ep-hint" style="margin-bottom:8px;">Pick the footer&rsquo;s overall arrangement &mdash; independent of the landing layout.</div>
      <div class="ep-row-3">
        <div class="ep-field">
          <label>Footer Layout</label>
          <select name="footer_layout" onchange="previewReload()">
            <option value="simple"   <%= (d.footer_layout || 'simple') === 'simple'   ? 'selected' : '' %>>Simple &mdash; copyright + admin</option>
            <option value="columns"  <%= d.footer_layout === 'columns'  ? 'selected' : '' %>>Columns &mdash; brand + link sets</option>
            <option value="centered" <%= d.footer_layout === 'centered' ? 'selected' : '' %>>Centered &mdash; brand + links stacked</option>
            <option value="expanded" <%= d.footer_layout === 'expanded' ? 'selected' : '' %>>Expanded &mdash; about + columns + newsletter</option>
            <option value="minimal"  <%= d.footer_layout === 'minimal'  ? 'selected' : '' %>>Minimal &mdash; copyright only</option>
            <option value="brand"    <%= d.footer_layout === 'brand'    ? 'selected' : '' %>>Brand &mdash; large brand + tagline + social</option>
          </select>
        </div>
        <div class="ep-field">
          <label>Alignment</label>
          <select name="footer_align" onchange="previewReload()">
            <option value="left"   <%= d.footer_align === 'left'   ? 'selected' : '' %>>Left</option>
            <option value="center" <%= (d.footer_align || 'center') === 'center' ? 'selected' : '' %>>Center</option>
            <option value="right"  <%= d.footer_align === 'right'  ? 'selected' : '' %>>Right</option>
          </select>
        </div>
        <div class="ep-field">
          <label>Columns</label>
          <select name="footer_columns" onchange="previewReload()">
            <% [1,2,3,4].forEach(function(n) { %>
              <option value="<%= n %>" <%= (d.footer_columns || '3') === String(n) ? 'selected' : '' %>><%= n %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="ep-row-3">
        <div class="ep-field">
          <label>Vertical Padding (px) <span class="ep-hint" style="display:inline;font-style:italic;"><%= d.footer_padding_y || '32' %></span></label>
          <input type="range" name="footer_padding_y" min="8" max="96" step="2" value="<%= d.footer_padding_y || '32' %>" oninput="this.previousElementSibling.querySelector('span').textContent=this.value" onchange="previewReload()">
        </div>
        <div class="ep-field">
          <label>Horizontal Padding (px) <span class="ep-hint" style="display:inline;font-style:italic;"><%= d.footer_padding_x || '24' %></span></label>
          <input type="range" name="footer_padding_x" min="8" max="96" step="2" value="<%= d.footer_padding_x || '24' %>" oninput="this.previousElementSibling.querySelector('span').textContent=this.value" onchange="previewReload()">
        </div>
        <div class="ep-field">
          <label>Brand Size (rem) <span class="ep-hint" style="display:inline;font-style:italic;"><%= d.footer_brand_size || '1.2' %></span></label>
          <input type="range" name="footer_brand_size" min="0.7" max="3" step="0.05" value="<%= d.footer_brand_size || '1.2' %>" oninput="this.previousElementSibling.querySelector('span').textContent=this.value" onchange="previewReload()">
        </div>
      </div>

      <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);margin:14px 0 6px;">PIECES</div>
      <div class="ep-row" style="grid-template-columns:repeat(3,1fr);gap:6px;">
        <label class="vis-item"><input type="checkbox" name="footer_show_brand"    <%= d.footer_show_brand    !== 'false' ? 'checked' : '' %>> Brand</label>
        <label class="vis-item"><input type="checkbox" name="footer_show_tagline"  <%= d.footer_show_tagline  !== 'false' ? 'checked' : '' %>> Tagline</label>
        <label class="vis-item"><input type="checkbox" name="footer_show_logo"     <%= d.footer_show_logo     === 'true'  ? 'checked' : '' %>> Logo Image</label>
        <label class="vis-item"><input type="checkbox" name="footer_show_social"   <%= d.footer_show_social   !== 'false' ? 'checked' : '' %>> Social Row</label>
        <label class="vis-item"><input type="checkbox" name="footer_show_newsletter" <%= d.footer_show_newsletter === 'true' ? 'checked' : '' %>> Newsletter</label>
        <label class="vis-item"><input type="checkbox" name="footer_show_qr"       <%= d.footer_show_qr       !== 'false' ? 'checked' : '' %>> QR Codes</label>
        <label class="vis-item"><input type="checkbox" name="vis_admin_link"       <%= d.vis_admin_link       !== 'false' ? 'checked' : '' %>> Admin Link</label>
      </div>

      <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);margin:14px 0 6px;">TYPOGRAPHY</div>
      <div class="ep-row-3">
        <div class="ep-field">
          <label>Body Size (rem) <span class="ep-hint" style="display:inline;font-style:italic;"><%= d.footer_text_size || '0.78' %></span></label>
          <input type="range" name="footer_text_size" min="0.5" max="1.2" step="0.02" value="<%= d.footer_text_size || '0.78' %>" oninput="this.previousElementSibling.querySelector('span').textContent=this.value" onchange="previewReload()">
        </div>
        <div class="ep-field">
          <label>Body Weight</label>
          <select name="footer_text_weight" onchange="previewReload()">
            <% ['300','400','500','600','700'].forEach(function(w) { %>
              <option value="<%= w %>" <%= (d.footer_text_weight || '400') === w ? 'selected' : '' %>><%= w %></option>
            <% }) %>
          </select>
        </div>
        <div class="ep-field">
          <label>Brand Weight</label>
          <select name="footer_brand_weight" onchange="previewReload()">
            <% ['300','400','500','600','700','800'].forEach(function(w) { %>
              <option value="<%= w %>" <%= (d.footer_brand_weight || '500') === w ? 'selected' : '' %>><%= w %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="ep-row-3">
        <div class="ep-field">
          <label>Heading Size (rem) <span class="ep-hint" style="display:inline;font-style:italic;"><%= d.footer_heading_size || '0.72' %></span></label>
          <input type="range" name="footer_heading_size" min="0.5" max="1.4" step="0.02" value="<%= d.footer_heading_size || '0.72' %>" oninput="this.previousElementSibling.querySelector('span').textContent=this.value" onchange="previewReload()">
        </div>
        <div class="ep-field">
          <label>Heading Weight</label>
          <select name="footer_heading_weight" onchange="previewReload()">
            <% ['300','400','500','600','700','800'].forEach(function(w) { %>
              <option value="<%= w %>" <%= (d.footer_heading_weight || '600') === w ? 'selected' : '' %>><%= w %></option>
            <% }) %>
          </select>
        </div>
        <div class="ep-field">
          <label>Heading Transform</label>
          <select name="footer_heading_transform" onchange="previewReload()">
            <option value="none"      <%= d.footer_heading_transform === 'none'      ? 'selected' : '' %>>As typed</option>
            <option value="uppercase" <%= (d.footer_heading_transform || 'uppercase') === 'uppercase' ? 'selected' : '' %>>UPPERCASE</option>
            <option value="lowercase" <%= d.footer_heading_transform === 'lowercase' ? 'selected' : '' %>>lowercase</option>
          </select>
        </div>
      </div>

      <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);margin:14px 0 6px;">COPY</div>
      <% const c = (typeof copy !== 'undefined' && copy) ? copy : {}; %>
      <div class="ep-row">
        <div class="ep-field">
          <label>Tagline</label>
          <input type="text" name="footer_tagline" value="<%= c.footer_tagline || '' %>" placeholder="Short line under brand" maxlength="160" onchange="previewReload()">
        </div>
        <div class="ep-field">
          <label>Copyright Override</label>
          <input type="text" name="footer_copyright" value="<%= c.footer_copyright || '' %>" placeholder="© {year} {name} (leave empty for auto)" onchange="previewReload()">
        </div>
      </div>
      <div class="ep-field">
        <label>About Paragraph <span class="ep-hint" style="display:inline;font-style:italic;">(Expanded / Brand layouts)</span></label>
        <textarea name="footer_about" rows="2" placeholder="Short description shown beside link columns" onchange="previewReload()"><%= c.footer_about || '' %></textarea>
      </div>

      <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);margin:14px 0 6px;">LINK COLUMNS</div>
      <div class="ep-hint" style="margin-bottom:8px;">One link per line, format <code>Label | /url</code>. Rendered in Columns / Expanded layouts.</div>
      <% [1,2,3,4].forEach(function(n) { %>
        <div class="ep-row" style="grid-template-columns:1fr 2fr;gap:6px;">
          <div class="ep-field">
            <label>Col <%= n %> Heading</label>
            <input type="text" name="footer_col<%= n %>_heading" value="<%= c['footer_col' + n + '_heading'] || '' %>" placeholder="<%= ['Company','Services','Resources','Legal'][n-1] %>" maxlength="40" onchange="previewReload()">
          </div>
          <div class="ep-field">
            <label>Col <%= n %> Links</label>
            <textarea name="footer_col<%= n %>_links" rows="2" placeholder="About | /about&#10;Contact | /contact" onchange="previewReload()"><%= c['footer_col' + n + '_links'] || '' %></textarea>
          </div>
        </div>
      <% }) %>

      <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);margin:14px 0 6px;">NEWSLETTER</div>
      <div class="ep-hint" style="margin-bottom:8px;">Only renders when the Newsletter piece is enabled above.</div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Heading</label>
          <input type="text" name="footer_newsletter_heading" value="<%= c.footer_newsletter_heading || '' %>" placeholder="Stay in touch" onchange="previewReload()">
        </div>
        <div class="ep-field">
          <label>Subtext</label>
          <input type="text" name="footer_newsletter_sub" value="<%= c.footer_newsletter_sub || '' %>" placeholder="Monthly updates, no spam." onchange="previewReload()">
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Placeholder</label>
          <input type="text" name="footer_newsletter_placeholder" value="<%= c.footer_newsletter_placeholder || '' %>" placeholder="you@example.com" onchange="previewReload()">
        </div>
        <div class="ep-field">
          <label>Button Text</label>
          <input type="text" name="footer_newsletter_button" value="<%= c.footer_newsletter_button || '' %>" placeholder="Subscribe" onchange="previewReload()">
        </div>
      </div>

      <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);margin:14px 0 6px;">SOCIAL</div>
      <div class="ep-field">
        <label>Heading</label>
        <input type="text" name="footer_social_heading" value="<%= c.footer_social_heading || '' %>" placeholder="Follow" maxlength="40" onchange="previewReload()">
      </div>
      <div class="ep-row-3">
        <div class="ep-field"><label>Facebook</label><input type="text" name="footer_social_facebook" value="<%= d.footer_social_facebook || '' %>" placeholder="https://facebook.com/..." onchange="previewReload()"></div>
        <div class="ep-field"><label>Instagram</label><input type="text" name="footer_social_instagram" value="<%= d.footer_social_instagram || '' %>" placeholder="https://instagram.com/..." onchange="previewReload()"></div>
        <div class="ep-field"><label>Twitter / X</label><input type="text" name="footer_social_twitter" value="<%= d.footer_social_twitter || '' %>" placeholder="https://x.com/..." onchange="previewReload()"></div>
      </div>
      <div class="ep-row-3">
        <div class="ep-field"><label>LinkedIn</label><input type="text" name="footer_social_linkedin" value="<%= d.footer_social_linkedin || '' %>" placeholder="https://linkedin.com/..." onchange="previewReload()"></div>
        <div class="ep-field"><label>YouTube</label><input type="text" name="footer_social_youtube" value="<%= d.footer_social_youtube || '' %>" placeholder="https://youtube.com/@..." onchange="previewReload()"></div>
        <div class="ep-field"><label>TikTok</label><input type="text" name="footer_social_tiktok" value="<%= d.footer_social_tiktok || '' %>" placeholder="https://tiktok.com/@..." onchange="previewReload()"></div>
      </div>
      <div class="ep-row-3">
        <div class="ep-field"><label>GitHub</label><input type="text" name="footer_social_github" value="<%= d.footer_social_github || '' %>" placeholder="https://github.com/..." onchange="previewReload()"></div>
        <div class="ep-field">&nbsp;</div>
        <div class="ep-field">&nbsp;</div>
      </div>
    </div>

    <%# ── TAB: Colors ── %>
    <div class="hf-pane" data-pane="colors" style="display:none;">
      <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);margin:0 0 6px;">HEADER</div>
      <div class="ep-field">
        <label>Background</label>
        <div class="color-row">
          <input type="color" value="<%= d.nav_bg || d.color_bg %>" onchange="this.nextElementSibling.value=this.value;previewReload()" oninput="this.nextElementSibling.value=this.value">
          <input type="text" name="nav_bg" value="<%= d.nav_bg || '' %>" placeholder="auto" onchange="previewReload()">
        </div>
      </div>
      <div class="ep-field">
        <label>Default Text <span class="ep-hint" style="display:inline;font-style:italic;">(fallback for brand &amp; links)</span></label>
        <div class="color-row">
          <input type="color" value="<%= d.nav_text_color || d.color_dark %>" onchange="this.nextElementSibling.value=this.value;previewReload()" oninput="this.nextElementSibling.value=this.value">
          <input type="text" name="nav_text_color" value="<%= d.nav_text_color || '' %>" placeholder="auto" onchange="previewReload()">
        </div>
      </div>

      <details style="margin-top:10px;border-top:1px solid var(--border);padding-top:10px;">
        <summary style="cursor:pointer;font-size:0.62rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--slate);user-select:none;">Per-element overrides</summary>
        <div style="margin-top:10px;">
          <div class="ep-hint" style="margin-bottom:8px;">Brand &amp; tagline colors live with their typography in the <strong>Layout</strong> tab.</div>
          <div class="ep-row">
            <div class="ep-field">
              <label>Link Resting</label>
              <div class="color-row">
