<!-- ── CUSTOM ELEMENTS ── -->
<div class="editor-section" data-tab="sections">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Custom Elements <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">
    <div class="ep-hint" style="margin-bottom:12px;">Platform features injected outside the template system. Toggle them on/off and see where they live.</div>

    <div style="border:1px solid var(--border);border-radius:2px;margin-bottom:8px;padding:10px 12px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
        <span style="font-size:0.75rem;font-weight:600;color:var(--on-surface);">Bug / Ticket Button</span>
        <select name="el_bug_button" style="width:auto;padding:3px 6px;font-size:0.68rem;" onchange="previewReload()">
          <option value="true" <%= d.el_bug_button !== 'false' ? 'selected' : '' %>>On</option>
          <option value="false" <%= d.el_bug_button === 'false' ? 'selected' : '' %>>Off</option>
        </select>
      </div>
      <div class="ep-hint">Floating report-a-bug button. Opens ticket submission modal.<br>
        <strong>Source:</strong> public/js/bugButton.js</div>
    </div>

    <div style="border:1px solid var(--border);border-radius:2px;margin-bottom:8px;padding:10px 12px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
        <span style="font-size:0.75rem;font-weight:600;color:var(--on-surface);">Notification Bell</span>
        <select name="el_notification_bell" style="width:auto;padding:3px 6px;font-size:0.68rem;" onchange="previewReload()">
          <option value="true" <%= d.el_notification_bell !== 'false' ? 'selected' : '' %>>On</option>
          <option value="false" <%= d.el_notification_bell === 'false' ? 'selected' : '' %>>Off</option>
        </select>
      </div>
      <div class="ep-hint">Platform announcements + ticket/scan counts bell (admin only).<br>
        <strong>Source:</strong> views/admin/partials/head.ejs</div>
    </div>

    <div style="border:1px solid var(--border);border-radius:2px;margin-bottom:8px;padding:10px 12px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
        <span style="font-size:0.75rem;font-weight:600;color:var(--on-surface);">Admin Tour</span>
        <select name="el_admin_tour" style="width:auto;padding:3px 6px;font-size:0.68rem;" onchange="previewReload()">
          <option value="true" <%= d.el_admin_tour !== 'false' ? 'selected' : '' %>>On</option>
          <option value="false" <%= d.el_admin_tour === 'false' ? 'selected' : '' %>>Off</option>
        </select>
      </div>
      <div class="ep-hint">Driver.js guided tour for new admin users.<br>
        <strong>Source:</strong> public/js/adminTour.js · public/css/adminTour.css</div>
    </div>

    <div style="border:1px solid var(--border);border-radius:2px;margin-bottom:8px;padding:10px 12px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
        <span style="font-size:0.75rem;font-weight:600;color:var(--on-surface);">Preview Banner</span>
        <select name="el_preview_banner" style="width:auto;padding:3px 6px;font-size:0.68rem;" onchange="previewReload()">
          <option value="true" <%= d.el_preview_banner !== 'false' ? 'selected' : '' %>>On</option>
          <option value="false" <%= d.el_preview_banner === 'false' ? 'selected' : '' %>>Off</option>
        </select>
      </div>
      <div class="ep-hint">Top banner shown when tenant is in preview mode with "Go Live" CTA.<br>
        <strong>Source:</strong> views/partials/preview-banner.ejs</div>
    </div>

    <div style="border:1px solid var(--border);border-radius:2px;margin-bottom:8px;padding:10px 12px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
        <span style="font-size:0.75rem;font-weight:600;color:var(--on-surface);">Maintenance Banner</span>
        <select name="el_maintenance_banner" style="width:auto;padding:3px 6px;font-size:0.68rem;" onchange="previewReload()">
          <option value="true" <%= d.el_maintenance_banner !== 'false' ? 'selected' : '' %>>On</option>
          <option value="false" <%= d.el_maintenance_banner === 'false' ? 'selected' : '' %>>Off</option>
        </select>
      </div>
      <div class="ep-hint">Countdown banner after server restart / maintenance window.<br>
        <strong>Source:</strong> views/partials/maintenance-banner.ejs</div>
    </div>

    <div style="border:1px solid var(--border);border-radius:2px;margin-bottom:8px;padding:10px 12px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
        <span style="font-size:0.75rem;font-weight:600;color:var(--on-surface);">3D Model Viewer</span>
        <select name="el_gltf_viewer" style="width:auto;padding:3px 6px;font-size:0.68rem;" onchange="previewReload()">
          <option value="true" <%= d.el_gltf_viewer === 'true' ? 'selected' : '' %>>On</option>
          <option value="false" <%= d.el_gltf_viewer !== 'true' ? 'selected' : '' %>>Off</option>
        </select>
      </div>
      <div class="ep-hint">Three.js GLTF viewer for header/logo 3D models. Heavy payload.<br>
        <strong>Source:</strong> public/js/gltfViewer.js</div>
    </div>

  </div>
</div>

</form>

<%# ─── Standalone forms for inline controls (HTML5 disallows nested <form>). ─── %>
<%# Each form is `hidden` and zero-size; its submit is triggered by buttons elsewhere via the `form` attribute. %>
<form id="link-create" action="/admin/design/links" method="POST" hidden></form>
<% (navLinks || []).forEach(function(l) { %>
  <form id="link-edit-<%= l._id %>" action="/admin/design/links" method="POST" hidden></form>
  <form id="link-delete-<%= l._id %>" action="/admin/design/links/<%= l._id %>/delete" method="POST" hidden></form>
<% }); %>
<% (templates || []).forEach(function(tpl) { %>
  <form id="tpl-act-<%= tpl._id %>"   action="/admin/templates/<%= tpl._id %>/activate"   method="POST" hidden></form>
  <form id="tpl-deact-<%= tpl._id %>" action="/admin/templates/<%= tpl._id %>/deactivate" method="POST" hidden></form>
<% }); %>

<%# ─── 14. LOGOS & BRAND IMAGES ─── %>
<div class="editor-section open" id="brand-images" data-tab="brand">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Logos &amp; Brand Images <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">
    <%
      const logoSlots = [
        { slot: 'logo_primary', label: 'Primary Logo',  hint: 'Header & default logo' },
        { slot: 'logo_white',   label: 'White Logo',    hint: 'For dark backgrounds (footer)' },
        { slot: 'logo_icon',    label: 'Icon / Favicon', hint: 'Browser tab + small contexts' },
        { slot: 'banner',       label: 'Banner',        hint: 'Hero / share image' },
      ];
    %>
    <div class="ep-hint" style="margin-bottom:10px;">Upload your logos and brand assets below. Each slot replaces the previous file when you upload a new one. Changes appear after a refresh.</div>

    <%# Combined preview + upload row per slot %>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;">
      <% logoSlots.forEach(ls => { %>
        <% const existing = brandImages.find(i => i.slot === ls.slot); %>
        <div style="border:1px solid var(--border);border-radius:3px;padding:10px;display:flex;flex-direction:column;gap:6px;">
          <div style="font-size:0.7rem;font-weight:700;color:var(--on-surface);letter-spacing:0.04em;"><%= ls.label %></div>
          <div style="font-size:0.6rem;color:var(--slate);"><%= ls.hint %></div>
          <div style="height:70px;border:1px dashed var(--border);background:<%= ls.slot === 'logo_white' ? 'var(--navy-deep)' : 'var(--ivory)' %>;display:flex;align-items:center;justify-content:center;overflow:hidden;">
            <% if (existing) { %>
              <img src="<%= existing.url %>" alt="<%= ls.label %>" style="max-height:60px;max-width:90%;object-fit:contain;">
            <% } else { %>
              <span style="font-size:0.62rem;color:var(--slate);">No image uploaded</span>
            <% } %>
          </div>
          <form method="POST" action="/admin/design/images" enctype="multipart/form-data" style="display:flex;gap:4px;align-items:center;flex-wrap:wrap;">
            <input type="hidden" name="slot" value="<%= ls.slot %>">
            <input type="hidden" name="label" value="<%= ls.label %>">
            <input type="file" name="image" accept="image/*" required style="font-size:0.62rem;flex:1;min-width:0;">
            <button type="submit" class="btn btn-navy btn-sm" style="font-size:0.62rem;padding:4px 10px;"><%= existing ? 'Replace' : 'Upload' %></button>
          </form>
          <% if (existing) { %>
            <form method="POST" action="/admin/design/images/<%= existing._id %>/delete" style="margin:0;" onsubmit="return confirm('Remove this <%= ls.label %>?');">
              <button type="submit" class="btn btn-ghost btn-sm" style="font-size:0.58rem;padding:2px 6px;color:var(--slate);">Remove</button>
            </form>
          <% } %>
        </div>
      <% }) %>
    </div>

    <% const supportCount = brandImages.filter(i => i.slot === 'support').length; %>
    <div class="ep-hint" style="margin-top:14px;padding-top:10px;border-top:1px solid var(--border);">
      <%= supportCount %> additional support image<%= supportCount !== 1 ? 's' : '' %> uploaded. Manage these from the <a href="/admin/assets" style="color:var(--navy);">Assets page</a>.
    </div>
  </div>
</div>

<%# ─── 15. 3D MODELS (collapsed) ─── %>
<div class="editor-section" data-tab="brand">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    3D Models <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">
    <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:10px;">
      <label style="font-size:0.75rem;display:flex;align-items:center;gap:6px;cursor:pointer;">
        <input type="checkbox" id="toggle_model_header" <%= design.model_header_enabled === 'true' ? 'checked' : '' %> style="width:14px;height:14px;accent-color:var(--navy);" onchange="toggleModel('model_header_enabled', this.checked)"> 3D Header
      </label>
      <label style="font-size:0.75rem;display:flex;align-items:center;gap:6px;cursor:pointer;">
        <input type="checkbox" id="toggle_model_logo" <%= design.model_logo_enabled === 'true' ? 'checked' : '' %> style="width:14px;height:14px;accent-color:var(--navy);" onchange="toggleModel('model_logo_enabled', this.checked)"> 3D Logo
      </label>
    </div>
    <%
      const modelSlots = [
        { slot: 'model_header', label: 'Header Model' },
        { slot: 'model_logo',   label: 'Logo Model' },
      ];
    %>
    <% modelSlots.forEach(ms => { %>
      <% const existing = brandModels.find(m => m.slot === ms.slot); %>
      <div style="margin-bottom:8px;">
        <div style="font-size:0.68rem;color:var(--on-surface);margin-bottom:4px;"><%= ms.label %> <% if (existing) { %><span style="color:var(--success);font-size:0.6rem;">uploaded</span><% } %></div>
        <form method="POST" action="/admin/design/models" enctype="multipart/form-data" style="display:flex;gap:4px;align-items:center;flex-wrap:wrap;">
          <input type="hidden" name="slot" value="<%= ms.slot %>">
          <input type="hidden" name="label" value="<%= ms.label %>">
          <input type="file" name="model" accept=".glb,.gltf" required style="font-size:0.65rem;max-width:160px;">
          <button type="submit" class="btn btn-ghost btn-sm" style="font-size:0.6rem;padding:3px 8px;"><%= existing ? 'Replace' : 'Upload' %></button>
        </form>
      </div>
    <% }) %>
    <div class="ep-hint">GLB format recommended. Max 20MB.</div>
  </div>
</div>

<%# ─── 16. THEMES ─── %>
<div class="editor-section" data-tab="brand">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Themes <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">
    <%# Save current as theme — separate form target %>
    <div style="margin-bottom:12px;">
      <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;color:var(--slate);margin-bottom:6px;">SAVE CURRENT</div>
    </div>
    <!-- This is a nested form workaround: we use formaction on the button -->
    <div style="display:flex;gap:6px;margin-bottom:14px;">
      <input type="text" id="themeNameInput" placeholder="Theme name" style="flex:1;padding:6px 8px;border:1px solid var(--border);border-radius:2px;font-size:0.75rem;font-family:var(--font-body);">
      <button type="button" class="btn btn-navy btn-sm" style="font-size:0.62rem;white-space:nowrap;" onclick="saveTheme()">Save Theme</button>
    </div>

    <% if (themes && themes.length) { %>
      <% for (const t of themes) { %>
      <div class="theme-card">
        <div class="theme-card-swatches">
          <div style="background:<%= t.settings.color_primary || '#1C2B4A' %>;"></div>
          <div style="background:<%= t.settings.color_primary_deep || '#0F1B30' %>;"></div>
          <div style="background:<%= t.settings.color_accent || '#C9A848' %>;"></div>
          <div style="background:<%= t.settings.color_bg || '#F5F3EF' %>;"></div>
        </div>
        <div class="theme-card-body">
          <div class="theme-card-name"><%= t.name %></div>
          <div class="theme-card-meta"><%= t.settings.font_heading || 'Default' %> / <%= t.settings.font_body || 'Default' %> &middot; <%= new Date(t.createdAt).toLocaleDateString() %></div>
          <div class="theme-card-actions">
            <form method="POST" action="/admin/design/themes/<%= t._id %>/apply" style="display:inline;">
              <button type="submit" class="btn btn-navy btn-sm" style="font-size:0.58rem;padding:3px 8px;" onclick="return confirm('Apply this theme?')">Apply</button>
            </form>
            <form method="POST" action="/admin/design/themes/<%= t._id %>/delete" style="display:inline;" onsubmit="return confirm('Delete?')">
              <button type="submit" class="btn btn-danger btn-sm" style="font-size:0.58rem;padding:3px 8px;">Del</button>
            </form>
          </div>
        </div>
      </div>
      <% } %>
    <% } else { %>
      <div style="font-size:0.75rem;color:var(--slate);padding:12px 0;">No saved themes yet.</div>
    <% } %>
  </div>
</div>

</div><!-- /.editor-panel -->

<%# ═══════════ RIGHT PANEL — PREVIEW ═══════════ %>
