            <input type="text" name="service<%= i %>_image" value="<%= copy['service' + i + '_image'] || '' %>" placeholder="/images/...">
          </div>
        </div>
      </div>
      <% }); %>
      <button type="button" class="dp-rep-add" onclick="repAdd(this)">+ Add Service</button>
    </div>
