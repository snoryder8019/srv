  process4_title:        { sel: '.process-list .process-item:nth-child(4) .process-title,.steps .step:nth-child(4) .step-text h3', prop: 'innerHTML' },
  process4_desc:         { sel: '.process-list .process-item:nth-child(4) .process-desc,.steps .step:nth-child(4) .step-text p', prop: 'innerHTML' },

  // ── Contact ──
  // index.ejs: #contact .section-eyebrow, .section-heading, .contact-sub, .contact-detail-item, .contact-form, .btn-submit
