// Map vis_ checkboxes → iframe section selectors
var visMap = {
  vis_header:    '#main-nav,.nav,.tl-nav',
  vis_hero:      '.hero,.lb-hero',
  vis_marquee:   '.marquee-bar',
  vis_services:  '#services,.services,#features,.features,.lb-cards',
  vis_portfolio: '#portfolio',
  vis_about:     '#about,.advisor-section',
  vis_process:   '#process,.process,#how,.how',
  vis_pricing:   '#pricing,.pricing,.lb-pricing',
  vis_reviews:   '[id*="review"],.lb-testimonials',
  vis_contact:   '#contact,.contact,.lb-cta',
  vis_blog:      '[id*="blog"],[class*="blog-section"]',
  vis_footer:    'footer,.tl-footer',
  vis_admin_link:'.footer-copy span:last-child,.tl-footer-admin,[style*="margin-top:12px"] a[href*="auth"]',
  vis_qr:        '#qr-share-widget',
};

var _previewReady = false;
function pushToPreview() {
  var frame = document.getElementById('previewFrame');
  if (!frame) return;

  // Try both: direct DOM access AND postMessage
  var doc = null;
  try { doc = frame.contentDocument || frame.contentWindow.document; } catch(x) {}

  // ── 1) CSS variables + fonts ──
  var fontBodyVal = '', fontHeadVal = '';
  var css = ':root{';
  Object.keys(cssVarMap).forEach(function(name) {
    var inp = document.querySelector('input[name="' + name + '"]');
    if (!inp) return;
    var vars = cssVarMap[name];
    if (!inp.value) return; // skip empty — prevents invalid CSS like "--var: !important;"
    for (var vi = 0; vi < vars.length; vi++) css += vars[vi] + ':' + inp.value + ' !important;';
  });
  // Range/select inputs with transforms
  Object.keys(cssVarTransform).forEach(function(name) {
    var inp = document.querySelector('[name="' + name + '"]');
    if (!inp) return;
    var t = cssVarTransform[name];
    var val = t.transform(inp.value);
    for (var vi = 0; vi < t.vars.length; vi++) css += t.vars[vi] + ':' + val + ' !important;';
  });
  Object.keys(fontMap).forEach(function(name) {
    var sel = document.querySelector('select[name="' + name + '"]');
    if (!sel) return;
    css += fontMap[name] + ":'" + sel.value + "',sans-serif !important;";
    if (name === 'font_body') fontBodyVal = sel.value;
    if (name === 'font_heading') fontHeadVal = sel.value;
  });
  css += '}';
  // Force font on body + headings for templates that hardcode font-family (landing.ejs)
  if (fontBodyVal) css += " body,p,a,span,div,li,input,textarea,select,button{font-family:'" + fontBodyVal + "',sans-serif !important;}";
  if (fontHeadVal) css += " h1,h2,h3,h4,h5,h6{font-family:'" + fontHeadVal + "',serif !important;}";

  // ── 2) Layout ──
  var layoutSel = document.querySelector('select[name="landing_layout"]');
  var layout = layoutSel ? layoutSel.value : '';

  // ── Direct DOM approach ──
  if (doc && doc.body) {
    // CSS vars
    var style = doc.getElementById('slab-live-vars');
    if (!style) { style = doc.createElement('style'); style.id = 'slab-live-vars'; doc.head.appendChild(style); }
    style.textContent = css;

    // Load Google Fonts in iframe so font-family changes are visible
    if (fontBodyVal) loadFontInIframe(doc, fontBodyVal);
    if (fontHeadVal) loadFontInIframe(doc, fontHeadVal);

    // Layout
    if (layout) doc.body.setAttribute('data-layout', layout);

    // Body data-attributes (gradient, card-hover-accent, hero-pattern)
    Object.keys(bodyDataMap).forEach(function(name) {
      var el = document.querySelector('[name="' + name + '"]');
      if (!el) return;
      var val = el.type === 'checkbox' ? (el.checked ? 'true' : 'false') : el.value;
      doc.body.setAttribute('data-' + bodyDataMap[name], val);
    });

    // Copy fields — skip empty values to preserve server-rendered defaults
    var _doneHeroHeading = false, _doneContactHeading = false;
    Object.keys(copyMap).forEach(function(name) {
      var field = document.querySelector('[name="' + name + '"]');
      if (!field) return;
      var val = field.value;
      var m = copyMap[name];

      // Deduplicate: heroHeading/headingBrEm process both fields in one pass
      if (m.prop === 'heroHeading') {
        if (_doneHeroHeading) return;
        _doneHeroHeading = true;
        var hVal = (document.querySelector('[name="hero_heading"]') || {}).value || '';
        var emVal = (document.querySelector('[name="hero_heading_em"]') || {}).value || '';
        if (!hVal && !emVal) return; // no data — keep server defaults
        var el = doc.querySelector(m.sel);
        if (el) el.innerHTML = hVal + (emVal ? ' <em>' + emVal + '</em>' : '');
        return;
      }
      if (m.prop === 'headingBrEm') {
        if (_doneContactHeading) return;
        _doneContactHeading = true;
        var mf = document.querySelector('[name="contact_heading"]');
        var ef = document.querySelector('[name="contact_heading_em"]');
        var mVal = mf ? mf.value : '', eVal = ef ? ef.value : '';
        if (!mVal && !eVal) return;
        var el = doc.querySelector(m.sel);
        if (el) el.innerHTML = mVal + (eVal ? '<br><em>' + eVal + '</em>' : '');
        return;
      }

      // Skip empty values — don't wipe server-rendered content
      if (!val && m.prop !== 'href' && m.prop !== 'placeholder' && m.prop !== 'formLabel') return;

      var el = doc.querySelector(m.sel);
      if (!el) return;

      if (m.prop === 'childText') {
        var emInput = document.querySelector('[name="' + name + '_em"]');
        if (emInput && emInput.value) { el.innerHTML = val + ' <em>' + emInput.value + '</em>'; }
        else if (val) { el.textContent = val; }
      } else if (m.prop === 'textContent') { el.textContent = val; }
      else if (m.prop === 'innerHTML') { el.innerHTML = val; }
      else if (m.prop === 'href') { el.setAttribute('href', val || '#'); }
      else if (m.prop === 'placeholder') { el.setAttribute('placeholder', val); }
      else if (m.prop === 'formLabel') {
        var ff = el.closest ? el.closest('.form-field') : null;
        var lbl = ff ? ff.querySelector('label') : null;
        if (lbl) lbl.textContent = val;
      }
    });

    // Visibility
    Object.keys(visMap).forEach(function(key) {
      var cb = document.querySelector('input[name="' + key + '"]');
      if (!cb) return;
      visMap[key].split(',').forEach(function(s) {
        var els = doc.querySelectorAll(s.trim());
        for (var i = 0; i < els.length; i++) els[i].style.display = cb.checked ? '' : 'none';
      });
    });

    _previewReady = true;
    return;
  }

  // ── Fallback: postMessage ──
  if (frame.contentWindow) {
    var msgCopy = [];
    var _pmDoneHero = false, _pmDoneContact = false;
    Object.keys(copyMap).forEach(function(name) {
      var field = document.querySelector('[name="' + name + '"]');
      if (!field) return;
      var val = field.value, m = copyMap[name];
      if (m.prop === 'heroHeading') {
        if (_pmDoneHero) return; _pmDoneHero = true;
        var hVal = (document.querySelector('[name="hero_heading"]') || {}).value || '';
        var emVal = (document.querySelector('[name="hero_heading_em"]') || {}).value || '';
        if (hVal || emVal) msgCopy.push({ sel: m.sel, prop: 'innerHTML', val: hVal + (emVal ? ' <em>' + emVal + '</em>' : '') });
        return;
      }
      if (m.prop === 'headingBrEm') {
        if (_pmDoneContact) return; _pmDoneContact = true;
        var mf = document.querySelector('[name="contact_heading"]');
        var ef = document.querySelector('[name="contact_heading_em"]');
        var mVal = mf ? mf.value : '', eVal = ef ? ef.value : '';
        if (mVal || eVal) msgCopy.push({ sel: m.sel, prop: 'innerHTML', val: mVal + (eVal ? '<br><em>' + eVal + '</em>' : '') });
        return;
      }
      if (!val && m.prop !== 'href' && m.prop !== 'placeholder' && m.prop !== 'formLabel') return;
      if (m.prop === 'childText') {
        var ei = document.querySelector('[name="' + name + '_em"]');
        if (ei && ei.value) msgCopy.push({ sel: m.sel, prop: 'innerHTML', val: val + ' <em>' + ei.value + '</em>' });
        else if (val) msgCopy.push({ sel: m.sel, prop: 'textContent', val: val });
      } else if (m.prop === 'formLabel') {
        msgCopy.push({ sel: m.sel, prop: 'formLabel', val: val });
      } else {
        msgCopy.push({ sel: m.sel, prop: m.prop, val: val });
      }
    });
    var vis = {};
    Object.keys(visMap).forEach(function(key) {
      var cb = document.querySelector('input[name="' + key + '"]');
      if (cb) vis[visMap[key]] = cb.checked;
    });
    var cssVarsObj = {};
    Object.keys(cssVarMap).forEach(function(n) { var inp = document.querySelector('input[name="' + n + '"]'); if (inp) { var vars = cssVarMap[n]; for (var vi = 0; vi < vars.length; vi++) cssVarsObj[vars[vi]] = inp.value; } });
    Object.keys(cssVarTransform).forEach(function(n) { var inp = document.querySelector('[name="' + n + '"]'); if (inp) { var t = cssVarTransform[n]; var val = t.transform(inp.value); for (var vi = 0; vi < t.vars.length; vi++) cssVarsObj[t.vars[vi]] = val; } });
    Object.keys(fontMap).forEach(function(n) { var sel = document.querySelector('select[name="' + n + '"]'); if (sel) cssVarsObj[fontMap[n]] = "'" + sel.value + "',sans-serif"; });
    var extraCss = '';
    if (fontBodyVal) extraCss += " body,p,a,span,div,li,input,textarea,select,button{font-family:'" + fontBodyVal + "',sans-serif !important;}";
    if (fontHeadVal) extraCss += " h1,h2,h3,h4,h5,h6{font-family:'" + fontHeadVal + "',serif !important;}";
    var fonts = [];
    if (fontBodyVal && _GF[fontBodyVal]) fonts.push('https://fonts.googleapis.com/css2?family=' + _GF[fontBodyVal] + '&display=swap');
    if (fontHeadVal && _GF[fontHeadVal]) fonts.push('https://fonts.googleapis.com/css2?family=' + _GF[fontHeadVal] + '&display=swap');
    var bodyAttrs = {};
    Object.keys(bodyDataMap).forEach(function(name) {
      var el = document.querySelector('[name="' + name + '"]');
      if (!el) return;
      bodyAttrs[bodyDataMap[name]] = el.type === 'checkbox' ? (el.checked ? 'true' : 'false') : el.value;
    });
    frame.contentWindow.postMessage({ type: 'slab-live-preview', cssVars: cssVarsObj, extraCss: extraCss, layout: layout, copy: msgCopy, visibility: vis, fonts: fonts, bodyAttrs: bodyAttrs }, '*');
  }
}

// Debounced push
var pushTimer;
function debouncedPush() {
  clearTimeout(pushTimer);
  pushTimer = setTimeout(pushToPreview, 80);
}

// ── Layout change → preview-only reload (no save until "Save All") ──
var _layoutSelect = document.querySelector('select[name="landing_layout"]');
if (_layoutSelect) {
  _layoutSelect.addEventListener('change', function() {
    var val = _layoutSelect.value;
    var f = document.getElementById('previewFrame');
    f.src = '/?preview_layout=' + val + '&t=' + Date.now();
  });
}

// ── Server-rendered fields: section_animation & snap_enabled need iframe reload to take effect ──
// (These drive EJS conditionals that inject JS/CSS blocks — cannot be patched via DOM/postMessage)
var _reloadFields = ['section_animation', 'snap_enabled'];
_reloadFields.forEach(function(name) {
  var el = document.querySelector('[name="' + name + '"]');
  if (!el) return;
  el.addEventListener('change', function() {
    // Save this key first via the /key API, then reload preview
    fetch('/admin/design/key', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ key: name, value: el.type === 'checkbox' ? (el.checked ? 'true' : 'false') : el.value })
    }).then(function() {
      var f = document.getElementById('previewFrame');
      f.src = '/?t=' + Date.now();
    });
  });
});

// Listen to all form changes
document.querySelectorAll('.editor-panel input, .editor-panel select, .editor-panel textarea').forEach(function(el) {
  el.addEventListener('input', debouncedPush);
  el.addEventListener('change', debouncedPush);
});

// Push once iframe loads — retry to handle slow renders
var _pvFrame = document.getElementById('previewFrame');
var _pvStatus = document.querySelector('.preview-bar span[style*="auto"]');
_pvFrame.addEventListener('load', function() {
  setTimeout(function() {
    pushToPreview();
    if (_pvStatus) _pvStatus.textContent = _previewReady ? 'Live Preview' : 'Preview (no DOM access — using postMessage)';
  }, 300);
  setTimeout(pushToPreview, 1000);
});
// Initial push after page load
setTimeout(function() {
  pushToPreview();
  if (_pvStatus) _pvStatus.textContent = _previewReady ? 'Live Preview' : 'Preview (connecting...)';
}, 500);

// ── Sync color pickers with hex display + swatches ──
document.querySelectorAll('input[type=color]').forEach(function(picker) {
  var textInput = picker.parentElement.querySelector('input[type=text]');
  picker.addEventListener('input', function() {
    if (textInput) textInput.value = picker.value;
    // Update palette swatches (the 6 primary ones)
    var swatches = document.querySelectorAll('#swatch-preview .swatch');
    var names = ['color_primary','color_primary_deep','color_primary_mid','color_accent','color_accent_light','color_bg'];
    names.forEach(function(n, i) {
      var inp = document.querySelector('input[name="' + n + '"]');
      if (inp && swatches[i]) swatches[i].style.background = inp.value;
    });
  });
});
// Also sync the range-slider label displays
document.querySelectorAll('input[type=range]').forEach(function(range) {
  range.addEventListener('input', function() {
    // Update the label that shows the current value (contains the value in its text)
    var label = range.closest('.ep-field') && range.closest('.ep-field').querySelector('label');
    if (!label) return;
    var text = label.textContent;
    // Replace trailing (Npx) or (N%) or (Ndeg) pattern
    label.textContent = text.replace(/\(\d+(?:px|%|deg)?\)/, '(' + range.value + (range.name === 'hero_overlay_opacity' ? '%' : range.name === 'card_border_radius' ? 'px' : range.name === 'gradient_angle' ? '\u00b0' : '') + ')');
  });
});

// ── 3D model toggle ──
function toggleModel(key, enabled) {
  fetch('/admin/design/toggle-model', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ key: key, value: enabled ? 'true' : 'false' })
  }).then(function(r) { return r.json(); });
}

// ── Save theme via fetch (avoids nested form issue) ──
function saveTheme() {
  var name = document.getElementById('themeNameInput').value.trim();
  if (!name) { alert('Enter a theme name'); return; }
  var form = document.createElement('form');
  form.method = 'POST';
  form.action = '/admin/design/themes';
  var inp = document.createElement('input');
  inp.type = 'hidden'; inp.name = 'theme_name'; inp.value = name;
  form.appendChild(inp);
  document.body.appendChild(form);
  form.submit();
}

// ══════════════════════════════════════════════════════════════════════════════
// DESIGN AGENT — chat panel (matches blog/pages pattern)
// ══════════════════════════════════════════════════════════════════════════════
(function() {
  var panel    = document.getElementById('agentPanel');
  var overlay  = document.getElementById('agentOverlay');
  var toggle   = document.getElementById('agentToggle');
  var closeBtn = document.getElementById('agentClose');
  var msgs     = document.getElementById('agentMsgs');
  var input    = document.getElementById('agentInput');
  var sendBtn  = document.getElementById('agentSend');
  var agentMessages = [];

  // ── Open / close ──
  function openPanel()  { panel.classList.add('open'); overlay.classList.add('active'); input.focus(); }
  function closePanel() { panel.classList.remove('open'); overlay.classList.remove('active'); }
  if (toggle)  toggle.addEventListener('click', openPanel);
  if (closeBtn) closeBtn.addEventListener('click', closePanel);
  if (overlay) overlay.addEventListener('click', closePanel);

  // ── Message display ──
  function appendMsg(role, text, extra) {
    var el = document.createElement('div');
    el.className = 'ap-msg ' + role;
    el.innerHTML = '<div class="ap-bubble">' + text + '</div>';
    if (extra) el.innerHTML += extra;
    msgs.appendChild(el);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function showTyping() {
    var el = document.createElement('div');
    el.id = 'apTyping'; el.className = 'ap-msg assistant';
    el.innerHTML = '<div class="ap-typing"><div class="ap-typing-dot"></div><div class="ap-typing-dot"></div><div class="ap-typing-dot"></div></div>';
    msgs.appendChild(el);
    msgs.scrollTop = msgs.scrollHeight;
  }
  function hideTyping() { var t = document.getElementById('apTyping'); if (t) t.remove(); }

  // ── Collect current design state ──
  function getCurrentDesign() {
    var d = {};
    document.querySelectorAll('.editor-panel input, .editor-panel select, .editor-panel textarea').forEach(function(el) {
      if (!el.name) return;
      if (el.type === 'checkbox') d[el.name] = el.checked ? 'true' : 'false';
      else d[el.name] = el.value;
    });
    return d;
  }

  // ── Fill form fields + trigger live preview ──
  function fillField(key, val) {
    var el = document.querySelector('[name="' + key + '"]');
    if (!el) return;
    if (el.type === 'checkbox') {
      el.checked = val === 'true';
    } else {
      el.value = val;
      if (el.type === 'color') {
        var textInput = el.parentElement && el.parentElement.querySelector('input[type=text]');
        if (textInput) textInput.value = val;
      }
    }
    el.classList.add('ai-filled');
    el.dispatchEvent(new Event('input', { bubbles: true }));
    el.dispatchEvent(new Event('change', { bubbles: true }));
  }

  // ── Send to agent ──
  async function sendAgent() {
    var text = input.value.trim();
    if (!text) return;
    input.value = '';
    input.style.height = 'auto';
    sendBtn.disabled = true;

    agentMessages.push({ role: 'user', content: text });
    appendMsg('user', text.replace(/&/g,'&amp;').replace(/</g,'&lt;'));
    showTyping();

    try {
      var res = await fetch('/admin/design/agent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          messages: agentMessages,
          currentDesign: getCurrentDesign()
        })
      });
      var data = await res.json();
      hideTyping();

      if (data.error) {
        appendMsg('assistant', 'Error: ' + data.error);
        return;
      }

      var fills = Object.entries(data.fill || {});
      fills.forEach(function(pair) { fillField(pair[0], pair[1]); });
      agentMessages.push({ role: 'assistant', content: data.message });

      var extra = '';
      if (fills.length) {
        var details = fills.map(function(pair) {
          var k = pair[0], v = pair[1];
          var isColor = k.indexOf('color_') === 0;
          var swatch = isColor
            ? '<span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:' + v + ';vertical-align:middle;margin-right:3px;border:1px solid rgba(0,0,0,0.1);"></span>'
            : '';
          return '<span style="font-size:0.65rem;color:var(--slate);">' + k + ': ' + swatch + v + '</span>';
        }).join('<br>');
        extra = '<div class="ap-fill-notice" style="margin-top:4px;">&#10003; ' +
          fills.length + ' field' + (fills.length > 1 ? 's' : '') + ' updated</div>' +
          '<div style="margin-top:2px;">' + details + '</div>';
      }
      appendMsg('assistant', data.message, extra);
    } catch(e) {
      hideTyping();
      appendMsg('assistant', 'Connection error. Please try again.');
    } finally {
      sendBtn.disabled = false;
      input.focus();
    }
  }

  // ── Input handlers ──
  sendBtn.addEventListener('click', sendAgent);
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendAgent(); }
  });
  input.addEventListener('input', function() {
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 120) + 'px';
  });

  // ── Quick prompts ──
  var quickPrompts = [
    'Bold dark palette',
    'Warm earthy tones',
    'Write hero copy',
    'Modern minimal look',
    'Toggle off blog & QR',
    'Suggest all service copy'
  ];
  var quickContainer = document.getElementById('apQuick');
  if (quickContainer) {
    // Shuffle and pick 4
    var shuffled = quickPrompts.sort(function() { return 0.5 - Math.random(); }).slice(0, 4);
    shuffled.forEach(function(q) {
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'ap-quick-btn';
      btn.textContent = q;
      btn.addEventListener('click', function() {
        input.value = q;
        sendAgent();
      });
      quickContainer.appendChild(btn);
    });
  }
})();
</script>
