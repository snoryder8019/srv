  <div class="preview-bar">
    <button type="button" class="btn btn-ghost" onclick="setViewport('desktop')" id="vpDesktop" style="border-color:var(--navy);">Desktop</button>
    <button type="button" class="btn btn-ghost" onclick="setViewport('tablet')" id="vpTablet">Tablet</button>
    <button type="button" class="btn btn-ghost" onclick="setViewport('mobile')" id="vpMobile">Mobile</button>
    <button type="button" class="btn btn-ghost" onclick="previewReload()">Refresh</button>
    <span style="margin-left:auto;font-size:0.65rem;color:var(--slate);">Live Preview</span>
