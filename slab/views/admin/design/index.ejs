<%- include('../partials/head', { title }) %>
<%- include('../partials/sidebar', { user, page }) %>

<style>
/* Color picker rows — color swatch + hex input side by side, always fits */
.color-row { display: flex; gap: 10px; align-items: center; }
.color-row input[type=color] { width: 44px; height: 38px; flex-shrink: 0; padding: 2px; border-radius: 2px; cursor: pointer; }
.color-row input[type=text] { flex: 1; min-width: 0; }

/* Section visibility grid — minimum 2 cols on very small screens */
.vis-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; }
@media (max-width: 420px) {
  .vis-grid { grid-template-columns: 1fr; }
}

/* Swatch preview row wraps */
.swatch-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 20px; }
.swatch { width: 52px; height: 36px; border-radius: 2px; flex-shrink: 0; }

/* Theme cards */
.theme-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
.theme-card { border: 1px solid var(--ivory-mid); border-radius: 2px; overflow: hidden; background: var(--white); }
.theme-card-swatches { display: flex; height: 32px; }
.theme-card-swatches div { flex: 1; }
.theme-card-body { padding: 12px; }
.theme-card-name { font-size: 0.85rem; font-weight: 600; color: var(--dark); margin-bottom: 4px; }
.theme-card-meta { font-size: 0.65rem; color: var(--slate); margin-bottom: 10px; }
.theme-card-actions { display: flex; gap: 6px; }

/* Site preview */
.preview-wrap { position: relative; border: 1px solid var(--ivory-mid); border-radius: 2px; overflow: hidden; background: var(--white); }
.preview-toolbar { display: flex; align-items: center; gap: 12px; padding: 10px 16px; background: var(--ivory); border-bottom: 1px solid var(--ivory-mid); }
.preview-toolbar .btn { padding: 5px 10px; font-size: 0.65rem; }
.preview-viewport { width: 100%; transition: all 0.3s; margin: 0 auto; display: block; }
.preview-viewport.mobile { max-width: 375px; }
.preview-viewport.tablet { max-width: 768px; }
.preview-iframe { width: 100%; height: 500px; border: none; background: var(--white); }

/* AI-filled indicator */
.ai-filled { border-color: var(--success) !important; background: rgba(21,128,61,0.04) !important; }
.ai-badge { display: none; font-size: 0.6rem; background: rgba(21,128,61,0.12); color: var(--success); padding: 2px 6px; border-radius: 2px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; }
.ai-badge.visible { display: inline-block; }
.revert-btn { display: none; font-size: 0.6rem; color: var(--slate); cursor: pointer; background: none; border: 1px solid var(--ivory-mid); padding: 2px 6px; border-radius: 2px; font-family: 'Jost',sans-serif; }
.revert-btn.visible { display: inline-block; }
.revert-btn:hover { color: var(--danger); border-color: rgba(185,28,28,0.3); }

/* ── AI AGENT BUTTON ── */
.agent-btn {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 8px 16px; border-radius: 2px;
  background: linear-gradient(135deg, #6B3FA0, #8B5FC0);
  color: #E8D08A; border: 1px solid rgba(201,168,72,0.3);
  font-family: 'Jost', sans-serif; font-size: 0.72rem;
  font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
  cursor: pointer; transition: all 0.2s;
}
.agent-btn:hover { background: linear-gradient(135deg, #8B5FC0, #6B3FA0); border-color: rgba(201,168,72,0.6); }
.agent-btn .agent-icon { font-size: 1rem; }

/* ── AGENT PANEL ── */
#agentPanel {
  position: fixed; top: 0; right: -440px; width: 420px; height: 100vh;
  background: var(--white); border-left: 1px solid var(--ivory-mid);
  box-shadow: -8px 0 40px rgba(15,27,48,0.12);
  z-index: 500; display: flex; flex-direction: column;
  transition: right 0.3s cubic-bezier(0.4,0,0.2,1);
}
#agentPanel.open { right: 0; }

.agent-panel-header {
  padding: 18px 20px; border-bottom: 1px solid var(--ivory-mid);
  background: linear-gradient(135deg, #4A2078, #6B3FA0);
  display: flex; align-items: center; justify-content: space-between;
  flex-shrink: 0;
}
.agent-panel-title {
  font-family: 'Cormorant Garamond', serif; font-size: 1.2rem;
  font-weight: 400; color: var(--white); display: flex; align-items: center; gap: 10px;
}
.agent-panel-title .dot {
  width: 8px; height: 8px; border-radius: 50%; background: #4ADE80;
  animation: pulse 2s infinite;
}
@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
.agent-panel-close {
  background: none; border: none; color: rgba(255,255,255,0.5);
  font-size: 1.3rem; cursor: pointer; padding: 4px; line-height: 1;
  transition: color 0.15s;
}
.agent-panel-close:hover { color: var(--white); }

.agent-panel-sub {
  padding: 10px 20px; background: rgba(107,63,160,0.08);
  border-bottom: 1px solid rgba(107,63,160,0.15); flex-shrink: 0;
  font-size: 0.72rem; color: #6B3FA0; letter-spacing: 0.04em;
}

.agent-msgs {
  flex: 1; overflow-y: auto; padding: 16px 20px;
  display: flex; flex-direction: column; gap: 12px;
}

.agent-msg { display: flex; flex-direction: column; gap: 4px; }
.agent-msg.user { align-items: flex-end; }
.agent-msg.assistant { align-items: flex-start; }

.agent-bubble {
  max-width: 88%; padding: 10px 14px; border-radius: 4px;
  font-size: 0.85rem; line-height: 1.5; font-weight: 300;
}
.agent-msg.user .agent-bubble {
  background: #6B3FA0; color: var(--white);
  border-radius: 4px 4px 1px 4px;
}
.agent-msg.assistant .agent-bubble {
  background: var(--ivory); color: var(--dark); border: 1px solid var(--ivory-mid);
  border-radius: 4px 4px 4px 1px;
}

.agent-fill-notice {
  font-size: 0.7rem; color: var(--success); font-weight: 600;
  letter-spacing: 0.06em; text-transform: uppercase;
  display: flex; align-items: center; gap: 5px; margin-top: 4px;
}

.agent-panel-footer { padding: 16px 20px; border-top: 1px solid var(--ivory-mid); flex-shrink: 0; }
.agent-quick-btns {
  display: flex; gap: 6px; margin-bottom: 10px; flex-wrap: wrap;
}
.agent-quick-btn {
  font-size: 0.67rem; padding: 5px 10px; border-radius: 2px;
  border: 1px solid var(--ivory-mid); background: var(--white);
  color: var(--slate); cursor: pointer; font-family: 'Jost', sans-serif;
  font-weight: 500; letter-spacing: 0.04em; transition: all 0.15s;
  white-space: nowrap;
}
.agent-quick-btn:hover { border-color: #6B3FA0; color: #6B3FA0; }
.agent-input-row { display: flex; gap: 8px; }
.agent-input {
  flex: 1; padding: 10px 14px; border: 1px solid var(--ivory-mid);
  border-radius: 2px; font-family: 'Jost', sans-serif; font-size: 0.88rem;
  font-weight: 300; color: var(--dark); outline: none; resize: none;
}
.agent-input:focus { border-color: #6B3FA0; }
.agent-send {
  width: 40px; flex-shrink: 0; background: #6B3FA0; color: var(--white);
  border: none; border-radius: 2px; font-size: 1.1rem; cursor: pointer;
  transition: background 0.15s;
}
.agent-send:hover { background: #8B5FC0; }
.agent-send:disabled { opacity: 0.4; cursor: default; }

.typing-indicator {
  display: flex; gap: 4px; padding: 12px 14px; align-self: flex-start;
}
.typing-dot {
  width: 7px; height: 7px; border-radius: 50%; background: var(--slate);
  animation: typingBounce 1.2s infinite;
}
.typing-dot:nth-child(2) { animation-delay: 0.15s; }
.typing-dot:nth-child(3) { animation-delay: 0.3s; }
@keyframes typingBounce { 0%,60%,100%{transform:translateY(0);opacity:0.3;} 30%{transform:translateY(-6px);opacity:1;} }

#agentOverlay {
  display: none; position: fixed; inset: 0; background: rgba(15,27,48,0.35);
  z-index: 499; backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);
}
#agentOverlay.active { display: block; }
</style>

<div class="topbar">
  <div class="topbar-title">Design & Settings</div>
  <div class="topbar-actions">
    <button type="button" class="agent-btn" id="agentToggle">
      <span class="agent-icon">&#9830;</span> Design Agent
    </button>
  </div>
</div>
<div class="content">
  <%- include('../partials/advisory', { needs: 'ai' }) %>

  <% if (saved) { %>
    <div class="alert alert-success">Settings saved successfully.</div>
  <% } %>
  <% if (error) { %>
    <div class="alert alert-error">Failed to save settings. Please try again.</div>
  <% } %>

  <!-- ═══════════ SITE PREVIEW ═══════════ -->
  <div class="card" style="margin-bottom:24px;">
    <div class="card-title">Site Preview</div>
    <div class="preview-wrap">
      <div class="preview-toolbar">
        <button type="button" class="btn btn-ghost" onclick="setViewport('desktop')" id="vpDesktop" style="border-color:var(--navy);">Desktop</button>
        <button type="button" class="btn btn-ghost" onclick="setViewport('tablet')" id="vpTablet">Tablet</button>
        <button type="button" class="btn btn-ghost" onclick="setViewport('mobile')" id="vpMobile">Mobile</button>
        <span style="margin-left:auto;font-size:0.65rem;color:var(--slate);">Live preview — save settings to update</span>
        <button type="button" class="btn btn-ghost" onclick="document.getElementById('previewFrame').src=document.getElementById('previewFrame').src" style="font-size:0.6rem;">Refresh</button>
      </div>
      <div class="preview-viewport" id="previewViewport">
        <iframe src="/" class="preview-iframe" id="previewFrame" sandbox="allow-same-origin allow-scripts"></iframe>
      </div>
    </div>
  </div>

  <form method="POST" action="/admin/design" id="designForm">

    <!-- COLOR PALETTE -->
    <div class="card">
      <div class="card-title">Color Palette</div>
      <div class="form-grid cols-3">
        <div class="form-field">
          <label>Primary Color <span class="ai-badge" id="badge-color_primary">AI</span> <button type="button" class="revert-btn" id="revert-color_primary" data-key="color_primary">Revert</button></label>
          <div class="color-row">
            <input type="color" name="color_primary" value="<%= design.color_primary %>" id="field-color_primary">
            <input type="text" value="<%= design.color_primary %>" readonly onfocus="this.select()">
          </div>
          <span style="font-size:0.65rem;color:var(--slate);">Main brand color — navs, headings, buttons</span>
        </div>
        <div class="form-field">
          <label>Primary Deep <span class="ai-badge" id="badge-color_primary_deep">AI</span> <button type="button" class="revert-btn" id="revert-color_primary_deep" data-key="color_primary_deep">Revert</button></label>
          <div class="color-row">
            <input type="color" name="color_primary_deep" value="<%= design.color_primary_deep %>" id="field-color_primary_deep">
            <input type="text" value="<%= design.color_primary_deep %>" readonly>
          </div>
          <span style="font-size:0.65rem;color:var(--slate);">Darkest shade — hero bg, footer</span>
        </div>
        <div class="form-field">
          <label>Primary Mid <span class="ai-badge" id="badge-color_primary_mid">AI</span> <button type="button" class="revert-btn" id="revert-color_primary_mid" data-key="color_primary_mid">Revert</button></label>
          <div class="color-row">
            <input type="color" name="color_primary_mid" value="<%= design.color_primary_mid %>" id="field-color_primary_mid">
            <input type="text" value="<%= design.color_primary_mid %>" readonly>
          </div>
          <span style="font-size:0.65rem;color:var(--slate);">Mid-tone — borders, hover states</span>
        </div>
        <div class="form-field">
          <label>Accent Color <span class="ai-badge" id="badge-color_accent">AI</span> <button type="button" class="revert-btn" id="revert-color_accent" data-key="color_accent">Revert</button></label>
          <div class="color-row">
            <input type="color" name="color_accent" value="<%= design.color_accent %>" id="field-color_accent">
            <input type="text" value="<%= design.color_accent %>" readonly>
          </div>
          <span style="font-size:0.65rem;color:var(--slate);">Gold accent — highlights, badges, CTA accents</span>
        </div>
        <div class="form-field">
          <label>Accent Light <span class="ai-badge" id="badge-color_accent_light">AI</span> <button type="button" class="revert-btn" id="revert-color_accent_light" data-key="color_accent_light">Revert</button></label>
          <div class="color-row">
            <input type="color" name="color_accent_light" value="<%= design.color_accent_light %>" id="field-color_accent_light">
            <input type="text" value="<%= design.color_accent_light %>" readonly>
          </div>
          <span style="font-size:0.65rem;color:var(--slate);">Light accent — text on dark backgrounds</span>
        </div>
        <div class="form-field">
          <label>Background Color <span class="ai-badge" id="badge-color_bg">AI</span> <button type="button" class="revert-btn" id="revert-color_bg" data-key="color_bg">Revert</button></label>
          <div class="color-row">
            <input type="color" name="color_bg" value="<%= design.color_bg %>" id="field-color_bg">
            <input type="text" value="<%= design.color_bg %>" readonly>
          </div>
          <span style="font-size:0.65rem;color:var(--slate);">Section backgrounds — ivory/cream tones</span>
        </div>
      </div>

      <!-- Live preview swatches -->
      <div style="margin-top:20px;">
        <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--slate);margin-bottom:10px;">Live Palette Preview</div>
        <div class="swatch-row" id="swatch-preview">
          <div class="swatch" style="background:<%= design.color_primary %>;" title="Primary"></div>
          <div class="swatch" style="background:<%= design.color_primary_deep %>;" title="Primary Deep"></div>
          <div class="swatch" style="background:<%= design.color_primary_mid %>;" title="Primary Mid"></div>
          <div class="swatch" style="background:<%= design.color_accent %>;" title="Accent"></div>
          <div class="swatch" style="background:<%= design.color_accent_light %>;" title="Accent Light"></div>
          <div class="swatch" style="background:<%= design.color_bg %>;border:1px solid var(--ivory-mid);" title="Background"></div>
        </div>
      </div>
    </div>

    <!-- FONTS -->
    <div class="card mt-24">
      <div class="card-title">Typography</div>
      <div class="form-grid">
        <div class="form-field">
          <label>Heading Font <span class="ai-badge" id="badge-font_heading">AI</span> <button type="button" class="revert-btn" id="revert-font_heading" data-key="font_heading">Revert</button></label>
          <select name="font_heading" id="field-font_heading">
            <% ['Cormorant Garamond','Playfair Display','Lora','Merriweather','Libre Baskerville'].forEach(f => { %>
              <option value="<%= f %>" <%= design.font_heading === f ? 'selected' : '' %>><%= f %></option>
            <% }) %>
          </select>
          <span style="font-size:0.65rem;color:var(--slate);">Used for page titles, section headings, hero text</span>
        </div>
        <div class="form-field">
          <label>Body Font <span class="ai-badge" id="badge-font_body">AI</span> <button type="button" class="revert-btn" id="revert-font_body" data-key="font_body">Revert</button></label>
          <select name="font_body" id="field-font_body">
            <% ['Jost','Inter','Poppins','Raleway','Nunito','DM Sans'].forEach(f => { %>
              <option value="<%= f %>" <%= design.font_body === f ? 'selected' : '' %>><%= f %></option>
            <% }) %>
          </select>
          <span style="font-size:0.65rem;color:var(--slate);">Used for body text, navigation, UI elements</span>
        </div>
      </div>
      <div style="margin-top:20px;padding:20px;background:var(--ivory);border-radius:2px;border:1px solid var(--ivory-mid);">
        <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--slate);margin-bottom:12px;">Font Preview (after save)</div>
        <div style="font-size:1.4rem;color:var(--dark);margin-bottom:6px;"><em>Heading: <%= design.font_heading %></em></div>
        <div style="font-size:0.9rem;color:var(--slate);font-weight:300;">Body: <%= design.font_body %> — The quick brown fox jumps over the lazy dog</div>
      </div>
    </div>

    <!-- SECTION VISIBILITY -->
    <div class="card mt-24">
      <div class="card-title">Section Visibility</div>
      <p style="font-size:0.85rem;color:var(--slate);font-weight:300;margin-bottom:24px;">Control which sections appear on your landing page. Hidden sections are completely removed from the public page.</p>
      <div class="vis-grid">
        <%
          const sections = [
            { key: 'vis_hero',      label: 'Hero', desc: 'Top banner / headline' },
            { key: 'vis_services',  label: 'Services', desc: 'Service cards section' },
            { key: 'vis_portfolio', label: 'Portfolio', desc: 'Work showcase grid' },
            { key: 'vis_about',     label: 'About', desc: 'Agency intro & stats' },
            { key: 'vis_process',   label: 'Process', desc: 'How it works steps' },
            { key: 'vis_reviews',   label: 'Reviews', desc: 'Google reviews' },
            { key: 'vis_contact',   label: 'Contact', desc: 'Contact form' },
            { key: 'vis_blog',      label: 'Blog Section', desc: 'Latest posts on home' },
          ];
        %>
        <% sections.forEach(s => { %>
          <label style="display:flex;align-items:flex-start;gap:12px;padding:16px;background:var(--ivory);border:1px solid var(--ivory-mid);border-radius:2px;cursor:pointer;transition:border-color 0.15s;" onmouseover="this.style.borderColor='var(--navy-mid)'" onmouseout="this.style.borderColor='var(--ivory-mid)'">
            <input type="checkbox" name="<%= s.key %>" id="field-<%= s.key %>" <%= design[s.key] !== 'false' && (s.key !== 'vis_blog' || design[s.key] === 'true') ? 'checked' : '' %> style="margin-top:2px;width:16px;height:16px;accent-color:var(--navy);flex-shrink:0;appearance:auto;-webkit-appearance:auto;">
            <div>
              <div style="font-size:0.82rem;font-weight:600;color:var(--dark);margin-bottom:2px;"><%= s.label %> <span class="ai-badge" id="badge-<%= s.key %>">AI</span></div>
              <div style="font-size:0.72rem;color:var(--slate);font-weight:300;"><%= s.desc %></div>
            </div>
          </label>
        <% }) %>
      </div>
    </div>

    <!-- LANDING PAGE LAYOUT -->
    <div class="card mt-24">
      <div class="card-title">Landing Page Layout <span class="ai-badge" id="badge-landing_layout">AI</span></div>
      <p style="font-size:0.85rem;color:var(--slate);font-weight:300;margin-bottom:20px;">Choose a layout for your landing page. Each layout rearranges the hero, services, and sections with a distinct look and feel.</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:16px;">
        <%
          const layouts = [
            { value: 'classic',  label: 'Classic',  desc: 'Split hero, 3-column services, editorial feel', icon: '◧' },
            { value: 'bold',     label: 'Bold',     desc: 'Full-width hero overlay, large service cards', icon: '◼' },
            { value: 'minimal',  label: 'Minimal',  desc: 'Centered hero, airy whitespace, clean lines', icon: '○' },
            { value: 'magazine', label: 'Magazine',  desc: 'Background hero with overlapping content card', icon: '◨' },
            { value: 'dark',     label: 'Dark',     desc: 'Dark-themed throughout with accent highlights', icon: '◉' },
          ];
        %>
        <% layouts.forEach(l => { %>
          <label style="display:flex;flex-direction:column;padding:20px 16px;border:2px solid <%= design.landing_layout === l.value ? 'var(--navy)' : 'var(--ivory-mid)' %>;border-radius:2px;cursor:pointer;transition:border-color 0.2s,box-shadow 0.2s;background:<%= design.landing_layout === l.value ? 'var(--ivory)' : 'var(--white)' %>;<%= design.landing_layout === l.value ? 'box-shadow:0 2px 12px rgba(28,43,74,0.1);' : '' %>" onmouseover="if(!this.querySelector('input').checked)this.style.borderColor='var(--navy-mid)'" onmouseout="if(!this.querySelector('input').checked)this.style.borderColor='var(--ivory-mid)'">
            <input type="radio" name="landing_layout" value="<%= l.value %>" id="field-landing_layout-<%= l.value %>" <%= design.landing_layout === l.value ? 'checked' : '' %> style="display:none;" onchange="this.closest('.card').querySelectorAll('label[style]').forEach(el=>{el.style.borderColor='var(--ivory-mid)';el.style.background='var(--white)';el.style.boxShadow='none'});this.closest('label').style.borderColor='var(--navy)';this.closest('label').style.background='var(--ivory)';this.closest('label').style.boxShadow='0 2px 12px rgba(28,43,74,0.1)'">
            <div style="font-size:2rem;text-align:center;margin-bottom:8px;color:var(--navy);"><%= l.icon %></div>
            <div style="font-size:0.82rem;font-weight:600;color:var(--dark);text-align:center;margin-bottom:4px;"><%= l.label %></div>
            <div style="font-size:0.68rem;color:var(--slate);text-align:center;line-height:1.5;"><%= l.desc %></div>
          </label>
        <% }) %>
      </div>
    </div>

    <!-- DISPLAY LAYOUTS -->
    <div class="card" style="margin-top:24px;">
      <div class="card-title">Display Layouts</div>
      <p style="font-size:0.85rem;color:var(--slate);margin-bottom:20px;">Control how portfolio items and blog posts are displayed in their listing sections.</p>
      <div class="form-grid cols-3">
        <div class="form-field">
          <label>Navbar Logo <span class="ai-badge" id="badge-nav_logo_display">AI</span></label>
          <select name="nav_logo_display" id="field-nav_logo_display" style="width:100%;padding:8px 10px;border:1.5px solid var(--ivory-mid);border-radius:2px;font-family:'Jost',sans-serif;font-size:0.82rem;background:var(--ivory);color:var(--dark);">
            <option value="text" <%= design.nav_logo_display === 'text' ? 'selected' : '' %>>Text only</option>
            <option value="image" <%= design.nav_logo_display === 'image' ? 'selected' : '' %>>Image only</option>
            <option value="both" <%= design.nav_logo_display === 'both' ? 'selected' : '' %>>Image + Text</option>
          </select>
          <span style="font-size:0.72rem;color:var(--slate);margin-top:4px;display:block;">How your brand appears in the navbar. Upload a logo in Brand Images below.</span>
        </div>
        <div class="form-field">
          <label>Portfolio Layout <span class="ai-badge" id="badge-portfolio_layout">AI</span></label>
          <select name="portfolio_layout" id="field-portfolio_layout" style="width:100%;padding:8px 10px;border:1.5px solid var(--ivory-mid);border-radius:2px;font-family:'Jost',sans-serif;font-size:0.82rem;background:var(--ivory);color:var(--dark);">
            <option value="grid" <%= design.portfolio_layout === 'grid' ? 'selected' : '' %>>Grid (equal columns)</option>
            <option value="masonry" <%= design.portfolio_layout === 'masonry' ? 'selected' : '' %>>Masonry (variable height)</option>
            <option value="carousel" <%= design.portfolio_layout === 'carousel' ? 'selected' : '' %>>Carousel (horizontal scroll)</option>
            <option value="list" <%= design.portfolio_layout === 'list' ? 'selected' : '' %>>List (text wrap)</option>
          </select>
          <span style="font-size:0.72rem;color:var(--slate);margin-top:4px;display:block;">How portfolio items appear on the public site.</span>
        </div>
        <div class="form-field">
          <label>Blog Listing Layout <span class="ai-badge" id="badge-blog_layout">AI</span></label>
          <select name="blog_layout" id="field-blog_layout" style="width:100%;padding:8px 10px;border:1.5px solid var(--ivory-mid);border-radius:2px;font-family:'Jost',sans-serif;font-size:0.82rem;background:var(--ivory);color:var(--dark);">
            <option value="grid" <%= design.blog_layout === 'grid' ? 'selected' : '' %>>Grid (card columns)</option>
            <option value="list" <%= design.blog_layout === 'list' ? 'selected' : '' %>>List (image + text rows)</option>
            <option value="masonry" <%= design.blog_layout === 'masonry' ? 'selected' : '' %>>Masonry (variable height cards)</option>
            <option value="featured" <%= design.blog_layout === 'featured' ? 'selected' : '' %>>Featured (first post large)</option>
          </select>
          <span style="font-size:0.72rem;color:var(--slate);margin-top:4px;display:block;">How blog posts appear on the public site.</span>
        </div>
      </div>
    </div>

    <!-- AI ASSISTANT -->
    <div class="card" style="margin-top:24px;">
      <div class="card-title">AI Assistant</div>
      <p style="font-size:0.85rem;color:var(--slate);margin-bottom:20px;">Configure the master agent that appears on your dashboard.</p>
      <div class="form-grid">
        <div class="form-field">
          <label>Agent Name <span class="ai-badge" id="badge-agent_name">AI</span></label>
          <input type="text" name="agent_name" id="field-agent_name" value="<%= design.agent_name %>" placeholder="Assistant">
        </div>
        <div class="form-field">
          <label>Greeting Message <span class="ai-badge" id="badge-agent_greeting">AI</span></label>
          <input type="text" name="agent_greeting" id="field-agent_greeting" value="<%= design.agent_greeting %>" placeholder="Hi! What would you like to create?">
        </div>
      </div>
      <p style="margin-top:12px;font-size:0.78rem;color:var(--slate);">MCP endpoint: <code style="background:var(--ivory);padding:2px 6px;border-radius:3px;">/admin/master-agent/mcp</code> — compatible with Claude Desktop &amp; Claude Code.</p>
    </div>

    <!-- SAVE -->
    <div class="form-actions" style="margin-top:24px;display:flex;gap:12px;flex-wrap:wrap;">
      <button type="submit" class="btn btn-navy">Save Settings</button>
      <a href="/admin" class="btn btn-ghost">Cancel</a>
    </div>

  </form>

  <!-- ═══════════ SAVED THEMES ═══════════ -->
  <div id="themes" class="card" style="margin-top:24px;">
    <div class="card-title">Saved Themes</div>
    <p style="font-size:0.85rem;color:var(--slate);font-weight:300;margin-bottom:20px;">Save your current color palette and layout as a theme. Apply saved themes to quickly switch between looks.</p>

    <!-- Save current as theme -->
    <form method="POST" action="/admin/design/themes" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:20px;">
      <input type="text" name="theme_name" placeholder="Theme name (e.g. Summer Vibes)" required style="padding:8px 12px;border:1px solid var(--ivory-mid);border-radius:2px;font-family:'Jost',sans-serif;font-size:0.85rem;max-width:260px;flex:1;">
      <button type="submit" class="btn btn-navy btn-sm" style="font-size:0.68rem;">Save Current as Theme</button>
    </form>

    <% if (themes && themes.length) { %>
      <div class="theme-grid">
        <% for (const t of themes) { %>
          <div class="theme-card">
            <div class="theme-card-swatches">
              <div style="background:<%= t.settings.color_primary || '#1C2B4A' %>;"></div>
              <div style="background:<%= t.settings.color_primary_deep || '#0F1B30' %>;"></div>
              <div style="background:<%= t.settings.color_primary_mid || '#2E4270' %>;"></div>
              <div style="background:<%= t.settings.color_accent || '#C9A848' %>;"></div>
              <div style="background:<%= t.settings.color_accent_light || '#E8D08A' %>;"></div>
              <div style="background:<%= t.settings.color_bg || '#F5F3EF' %>;"></div>
            </div>
            <div class="theme-card-body">
              <div class="theme-card-name"><%= t.name %></div>
              <div class="theme-card-meta"><%= t.settings.font_heading || 'Default' %> / <%= t.settings.font_body || 'Default' %> &middot; <%= new Date(t.createdAt).toLocaleDateString() %></div>
              <div class="theme-card-actions">
                <form method="POST" action="/admin/design/themes/<%= t._id %>/apply" style="display:inline;">
                  <button type="submit" class="btn btn-navy btn-sm" style="font-size:0.6rem;" onclick="return confirm('Apply this theme? Current unsaved changes will be lost.')">Apply</button>
                </form>
                <form method="POST" action="/admin/design/themes/<%= t._id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this theme?')">
                  <button type="submit" class="btn btn-danger btn-sm" style="font-size:0.6rem;">Delete</button>
                </form>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% } else { %>
      <div class="empty" style="padding:32px;">
        <div class="empty-icon">&#127912;</div>
        <p>No saved themes yet. Save your current settings as a theme above.</p>
      </div>
    <% } %>
  </div>

  <!-- ═══════════ BRAND IMAGES ═══════════ -->
  <div id="brand-images" class="card" style="margin-top:24px;">
    <div class="card-title">Brand Images</div>
    <p style="font-size:0.85rem;color:var(--slate);font-weight:300;margin-bottom:20px;">Upload logos, banners, and support images. These are available site-wide and in the email campaign builder.</p>

    <!-- Logo slots -->
    <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--slate);margin-bottom:12px;">Logos</div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-bottom:24px;">
      <%
        const logoSlots = [
          { slot: 'logo_primary', label: 'Primary Logo', desc: 'Main full-color logo' },
          { slot: 'logo_white', label: 'White Logo', desc: 'For dark backgrounds' },
          { slot: 'logo_icon', label: 'Icon / Favicon', desc: 'Square mark or favicon' },
        ];
      %>
      <% for (const ls of logoSlots) { %>
        <% const existing = brandImages.find(i => i.slot === ls.slot); %>
        <div style="border:1px solid var(--ivory-mid);border-radius:2px;overflow:hidden;">
          <div style="aspect-ratio:16/10;background:var(--ivory);display:flex;align-items:center;justify-content:center;overflow:hidden;<%= ls.slot === 'logo_white' ? 'background:var(--navy-deep);' : '' %>">
            <% if (existing) { %>
              <img src="<%= existing.url %>" alt="<%= ls.label %>" style="max-width:100%;max-height:100%;object-fit:contain;">
            <% } else { %>
              <span style="font-size:0.78rem;color:var(--slate);">No image</span>
            <% } %>
          </div>
          <div style="padding:10px 12px;">
            <div style="font-size:0.78rem;font-weight:600;color:var(--dark);margin-bottom:2px;"><%= ls.label %></div>
            <div style="font-size:0.65rem;color:var(--slate);margin-bottom:8px;"><%= ls.desc %></div>
            <form method="POST" action="/admin/design/images" enctype="multipart/form-data" style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
              <input type="hidden" name="slot" value="<%= ls.slot %>">
              <input type="hidden" name="label" value="<%= ls.label %>">
              <input type="file" name="image" accept="image/*" required style="font-size:0.72rem;max-width:160px;">
              <button type="submit" class="btn btn-ghost btn-sm" style="font-size:0.65rem;"><%= existing ? 'Replace' : 'Upload' %></button>
              <% if (existing) { %>
              </form>
              <form method="POST" action="/admin/design/images/<%= existing._id %>/delete" onsubmit="return confirm('Remove this logo?')" style="display:inline;">
                <button class="btn btn-danger btn-sm" style="font-size:0.65rem;">Remove</button>
              </form>
              <% } else { %>
              </form>
              <% } %>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Banner slot -->
    <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--slate);margin-bottom:12px;">Banner</div>
    <%
      const bannerImg = brandImages.find(i => i.slot === 'banner');
    %>
    <div style="border:1px solid var(--ivory-mid);border-radius:2px;overflow:hidden;margin-bottom:24px;">
      <div style="aspect-ratio:3/1;background:var(--ivory);display:flex;align-items:center;justify-content:center;overflow:hidden;">
        <% if (bannerImg) { %>
          <img src="<%= bannerImg.url %>" alt="Banner" style="width:100%;height:100%;object-fit:cover;">
        <% } else { %>
          <span style="font-size:0.78rem;color:var(--slate);">No banner uploaded</span>
        <% } %>
      </div>
      <div style="padding:10px 12px;display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
        <form method="POST" action="/admin/design/images" enctype="multipart/form-data" style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
          <input type="hidden" name="slot" value="banner">
          <input type="hidden" name="label" value="Banner">
          <input type="file" name="image" accept="image/*" required style="font-size:0.72rem;max-width:200px;">
          <button type="submit" class="btn btn-ghost btn-sm" style="font-size:0.65rem;"><%= bannerImg ? 'Replace' : 'Upload' %></button>
        </form>
        <% if (bannerImg) { %>
        <form method="POST" action="/admin/design/images/<%= bannerImg._id %>/delete" onsubmit="return confirm('Remove banner?')" style="display:inline;">
          <button class="btn btn-danger btn-sm" style="font-size:0.65rem;">Remove</button>
        </form>
        <% } %>
        <span style="font-size:0.65rem;color:var(--slate);margin-left:auto;">Recommended: 1200x400 or wider</span>
      </div>
    </div>

    <!-- Support images -->
    <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--slate);margin-bottom:12px;">Support Images</div>
    <p style="font-size:0.78rem;color:var(--slate);margin-bottom:12px;">Extra images for emails, social, and marketing materials. Upload as many as needed.</p>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-bottom:16px;">
      <% const supportImages = brandImages.filter(i => i.slot === 'support'); %>
      <% for (const si of supportImages) { %>
      <div style="border:1px solid var(--ivory-mid);border-radius:2px;overflow:hidden;">
        <div style="aspect-ratio:1/1;background:var(--ivory);display:flex;align-items:center;justify-content:center;overflow:hidden;">
          <img src="<%= si.url %>" alt="<%= si.label %>" style="width:100%;height:100%;object-fit:cover;">
        </div>
        <div style="padding:8px 10px;">
          <div style="font-size:0.72rem;font-weight:500;color:var(--dark);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="<%= si.label %>"><%= si.label %></div>
          <div style="display:flex;gap:4px;margin-top:6px;align-items:center;">
            <button class="btn btn-ghost btn-sm" style="font-size:0.6rem;" onclick="navigator.clipboard.writeText('<%= si.url %>');this.textContent='Copied!';setTimeout(()=>this.textContent='Copy URL',1500)">Copy URL</button>
            <form method="POST" action="/admin/design/images/<%= si._id %>/delete" onsubmit="return confirm('Delete this image?')" style="display:inline;">
              <button class="btn btn-danger btn-sm" style="font-size:0.6rem;">Del</button>
            </form>
          </div>
        </div>
      </div>
      <% } %>
    </div>

    <form method="POST" action="/admin/design/images/support" enctype="multipart/form-data" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
      <input type="file" name="image" accept="image/*" required style="font-size:0.72rem;max-width:200px;">
      <input type="text" name="label" placeholder="Image label" style="padding:6px 10px;border:1px solid var(--ivory-mid);border-radius:2px;font-family:'Jost',sans-serif;font-size:0.82rem;max-width:180px;">
      <button type="submit" class="btn btn-navy btn-sm" style="font-size:0.68rem;">Upload Support Image</button>
    </form>
  </div>

</div>

</div></div>

<!-- Agent Panel -->
<div id="agentOverlay"></div>
<div id="agentPanel">
  <div class="agent-panel-header">
    <div class="agent-panel-title">
      <span class="dot"></span>
      Design Agent
    </div>
    <button class="agent-panel-close" id="agentClose">&#10005;</button>
  </div>
  <div class="agent-panel-sub">
    Powered by Qwen 2.5 &middot; Updates colors, fonts, layouts & visibility
  </div>
  <div class="agent-msgs" id="agentMsgs">
    <div class="agent-msg assistant">
      <div class="agent-bubble">
        Hello! I'm your design assistant. I can help you tweak colors, switch fonts, change layouts, or configure section visibility.<br><br>
        Try: <em>"Switch to a modern teal and coral palette"</em> or <em>"Use Playfair Display for headings"</em>
      </div>
    </div>
  </div>
  <div class="agent-panel-footer">
    <div class="agent-quick-btns" id="designQuick"></div>
    <script>
    (function(){
      const pool = [
        { label: 'Earthy Palette', prompt: 'Create a warm, earthy color palette with terracotta and sage tones' },
        { label: 'Modern Blue', prompt: 'Switch to a clean modern blue and white palette' },
        { label: 'Classic Fonts', prompt: 'Set fonts to Playfair Display headings and Inter body text' },
        { label: 'Show All Sections', prompt: 'Show all sections on the homepage including blog' },
        { label: 'Luxury Dark', prompt: 'Suggest a professional, luxury-feel color scheme with dark tones' },
        { label: 'Minimal Light', prompt: 'Create a minimal, airy palette with lots of white space and soft grays' },
        { label: 'Bold & Vibrant', prompt: 'Switch to a bold, vibrant color palette with high contrast' },
        { label: 'Ocean Tones', prompt: 'Create a coastal color palette with deep navy and seafoam green' },
        { label: 'Modern Sans', prompt: 'Set fonts to DM Sans for headings and Nunito for body text' },
        { label: 'Grid Portfolio', prompt: 'Switch portfolio layout to grid and blog to featured' },
        { label: 'Hide Reviews', prompt: 'Hide the reviews section and show the blog section' },
        { label: 'Magazine Layout', prompt: 'Switch the landing layout to magazine style' },
      ];
      for(let i=pool.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[pool[i],pool[j]]=[pool[j],pool[i]];}
      const el=document.getElementById('designQuick');
      let idx=0;
      function render(){
        el.innerHTML='';
        const batch=pool.slice(idx,idx+5);
        if(batch.length<5) batch.push(...pool.slice(0,5-batch.length));
        batch.forEach(s=>{
          const b=document.createElement('button');b.className='agent-quick-btn';b.dataset.prompt=s.prompt;b.textContent=s.label;
          b.onclick=()=>{document.getElementById('agentInput').value=s.prompt;document.getElementById('agentSend').click();};
          el.appendChild(b);
        });
        const cyc=document.createElement('button');cyc.className='ap-cycle-btn';cyc.style.cssText='opacity:0.5;font-size:0.7rem;padding:5px 8px;border:1px solid var(--ivory-mid);background:var(--white);color:var(--slate);cursor:pointer;border-radius:2px;';cyc.textContent='\u267B';cyc.title='More suggestions';
        cyc.onclick=(e)=>{e.stopPropagation();idx=(idx+3)%pool.length;render();};
        el.appendChild(cyc);
      }
      render();
    })();
    </script>
    <div class="agent-input-row">
      <textarea class="agent-input" id="agentInput" placeholder="Ask the agent to update design settings..." rows="1"></textarea>
      <button class="agent-send" id="agentSend">&#8593;</button>
    </div>
  </div>
</div>

<script>
// ── Preview viewport switcher ──
function setViewport(mode) {
  var vp = document.getElementById('previewViewport');
  vp.classList.remove('mobile', 'tablet');
  if (mode !== 'desktop') vp.classList.add(mode);
  ['Desktop','Tablet','Mobile'].forEach(function(m) {
    var btn = document.getElementById('vp' + m);
    btn.style.borderColor = m.toLowerCase() === mode ? 'var(--navy)' : '';
  });
}

// ── Sync color inputs with hex display + swatches ──
document.querySelectorAll('input[type=color]').forEach(function(picker) {
  var textInput = picker.nextElementSibling;
  picker.addEventListener('input', function() {
    if (textInput) textInput.value = picker.value;
    var swatches = document.querySelectorAll('#swatch-preview div');
    var inputs = document.querySelectorAll('input[type=color]');
    inputs.forEach(function(p, i) { if (swatches[i]) swatches[i].style.background = p.value; });
  });
});

// ── Agent panel logic ──
(function() {
  var originals = {};
  document.querySelectorAll('[id^="field-"]').forEach(function(el) {
    var key = el.id.replace('field-', '');
    if (el.type === 'checkbox') originals[key] = el.checked;
    else if (el.tagName === 'SELECT') originals[key] = el.value;
    else originals[key] = el.value;
  });

  var aiFilledKeys = new Set();
  var messages = [];

  // Panel open/close
  var panel = document.getElementById('agentPanel');
  var overlay = document.getElementById('agentOverlay');
  document.getElementById('agentToggle').addEventListener('click', openPanel);
  document.getElementById('agentClose').addEventListener('click', closePanel);
  overlay.addEventListener('click', closePanel);

  function openPanel() { panel.classList.add('open'); overlay.classList.add('active'); }
  function closePanel() { panel.classList.remove('open'); overlay.classList.remove('active'); }

  // Quick prompt buttons
  document.querySelectorAll('.agent-quick-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('agentInput').value = btn.dataset.prompt;
      sendMessage();
    });
  });

  // Send on Enter (not shift+enter)
  var input = document.getElementById('agentInput');
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  });
  document.getElementById('agentSend').addEventListener('click', sendMessage);

  // Auto-resize textarea
  input.addEventListener('input', function() {
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 120) + 'px';
  });

  function getCurrentDesign() {
    var d = {};
    document.querySelectorAll('[id^="field-"]').forEach(function(el) {
      var key = el.id.replace('field-', '');
      if (el.type === 'checkbox') d[key] = el.checked ? 'true' : 'false';
      else d[key] = el.value;
    });
    return d;
  }

  function appendMessage(role, text, fillCount) {
    var msgs = document.getElementById('agentMsgs');
    var msgEl = document.createElement('div');
    msgEl.className = 'agent-msg ' + role;
    var bubble = document.createElement('div');
    bubble.className = 'agent-bubble';
    bubble.textContent = text;
    msgEl.appendChild(bubble);
    if (fillCount && fillCount > 0) {
      var notice = document.createElement('div');
      notice.className = 'agent-fill-notice';
      notice.textContent = '\u2713 ' + fillCount + ' setting' + (fillCount > 1 ? 's' : '') + ' updated';
      msgEl.appendChild(notice);
    }
    msgs.appendChild(msgEl);
    msgs.scrollTop = msgs.scrollHeight;
    return msgEl;
  }

  function showTyping() {
    var msgs = document.getElementById('agentMsgs');
    var el = document.createElement('div');
    el.id = 'typingIndicator';
    el.className = 'typing-indicator';
    el.innerHTML = '<div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>';
    msgs.appendChild(el);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function hideTyping() {
    var el = document.getElementById('typingIndicator');
    if (el) el.remove();
  }

  function fillField(key, value) {
    var el = document.getElementById('field-' + key);
    if (!el) return;

    if (!aiFilledKeys.has(key)) {
      if (el.type === 'checkbox') originals[key] = el.checked;
      else originals[key] = el.value;
    }

    if (el.type === 'checkbox') {
      el.checked = (value === 'true' || value === true);
    } else if (el.type === 'color') {
      el.value = value;
      // Also update the hex text input next to it
      var txt = el.nextElementSibling;
      if (txt) txt.value = value;
    } else if (el.tagName === 'SELECT') {
      el.value = value;
    } else {
      el.value = value;
    }

    el.classList.add('ai-filled');
    aiFilledKeys.add(key);

    var badge = document.getElementById('badge-' + key);
    if (badge) badge.classList.add('visible');
    var revertBtn = document.getElementById('revert-' + key);
    if (revertBtn) revertBtn.classList.add('visible');

    // Update swatches if color field
    if (key.startsWith('color_')) {
      var swatches = document.querySelectorAll('#swatch-preview div');
      var colorInputs = document.querySelectorAll('input[type=color]');
      colorInputs.forEach(function(p, i) { if (swatches[i]) swatches[i].style.background = p.value; });
    }
  }

  // Revert individual field
  document.querySelectorAll('.revert-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var key = btn.dataset.key;
      var el = document.getElementById('field-' + key);
      if (!el) return;

      if (el.type === 'checkbox') el.checked = originals[key];
      else if (el.type === 'color') {
        el.value = originals[key];
        var txt = el.nextElementSibling;
        if (txt) txt.value = originals[key];
      } else el.value = originals[key];

      el.classList.remove('ai-filled');
      aiFilledKeys.delete(key);
      var badge = document.getElementById('badge-' + key);
      if (badge) badge.classList.remove('visible');
      btn.classList.remove('visible');

      // Update swatches
      var swatches = document.querySelectorAll('#swatch-preview div');
      var colorInputs = document.querySelectorAll('input[type=color]');
      colorInputs.forEach(function(p, i) { if (swatches[i]) swatches[i].style.background = p.value; });
    });
  });

  async function sendMessage() {
    var text = input.value.trim();
    if (!text) return;
    input.value = '';
    input.style.height = 'auto';
    document.getElementById('agentSend').disabled = true;

    messages.push({ role: 'user', content: text });
    appendMessage('user', text);
    showTyping();

    try {
      var res = await fetch('/admin/design/agent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: messages, currentDesign: getCurrentDesign() })
      });
      var data = await res.json();
      hideTyping();

      if (data.error) {
        appendMessage('assistant', 'Error: ' + data.error, 0);
      } else {
        var fillKeys = Object.keys(data.fill || {});
        fillKeys.forEach(function(key) { fillField(key, data.fill[key]); });
        messages.push({ role: 'assistant', content: data.message });
        appendMessage('assistant', data.message, fillKeys.length);
      }
    } catch (err) {
      hideTyping();
      appendMessage('assistant', 'Connection error. Please try again.', 0);
    } finally {
      document.getElementById('agentSend').disabled = false;
      input.focus();
    }
  }
})();

// Pre-fill from dashboard master agent
(function() {
  try {
    var raw = sessionStorage.getItem('slab_agent_fill');
    if (!raw) return;
    var data = JSON.parse(raw);
    if (data.department !== 'design' || !data.fill) return;
    sessionStorage.removeItem('slab_agent_fill');
    Object.entries(data.fill).forEach(function(e) { if (e[1]) fillField(e[0], e[1]); });
  } catch(ex) { /* ignore */ }
})();
</script>
<script src="/js/tours/design.js"></script>

</body>
