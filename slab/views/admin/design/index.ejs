    <div class="ep-field">
      <label>Section Label</label>
      <input type="text" name="process_label" value="<%= copy.process_label || '' %>">
    </div>
    <div class="ep-row">
      <div class="ep-field">
        <label>Heading</label>
        <input type="text" name="process_heading" value="<%= copy.process_heading || '' %>">
      </div>
      <div class="ep-field">
        <label>Heading Emphasis</label>
        <input type="text" name="process_heading_em" value="<%= copy.process_heading_em || '' %>">
      </div>
    </div>
    <%
      const _procIdx = new Set();
      Object.keys(copy).forEach(k => { const m = k.match(/^process(\d+)_/); if (m) _procIdx.add(parseInt(m[1], 10)); });
      const _procArr = [..._procIdx].sort((a, b) => a - b);
      if (_procArr.length === 0) _procArr.push(1, 2, 3, 4);
    %>
    <div class="dp-repeater"
         data-prefix="process"
         data-noun="Step"
         data-fields='[{"key":"title","label":"Title","type":"text"},{"key":"desc","label":"Description","type":"textarea","rows":2}]'>
      <% _procArr.forEach(function(i, iArr) { %>
      <div class="dp-rep-item" data-idx="<%= i %>">
        <div class="dp-rep-head">
          <span>Step <%= i %></span>
          <div class="dp-rep-actions">
            <button type="button" data-dir="-1" onclick="repMove(this, -1)" title="Move up"<%= iArr === 0 ? ' disabled' : '' %>>↑</button>
            <button type="button" data-dir="1" onclick="repMove(this, 1)" title="Move down"<%= iArr === _procArr.length - 1 ? ' disabled' : '' %>>↓</button>
            <button type="button" class="dp-rep-remove" onclick="repRemove(this)" title="Remove this step">✕</button>
          </div>
        </div>
        <div class="ep-field">
          <label>Title</label>
          <input type="text" name="process<%= i %>_title" value="<%= copy['process' + i + '_title'] || '' %>">
        </div>
        <div class="ep-field">
          <label>Description</label>
          <textarea name="process<%= i %>_desc" rows="2"><%= copy['process' + i + '_desc'] || '' %></textarea>
        </div>
      </div>
      <% }); %>
      <button type="button" class="dp-rep-add" onclick="repAdd(this)">+ Add Step</button>
    </div>
  </div>
</div>

<%# ─── 8b. CUSTOM SECTIONS ─── %>
<%# ─── 8b. CUSTOM SECTIONS — inline copy editors, one accordion per section ─── %>
<% _validSections.forEach(function(sec) { %>
  <% const _tmpl = _sectionTemplates[sec.type] || {};
     const _fields = _tmpl.fields || [];
     const _hidden = sec.visible === false;
  %>
  <div class="editor-section cs-edit" data-tab="copy" data-cs-id="<%= sec._id %>">
    <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
      <span><%= _tmpl.icon || '▦' %> <%= sec.label || 'Custom Section' %></span>
      <% if (_hidden) { %><span style="font-size:0.55rem;font-weight:700;letter-spacing:0.12em;background:rgba(0,0,0,0.06);color:var(--slate);padding:1px 5px;border-radius:2px;margin-left:6px;">HIDDEN</span><% } %>
      <span class="arrow">&#9654;</span>
    </button>
    <div class="editor-section-body">
      <div class="ep-hint" style="margin-bottom:8px;">
        <strong><%= _tmpl.label || sec.type %></strong> — order & visibility under Section Visibility (Sections tab).
      </div>
      <%
        // Partition template fields into singletons vs. repeatable groups
        // (cards1_*..cardN_* and q1/a1..qN/aN). Anything outside known
        // repeatable patterns renders as a regular singleton input.
        const _cardRx = /^card(\d+)_(title|body|image|link)$/;
        const _faqRx = /^(q|a)(\d+)$/;
        const _singletons = [];
        _fields.forEach(function(f) {
          if (sec.type === 'cards' && _cardRx.test(f.key)) return;
          if (sec.type === 'faq' && _faqRx.test(f.key)) return;
          _singletons.push(f);
        });
      %>
      <% _singletons.forEach(function(f) { %>
        <div class="ep-field">
          <label><%= f.label %></label>
          <% if (f.type === 'textarea') { %>
            <textarea data-cs-field="<%= f.key %>" rows="<%= f.rows || 2 %>"><%= (sec.fields && sec.fields[f.key]) || '' %></textarea>
          <% } else { %>
            <input type="text" data-cs-field="<%= f.key %>" value="<%= (sec.fields && sec.fields[f.key]) ? String(sec.fields[f.key]).replace(/"/g, '&quot;') : '' %>">
          <% } %>
        </div>
      <% }); %>

      <% if (sec.type === 'cards') { %>
        <%
          const _cardIdx = new Set();
          Object.keys(sec.fields || {}).forEach(k => { const m = k.match(_cardRx); if (m) _cardIdx.add(parseInt(m[1], 10)); });
          const _cardArr = [..._cardIdx].sort((a, b) => a - b);
          if (_cardArr.length === 0) _cardArr.push(1, 2, 3, 4);
        %>
        <div class="dp-repeater cs-repeater" style="margin-top:10px;"
             data-prefix="card"
             data-noun="Card"
             data-fields='[{"key":"title","label":"Title","type":"text"},{"key":"body","label":"Body","type":"textarea","rows":2},{"key":"image","label":"Image URL","type":"text","placeholder":"/images/..."},{"key":"link","label":"Link URL","type":"text","placeholder":"/products/sku or https://..."}]'>
          <% _cardArr.forEach(function(i, iArr) { %>
          <div class="dp-rep-item" data-idx="<%= i %>">
            <div class="dp-rep-head">
              <span>Card <%= i %></span>
              <div class="dp-rep-actions">
                <button type="button" data-dir="-1" onclick="repMove(this, -1)" title="Move up"<%= iArr === 0 ? ' disabled' : '' %>>↑</button>
                <button type="button" data-dir="1" onclick="repMove(this, 1)" title="Move down"<%= iArr === _cardArr.length - 1 ? ' disabled' : '' %>>↓</button>
                <button type="button" class="dp-rep-remove" onclick="csRepRemove(this)" title="Remove this card">✕</button>
              </div>
            </div>
            <div class="ep-field">
              <label>Title</label>
              <input type="text" data-cs-field="card<%= i %>_title" value="<%= (sec.fields && sec.fields['card' + i + '_title']) ? String(sec.fields['card' + i + '_title']).replace(/"/g, '&quot;') : '' %>">
            </div>
            <div class="ep-field">
              <label>Body</label>
              <textarea data-cs-field="card<%= i %>_body" rows="2"><%= (sec.fields && sec.fields['card' + i + '_body']) || '' %></textarea>
            </div>
            <div class="ep-field">
              <label>Image URL</label>
              <input type="text" data-cs-field="card<%= i %>_image" value="<%= (sec.fields && sec.fields['card' + i + '_image']) ? String(sec.fields['card' + i + '_image']).replace(/"/g, '&quot;') : '' %>" placeholder="/images/...">
            </div>
            <div class="ep-field">
              <label>Link URL <span style="color:var(--muted);font-weight:400;font-size:0.78em;">(makes the card clickable)</span></label>
              <input type="text" data-cs-field="card<%= i %>_link" value="<%= (sec.fields && sec.fields['card' + i + '_link']) ? String(sec.fields['card' + i + '_link']).replace(/"/g, '&quot;') : '' %>" placeholder="/products/sku or https://...">
            </div>
          </div>
          <% }); %>
          <button type="button" class="dp-rep-add" onclick="csRepAdd(this)">+ Add Card</button>
        </div>
      <% } else if (sec.type === 'faq') { %>
        <%
          const _faqIdx = new Set();
          Object.keys(sec.fields || {}).forEach(k => { const m = k.match(/^q(\d+)$/); if (m) _faqIdx.add(parseInt(m[1], 10)); });
          const _faqArr = [..._faqIdx].sort((a, b) => a - b);
          if (_faqArr.length === 0) _faqArr.push(1, 2, 3, 4, 5);
        %>
        <div class="dp-repeater cs-repeater" style="margin-top:10px;"
             data-prefix="q"
             data-noun="Q&amp;A"
             data-fields='[{"keyMode":"only","prefix":"q","labelTpl":"Question {n}","type":"text"},{"keyMode":"only","prefix":"a","labelTpl":"Answer {n}","type":"textarea","rows":2}]'>
          <% _faqArr.forEach(function(i, iArr) { %>
          <div class="dp-rep-item" data-idx="<%= i %>">
            <div class="dp-rep-head">
              <span>Q&amp;A <%= i %></span>
              <div class="dp-rep-actions">
                <button type="button" data-dir="-1" onclick="repMove(this, -1)" title="Move up"<%= iArr === 0 ? ' disabled' : '' %>>↑</button>
                <button type="button" data-dir="1" onclick="repMove(this, 1)" title="Move down"<%= iArr === _faqArr.length - 1 ? ' disabled' : '' %>>↓</button>
                <button type="button" class="dp-rep-remove" onclick="csRepRemove(this)" title="Remove this Q&amp;A">✕</button>
              </div>
            </div>
            <div class="ep-field">
              <label>Question <%= i %></label>
              <input type="text" data-cs-field="q<%= i %>" value="<%= (sec.fields && sec.fields['q' + i]) ? String(sec.fields['q' + i]).replace(/"/g, '&quot;') : '' %>">
            </div>
            <div class="ep-field">
              <label>Answer <%= i %></label>
              <textarea data-cs-field="a<%= i %>" rows="2"><%= (sec.fields && sec.fields['a' + i]) || '' %></textarea>
            </div>
          </div>
          <% }); %>
          <button type="button" class="dp-rep-add" onclick="csRepAdd(this)">+ Add Q&amp;A</button>
        </div>
      <% } %>

      <div style="display:flex;gap:6px;margin-top:10px;">
        <button type="button" class="btn btn-navy" style="font-size:0.62rem;padding:5px 12px;letter-spacing:0.08em;" onclick="csSave('<%= sec._id %>', this)">Save Section</button>
        <button type="button" class="btn btn-ghost" style="font-size:0.62rem;padding:5px 12px;letter-spacing:0.08em;color:#8B1C1C;" onclick="csDelete('<%= sec._id %>', this)">Delete</button>
      </div>
    </div>
  </div>
<% }); %>

<%# ── + Add Custom Section (always visible in Copy tab) ── %>
<div class="editor-section open" data-tab="copy" id="cs-add-section">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
