<%# ─── 9. PRICING TIERS ─── %>
<div class="editor-section">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Pricing Tiers <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">
    <div class="ep-field">
      <label>Section Heading</label>
      <input type="text" name="startup_price_heading" value="<%= copy.startup_price_heading || '' %>" placeholder="e.g. Simple Pricing">
    </div>
    <div class="ep-field">
      <label>Section Description</label>
      <textarea name="startup_price_desc" rows="2" placeholder="Pricing section subheading"><%= copy.startup_price_desc || '' %></textarea>
    </div>
    <div class="ep-row">
      <div class="ep-field">
        <label>CTA Button Text</label>
        <input type="text" name="startup_price_cta" value="<%= copy.startup_price_cta || '' %>" placeholder="Get Started">
      </div>
      <div class="ep-field">
        <label>Footer Note</label>
        <input type="text" name="startup_price_note" value="<%= copy.startup_price_note || '' %>" placeholder="e.g. Cancel anytime">
      </div>
    </div>

    <%# ── Tier 1 (startup / primary) ── %>
    <div style="margin-top:10px;padding-top:8px;border-top:1px solid var(--border);">
      <div style="font-size:0.62rem;font-weight:600;color:var(--slate);letter-spacing:0.1em;margin-bottom:6px;">TIER 1 (PRIMARY)</div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Label</label>
          <input type="text" name="startup_price_label" value="<%= copy.startup_price_label || '' %>" placeholder="e.g. Monthly">
        </div>
        <div class="ep-field">
          <label>Amount</label>
          <input type="text" name="startup_price_amount" value="<%= copy.startup_price_amount || '' %>" placeholder="$50">
        </div>
      </div>
      <div class="ep-field">
        <label>Unit</label>
        <input type="text" name="startup_price_unit" value="<%= copy.startup_price_unit || '' %>" placeholder="/mo">
      </div>
      <div class="ep-field">
        <label>Features (comma-separated)</label>
        <textarea name="startup_price_features" rows="2" placeholder="Feature 1, Feature 2, Feature 3"><%= copy.startup_price_features || '' %></textarea>
      </div>
    </div>

    <%# ── Tier 2 ── %>
    <div style="margin-top:10px;padding-top:8px;border-top:1px solid var(--border);">
      <div style="font-size:0.62rem;font-weight:600;color:var(--slate);letter-spacing:0.1em;margin-bottom:6px;">TIER 2</div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Label</label>
          <input type="text" name="pricing_tier2_label" value="<%= copy.pricing_tier2_label || '' %>" placeholder="e.g. Quarterly">
        </div>
        <div class="ep-field">
          <label>Amount</label>
          <input type="text" name="pricing_tier2_amount" value="<%= copy.pricing_tier2_amount || '' %>" placeholder="$120">
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Unit</label>
          <input type="text" name="pricing_tier2_unit" value="<%= copy.pricing_tier2_unit || '' %>" placeholder="/qtr">
        </div>
        <div class="ep-field">
          <label>Equiv Note</label>
          <input type="text" name="pricing_tier2_equiv" value="<%= copy.pricing_tier2_equiv || '' %>" placeholder="~$40/mo">
        </div>
      </div>
      <div class="ep-field">
        <label>CTA Link</label>
        <input type="text" name="pricing_tier2_cta_link" value="<%= copy.pricing_tier2_cta_link || '' %>" placeholder="/start or #contact">
        <div class="ep-hint">Leave blank to use default</div>
      </div>
    </div>

    <%# ── Tier 3 ── %>
    <div style="margin-top:10px;padding-top:8px;border-top:1px solid var(--border);">
      <div style="font-size:0.62rem;font-weight:600;color:var(--slate);letter-spacing:0.1em;margin-bottom:6px;">TIER 3</div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Label</label>
          <input type="text" name="pricing_tier3_label" value="<%= copy.pricing_tier3_label || '' %>" placeholder="e.g. Annual">
        </div>
        <div class="ep-field">
          <label>Amount</label>
          <input type="text" name="pricing_tier3_amount" value="<%= copy.pricing_tier3_amount || '' %>" placeholder="$300">
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Unit</label>
          <input type="text" name="pricing_tier3_unit" value="<%= copy.pricing_tier3_unit || '' %>" placeholder="/yr">
        </div>
        <div class="ep-field">
          <label>Equiv Note</label>
          <input type="text" name="pricing_tier3_equiv" value="<%= copy.pricing_tier3_equiv || '' %>" placeholder="$25/mo — 50% off">
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>CTA Link</label>
          <input type="text" name="pricing_tier3_cta_link" value="<%= copy.pricing_tier3_cta_link || '' %>" placeholder="/start or #contact">
        </div>
        <div class="ep-field">
          <label style="margin-bottom:10px;">&nbsp;</label>
          <label style="font-size:0.75rem;text-transform:none;letter-spacing:0;display:flex;align-items:center;gap:6px;cursor:pointer;">
            <input type="checkbox" name="pricing_tier3_featured" value="yes" <%= copy.pricing_tier3_featured === 'yes' ? 'checked' : '' %> style="width:14px;height:14px;accent-color:var(--navy);"> Featured
          </label>
        </div>
      </div>
    </div>

    <%# ── Tier 4 ── %>
    <div style="margin-top:10px;padding-top:8px;border-top:1px solid var(--border);">
      <div style="font-size:0.62rem;font-weight:600;color:var(--slate);letter-spacing:0.1em;margin-bottom:6px;">TIER 4</div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Label</label>
          <input type="text" name="pricing_tier4_label" value="<%= copy.pricing_tier4_label || '' %>" placeholder="e.g. Lifetime">
        </div>
        <div class="ep-field">
          <label>Amount</label>
          <input type="text" name="pricing_tier4_amount" value="<%= copy.pricing_tier4_amount || '' %>" placeholder="$1,200">
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Unit</label>
          <input type="text" name="pricing_tier4_unit" value="<%= copy.pricing_tier4_unit || '' %>" placeholder="one-time">
        </div>
        <div class="ep-field">
          <label>Equiv Note</label>
          <input type="text" name="pricing_tier4_equiv" value="<%= copy.pricing_tier4_equiv || '' %>" placeholder="2-year equivalent">
        </div>
      </div>
      <div class="ep-field">
        <label>CTA Link</label>
        <input type="text" name="pricing_tier4_cta_link" value="<%= copy.pricing_tier4_cta_link || '' %>" placeholder="/start or #contact">
      </div>
    </div>

    <%# ── Promo Banner ── %>
    <div style="margin-top:10px;padding-top:8px;border-top:1px solid var(--border);">
      <div style="font-size:0.62rem;font-weight:600;color:var(--slate);letter-spacing:0.1em;margin-bottom:6px;">PROMO BANNER</div>
      <div class="ep-field">
        <label style="font-size:0.75rem;text-transform:none;letter-spacing:0;display:flex;align-items:center;gap:6px;cursor:pointer;">
          <input type="checkbox" name="promo_enabled" value="yes" <%= copy.promo_enabled === 'yes' ? 'checked' : '' %> style="width:14px;height:14px;accent-color:var(--navy);"> Enable promo banner
        </label>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Badge</label>
          <input type="text" name="promo_badge" value="<%= copy.promo_badge || '' %>" placeholder="NEW">
        </div>
        <div class="ep-field">
          <label>Heading</label>
          <input type="text" name="promo_heading" value="<%= copy.promo_heading || '' %>" placeholder="Limited Time Offer">
        </div>
      </div>
      <div class="ep-field">
        <label>Text</label>
        <textarea name="promo_text" rows="2" placeholder="Promo details..."><%= copy.promo_text || '' %></textarea>
      </div>
    </div>
  </div>
</div>

<%# ─── 10. CONTACT COPY ─── %>
<div class="editor-section">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Contact <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">
    <div class="ep-field">
      <label>Eyebrow</label>
      <input type="text" name="contact_eyebrow" value="<%= copy.contact_eyebrow || '' %>">
    </div>
    <div class="ep-field">
      <label>Heading</label>
      <input type="text" name="contact_heading" value="<%= copy.contact_heading || '' %>">
    </div>
    <div class="ep-row">
      <div class="ep-field">
        <label>Heading Emphasis</label>
        <input type="text" name="contact_heading_em" value="<%= copy.contact_heading_em || '' %>">
      </div>
      <div class="ep-field">
        <label>Subheading</label>
        <input type="text" name="contact_sub" value="<%= copy.contact_sub || '' %>">
      </div>
    </div>
    <div style="margin-top:8px;padding-top:6px;border-top:1px solid var(--border);">
      <div style="font-size:0.62rem;font-weight:600;color:var(--slate);letter-spacing:0.1em;margin-bottom:6px;">DETAIL ITEMS</div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Location Title</label>
          <input type="text" name="contact_location_label" value="<%= copy.contact_location_label || '' %>" placeholder="Location">
        </div>
        <div class="ep-field">
          <label>Location Value</label>
          <input type="text" name="contact_location" value="<%= copy.contact_location || '' %>">
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Serving Title</label>
          <input type="text" name="contact_serving_label" value="<%= copy.contact_serving_label || '' %>" placeholder="Serving">
        </div>
        <div class="ep-field">
          <label>Serving Value</label>
          <input type="text" name="contact_serving" value="<%= copy.contact_serving || '' %>">
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Services Title</label>
          <input type="text" name="contact_services_label" value="<%= copy.contact_services_label || '' %>" placeholder="Services">
        </div>
        <div class="ep-field">
          <label>Services Value</label>
          <input type="text" name="contact_services" value="<%= copy.contact_services || '' %>">
        </div>
      </div>
    </div>
    <div class="ep-field">
      <label>Submit Button</label>
      <input type="text" name="contact_btn" value="<%= copy.contact_btn || '' %>" placeholder="Send Message">
    </div>
    <div style="margin-top:8px;padding-top:6px;border-top:1px solid var(--border);">
      <div style="font-size:0.62rem;font-weight:600;color:var(--slate);letter-spacing:0.1em;margin-bottom:6px;">SECTION COLORS</div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Left Panel BG</label>
          <div class="color-row">
            <input type="color" name="contact_bg" value="<%= design.contact_bg || design.color_primary_deep %>">
            <input type="text" value="<%= design.contact_bg || '' %>" placeholder="(primary deep)" readonly>
          </div>
        </div>
        <div class="ep-field">
          <label>Form Panel BG</label>
          <div class="color-row">
            <input type="color" name="contact_form_bg" value="<%= design.contact_form_bg || design.color_bg %>">
            <input type="text" value="<%= design.contact_form_bg || '' %>" placeholder="(bg)" readonly>
          </div>
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Heading</label>
          <div class="color-row">
            <input type="color" name="contact_heading_color" value="<%= design.contact_heading_color || '#FFFFFF' %>">
            <input type="text" value="<%= design.contact_heading_color || '' %>" placeholder="(white)" readonly>
          </div>
        </div>
        <div class="ep-field">
          <label>Eyebrow</label>
          <div class="color-row">
            <input type="color" name="contact_eyebrow_color" value="<%= design.contact_eyebrow_color || design.color_accent_light %>">
            <input type="text" value="<%= design.contact_eyebrow_color || '' %>" placeholder="(accent light)" readonly>
          </div>
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Body Text</label>
          <div class="color-row">
            <input type="color" name="contact_text_color" value="<%= design.contact_text_color || '#FDFCFA' %>">
            <input type="text" value="<%= design.contact_text_color || '' %>" placeholder="(auto)" readonly>
          </div>
        </div>
        <div class="ep-field">
          <label>Detail Labels</label>
          <div class="color-row">
            <input type="color" name="contact_label_color" value="<%= design.contact_label_color || design.color_accent %>">
            <input type="text" value="<%= design.contact_label_color || '' %>" placeholder="(accent)" readonly>
          </div>
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Detail Values</label>
          <div class="color-row">
            <input type="color" name="contact_value_color" value="<%= design.contact_value_color || '#FDFCFA' %>">
            <input type="text" value="<%= design.contact_value_color || '' %>" placeholder="(auto)" readonly>
          </div>
        </div>
        <div class="ep-field">
          <label>Form Labels</label>
          <div class="color-row">
            <input type="color" name="contact_form_label_color" value="<%= design.contact_form_label_color || '#6B7380' %>">
            <input type="text" value="<%= design.contact_form_label_color || '' %>" placeholder="(muted)" readonly>
          </div>
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Button BG</label>
          <div class="color-row">
            <input type="color" name="contact_btn_bg" value="<%= design.contact_btn_bg || design.color_primary %>">
            <input type="text" value="<%= design.contact_btn_bg || '' %>" placeholder="(primary)" readonly>
          </div>
        </div>
        <div class="ep-field">
          <label>Button Text</label>
          <div class="color-row">
            <input type="color" name="contact_btn_color" value="<%= design.contact_btn_color || '#FFFFFF' %>">
            <input type="text" value="<%= design.contact_btn_color || '' %>" placeholder="(white)" readonly>
          </div>
        </div>
      </div>
    </div>
    <div style="margin-top:8px;padding-top:6px;border-top:1px solid var(--border);">
      <div style="font-size:0.62rem;font-weight:600;color:var(--slate);letter-spacing:0.1em;margin-bottom:6px;">FORM FIELDS</div>
      <%
        const contactFormFields = [
          { prefix: 'contact_fname',    lbl: 'First Name' },
          { prefix: 'contact_lname',    lbl: 'Last Name' },
          { prefix: 'contact_email',    lbl: 'Email' },
          { prefix: 'contact_company',  lbl: 'Company' },
          { prefix: 'contact_service',  lbl: 'Service' },
          { prefix: 'contact_message',  lbl: 'Message' },
        ];
      %>
      <% contactFormFields.forEach(cf => { %>
      <div class="ep-row">
        <div class="ep-field">
          <label><%= cf.lbl %> Label</label>
          <input type="text" name="<%= cf.prefix %>_label" value="<%= copy[cf.prefix + '_label'] || '' %>">
        </div>
        <div class="ep-field">
