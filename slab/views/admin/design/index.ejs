        <label>Accent <span class="ep-hint" style="display:inline;font-style:italic;">(social icons, dividers)</span></label>
        <div class="color-row">
          <input type="color" value="<%= d.footer_accent_color || d.color_accent %>" onchange="this.nextElementSibling.value=this.value;previewReload()" oninput="this.nextElementSibling.value=this.value">
          <input type="text" name="footer_accent_color" value="<%= d.footer_accent_color || '' %>" placeholder="auto" onchange="previewReload()">
        </div>
      </div>
    </div>

    <%# ── TAB: Links ── %>
    <div class="hf-pane" data-pane="links" style="display:none;">
      <div class="ep-hint" style="margin-bottom:10px;">CMS pages auto-populate. Add external URLs &amp; section anchors here.</div>

      <% if (navLinks && navLinks.length) { %>
        <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:14px;">
          <% navLinks.forEach(function(l) { const fid = 'link-edit-' + l._id; %>
            <div style="border:1px solid var(--border);border-radius:2px;padding:8px;background:var(--surface);">
              <input type="hidden" name="_id" value="<%= l._id %>" form="<%= fid %>">
              <div class="ep-row" style="grid-template-columns:1fr 1.4fr;gap:6px;">
                <div class="ep-field" style="margin-bottom:6px;">
                  <label>Label</label>
                  <input type="text" name="label" value="<%= l.label %>" maxlength="60" form="<%= fid %>">
                </div>
                <div class="ep-field" style="margin-bottom:6px;">
                  <label>URL</label>
                  <input type="text" name="url" value="<%= l.url %>" maxlength="500" placeholder="/about or https://..." form="<%= fid %>">
                </div>
              </div>
              <div class="ep-row-3" style="gap:6px;">
                <div class="ep-field" style="margin-bottom:0;">
                  <label>Show in</label>
                  <select name="location" form="<%= fid %>">
                    <option value="header" <%= l.location === 'header' ? 'selected' : '' %>>Header only</option>
                    <option value="footer" <%= l.location === 'footer' ? 'selected' : '' %>>Footer only</option>
                    <option value="both"   <%= (l.location || 'both') === 'both' ? 'selected' : '' %>>Both</option>
                  </select>
                </div>
                <div class="ep-field" style="margin-bottom:0;">
                  <label>Open</label>
                  <select name="target" form="<%= fid %>">
                    <option value="_self"  <%= l.target !== '_blank' ? 'selected' : '' %>>Same tab</option>
                    <option value="_blank" <%= l.target === '_blank' ? 'selected' : '' %>>New tab</option>
                  </select>
                </div>
                <div class="ep-field" style="margin-bottom:0;display:flex;gap:4px;align-items:flex-end;">
                  <button type="submit" form="<%= fid %>" class="btn btn-navy" style="font-size:0.6rem;padding:6px 8px;flex:1;">Save</button>
                  <button type="submit" form="link-delete-<%= l._id %>" class="btn btn-ghost" style="font-size:0.6rem;padding:6px 8px;color:var(--danger);" onclick="return confirm('Delete this link?')">&times;</button>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>

      <div style="border:1px dashed var(--border);border-radius:2px;padding:10px;background:var(--ivory);">
        <div style="font-size:0.62rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--slate);margin-bottom:8px;">+ Add new link</div>
        <div class="ep-row" style="grid-template-columns:1fr 1.4fr;gap:6px;">
          <div class="ep-field" style="margin-bottom:6px;">
            <label>Label</label>
            <input type="text" name="label" maxlength="60" placeholder="Shop" form="link-create">
          </div>
          <div class="ep-field" style="margin-bottom:6px;">
            <label>URL</label>
            <input type="text" name="url" maxlength="500" placeholder="/shop or https://..." form="link-create">
          </div>
        </div>
        <div class="ep-row-3" style="gap:6px;">
          <div class="ep-field" style="margin-bottom:0;">
            <label>Show in</label>
            <select name="location" form="link-create">
              <option value="both" selected>Both</option>
              <option value="header">Header only</option>
              <option value="footer">Footer only</option>
            </select>
          </div>
          <div class="ep-field" style="margin-bottom:0;">
            <label>Open</label>
            <select name="target" form="link-create">
              <option value="_self" selected>Same tab</option>
              <option value="_blank">New tab</option>
            </select>
          </div>
          <div class="ep-field" style="margin-bottom:0;display:flex;align-items:flex-end;">
            <button type="submit" form="link-create" class="btn btn-navy" style="font-size:0.62rem;padding:7px 10px;width:100%;">Add Link</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

