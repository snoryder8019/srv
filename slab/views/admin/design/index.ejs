// ── Live preview engine ──
// Maps design field → CSS variable names (covers both index.ejs and landing.ejs)
//
// IMPORTANT: Only map raw user-controlled color inputs here.
// Do NOT map to server-computed vars (--surface, --on-surface, --on-surface-muted,
// --border, --on-ivory, --on-ivory-muted, --on-navy, etc.) — those are derived by
// enrichDesignContrast() on the server and their live-preview equivalents are
// injected separately below via computedVarsFromInputs().
// Overwriting computed vars with raw color inputs causes the header and nav to
// render stripped of their contrast-aware styles, producing the "preview looks
// unstyled" bug (surface bleeds through as page-bg instead of white/card bg).
var cssVarMap = {
  color_primary:      ['--navy', '--primary'],
  color_primary_deep: ['--navy-deep', '--primary-deep', '--bg'],
  color_primary_mid:  ['--navy-mid', '--primary-mid', '--card'],
  color_accent:       ['--gold', '--accent'],
  color_accent_light: ['--gold-light', '--accent-light', '--accent-hover'],
  color_bg:           ['--ivory', '--bg-page'],  // --surface intentionally excluded (computed)
  color_accent_2:     ['--accent-2'],
  color_accent_3:     ['--accent-3'],
  color_dark:         ['--dark'],   // --on-surface intentionally excluded (computed)
  color_white:        ['--white'],
  color_muted:        ['--muted'], // --on-surface-muted intentionally excluded (computed)
  color_border:       ['--ivory-mid'], // --border intentionally excluded (computed)
  color_success:      ['--success'],
  color_danger:       ['--crimson'],
  hero_overlay_color:      ['--hero-overlay'],
  contact_bg:              ['--contact-bg'],
  contact_heading_color:   ['--contact-heading'],
  contact_eyebrow_color:   ['--contact-eyebrow'],
  contact_text_color:      ['--contact-text'],
  contact_label_color:     ['--contact-label'],
  contact_value_color:     ['--contact-value'],
  contact_form_bg:         ['--contact-form-bg'],
  contact_form_label_color:['--contact-form-label'],
  contact_btn_bg:          ['--contact-btn-bg'],
  contact_btn_color:       ['--contact-btn-color'],
};

// ── Client-side approximation of enrichDesignContrast() ──
// Mirrors the server-side logic so computed CSS vars (--surface, --on-surface,
// --border, --on-ivory, etc.) stay accurate in the live preview as the user
// adjusts colors. Without this the header renders with wrong surface/text colors.
function _hexToRgb(hex) {
  hex = (hex || '').replace('#', '');
  if (hex.length === 3) hex = hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
  if (hex.length !== 6) return null;
  var n = parseInt(hex, 16);
  return { r: (n >> 16) & 255, g: (n >> 8) & 255, b: n & 255 };
}
function _relativeLuminance(hex) {
  var c = _hexToRgb(hex);
  if (!c) return 0.5;
  return [c.r, c.g, c.b].reduce(function(acc, ch, i) {
    ch /= 255;
    ch = ch <= 0.04045 ? ch / 12.92 : Math.pow((ch + 0.055) / 1.055, 2.4);
    return acc + ch * [0.2126, 0.7152, 0.0722][i];
  }, 0);
}
function _readableText(bgHex) {
  return _relativeLuminance(bgHex) > 0.179 ? '#0F1B30' : '#FDFCFA';
}
function _mixHex(hex1, hex2, w) {
  var a = _hexToRgb(hex1) || {r:0,g:0,b:0};
  var b = _hexToRgb(hex2) || {r:255,g:255,b:255};
  var mix = function(c1, c2) { return Math.round(c1 * w + c2 * (1 - w)); };
  var r = mix(a.r, b.r), g = mix(a.g, b.g), bl = mix(a.b, b.b);
  return '#' + ((1 << 24) + (r << 16) + (g << 8) + bl).toString(16).slice(1).toUpperCase();
}
function computedVarsFromInputs() {
  // Read current raw color values from the form
  function inp(name) { var el = document.querySelector('input[name="' + name + '"]'); return el ? (el.value || '') : ''; }
  var colorBg      = inp('color_bg');
  var colorPrimary = inp('color_primary');
  var colorAccent  = inp('color_accent');

  if (!colorBg || !colorPrimary) return {};

  var bgLum = _relativeLuminance(colorBg);
  var onBg  = _readableText(colorBg);

  // --surface: white on light bg, slightly lifted on dark bg
  var surface = bgLum > 0.4 ? '#FFFFFF' : _mixHex('#FFFFFF', colorBg, 0.12);
  var onSurface = _readableText(surface);

  // --border: mix of onBg with bg
  var border = bgLum > 0.4
    ? _mixHex(onBg, colorBg, 0.22)
    : _mixHex(onBg, colorBg, 0.30);

  return {
    '--surface':          surface,
    '--on-surface':       onSurface,
    '--on-surface-muted': _mixHex(onSurface, surface, 0.65),
    '--border':           border,
    '--on-ivory':         onBg,
    '--on-ivory-muted':   _mixHex(onBg, colorBg, 0.6),
    '--on-navy':          _readableText(inp('color_primary') || colorPrimary),
    '--on-navy-deep':     _readableText(inp('color_primary_deep') || colorPrimary),
    '--on-navy-mid':      _readableText(inp('color_primary_mid') || colorPrimary),
    '--on-gold':          _readableText(inp('color_accent') || colorAccent),
    '--on-gold-light':    _readableText(inp('color_accent_light') || colorAccent),
  };
}

