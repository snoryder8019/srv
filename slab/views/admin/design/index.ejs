<script>
// ── Tab switching ──
function dpSwitch(tab) {
  document.querySelectorAll('#dpTabs .dp-tab').forEach(function(b) {
    b.classList.toggle('active', b.dataset.tab === tab);
  });
  document.querySelectorAll('.editor-section[data-tab]').forEach(function(s) {
    s.classList.toggle('dp-show', s.dataset.tab === tab);
  });
  // Persist tab to URL hash so refresh / deep-links survive
  try { history.replaceState(null, '', '#tab=' + tab); } catch (e) {}
}
(function() {
  var initial = 'source';
  var m = location.hash.match(/tab=([a-z]+)/);
  if (m && ['source','design','copy','sections','templates','brand'].indexOf(m[1]) !== -1) initial = m[1];
  dpSwitch(initial);
})();

// ── Accordion toggle ──
function toggleSection(btn) {
  var section = btn.closest('.editor-section');
  section.classList.toggle('open');
}

// ── Repeater (add/remove items in copy lists; data-attrs drive everything) ──
// Wrapper config (set as JSON on the .dp-repeater element):
//   data-prefix     — key prefix (e.g. "service", "process", "pricing_tier")
//   data-fields     — JSON array [{key:"title",label:"Title",type:"text"},...]
//   data-noun       — singular label for the +Add button ("Service")
//   data-startidx   — first index used by template (default 1)
function repAdd(btn) {
  var wrap = btn.closest('.dp-repeater');
  var prefix = wrap.dataset.prefix;
  var fields;
  try { fields = JSON.parse(wrap.dataset.fields); } catch (e) { fields = []; }
  var items = wrap.querySelectorAll('.dp-rep-item');
  // Find next free index — scan existing items and use max+1.
  var nextIdx = 1;
  items.forEach(function(it) { var n = parseInt(it.dataset.idx, 10); if (n >= nextIdx) nextIdx = n + 1; });
  var item = document.createElement('div');
  item.className = 'dp-rep-item';
  item.dataset.idx = nextIdx;
  var nounCap = (wrap.dataset.noun || 'Item') + ' ' + nextIdx;
  var html = '<div class="dp-rep-head"><span>' + nounCap + '</span>' +
    '<div class="dp-rep-actions">' +
      '<button type="button" data-dir="-1" onclick="repMove(this, -1)" title="Move up">↑</button>' +
      '<button type="button" data-dir="1" onclick="repMove(this, 1)" title="Move down">↓</button>' +
      '<button type="button" class="dp-rep-remove" onclick="repRemove(this)" title="Remove this ' + (wrap.dataset.noun || 'item').toLowerCase() + '">✕</button>' +
    '</div></div>';
  fields.forEach(function(f) {
    var name = prefix + nextIdx + '_' + f.key;
    html += '<div class="ep-field"><label>' + (f.label || f.key) + '</label>';
    if (f.type === 'textarea') html += '<textarea name="' + name + '" rows="' + (f.rows || 2) + '"></textarea>';
    else if (f.type === 'checkbox') html += '<label style="display:flex;align-items:center;gap:6px;font-size:0.72rem;text-transform:none;letter-spacing:0;"><input type="checkbox" name="' + name + '" value="yes" style="width:14px;height:14px;accent-color:var(--navy);"> ' + (f.checkboxLabel || 'Yes') + '</label>';
    else if (f.type === 'select') {
      var opts = Array.isArray(f.options) ? f.options : [];
      html += '<select name="' + name + '">' +
        opts.map(function(o) { return '<option value="' + o + '">' + o + '</option>'; }).join('') +
      '</select>';
    }
    else html += '<input type="text" name="' + name + '"' + (f.placeholder ? ' placeholder="' + f.placeholder + '"' : '') + '>';
    html += '</div>';
  });
  item.innerHTML = html;
  // Insert before the +Add button
  btn.parentNode.insertBefore(item, btn);
  repRefreshBoundary(wrap);
  // Focus first input
  var first = item.querySelector('input,textarea');
  if (first) first.focus();
}
function repRemove(btn) {
  var item = btn.closest('.dp-rep-item');
  if (!item) return;
  if (!confirm('Remove this item? Saved data for it will be cleared on next Save All.')) return;
  var wrap = item.closest('.dp-repeater');
  // Mark every keyed input on this row for removal so the server deletes them.
  item.querySelectorAll('[name]').forEach(function(el) {
    var hidden = document.createElement('input');
    hidden.type = 'hidden';
    hidden.name = '_keys_to_remove';
    hidden.value = el.name;
    document.getElementById('designForm').appendChild(hidden);
  });
  item.remove();
  if (wrap) repRefreshBoundary(wrap);
}

// ── Custom-section repeater (cards / FAQ pairs inside per-section editors) ──
// Uses data-cs-field instead of name; saves happen via csSave AJAX. No
// _keys_to_remove tracking needed since server overwrites sec.fields entirely.
function csRepAdd(btn) {
  var wrap = btn.closest('.cs-repeater');
  var prefix = wrap.dataset.prefix;
  var fields;
  try { fields = JSON.parse(wrap.dataset.fields); } catch (e) { fields = []; }
  var nextIdx = 1;
  wrap.querySelectorAll('.dp-rep-item').forEach(function(it) {
    var n = parseInt(it.dataset.idx, 10); if (n >= nextIdx) nextIdx = n + 1;
  });
  var item = document.createElement('div');
  item.className = 'dp-rep-item';
  item.dataset.idx = nextIdx;
  var noun = (wrap.dataset.noun || 'Item') + ' ' + nextIdx;
  var html = '<div class="dp-rep-head"><span>' + noun + '</span>' +
    '<div class="dp-rep-actions">' +
      '<button type="button" data-dir="-1" onclick="repMove(this, -1)" title="Move up">↑</button>' +
      '<button type="button" data-dir="1" onclick="repMove(this, 1)" title="Move down">↓</button>' +
      '<button type="button" class="dp-rep-remove" onclick="csRepRemove(this)" title="Remove">✕</button>' +
    '</div></div>';
  fields.forEach(function(f) {
    // keyMode "only" → field name = f.prefix + idx (e.g. q5, a5).
    // keyMode "suffix" (default) → field name = wrap.prefix + idx + '_' + f.key (e.g. card5_title).
    var key = f.keyMode === 'only'
      ? (f.prefix || prefix) + nextIdx
      : prefix + nextIdx + '_' + f.key;
    var label = typeof f.labelTpl === 'string' ? f.labelTpl.replace('{n}', nextIdx) : (f.label || f.key);
    html += '<div class="ep-field"><label>' + label + '</label>';
    if (f.type === 'textarea') html += '<textarea data-cs-field="' + key + '" rows="' + (f.rows || 2) + '"></textarea>';
    else html += '<input type="text" data-cs-field="' + key + '"' + (f.placeholder ? ' placeholder="' + f.placeholder + '"' : '') + '>';
    html += '</div>';
  });
  item.innerHTML = html;
  btn.parentNode.insertBefore(item, btn);
  repRefreshBoundary(wrap);
  var first = item.querySelector('input,textarea');
  if (first) first.focus();
}
function csRepRemove(btn) {
  var item = btn.closest('.dp-rep-item');
  if (!item) return;
  if (!confirm('Remove this item? Click Save Section to commit.')) return;
  var wrap = item.closest('.dp-repeater');
  item.remove();
  if (wrap) repRefreshBoundary(wrap);
}

// ── Reorder repeater rows (works for both main-form and cs repeaters) ──
// Strategy: swap rows in DOM, then renumber ALL rows 1..N so input
// names/data-cs-fields match the new visual order. Save persists the new
// numbering. The keys-to-remove channel handles any indexes that fall off
// when count drops (only via × Remove, not via reorder).
function repMove(btn, dir) {
  var item = btn.closest('.dp-rep-item');
  if (!item) return;
  var sibling = dir < 0 ? item.previousElementSibling : item.nextElementSibling;
  while (sibling && !sibling.classList.contains('dp-rep-item')) {
    sibling = dir < 0 ? sibling.previousElementSibling : sibling.nextElementSibling;
  }
  if (!sibling) return;
  var parent = item.parentNode;
  if (dir < 0) parent.insertBefore(item, sibling);
  else parent.insertBefore(sibling, item);
  repRenumber(item.closest('.dp-repeater'));
}
function repRenumber(wrap) {
  if (!wrap) return;
  var isCs = wrap.classList.contains('cs-repeater');
  var attrName = isCs ? 'data-cs-field' : 'name';
  var noun = wrap.dataset.noun || 'Item';
  var items = wrap.querySelectorAll('.dp-rep-item');
  items.forEach(function(item, i) {
    var newIdx = i + 1;
    item.dataset.idx = newIdx;
    var head = item.querySelector('.dp-rep-head > span');
    if (head) head.textContent = noun + ' ' + newIdx;
    item.querySelectorAll('[' + attrName + ']').forEach(function(el) {
      var oldKey = el.getAttribute(attrName);
      // Replace the FIRST digit-run in the key with newIdx — covers
      // service{N}_title, card{N}_body, q{N}, a{N}, pricing_tier{N}_cta, etc.
      var newKey = oldKey.replace(/(\d+)/, newIdx);
      if (newKey !== oldKey) el.setAttribute(attrName, newKey);
    });
  });
  repRefreshBoundary(wrap);
}
function repRefreshBoundary(wrap) {
  var items = wrap.querySelectorAll('.dp-rep-item');
  items.forEach(function(item, i) {
    item.querySelectorAll('.dp-rep-actions button[data-dir]').forEach(function(b) {
      var d = parseInt(b.dataset.dir, 10);
      b.disabled = (d < 0 && i === 0) || (d > 0 && i === items.length - 1);
    });
  });
}

// ── Custom sections: save / delete / create / reorder / visibility ──
async function csSave(id, btn) {
  var card = btn.closest('.cs-edit');
  var fd = new URLSearchParams();
  card.querySelectorAll('[data-cs-field]').forEach(function(el) { fd.append(el.dataset.csField, el.value); });
  // Preserve current visibility (server overwrites if missing)
  var visBtn = document.querySelector('.cs-vis-toggle[data-cs-id="' + id + '"]');
  if (visBtn && visBtn.dataset.visible === 'true') fd.append('visible', 'on');
  btn.disabled = true; var prev = btn.textContent; btn.textContent = 'Saving…';
  try {
    var r = await fetch('/admin/sections/custom/' + id + '/copy', { method: 'POST', body: fd });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    btn.textContent = '✓ Saved'; setTimeout(function() { btn.textContent = prev; btn.disabled = false; }, 1200);
    // Re-render the live preview so the new section content is visible
    previewReload();
  } catch (e) { btn.textContent = '✕ Failed'; btn.disabled = false; alert('Save failed: ' + e.message); }
}
async function csDelete(id, btn) {
  if (!confirm('Delete this section permanently?')) return;
  btn.disabled = true;
  try {
    var r = await fetch('/admin/sections/custom/' + id, { method: 'DELETE' });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    location.reload();
  } catch (e) { btn.disabled = false; alert('Delete failed: ' + e.message); }
}
async function csCreate(btn) {
  var type = document.getElementById('cs-new-type').value;
  var label = document.getElementById('cs-new-label').value.trim();
  var err = document.getElementById('cs-new-err');
  err.style.display = 'none';
  if (!label) { err.textContent = 'Label is required.'; err.style.display = 'block'; return; }
  btn.disabled = true;
  try {
    var fd = new URLSearchParams(); fd.append('type', type); fd.append('label', label);
    var r = await fetch('/admin/sections/custom/new', { method: 'POST', body: fd });
    var data = await r.json();
    if (!r.ok || !data.ok) throw new Error(data.error || ('HTTP ' + r.status));
    location.reload();
  } catch (e) { btn.disabled = false; err.textContent = e.message; err.style.display = 'block'; }
}
async function csMove(id, dir) {
  var list = document.getElementById('cs-order-list');
  var rows = Array.from(list.querySelectorAll('.cs-row'));
  var idx = rows.findIndex(function(r) { return r.dataset.csId === id; });
  var to = idx + dir;
  if (to < 0 || to >= rows.length) return;
  list.insertBefore(rows[idx], dir < 0 ? rows[to] : rows[to].nextSibling);
  // Renumber labels
  list.querySelectorAll('.cs-row').forEach(function(row, i) {
    var lbl = row.querySelector('[data-cs-index]'); if (lbl) lbl.textContent = (i + 1);
  });
  // Persist
  var orderJson = JSON.stringify(Array.from(list.querySelectorAll('.cs-row')).map(function(r) { return r.dataset.csId; }));
  var fd = new URLSearchParams(); fd.append('orderJson', orderJson);
  try {
    await fetch('/admin/sections/custom/reorder', { method: 'POST', body: fd });
    previewReload();
  } catch (e) { alert('Reorder save failed: ' + e.message); }
}
async function csToggleVisible(id, btn) {
  var nowVisible = btn.dataset.visible !== 'true'; // flip
  // Pull current copy fields so we don't accidentally wipe them
  var editCard = document.querySelector('.cs-edit[data-cs-id="' + id + '"]');
  var fd = new URLSearchParams();
  if (editCard) editCard.querySelectorAll('[data-cs-field]').forEach(function(el) { fd.append(el.dataset.csField, el.value); });
  if (nowVisible) fd.append('visible', 'on');
  try {
    var r = await fetch('/admin/sections/custom/' + id + '/copy', { method: 'POST', body: fd });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    btn.dataset.visible = nowVisible ? 'true' : 'false';
    btn.textContent = nowVisible ? '◉' : '○';
    btn.style.color = nowVisible ? 'var(--navy)' : 'var(--slate)';
    btn.title = nowVisible ? 'Hide section' : 'Show section';
    previewReload();
  } catch (e) { alert('Visibility update failed: ' + e.message); }
}

// ── Header & Footer sub-tabs ──
function hfTab(btn) {
  var section = btn.closest('.editor-section');
  var target = btn.getAttribute('data-tab');
  section.querySelectorAll('.hf-tab').forEach(function(t) {
    var active = t === btn;
    t.classList.toggle('is-active', active);
    t.style.color = active ? 'var(--on-surface)' : 'var(--slate)';
