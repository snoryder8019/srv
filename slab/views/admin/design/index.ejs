      <span style="font-size:0.85rem;">&#9830;</span> Agent
    </button>
  </div>
  <div id="previewViewport" style="flex:1;display:flex;justify-content:center;overflow:hidden;">
    <iframe id="previewFrame" src="/" style="width:100%;height:100%;border:none;background:var(--surface);"></iframe>
