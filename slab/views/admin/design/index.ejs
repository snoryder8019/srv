<%# ─── 5b. HERO SLIDES (slideshow hero style) ─── %>
<div class="editor-section" data-tab="copy">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Hero Slides <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">
    <div class="ep-hint" style="margin-bottom:10px;">
      Used when <strong>Hero Style = Slideshow</strong>. Each slide gets a background image, headline, optional tag chip,
      and a link target. Quick-anchor buttons jump straight to common public landing sections.
    </div>
    <%
      const _slideIdxAdm = new Set();
      Object.keys(copy).forEach(k => { const m = k.match(/^slide(\d+)_/); if (m) _slideIdxAdm.add(parseInt(m[1], 10)); });
      const _slideArr = [..._slideIdxAdm].sort((a, b) => a - b);
      if (_slideArr.length === 0) _slideArr.push(1, 2, 3);
    %>
    <div class="dp-repeater"
         data-prefix="slide"
         data-noun="Slide"
         data-fields='[{"key":"image","label":"Background Image","type":"text","placeholder":"/uploads/..."},{"key":"tag","label":"Tag Chip","type":"text","placeholder":"e.g. FEATURED"},{"key":"eyebrow","label":"Eyebrow","type":"text"},{"key":"heading","label":"Heading","type":"text"},{"key":"sub","label":"Subtext","type":"textarea","rows":2},{"key":"link","label":"Link","type":"text","placeholder":"#services or /pricing"},{"key":"cta","label":"CTA Button Text","type":"text","placeholder":"Learn more"}]'>
      <% _slideArr.forEach(function(i, iArr) { %>
      <div class="dp-rep-item" data-idx="<%= i %>">
        <div class="dp-rep-head">
          <span>Slide <%= i %></span>
          <div class="dp-rep-actions">
            <button type="button" data-dir="-1" onclick="repMove(this, -1)" title="Move up"<%= iArr === 0 ? ' disabled' : '' %>>↑</button>
            <button type="button" data-dir="1" onclick="repMove(this, 1)" title="Move down"<%= iArr === _slideArr.length - 1 ? ' disabled' : '' %>>↓</button>
            <button type="button" class="dp-rep-remove" onclick="repRemove(this)" title="Remove this slide">✕</button>
          </div>
        </div>
        <div class="ep-field">
          <label>Background Image URL</label>
          <input type="text" name="slide<%= i %>_image" value="<%= copy['slide' + i + '_image'] || '' %>" placeholder="/uploads/...">
        </div>
        <div class="ep-row">
          <div class="ep-field">
            <label>Tag Chip <span style="font-weight:400;color:var(--on-surface-muted);">(small badge)</span></label>
            <input type="text" name="slide<%= i %>_tag" value="<%= copy['slide' + i + '_tag'] || '' %>" placeholder="e.g. FEATURED, NEW">
          </div>
          <div class="ep-field">
            <label>Eyebrow</label>
            <input type="text" name="slide<%= i %>_eyebrow" value="<%= copy['slide' + i + '_eyebrow'] || '' %>" placeholder="optional small text above heading">
          </div>
        </div>
        <div class="ep-field">
          <label>Heading</label>
          <input type="text" name="slide<%= i %>_heading" value="<%= copy['slide' + i + '_heading'] || '' %>">
        </div>
        <div class="ep-field">
          <label>Subtext</label>
          <textarea name="slide<%= i %>_sub" rows="2"><%= copy['slide' + i + '_sub'] || '' %></textarea>
        </div>
        <div class="ep-field">
          <label>Link Target — wraps the whole slide, so a click anywhere navigates</label>
          <input type="text" name="slide<%= i %>_link" id="slide_<%= i %>_link" value="<%= copy['slide' + i + '_link'] || '' %>" placeholder="#services, /pricing, https://...">
          <div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:6px;">
            <% ['#services','#portfolio','#about','#process','#pricing','#contact','/blog','/start'].forEach(function(anchor) { %>
              <button type="button"
                      onclick="document.getElementById('slide_<%= i %>_link').value='<%= anchor %>';document.getElementById('slide_<%= i %>_link').dispatchEvent(new Event('input',{bubbles:true}));"
                      style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:4px 8px;border:1px solid var(--border);border-radius:2px;background:var(--ivory);color:var(--navy);cursor:pointer;font-family:var(--font-body);">→ <%= anchor %></button>
            <% }); %>
          </div>
        </div>
        <div class="ep-field">
          <label>CTA Button Text <span style="font-weight:400;color:var(--on-surface-muted);">(only rendered if Link is set)</span></label>
          <input type="text" name="slide<%= i %>_cta" value="<%= copy['slide' + i + '_cta'] || '' %>" placeholder="Learn more">
        </div>
      </div>
      <% }); %>
      <button type="button" class="dp-rep-add" onclick="repAdd(this)">+ Add Slide</button>
    </div>
  </div>
</div>

