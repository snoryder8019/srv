            <input type="color" name="contact_heading_color" value="<%= design.contact_heading_color || '#FFFFFF' %>">
            <input type="text" value="<%= design.contact_heading_color || '' %>" placeholder="(white)" readonly>
          </div>
        </div>
        <div class="ep-field">
          <label>Eyebrow</label>
          <div class="color-row">
            <input type="color" name="contact_eyebrow_color" value="<%= design.contact_eyebrow_color || design.color_accent_light %>">
            <input type="text" value="<%= design.contact_eyebrow_color || '' %>" placeholder="(accent light)" readonly>
          </div>
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Body Text</label>
          <div class="color-row">
            <input type="color" name="contact_text_color" value="<%= design.contact_text_color || '#FDFCFA' %>">
            <input type="text" value="<%= design.contact_text_color || '' %>" placeholder="(auto)" readonly>
          </div>
        </div>
        <div class="ep-field">
          <label>Detail Labels</label>
          <div class="color-row">
            <input type="color" name="contact_label_color" value="<%= design.contact_label_color || design.color_accent %>">
            <input type="text" value="<%= design.contact_label_color || '' %>" placeholder="(accent)" readonly>
          </div>
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Detail Values</label>
          <div class="color-row">
            <input type="color" name="contact_value_color" value="<%= design.contact_value_color || '#FDFCFA' %>">
            <input type="text" value="<%= design.contact_value_color || '' %>" placeholder="(auto)" readonly>
          </div>
        </div>
        <div class="ep-field">
          <label>Form Labels</label>
          <div class="color-row">
            <input type="color" name="contact_form_label_color" value="<%= design.contact_form_label_color || '#6B7380' %>">
            <input type="text" value="<%= design.contact_form_label_color || '' %>" placeholder="(muted)" readonly>
          </div>
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Button BG</label>
          <div class="color-row">
            <input type="color" name="contact_btn_bg" value="<%= design.contact_btn_bg || design.color_primary %>">
            <input type="text" value="<%= design.contact_btn_bg || '' %>" placeholder="(primary)" readonly>
          </div>
        </div>
        <div class="ep-field">
          <label>Button Text</label>
          <div class="color-row">
            <input type="color" name="contact_btn_color" value="<%= design.contact_btn_color || '#FFFFFF' %>">
            <input type="text" value="<%= design.contact_btn_color || '' %>" placeholder="(white)" readonly>
          </div>
        </div>
      </div>
    </div>
    <div style="margin-top:8px;padding-top:6px;border-top:1px solid var(--border);">
      <div style="font-size:0.62rem;font-weight:600;color:var(--slate);letter-spacing:0.1em;margin-bottom:6px;">FORM FIELDS</div>
      <div class="ep-hint" style="margin-bottom:8px;">Check <strong>Hide</strong> to remove a stock field from the public form. Tenants can also add custom fields below.</div>
      <%
        const contactFormFields = [
          { prefix: 'contact_fname',    lbl: 'First Name' },
          { prefix: 'contact_lname',    lbl: 'Last Name' },
          { prefix: 'contact_email',    lbl: 'Email' },
          { prefix: 'contact_company',  lbl: 'Company' },
          { prefix: 'contact_service',  lbl: 'Service' },
          { prefix: 'contact_message',  lbl: 'Message' },
        ];
      %>
      <% contactFormFields.forEach(cf => { %>
      <div style="margin-bottom:10px;padding:8px 10px;border:1px solid var(--border);border-radius:2px;background:var(--ivory);">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
          <strong style="font-size:0.7rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--on-surface);"><%= cf.lbl %></strong>
          <label style="display:flex;align-items:center;gap:6px;font-size:0.68rem;font-weight:600;color:var(--slate);cursor:pointer;">
            <input type="checkbox" name="<%= cf.prefix %>_hidden" value="true"
              <%= copy[cf.prefix + '_hidden'] === 'true' ? 'checked' : '' %>
              style="width:14px;height:14px;accent-color:var(--navy);">
            Hide field
          </label>
        </div>
        <div class="ep-row">
          <div class="ep-field">
            <label>Label</label>
            <input type="text" name="<%= cf.prefix %>_label" value="<%= copy[cf.prefix + '_label'] || '' %>">
          </div>
          <div class="ep-field">
            <label>Placeholder</label>
            <input type="text" name="<%= cf.prefix %>_placeholder" value="<%= copy[cf.prefix + '_placeholder'] || '' %>">
          </div>
        </div>
      </div>
      <% }) %>
      <div class="ep-row" style="margin-top:6px;">
        <div class="ep-field">
          <label>Service Fallback</label>
          <input type="text" name="contact_service_fallback" value="<%= copy.contact_service_fallback || '' %>">
        </div>
        <div class="ep-field">
          <label>Service Extra</label>
          <input type="text" name="contact_service_extra" value="<%= copy.contact_service_extra || '' %>">
        </div>
      </div>
    </div>

    <%# ── Custom contact fields (repeater) ── %>
    <div style="margin-top:12px;padding-top:8px;border-top:1px solid var(--border);">
      <div style="font-size:0.62rem;font-weight:600;color:var(--slate);letter-spacing:0.1em;margin-bottom:6px;">CUSTOM FIELDS</div>
      <div class="ep-hint" style="margin-bottom:8px;">Add extra fields (phone, budget, dropdown, etc). These render between the stock fields and the submit button.</div>
      <%
        const _cfIdx = new Set();
        Object.keys(copy).forEach(k => { const m = k.match(/^contact_field(\d+)_/); if (m) _cfIdx.add(parseInt(m[1], 10)); });
        const _cfArr = [..._cfIdx].sort((a, b) => a - b);
      %>
      <div class="dp-repeater"
           data-prefix="contact_field"
           data-noun="Field"
           data-fields='[{"key":"label","label":"Label","type":"text","placeholder":"e.g. Phone Number"},{"key":"name","label":"Name attribute","type":"text","placeholder":"phone (defaults to field{n})"},{"key":"placeholder","label":"Placeholder","type":"text"},{"key":"type","label":"Type","type":"select","options":["text","email","tel","url","number","textarea","select"]},{"key":"options","label":"Select options (pipe-separated)","type":"text","placeholder":"Option A | Option B | Option C"},{"key":"required","label":"Required","type":"checkbox","checkboxLabel":"Make this field required"}]'>
        <% _cfArr.forEach(function(i, iArr) { %>
        <div class="dp-rep-item" data-idx="<%= i %>">
          <div class="dp-rep-head">
            <span>Field <%= i %></span>
            <div class="dp-rep-actions">
              <button type="button" data-dir="-1" onclick="repMove(this, -1)" title="Move up"<%= iArr === 0 ? ' disabled' : '' %>>↑</button>
              <button type="button" data-dir="1" onclick="repMove(this, 1)" title="Move down"<%= iArr === _cfArr.length - 1 ? ' disabled' : '' %>>↓</button>
              <button type="button" class="dp-rep-remove" onclick="repRemove(this)" title="Remove this field">✕</button>
            </div>
          </div>
          <div class="ep-row">
            <div class="ep-field">
              <label>Label</label>
              <input type="text" name="contact_field<%= i %>_label" value="<%= copy['contact_field' + i + '_label'] || '' %>" placeholder="e.g. Phone Number">
            </div>
            <div class="ep-field">
              <label>Name attribute</label>
              <input type="text" name="contact_field<%= i %>_name" value="<%= copy['contact_field' + i + '_name'] || '' %>" placeholder="phone (defaults to field<%= i %>)">
            </div>
          </div>
          <div class="ep-field">
            <label>Placeholder</label>
            <input type="text" name="contact_field<%= i %>_placeholder" value="<%= copy['contact_field' + i + '_placeholder'] || '' %>">
          </div>
          <div class="ep-row">
            <div class="ep-field">
              <label>Type</label>
              <select name="contact_field<%= i %>_type">
                <% ['text','email','tel','url','number','textarea','select'].forEach(function(t) { %>
                  <option value="<%= t %>" <%= (copy['contact_field' + i + '_type'] || 'text') === t ? 'selected' : '' %>><%= t %></option>
                <% }) %>
              </select>
            </div>
            <div class="ep-field">
              <label>Select options (pipe-separated)</label>
              <input type="text" name="contact_field<%= i %>_options" value="<%= copy['contact_field' + i + '_options'] || '' %>" placeholder="Option A | Option B | Option C">
            </div>
          </div>
          <div class="ep-field">
            <label style="display:flex;align-items:center;gap:6px;font-size:0.72rem;text-transform:none;letter-spacing:0;">
              <input type="checkbox" name="contact_field<%= i %>_required" value="yes"
                <%= copy['contact_field' + i + '_required'] === 'yes' ? 'checked' : '' %>
                style="width:14px;height:14px;accent-color:var(--navy);">
              Make this field required
            </label>
          </div>
        </div>
        <% }); %>
        <button type="button" class="dp-rep-add" onclick="repAdd(this)">+ Add Field</button>
      </div>
    </div>
  </div>
</div>

<%# ─── 11. HERO & SECTION STYLING ─── %>
<div class="editor-section" data-tab="design">
  <button type="button" class="editor-section-toggle" onclick="toggleSection(this)">
    Hero & Section Styling <span class="arrow">&#9654;</span>
  </button>
  <div class="editor-section-body">

    <%# ── Hero style picker (split / slideshow / image_card) ── %>
    <div class="ep-field">
      <label>Hero Style</label>
      <select name="hero_style" id="field-hero_style" onchange="document.querySelectorAll('[data-hero-style-only]').forEach(function(el){ el.style.display = (el.getAttribute('data-hero-style-only').split(',').indexOf(this.value) >= 0) ? '' : 'none'; }.bind(this));">
        <option value="split"       <%= (design.hero_style || 'split') === 'split'       ? 'selected' : '' %>>Split — Text-Typeface Heavy (current)</option>
        <option value="slideshow"   <%= design.hero_style === 'slideshow'                ? 'selected' : '' %>>Slideshow — Multi-slide with dots + linkable</option>
        <option value="image_card"  <%= design.hero_style === 'image_card'               ? 'selected' : '' %>>Image Card — Static image with shadow card overlay</option>
      </select>
      <div class="ep-hint" style="margin-top:6px;">Switch how the top of the landing page renders. Slideshow uses the "Hero Slides" panel below for content.</div>
    </div>

    <%# ── Slideshow-only controls ── %>
    <div data-hero-style-only="slideshow" style="<%= design.hero_style === 'slideshow' ? '' : 'display:none;' %>border:1px solid var(--border);border-radius:2px;padding:12px;margin:10px 0;background:var(--surface);">
      <div style="font-size:0.7rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:10px;">Slideshow Settings</div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Auto-advance (seconds, 0 = off)</label>
          <input type="number" min="0" max="60" step="1" name="hero_slideshow_interval" value="<%= design.hero_slideshow_interval || '6' %>">
        </div>
        <div class="ep-field">
          <label>Active Dot Color</label>
          <input type="color" name="hero_slideshow_dot_color" value="<%= design.hero_slideshow_dot_color || design.color_accent || '#C9A848' %>">
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;margin-top:8px;">
        <label style="font-size:0.75rem;display:flex;align-items:center;gap:6px;cursor:pointer;">
          <input type="checkbox" name="hero_slideshow_dots" <%= design.hero_slideshow_dots !== 'false' ? 'checked' : '' %> style="width:14px;height:14px;accent-color:var(--navy);"> Show dot indicators
        </label>
        <label style="font-size:0.75rem;display:flex;align-items:center;gap:6px;cursor:pointer;">
          <input type="checkbox" name="hero_slideshow_arrows" <%= design.hero_slideshow_arrows !== 'false' ? 'checked' : '' %> style="width:14px;height:14px;accent-color:var(--navy);"> Show prev/next arrows
        </label>
      </div>
      <div class="ep-hint" style="margin-top:8px;">Add slides in the <strong>Hero Slides</strong> copy panel (under the Copy tab). Each slide can have its own image, heading, tag, and link target.</div>
    </div>

    <%# ── Image-card only controls ── %>
    <div data-hero-style-only="image_card" style="<%= design.hero_style === 'image_card' ? '' : 'display:none;' %>border:1px solid var(--border);border-radius:2px;padding:12px;margin:10px 0;background:var(--surface);">
      <div style="font-size:0.7rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:10px;">Image Card Settings</div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Card Position</label>
          <select name="hero_card_position">
            <option value="left"   <%= (design.hero_card_position || 'left') === 'left'   ? 'selected' : '' %>>Left</option>
            <option value="center" <%= design.hero_card_position === 'center'             ? 'selected' : '' %>>Center</option>
            <option value="right"  <%= design.hero_card_position === 'right'              ? 'selected' : '' %>>Right</option>
          </select>
        </div>
        <div class="ep-field">
          <label>Card Blur (<%= design.hero_card_blur || '8' %>px)</label>
          <input type="range" min="0" max="24" step="1" name="hero_card_blur" value="<%= design.hero_card_blur || '8' %>" style="width:100%;">
        </div>
      </div>
      <div class="ep-row">
        <div class="ep-field">
          <label>Card Background (CSS color)</label>
          <input type="text" name="hero_card_bg" value="<%= design.hero_card_bg || '' %>" placeholder="rgba(253,252,250,0.92)">
        </div>
        <div class="ep-field">
          <label>Card Text Color</label>
          <input type="text" name="hero_card_text_color" value="<%= design.hero_card_text_color || '' %>" placeholder="auto">
        </div>
      </div>
      <label style="font-size:0.75rem;display:flex;align-items:center;gap:6px;cursor:pointer;margin-top:8px;">
        <input type="checkbox" name="hero_card_shadow" <%= design.hero_card_shadow !== 'false' ? 'checked' : '' %> style="width:14px;height:14px;accent-color:var(--navy);"> Drop shadow on card
      </label>
      <div class="ep-hint" style="margin-top:8px;">Background uses the <strong>Hero Section Image</strong> (Assets → Hero) or the full-bleed media below. The card holds your existing hero copy with the shadow-box treatment.</div>
    </div>

    <%# ── Full-bleed hero background (image or video from tenant assets) ── %>
    <div id="heroBgMediaBlock" style="border:1px solid var(--border);border-radius:2px;padding:10px 12px;margin-bottom:12px;background:var(--surface);">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;gap:8px;flex-wrap:wrap;">
        <label style="font-size:0.7rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--on-surface);margin:0;">Hero Full Background</label>
        <div style="display:flex;gap:6px;">
          <button type="button" id="heroBgPickImage" style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:5px 10px;border:1px solid var(--border);border-radius:2px;background:var(--ivory);color:var(--navy);cursor:pointer;font-family:var(--font-body);">Pick Image</button>
          <button type="button" id="heroBgPickVideo" style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:5px 10px;border:1px solid var(--border);border-radius:2px;background:var(--ivory);color:var(--navy);cursor:pointer;font-family:var(--font-body);">Pick Video</button>
          <button type="button" id="heroBgClear" style="font-size:0.62rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:5px 10px;border:1px solid var(--border);border-radius:2px;background:var(--ivory);color:#8B1C1C;cursor:pointer;font-family:var(--font-body);<%= design.hero_bg_media_url ? '' : 'display:none;' %>">Clear</button>
        </div>
      </div>
      <input type="hidden" name="hero_bg_media_url"    id="field-hero_bg_media_url"    value="<%= design.hero_bg_media_url || '' %>">
      <input type="hidden" name="hero_bg_media_type"   id="field-hero_bg_media_type"   value="<%= design.hero_bg_media_type || '' %>">
      <input type="hidden" name="hero_bg_media_poster" id="field-hero_bg_media_poster" value="<%= design.hero_bg_media_poster || '' %>">
      <div id="heroBgPreview" style="<%= design.hero_bg_media_url ? '' : 'display:none;' %>border:1px solid var(--border);border-radius:2px;overflow:hidden;background:#000;aspect-ratio:16/9;display:flex;align-items:center;justify-content:center;">
        <% if (design.hero_bg_media_type === 'video') { %>
          <video src="<%= design.hero_bg_media_url %>" muted playsinline autoplay loop style="width:100%;height:100%;object-fit:cover;"></video>
        <% } else if (design.hero_bg_media_url) { %>
          <img src="<%= design.hero_bg_media_url %>" alt="Hero background" style="width:100%;height:100%;object-fit:cover;">
        <% } %>
      </div>
      <div class="ep-hint" style="margin-top:8px;">Overrides the split-panel layout with a full-bleed image or looping video. Overlay color/opacity below sit on top.</div>
    </div>

    <div class="ep-row">
      <div class="ep-field">
        <label>Text Align</label>
        <select name="hero_text_align">
          <option value="left" <%= design.hero_text_align === 'left' ? 'selected' : '' %>>Left</option>
          <option value="center" <%= design.hero_text_align === 'center' ? 'selected' : '' %>>Center</option>
          <option value="right" <%= design.hero_text_align === 'right' ? 'selected' : '' %>>Right</option>
        </select>
      </div>
      <div class="ep-field">
        <label>Hero Height</label>
        <select name="hero_height">
          <option value="100vh" <%= design.hero_height === '100vh' ? 'selected' : '' %>>Full (100vh)</option>
          <option value="80vh" <%= design.hero_height === '80vh' ? 'selected' : '' %>>80%</option>
          <option value="60vh" <%= design.hero_height === '60vh' ? 'selected' : '' %>>60%</option>
          <option value="auto" <%= design.hero_height === 'auto' ? 'selected' : '' %>>Auto</option>
        </select>
      </div>
    </div>
    <div class="ep-field">
      <label>Overlay Opacity (<%= design.hero_overlay_opacity || '55' %>%)</label>
      <input type="range" name="hero_overlay_opacity" min="0" max="100" value="<%= design.hero_overlay_opacity || '55' %>" style="width:100%;">
    </div>
    <div class="ep-row">
      <div class="ep-field">
        <label>Overlay Color</label>
        <div class="color-row">
          <input type="color" name="hero_overlay_color" value="<%= design.hero_overlay_color || design.color_primary_deep %>">
        </div>
      </div>
      <div class="ep-field">
        <label>BG Pattern</label>
        <select name="hero_bg_pattern">
          <option value="none" <%= design.hero_bg_pattern === 'none' ? 'selected' : '' %>>None</option>
          <option value="grid" <%= design.hero_bg_pattern === 'grid' ? 'selected' : '' %>>Grid</option>
          <option value="diagonal" <%= design.hero_bg_pattern === 'diagonal' ? 'selected' : '' %>>Diagonal</option>
          <option value="dots" <%= design.hero_bg_pattern === 'dots' ? 'selected' : '' %>>Dots</option>
        </select>
      </div>
    </div>
    <div class="ep-field">
      <label>Card Radius (<%= design.card_border_radius || '2' %>px)</label>
      <input type="range" name="card_border_radius" min="0" max="16" value="<%= design.card_border_radius || '2' %>" style="width:100%;">
    </div>
    <div class="ep-row">
      <div class="ep-field">
        <label>Gradient Angle (<%= design.gradient_angle || '135' %>&deg;)</label>
        <input type="range" name="gradient_angle" min="0" max="360" value="<%= design.gradient_angle || '135' %>" style="width:100%;">
      </div>
    </div>
    <div style="display:flex;flex-direction:column;gap:8px;margin-top:10px;">
      <label style="font-size:0.75rem;display:flex;align-items:center;gap:6px;cursor:pointer;">
        <input type="checkbox" name="gradient_enabled" id="field-gradient_enabled" <%= design.gradient_enabled === 'true' ? 'checked' : '' %> style="width:14px;height:14px;accent-color:var(--navy);"> Gradient backgrounds
      </label>
      <label style="font-size:0.75rem;display:flex;align-items:center;gap:6px;cursor:pointer;">
        <input type="checkbox" name="card_hover_accent" id="field-card_hover_accent" <%= design.card_hover_accent === 'true' ? 'checked' : '' %> style="width:14px;height:14px;accent-color:var(--navy);"> Card hover accents
      </label>
    </div>
  </div>
</div>

