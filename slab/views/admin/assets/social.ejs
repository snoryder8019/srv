<script>
(function() {
  'use strict';
  const panel = document.getElementById('agentPanel');
  const toggleBtn = document.getElementById('agentToggleBtn');
  const closeBtn = document.getElementById('agentCloseBtn');
  const messagesEl = document.getElementById('apMessages');
  const inputEl = document.getElementById('apInput');
  const sendBtn = document.getElementById('apSendBtn');
  const quickEl = document.getElementById('apQuick');

  let history = [];
  let sending = false;

  toggleBtn.addEventListener('click', () => panel.classList.toggle('open'));
  closeBtn.addEventListener('click', () => panel.classList.remove('open'));

  function addMessage(role, html) {
    const div = document.createElement('div');
    div.className = `ap-msg ap-msg-${role}`;
    div.innerHTML = html;
    messagesEl.appendChild(div);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    return div;
  }

  let lastDesign = null;  // store last design for retry
  let lastPrompt = '';

  async function sendMessage(text) {
    if (!text.trim() || sending) return;
    sending = true;
    sendBtn.disabled = true;
    lastPrompt = text;

    addMessage('user', esc(text));
    history.push({ role: 'user', content: text });
    inputEl.value = '';

    const loadingEl = addMessage('agent', '<span class="ap-msg-loading">Designing... (SD backgrounds may take 15-45s)</span>');

    try {
      const folder = document.getElementById('exportFolder')?.value || 'clients';
      const clientId = document.getElementById('clientSelect')?.value || '';

      const r = await fetch('/admin/assets/agent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: history, mode: 'generate', folder, clientId }),
      });
      const data = await r.json();
      loadingEl.remove();

      // Store design for retry/edit
      lastDesign = data.design || null;
      const variations = data.variations || [];

      let replyHtml = esc(data.message || 'Done.');

      if (variations.length > 1) {
        // Multiple variations — show cards
        replyHtml += '<div class="ap-variations">';
        variations.forEach((v, i) => {
          replyHtml += `<div class="ap-var-card" data-idx="${i}">`;
          replyHtml += `<img src="${v.publicUrl}" alt="${esc(v.title)}" loading="lazy">`;
          replyHtml += `<div class="ap-var-label">Option ${i + 1}</div>`;
          replyHtml += `<div class="ap-var-actions">`;
          replyHtml += `<button class="ap-var-btn edit-btn" data-action="edit" data-idx="${i}">Edit Layers</button>`;
          replyHtml += `<button class="ap-var-btn" data-action="copy" data-url="${v.publicUrl}">Copy URL</button>`;
          replyHtml += `</div></div>`;
        });
        replyHtml += '</div>';
      } else if (variations.length === 1) {
        // Single variation
        replyHtml += `<img class="ap-preview" src="${variations[0].publicUrl}" alt="${esc(variations[0].title)}" loading="lazy">`;
        replyHtml += `<div style="margin-top:6px;display:flex;gap:6px;flex-wrap:wrap;">`;
        replyHtml += `<button class="ap-var-btn edit-btn" data-action="edit" data-idx="0">Edit Layers</button>`;
        replyHtml += `<button class="ap-var-btn" data-action="copy" data-url="${variations[0].publicUrl}">Copy URL</button>`;
        replyHtml += `<button class="ap-var-btn" data-action="open" data-url="${variations[0].publicUrl}">Open</button>`;
        replyHtml += `</div>`;
      }

      // Retry button
      replyHtml += `<div style="margin-top:8px;"><button class="ap-var-btn" data-action="retry" style="width:auto;padding:4px 12px;">Retry</button></div>`;

      const msgEl = addMessage('agent', replyHtml);
      history.push({ role: 'assistant', content: data.message || 'Done.' });

      // Wire up buttons inside this message
      msgEl.querySelectorAll('[data-action]').forEach(btn => {
        btn.addEventListener('click', () => {
          const action = btn.dataset.action;
          const idx = parseInt(btn.dataset.idx) || 0;
          if (action === 'edit') {
            // Load into social generator with the correct SD bg for this variation
            if (lastDesign) {
              const editDesign = { ...lastDesign };
              if (variations[idx]?.sdBgUrl) editDesign.sdBgUrl = variations[idx].sdBgUrl;
              window.loadAgentDesign(editDesign);
            }
          } else if (action === 'copy') {
            navigator.clipboard.writeText(btn.dataset.url);
            btn.textContent = 'Copied!';
            setTimeout(() => { btn.textContent = 'Copy URL'; }, 1500);
          } else if (action === 'open') {
            window.open(btn.dataset.url, '_blank');
          } else if (action === 'retry') {
            sendMessage(lastPrompt);
          }
        });
      });

    } catch (err) {
      loadingEl.remove();
      addMessage('agent', 'Error: ' + esc(err.message));
    }

    sending = false;
    sendBtn.disabled = false;
  }

  sendBtn.addEventListener('click', () => sendMessage(inputEl.value));
  inputEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(inputEl.value); }
  });

  // Quick prompts
  quickEl.addEventListener('click', (e) => {
    const btn = e.target.closest('.ap-quick-btn');
    if (btn?.dataset.prompt) sendMessage(btn.dataset.prompt);
  });

  function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
})();
</script>
