  addLayer({ type:'circle', x: canvasW/2-r, y: canvasH/2-r, w: r*2, h: r*2, fill: activeColor, stroke:'', strokeWidth:0 });
});
document.getElementById('addLineBtn').addEventListener('click', () => {
