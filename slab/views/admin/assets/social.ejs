];
let _sdPromptIdx = 0;
let _sdSpinDeg = 0;

// Shuffle on load
(function() {
  for (let i = SD_PROMPT_POOL.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [SD_PROMPT_POOL[i], SD_PROMPT_POOL[j]] = [SD_PROMPT_POOL[j], SD_PROMPT_POOL[i]];
  }
})();

function sdRenderChips(picks) {
  const wrap = document.getElementById('sdQuickWrap');
  wrap.innerHTML = '';
  picks.forEach((p, idx) => {
    const btn = document.createElement('button');
    btn.className = 'tool-btn sd-quick';
    btn.style.cssText = 'font-size:0.6rem;padding:3px 6px;opacity:0;transform:translateY(4px);transition:opacity 0.3s ease,transform 0.3s ease;';
    btn.textContent = p.label;
    btn.addEventListener('click', () => {
      document.getElementById('sdPrompt').value = p.prompt;
      generateSdBackground(p.prompt, document.getElementById('sdNegPrompt').value);
    });
    wrap.appendChild(btn);
    setTimeout(() => { btn.style.opacity = '1'; btn.style.transform = 'translateY(0)'; }, 40 + idx * 60);
  });
}

window.sdCyclePrompts = function() {
  const wrap = document.getElementById('sdQuickWrap');
  const old = wrap.querySelectorAll('.sd-quick');
  old.forEach(b => { b.style.opacity = '0'; b.style.transform = 'translateY(4px)'; });

  _sdSpinDeg += 360;
  const cycleBtn = document.getElementById('sdCycleBtn');
  if (cycleBtn) cycleBtn.style.transform = `rotate(${_sdSpinDeg}deg)`;

  const delay = old.length ? 180 : 0;
  const picks = [];
  for (let i = 0; i < 4; i++) {
    picks.push(SD_PROMPT_POOL[(_sdPromptIdx + i) % SD_PROMPT_POOL.length]);
  }
  _sdPromptIdx = (_sdPromptIdx + 4) % SD_PROMPT_POOL.length;

  setTimeout(() => sdRenderChips(picks), delay);
};

// Initial render
sdCyclePrompts();

// ═══════════════════════════════════════════
//  BRAND KIT LOADER
// ═══════════════════════════════════════════
async function loadBrandKit(type, id) {
  try {
    const url = type === 'tenant' ? '/admin/assets/brand-kit/tenant' : `/admin/assets/brand-kit/client/${id}`;
    const data = await fetch(url).then(r => r.json());
    currentBrandKit = data;
    buildForType = type;
    buildForId = id;

    // Update hidden clientSelect for export tagging
    document.getElementById('clientSelect').value = type === 'client' ? id : '';

    // Set brand palette
    PALETTES.brand = data.colors?.length ? [...data.colors] : ['#1C2B4A','#C9A848','#F5F3EF'];
    currentPalette = [...PALETTES.brand];

    // Set font dropdowns
    if (data.fonts?.heading) document.getElementById('brandFontHeading').value = data.fonts.heading;
    if (data.fonts?.body) document.getElementById('brandFontBody').value = data.fonts.body;

    // Force palette preset to "brand"
    document.getElementById('palPreset').value = 'brand';

    // Info label
    document.getElementById('buildForInfo').textContent =
      `${data.name} — ${data.colors?.length || 0} colors · ${data.fonts?.heading || 'default'} / ${data.fonts?.body || 'default'}`;

    renderPalette();
    renderPalEditor();
    loadPresetList(); // re-filter presets
  } catch(err) {
    console.error('[brand-kit] load error:', err);
  }
}

document.getElementById('buildForSelect').addEventListener('change', e => {
  const val = e.target.value;
  if (val === 'tenant') {
    loadBrandKit('tenant', null);
  } else if (val.startsWith('client:')) {
    loadBrandKit('client', val.replace('client:', ''));
  }
});
document.getElementById('loadBrandKitBtn').addEventListener('click', () => {
  document.getElementById('buildForSelect').dispatchEvent(new Event('change'));
});

// ═══════════════════════════════════════════
//  PALETTE
// ═══════════════════════════════════════════
function renderPalette() {
  const wrap = document.getElementById('palSwatches');
  wrap.innerHTML = '';
  currentPalette.forEach((clr) => {
    const s = document.createElement('div');
    s.className = 'pal-swatch' + (clr === activeColor ? ' active' : '');
    s.style.background = clr;
    s.title = clr;
    s.addEventListener('click', () => { setActiveColor(clr); });
    wrap.appendChild(s);
  });
}
function setActiveColor(clr) {
  activeColor = clr;
  document.getElementById('activeColor').value = clr;
  document.getElementById('activeColorHex').value = clr;
  renderPalette();
}
document.getElementById('palPreset').addEventListener('change', e => {
  const key = e.target.value;
  if (key === 'brand') {
    currentPalette = PALETTES.brand.length ? [...PALETTES.brand] : ['#1C2B4A','#C9A848','#F5F3EF'];
  } else {
    currentPalette = [...(PALETTES[key] || PALETTES.brand)];
  }
  renderPalette();
  renderPalEditor();
});
document.getElementById('activeColor').addEventListener('input', e => { setActiveColor(e.target.value); });
document.getElementById('activeColorHex').addEventListener('change', e => { setActiveColor(e.target.value); });

// ═══════════════════════════════════════════
//  INLINE PALETTE EDITOR
// ═══════════════════════════════════════════
function renderPalEditor() {
  const wrap = document.getElementById('palEditorSwatches');
  wrap.innerHTML = '';
  currentPalette.forEach((clr, i) => {
    const s = document.createElement('div');
    s.style.cssText = 'position:relative;display:inline-block;';
    s.innerHTML = `
      <div class="pal-swatch" style="background:${clr}" title="${clr}"></div>
      <span style="position:absolute;top:-4px;right:-4px;width:14px;height:14px;background:#c0392b;color:#fff;border-radius:50%;font-size:9px;line-height:14px;text-align:center;cursor:pointer;display:none;" class="pal-rm">x</span>`;
    s.addEventListener('mouseenter', () => s.querySelector('.pal-rm').style.display = 'block');
    s.addEventListener('mouseleave', () => s.querySelector('.pal-rm').style.display = 'none');
    s.querySelector('.pal-swatch').addEventListener('click', () => {
      setActiveColor(clr);
      document.getElementById('palEditColor').value = clr;
      document.getElementById('palEditHex').value = clr;
    });
    s.querySelector('.pal-rm').addEventListener('click', (e) => {
      e.stopPropagation();
      currentPalette.splice(i, 1);
      PALETTES.brand = [...currentPalette];
      renderPalette();
      renderPalEditor();
    });
    wrap.appendChild(s);
  });
}
document.getElementById('palEditColor').addEventListener('input', e => {
  document.getElementById('palEditHex').value = e.target.value;
});
document.getElementById('palEditHex').addEventListener('change', e => {
  if (/^#[0-9a-fA-F]{3,8}$/.test(e.target.value)) {
    document.getElementById('palEditColor').value = e.target.value;
