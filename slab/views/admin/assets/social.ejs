      { label: 'IG Story Offer', prompt: 'Make an Instagram story announcing a special offer' },
      { label: 'LinkedIn Banner', prompt: `Create a LinkedIn banner for ${biz}` },
      { label: 'Twitter Header', prompt: `Design a Twitter/X header image for ${biz}` },
      { label: 'YouTube Thumb', prompt: `Create a YouTube thumbnail promoting ${svc}` },
      { label: 'Pinterest Pin', prompt: `Design a Pinterest pin with tips related to ${svc}` },
      { label: 'Brand Quote', prompt: `Create an Instagram post with an inspirational quote related to ${brand.businessType || 'our industry'}` },
