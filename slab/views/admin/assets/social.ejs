<%- include('../partials/head', { title: 'Social Media Generator' }) %>
<%- include('../partials/sidebar', { page: 'assets', user: user }) %>

<style>
  /* ── LAYOUT ── */
  .sg-layout { display: grid; grid-template-columns: 300px 1fr 240px; gap: 0; height: calc(100vh - 64px); overflow: hidden; }
  .sg-panel { background: var(--white); display: flex; flex-direction: column; overflow: hidden; }
  .sg-panel-left { border-right: 1px solid var(--ivory-mid); }
  .sg-panel-right { border-left: 1px solid var(--ivory-mid); }
  .sg-panel-scroll { flex: 1; overflow-y: auto; padding: 14px; }
  .sg-panel-head {
    padding: 10px 14px; border-bottom: 1px solid var(--ivory-mid);
    font-size: 0.58rem; font-weight: 700; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--slate);
    display: flex; align-items: center; justify-content: space-between;
  }

  /* ── ACCORDION SECTIONS ── */
  .sg-sec { margin-bottom: 2px; }
  .sg-sec-head {
    padding: 8px 0; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--slate); cursor: pointer;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid var(--ivory-mid); user-select: none;
  }
  .sg-sec-head:hover { color: var(--dark); }
  .sg-sec-body { padding: 10px 0; }
  .sg-sec-body.collapsed { display: none; }

  /* ── INPUTS ── */
  .sg-input {
    width: 100%; padding: 5px 8px; border: 1.5px solid var(--ivory-mid);
    border-radius: 2px; font-size: 0.78rem; font-family: 'Jost', sans-serif;
    color: var(--dark); background: var(--ivory);
  }
  .sg-input:focus { outline: none; border-color: var(--navy-mid); background: var(--white); }
  .sg-select {
    width: 100%; padding: 5px 8px; border: 1.5px solid var(--ivory-mid);
    border-radius: 2px; font-size: 0.78rem; font-family: 'Jost', sans-serif;
    color: #0F1B30; background: #F5F3EF; cursor: pointer;
  }
  .sg-select option { color: #0F1B30; background: #FDFCFA; }
  .sg-select option:disabled { color: #6B7380; background: #E6E1D6; }
  .sg-row { display: flex; gap: 6px; align-items: center; margin-bottom: 6px; }
  .sg-lbl { font-size: 0.6rem; font-weight: 600; color: var(--slate); letter-spacing: 0.06em; min-width: 48px; flex-shrink: 0; }

  /* ── SIZE PRESETS ── */
  .sz-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 4px; margin-bottom: 8px; }
  .sz-btn {
    padding: 5px 4px; border: 1.5px solid var(--ivory-mid); border-radius: 2px;
    text-align: center; cursor: pointer; font-size: 0.58rem; font-weight: 600;
    color: var(--slate); background: var(--white); transition: all 0.1s;
    letter-spacing: 0.04em;
  }
  .sz-btn:hover { border-color: var(--navy-mid); color: var(--navy); }
  .sz-btn.active { background: var(--navy); color: var(--white); border-color: var(--navy); }

  /* ── TOOL BUTTONS ── */
  .tool-bar { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 8px; }
  .tool-btn {
    padding: 5px 8px; border: 1.5px solid var(--ivory-mid); border-radius: 2px;
    font-size: 0.68rem; font-weight: 600; cursor: pointer; background: var(--white);
    color: var(--slate); transition: all 0.1s;
  }
  .tool-btn:hover { border-color: var(--navy-mid); color: var(--navy); }

  /* ── COLOR PALETTES ── */
  .pal-row { display: flex; gap: 3px; margin-bottom: 6px; flex-wrap: wrap; align-items: center; }
  .pal-label { font-size: 0.55rem; font-weight: 700; color: var(--slate); letter-spacing: 0.1em; text-transform: uppercase; width: 100%; margin-bottom: 2px; }
  .pal-swatch {
    width: 24px; height: 24px; border-radius: 2px; cursor: pointer;
    border: 2px solid transparent; transition: all 0.1s; flex-shrink: 0;
  }
  .pal-swatch:hover { border-color: var(--dark); transform: scale(1.15); }
  .pal-swatch.active { border-color: var(--gold); box-shadow: 0 0 0 2px rgba(201,168,72,0.3); }

  /* ── CANVAS AREA ── */
  .sg-canvas-area {
    background: #E8E5DF; display: flex; flex-direction: column;
    align-items: center; justify-content: center; overflow: auto; padding: 20px;
    position: relative;
  }
  .sg-canvas-wrap { position: relative; box-shadow: 0 4px 24px rgba(15,27,48,0.15); }
  #sgCanvas { display: block; cursor: default; }
  .sg-canvas-info {
    margin-top: 8px; font-size: 0.65rem; color: var(--slate); text-align: center;
  }
  .sg-canvas-actions { margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; }

  /* ── LAYERS PANEL ── */
  .layer-item {
    display: flex; align-items: center; gap: 6px; padding: 6px 8px;
    border: 1.5px solid transparent; border-radius: 2px; cursor: pointer;
    transition: all 0.1s; font-size: 0.72rem; margin-bottom: 2px;
  }
  .layer-item:hover { background: var(--ivory); }
  .layer-item.active { border-color: var(--gold); background: rgba(201,168,72,0.05); }
  .layer-icon { width: 18px; text-align: center; font-size: 0.7rem; flex-shrink: 0; color: var(--slate); }
  .layer-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--dark); font-weight: 500; }
  .layer-actions { display: flex; gap: 2px; flex-shrink: 0; }
  .layer-btn {
    width: 20px; height: 20px; border: none; background: none; cursor: pointer;
    font-size: 0.65rem; color: var(--slate); border-radius: 2px; display: flex;
    align-items: center; justify-content: center;
  }
  .layer-btn:hover { background: var(--ivory-mid); color: var(--dark); }
  .layer-btn.vis-off { opacity: 0.35; }

  /* ── LAYER PROPS (bottom of right panel) ── */
  .lp-section { padding: 10px 14px; border-top: 1px solid var(--ivory-mid); }
  .lp-title { font-size: 0.58rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--slate); margin-bottom: 8px; }

  /* ── PRESETS LIST ── */
  .preset-item {
    display: flex; align-items: center; gap: 6px; padding: 6px 8px;
    border: 1.5px solid var(--ivory-mid); border-radius: 2px; cursor: pointer;
    margin-bottom: 4px; font-size: 0.72rem; transition: all 0.1s;
  }
  .preset-item:hover { border-color: var(--navy-mid); }
  .preset-item .pi-name { flex: 1; font-weight: 500; color: var(--dark); }
  .preset-item .pi-size { font-size: 0.6rem; color: var(--slate); }
  .preset-item .pi-del { color: var(--slate); cursor: pointer; font-size: 0.7rem; }
  .preset-item .pi-del:hover { color: #c0392b; }

  /* Drop zone overlay */
  .sg-drop-overlay {
    display: none; position: absolute; inset: 0; z-index: 10;
    background: rgba(201,168,72,0.12); border: 3px dashed var(--gold);
    align-items: center; justify-content: center;
    font-size: 1rem; color: var(--gold); font-weight: 600;
  }
  .sg-drop-overlay.visible { display: flex; }

  /* ── FLOATING TOOL RAIL (mobile) ── */
  .sg-fab-rail {
    display: none; position: fixed; left: 8px; top: 50%; transform: translateY(-50%);
    z-index: 50; flex-direction: column; gap: 8px;
  }
  .sg-fab {
    width: 44px; height: 44px; border-radius: 50%; border: none; cursor: pointer;
    background: var(--navy); color: var(--white); font-size: 1rem;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 10px rgba(15,27,48,0.25); transition: all 0.15s;
    font-family: 'Jost', sans-serif; position: relative;
  }
  .sg-fab:hover, .sg-fab.active { background: var(--gold); color: var(--dark); }
  .sg-fab-label {
    display: none; position: absolute; left: 52px; top: 50%; transform: translateY(-50%);
    background: var(--navy); color: var(--white); padding: 4px 10px; border-radius: 2px;
    font-size: 0.65rem; font-weight: 600; letter-spacing: 0.06em; white-space: nowrap;
    pointer-events: none;
  }
  .sg-fab:hover .sg-fab-label { display: block; }

  /* ── MOBILE OVERLAY PANEL ── */
  .sg-mob-overlay {
    display: none; position: fixed; top: 0; left: 0; width: min(320px, 88vw); height: 100vh;
    background: var(--white); z-index: 60; flex-direction: column;
    box-shadow: 4px 0 24px rgba(15,27,48,0.18);
    transition: transform 0.25s cubic-bezier(0.4,0,0.2,1);
  }
  .sg-mob-overlay.open { display: flex; }
  .sg-mob-overlay-head {
    padding: 14px 16px; border-bottom: 1px solid var(--ivory-mid);
    display: flex; align-items: center; justify-content: space-between;
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--slate); flex-shrink: 0;
  }
  .sg-mob-overlay-close {
    background: none; border: none; font-size: 1.3rem; cursor: pointer;
    color: var(--slate); padding: 4px; line-height: 1;
  }
  .sg-mob-overlay-close:hover { color: var(--dark); }
  .sg-mob-overlay-body { flex: 1; overflow-y: auto; padding: 14px; }
  .sg-mob-backdrop {
    display: none; position: fixed; inset: 0; z-index: 55;
    background: rgba(15,27,48,0.3); backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);
  }
  .sg-mob-backdrop.open { display: block; }

  /* ── RESPONSIVE ── */
  @media (max-width: 1100px) { .sg-layout { grid-template-columns: 260px 1fr 200px; } }
  @media (max-width: 820px) {
    .sg-fab-rail { display: flex; }
    .sg-layout {
      grid-template-columns: 1fr; grid-template-rows: 1fr;
      height: calc(100vh - 64px); height: calc(100dvh - 64px); overflow: hidden;
    }
    .sg-panel-left, .sg-panel-right { display: none !important; }
    .sg-canvas-area {
      display: flex; overflow: auto; padding: 10px 10px 10px 60px;
      height: 100%; width: 100%; box-sizing: border-box;
    }
    .sg-canvas-wrap { max-width: calc(100vw - 70px); max-height: calc(100vh - 100px); max-height: calc(100dvh - 100px); }
    .sg-canvas-wrap canvas { max-width: 100%; max-height: 100%; height: auto; width: auto; object-fit: contain; }
    .sg-canvas-info { font-size: 0.6rem; }
    .topbar-actions .btn { font-size: 0.62rem; padding: 4px 6px; }
  }
  @media (max-width: 520px) {
    .sg-fab { width: 40px; height: 40px; font-size: 0.9rem; }
    .sg-fab-rail { left: 6px; gap: 6px; }
    .sg-canvas-area { padding-left: 52px; padding-right: 6px; }
    .sg-canvas-wrap { max-width: calc(100vw - 58px); }
    .sg-mob-overlay { width: min(300px, 92vw); }
    .sg-mob-overlay-body .sg-input, .sg-mob-overlay-body .sg-select { font-size: 0.82rem; padding: 8px 10px; }
    .sg-mob-overlay-body .tool-btn { padding: 10px 14px; }
  }
</style>

<div class="topbar">
  <div class="topbar-title">Social Media Generator</div>
  <div class="topbar-actions">
    <a href="/admin/assets" class="btn btn-ghost btn-sm">&larr; Assets</a>
    <a href="/admin/assets/trim" class="btn btn-ghost btn-sm">Video Trimmer</a>
    <button class="btn btn-gold btn-sm" id="agentToggleBtn">Asset Agent</button>
  </div>
</div>

<div style="padding:0 16px;">
  <%- include('../partials/advisory', { needs: 'ai,s3' }) %>
</div>
<!-- Mobile floating tool rail -->
<div class="sg-fab-rail" id="sgFabRail">
  <button class="sg-fab" data-fab="size" title="Canvas Size">⊞<span class="sg-fab-label">Size</span></button>
  <button class="sg-fab" data-fab="layers" title="Layers">◫<span class="sg-fab-label">Layers</span></button>
  <button class="sg-fab" data-fab="add" title="Add Layer">+<span class="sg-fab-label">Add</span></button>
  <button class="sg-fab" data-fab="bg" title="Background">◐<span class="sg-fab-label">BG</span></button>
  <button class="sg-fab" data-fab="palette" title="Colors">◈<span class="sg-fab-label">Colors</span></button>
  <button class="sg-fab" data-fab="export" title="Export">↓<span class="sg-fab-label">Export</span></button>
  <button class="sg-fab" data-fab="tools" title="All Tools" style="background:var(--gold);color:var(--dark);">≡<span class="sg-fab-label">All Tools</span></button>
</div>
<div class="sg-mob-backdrop" id="sgMobBackdrop"></div>
<div class="sg-mob-overlay" id="sgMobOverlay">
  <div class="sg-mob-overlay-head">
    <span id="sgMobOverlayTitle">Tools</span>
    <button class="sg-mob-overlay-close" id="sgMobOverlayClose">&times;</button>
  </div>
  <div class="sg-mob-overlay-body" id="sgMobOverlayBody"></div>
</div>

<div class="sg-layout">

  <!-- ═══ LEFT PANEL ═══ -->
  <div class="sg-panel sg-panel-left" id="sgPanelLeft">
    <div class="sg-panel-head">Tools</div>
    <div class="sg-panel-scroll">

      <!-- SIZE -->
      <div class="sg-sec">
        <div class="sg-sec-head" data-toggle="secSize">Canvas Size <span>▸</span></div>
        <div class="sg-sec-body collapsed" id="secSize">
          <div class="sz-grid" id="sizeGrid">
            <div class="sz-btn active" data-w="1080" data-h="1080" data-name="ig-post">IG Post<br>1:1</div>
            <div class="sz-btn" data-w="1080" data-h="1920" data-name="ig-story">Story<br>9:16</div>
            <div class="sz-btn" data-w="1200" data-h="630" data-name="fb-post">FB Post<br>1.9:1</div>
            <div class="sz-btn" data-w="1640" data-h="624" data-name="fb-cover">FB Cover<br>2.6:1</div>
            <div class="sz-btn" data-w="1600" data-h="900" data-name="twitter">X/Twitter<br>16:9</div>
            <div class="sz-btn" data-w="1000" data-h="1500" data-name="pinterest">Pinterest<br>2:3</div>
            <div class="sz-btn" data-w="1280" data-h="720" data-name="yt-thumb">YouTube<br>16:9</div>
            <div class="sz-btn" data-w="1200" data-h="627" data-name="linkedin">LinkedIn<br>1.9:1</div>
            <div class="sz-btn" data-w="1080" data-h="1350" data-name="ig-portrait">IG Port.<br>4:5</div>
          </div>
          <div class="sg-row">
            <span class="sg-lbl">W</span><input type="number" class="sg-input" id="customW" value="1080" style="width:70px;">
            <span class="sg-lbl">H</span><input type="number" class="sg-input" id="customH" value="1080" style="width:70px;">
            <button class="tool-btn" id="applySizeBtn">Set</button>
          </div>
        </div>
      </div>

      <!-- ADD LAYERS -->
      <div class="sg-sec">
        <div class="sg-sec-head" data-toggle="secAdd">Add Layers <span>▸</span></div>
        <div class="sg-sec-body collapsed" id="secAdd">
          <div class="tool-bar">
            <button class="tool-btn" id="addImageBtn">+ Image</button>
            <button class="tool-btn" id="addLocalBtn">+ Upload</button>
            <button class="tool-btn" id="addTextBtn">+ Text</button>
            <button class="tool-btn" id="addRectBtn">+ Rect</button>
            <button class="tool-btn" id="addCircBtn">+ Circle</button>
            <button class="tool-btn" id="addLineBtn">+ Line</button>
          </div>
          <div style="font-size:0.65rem;color:var(--slate);">Drag & drop images/videos onto the canvas, or use the buttons above.</div>
          <input type="file" id="localFileInput" accept="image/*,video/*" multiple style="display:none;">
        </div>
      </div>

      <!-- BACKGROUND -->
      <div class="sg-sec">
        <div class="sg-sec-head" data-toggle="secBg">Background <span>▸</span></div>
        <div class="sg-sec-body collapsed" id="secBg">
          <div class="sg-row">
            <span class="sg-lbl">Color</span>
            <input type="color" id="bgColor" value="#F5F3EF" style="width:32px;height:28px;border:1px solid var(--ivory-mid);cursor:pointer;">
            <input type="text" class="sg-input" id="bgColorHex" value="#F5F3EF" style="width:80px;">
          </div>
        </div>
      </div>

      <!-- AI BACKGROUND -->
      <div class="sg-sec">
        <div class="sg-sec-head" data-toggle="secAiBg">AI Background <span>▸</span></div>
        <div class="sg-sec-body collapsed" id="secAiBg">
          <div style="margin-bottom:6px;">
            <input type="text" class="sg-input" id="sdPrompt" placeholder="e.g. paintstrokes, St. Patrick's Day, sunset bokeh..." style="width:100%;">
          </div>
          <div style="margin-bottom:6px;">
            <input type="text" class="sg-input" id="sdNegPrompt" placeholder="Negative (auto-filled)" value="text, words, letters, watermark, blurry, low quality" style="width:100%;font-size:0.68rem;color:var(--slate);">
          </div>
          <div class="tool-bar">
            <button class="tool-btn" id="genBgBtn" style="background:var(--gold);color:var(--dark);border-color:var(--gold);flex:1;">Generate Background</button>
            <button class="tool-btn" id="clearBgBtn" title="Remove AI background">Clear</button>
          </div>
          <div id="sdStatus" style="font-size:0.68rem;color:var(--slate);margin-top:4px;"></div>
          <div style="margin-top:6px;">
            <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
              <span style="font-size:0.55rem;color:var(--slate);letter-spacing:0.1em;text-transform:uppercase;font-weight:700;">Quick Prompts</span>
              <button id="sdCycleBtn" class="tool-btn" onclick="sdCyclePrompts()" title="More prompts" style="padding:1px 5px;font-size:0.7rem;line-height:1;transition:transform 0.55s cubic-bezier(.2,.8,.3,1.1);">&#x267B;</button>
            </div>
            <div id="sdQuickWrap" style="display:flex;gap:3px;flex-wrap:wrap;"></div>
          </div>
        </div>
      </div>

      <!-- BUILD FOR -->
      <div class="sg-sec">
        <div class="sg-sec-head" data-toggle="secBuildFor">Build For <span>▸</span></div>
        <div class="sg-sec-body collapsed" id="secBuildFor">
          <div class="sg-row" style="margin-bottom:6px;">
            <select class="sg-select" id="buildForSelect" style="flex:1;">
              <option value="tenant">My Brand</option>
            </select>
            <button class="tool-btn" id="loadBrandKitBtn" title="Load brand kit">Load</button>
          </div>
          <div id="buildForInfo" style="font-size:0.62rem;color:var(--slate);margin-bottom:4px;"></div>
        </div>
      </div>

      <!-- PALETTE -->
      <div class="sg-sec">
        <div class="sg-sec-head" data-toggle="secPal">Color Palette <span>▸</span></div>
        <div class="sg-sec-body collapsed" id="secPal">
          <div class="sg-row" style="margin-bottom:4px;">
            <span class="sg-lbl">Preset</span>
            <select class="sg-select" id="palPreset" style="flex:1;">
              <option value="brand">Brand Kit</option>
              <option value="modern">Modern Dark</option>
              <option value="warm">Warm Sunset</option>
              <option value="cool">Cool Blue</option>
              <option value="earth">Earthy</option>
              <option value="pastel">Pastel</option>
              <option value="bold">Bold Pop</option>
              <option value="mono">Monochrome</option>
            </select>
          </div>
          <div id="palSwatches" class="pal-row"></div>
          <!-- Inline palette editor -->
          <div id="palEditor" style="margin-top:6px;">
            <div style="display:flex;gap:3px;flex-wrap:wrap;align-items:center;" id="palEditorSwatches"></div>
            <div class="sg-row" style="margin-top:4px;">
              <input type="color" id="palEditColor" value="#1C2B4A" style="width:28px;height:24px;border:1px solid var(--ivory-mid);cursor:pointer;">
              <input type="text" class="sg-input" id="palEditHex" value="#1C2B4A" placeholder="#hex" style="width:72px;">
              <button class="tool-btn" id="palAddBtn" title="Add color to palette" style="font-size:0.6rem;">+ Add</button>
              <button class="tool-btn" id="palSaveBtn" title="Save palette back to brand" style="font-size:0.6rem;background:var(--gold);color:var(--dark);border-color:var(--gold);">Save</button>
            </div>
          </div>
          <div class="sg-row" style="margin-top:6px;">
            <span class="sg-lbl">Active</span>
            <input type="color" id="activeColor" value="#1C2B4A" style="width:32px;height:28px;border:1px solid var(--ivory-mid);cursor:pointer;">
            <input type="text" class="sg-input" id="activeColorHex" value="#1C2B4A" style="flex:1;">
            <button class="tool-btn" id="applyFillBtn" title="Apply as fill">Fill</button>
            <button class="tool-btn" id="applyStrokeBtn" title="Apply as stroke">Strk</button>
            <button class="tool-btn" id="applyTextClrBtn" title="Apply as text color">Txt</button>
          </div>
        </div>
      </div>

      <!-- FONTS (from brand kit) -->
      <div class="sg-sec">
        <div class="sg-sec-head" data-toggle="secFonts">Brand Fonts <span>▸</span></div>
        <div class="sg-sec-body collapsed" id="secFonts">
          <div class="sg-row">
            <span class="sg-lbl">Heading</span>
            <select class="sg-select" id="brandFontHeading" style="flex:1;">
              <option value="Cormorant Garamond">Cormorant Garamond</option>
              <option value="Playfair Display">Playfair Display</option>
              <option value="Lora">Lora</option>
              <option value="Merriweather">Merriweather</option>
              <option value="Libre Baskerville">Libre Baskerville</option>
              <option value="Jost">Jost</option>
              <option value="Inter">Inter</option>
              <option value="Poppins">Poppins</option>
              <option value="Raleway">Raleway</option>
              <option value="Nunito">Nunito</option>
              <option value="DM Sans">DM Sans</option>
            </select>
          </div>
          <div class="sg-row">
            <span class="sg-lbl">Body</span>
            <select class="sg-select" id="brandFontBody" style="flex:1;">
              <option value="Jost">Jost</option>
              <option value="Inter">Inter</option>
              <option value="Poppins">Poppins</option>
              <option value="Raleway">Raleway</option>
              <option value="Nunito">Nunito</option>
              <option value="DM Sans">DM Sans</option>
              <option value="Cormorant Garamond">Cormorant Garamond</option>
              <option value="Playfair Display">Playfair Display</option>
              <option value="Lora">Lora</option>
              <option value="Merriweather">Merriweather</option>
              <option value="Libre Baskerville">Libre Baskerville</option>
            </select>
          </div>
          <div style="font-size:0.6rem;color:var(--slate);margin-top:2px;">New text layers will use these fonts.</div>
        </div>
