  addLayer({ type:'text', x: canvasW*0.1, y: canvasH*0.4, w: canvasW*0.8, h: 80, text:'Your Text', fontSize:56, fontFamily: headingFont, color:'#FFFFFF', align:'center', bold:true, italic:false });
});
document.getElementById('addRectBtn').addEventListener('click', () => {
