});
function setCanvasSize(w, h, name) {
  canvasW = w; canvasH = h; sizeName = name;
  canvas.width = w; canvas.height = h;
  document.getElementById('customW').value = w;
  document.getElementById('customH').value = h;
  scaleCanvas();
  render();
}
function scaleCanvas() {
  const area = document.getElementById('canvasArea');
  const isMob = window.innerWidth <= 820;
  const padX = isMob ? 20 : 60;
  const padY = isMob ? 40 : 100;
  const maxW = area.clientWidth - padX;
  const maxH = area.clientHeight - padY;
  const scale = Math.min(1, maxW / canvasW, maxH / canvasH);
  canvas.style.width = Math.max(60, canvasW * scale) + 'px';
  canvas.style.height = Math.max(60, canvasH * scale) + 'px';
  document.getElementById('canvasInfo').textContent = `${canvasW} x ${canvasH} · ${sizeName}`;
}
window.addEventListener('resize', scaleCanvas);

// ═══════════════════════════════════════════
//  BACKGROUND
// ═══════════════════════════════════════════
document.getElementById('bgColor').addEventListener('input', e => { bgColor = e.target.value; document.getElementById('bgColorHex').value = bgColor; render(); });
document.getElementById('bgColorHex').addEventListener('change', e => { bgColor = e.target.value; document.getElementById('bgColor').value = bgColor; render(); });

// ═══════════════════════════════════════════
//  AI BACKGROUND (Stable Diffusion)
// ═══════════════════════════════════════════
async function generateSdBackground(prompt, negPrompt) {
  const status = document.getElementById('sdStatus');
  const btn = document.getElementById('genBgBtn');
  if (!prompt.trim()) { status.textContent = 'Enter a prompt first.'; return; }

  btn.disabled = true;
  btn.textContent = 'Generating...';
  status.textContent = 'Calling Stable Diffusion (15-45s)...';

  try {
    const r = await fetch('/admin/assets/generate-bg', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        prompt: prompt.trim(),
        negative_prompt: negPrompt || 'text, words, letters, watermark, blurry, low quality',
        sizePreset: sizeName,
      }),
    });
    const data = await r.json();
    if (!data.success) throw new Error(data.error || 'Generation failed');

    // Add as a layer at the bottom of the stack
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = () => {
      // Remove any existing AI background layer
      layers = layers.filter(l => !l._aiBg);
      const layer = { type:'image', x:0, y:0, w:canvasW, h:canvasH, src:data.url, img, name:'AI Background', _aiBg:true, id:nextId++, visible:true, opacity:1 };
      layers.unshift(layer);
      selId = layer.id;
      renderLayerList();
      render();
      status.textContent = 'Background added as layer!';
      setTimeout(() => { status.textContent = ''; }, 3000);
    };
    img.onerror = () => { status.textContent = 'Failed to load generated image.'; };
    img.src = data.url;
  } catch (err) {
    status.textContent = 'Error: ' + err.message;
  }
  btn.disabled = false;
  btn.textContent = 'Generate Background';
}

document.getElementById('genBgBtn').addEventListener('click', () => {
  generateSdBackground(
    document.getElementById('sdPrompt').value,
    document.getElementById('sdNegPrompt').value
  );
});
document.getElementById('clearBgBtn').addEventListener('click', () => {
  layers = layers.filter(l => !l._aiBg);
  document.getElementById('sdPrompt').value = '';
  document.getElementById('sdStatus').textContent = 'Background cleared.';
  setTimeout(() => { document.getElementById('sdStatus').textContent = ''; }, 2000);
  renderLayerList();
  render();
});
// ═══ Cycling Quick Prompts ═══
const SD_PROMPT_POOL = [
  { label: 'Paintstrokes', prompt: 'abstract acrylic paint strokes, rich texture, artistic background, navy and gold palette' },
  { label: "St. Patrick's", prompt: 'green shamrock bokeh background, gold glitter, festive St Patricks Day, soft lighting' },
