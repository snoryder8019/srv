// ═══════════════════════════════════════════
//  LAYERS — DATA
// ═══════════════════════════════════════════
function addLayer(layer) {
  layer.id = nextId++;
  layer.visible = true;
  layer.opacity = layer.opacity ?? 1;
  layers.push(layer);
  selId = layer.id;
  renderLayerList();
  render();
  return layer;
}
function selLayer() { return layers.find(l => l.id === selId); }
function removeLayer(id) {
  layers = layers.filter(l => l.id !== id);
  if (selId === id) selId = null;
  renderLayerList();
  render();
}

