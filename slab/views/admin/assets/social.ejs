});

function addImageLayer(src, name) {
  const img = new Image();
  img.crossOrigin = 'anonymous';
  img.onload = () => {
    const scale = Math.min(canvasW / img.naturalWidth, canvasH / img.naturalHeight, 1);
    const w = img.naturalWidth * scale;
    const h = img.naturalHeight * scale;
    addLayer({ type:'image', x:(canvasW-w)/2, y:(canvasH-h)/2, w, h, src, img, name: name||'Image' });
  };
  img.onerror = () => alert('Could not load image');
  img.src = src;
}
function addVideoLayer(src, name) {
  const vid = document.createElement('video');
  vid.crossOrigin = 'anonymous';
  vid.src = src; vid.muted = true; vid.loop = true; vid.playsInline = true;
  vid.addEventListener('loadedmetadata', () => {
    const scale = Math.min(canvasW/vid.videoWidth, canvasH/vid.videoHeight, 1);
    const w = vid.videoWidth*scale, h = vid.videoHeight*scale;
    const layer = addLayer({ type:'video', x:(canvasW-w)/2, y:(canvasH-h)/2, w, h, src, vid, name: name||'Video' });
    vid.play().catch(()=>{});
    // continuous render for video
    (function tick(){ if(layers.find(l=>l.id===layer.id)) { render(); requestAnimationFrame(tick); } })();
  });
  vid.addEventListener('error', () => alert('Could not load video'));
}

// ═══════════════════════════════════════════
//  DRAG & DROP onto canvas
// ═══════════════════════════════════════════
const canvasArea = document.getElementById('canvasArea');
const dropOverlay = document.getElementById('dropOverlay');
canvasArea.addEventListener('dragover', e => { e.preventDefault(); dropOverlay.classList.add('visible'); });
canvasArea.addEventListener('dragleave', e => { if(!canvasArea.contains(e.relatedTarget)) dropOverlay.classList.remove('visible'); });
canvasArea.addEventListener('drop', e => {
  e.preventDefault();
  dropOverlay.classList.remove('visible');
  for (const f of e.dataTransfer.files) {
    const url = URL.createObjectURL(f);
    if (f.type.startsWith('video/')) addVideoLayer(url, f.name);
    else if (f.type.startsWith('image/')) addImageLayer(url, f.name);
  }
});

// ═══════════════════════════════════════════
//  RENDER
// ═══════════════════════════════════════════
function render() {
  ctx.clearRect(0, 0, canvasW, canvasH);
  // bg
  ctx.fillStyle = bgColor;
  ctx.fillRect(0, 0, canvasW, canvasH);

  layers.forEach(l => {
    if (!l.visible) return;
    ctx.save();
    ctx.globalAlpha = l.opacity;

    if (l.type === 'image' && l.img) {
      ctx.drawImage(l.img, l.x, l.y, l.w, l.h);
    } else if (l.type === 'video' && l.vid) {
      try { ctx.drawImage(l.vid, l.x, l.y, l.w, l.h); } catch(e){}
    } else if (l.type === 'rect') {
      if (l.fill) { ctx.fillStyle = l.fill; if (l.radius) { roundRect(ctx, l.x, l.y, l.w, l.h, l.radius); ctx.fill(); } else ctx.fillRect(l.x, l.y, l.w, l.h); }
      if (l.stroke && l.strokeWidth) { ctx.strokeStyle = l.stroke; ctx.lineWidth = l.strokeWidth; if (l.radius) { roundRect(ctx, l.x, l.y, l.w, l.h, l.radius); ctx.stroke(); } else ctx.strokeRect(l.x, l.y, l.w, l.h); }
    } else if (l.type === 'circle') {
      const rx = l.w/2, ry = l.h/2;
      ctx.beginPath();
      ctx.ellipse(l.x+rx, l.y+ry, Math.abs(rx), Math.abs(ry), 0, 0, Math.PI*2);
      if (l.fill) { ctx.fillStyle = l.fill; ctx.fill(); }
      if (l.stroke && l.strokeWidth) { ctx.strokeStyle = l.stroke; ctx.lineWidth = l.strokeWidth; ctx.stroke(); }
    } else if (l.type === 'line') {
      ctx.beginPath();
      ctx.moveTo(l.x, l.y);
      ctx.lineTo(l.x + l.w, l.y + (l.h||0));
      ctx.strokeStyle = l.stroke || '#000';
      ctx.lineWidth = l.strokeWidth || 2;
      if (l.dash) ctx.setLineDash([l.dash, l.dash]);
      ctx.stroke();
      ctx.setLineDash([]);
    } else if (l.type === 'text') {
      const fs = l.fontSize || 48;
      ctx.fillStyle = l.color || '#000';
      ctx.font = `${l.bold?'bold ':' '}${l.italic?'italic ':''}${fs}px ${l.fontFamily || 'Jost'}, sans-serif`;
      ctx.textAlign = l.align || 'left';
      ctx.textBaseline = 'top';
      // shadow
      ctx.shadowColor = 'rgba(0,0,0,0.4)';
      ctx.shadowBlur = 6; ctx.shadowOffsetX = 1; ctx.shadowOffsetY = 1;
      const ax = l.align === 'center' ? l.x + l.w/2 : l.align === 'right' ? l.x + l.w : l.x;
      wrapAndDraw(ctx, l.text, ax, l.y, l.w, fs * 1.2);
      ctx.shadowColor = 'transparent'; ctx.shadowBlur = 0;
    }

    ctx.restore();
  });

  // selection outline
  if (selId) {
    const l = selLayer();
    if (l && l.visible) {
      ctx.save();
      ctx.strokeStyle = '#C9A848';
      ctx.lineWidth = Math.max(2, canvasW * 0.002);
      ctx.setLineDash([8, 4]);
      if (l.type === 'line') {
        ctx.beginPath(); ctx.moveTo(l.x-4, l.y-4); ctx.lineTo(l.x+l.w+4, l.y+(l.h||0)+4); ctx.stroke();
      } else {
        ctx.strokeRect(l.x-2, l.y-2, l.w+4, l.h+4);
      }
      ctx.setLineDash([]);
      // resize handle (bottom-right)
      const hs = Math.max(10, canvasW*0.012);
      ctx.fillStyle = '#C9A848';
      ctx.fillRect(l.x+l.w-hs/2, l.y+(l.h||0)-hs/2, hs, hs);
      ctx.strokeStyle = '#fff'; ctx.lineWidth = 1;
      ctx.strokeRect(l.x+l.w-hs/2, l.y+(l.h||0)-hs/2, hs, hs);
      ctx.restore();
    }
  }
}

function roundRect(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x+r, y);
  ctx.lineTo(x+w-r, y); ctx.arcTo(x+w, y, x+w, y+r, r);
  ctx.lineTo(x+w, y+h-r); ctx.arcTo(x+w, y+h, x+w-r, y+h, r);
  ctx.lineTo(x+r, y+h); ctx.arcTo(x, y+h, x, y+h-r, r);
  ctx.lineTo(x, y+r); ctx.arcTo(x, y, x+r, y, r);
  ctx.closePath();
}

function wrapAndDraw(ctx, text, x, y, maxW, lineH) {
  const words = text.split(' ');
  let line = words[0] || '';
  let cy = y;
  for (let i=1; i<words.length; i++) {
    const test = line + ' ' + words[i];
    if (ctx.measureText(test).width > maxW) { ctx.fillText(line, x, cy); cy += lineH; line = words[i]; }
    else line = test;
  }
  ctx.fillText(line, x, cy);
}

// ═══════════════════════════════════════════
//  HIT TESTING & MOUSE
// ═══════════════════════════════════════════
function canvasCoords(e) {
  const r = canvas.getBoundingClientRect();
  return { x: (e.clientX - r.left) / r.width * canvasW, y: (e.clientY - r.top) / r.height * canvasH };
}
function hitTest(mx, my) {
  for (let i = layers.length - 1; i >= 0; i--) {
    const l = layers[i];
    if (!l.visible) continue;
    if (l.type === 'line') {
      // thin rect around line
      const x1=l.x, y1=l.y, x2=l.x+l.w, y2=l.y+(l.h||0);
      const d = distToLine(mx, my, x1, y1, x2, y2);
      if (d < 15) return l;
    } else {
      if (mx >= l.x && mx <= l.x+l.w && my >= l.y && my <= l.y+l.h) return l;
    }
  }
  return null;
}
function distToLine(px,py,x1,y1,x2,y2) {
  const A=px-x1, B=py-y1, C=x2-x1, D=y2-y1;
  const dot=A*C+B*D, len2=C*C+D*D;
  let t = len2 ? dot/len2 : -1;
  t = Math.max(0, Math.min(1, t));
  return Math.hypot(px-(x1+t*C), py-(y1+t*D));
}
function isOnResizeHandle(l, mx, my) {
  const hs = Math.max(14, canvasW*0.015);
  const hx = l.x + l.w, hy = l.y + (l.h||0);
  return Math.abs(mx-hx) < hs && Math.abs(my-hy) < hs;
}

canvas.addEventListener('mousedown', e => {
  const {x,y} = canvasCoords(e);
  // check resize handle first
  const sl = selLayer();
  if (sl && isOnResizeHandle(sl, x, y)) {
    resize = { id: sl.id, startX: x, startY: y, origW: sl.w, origH: sl.h||0, origX: sl.x, origY: sl.y };
    return;
  }
  const hit = hitTest(x, y);
  if (hit) {
    selId = hit.id;
    drag = { id: hit.id, startX: x, startY: y, origX: hit.x, origY: hit.y };
    renderLayerList(); renderProps(); render();
  } else {
    selId = null;
    renderLayerList(); renderProps(); render();
  }
});
canvas.addEventListener('mousemove', e => {
  const {x,y} = canvasCoords(e);
  if (resize) {
    const l = layers.find(l=>l.id===resize.id);
    if (!l) return;
    l.w = Math.max(20, resize.origW + (x - resize.startX));
    l.h = Math.max(10, resize.origH + (y - resize.startY));
    render();
    return;
  }
  if (drag) {
    const l = layers.find(l=>l.id===drag.id);
    if (!l) return;
    l.x = drag.origX + (x - drag.startX);
    l.y = drag.origY + (y - drag.startY);
    render();
    return;
  }
  // cursor hint
  const sl = selLayer();
  if (sl && isOnResizeHandle(sl, x, y)) { canvas.style.cursor = 'nwse-resize'; }
  else if (hitTest(x, y)) { canvas.style.cursor = 'move'; }
  else { canvas.style.cursor = 'default'; }
});
canvas.addEventListener('mouseup', () => { drag = null; resize = null; renderProps(); });
canvas.addEventListener('mouseleave', () => { drag = null; resize = null; });

// Keyboard
document.addEventListener('keydown', e => {
  if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;
  if ((e.key === 'Delete' || e.key === 'Backspace') && selId) { removeLayer(selId); renderProps(); }
});

// ═══════════════════════════════════════════
//  LAYER LIST
// ═══════════════════════════════════════════
function renderLayerList() {
  const wrap = document.getElementById('layerList');
  wrap.innerHTML = '';
  // render top-to-bottom = last layer first
  for (let i = layers.length-1; i >= 0; i--) {
    const l = layers[i];
    const icons = {image:'🖼',video:'▷',text:'T',rect:'▬',circle:'●',line:'╱'};
    const div = document.createElement('div');
    div.className = 'layer-item' + (l.id===selId?' active':'');
    div.innerHTML = `
      <span class="layer-icon">${icons[l.type]||'?'}</span>
      <span class="layer-name">${esc(l.name||l.type+(l.text?' "'+l.text.slice(0,12)+'"':''))}</span>
      <span class="layer-actions">
        <button class="layer-btn ${l.visible?'':'vis-off'}" data-vis="${l.id}" title="Toggle visibility">${l.visible?'◉':'◎'}</button>
        <button class="layer-btn" data-del="${l.id}" title="Delete">✕</button>
      </span>`;
    div.addEventListener('click', e => {
      if (e.target.dataset.vis || e.target.dataset.del) return;
      selId = l.id; renderLayerList(); renderProps(); render();
    });
    div.querySelector('[data-vis]').addEventListener('click', () => { l.visible = !l.visible; renderLayerList(); render(); });
    div.querySelector('[data-del]').addEventListener('click', () => { removeLayer(l.id); renderProps(); });
    wrap.appendChild(div);
  }
}

// Layer up/down
document.getElementById('layerUpBtn').addEventListener('click', () => {
  const idx = layers.findIndex(l=>l.id===selId);
  if (idx < 0 || idx >= layers.length-1) return;
  [layers[idx], layers[idx+1]] = [layers[idx+1], layers[idx]];
  renderLayerList(); render();
});
document.getElementById('layerDownBtn').addEventListener('click', () => {
  const idx = layers.findIndex(l=>l.id===selId);
  if (idx < 1) return;
  [layers[idx], layers[idx-1]] = [layers[idx-1], layers[idx]];
  renderLayerList(); render();
});

// ═══════════════════════════════════════════
//  LAYER PROPERTIES
// ═══════════════════════════════════════════
function renderProps() {
  const wrap = document.getElementById('propsContent');
  const sec = document.getElementById('layerProps');
  const l = selLayer();
  if (!l) { sec.style.display = 'none'; return; }
  sec.style.display = '';

  let html = `
    <div class="sg-row"><span class="sg-lbl">X</span><input type="number" class="sg-input" data-prop="x" value="${Math.round(l.x)}" style="width:60px">
    <span class="sg-lbl">Y</span><input type="number" class="sg-input" data-prop="y" value="${Math.round(l.y)}" style="width:60px"></div>
    <div class="sg-row"><span class="sg-lbl">W</span><input type="number" class="sg-input" data-prop="w" value="${Math.round(l.w)}" style="width:60px">
    <span class="sg-lbl">H</span><input type="number" class="sg-input" data-prop="h" value="${Math.round(l.h||0)}" style="width:60px"></div>
    <div class="sg-row"><span class="sg-lbl">Opacity</span><input type="range" data-prop="opacity" min="0" max="1" step="0.05" value="${l.opacity}" style="flex:1"></div>`;

  if (l.type === 'text') {
    html += `
      <div class="sg-row"><span class="sg-lbl">Text</span><input type="text" class="sg-input" data-prop="text" value="${esc(l.text)}" style="flex:1"></div>
      <div class="sg-row"><span class="sg-lbl">Size</span><input type="number" class="sg-input" data-prop="fontSize" value="${l.fontSize}" style="width:55px">
      <span class="sg-lbl">Font</span><select class="sg-select" data-prop="fontFamily" style="flex:1">
        ${['Cormorant Garamond','Playfair Display','Lora','Merriweather','Libre Baskerville','Jost','Inter','Poppins','Raleway','Nunito','DM Sans','Arial','Georgia','Impact','Courier New']
          .map(f => '<option value="'+f+'" '+(l.fontFamily===f?'selected':'')+'>'+f+'</option>').join('')}
      </select></div>
      <div class="sg-row"><span class="sg-lbl">Color</span><input type="color" data-prop="color" value="${l.color}" style="width:32px;height:24px;border:1px solid var(--ivory-mid);cursor:pointer;">
      <span class="sg-lbl">Align</span><select class="sg-select" data-prop="align" style="width:70px">
        <option ${l.align==='left'?'selected':''}>left</option><option ${l.align==='center'?'selected':''}>center</option><option ${l.align==='right'?'selected':''}>right</option>
      </select>
      <label style="font-size:0.65rem;display:flex;align-items:center;gap:3px;"><input type="checkbox" data-prop="bold" ${l.bold?'checked':''}> B</label>
      <label style="font-size:0.65rem;display:flex;align-items:center;gap:3px;"><input type="checkbox" data-prop="italic" ${l.italic?'checked':''}> I</label>
      </div>`;
  }
  if (l.type === 'rect') {
    html += `
      <div class="sg-row"><span class="sg-lbl">Fill</span><input type="color" data-prop="fill" value="${l.fill||'#000000'}" style="width:32px;height:24px;cursor:pointer;">
      <span class="sg-lbl">Stroke</span><input type="color" data-prop="stroke" value="${l.stroke||'#000000'}" style="width:32px;height:24px;cursor:pointer;">
      <input type="number" class="sg-input" data-prop="strokeWidth" value="${l.strokeWidth||0}" style="width:40px" title="Stroke width"></div>
      <div class="sg-row"><span class="sg-lbl">Radius</span><input type="number" class="sg-input" data-prop="radius" value="${l.radius||0}" style="width:50px"></div>`;
  }
  if (l.type === 'circle') {
    html += `
      <div class="sg-row"><span class="sg-lbl">Fill</span><input type="color" data-prop="fill" value="${l.fill||'#000000'}" style="width:32px;height:24px;cursor:pointer;">
      <span class="sg-lbl">Stroke</span><input type="color" data-prop="stroke" value="${l.stroke||'#000000'}" style="width:32px;height:24px;cursor:pointer;">
      <input type="number" class="sg-input" data-prop="strokeWidth" value="${l.strokeWidth||0}" style="width:40px"></div>`;
  }
  if (l.type === 'line') {
    html += `
      <div class="sg-row"><span class="sg-lbl">Stroke</span><input type="color" data-prop="stroke" value="${l.stroke||'#000000'}" style="width:32px;height:24px;cursor:pointer;">
      <input type="number" class="sg-input" data-prop="strokeWidth" value="${l.strokeWidth||2}" style="width:40px">
      <span class="sg-lbl">Dash</span><input type="number" class="sg-input" data-prop="dash" value="${l.dash||0}" style="width:40px"></div>`;
  }

  wrap.innerHTML = html;

  // Bind prop inputs
  wrap.querySelectorAll('[data-prop]').forEach(el => {
    const ev = (el.type === 'range' || el.type === 'color') ? 'input' : 'change';
    el.addEventListener(ev, () => {
      const prop = el.dataset.prop;
      const numProps = ['x','y','w','h','fontSize','strokeWidth','radius','dash','opacity'];
      const boolProps = ['bold','italic'];
      if (boolProps.includes(prop)) l[prop] = el.checked;
      else if (numProps.includes(prop)) l[prop] = parseFloat(el.value) || 0;
      else l[prop] = el.value;
      render();
    });
  });
}

// ═══════════════════════════════════════════
//  PRESETS — SAVE / LOAD
// ═══════════════════════════════════════════
function serializeLayers() {
  return layers.map(l => {
    const s = { ...l };
    delete s.img; delete s.vid; // can't serialize DOM elements
    return s;
  });
}

function deserializeLayers(arr) {
  layers = [];
  selId = null;
  nextId = 1;
  let loadCount = 0;
  const total = arr.length;
  arr.forEach(data => {
    const l = { ...data, id: nextId++, visible: data.visible !== false, opacity: data.opacity ?? 1 };
    if (l.type === 'image' && l.src) {
      const img = new Image();
      img.crossOrigin = 'anonymous';
      img.onload = () => { l.img = img; if(++loadCount >= total) render(); };
      img.onerror = () => { if(++loadCount >= total) render(); };
      img.src = l.src;
    } else if (l.type === 'video' && l.src) {
      const vid = document.createElement('video');
      vid.crossOrigin = 'anonymous'; vid.src = l.src; vid.muted = true; vid.loop = true; vid.playsInline = true;
      vid.addEventListener('loadedmetadata', () => { l.vid = vid; vid.play().catch(()=>{}); if(++loadCount>=total) render(); });
      vid.addEventListener('error', () => { if(++loadCount>=total) render(); });
    } else {
      loadCount++;
    }
    layers.push(l);
  });
  if (!total) render();
  renderLayerList();
}

document.getElementById('savePresetBtn').addEventListener('click', async () => {
  const name = document.getElementById('presetName').value.trim() || 'Untitled';
  const body = {
    name, canvasW, canvasH, sizePreset: sizeName, bgColor,
    palette: currentPalette,
    layers: serializeLayers(),
    clientId: buildForType === 'client' ? buildForId : null,
    brandTarget: buildForType === 'client' ? buildForId : 'tenant',
    folder: document.getElementById('exportFolder').value || 'clients',
  };
  try {
    let r;
    if (currentPresetId) {
      r = await fetch(`/admin/assets/social/presets/${currentPresetId}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
    } else {
      r = await fetch('/admin/assets/social/presets', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
    }
    const data = await r.json();
    if (data.success) {
      if (data.preset) currentPresetId = data.preset._id;
      loadPresetList();
      document.getElementById('presetName').value = name;
    }
  } catch(err) { alert('Error saving preset: '+err.message); }
});

async function loadPresetList() {
  try {
    // If brand kit is loaded, show its presets; otherwise fetch all
    let presets = [];
    if (currentBrandKit?.presets?.length) {
      presets = currentBrandKit.presets;
    } else {
      const qs = buildForType === 'client' && buildForId ? `?clientId=${buildForId}` : '';
      const r = await fetch('/admin/assets/social/presets' + qs);
      const data = await r.json();
      presets = data.presets || [];
    }
    const wrap = document.getElementById('presetList');
    wrap.innerHTML = '';
    if (!presets.length) {
      wrap.innerHTML = '<div style="font-size:0.65rem;color:var(--slate);">No saved presets for this brand.</div>';
      return;
    }
    presets.forEach(p => {
      const div = document.createElement('div');
      div.className = 'preset-item';
      const owner = p.clientId ? (clientsList.find(c => c._id === p.clientId)?.name || 'Client') : 'Brand';
      div.innerHTML = `<span class="pi-name">${esc(p.name)}</span><span class="pi-size" style="opacity:0.6;">${owner} · ${p.canvasW}x${p.canvasH}</span><span class="pi-del" data-del="${p._id}" title="Delete">✕</span>`;
      div.addEventListener('click', e => {
        if (e.target.dataset.del) return;
        loadPreset(p);
      });
      div.querySelector('[data-del]').addEventListener('click', async e => {
        e.stopPropagation();
        if (!confirm('Delete preset "'+p.name+'"?')) return;
        await fetch(`/admin/assets/social/presets/${p._id}`, { method:'DELETE' });
        currentBrandKit = null; // force refetch
        loadPresetList();
      });
      wrap.appendChild(div);
    });
  } catch(e) {}
}

function loadPreset(p) {
  currentPresetId = p._id;
  setCanvasSize(p.canvasW, p.canvasH, p.sizePreset || `${p.canvasW}x${p.canvasH}`);
  bgColor = p.bgColor || '#F5F3EF';
  document.getElementById('bgColor').value = bgColor;
  document.getElementById('bgColorHex').value = bgColor;
  if (p.palette?.length) { currentPalette = [...p.palette]; renderPalette(); }
  document.getElementById('presetName').value = p.name;
  if (p.clientId) document.getElementById('clientSelect').value = p.clientId;
  if (p.folder) document.getElementById('exportFolder').value = p.folder;
  // highlight correct size btn
  document.querySelectorAll('.sz-btn').forEach(b => b.classList.toggle('active', b.dataset.name === p.sizePreset));
  deserializeLayers(p.layers || []);
}

// ═══════════════════════════════════════════
//  EXPORT
// ═══════════════════════════════════════════
document.getElementById('downloadPngBtn').addEventListener('click', () => {
  // render at full res without selection outline
  const prevSel = selId; selId = null; render();
  const link = document.createElement('a');
  const title = document.getElementById('exportTitle').value.trim() || 'social-asset';
  link.download = `${title}-${sizeName}.png`;
  link.href = canvas.toDataURL('image/png');
  link.click();
  selId = prevSel; render();
});

document.getElementById('saveLibBtn').addEventListener('click', async () => {
  const status = document.getElementById('exportStatus');
  status.textContent = 'Uploading...';
  const prevSel = selId; selId = null; render();
  try {
    const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/png'));
    selId = prevSel; render();
    const title = document.getElementById('exportTitle').value.trim() || 'social-asset';
    const folder = document.getElementById('exportFolder').value;
    const clientId = document.getElementById('clientSelect').value;
    const fd = new FormData();
    fd.append('image', blob, `${title}-${sizeName}.png`);
    fd.append('folder', folder);
    fd.append('title', title);
    fd.append('preset', sizeName);
    if (clientId) fd.append('clientId', clientId);
    const r = await fetch('/admin/assets/social-upload', { method:'POST', body: fd });
    const data = await r.json();
    status.textContent = data.success ? '✓ Saved to library!' : ('Error: '+(data.error||'Failed'));
    setTimeout(() => { status.textContent = ''; }, 3000);
  } catch(err) { selId = prevSel; render(); status.textContent = 'Error: '+err.message; }
});

// ═══════════════════════════════════════════
//  HELPERS
// ═══════════════════════════════════════════
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// ═══════════════════════════════════════════
//  AGENT → GENERATOR BRIDGE
//  Called from agent panel to load a design
//  as editable layers in the canvas
// ═══════════════════════════════════════════
window.loadAgentDesign = function(design) {
  // Set canvas size
  const DIMS = {
    'ig-post':[1080,1080],'ig-story':[1080,1920],'fb-post':[1200,630],
    'fb-cover':[1640,624],'twitter':[1600,900],'pinterest':[1000,1500],
    'yt-thumb':[1280,720],'linkedin':[1200,627],'ig-portrait':[1080,1350],
  };
  const sz = design.size || 'ig-post';
  const [w, h] = DIMS[sz] || DIMS['ig-post'];
  setCanvasSize(w, h, sz);
  // Activate matching size button
  document.querySelectorAll('.sz-btn').forEach(b => b.classList.toggle('active', b.dataset.name === sz));

  // Set background color
  bgColor = design.bgColor || '#F5F3EF';
  document.getElementById('bgColor').value = bgColor;
  document.getElementById('bgColorHex').value = bgColor;

  // Clear existing layers and load new ones
  layers = [];
  selId = null;
  nextId = 1;

  // Build full layer list: SD background (if any) at bottom, then agent layers on top
  const allLayers = [];
  if (design.sdBgUrl) {
    allLayers.push({ type:'image', x:0, y:0, w, h, src:design.sdBgUrl, name:'AI Background', _aiBg:true });
  }
  (design.layers || []).forEach(l => allLayers.push(l));

  let loadPending = 0;
  const totalImages = allLayers.filter(l => l.type === 'image' && l.src).length;

  allLayers.forEach(data => {
    const l = { ...data, id: nextId++, visible: true, opacity: data.opacity ?? 1 };
    if (l.type === 'image' && l.src) {
      const im = new Image();
      im.crossOrigin = 'anonymous';
      im.onload = () => { l.img = im; if (++loadPending >= totalImages) render(); };
      im.onerror = () => { if (++loadPending >= totalImages) render(); };
      im.src = l.src;
    }
    layers.push(l);
  });

  renderLayerList();
  if (!totalImages) render();

  // Close agent panel
  document.getElementById('agentPanel')?.classList.remove('open');
};

// init
scaleCanvas();
render();
renderLayerList();

})();
</script>

