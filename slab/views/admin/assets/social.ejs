<script>
(function(){
'use strict';

// ═══════════════════════════════════════════
//  MOBILE FLOATING TOOL RAIL
// ═══════════════════════════════════════════
const sgMobOverlay = document.getElementById('sgMobOverlay');
const sgMobBackdrop = document.getElementById('sgMobBackdrop');
const sgMobBody = document.getElementById('sgMobOverlayBody');
const sgMobTitle = document.getElementById('sgMobOverlayTitle');

// Map FAB ids to which accordion section(s) to clone into the overlay
const fabSectionMap = {
  size:    ['secSize'],
  add:     ['secAdd'],
  bg:      ['secBg', 'secAiBg'],
  palette: ['secPal'],
  export:  ['secExport'],
  layers:  '_layers',
  tools:   '_all',
};
const fabTitleMap = {
  size: 'Canvas Size', add: 'Add Layers', bg: 'Background',
  palette: 'Colors', export: 'Export', layers: 'Layers', tools: 'All Tools',
};

function sgMobOpen(fabKey) {
  if (!sgMobOverlay) return;
  sgMobTitle.textContent = fabTitleMap[fabKey] || 'Tools';
  sgMobBody.innerHTML = '';

  const mapping = fabSectionMap[fabKey];
  if (mapping === '_layers') {
    // Clone layers panel content
    const rp = document.getElementById('sgPanelRight');
    if (rp) sgMobBody.innerHTML = rp.querySelector('.sg-panel-scroll')?.innerHTML || '';
    const lp = document.getElementById('layerProps');
    if (lp && lp.style.display !== 'none') sgMobBody.innerHTML += lp.outerHTML;
  } else if (mapping === '_all') {
    // Clone entire tools panel
    const lp = document.getElementById('sgPanelLeft');
    if (lp) sgMobBody.innerHTML = lp.querySelector('.sg-panel-scroll')?.innerHTML || '';
  } else if (Array.isArray(mapping)) {
    mapping.forEach(secId => {
      const sec = document.getElementById(secId);
      if (sec) sgMobBody.innerHTML += sec.parentElement.outerHTML;
    });
  }

  // Wire up accordion toggles inside overlay
  sgMobBody.querySelectorAll('.sg-sec-head[data-toggle]').forEach(h => {
    h.addEventListener('click', () => {
      const body = h.nextElementSibling;
      if (body) body.classList.toggle('collapsed');
      const arrow = h.querySelector('span');
      if (arrow) arrow.textContent = body?.classList.contains('collapsed') ? '▸' : '▾';
    });
  });

  // Event delegation for size preset buttons in overlay
  sgMobBody.querySelectorAll('.sz-btn').forEach(b => {
    b.addEventListener('click', () => {
      sgMobBody.querySelectorAll('.sz-btn').forEach(x => x.classList.remove('active'));
      document.querySelectorAll('.sz-btn').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
      if (typeof setCanvasSize === 'function') setCanvasSize(+b.dataset.w, +b.dataset.h, b.dataset.name);
    });
  });

  // Event delegation for tool-btn clicks (add layer, generate, etc.)
  sgMobBody.querySelectorAll('.tool-btn').forEach(btn => {
    if (btn.id) {
      const orig = document.getElementById(btn.id);
      if (orig && orig !== btn) btn.addEventListener('click', (e) => { e.preventDefault(); orig.click(); });
    }
  });

  // Sync inputs back: listen for changes in overlay and relay to real panel
  sgMobBody.querySelectorAll('input, select, textarea').forEach(el => {
    if (!el.id) return;
    const orig = document.getElementById(el.id);
    if (!orig || orig === el) return;
    // Sync current value from original to overlay copy
    el.value = orig.value;
    el.addEventListener('input', () => { orig.value = el.value; orig.dispatchEvent(new Event('input', {bubbles:true})); });
    el.addEventListener('change', () => { orig.value = el.value; orig.dispatchEvent(new Event('change', {bubbles:true})); });
  });
  sgMobBody.querySelectorAll('button').forEach(btn => {
    if (btn.id && !btn.classList.contains('tool-btn')) {
      const orig = document.getElementById(btn.id);
      if (orig && orig !== btn) btn.addEventListener('click', () => orig.click());
    }
  });

  sgMobOverlay.classList.add('open');
  sgMobBackdrop.classList.add('open');
  document.querySelectorAll('.sg-fab').forEach(f => f.classList.toggle('active', f.dataset.fab === fabKey));
}

function sgMobClose() {
  if (sgMobOverlay) sgMobOverlay.classList.remove('open');
  if (sgMobBackdrop) sgMobBackdrop.classList.remove('open');
  document.querySelectorAll('.sg-fab').forEach(f => f.classList.remove('active'));
}

document.querySelectorAll('.sg-fab').forEach(fab => {
  fab.addEventListener('click', () => {
    const key = fab.dataset.fab;
    if (sgMobOverlay?.classList.contains('open') && fab.classList.contains('active')) {
      sgMobClose();
    } else {
      sgMobOpen(key);
    }
  });
});
document.getElementById('sgMobOverlayClose')?.addEventListener('click', sgMobClose);
document.getElementById('sgMobBackdrop')?.addEventListener('click', sgMobClose);

