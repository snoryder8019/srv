<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard — Candace Wallace</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --navy: #1C2B4A;
      --navy-deep: #0F1B30;
      --gold: #C9A848;
      --gold-light: #E8D08A;
      --ivory: #F5F3EF;
      --ivory-mid: #E6E1D6;
      --slate: #6B7380;
      --dark: #0F1B30;
      --white: #FDFCFA;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Jost', sans-serif; background: var(--ivory); color: var(--dark); min-height: 100vh; }

    /* Sidebar */
    .layout { display: flex; min-height: 100vh; }
    .sidebar {
      width: 240px;
      background: var(--navy-deep);
      display: flex;
      flex-direction: column;
      padding: 32px 0;
      flex-shrink: 0;
    }
    .sidebar-brand {
      padding: 0 28px 32px;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .sidebar-brand-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      font-weight: 300;
      color: var(--white);
    }
    .sidebar-brand-sub {
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
      margin-top: 4px;
    }
    .sidebar-nav { padding: 24px 0; flex: 1; }
    .sidebar-nav a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 11px 28px;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.45);
      text-decoration: none;
      transition: color 0.2s, background 0.2s;
    }
    .sidebar-nav a:hover,
    .sidebar-nav a.active { color: var(--gold-light); background: rgba(201,168,72,0.07); }
    .sidebar-footer {
      padding: 24px 28px 0;
      border-top: 1px solid rgba(255,255,255,0.07);
    }
    .sidebar-user-name {
      font-size: 0.82rem;
      font-weight: 500;
      color: rgba(255,255,255,0.6);
      margin-bottom: 12px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .btn-logout {
      display: block;
      background: rgba(139,28,28,0.15);
      color: rgba(255,100,100,0.7);
      border: 1px solid rgba(139,28,28,0.25);
      padding: 8px 16px;
      border-radius: 2px;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      text-align: center;
      transition: background 0.2s;
    }
    .btn-logout:hover { background: rgba(139,28,28,0.3); }

    /* Main */
    .main { flex: 1; display: flex; flex-direction: column; }
    .topbar {
      background: var(--white);
      border-bottom: 1px solid var(--ivory-mid);
      padding: 20px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .topbar-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem;
      font-weight: 300;
      color: var(--dark);
    }
    .topbar-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(201,168,72,0.1);
      border: 1px solid rgba(201,168,72,0.3);
      border-radius: 2px;
      padding: 6px 14px;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .content { padding: 40px; flex: 1; }

    .stat-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 40px;
    }
    .stat-card {
      background: var(--white);
      border: 1px solid var(--ivory-mid);
      padding: 28px 24px;
    }
    .stat-card-label {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--slate);
      margin-bottom: 10px;
    }
    .stat-card-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.8rem;
      font-weight: 300;
      color: var(--navy);
      line-height: 1;
    }

    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      font-weight: 300;
      color: var(--dark);
      margin-bottom: 20px;
    }

    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 40px; }

    .info-card {
      background: var(--white);
      border: 1px solid var(--ivory-mid);
      padding: 28px 24px;
    }
    .info-card-label {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--slate);
      margin-bottom: 8px;
    }
    .info-card-value {
      font-size: 0.95rem;
      font-weight: 400;
      color: var(--dark);
    }

    .view-site-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--navy);
      color: var(--white);
      padding: 12px 28px;
      text-decoration: none;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-radius: 2px;
      transition: background 0.2s;
    }
    .view-site-btn:hover { background: var(--navy-deep); }
  </style>
</head>
<body>
<div class="layout">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-brand">
      <div class="sidebar-brand-name">Candace Wallace</div>
      <div class="sidebar-brand-sub">Admin Portal</div>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin" class="active">Dashboard</a>
      <a href="/">View Public Site</a>
    </nav>
    <div class="sidebar-footer">
      <div class="sidebar-user-name"><%= user.displayName %></div>
      <a href="/auth/logout" class="btn-logout">Sign Out</a>
    </div>
  </aside>

  <!-- Main -->
  <div class="main">
    <div class="topbar">
      <div class="topbar-title">Dashboard</div>
      <div class="topbar-badge">Admin Access</div>
    </div>
    <div class="content">
      <div class="stat-row">
        <div class="stat-card">
          <div class="stat-card-label">Status</div>
          <div class="stat-card-num" style="font-size:1.4rem;color:#2a7a2a;">Live</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-label">Services</div>
          <div class="stat-card-num">3</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-label">Auth</div>
          <div class="stat-card-num" style="font-size:1.2rem;">JWT</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-label">Session</div>
          <div class="stat-card-num" style="font-size:1.2rem;">8h</div>
        </div>
      </div>

      <div class="section-title">Account Info</div>
      <div class="info-grid">
        <div class="info-card">
          <div class="info-card-label">Signed in as</div>
          <div class="info-card-value"><%= user.email %></div>
        </div>
        <div class="info-card">
          <div class="info-card-label">Display Name</div>
          <div class="info-card-value"><%= user.displayName %></div>
        </div>
        <div class="info-card">
          <div class="info-card-label">Admin Role</div>
          <div class="info-card-value">Candace Wallace Admin</div>
        </div>
        <div class="info-card">
          <div class="info-card-label">Auth Provider</div>
          <div class="info-card-value">Google OAuth 2.0 + JWT</div>
        </div>
      </div>

      <a href="/" class="view-site-btn">View Public Site &rarr;</a>
    </div>
  </div>
</div>
</body>
</html>
