<%- include('../partials/head', { title: 'Triple-Twenty' }) %>

<div class="lobby">

  <!-- ══ HERO ══ -->
  <div class="lobby-hero">
    <div class="dart-icon">🎯</div>
    <h1>Triple-Twenty</h1>
    <p class="subtitle">AI-Powered Darts Scoring System</p>
  </div>

  <!-- ══ PITCH / TRUST ══ -->
  <section class="lobby-pitch">
    <div class="pitch-grid">
      <div class="pitch-card">
        <div class="pitch-icon">📈</div>
        <h3>Keep Track</h3>
        <p>Persistent stats, head-to-head history, and a leaderboard across every game you play.</p>
      </div>
      <div class="pitch-card">
        <div class="pitch-icon">👥</div>
        <h3>Play with Friends</h3>
        <p>Multiplayer camera sessions, per-player remotes, and live notifications when it's your turn.</p>
      </div>
      <div class="pitch-card">
        <div class="pitch-icon">🎯</div>
        <h3>Cricket &amp; 501</h3>
        <p>Solo practice or 2–4 player versus. Full cricket and 501 rulesets with bust detection.</p>
      </div>
      <div class="pitch-card pitch-card-wide">
        <div class="pitch-icon">🤖</div>
        <h3>You're Teaching the Robot</h3>
        <p>
          Every correction you submit helps train some guy's basement computer to score darts better.
          <strong>Your data is never sold and never shared.</strong> It's used only to run the app
          and improve scoring — nothing else.
        </p>
        <p class="pitch-fineprint">
          Google handles sign-in, so we never see your password. Traffic runs over HTTPS. Your name,
          email, and game records sit in our database as plain text — no fancier than that.
        </p>
      </div>
    </div>
  </section>

  <!-- ══ LIVE EVENTS ══ -->
  <section class="live-section" id="liveSection">
    <div class="live-section-header">
      <span class="live-badge-lg">● LIVE</span>
      <h2>Active Games</h2>
      <span class="live-count" id="liveCount"></span>
    </div>

    <% if (activeGames && activeGames.length > 0) { %>
      <div class="live-games-grid" id="liveGamesGrid">
        <% activeGames.forEach(function(game) { %>
          <div class="live-game-card" id="lgc_<%= game._id %>" data-game-id="<%= game._id %>" data-mode="<%= game.mode %>">
            <div class="lgc-header">
              <span class="lgc-mode"><%= game.mode.toUpperCase() %></span>
              <span class="lgc-title"><%= game.name || game.players.map(function(p){return p.name}).join(' vs ') %></span>
              <span class="lgc-status <%= game.status === 'active' ? 'status-active' : 'status-waiting' %>">
                <%= game.status === 'active' ? '● Live' : '◌ Waiting' %>
              </span>
              <span class="lgc-rounds">R<%= game.roundCount %></span>
            </div>
            <div class="lgc-feed-wrap">
              <img class="lgc-feed-img" id="lgcImg_<%= game._id %>_0" src="" alt="" style="display:none;">
              <div class="lgc-feed-placeholder" id="lgcPlaceholder_<%= game._id %>">
                <span>📷</span><span>Waiting for camera</span>
              </div>
              <div class="lgc-dart-overlay" id="lgcDarts_<%= game._id %>"></div>
            </div>
            <div class="lgc-scoreboard" id="lgcBoard_<%= game._id %>">
              <% game.players.forEach(function(p, i) { %>
                <div class="lgc-player <%= i === game.currentPlayerIndex && game.status === 'active' ? 'lgc-active-player' : '' %>"
                     id="lgcPlayer_<%= game._id %>_<%= i %>">
                  <span class="lgc-player-name"><%= p.name %></span>
                  <% if (game.mode === '501') { %>
                    <span class="lgc-player-score" id="lgcScore_<%= game._id %>_<%= i %>"><%= p.remaining %></span>
                  <% } else { %>
                    <span class="lgc-player-score" id="lgcScore_<%= game._id %>_<%= i %>"><%= p.cricketPoints || 0 %> pts</span>
                  <% } %>
                  <% if (i === game.currentPlayerIndex && game.status === 'active') { %>
                    <span class="lgc-turn-dot">▶</span>
                  <% } %>
                </div>
              <% }); %>
            </div>
            <% if (game.lastRound) { %>
              <div class="lgc-last-round" id="lgcLastRound_<%= game._id %>">
                Last: <%= (game.lastRound.darts || []).map(d => d.score).join(' + ') %> = <strong><%= game.lastRound.total %></strong>
              </div>
            <% } else { %>
              <div class="lgc-last-round" id="lgcLastRound_<%= game._id %>">No rounds yet</div>
            <% } %>
            <div class="lgc-actions">
              <a href="/game/<%= game._id %>" class="btn btn-sm">📺 Watch</a>
              <a href="/remote/<%= game.inviteCode %>" class="btn btn-sm btn-primary">Join →</a>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="live-empty" id="liveEmpty">
        <span>No active games right now.</span>
        <span class="hint">Start one below and it'll appear here live.</span>
      </div>
    <% } %>
    <div class="live-games-grid" id="liveGamesGridDynamic" style="<%= activeGames && activeGames.length ? 'display:none' : '' %>"></div>
  </section>

  <!-- ══ NEW GAME + JOIN + LEADERBOARD ══ -->
  <div class="lobby-grid">

    <div class="card new-game-card">
      <h2>🎮 New Game</h2>
      <div class="form-group">
        <label>Game Mode</label>
        <div class="mode-select">
          <button type="button" class="mode-btn active" data-mode="501">501</button>
          <button type="button" class="mode-btn" data-mode="cricket">Cricket</button>
        </div>
        <input type="hidden" id="gameMode" value="501">
      </div>
      <div class="form-group">
        <label>Play Style</label>
        <div class="mode-select">
          <button type="button" class="play-style-btn active" data-style="versus">👥 Versus (2–4)</button>
          <button type="button" class="play-style-btn" data-style="solo">🎯 Solo</button>
        </div>
        <input type="hidden" id="playStyle" value="versus">
      </div>
      <div class="form-group" id="playersGroup">
        <label>Players</label>
        <div id="playerList">
          <input type="text" name="player" placeholder="Player 1" class="player-input">
          <input type="text" name="player" placeholder="Player 2" class="player-input">
        </div>
        <button type="button" id="addPlayerBtn" class="btn btn-sm" style="margin-top:8px">+ Add Player</button>
        <div class="hint" style="margin-top:6px;">Up to 4 players. Cricket uses standard multi-player rules.</div>
      </div>
      <div class="form-group">
        <label>Host Camera Source</label>
        <div class="cam-type-row">
          <button type="button" class="cam-type-btn active" data-cam="phone">📱 Phone</button>
          <button type="button" class="cam-type-btn" data-cam="ip">📷 IP Cam</button>
        </div>
        <input type="hidden" id="camType" value="phone">
        <div id="ipCamFields" style="display:none; margin-top:10px;">
          <input type="text" id="camIp" placeholder="192.168.1.x">
          <div class="cam-creds-row" style="margin-top:6px;">
            <input type="text" id="camUser" placeholder="Username">
            <input type="password" id="camPass" placeholder="Password">
          </div>
          <button type="button" id="testCamBtn" class="btn btn-sm" style="margin-top:8px">Test Camera</button>
          <div id="camPreview" style="display:none; margin-top:8px;">
            <img id="camTestImg" style="max-width:100%; border-radius:8px; border:1px solid var(--border);">
          </div>
        </div>
      </div>
      <button type="button" id="startGameBtn" class="btn btn-primary btn-lg" style="width:100%;">
        Create Game &amp; Get Invite
      </button>
      <div id="createError" class="error-msg" style="display:none;"></div>
    </div>

    <div class="lobby-side-col">
      <div class="card join-card">
        <h2>🔗 Join Game</h2>
        <p class="hint">Have an invite code? Jump right in.</p>
        <div class="join-row">
          <input type="text" id="joinCode" placeholder="A3F2..." maxlength="8"
            style="text-transform:uppercase; font-size:1.3rem; letter-spacing:3px; text-align:center;">
          <button class="btn btn-primary" id="joinBtn">Join →</button>
        </div>
        <div id="joinError" class="error-msg" style="display:none;"></div>
      </div>
      <div class="card leaderboard-shortcut">
        <h2>🏆 Leaderboard</h2>
        <p class="hint">Rankings, head-to-head history, and ML correction stats.</p>
        <a href="/leaderboard" class="btn btn-primary" style="width:100%; margin-top:8px;">View Leaderboard</a>
        <a href="/audience" class="btn btn-sm" style="width:100%; margin-top:6px;">📺 Audience View (multi-game)</a>
      </div>
    </div>
  </div>

  <!-- ══ INVITE MODAL ══ -->
  <div class="modal-overlay" id="inviteModal" style="display:none;">
    <div class="modal-card">
      <h2>Game Created! 🎯</h2>
      <p>Share this invite with your players</p>
      <div class="invite-code" id="inviteCodeDisplay"></div>
      <div class="invite-url-row">
        <input type="text" id="inviteUrlInput" readonly>
        <button class="btn btn-sm" id="copyInviteBtn">Copy</button>
      </div>
      <div class="qr-wrap" id="qrWrap"></div>
      <div class="modal-actions">
        <a id="hostGameLink" class="btn btn-primary btn-lg">Open Host View →</a>
        <a id="scoreboardLink" class="btn btn-secondary" target="_blank">📺 Scoreboard</a>
      </div>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<!-- Non-socket JS runs fine before foot.ejs -->
<script>
async function loadActiveGames() {
  try {
    const resp = await fetch('/api/active-games');
    const { games } = await resp.json();
    const countEl = document.getElementById('liveCount');
    const activeCount = games.filter(g => g.status === 'active').length;
    if (countEl) countEl.textContent = games.length ? `${activeCount} live · ${games.length} total` : '';

    if (!games.length) {
      const empty = document.getElementById('liveEmpty');
      const grid  = document.getElementById('liveGamesGrid');
      if (empty) empty.style.display = 'flex';
      if (grid)  grid.style.display  = 'none';
      document.getElementById('liveGamesGridDynamic').innerHTML = '';
      return;
    }
    const empty = document.getElementById('liveEmpty');
    if (empty) empty.style.display = 'none';
    const dynamicGrid = document.getElementById('liveGamesGridDynamic');
    dynamicGrid.style.display = 'grid';
    dynamicGrid.innerHTML = games.map(renderGameCard).join('');
    const ssrGrid = document.getElementById('liveGamesGrid');
    if (ssrGrid) ssrGrid.style.display = 'none';
  } catch (err) { console.error('Could not load active games', err); }
}

function renderGameCard(g) {
  const playerRows = g.players.map((p, i) => {
    const active = i === g.currentPlayerIndex && g.status === 'active';
    const score  = g.mode === '501' ? p.remaining : (p.cricketPoints || 0) + ' pts';
    return `<div class="lgc-player ${active ? 'lgc-active-player' : ''}" id="lgcPlayer_${g._id}_${i}">
      <span class="lgc-player-name">${p.name}</span>
      <span class="lgc-player-score" id="lgcScore_${g._id}_${i}">${score}</span>
      ${active ? '<span class="lgc-turn-dot">▶</span>' : ''}
    </div>`;
  }).join('');
  const lastRoundHtml = g.lastRound
    ? `Last: ${(g.lastRound.darts||[]).map(d=>d.score).join(' + ')} = <strong>${g.lastRound.total}</strong>`
    : 'No rounds yet';
  const statusCls  = g.status === 'active' ? 'status-active' : 'status-waiting';
  const statusText = g.status === 'active' ? '● Live' : '◌ Waiting';
  const cardTitle  = g.name || g.players.map(p => p.name).join(' vs ');
  return `<div class="live-game-card" id="lgc_${g._id}" data-game-id="${g._id}" data-mode="${g.mode}">
    <div class="lgc-header">
      <span class="lgc-mode">${g.mode.toUpperCase()}</span>
      <span class="lgc-title">${cardTitle}</span>
      <span class="lgc-status ${statusCls}">${statusText}</span>
      <span class="lgc-rounds">R${g.roundCount}</span>
    </div>
    <div class="lgc-feed-wrap">
      <img class="lgc-feed-img" id="lgcImg_${g._id}_0" src="" alt="" style="display:none;">
      <div class="lgc-feed-placeholder" id="lgcPlaceholder_${g._id}"><span>📷</span><span>Waiting for camera</span></div>
      <div class="lgc-dart-overlay" id="lgcDarts_${g._id}"></div>
    </div>
    <div class="lgc-scoreboard" id="lgcBoard_${g._id}">${playerRows}</div>
    <div class="lgc-last-round" id="lgcLastRound_${g._id}">${lastRoundHtml}</div>
    <div class="lgc-actions">
      <a href="/game/${g._id}" class="btn btn-sm">📺 Watch</a>
      <a href="/remote/${g.inviteCode}" class="btn btn-sm btn-primary">Join →</a>
    </div>
  </div>`;
}

setInterval(loadActiveGames, 15000);

document.querySelectorAll('.mode-btn').forEach(btn =>
  btn.addEventListener('click', () => {
    document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('gameMode').value = btn.dataset.mode;
  }));

document.querySelectorAll('.cam-type-btn').forEach(btn =>
  btn.addEventListener('click', () => {
    document.querySelectorAll('.cam-type-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('camType').value = btn.dataset.cam;
    document.getElementById('ipCamFields').style.display = btn.dataset.cam === 'ip' ? 'block' : 'none';
  }));

document.getElementById('addPlayerBtn').addEventListener('click', () => {
  if (document.getElementById('playStyle').value === 'solo') return;
  const list  = document.getElementById('playerList');
  const count = list.querySelectorAll('input').length + 1;
  if (count > 4) return;
  const inp = document.createElement('input');
  inp.type = 'text'; inp.name = 'player';
  inp.placeholder = 'Player ' + count;
  inp.className = 'player-input';
  list.appendChild(inp);
});

document.getElementById('testCamBtn')?.addEventListener('click', () => {
  const ip = document.getElementById('camIp').value.trim();
  if (!ip) return alert('Enter camera IP first');
  const img = document.getElementById('camTestImg');
  const u = document.getElementById('camUser').value.trim();
  const p = document.getElementById('camPass').value.trim();
  img.src = `http://${u}:${p}@${ip}/cgi-bin/snapshot.cgi?t=${Date.now()}`;
  document.getElementById('camPreview').style.display = 'block';
  img.onerror = () => alert('Could not reach camera. Check you are on the same WiFi.');
});

// Play style toggle
document.querySelectorAll('.play-style-btn').forEach(btn =>
  btn.addEventListener('click', () => {
    document.querySelectorAll('.play-style-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const style = btn.dataset.style;
    document.getElementById('playStyle').value = style;
    const list = document.getElementById('playerList');
    const inputs = list.querySelectorAll('input');
    if (style === 'solo') {
      // Keep only one slot; prefill with "You" if empty
      for (let i = inputs.length - 1; i > 0; i--) inputs[i].remove();
      const first = list.querySelector('input');
      if (first && !first.value) first.placeholder = 'Your name';
      document.getElementById('addPlayerBtn').style.display = 'none';
    } else {
      // Restore versus: if only one slot present, add a second
      document.getElementById('addPlayerBtn').style.display = '';
      if (list.querySelectorAll('input').length < 2) {
        const inp = document.createElement('input');
        inp.type = 'text'; inp.name = 'player';
        inp.placeholder = 'Player 2';
        inp.className = 'player-input';
        list.appendChild(inp);
      }
      const first = list.querySelector('input');
      if (first) first.placeholder = 'Player 1';
    }
  }));

document.getElementById('startGameBtn').addEventListener('click', async () => {
  const style = document.getElementById('playStyle').value;
  const names = Array.from(document.querySelectorAll('.player-input')).map(i => i.value.trim()).filter(Boolean);
  const minPlayers = style === 'solo' ? 1 : 2;
  if (names.length < minPlayers) {
    document.getElementById('createError').textContent =
      style === 'solo' ? 'Enter your name' : 'Add at least 2 players for versus';
    document.getElementById('createError').style.display = 'block';
    return;
  }
  if (style === 'versus' && names.length > 4) {
    document.getElementById('createError').textContent = 'Max 4 players';
    document.getElementById('createError').style.display = 'block';
    return;
  }
  document.getElementById('createError').style.display = 'none';
  const camType = document.getElementById('camType').value;
  let camera = null;
  if (camType === 'ip') {
    const ip = document.getElementById('camIp').value.trim();
    if (ip) camera = { ip, username: document.getElementById('camUser').value.trim(), password: document.getElementById('camPass').value.trim() };
  }
  const btn = document.getElementById('startGameBtn');
  btn.textContent = 'Creating...'; btn.disabled = true;
  try {
    const resp = await fetch('/api/game', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mode: document.getElementById('gameMode').value, players: names.map(n => ({ name: n })), camera })
    });
    const game = await resp.json();
    if (!game._id) throw new Error(game.error || 'Failed');
    showInviteModal(game);
  } catch (err) {
    document.getElementById('createError').textContent = err.message;
    document.getElementById('createError').style.display = 'block';
  } finally { btn.textContent = 'Create Game & Get Invite'; btn.disabled = false; }
});

function showInviteModal(game) {
  const remoteUrl = `${window.location.origin}/remote/${game.inviteCode}`;
  document.getElementById('inviteCodeDisplay').textContent = game.inviteCode;
  document.getElementById('inviteUrlInput').value          = remoteUrl;
  document.getElementById('hostGameLink').href             = `/camera/${game._id}`;
  document.getElementById('scoreboardLink').href           = `/game/${game._id}`;
  document.getElementById('qrWrap').innerHTML = '';
  new QRCode(document.getElementById('qrWrap'), { text: remoteUrl, width: 160, height: 160, colorDark: '#000', colorLight: '#fff' });
  document.getElementById('inviteModal').style.display = 'flex';
}

document.getElementById('copyInviteBtn').addEventListener('click', () => {
  navigator.clipboard.writeText(document.getElementById('inviteUrlInput').value).then(() => {
    document.getElementById('copyInviteBtn').textContent = 'Copied!';
    setTimeout(() => document.getElementById('copyInviteBtn').textContent = 'Copy', 2000);
  });
});
document.getElementById('inviteModal').addEventListener('click', function(e) { if (e.target === this) this.style.display = 'none'; });

document.getElementById('joinBtn').addEventListener('click', () => {
  const code = document.getElementById('joinCode').value.trim().toUpperCase();
  if (code) window.location.href = `/remote/${code}`;
});
document.getElementById('joinCode').addEventListener('keydown', e => {
  if (e.key === 'Enter') document.getElementById('joinBtn').click();
});
</script>

<%- include('../partials/foot') %>

<!-- Socket init — MUST be after foot.ejs so socket.io.js is loaded -->
<script>
const socket = window._ttSocket || io();
window._ttSocket = socket;

socket.on('lobby-update', loadActiveGames);

socket.on('lobby-frame', ({ gameId, playerIndex, frame, analysis }) => {
  const img = document.getElementById('lgcImg_' + gameId + '_' + playerIndex)
           || document.getElementById('lgcImg_' + gameId + '_0');
  if (img) {
    img.src = 'data:image/jpeg;base64,' + frame;
    img.style.display = 'block';
    const ph = document.getElementById('lgcPlaceholder_' + gameId);
    if (ph) ph.style.display = 'none';
  }
  if (analysis?.darts) {
    const overlay = document.getElementById('lgcDarts_' + gameId);
    if (overlay) overlay.innerHTML = analysis.darts.map(d => {
      const p = d.ring === 'double' ? 'D' : d.ring === 'triple' ? 'T' : '';
      return `<span class="lgc-dart-badge">${p}${d.segment}=${d.score}</span>`;
    }).join('');
  }
});

socket.on('lobby-score-update', ({ gameId, players, currentPlayerIndex, lastRound, roundCount }) => {
  players.forEach((p, i) => {
    const scoreEl  = document.getElementById('lgcScore_' + gameId + '_' + i);
    const playerEl = document.getElementById('lgcPlayer_' + gameId + '_' + i);
    if (scoreEl)  scoreEl.textContent = p.remaining !== undefined ? p.remaining : (p.cricketPoints || 0) + ' pts';
    if (playerEl) playerEl.classList.toggle('lgc-active-player', i === currentPlayerIndex);
  });
  const roundsEl = document.querySelector(`[data-game-id="${gameId}"] .lgc-rounds`);
  if (roundsEl) roundsEl.textContent = 'R' + roundCount;
  if (lastRound) {
    const lastEl = document.getElementById('lgcLastRound_' + gameId);
    if (lastEl) lastEl.innerHTML = `Last: ${(lastRound.darts||[]).map(d=>d.score).join(' + ')} = <strong>${lastRound.total}</strong>`;
  }
});

loadActiveGames();
</script>
