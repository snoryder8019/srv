<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Triple-Twenty' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <% if (typeof user !== 'undefined' && user) { %>
  <meta name="tt-user-id"   content="<%= user._id %>">
  <meta name="tt-user-name" content="<%= user.displayName %>">
  <% } %>
</head>
<body>
  <header class="top-bar">
    <a href="/" class="logo">🎯 Triple-Twenty</a>
    <div class="top-right">
      <span class="health-dot" id="healthDot" title="Backend status"></span>
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/dashboard" class="btn btn-sm dash-btn">⚙ My Games</a>
        <div class="user-menu-wrap">
          <button class="user-menu-btn" id="userMenuBtn">
            <% if (user.avatar) { %><img src="<%= user.avatar %>" class="user-avatar"><% } %>
            <span class="user-menu-name"><%= user.displayName.split(' ')[0] %></span>
            <span class="user-menu-chevron">▾</span>
          </button>
          <div class="user-dropdown" id="userDropdown">
            <div class="user-dropdown-header">
              <% if (user.avatar) { %><img src="<%= user.avatar %>" class="user-avatar-lg"><% } %>
              <div>
                <div class="user-dropdown-name"><%= user.displayName %></div>
                <div class="user-dropdown-email"><%= user.email %></div>
              </div>
            </div>
            <a href="/dashboard" class="dropdown-item">⚙ Game Management</a>
            <a href="/leaderboard" class="dropdown-item">🏆 Leaderboard</a>
            <div class="dropdown-divider"></div>
            <a href="/auth/logout" class="dropdown-item dropdown-item-danger">Sign Out</a>
          </div>
        </div>
      <% } else { %>
        <a href="/leaderboard" class="btn btn-sm">🏆 Leaderboard</a>
        <a href="/auth/google" class="btn btn-sm btn-primary">Sign in with Google</a>
      <% } %>
    </div>
  </header>

  <!-- Global turn notification toasts — appear on ALL views -->
  <div id="turnToastContainer"></div>

