<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Triple-Twenty' %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="top-bar">
    <a href="/" class="logo">Triple-Twenty</a>
    <div class="top-right">
      <span class="health-dot" id="healthDot" title="Backend status"></span>
      <% if (typeof user !== 'undefined' && user) { %>
        <span class="user-badge">
          <% if (user.avatar) { %><img src="<%= user.avatar %>" class="user-avatar"><% } %>
          <%= user.displayName %>
        </span>
        <a href="/auth/logout" class="btn btn-sm">Logout</a>
      <% } else { %>
        <a href="/auth/google" class="btn btn-sm btn-primary">Sign in with Google</a>
      <% } %>
    </div>
  </header>
  <main>
    <%- body %>
  </main>
  <script src="/js/app.js"></script>
</body>
</html>
