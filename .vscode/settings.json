{
  // === FILE WATCHER — biggest resource saver ===
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/coverage/**": true,
    "**/.next/**": true,
    "**/package-lock.json": true,
    "**/piper-tts/**": true,
    "**/depricated/**": true
  },

  // === SEARCH — stop ripgrep from scanning node_modules ===
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/package-lock.json": true,
    "**/piper-tts": true,
    "**/depricated": true
  },
  "search.followSymlinks": false,

  // === FILE EXPLORER — skip indexing junk ===
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/depricated": true
  },

  // === TYPESCRIPT — limit the TS server ===
  "typescript.tsserver.maxTsServerMemory": 512,
  "typescript.disableAutomaticTypeAcquisition": true,

  // === EXTENSIONS — disable heavy features ===
  "extensions.autoUpdate": false,
  "extensions.autoCheckUpdates": false,
  "git.autorefresh": false,
  "git.autoRepositoryDetection": "openEditors",

  // === EDITOR — reduce overhead ===
  "editor.minimap.enabled": false,
  "editor.bracketPairColorization.enabled": false,
  "editor.linkedEditing": false,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 8,

  // === TELEMETRY — stop background pings ===
  "telemetry.telemetryLevel": "off"
}
