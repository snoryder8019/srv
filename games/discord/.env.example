# ─── Discord ───────────────────────────────────────────────────────
# From https://discord.com/developers/applications → your app → Bot → Reset Token
DISCORD_TOKEN=replace_me
DISCRD_APP_ID=1506859486218813470
DISCORD_PUB_ID=0e24a00f7c5bfc6a0f5040d7e1b80bbd116156bf90857d65089e94b97aee2d86
# The Discord server (guild) ID where the bot operates.
# Enable Developer Mode in Discord (Settings → Advanced), then right-click your server → Copy Server ID.
DISCORD_GUILD_ID=replace_me

# ─── Games portal ──────────────────────────────────────────────────
# Public stats endpoints; no auth required.
GAMES_API_BASE=https://games.madladslab.com

# ─── Polling cadence (seconds) ─────────────────────────────────────
# Discord rate-limits voice channel renames to 2 per 10 min per channel.
# Keep VOICE_UPDATE_INTERVAL ≥ 360 (6 min) to be safe.
API_POLL_INTERVAL=60
VOICE_UPDATE_INTERVAL=420
EMBED_UPDATE_INTERVAL=60
PRESENCE_ROTATE_INTERVAL=30

# ─── Channel naming ────────────────────────────────────────────────
STATS_CATEGORY_NAME=📊 Server Stats
DASHBOARD_CHANNEL_NAME=games-dashboard

# Set to 1 to hide servers that are offline from the voice-channel list.
HIDE_OFFLINE=0

# ─── Voice channel join → portal toast ─────────────────────────────
# Discord channel ID (or comma-separated list) of the *joinable* voice
# channel(s) you want to surface on the games portal index. Right-click
# the channel → Copy Channel ID. Requires the GuildVoiceStates intent
# (already enabled in index.js).
GAMES_VOICE_CHANNEL_ID=
# Shared secret with the games portal (same value as BRIDGE_SECRET in
# /srv/games/.env). The bot POSTs voice joins to /internal/discord/voice-join
# with this in the X-Bridge-Secret header.
BRIDGE_SECRET=
