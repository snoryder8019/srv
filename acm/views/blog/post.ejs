<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{background:#0a0a0a;color:#f5f0eb;font-family:'Inter',sans-serif;padding:2rem;}
    .container{max-width:700px;margin:0 auto;}
    .meta{font-size:.8rem;opacity:.5;margin-bottom:1.5rem;}
    .badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:.65rem;background:rgba(201,169,110,.2);color:#c9a96e;margin-left:.5rem;}
    h1{font-family:'Playfair Display',serif;font-size:2rem;margin-bottom:.75rem;}
    .content{font-size:.95rem;line-height:1.8;opacity:.85;}
    .content h2,.content h3{font-family:'Playfair Display',serif;margin:1.5rem 0 .75rem;}
    .content p{margin-bottom:1rem;}
    .content img{max-width:100%;border-radius:8px;margin:1rem 0;}
    .tags{margin-top:2rem;display:flex;gap:.5rem;flex-wrap:wrap;}
    .tag{padding:3px 10px;border:1px solid rgba(245,240,235,.15);border-radius:12px;font-size:.75rem;opacity:.6;}
    .back{display:inline-block;margin-top:2rem;color:#c9a96e;font-size:.85rem;text-decoration:none;}
  </style>
</head>
<body>
  <div class="container">
    <a href="/blog" class="back" style="margin-bottom:1.5rem;">&larr; Back to Blog</a>
    <% if (post.coverImage) { %><img src="<%= post.coverImage %>" style="width:100%;border-radius:8px;margin-bottom:1.5rem;"><% } %>
    <h1><%= post.title %></h1>
    <div class="meta"><%= post.publishedAt ? post.publishedAt.toLocaleDateString() : '' %><% if (post.restaurant !== 'all') { %><span class="badge"><%= post.restaurant %></span><% } %><% if (post.category) { %> &middot; <%= post.category %><% } %></div>
    <div class="content"><%- post.content %></div>
    <% if (post.tags && post.tags.length) { %>
    <div class="tags"><% post.tags.forEach(function(t) { %><span class="tag"><%= t %></span><% }); %></div>
    <% } %>
    <a href="/blog" class="back">&larr; All Posts</a>
  </div>
</body>
</html>
