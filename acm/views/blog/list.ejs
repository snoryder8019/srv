<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{background:#0a0a0a;color:#f5f0eb;font-family:'Inter',sans-serif;padding:2rem;}
    .container{max-width:800px;margin:0 auto;}
    .header{text-align:center;margin-bottom:3rem;}
    .header a{display:inline-block;margin-bottom:1rem;}
    .header img{height:40px;filter:brightness(1.2);}
    h1{font-family:'Playfair Display',serif;font-size:2rem;margin-bottom:.5rem;}
    .posts{display:flex;flex-direction:column;gap:1.5rem;}
    .post-card{border:1px solid rgba(245,240,235,.1);border-radius:8px;padding:1.5rem;background:rgba(255,255,255,.02);transition:background .15s;}
    .post-card:hover{background:rgba(255,255,255,.05);}
    .post-card h2{font-family:'Playfair Display',serif;font-size:1.25rem;margin-bottom:.5rem;}
    .post-card h2 a{color:#f5f0eb;text-decoration:none;}
    .post-card h2 a:hover{color:#c9a96e;}
    .post-meta{font-size:.8rem;opacity:.5;margin-bottom:.5rem;}
    .post-excerpt{font-size:.9rem;opacity:.75;line-height:1.6;}
    .badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:.65rem;background:rgba(201,169,110,.2);color:#c9a96e;margin-left:.5rem;}
    .back{display:inline-block;margin-top:2rem;color:#c9a96e;font-size:.85rem;text-decoration:none;}
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <a href="/"><img src="/images/acm.png" alt="ACM"></a>
      <h1>Blog</h1>
    </div>
    <div class="posts">
      <% posts.forEach(function(p) { %>
      <div class="post-card">
        <h2><a href="/blog/<%= p.slug %>"><%= p.title %></a></h2>
        <div class="post-meta"><%= p.publishedAt ? p.publishedAt.toLocaleDateString() : '' %><% if (p.restaurant !== 'all') { %><span class="badge"><%= p.restaurant %></span><% } %></div>
        <% if (p.excerpt) { %><p class="post-excerpt"><%= p.excerpt %></p><% } %>
      </div>
      <% }); %>
      <% if (!posts.length) { %><p style="text-align:center;opacity:.5;">No posts yet.</p><% } %>
    </div>
    <a href="/" class="back">&larr; Back to ACM</a>
  </div>
</body>
</html>
