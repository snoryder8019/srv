<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Claimed — ACM</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{background:#0a0a0a;color:#f5f0eb;font-family:'Inter',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:1rem;}
    .card{width:100%;max-width:420px;border:1px solid rgba(245,240,235,.12);border-radius:12px;background:rgba(255,255,255,.03);padding:2rem;text-align:center;}
    h1{font-family:'Playfair Display',serif;font-size:1.75rem;margin-bottom:.75rem;color:#c9a96e;}
    p{font-size:.9rem;opacity:.75;line-height:1.6;margin-bottom:.5rem;}
    .code{font-family:monospace;font-size:1.5rem;letter-spacing:.15em;margin:1rem 0;padding:.75rem;background:rgba(255,255,255,.06);border-radius:8px;}
    .instructions{font-size:.85rem;opacity:.6;margin-top:1rem;}
  </style>
</head>
<body>
  <div class="card">
    <h1>Offer Claimed!</h1>
    <p>Present this code at <strong><%= RESTAURANTS[promo.restaurant] %></strong></p>
    <div class="code"><%= promo.code %></div>
    <% if (promo.discountValue) { %>
      <p>
        <% if (promo.discountType === 'percent') { %>
          <strong><%= promo.discountValue %>% off</strong> your next visit
        <% } else { %>
          <strong>$<%= promo.discountValue %> off</strong> your next visit
        <% } %>
      </p>
    <% } %>
    <p class="instructions">Show this screen to your server to redeem.</p>
  </div>
</body>
</html>
