<%- include('../layout', { title, section, user }) %>

<div class="quick-actions">
  <a href="/admin/promos/<%= promo._id %>" class="btn">Back to Promo</a>
  <a href="/admin/promos" class="btn">All Promos</a>
</div>

<div class="card">
  <div class="card-header">
    <h2>Redemptions for "<%= promo.name %>" (<%= promo.code %>)</h2>
    <span class="badge badge-<%= promo.isActive ? 'active' : 'inactive' %>"><%= promo.isActive ? 'Active' : 'Inactive' %></span>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr><th>Date</th><th>Customer</th><th>Restaurant</th><th>Scanned By</th><th>Status</th><th>Notes</th></tr>
      </thead>
      <tbody>
        <% redemptions.forEach(function(r) { %>
        <tr>
          <td><%= r.scannedAt.toLocaleString() %></td>
          <td><%= r.user ? (r.user.displayName || r.user.email) : (r.subscriberEmail || '—') %></td>
          <td><%= RESTAURANTS[r.restaurant] || r.restaurant %></td>
          <td><%= r.scannedBy ? (r.scannedBy.displayName || r.scannedBy.email) : '—' %></td>
          <td><span class="badge badge-<%= r.status === 'redeemed' ? 'active' : r.status %>"><%= r.status %></span></td>
          <td><%= r.notes || '—' %></td>
        </tr>
        <% }); %>
        <% if (!redemptions.length) { %>
        <tr><td colspan="6" style="text-align:center;color:var(--text-dim);">No redemptions yet</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../layout-close') %>
