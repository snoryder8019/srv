<%- include('../layout', { title, section, user }) %>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-label">Active Promos</div>
    <div class="stat-value"><%= stats.activePromos %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Total Redemptions</div>
    <div class="stat-value"><%= stats.totalRedemptions %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Nook Redemptions</div>
    <div class="stat-value"><%= stats.restaurantStats.nook || 0 %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Heyday Redemptions</div>
    <div class="stat-value"><%= stats.restaurantStats.heyday || 0 %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Graffiti Redemptions</div>
    <div class="stat-value"><%= stats.restaurantStats.graffiti || 0 %></div>
  </div>
</div>

<div class="quick-actions">
  <a href="/admin/promos/new" class="btn btn-primary">Create Promo</a>
  <a href="/scan" class="btn" target="_blank">Open Scanner</a>
</div>

<div class="card">
  <div class="card-header"><h2>All Promos</h2></div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr><th>QR</th><th>Name</th><th>Type</th><th>Restaurant</th><th>Code</th><th>Redeemed</th><th>Status</th><th></th></tr>
      </thead>
      <tbody>
        <% promos.forEach(function(p) { %>
        <tr>
          <td>
            <div class="qr-preview" style="padding:4px;">
              <img src="<%= getPromoQRUrl(p.code, 60) %>" alt="QR" style="width:50px;height:50px;">
            </div>
          </td>
          <td><a href="/admin/promos/<%= p._id %>"><%= p.name %></a></td>
          <td><%= p.type %></td>
          <td><%= RESTAURANTS[p.restaurant] %></td>
          <td style="font-family:monospace;"><%= p.code %></td>
          <td><%= p.currentRedemptions %><%= p.maxRedemptions > 0 ? '/' + p.maxRedemptions : '' %></td>
          <td><span class="badge badge-<%= p.isActive ? 'active' : 'inactive' %>"><%= p.isActive ? 'Active' : 'Inactive' %></span></td>
          <td>
            <a href="/admin/promos/<%= p._id %>" class="btn btn-sm">Edit</a>
            <a href="/admin/promos/<%= p._id %>/redemptions" class="btn btn-sm">History</a>
          </td>
        </tr>
        <% }); %>
        <% if (!promos.length) { %>
        <tr><td colspan="8" style="text-align:center;color:var(--text-dim);">No promos yet</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../layout-close') %>
