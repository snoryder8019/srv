<%- include('../layout', { title, section, user }) %>

<div class="search-bar">
  <a href="/admin/email/campaigns/new" class="btn btn-primary">New Campaign</a>
  <form method="get" style="display:flex;gap:.5rem;">
    <select name="status" onchange="this.form.submit()">
      <option value="">All Status</option>
      <option value="draft" <%= statusFilter === 'draft' ? 'selected' : '' %>>Draft</option>
      <option value="scheduled" <%= statusFilter === 'scheduled' ? 'selected' : '' %>>Scheduled</option>
      <option value="sent" <%= statusFilter === 'sent' ? 'selected' : '' %>>Sent</option>
      <option value="sending" <%= statusFilter === 'sending' ? 'selected' : '' %>>Sending</option>
      <option value="failed" <%= statusFilter === 'failed' ? 'selected' : '' %>>Failed</option>
    </select>
  </form>
</div>

<div class="card">
  <div class="table-wrap">
    <table>
      <thead>
        <tr><th>Name</th><th>Subject</th><th>Restaurant</th><th>Status</th><th>Sent</th><th>Opened</th><th>Created</th><th></th></tr>
      </thead>
      <tbody>
        <% campaigns.forEach(function(c) { %>
        <tr>
          <td><a href="/admin/email/campaigns/<%= c._id %>"><%= c.name %></a></td>
          <td><%= c.subject %></td>
          <td><%= c.restaurant %></td>
          <td><span class="badge badge-<%= c.status %>"><%= c.status %></span></td>
          <td><%= c.stats.sent %></td>
          <td><%= c.stats.opened %></td>
          <td><%= c.createdAt.toLocaleDateString() %></td>
          <td><a href="/admin/email/campaigns/<%= c._id %>" class="btn btn-sm">Edit</a></td>
        </tr>
        <% }); %>
        <% if (!campaigns.length) { %>
        <tr><td colspan="8" style="text-align:center;color:var(--text-dim);">No campaigns found</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../layout-close') %>
