<%- include('../layout', { title, section, user }) %>

<div class="quick-actions">
  <a href="/admin/email/templates/new" class="btn btn-primary">New Template</a>
</div>

<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1rem;">
  <% templates.forEach(function(t) { %>
  <div class="card">
    <div class="card-header">
      <h2><%= t.name %></h2>
      <span class="badge badge-<%= t.restaurant === 'all' ? 'user' : 'admin' %>"><%= t.restaurant %></span>
    </div>
    <p style="font-size:.85rem;color:var(--text-dim);margin-bottom:.75rem;"><%= t.description || 'No description' %></p>
    <div style="background:#fff;color:#333;border-radius:4px;padding:.75rem;max-height:120px;overflow:hidden;font-size:.75rem;margin-bottom:.75rem;">
      <%- t.htmlContent.substring(0, 300) %>
    </div>
    <a href="/admin/email/templates/<%= t._id %>" class="btn btn-sm">Edit Template</a>
  </div>
  <% }); %>
  <% if (!templates.length) { %>
  <div class="card" style="text-align:center;color:var(--text-dim);padding:2rem;">
    No templates yet. Create your first newsletter template.
  </div>
  <% } %>
</div>

<%- include('../layout-close') %>
