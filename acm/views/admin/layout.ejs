<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title : 'Admin' %> — ACM Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/stylesheets/admin.css">
</head>
<body>
<div class="admin-wrap">

  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <img src="/images/acm.png" alt="ACM"> ACM Admin
    </div>
    <nav class="sidebar-nav">
      <a href="/admin/dashboard" class="<%= section === 'dashboard' ? 'active' : '' %>">
        <span class="nav-icon">&#9632;</span> Dashboard
      </a>
      <a href="/admin/users" class="<%= section === 'users' ? 'active' : '' %>">
        <span class="nav-icon">&#9787;</span> Users
      </a>
      <a href="/admin/email" class="<%= section === 'email' ? 'active' : '' %>">
        <span class="nav-icon">&#9993;</span> Email Marketing
      </a>
      <a href="/admin/email/templates" class="<%= section === 'templates' ? 'active' : '' %>">
        <span class="nav-icon">&#9998;</span> Newsletters
      </a>
      <a href="/admin/blog" class="<%= section === 'blog' ? 'active' : '' %>">
        <span class="nav-icon">&#9998;</span> Blog
      </a>
      <a href="/admin/promos" class="<%= section === 'promos' ? 'active' : '' %>">
        <span class="nav-icon">&#10022;</span> QR Promos
      </a>
      <a href="/admin/assets" class="<%= section === 'assets' ? 'active' : '' %>">
        <span class="nav-icon">&#9733;</span> Assets / AI Images
      </a>
    </nav>
    <div class="sidebar-user">
      <strong><%= user ? (user.displayName || user.email) : 'Admin' %></strong><br>
      <span><%= user ? user.role : '' %></span> &middot;
      <a href="/logout">Logout</a>
    </div>
  </aside>

  <!-- Main -->
  <div class="main-content">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:.75rem;">
        <button class="menu-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">&#9776;</button>
        <h1><%= typeof title !== 'undefined' ? title : 'Admin' %></h1>
      </div>
      <div class="topbar-actions">
        <a href="/" target="_blank">View Site</a>
        <a href="/logout">Logout</a>
      </div>
    </div>
    <div class="page">
