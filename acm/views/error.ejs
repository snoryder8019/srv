<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Error — ACM</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{background:#0a0a0a;color:#f5f0eb;font-family:'Inter',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:2rem;}
    .error-card{max-width:600px;width:100%;}
    h1{font-size:1.5rem;margin-bottom:.5rem;}
    h2{font-size:1rem;opacity:.5;margin-bottom:1rem;}
    pre{background:rgba(255,255,255,.05);padding:1rem;border-radius:4px;font-size:.8rem;overflow-x:auto;white-space:pre-wrap;opacity:.6;}
    a{color:#c9a96e;margin-top:1rem;display:inline-block;}
  </style>
</head>
<body>
  <div class="error-card">
    <h1><%= message %></h1>
    <h2><%= error.status %></h2>
    <% if (error.stack) { %>
    <pre><%= error.stack %></pre>
    <% } %>
    <a href="/">Back to home</a>
  </div>
</body>
</html>
