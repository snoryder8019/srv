<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Game Servers — bih</title>
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    .servers-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; padding: 24px; }
    .server-card { background: var(--surface, #1a1a1a); border: 1px solid var(--border, #2a2a2a); border-radius: 6px; padding: 20px; }
    .server-card h3 { margin: 0 0 8px; font-size: 1rem; }
    .status-badge { display: inline-block; padding: 2px 8px; border-radius: 3px; font-size: 0.75rem; font-weight: bold; margin-bottom: 12px; }
    .status-online { background: #1a3a2a; color: #4caf82; }
    .status-offline { background: #2a1a1a; color: #cd412b; }
    .status-loading { background: #2a2a1a; color: #e6b800; }
    .server-info { font-size: 0.8rem; color: #888; margin-bottom: 12px; }
    .server-actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .btn { padding: 6px 14px; border: 1px solid #333; border-radius: 3px; background: transparent; color: #ccc; font-size: 0.8rem; cursor: pointer; transition: all 0.15s; }
    .btn:hover { border-color: #555; color: #fff; }
    .btn-start:hover { border-color: #4caf82; color: #4caf82; }
    .btn-stop:hover { border-color: #cd412b; color: #cd412b; }
    .btn-restart:hover { border-color: #e6b800; color: #e6b800; }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .page-header { padding: 24px 24px 0; display: flex; align-items: center; justify-content: space-between; }
    .page-header h2 { margin: 0; font-size: 1.2rem; }
    .back-link { color: #888; font-size: 0.8rem; text-decoration: none; }
    .back-link:hover { color: #ccc; }
    .toast { position: fixed; bottom: 20px; right: 20px; background: #222; border: 1px solid #333; border-radius: 4px; padding: 10px 16px; font-size: 0.82rem; display: none; z-index: 999; }
  </style>
</head>
<body>
  <div class="page-header">
    <h2>Game Servers</h2>
    <a class="back-link" href="/dashboard">&larr; Dashboard</a>
  </div>

  <div class="servers-grid" id="grid">
    <% ['rust','valheim','l4d2','7dtd'].forEach(g => { %>
    <div class="server-card" data-game="<%= g %>">
      <h3><%= g.toUpperCase() %></h3>
      <div class="status-badge status-loading" id="badge-<%= g %>">LOADING...</div>
      <div class="server-info" id="info-<%= g %>">—</div>
      <% if (isGameAdmin) { %>
      <div class="server-actions">
        <button class="btn btn-start" onclick="control('<%= g %>','start')">Start</button>
        <button class="btn btn-stop" onclick="control('<%= g %>','stop')">Stop</button>
        <button class="btn btn-restart" onclick="control('<%= g %>','restart')">Restart</button>
      </div>
      <% } %>
    </div>
    <% }) %>
  </div>

  <div class="toast" id="toast"></div>

  <script>
    const GAMES = ['rust','valheim','l4d2','7dtd'];
    const isAdmin = <%= isGameAdmin %>;

    function showToast(msg, ok = true) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.style.borderColor = ok ? '#4caf82' : '#cd412b';
      t.style.display = 'block';
      setTimeout(() => t.style.display = 'none', 3000);
    }

    async function loadStatus(game) {
      const badge = document.getElementById('badge-' + game);
      const info = document.getElementById('info-' + game);
      try {
        const r = await fetch('/servers/status/' + game);
        const d = await r.json();
        if (d.running) {
          badge.className = 'status-badge status-online';
          badge.textContent = 'ONLINE';
          info.textContent = d.players !== undefined ? `Players: ${d.players}` : 'Running';
        } else {
          badge.className = 'status-badge status-offline';
          badge.textContent = 'OFFLINE';
          info.textContent = d.uptime || '—';
        }
      } catch (e) {
        badge.className = 'status-badge status-offline';
        badge.textContent = 'ERROR';
      }
    }

    async function control(game, action) {
      if (!confirm(`${action.toUpperCase()} ${game.toUpperCase()}?`)) return;
      try {
        const r = await fetch(`/servers/control/${game}/${action}`, { method: 'POST' });
        const d = await r.json();
        if (d.error) showToast(d.error, false);
        else { showToast(d.message || 'Done'); setTimeout(() => loadStatus(game), 2000); }
      } catch (e) {
        showToast('Request failed', false);
      }
    }

    GAMES.forEach(g => loadStatus(g));
    setInterval(() => GAMES.forEach(g => loadStatus(g)), 30000);
  </script>
</body>
</html>
