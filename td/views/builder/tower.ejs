<%- include('../partials/header') %>

<main class="td-builder">
  <div id="td-builder-host" class="canvas-host"></div>
  <aside class="td-form" id="td-form">
    <button class="hud-toggle" id="hud-toggle" type="button" aria-label="Toggle form">▼ Form</button>
    <h2>Tower Builder</h2>
    <form id="tower-form">
      <label>Name <input name="name" required></label>
      <label>Slug <input name="slug" required pattern="[a-z0-9-]+"></label>
      <label>Description <textarea name="description"></textarea></label>
      <label>Category
        <select name="category">
          <option value="kinetic">Kinetic</option>
          <option value="energy">Energy</option>
          <option value="support">Support</option>
          <option value="special">Special</option>
        </select>
      </label>

      <fieldset>
        <legend>Model</legend>
        <input type="file" id="gltf-upload" accept=".gltf,.glb">
        <input name="gltfUrl" id="gltfUrl" placeholder="/assets/gltf/uploads/..." readonly>
        <label>Scale <input type="number" name="scale" value="1" step="0.1" min="0.1" max="5"></label>
      </fieldset>

      <fieldset>
        <legend>Stats</legend>
        <label>Damage <input type="number" name="stats.damage" value="10"></label>
        <label>Range (hex) <input type="number" name="stats.range" value="3"></label>
        <label>Fire Rate <input type="number" name="stats.fireRate" value="1" step="0.1"></label>
        <label>Cost <input type="number" name="stats.cost" value="50"></label>
      </fieldset>

      <button type="submit" class="btn primary">Save Draft</button>
    </form>
  </aside>
</main>

<script type="importmap">
{
  "imports": {
    "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
    "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
  }
}
</script>
<script type="module" src="/js/builder/tower-builder.js"></script>
<script>
  (function () {
    const form = document.getElementById('td-form');
    const btn = document.getElementById('hud-toggle');
    if (btn && form) {
      btn.addEventListener('click', () => {
        form.classList.toggle('collapsed');
        btn.textContent = form.classList.contains('collapsed') ? '▲ Form' : '▼ Form';
      });
    }
  })();
</script>

<%- include('../partials/footer') %>
