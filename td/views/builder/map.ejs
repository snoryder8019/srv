<%- include('../partials/header') %>

<main class="td-builder">
  <div id="td-map-host" class="canvas-host"></div>
  <aside class="td-form" id="td-form">
    <button class="hud-toggle" id="hud-toggle" type="button" aria-label="Toggle form">▼ Tools</button>
    <h2>Map Builder</h2>
    <form id="map-form">
      <label>Name <input name="name" required></label>
      <label>Slug <input name="slug" required pattern="[a-z0-9-]+"></label>
      <label>Radius
        <input type="number" name="radius" value="6" min="3" max="20">
      </label>
      <div class="tool-row">
        <strong>Paint mode</strong>
        <button type="button" data-tool="spawn">Spawn</button>
        <button type="button" data-tool="base">Base</button>
        <button type="button" data-tool="path">Path</button>
        <button type="button" data-tool="blocked">Blocked</button>
        <button type="button" data-tool="clear">Clear</button>
      </div>
      <button type="submit" class="btn primary">Save Draft</button>
    </form>
  </aside>
</main>

<script type="importmap">
{
  "imports": {
    "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
    "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
  }
}
</script>
<script type="module" src="/js/builder/map-builder.js"></script>
<script>
  (function () {
    const form = document.getElementById('td-form');
    const btn = document.getElementById('hud-toggle');
    if (btn && form) {
      btn.addEventListener('click', () => {
        form.classList.toggle('collapsed');
        btn.textContent = form.classList.contains('collapsed') ? '▲ Tools' : '▼ Tools';
      });
    }
  })();
</script>

<%- include('../partials/footer') %>
