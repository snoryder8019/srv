<%- include('partials/header') %>

<main class="td-browse">
  <h1>Community Builds</h1>
  <section>
    <h2>Towers</h2>
    <div id="tower-grid">Loading…</div>
  </section>
  <section>
    <h2>Maps</h2>
    <div id="map-grid">Loading…</div>
  </section>
</main>

<script type="module">
  async function load() {
    const [t, m] = await Promise.all([
      fetch('/api/v1/towers?status=approved').then(r => r.json()),
      fetch('/api/v1/maps?status=approved').then(r => r.json()),
    ]);
    document.getElementById('tower-grid').innerHTML =
      (t.towers || []).map(x => `<div class="card">${x.name}</div>`).join('') || '<em>No towers yet.</em>';
    document.getElementById('map-grid').innerHTML =
      (m.maps || []).map(x => `<div class="card">${x.name}</div>`).join('') || '<em>No maps yet.</em>';
  }
  load();
</script>

<%- include('partials/footer') %>
