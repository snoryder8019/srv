<%- include('../partials/header') %>

<main class="td-game">
  <div id="td-canvas-host" class="canvas-host">
    <div class="orient-hint" id="orient-hint">↻ Rotate to landscape for a better view</div>
  </div>
  <aside class="td-hud" id="td-hud">
    <button class="hud-toggle" id="hud-toggle" type="button" aria-label="Toggle HUD">▼ HUD</button>
    <div class="hud-section">
      <h3>Status</h3>
      <div>Wave: <span id="hud-wave">-</span></div>
      <div>Base: <span id="hud-health">-</span></div>
      <div>$: <span id="hud-currency">-</span></div>
      <div>Score: <span id="hud-score">0</span></div>
    </div>
    <div class="hud-section">
      <h3>Towers</h3>
      <div id="hud-tower-picker">Loading…</div>
    </div>
    <div class="hud-section">
      <small>Tap a tower, then tap an empty hex to place. Pinch to zoom, drag to rotate.</small>
    </div>
  </aside>
</main>

<script src="/socket.io/socket.io.js"></script>
<script type="importmap">
{
  "imports": {
    "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
    "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
  }
}
</script>
<script type="module" src="/js/game/play.js"></script>
<script>
  // HUD collapse toggle (mobile)
  (function () {
    const hud = document.getElementById('td-hud');
    const btn = document.getElementById('hud-toggle');
    if (btn && hud) {
      btn.addEventListener('click', () => {
        hud.classList.toggle('collapsed');
        btn.textContent = hud.classList.contains('collapsed') ? '▲ HUD' : '▼ HUD';
      });
    }
    // Orientation hint - show in portrait on small screens for ~5 seconds
    const hint = document.getElementById('orient-hint');
    if (hint && window.matchMedia('(max-width: 640px) and (orientation: portrait)').matches) {
      hint.classList.add('show');
      setTimeout(() => hint.classList.remove('show'), 5000);
    }
  })();
</script>

<%- include('../partials/footer') %>
