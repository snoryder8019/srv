# ===== Towers (TD) Environment =====
# Copy to .env and fill in your own values.
# td is independent - no shared credentials with other services.

# Server
PORT=3720
NODE_ENV=development
DOMAIN=towers.madladslab.com
PUBLIC_URL=https://towers.madladslab.com

# Database (td's own MongoDB connection string)
DB_URL=
DB_NAME=td

# Google OAuth (td's own OAuth app)
# Register this URI in Google Cloud Console -> Credentials:
#   https://towers.madladslab.com/auth/google/callback
GGLCID=
GGLSEC=

# Sessions / JWT (generate fresh, e.g. `openssl rand -hex 32`)
SESHSEC=
JWT_SECRET=

# Asset uploads
ASSET_UPLOAD_DIR=./public/assets/gltf
ASSET_MAX_SIZE_MB=25

# Logging
LOG_LEVEL=info
