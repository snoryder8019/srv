<%- include('partials/header') %>

<section class="cal">
  <header class="cal-header">
    <h2>This Month</h2>
    <button id="newEvent" class="btn-primary">+ New Event</button>
  </header>

  <div id="feed" class="feed-strip"></div>

  <ul class="event-list">
    <% events.forEach(ev => { %>
      <li class="event" data-id="<%= ev._id %>">
        <span class="when"><%= ev.start %></span>
        <span class="title"><%- ev.title %></span>
        <span class="src">[<%= ev.source %>]</span>
      </li>
    <% }) %>
    <% if (!events.length) { %>
      <li class="empty">No events yet. Click "+ New Event" or connect a calendar.</li>
    <% } %>
  </ul>
</section>

<dialog id="eventDialog">
  <form id="eventForm" method="dialog">
    <h3>New Event</h3>
    <label>Title <input name="title" required></label>
    <label>Start <input name="start" type="datetime-local" required></label>
    <label>End <input name="end" type="datetime-local" required></label>
    <label>Location <input name="location"></label>
    <label>Description <textarea name="description"></textarea></label>
    <label><input type="checkbox" name="allDay"> All day</label>
    <menu>
      <button value="cancel">Cancel</button>
      <button id="saveEvent" value="default" class="btn-primary">Save</button>
    </menu>
  </form>
</dialog>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/calendar.js"></script>

<%- include('partials/footer') %>
