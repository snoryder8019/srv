<%- include('../partials/header') %>

<h1>Slab Subscribers</h1>
<p>Issue API keys for Slab tenant admin panels to consume this family's calendar.</p>

<% if (newKey) { %>
  <div class="notice">
    <strong>New API key (copy now — shown once):</strong>
    <code><%= newKey %></code>
  </div>
<% } %>

<form method="post" action="/admin/slab-subscribers" class="form-row">
  <input name="tenantKey" placeholder="Slab tenant key" required>
  <input name="familyId" placeholder="Family ID" required>
  <input name="label" placeholder="Label (optional)">
  <button class="btn-primary">Issue Key</button>
</form>

<ul class="list">
  <% subs.forEach(s => { %>
    <li>
      <strong><%= s.label || s.tenantKey %></strong> — tenant: <%= s.tenantKey %>
      <% if (s.revoked) { %><span class="bad">revoked</span><% } %>
    </li>
  <% }) %>
</ul>

<%- include('../partials/footer') %>
