<%- include('../partials/header') %>

<h1>Families</h1>

<form method="post" action="/admin/families" class="form-row">
  <input name="name" placeholder="Family name" required>
  <input name="ownerEmail" type="email" placeholder="Owner email" required>
  <input name="timezone" placeholder="Timezone (e.g. America/New_York)">
  <input name="weatherLocation" placeholder="Weather location (e.g. Boston, MA)">
  <button class="btn-primary">Create</button>
</form>

<ul class="list">
  <% families.forEach(f => { %>
    <li><strong><%= f.name %></strong> — <%= f.ownerEmail %> · <%= f.timezone %></li>
  <% }) %>
</ul>

<%- include('../partials/footer') %>
