<%- include('../partials/header') %>

<h1>Feed Items</h1>

<form method="post" action="/admin/feed" class="form-row">
  <input name="familyId" placeholder="Family ID" required>
  <select name="type" required>
    <option value="thought">Thought</option>
    <option value="joke">Joke</option>
    <option value="bill">Bill</option>
    <option value="localEvent">Local Event</option>
    <option value="weather">Weather</option>
  </select>
  <input name="title" placeholder="Title" required>
  <input name="body" placeholder="Body">
  <input name="displayDate" type="date" required>
  <button class="btn-primary">Add</button>
</form>

<ul class="list">
  <% items.forEach(i => { %>
    <li>
      <span class="type">[<%= i.type %>]</span>
      <strong><%= i.payload?.title %></strong>
      — <%= i.payload?.body %>
      <span class="when"><%= i.displayDate?.toISOString?.().slice(0,10) %></span>
    </li>
  <% }) %>
</ul>

<%- include('../partials/footer') %>
