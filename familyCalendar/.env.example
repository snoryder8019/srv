# ── Family Calendar ───────────────────────────────────────────────────────────
PORT=3611
NODE_ENV=development
DOMAIN=https://family-calendar.madladslab.com

# MongoDB — shared cluster, dedicated DB
DB_URL=mongodb+srv://user:pass@cluster0.example.mongodb.net
DB_NAME=familyCalendar

# Sessions / cookies
SESHSEC=replace_me_session_secret
COOKIE_DOMAIN=.madladslab.com

# Encryption — encrypts OAuth refresh tokens at rest
MASTER_KEY=replace_me_64_hex_chars_32_bytes

# Google OAuth (Calendar scope: https://www.googleapis.com/auth/calendar)
GGLCID=
GGLSEC=

# Zoho OAuth (Phase 2)
ZOHO_CID=
ZOHO_SEC=
ZOHO_REGION=com

# Slab bridge — outbound API key clients use to subscribe (also stored per-subscription)
SLAB_BRIDGE_INTERNAL_KEY=

# Weather (Phase 3)
WEATHER_PROVIDER=openweather
WEATHER_API_KEY=

# Ollama (Phase 3 — daily AI thoughts/jokes)
OLLAMA_URL=https://ollama.madladslab.com/v1/chat/completions
OLLAMA_MODEL=deepseek-r1:7b
