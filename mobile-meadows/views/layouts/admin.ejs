<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Admin — ' + siteName %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
  <script src="/socket.io/socket.io.js" defer></script>
  <script src="/js/admin.js" defer></script>
</head>
<body class="admin-body">
  <aside class="admin-sidebar">
    <a href="/admin" class="sidebar-brand"><%= siteName %><br><small>Admin</small></a>
    <nav class="sidebar-nav">
      <a href="/admin">Dashboard</a>
      <a href="/admin/bookings">Bookings</a>
      <a href="/admin/calendar">Calendar</a>
      <a href="/admin/content">Site Content</a>
      <a href="/admin/design">Design</a>
      <a href="/admin/users">Users</a>
      <hr>
      <a href="/" target="_blank">View Site</a>
      <a href="/auth/logout">Logout</a>
    </nav>
  </aside>
  <div class="admin-main">
    <header class="admin-header">
      <button class="sidebar-toggle" onclick="document.body.classList.toggle('sidebar-open')">&#9776;</button>
      <span>Welcome, <%= currentUser.displayName %></span>
    </header>
    <div class="admin-content">
      <%- body %>
    </div>
  </div>
</body>
</html>
