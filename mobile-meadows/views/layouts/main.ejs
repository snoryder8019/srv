<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : siteName %></title>
  <link rel="stylesheet" href="/css/style.css">
  <% const _activeTheme = (siteTheme && siteTheme.activeTheme) || 'default'; %>
  <% const _themedThemes = ['camping-highway', 'desert-sunset', 'lake-country', 'mountain-lodge', 'open-road', 'ozark-morning']; %>
  <% if (_themedThemes.includes(_activeTheme)) { %>
    <link rel="stylesheet" href="/css/themes/<%= _activeTheme %>.css">
  <% } %>
  <% const cc = siteTheme && siteTheme.customColors; %>
  <% if (cc && (cc.primary || cc.primaryDark || cc.primaryLight || cc.accent || cc.bg || cc.bgCard || cc.text || cc.textLight)) { %>
    <style>
      :root {
        <% if (cc.primary) { %>--primary: <%= cc.primary %>;<% } %>
        <% if (cc.primaryDark) { %>--primary-dark: <%= cc.primaryDark %>;<% } %>
        <% if (cc.primaryLight) { %>--primary-light: <%= cc.primaryLight %>;<% } %>
        <% if (cc.accent) { %>--accent: <%= cc.accent %>;<% } %>
        <% if (cc.bg) { %>--bg: <%= cc.bg %>;<% } %>
        <% if (cc.bgCard) { %>--bg-card: <%= cc.bgCard %>;<% } %>
        <% if (cc.text) { %>--text: <%= cc.text %>;<% } %>
        <% if (cc.textLight) { %>--text-light: <%= cc.textLight %>;<% } %>
      }
    </style>
  <% } %>
  <script src="/socket.io/socket.io.js" defer></script>
  <script src="/js/app.js" defer></script>
</head>
<body data-theme="<%= _activeTheme %>">
  <%- include('../partials/nav') %>
  <main>
    <%- body %>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
