<h1>Site Design</h1>
<p>Choose a theme and customize the look and feel of your public-facing site.</p>

<!-- Active Theme Indicator -->
<div class="admin-card" style="border-left: 4px solid #2d6a4f; margin-bottom: 2rem;">
  <h2 style="margin-bottom: 0.5rem;">Active Theme: <span style="color: var(--primary);"><%= theme.activeTheme === 'default' ? 'Default (Green & Tan)' : 'Camping Highway' %></span></h2>
  <p style="color: var(--text-light); font-size: 0.9rem;">Changes apply immediately to the public site.</p>
</div>

<!-- Theme Cards -->
<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">

  <!-- Default Theme Card -->
  <div class="admin-card" style="position: relative; overflow: hidden; <%= theme.activeTheme === 'default' ? 'border: 2px solid #2d6a4f;' : '' %>">
    <% if (theme.activeTheme === 'default') { %>
      <div style="position: absolute; top: 12px; right: 12px; background: #2d6a4f; color: #fff; padding: 3px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600;">ACTIVE</div>
    <% } %>
    <!-- Preview -->
    <div style="border-radius: var(--radius); overflow: hidden; margin-bottom: 1rem; border: 1px solid #ddd;">
      <!-- Mini nav -->
      <div style="background: #1b4332; padding: 8px 12px; display: flex; justify-content: space-between; align-items: center;">
        <span style="color: #fff; font-weight: 700; font-size: 0.8rem;">Mobile Meadows</span>
        <div style="display: flex; gap: 8px;">
          <span style="color: rgba(255,255,255,0.8); font-size: 0.65rem;">Home</span>
          <span style="color: rgba(255,255,255,0.8); font-size: 0.65rem;">Calendar</span>
        </div>
      </div>
      <!-- Mini hero -->
      <div style="background: linear-gradient(135deg, #1b4332, #2d6a4f); padding: 20px 12px; text-align: center;">
        <div style="color: #fff; font-weight: 700; font-size: 0.9rem;">Your RV Repair Experts</div>
        <div style="color: rgba(255,255,255,0.8); font-size: 0.65rem; margin-top: 4px;">Mobile & Roof Services</div>
        <div style="margin-top: 8px; display: inline-block; background: #2d6a4f; color: #fff; padding: 3px 10px; border-radius: 4px; font-size: 0.6rem;">Book Now</div>
      </div>
      <!-- Mini services -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; background: #fefae0;">
        <div style="padding: 10px; text-align: center; border-right: 1px solid #ddd;">
          <div style="font-size: 1.2rem;">&#128663;</div>
          <div style="font-size: 0.6rem; color: #1b4332; font-weight: 600;">Mobile Repair</div>
        </div>
        <div style="padding: 10px; text-align: center;">
          <div style="font-size: 1.2rem;">&#127968;</div>
          <div style="font-size: 0.6rem; color: #1b4332; font-weight: 600;">Roof Repair</div>
        </div>
      </div>
    </div>
    <h2 style="font-size: 1.1rem;">Default</h2>
    <p style="color: var(--text-light); font-size: 0.85rem; margin-bottom: 1rem;">Clean, professional green & tan. Earthy RV-service feel with a warm accent palette.</p>
    <% if (theme.activeTheme !== 'default') { %>
      <form action="/admin/design/theme" method="POST" style="display:inline;">
        <input type="hidden" name="activeTheme" value="default">
        <button type="submit" class="btn btn-primary">Activate Theme</button>
      </form>
    <% } else { %>
      <button class="btn" disabled style="opacity: 0.5;">Currently Active</button>
    <% } %>
  </div>

  <!-- Camping Highway Theme Card -->
  <div class="admin-card" style="position: relative; overflow: hidden; <%= theme.activeTheme === 'camping-highway' ? 'border: 2px solid #e8722a;' : '' %>">
    <% if (theme.activeTheme === 'camping-highway') { %>
      <div style="position: absolute; top: 12px; right: 12px; background: #e8722a; color: #fff; padding: 3px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600;">ACTIVE</div>
    <% } %>
    <!-- Preview -->
    <div style="border-radius: var(--radius); overflow: hidden; margin-bottom: 1rem; border: 1px solid #3a3a3e;">
      <!-- Mini nav -->
      <div style="background: #0f1420; padding: 8px 12px; display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #e8c840;">
        <span style="color: #f0e6d2; font-weight: 700; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; font-family: Impact, sans-serif;">Mobile Meadows</span>
        <div style="display: flex; gap: 8px;">
          <span style="color: rgba(240,230,210,0.8); font-size: 0.65rem;">Home</span>
          <span style="color: rgba(240,230,210,0.8); font-size: 0.65rem;">Calendar</span>
        </div>
      </div>
      <!-- Mini hero -->
      <div style="background: linear-gradient(180deg, #0f1420 0%, #1a2744 40%, #2d4a3a 70%, #0d2818 100%); padding: 24px 12px; text-align: center; position: relative;">
        <div style="color: #f0e6d2; font-weight: 700; font-size: 0.95rem; letter-spacing: 0.08em; text-transform: uppercase; font-family: Impact, sans-serif; text-shadow: 0 2px 10px rgba(0,0,0,0.5);">Hit The Road</div>
        <div style="color: rgba(240,230,210,0.7); font-size: 0.65rem; margin-top: 4px;">Repair Where You Camp</div>
        <div style="margin-top: 8px; display: inline-block; background: #e8722a; color: #fff; padding: 3px 10px; border-radius: 3px; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.06em; box-shadow: 0 2px 8px rgba(232,114,42,0.3);">Book Now</div>
        <!-- Mini pine silhouettes -->
        <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 20px; background: linear-gradient(transparent, #0d2818);"></div>
      </div>
      <!-- Mini services -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; background: #2a2a2e;">
        <div style="padding: 10px; text-align: center; border-right: 1px solid #3a3a3e;">
          <div style="font-size: 1.2rem;">&#128663;</div>
          <div style="font-size: 0.6rem; color: #f0e6d2; font-weight: 600;">Mobile Repair</div>
        </div>
        <div style="padding: 10px; text-align: center;">
          <div style="font-size: 1.2rem;">&#127968;</div>
          <div style="font-size: 0.6rem; color: #f0e6d2; font-weight: 600;">Roof Repair</div>
        </div>
      </div>
      <!-- Road stripe -->
      <div style="height: 4px; background: repeating-linear-gradient(90deg, #e8c840 0px, #e8c840 30px, transparent 30px, transparent 45px);"></div>
    </div>
    <h2 style="font-size: 1.1rem;">Camping Highway</h2>
    <p style="color: var(--text-light); font-size: 0.85rem; margin-bottom: 1rem;">Dark asphalt tones, pine forest silhouettes, campfire warmth, road stripe accents. Night sky with twinkling stars.</p>
    <% if (theme.activeTheme !== 'camping-highway') { %>
      <form action="/admin/design/theme" method="POST" style="display:inline;">
        <input type="hidden" name="activeTheme" value="camping-highway">
        <button type="submit" class="btn btn-primary">Activate Theme</button>
      </form>
    <% } else { %>
      <button class="btn" disabled style="opacity: 0.5;">Currently Active</button>
    <% } %>
  </div>

</div>

<!-- Theme Settings -->
<div class="admin-card">
  <h2>Theme Settings</h2>
  <form action="/admin/design/settings" method="POST">
    <div class="form-row">
      <div class="form-group">
        <label>Hero Style</label>
        <select name="heroStyle">
          <option value="gradient" <%= theme.heroStyle === 'gradient' ? 'selected' : '' %>>Gradient Background</option>
          <option value="image" <%= theme.heroStyle === 'image' ? 'selected' : '' %>>Background Image</option>
        </select>
      </div>
      <div class="form-group">
        <label>Hero Overlay Opacity</label>
        <input type="range" name="heroOverlayOpacity" min="0" max="1" step="0.1" value="<%= theme.heroOverlayOpacity %>"
               oninput="document.getElementById('opacity-val').textContent = this.value">
        <span id="opacity-val" style="font-size: 0.85rem; color: var(--text-light);"><%= theme.heroOverlayOpacity %></span>
      </div>
    </div>

    <h3 style="margin: 1.5rem 0 1rem; font-size: 1rem;">Custom Color Overrides</h3>
    <p style="font-size: 0.85rem; color: var(--text-light); margin-bottom: 1rem;">Leave blank to use theme defaults. Set custom colors to override any theme.</p>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem;">
      <div class="form-group">
        <label>Primary</label>
        <div style="display: flex; gap: 0.5rem; align-items: center;">
          <input type="color" name="customColors[primary]" value="<%= (theme.customColors && theme.customColors.primary) || (theme.activeTheme === 'camping-highway' ? '#1a472a' : '#2d6a4f') %>" style="width: 40px; height: 32px; padding: 0; border: none; cursor: pointer;">
          <input type="text" name="customColors[primary]" value="<%= (theme.customColors && theme.customColors.primary) || '' %>" placeholder="#2d6a4f" style="flex: 1;">
        </div>
      </div>
      <div class="form-group">
        <label>Accent</label>
        <div style="display: flex; gap: 0.5rem; align-items: center;">
          <input type="color" name="customColors[accent]" value="<%= (theme.customColors && theme.customColors.accent) || (theme.activeTheme === 'camping-highway' ? '#e8722a' : '#d4a373') %>" style="width: 40px; height: 32px; padding: 0; border: none; cursor: pointer;">
          <input type="text" name="customColors[accent]" value="<%= (theme.customColors && theme.customColors.accent) || '' %>" placeholder="#d4a373" style="flex: 1;">
        </div>
      </div>
      <div class="form-group">
        <label>Background</label>
        <div style="display: flex; gap: 0.5rem; align-items: center;">
          <input type="color" name="customColors[bg]" value="<%= (theme.customColors && theme.customColors.bg) || (theme.activeTheme === 'camping-highway' ? '#1c1c1e' : '#fefae0') %>" style="width: 40px; height: 32px; padding: 0; border: none; cursor: pointer;">
          <input type="text" name="customColors[bg]" value="<%= (theme.customColors && theme.customColors.bg) || '' %>" placeholder="#fefae0" style="flex: 1;">
        </div>
      </div>
      <div class="form-group">
        <label>Card Background</label>
        <div style="display: flex; gap: 0.5rem; align-items: center;">
          <input type="color" name="customColors[bgCard]" value="<%= (theme.customColors && theme.customColors.bgCard) || (theme.activeTheme === 'camping-highway' ? '#2a2a2e' : '#ffffff') %>" style="width: 40px; height: 32px; padding: 0; border: none; cursor: pointer;">
          <input type="text" name="customColors[bgCard]" value="<%= (theme.customColors && theme.customColors.bgCard) || '' %>" placeholder="#ffffff" style="flex: 1;">
        </div>
      </div>
    </div>

    <div style="margin-top: 1.5rem;">
      <button type="submit" class="btn btn-primary">Save Settings</button>
      <form action="/admin/design/reset" method="POST" style="display: inline; margin-left: 0.5rem;">
        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Reset all custom colors to theme defaults?')">Reset Colors</button>
      </form>
    </div>
  </form>
</div>

<!-- Template Rules Info -->
<div class="admin-card">
  <h2>Templating Rules</h2>
  <div style="font-size: 0.9rem; color: var(--text-light); line-height: 1.7;">
    <p><strong>How themes work:</strong></p>
    <ul style="margin: 0.5rem 0 1rem 1.5rem;">
      <li><strong>Default theme</strong> uses the base <code>style.css</code> — green & tan palette, clean layout</li>
      <li><strong>Camping Highway</strong> loads an overlay CSS that overrides colors, typography, and adds visual effects (stars, pine silhouettes, road stripes)</li>
      <li><strong>Custom colors</strong> override both themes via inline CSS variables on the <code>&lt;body&gt;</code> tag</li>
      <li>Theme changes are <strong>instant</strong> — no rebuild or restart needed</li>
      <li>The admin panel always uses its own styling regardless of public theme</li>
    </ul>
    <p><strong>Adding new themes:</strong></p>
    <ul style="margin: 0.5rem 0 0 1.5rem;">
      <li>Create a CSS file in <code>/css/themes/</code> that overrides <code>:root</code> variables</li>
      <li>Add the theme name to the <code>SiteTheme</code> model enum</li>
      <li>Add a preview card on this page</li>
    </ul>
  </div>
</div>
