<h1>Site Design</h1>
<p>Choose a theme and customize the look and feel of your public-facing site.</p>

<!-- Active Theme Indicator -->
<div class="admin-card" style="border-left: 4px solid #2d6a4f; margin-bottom: 2rem;">
  <h2 style="margin-bottom: 0.5rem;">Active Theme: <span style="color: var(--primary);"><%=
    theme.activeTheme === 'default'          ? 'Default (Green & Tan)'  :
    theme.activeTheme === 'camping-highway'  ? 'Camping Highway'        :
    theme.activeTheme === 'desert-sunset'    ? 'Desert Sunset'          :
    theme.activeTheme === 'lake-country'     ? 'Lake Country'           :
    theme.activeTheme === 'mountain-lodge'   ? 'Mountain Lodge'         :
    theme.activeTheme === 'open-road'        ? 'Open Road'              :
    theme.activeTheme === 'ozark-morning'    ? 'Ozark Morning'          : theme.activeTheme
  %></span></h2>
  <p style="color: var(--text-light); font-size: 0.9rem;">Changes apply immediately to the public site.</p>
</div>

<!-- Theme Cards -->
<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">

  <!-- ── Default Theme ── -->
  <div class="admin-card" style="position: relative; overflow: hidden; <%= theme.activeTheme === 'default' ? 'border: 2px solid #2d6a4f;' : '' %>">
    <% if (theme.activeTheme === 'default') { %><div style="position: absolute; top: 12px; right: 12px; background: #2d6a4f; color: #fff; padding: 3px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600;">ACTIVE</div><% } %>
    <div style="border-radius: var(--radius); overflow: hidden; margin-bottom: 1rem; border: 1px solid #ddd;">
      <div style="background: #1b4332; padding: 8px 12px; display: flex; justify-content: space-between; align-items: center;">
        <span style="color: #fff; font-weight: 700; font-size: 0.8rem;">Mobile Meadows</span>
        <div style="display: flex; gap: 8px;"><span style="color: rgba(255,255,255,0.8); font-size: 0.65rem;">Home</span><span style="color: rgba(255,255,255,0.8); font-size: 0.65rem;">Calendar</span></div>
      </div>
      <div style="background: linear-gradient(135deg, #1b4332, #2d6a4f); padding: 20px 12px; text-align: center;">
        <div style="color: #fff; font-weight: 700; font-size: 0.9rem;">Your RV Repair Experts</div>
        <div style="color: rgba(255,255,255,0.8); font-size: 0.65rem; margin-top: 4px;">Mobile & Roof Services</div>
        <div style="margin-top: 8px; display: inline-block; background: #2d6a4f; color: #fff; padding: 3px 10px; border-radius: 4px; font-size: 0.6rem;">Book Now</div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; background: #fefae0;">
        <div style="padding: 10px; text-align: center; border-right: 1px solid #ddd;"><div style="font-size: 1.2rem;">&#128663;</div><div style="font-size: 0.6rem; color: #1b4332; font-weight: 600;">Mobile Repair</div></div>
        <div style="padding: 10px; text-align: center;"><div style="font-size: 1.2rem;">&#127968;</div><div style="font-size: 0.6rem; color: #1b4332; font-weight: 600;">Roof Repair</div></div>
      </div>
    </div>
    <h2 style="font-size: 1.1rem;">Default</h2>
    <p style="color: var(--text-light); font-size: 0.85rem; margin-bottom: 1rem;">Clean, professional green & tan. Earthy RV-service feel with a warm accent palette.</p>
    <% if (theme.activeTheme !== 'default') { %>
      <form action="/admin/design/theme" method="POST" style="display:inline;"><input type="hidden" name="activeTheme" value="default"><button type="submit" class="btn btn-primary">Activate Theme</button></form>
    <% } else { %><button class="btn" disabled style="opacity: 0.5;">Currently Active</button><% } %>
  </div>

  <!-- ── Camping Highway ── -->
  <div class="admin-card" style="position: relative; overflow: hidden; <%= theme.activeTheme === 'camping-highway' ? 'border: 2px solid #e8722a;' : '' %>">
    <% if (theme.activeTheme === 'camping-highway') { %><div style="position: absolute; top: 12px; right: 12px; background: #e8722a; color: #fff; padding: 3px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600;">ACTIVE</div><% } %>
    <div style="border-radius: var(--radius); overflow: hidden; margin-bottom: 1rem; border: 1px solid #3a3a3e;">
      <div style="background: #0f1420; padding: 8px 12px; display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #e8c840;">
        <span style="color: #f0e6d2; font-weight: 700; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; font-family: Impact, sans-serif;">Mobile Meadows</span>
        <div style="display: flex; gap: 8px;"><span style="color: rgba(240,230,210,0.8); font-size: 0.65rem;">Home</span><span style="color: rgba(240,230,210,0.8); font-size: 0.65rem;">Calendar</span></div>
      </div>
      <div style="background: linear-gradient(180deg, #0f1420 0%, #1a2744 40%, #2d4a3a 70%, #0d2818 100%); padding: 24px 12px; text-align: center;">
        <div style="color: #f0e6d2; font-weight: 700; font-size: 0.95rem; letter-spacing: 0.08em; text-transform: uppercase; font-family: Impact, sans-serif; text-shadow: 0 2px 10px rgba(0,0,0,0.5);">Hit The Road</div>
        <div style="color: rgba(240,230,210,0.7); font-size: 0.65rem; margin-top: 4px;">Repair Where You Camp</div>
        <div style="margin-top: 8px; display: inline-block; background: #e8722a; color: #fff; padding: 3px 10px; border-radius: 3px; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.06em;">Book Now</div>
        <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 20px; background: linear-gradient(transparent, #0d2818);"></div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; background: #2a2a2e;">
        <div style="padding: 10px; text-align: center; border-right: 1px solid #3a3a3e;"><div style="font-size: 1.2rem;">&#128663;</div><div style="font-size: 0.6rem; color: #f0e6d2; font-weight: 600;">Mobile Repair</div></div>
        <div style="padding: 10px; text-align: center;"><div style="font-size: 1.2rem;">&#127968;</div><div style="font-size: 0.6rem; color: #f0e6d2; font-weight: 600;">Roof Repair</div></div>
      </div>
      <div style="height: 4px; background: repeating-linear-gradient(90deg, #e8c840 0px, #e8c840 30px, transparent 30px, transparent 45px);"></div>
    </div>
    <h2 style="font-size: 1.1rem;">Camping Highway</h2>
    <p style="color: var(--text-light); font-size: 0.85rem; margin-bottom: 1rem;">Dark asphalt tones, pine forest silhouettes, campfire warmth. Night sky with twinkling stars and road stripe accents.</p>
    <% if (theme.activeTheme !== 'camping-highway') { %>
      <form action="/admin/design/theme" method="POST" style="display:inline;"><input type="hidden" name="activeTheme" value="camping-highway"><button type="submit" class="btn btn-primary">Activate Theme</button></form>
    <% } else { %><button class="btn" disabled style="opacity: 0.5;">Currently Active</button><% } %>
  </div>

  <!-- ── Desert Sunset ── -->
  <div class="admin-card" style="position: relative; overflow: hidden; <%= theme.activeTheme === 'desert-sunset' ? 'border: 2px solid #c4553e;' : '' %>">
    <% if (theme.activeTheme === 'desert-sunset') { %><div style="position: absolute; top: 12px; right: 12px; background: #c4553e; color: #fff; padding: 3px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600;">ACTIVE</div><% } %>
    <div style="border-radius: var(--radius); overflow: hidden; margin-bottom: 1rem; border: 1px solid #e8d5c0;">
      <div style="background: #6b4226; padding: 8px 12px; display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #ffcf77;">
        <span style="color: #fff8e8; font-weight: 700; font-size: 0.8rem; font-family: Georgia, serif;">Mobile Meadows</span>
        <div style="display: flex; gap: 8px;"><span style="color: rgba(255,248,232,0.8); font-size: 0.65rem;">Home</span><span style="color: rgba(255,248,232,0.8); font-size: 0.65rem;">Calendar</span></div>
      </div>
      <div style="background: linear-gradient(180deg, #1a0f07 0%, #6b2d1a 25%, #c4553e 55%, #f0a500 75%, #e8c99a 100%); padding: 24px 12px; text-align: center;">
        <div style="color: #fff; font-weight: 700; font-size: 0.9rem; font-family: Georgia, serif; text-shadow: 0 2px 8px rgba(0,0,0,0.5);">Your RV Repair Experts</div>
        <div style="color: rgba(255,248,220,0.85); font-size: 0.65rem; margin-top: 4px;">Mobile & Roof Services</div>
        <div style="margin-top: 8px; display: inline-block; background: #c4553e; color: #fff; padding: 3px 10px; border-radius: 5px; font-size: 0.6rem;">Book Now</div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; background: #e8c99a;">
        <div style="padding: 10px; text-align: center; border-right: 1px solid #ddd0b8;"><div style="font-size: 1.2rem;">&#128663;</div><div style="font-size: 0.6rem; color: #5c2218; font-weight: 600;">Mobile Repair</div></div>
        <div style="padding: 10px; text-align: center;"><div style="font-size: 1.2rem;">&#127968;</div><div style="font-size: 0.6rem; color: #5c2218; font-weight: 600;">Roof Repair</div></div>
      </div>
    </div>
    <h2 style="font-size: 1.1rem;">Desert Sunset</h2>
    <p style="color: var(--text-light); font-size: 0.85rem; margin-bottom: 1rem;">Warm terracotta, mesa reds, dusty sage and golden hour light. Southwest desert warmth at dusk.</p>
    <% if (theme.activeTheme !== 'desert-sunset') { %>
      <form action="/admin/design/theme" method="POST" style="display:inline;"><input type="hidden" name="activeTheme" value="desert-sunset"><button type="submit" class="btn btn-primary">Activate Theme</button></form>
    <% } else { %><button class="btn" disabled style="opacity: 0.5;">Currently Active</button><% } %>
  </div>

  <!-- ── Lake Country ── -->
  <div class="admin-card" style="position: relative; overflow: hidden; <%= theme.activeTheme === 'lake-country' ? 'border: 2px solid #1a6b8a;' : '' %>">
    <% if (theme.activeTheme === 'lake-country') { %><div style="position: absolute; top: 12px; right: 12px; background: #1a6b8a; color: #fff; padding: 3px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600;">ACTIVE</div><% } %>
    <div style="border-radius: var(--radius); overflow: hidden; margin-bottom: 1rem; border: 1px solid #c0dce8;">
      <div style="background: #0d4059; padding: 8px 12px; display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #d4a72c;">
        <span style="color: #f0f8fb; font-weight: 700; font-size: 0.8rem; font-family: Georgia, serif;">Mobile Meadows</span>
        <div style="display: flex; gap: 8px;"><span style="color: rgba(220,240,248,0.85); font-size: 0.65rem;">Home</span><span style="color: rgba(220,240,248,0.85); font-size: 0.65rem;">Calendar</span></div>
      </div>
      <div style="background: linear-gradient(180deg, #051a2e 0%, #0d4059 25%, #1a6b8a 50%, #7ec8e3 75%, #cde8f0 100%); padding: 24px 12px; text-align: center;">
        <div style="color: #f0f8fb; font-weight: 700; font-size: 0.9rem; font-family: Georgia, serif; text-shadow: 0 2px 8px rgba(0,0,0,0.4);">Your RV Repair Experts</div>
        <div style="color: rgba(220,240,248,0.85); font-size: 0.65rem; margin-top: 4px;">Mobile & Roof Services</div>
        <div style="margin-top: 8px; display: inline-block; background: #1a6b8a; color: #fff; padding: 3px 10px; border-radius: 5px; font-size: 0.6rem;">Book Now</div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; background: #cde8f0;">
        <div style="padding: 10px; text-align: center; border-right: 1px solid #aacedd;"><div style="font-size: 1.2rem;">&#128663;</div><div style="font-size: 0.6rem; color: #0d4059; font-weight: 600;">Mobile Repair</div></div>
        <div style="padding: 10px; text-align: center;"><div style="font-size: 1.2rem;">&#127968;</div><div style="font-size: 0.6rem; color: #0d4059; font-weight: 600;">Roof Repair</div></div>
      </div>
    </div>
    <h2 style="font-size: 1.1rem;">Lake Country</h2>
    <p style="color: var(--text-light); font-size: 0.85rem; margin-bottom: 1rem;">Clear water blues, dock wood, morning mist and fishing gold. Peaceful Ozark lakeside at dawn.</p>
    <% if (theme.activeTheme !== 'lake-country') { %>
      <form action="/admin/design/theme" method="POST" style="display:inline;"><input type="hidden" name="activeTheme" value="lake-country"><button type="submit" class="btn btn-primary">Activate Theme</button></form>
    <% } else { %><button class="btn" disabled style="opacity: 0.5;">Currently Active</button><% } %>
  </div>

  <!-- ── Mountain Lodge ── -->
  <div class="admin-card" style="position: relative; overflow: hidden; <%= theme.activeTheme === 'mountain-lodge' ? 'border: 2px solid #5c3d2e;' : '' %>">
    <% if (theme.activeTheme === 'mountain-lodge') { %><div style="position: absolute; top: 12px; right: 12px; background: #5c3d2e; color: #fff; padding: 3px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600;">ACTIVE</div><% } %>
    <div style="border-radius: var(--radius); overflow: hidden; margin-bottom: 1rem; border: 1px solid #ddd0c4;">
      <div style="background: #3a2218; padding: 8px 12px; display: flex; justify-content: space-between; align-items: center; border-bottom: 3px solid #c9783a;">
        <span style="color: #f8f6f4; font-weight: 700; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; font-family: Impact, sans-serif;">Mobile Meadows</span>
        <div style="display: flex; gap: 8px;"><span style="color: rgba(248,246,244,0.8); font-size: 0.65rem;">HOME</span><span style="color: rgba(248,246,244,0.8); font-size: 0.65rem;">CALENDAR</span></div>
      </div>
      <div style="background: linear-gradient(180deg, #1a2030 0%, #2d3a4a 18%, #f8f6f4 18%, #e0d8d0 40%, #a09585 65%, #3a2218 100%); padding: 24px 12px; text-align: center; min-height: 80px; position: relative;">
        <div style="color: #fff; font-weight: 700; font-size: 0.9rem; letter-spacing: 0.08em; text-transform: uppercase; font-family: Impact, sans-serif; text-shadow: 0 2px 10px rgba(0,0,0,0.7);">Your RV Repair Experts</div>
        <div style="color: rgba(255,255,255,0.8); font-size: 0.65rem; margin-top: 4px;">Mobile & Roof Services</div>
        <div style="margin-top: 8px; display: inline-block; background: #5c3d2e; color: #f8f6f4; padding: 3px 10px; border-radius: 2px; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em;">Book Now</div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; background: #f5f0eb;">
        <div style="padding: 10px; text-align: center; border-right: 1px solid #ddd0c4;"><div style="font-size: 1.2rem;">&#128663;</div><div style="font-size: 0.6rem; color: #3a2218; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Mobile Repair</div></div>
        <div style="padding: 10px; text-align: center;"><div style="font-size: 1.2rem;">&#127968;</div><div style="font-size: 0.6rem; color: #3a2218; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Roof Repair</div></div>
      </div>
    </div>
    <h2 style="font-size: 1.1rem;">Mountain Lodge</h2>
    <p style="color: var(--text-light); font-size: 0.85rem; margin-bottom: 1rem;">Warm cedar, granite grey, snowcap white. Rustic cabin aesthetic with ember orange accents.</p>
    <% if (theme.activeTheme !== 'mountain-lodge') { %>
      <form action="/admin/design/theme" method="POST" style="display:inline;"><input type="hidden" name="activeTheme" value="mountain-lodge"><button type="submit" class="btn btn-primary">Activate Theme</button></form>
    <% } else { %><button class="btn" disabled style="opacity: 0.5;">Currently Active</button><% } %>
  </div>

  <!-- ── Open Road ── -->
  <div class="admin-card" style="position: relative; overflow: hidden; <%= theme.activeTheme === 'open-road' ? 'border: 2px solid #c41e3a;' : '' %>">
    <% if (theme.activeTheme === 'open-road') { %><div style="position: absolute; top: 12px; right: 12px; background: #c41e3a; color: #fff; padding: 3px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600;">ACTIVE</div><% } %>
    <div style="border-radius: var(--radius); overflow: hidden; margin-bottom: 1rem; border: 1px solid #e0dbd4;">
      <div style="background: #1a1a1a; padding: 8px 12px; display: flex; justify-content: space-between; align-items: center; border-bottom: 3px solid #c41e3a; position: relative;">
        <span style="color: #fff; font-weight: 700; font-size: 0.85rem; letter-spacing: 0.15em; text-transform: uppercase; font-family: Impact, sans-serif;">Mobile Meadows</span>
        <div style="display: flex; gap: 8px;"><span style="color: rgba(255,255,255,0.75); font-size: 0.65rem; font-weight: 600;">HOME</span><span style="color: rgba(255,255,255,0.75); font-size: 0.65rem; font-weight: 600;">CALENDAR</span></div>
      </div>
      <!-- Checkerboard stripe -->
      <div style="height: 5px; background: repeating-linear-gradient(90deg, #1a1a1a 0px, #1a1a1a 5px, #fff 5px, #fff 10px);"></div>
      <div style="background: linear-gradient(180deg, #0a0a12 0%, #1a1a2e 30%, #1a5fa8 60%, #c8c8d0 80%, #f7f5f0 100%); padding: 20px 12px; text-align: center;">
        <div style="color: #fff; font-weight: 700; font-size: 0.95rem; letter-spacing: 0.1em; text-transform: uppercase; font-family: Impact, sans-serif; text-shadow: 0 0 20px rgba(196,30,58,0.6), 0 2px 8px rgba(0,0,0,0.7);">Hit The Road</div>
        <div style="color: rgba(255,255,255,0.8); font-size: 0.65rem; margin-top: 4px;">Repair Where You Roam</div>
        <div style="margin-top: 8px; display: inline-block; background: #c41e3a; color: #fff; padding: 3px 12px; border-radius: 2px; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; box-shadow: 0 2px 0 #8b0f25;">Book Now</div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; background: #fdf8f0;">
        <div style="padding: 10px; text-align: center; border-right: 2px solid #e0dbd4;"><div style="font-size: 1.2rem;">&#128663;</div><div style="font-size: 0.6rem; color: #1a1a1a; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">Mobile Repair</div></div>
        <div style="padding: 10px; text-align: center;"><div style="font-size: 1.2rem;">&#127968;</div><div style="font-size: 0.6rem; color: #1a1a1a; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">Roof Repair</div></div>
      </div>
    </div>
    <h2 style="font-size: 1.1rem;">Open Road</h2>
    <p style="color: var(--text-light); font-size: 0.85rem; margin-bottom: 1rem;">Classic Americana. Diner red & blue, chrome accents, checkerboard stripes. Route 66 roadside energy.</p>
    <% if (theme.activeTheme !== 'open-road') { %>
      <form action="/admin/design/theme" method="POST" style="display:inline;"><input type="hidden" name="activeTheme" value="open-road"><button type="submit" class="btn btn-primary">Activate Theme</button></form>
    <% } else { %><button class="btn" disabled style="opacity: 0.5;">Currently Active</button><% } %>
  </div>

  <!-- ── Ozark Morning ── -->
  <div class="admin-card" style="position: relative; overflow: hidden; <%= theme.activeTheme === 'ozark-morning' ? 'border: 2px solid #3d7a5e;' : '' %>">
    <% if (theme.activeTheme === 'ozark-morning') { %><div style="position: absolute; top: 12px; right: 12px; background: #3d7a5e; color: #fff; padding: 3px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600;">ACTIVE</div><% } %>
    <div style="border-radius: 8px; overflow: hidden; margin-bottom: 1rem; border: 1px solid #c8ddd4;">
      <div style="background: #fff; padding: 8px 12px; display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #c8ddd4; box-shadow: 0 2px 8px rgba(30,80,55,0.08);">
        <span style="color: #245240; font-weight: 700; font-size: 0.8rem; font-family: Georgia, serif;">Mobile Meadows</span>
        <div style="display: flex; gap: 8px;"><span style="color: #6a8a78; font-size: 0.65rem; font-weight: 600;">Home</span><span style="color: #6a8a78; font-size: 0.65rem; font-weight: 600;">Calendar</span></div>
      </div>
      <div style="background: linear-gradient(180deg, #b8d4e8 0%, #c8e4d8 30%, #d8eee5 55%, #e8f5ee 75%, #f2f7f4 100%); padding: 24px 12px; text-align: center;">
        <div style="color: #245240; font-weight: 700; font-size: 0.9rem; font-family: Georgia, serif; text-shadow: 0 2px 12px rgba(255,255,255,0.7);">Your RV Repair Experts</div>
        <div style="color: #6a8a78; font-size: 0.65rem; margin-top: 4px;">Mobile & Roof Services</div>
        <div style="margin-top: 10px; display: inline-block; background: linear-gradient(135deg, #5aab84, #245240); color: #fff; padding: 4px 14px; border-radius: 50px; font-size: 0.6rem; font-weight: 800; box-shadow: 0 3px 10px rgba(61,122,94,0.3);">Book Now</div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; background: #f2f7f4;">
        <div style="padding: 10px; text-align: center; border-right: 1px solid #c8ddd4;"><div style="font-size: 1.2rem;">&#128663;</div><div style="font-size: 0.6rem; color: #245240; font-weight: 700;">Mobile Repair</div></div>
        <div style="padding: 10px; text-align: center;"><div style="font-size: 1.2rem;">&#127968;</div><div style="font-size: 0.6rem; color: #245240; font-weight: 700;">Roof Repair</div></div>
      </div>
    </div>
    <h2 style="font-size: 1.1rem;">Ozark Morning</h2>
    <p style="color: var(--text-light); font-size: 0.85rem; margin-bottom: 1rem;">Misty hills, wildflower meadows, soft greens with wildflower orange. Friendly local Branson feel.</p>
    <% if (theme.activeTheme !== 'ozark-morning') { %>
      <form action="/admin/design/theme" method="POST" style="display:inline;"><input type="hidden" name="activeTheme" value="ozark-morning"><button type="submit" class="btn btn-primary">Activate Theme</button></form>
    <% } else { %><button class="btn" disabled style="opacity: 0.5;">Currently Active</button><% } %>
  </div>

</div>

<!-- Theme Settings -->
<div class="admin-card">
  <h2>Theme Settings</h2>
  <form action="/admin/design/settings" method="POST">
    <div class="form-row">
      <div class="form-group">
        <label>Hero Style</label>
        <select name="heroStyle">
          <option value="gradient" <%= theme.heroStyle === 'gradient' ? 'selected' : '' %>>Gradient Background</option>
          <option value="image" <%= theme.heroStyle === 'image' ? 'selected' : '' %>>Background Image</option>
        </select>
      </div>
      <div class="form-group">
        <label>Hero Overlay Opacity</label>
        <input type="range" name="heroOverlayOpacity" min="0" max="1" step="0.1" value="<%= theme.heroOverlayOpacity %>"
               oninput="document.getElementById('opacity-val').textContent = this.value">
        <span id="opacity-val" style="font-size: 0.85rem; color: var(--text-light);"><%= theme.heroOverlayOpacity %></span>
      </div>
    </div>

    <h3 style="margin: 1.5rem 0 1rem; font-size: 1rem;">Custom Color Overrides</h3>
    <p style="font-size: 0.85rem; color: var(--text-light); margin-bottom: 1rem;">Leave blank to use theme defaults. Set custom colors to override any theme.</p>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem;">
      <div class="form-group">
        <label>Primary</label>
        <div style="display: flex; gap: 0.5rem; align-items: center;">
          <input type="color" name="customColors[primary]" value="<%= (theme.customColors && theme.customColors.primary) || '#2d6a4f' %>" style="width: 40px; height: 32px; padding: 0; border: none; cursor: pointer;">
          <input type="text" name="customColors[primary]" value="<%= (theme.customColors && theme.customColors.primary) || '' %>" placeholder="#2d6a4f" style="flex: 1;">
        </div>
      </div>
      <div class="form-group">
        <label>Accent</label>
        <div style="display: flex; gap: 0.5rem; align-items: center;">
          <input type="color" name="customColors[accent]" value="<%= (theme.customColors && theme.customColors.accent) || '#d4a373' %>" style="width: 40px; height: 32px; padding: 0; border: none; cursor: pointer;">
          <input type="text" name="customColors[accent]" value="<%= (theme.customColors && theme.customColors.accent) || '' %>" placeholder="#d4a373" style="flex: 1;">
        </div>
      </div>
      <div class="form-group">
        <label>Background</label>
        <div style="display: flex; gap: 0.5rem; align-items: center;">
          <input type="color" name="customColors[bg]" value="<%= (theme.customColors && theme.customColors.bg) || '#fefae0' %>" style="width: 40px; height: 32px; padding: 0; border: none; cursor: pointer;">
          <input type="text" name="customColors[bg]" value="<%= (theme.customColors && theme.customColors.bg) || '' %>" placeholder="#fefae0" style="flex: 1;">
        </div>
      </div>
      <div class="form-group">
        <label>Card Background</label>
        <div style="display: flex; gap: 0.5rem; align-items: center;">
          <input type="color" name="customColors[bgCard]" value="<%= (theme.customColors && theme.customColors.bgCard) || '#ffffff' %>" style="width: 40px; height: 32px; padding: 0; border: none; cursor: pointer;">
          <input type="text" name="customColors[bgCard]" value="<%= (theme.customColors && theme.customColors.bgCard) || '' %>" placeholder="#ffffff" style="flex: 1;">
        </div>
      </div>
    </div>

    <div style="margin-top: 1.5rem;">
      <button type="submit" class="btn btn-primary">Save Settings</button>
      <form action="/admin/design/reset" method="POST" style="display: inline; margin-left: 0.5rem;">
        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Reset all custom colors to theme defaults?')">Reset Colors</button>
      </form>
    </div>
  </form>
</div>

<!-- Template Rules Info -->
<div class="admin-card">
  <h2>Templating Rules</h2>
  <div style="font-size: 0.9rem; color: var(--text-light); line-height: 1.7;">
    <p><strong>How themes work:</strong></p>
    <ul style="margin: 0.5rem 0 1rem 1.5rem;">
      <li><strong>Default theme</strong> uses the base <code>style.css</code> — green & tan palette, clean layout</li>
      <li><strong>All other themes</strong> load an overlay CSS that overrides colors, typography, and adds visual effects</li>
      <li><strong>Custom colors</strong> override both themes via inline CSS variables on the <code>&lt;body&gt;</code> tag</li>
      <li>Theme changes are <strong>instant</strong> — no rebuild or restart needed</li>
      <li>The admin panel always uses its own styling regardless of public theme</li>
    </ul>
    <p><strong>Adding new themes:</strong></p>
    <ul style="margin: 0.5rem 0 0 1.5rem;">
      <li>Create a CSS file in <code>/public/css/themes/</code> that overrides <code>:root</code> variables</li>
      <li>Add the theme name to the <code>SiteTheme</code> model enum</li>
      <li>Add a preview card on this page</li>
    </ul>
  </div>
</div>
