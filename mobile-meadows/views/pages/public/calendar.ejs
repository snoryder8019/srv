<section class="calendar-page">
  <h1>Service Calendar</h1>
  <p class="calendar-subtitle">Select a service type and pick an available date to book your appointment.</p>

  <div class="calendar-filters">
    <button class="filter-btn active" data-service="all">All Services</button>
    <button class="filter-btn" data-service="mobile-repair">Mobile Repair</button>
    <button class="filter-btn" data-service="roof-repair">Roof Repair</button>
  </div>

  <div class="calendar-nav">
    <button id="cal-prev" class="btn btn-sm">&larr; Prev</button>
    <h2 id="cal-month-label"></h2>
    <button id="cal-next" class="btn btn-sm">Next &rarr;</button>
  </div>

  <div class="calendar-grid" id="calendar-grid"></div>

  <div class="slot-panel" id="slot-panel" style="display:none;">
    <h3 id="slot-date-label"></h3>
    <div id="slot-list"></div>
  </div>
</section>

<script src="/js/calendar.js" defer></script>
