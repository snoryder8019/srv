<!-- Hero -->
<section class="hero">
  <div class="hero-content">
    <h1><%= (content.hero && content.hero.heading) || siteName %></h1>
    <p class="hero-sub"><%= (content.hero && content.hero.subheading) || siteTagline %></p>
    <a href="/calendar" class="btn btn-primary">Book a Service</a>
  </div>
</section>

<!-- Road Divider (visible in camping-highway theme) -->
<div class="road-divider"></div>

<!-- Dual Service Boxes -->
<section class="services">
  <div class="service-box">
    <div class="service-icon">&#128663;</div>
    <h2><%= (content['mobile-repair'] && content['mobile-repair'].heading) || 'Mobile RV & Motorhome Repair' %></h2>
    <p><%- (content['mobile-repair'] && content['mobile-repair'].body) || 'On-site repair and service for RVs and motorhomes. We come to you anywhere in the Branson, MO area.' %></p>
    <a href="/calendar?service=mobile-repair" class="btn btn-secondary">View Availability</a>
  </div>
  <div class="service-box">
    <div class="service-icon">&#127968;</div>
    <h2><%= (content['roof-repair'] && content['roof-repair'].heading) || 'RV Roof Repair' %></h2>
    <p><%- (content['roof-repair'] && content['roof-repair'].body) || 'Specialized RV rooftop repair at our garage facility. Inspection, patching, coating, and full replacement.' %></p>
    <a href="/calendar?service=roof-repair" class="btn btn-secondary">Book Roof Service</a>
  </div>
</section>

<!-- About -->
<section class="about">
  <h2><%= (content.about && content.about.heading) || 'About Mobile Meadows' %></h2>
  <p><%- (content.about && content.about.body) || 'Serving Branson, Missouri and the surrounding areas with reliable, professional RV and motorhome repair services — mobile and in-shop.' %></p>
</section>
