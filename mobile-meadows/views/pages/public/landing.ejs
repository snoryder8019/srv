<!-- Hero -->
<section class="hero" style="background-image: url('/images/hero-rv-highway.jpg');">
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <h1><%= (content.hero && content.hero.heading) || siteName %></h1>
    <p class="hero-sub"><%= (content.hero && content.hero.subheading) || siteTagline %></p>
    <a href="/calendar" class="btn btn-primary">Book a Service</a>
  </div>
</section>

<!-- Road Divider (visible in camping-highway theme) -->
<div class="road-divider"></div>

<!-- Dual Service Boxes -->
<section class="services">

  <div class="service-box" style="background-image: url('/images/service-mobile-repair.jpg');">
    <div class="service-box-overlay"></div>
    <div class="service-box-content">
      <h2><%= (content['mobile-repair'] && content['mobile-repair'].heading) || 'Mobile RV & Motorhome Repair' %></h2>
      <p><%- (content['mobile-repair'] && content['mobile-repair'].body) || 'On-site repair and service for RVs and motorhomes. We come to you anywhere in the Branson, MO area.' %></p>
      <a href="/calendar?service=mobile-repair" class="btn btn-primary">View Availability</a>
    </div>
  </div>

  <div class="service-box" style="background-image: url('/images/service-roof-repair.jpg');">
    <div class="service-box-overlay"></div>
    <div class="service-box-content">
      <h2><%= (content['roof-repair'] && content['roof-repair'].heading) || 'RV Roof Repair' %></h2>
      <p><%- (content['roof-repair'] && content['roof-repair'].body) || 'Specialized RV rooftop repair at our garage facility. Inspection, patching, coating, and full replacement.' %></p>

      <!-- Roof Cost Calculator widget — populated by /public/js/roof-calculator.js -->
      <div id="roof-calculator" class="roof-calc-wrapper"></div>

      <!-- Fallback direct link shown until JS hydrates the calculator -->
      <a href="/calendar?service=roof-repair" class="btn btn-primary" id="roof-fallback-btn">Book Roof Service</a>
    </div>
  </div>

</section>

<!-- About -->
<section class="about" style="background-image: url('/images/about-landscape.jpg');">
  <div class="about-overlay"></div>
  <div class="about-content">
    <h2><%= (content.about && content.about.heading) || 'About Mobile Meadows' %></h2>
    <p><%- (content.about && content.about.body) || 'Serving Branson, Missouri and the surrounding areas with reliable, professional RV and motorhome repair services — mobile and in-shop.' %></p>
  </div>
</section>

<script src="/js/roof-calculator.js" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const calc = document.getElementById('roof-calculator');
    const fallback = document.getElementById('roof-fallback-btn');
    const observer = new MutationObserver(() => {
      if (calc.innerHTML.trim()) fallback.style.display = 'none';
    });
    observer.observe(calc, { childList: true });
  });
</script>
