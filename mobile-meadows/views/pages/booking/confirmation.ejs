<section class="booking-confirmation">
  <div class="confirmation-card">
    <div class="confirmation-icon">&#9989;</div>
    <h1>Booking Request Submitted!</h1>
    <p>Thank you, <strong><%= booking.guestName %></strong>. Your request has been received.</p>
    <div class="confirmation-details">
      <p><strong>Service:</strong> <%= booking.serviceType === 'mobile-repair' ? 'Mobile RV Repair' : 'RV Roof Repair' %></p>
      <p><strong>Date:</strong> <%= new Date(slot.date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
      <p><strong>Time:</strong> <%= slot.startTime %> - <%= slot.endTime %></p>
    </div>
    <h3>What happens next?</h3>
    <ol>
      <li>Our team reviews your request</li>
      <li>We may call you at <strong><%= booking.guestPhone %></strong> to confirm details</li>
      <li>You'll receive a confirmation email at <strong><%= booking.guestEmail %></strong></li>
    </ol>
    <a href="/" class="btn btn-primary">Back to Home</a>
  </div>
</section>
