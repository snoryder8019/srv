<%- include('../partials/head', { title: 'Share a Link' }) %>
<%- include('../partials/nav') %>
<main class="page-main">
  <%- include('../partials/flash') %>
  <div class="page-header">
    <h1>Share a Link</h1>
  </div>
  <p class="page-sub">Submit a link from Reddit, Instagram, or Facebook. Our team will review it before it appears in the digest.</p>

  <form action="/shares" method="POST" class="form-card">
    <div class="form-group">
      <label for="title">Title</label>
      <input type="text" id="title" name="title" class="form-input" placeholder="Describe the link..." required maxlength="120">
    </div>

    <div class="form-group">
      <label for="url">Link URL</label>
      <input type="url" id="url" name="url" class="form-input" placeholder="https://..." required>
    </div>

    <div class="form-group">
      <label for="platform">Platform</label>
      <select id="platform" name="platform" class="form-input" required>
        <option value="">Select platform...</option>
        <option value="reddit">Reddit</option>
        <option value="instagram">Instagram</option>
        <option value="facebook">Facebook</option>
        <option value="other">Other</option>
      </select>
    </div>

    <div class="form-group">
      <label for="description">Description <span class="form-optional">(optional)</span></label>
      <textarea id="description" name="description" class="form-input" rows="3" placeholder="Why is this worth sharing?" maxlength="500"></textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Submit for Review</button>
      <a href="/shares" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</main>
<%- include('../partials/footer') %>
