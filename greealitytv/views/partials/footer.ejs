<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="logo-grm">GREE</span><span class="logo-red">ALITY</span><span class="logo-tv">TV</span>
      <p>Greeley's community hub.</p>
    </div>
    <div class="footer-links">
      <a href="/feed">Feed</a>
      <a href="/posts">Articles</a>
      <a href="/videos">Videos</a>
      <a href="/local">Local</a>
      <a href="/gigs">Gigs</a>
      <a href="/shares">Digest</a>
      <a href="/votes">Votes</a>
    </div>
    <div class="footer-share">
      <button class="footer-btn" id="copyLinkBtn" onclick="footerCopyLink()">📋 Copy Link</button>
      <button class="footer-btn" id="shareQrBtn" onclick="footerShowQr()">⬛ Share QR</button>
    </div>
    <p class="footer-copy">&copy; <%= new Date().getFullYear() %> GreeAlityTV. Community owned, community powered.</p>
  </div>
</footer>

<!-- QR Modal -->
<div id="qrModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:9999;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:12px;padding:2rem;text-align:center;max-width:280px;width:90%;position:relative;">
    <button onclick="document.getElementById('qrModal').style.display='none'" style="position:absolute;top:.6rem;right:.9rem;background:none;border:none;font-size:1.3rem;cursor:pointer;color:#333;">✕</button>
    <p style="margin:0 0 1rem;font-weight:700;color:#1a2340;font-size:.95rem;">Scan to visit this page</p>
    <div id="qrCode"></div>
    <p id="qrUrl" style="margin:.75rem 0 0;font-size:.7rem;color:#666;word-break:break-all;"></p>
  </div>
</div>

<!-- Google Translate (hidden — controlled by custom EN/ES toggle) -->
<div id="google_translate_element" style="display:none;" aria-hidden="true"></div>
<script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script src="/js/main.js"></script>

<!-- Cookie Consent Banner -->
<div id="cookieBanner" class="cookie-banner" role="dialog" aria-label="Cookie consent" style="display:none;">
  <div class="cookie-banner-inner">
    <div class="cookie-banner-text">
      <strong>We use cookies</strong>
      <p>GreeAlityTV uses cookies to keep you signed in and remember your preferences. We don't sell your data or use third-party ad trackers.</p>
    </div>
    <div class="cookie-banner-actions">
      <button id="cookieAccept" class="btn btn-primary btn-sm">Accept</button>
      <button id="cookieDecline" class="btn btn-outline btn-sm">Decline</button>
    </div>
  </div>
</div>
</body>
</html>
