<%- include('../partials/head', { title: 'Verifications — Admin' }) %>
<%- include('../partials/nav') %>
<main class="page-main admin-main">
  <%- include('../partials/flash') %>
  <div class="admin-header">
    <h1>Greeley Verified — Requests</h1>
    <a href="/admin" class="btn btn-outline btn-sm">← Dashboard</a>
  </div>

  <!-- TODO: wire up with real data from VerificationRequest model (Phase 2) -->
  <div class="admin-section">
    <h2>Pending Mail Queue <span class="stat-sub">(paid, awaiting postcard)</span></h2>
    <table class="admin-table">
      <thead>
        <tr>
          <th>User</th>
          <th>Address</th>
          <th>City</th>
          <th>ZIP</th>
          <th>Paid</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (typeof requests !== 'undefined' && requests.length) { %>
          <% requests.filter(r => r.status === 'paid').forEach(r => { %>
            <tr>
              <td>
                <% if (r.user) { %>
                  <img src="<%= r.user.avatar %>" style="width:24px;height:24px;border-radius:50%;vertical-align:middle;margin-right:.4rem;">
                  <%= r.user.displayName %>
                <% } %>
              </td>
              <td><%= r.streetAddress %></td>
              <td><%= r.city %></td>
              <td><%= r.zip %></td>
              <td><%= r.paidAt ? new Date(r.paidAt).toLocaleDateString() : '—' %></td>
              <td><span class="badge badge-gold"><%= r.status %></span></td>
              <td>
                <form action="/admin/verifications/<%= r._id %>/mail" method="POST" style="display:inline">
                  <button class="btn btn-primary btn-xs">Mark Mailed + Generate Code</button>
                </form>
                <form action="/admin/verifications/<%= r._id %>/reject" method="POST" style="display:inline" onsubmit="return confirm('Reject and refund?')">
                  <button class="btn btn-danger btn-xs">Reject</button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--gray-600);">No pending requests.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="admin-section" style="margin-top:2rem">
    <h2>Mailed — Awaiting User Confirmation</h2>
    <table class="admin-table">
      <thead>
        <tr>
          <th>User</th>
          <th>Address</th>
          <th>Code</th>
          <th>Mailed</th>
          <th>Expires</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% if (typeof requests !== 'undefined' && requests.filter(r => r.status === 'mailed').length) { %>
          <% requests.filter(r => r.status === 'mailed').forEach(r => { %>
            <tr>
              <td><%= r.user ? r.user.displayName : '—' %></td>
              <td><%= r.streetAddress %>, <%= r.city %></td>
              <td><code><%= r.code %></code></td>
              <td><%= r.mailedAt ? new Date(r.mailedAt).toLocaleDateString() : '—' %></td>
              <td><%= r.codeExpiresAt ? new Date(r.codeExpiresAt).toLocaleDateString() : '—' %></td>
              <td><span class="badge badge-blue">mailed</span></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="6" style="text-align:center;padding:2rem;color:var(--gray-600);">None mailed yet.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</main>
<%- include('../partials/footer') %>
