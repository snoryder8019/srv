<%- include('../partials/head', { title: 'Admin Dashboard' }) %>
<%- include('../partials/nav') %>
<main class="page-main admin-main">
  <%- include('../partials/flash') %>
  <div class="admin-header">
    <h1>Admin Dashboard</h1>
    <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
      <a href="/admin/local" class="btn btn-outline btn-sm">Local Listings</a>
      <a href="/admin/gigs"  class="btn btn-outline btn-sm">Gigs &amp; Jobs</a>
      <a href="/admin/users" class="btn btn-outline btn-sm">Users</a>
    </div>
  </div>

  <div class="stats-grid">
    <div class="stat-card">
      <span class="stat-num"><%= stats.totalUsers %></span>
      <span class="stat-label">Total Users</span>
      <span class="stat-sub">+<%= stats.newUsers %> this week</span>
    </div>
    <div class="stat-card">
      <span class="stat-num"><%= stats.publishedPosts %></span>
      <span class="stat-label">Published Posts</span>
      <span class="stat-sub"><%= stats.totalPosts %> total</span>
    </div>
    <div class="stat-card">
      <span class="stat-num"><%= stats.totalVideos %></span>
      <span class="stat-label">Videos</span>
    </div>
    <div class="stat-card">
      <span class="stat-num"><%= stats.activePetitions %></span>
      <span class="stat-label">Active Petitions</span>
      <span class="stat-sub"><%= stats.totalPetitions %> total</span>
    </div>
    <div class="stat-card">
      <span class="stat-num"><%= stats.approvedLocals %></span>
      <span class="stat-label">Local Listings</span>
      <span class="stat-sub"><%= stats.totalLocals %> total</span>
    </div>
    <div class="stat-card">
      <span class="stat-num"><%= stats.approvedGigs %></span>
      <span class="stat-label">Active Gigs/Jobs</span>
      <span class="stat-sub"><%= stats.totalGigs %> total</span>
    </div>
  </div>

  <!-- Pending Approval Queues -->
  <% const totalPending = pendingPosts.length + pendingVideos.length + pendingShares.length + pendingLocals.length + pendingGigs.length; %>
  <% if (totalPending > 0) { %>
  <section class="admin-section pending-section">
    <h2>Pending Approval <span class="badge-count"><%= totalPending %></span></h2>

    <% if (pendingPosts.length > 0) { %>
    <h3 class="pending-sub">Articles (<%= pendingPosts.length %>)</h3>
    <table class="admin-table">
      <thead><tr><th>Title</th><th>Author</th><th>Submitted</th><th>Actions</th></tr></thead>
      <tbody>
        <% pendingPosts.forEach(p => { %>
          <tr>
            <td><strong><%= p.title.substring(0, 50) %><%= p.title.length > 50 ? '...' : '' %></strong></td>
            <td><%= p.author ? p.author.displayName : '?' %></td>
            <td><%= new Date(p.createdAt).toLocaleDateString() %></td>
            <td class="action-cell">
              <form action="/admin/posts/<%= p._id %>/approve" method="POST" style="display:inline">
                <button class="btn btn-primary btn-xs">Approve</button>
              </form>
              <form action="/admin/posts/<%= p._id %>/reject" method="POST" style="display:inline">
                <button class="btn btn-outline btn-xs">Reject</button>
              </form>
              <form action="/admin/posts/<%= p._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete?')">
                <button class="btn btn-danger btn-xs">Del</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>

    <% if (pendingVideos.length > 0) { %>
    <h3 class="pending-sub">Videos (<%= pendingVideos.length %>)</h3>
    <table class="admin-table">
      <thead><tr><th>Title</th><th>Author</th><th>Submitted</th><th>Actions</th></tr></thead>
      <tbody>
        <% pendingVideos.forEach(v => { %>
          <tr>
            <td><strong><%= v.title.substring(0, 50) %><%= v.title.length > 50 ? '...' : '' %></strong></td>
            <td><%= v.author ? v.author.displayName : '?' %></td>
            <td><%= new Date(v.createdAt).toLocaleDateString() %></td>
            <td class="action-cell">
              <form action="/admin/videos/<%= v._id %>/approve" method="POST" style="display:inline">
                <button class="btn btn-primary btn-xs">Approve</button>
              </form>
              <form action="/admin/videos/<%= v._id %>/reject" method="POST" style="display:inline">
                <button class="btn btn-outline btn-xs">Reject</button>
              </form>
              <form action="/admin/videos/<%= v._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete?')">
                <button class="btn btn-danger btn-xs">Del</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>

    <% if (pendingShares.length > 0) { %>
    <h3 class="pending-sub">Shared Links (<%= pendingShares.length %>)</h3>
    <table class="admin-table">
      <thead><tr><th>Title</th><th>Platform</th><th>Submitted By</th><th>Date</th><th>Actions</th></tr></thead>
      <tbody>
        <% pendingShares.forEach(s => { %>
          <tr>
            <td><a href="<%= s.url %>" target="_blank" rel="noopener"><%= s.title.substring(0, 45) %><%= s.title.length > 45 ? '...' : '' %></a></td>
            <td><span class="tag tag-<%= s.platform %>"><%= s.platform %></span></td>
            <td><%= s.submittedBy ? s.submittedBy.displayName : '?' %></td>
            <td><%= new Date(s.createdAt).toLocaleDateString() %></td>
            <td class="action-cell">
              <form action="/admin/shares/<%= s._id %>/approve" method="POST" style="display:inline">
                <button class="btn btn-primary btn-xs">Approve</button>
              </form>
              <form action="/admin/shares/<%= s._id %>/reject" method="POST" style="display:inline">
                <button class="btn btn-outline btn-xs">Reject</button>
              </form>
              <form action="/admin/shares/<%= s._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete?')">
                <button class="btn btn-danger btn-xs">Del</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>

    <% if (pendingLocals.length > 0) { %>
    <h3 class="pending-sub">Local Listings (<%= pendingLocals.length %>)</h3>
    <table class="admin-table">
      <thead><tr><th>Name</th><th>Category</th><th>Neighborhood</th><th>Submitted By</th><th>Date</th><th>Actions</th></tr></thead>
      <tbody>
        <% pendingLocals.forEach(l => { %>
          <tr>
            <td><strong><%= l.name.substring(0, 45) %><%= l.name.length > 45 ? '...' : '' %></strong></td>
            <td><span class="tag"><%= l.category %></span></td>
            <td><%= l.neighborhood %></td>
            <td><%= l.submittedBy ? l.submittedBy.displayName : '?' %></td>
            <td><%= new Date(l.createdAt).toLocaleDateString() %></td>
            <td class="action-cell">
              <form action="/admin/local/<%= l._id %>/approve" method="POST" style="display:inline">
                <button class="btn btn-primary btn-xs">Approve</button>
              </form>
              <form action="/admin/local/<%= l._id %>/reject" method="POST" style="display:inline">
                <button class="btn btn-outline btn-xs">Reject</button>
              </form>
              <form action="/admin/local/<%= l._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete?')">
                <button class="btn btn-danger btn-xs">Del</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>

    <% if (pendingGigs.length > 0) { %>
    <h3 class="pending-sub">Gigs &amp; Jobs (<%= pendingGigs.length %>)</h3>
    <table class="admin-table">
      <thead><tr><th>Title</th><th>Type</th><th>Category</th><th>Submitted By</th><th>Date</th><th>Actions</th></tr></thead>
      <tbody>
        <% pendingGigs.forEach(g => { %>
          <tr>
            <td><strong><%= g.title.substring(0, 45) %><%= g.title.length > 45 ? '...' : '' %></strong></td>
            <td><span class="tag"><%= g.type %></span></td>
            <td><%= g.category %></td>
            <td><%= g.submittedBy ? g.submittedBy.displayName : '?' %></td>
            <td><%= new Date(g.createdAt).toLocaleDateString() %></td>
            <td class="action-cell">
              <form action="/admin/gigs/<%= g._id %>/approve" method="POST" style="display:inline">
                <button class="btn btn-primary btn-xs">Approve</button>
              </form>
              <form action="/admin/gigs/<%= g._id %>/reject" method="POST" style="display:inline">
                <button class="btn btn-outline btn-xs">Reject</button>
              </form>
              <form action="/admin/gigs/<%= g._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete?')">
                <button class="btn btn-danger btn-xs">Del</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </section>
  <% } else { %>
  <section class="admin-section">
    <p class="empty-state" style="padding:1rem 0;">No pending content — all caught up!</p>
  </section>
  <% } %>

  <div class="admin-grid">
    <section class="admin-section">
      <h2>Recent Articles</h2>
      <table class="admin-table">
        <thead><tr><th>Title</th><th>Author</th><th>Date</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% recentPosts.forEach(p => { %>
            <tr>
              <td><a href="/posts/<%= p._id %>"><%= p.title.substring(0, 40) %><%= p.title.length > 40 ? '...' : '' %></a></td>
              <td><%= p.author ? p.author.displayName : '?' %></td>
              <td><%= new Date(p.createdAt).toLocaleDateString() %></td>
              <td><span class="status-badge <%= p.published ? 'status-green' : 'status-gray' %>"><%= p.published ? 'Published' : 'Draft' %></span></td>
              <td class="action-cell">
                <button class="btn btn-outline btn-xs toggle-publish" data-id="<%= p._id %>" data-published="<%= p.published %>">
                  <%= p.published ? 'Unpublish' : 'Publish' %>
                </button>
                <form action="/admin/posts/<%= p._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete?')">
                  <button class="btn btn-danger btn-xs">Del</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>

    <section class="admin-section">
      <h2>Recent Signups</h2>
      <div class="user-list">
        <% recentUsers.forEach(u => { %>
          <div class="user-row">
            <% if (u.avatar) { %><img src="<%= u.avatar %>" class="meta-avatar"><% } %>
            <div>
              <span class="user-name"><%= u.displayName %></span>
              <span class="user-email"><%= u.email %></span>
            </div>
            <span class="list-meta"><%= new Date(u.createdAt).toLocaleDateString() %></span>
            <span class="status-badge <%= u.isAdmin ? 'status-red' : 'status-gray' %>"><%= u.isAdmin ? 'Admin' : 'User' %></span>
          </div>
        <% }) %>
      </div>
    </section>
  </div>
</main>

<script>
document.querySelectorAll('.toggle-publish').forEach(btn => {
  btn.addEventListener('click', async () => {
    const res = await fetch(`/admin/posts/${btn.dataset.id}/publish?_method=PUT`, { method: 'POST' });
    const data = await res.json();
    btn.textContent = data.published ? 'Unpublish' : 'Publish';
    btn.dataset.published = data.published;
    const badge = btn.closest('tr').querySelector('.status-badge');
    badge.textContent = data.published ? 'Published' : 'Draft';
    badge.className = `status-badge ${data.published ? 'status-green' : 'status-gray'}`;
  });
});
</script>
<%- include('../partials/footer') %>
