<%- include('../partials/head', { title: 'Post a Gig or Job' }) %>
<%- include('../partials/nav') %>
<main class="page-main">
  <%- include('../partials/flash') %>
  <div class="form-container">
    <div class="form-header">
      <h1>Post a Gig or Job</h1>
      <p>All postings are reviewed before publishing. Include clear contact info so applicants can reach you.</p>
    </div>

    <form action="/gigs" method="POST" class="content-form">

      <div class="form-row">
        <div class="form-group">
          <label for="type">Type <span class="req">*</span></label>
          <select id="type" name="type" required>
            <option value="">— Select —</option>
            <option value="gig">⚡ Gig (short-term / one-off)</option>
            <option value="job">💼 Job (regular position)</option>
          </select>
        </div>
        <div class="form-group">
          <label for="category">Category <span class="req">*</span></label>
          <select id="category" name="category" required>
            <option value="">— Select —</option>
            <% categories.forEach(c => { %>
              <option value="<%= c %>"><%= c %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="title">Title <span class="req">*</span></label>
        <input type="text" id="title" name="title" required maxlength="120"
               placeholder="e.g. Lawn mowing this weekend, Line Cook, Delivery Driver…">
      </div>

      <div class="form-group">
        <label for="company">Company / Employer <span class="field-hint">(optional)</span></label>
        <input type="text" id="company" name="company" maxlength="100" placeholder="Leave blank for personal gig">
      </div>

      <div class="form-group">
        <label for="description">Description <span class="req">*</span></label>
        <textarea id="description" name="description" required rows="5" maxlength="1200"
                  placeholder="Describe the work, schedule, requirements, and any relevant details…"></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="pay">Pay / Compensation <span class="field-hint">(optional)</span></label>
          <input type="text" id="pay" name="pay" maxlength="80" placeholder="e.g. $18/hr, $200 flat, Negotiable">
        </div>
        <div class="form-group">
          <label for="contact">Contact <span class="req">*</span></label>
          <input type="text" id="contact" name="contact" required maxlength="200"
                 placeholder="Email, phone, or application URL">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="neighborhood">Neighborhood <span class="field-hint">(optional)</span></label>
          <select id="neighborhood" name="neighborhood">
            <option value="">— Any / Not specified —</option>
            <% neighborhoods.forEach(n => { %>
              <option value="<%= n %>"><%= n %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label for="expiresAt">Listing Expires <span class="field-hint">(optional)</span></label>
          <input type="date" id="expiresAt" name="expiresAt">
        </div>
      </div>

      <div class="form-group form-check">
        <label class="check-label">
          <input type="checkbox" name="isRemote" id="isRemote">
          <span>This is a remote position</span>
        </label>
      </div>

      <div class="form-actions">
        <a href="/gigs" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">Submit for Review</button>
      </div>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
