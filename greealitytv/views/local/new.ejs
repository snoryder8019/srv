<%- include('../partials/head', { title: 'Add a Local Listing' }) %>
<%- include('../partials/nav') %>
<main class="page-main">
  <%- include('../partials/flash') %>
  <div class="form-container">
    <div class="form-header">
      <h1>Add a Local Listing</h1>
      <p>Submit a food spot, business, service, or food truck in Greeley. All listings are reviewed before publishing.</p>
    </div>

    <form action="/local" method="POST" enctype="multipart/form-data" class="content-form">

      <div class="form-group">
        <label for="name">Name <span class="req">*</span></label>
        <input type="text" id="name" name="name" required maxlength="120" placeholder="e.g. Taco Loco, Mike's Plumbing…">
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="category">Category <span class="req">*</span></label>
          <select id="category" name="category" required>
            <option value="">— Select —</option>
            <option value="food">🍽 Food</option>
            <option value="business">🏢 Business</option>
            <option value="service">🔧 Service</option>
            <option value="food-truck">🚚 Food Truck</option>
          </select>
        </div>

        <div class="form-group">
          <label for="neighborhood">Neighborhood <span class="req">*</span></label>
          <select id="neighborhood" name="neighborhood" required>
            <option value="">— Select —</option>
            <% neighborhoods.forEach(n => { %>
              <option value="<%= n %>"><%= n %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="description">Description <span class="req">*</span></label>
        <textarea id="description" name="description" required rows="4" maxlength="600" placeholder="Tell neighbors what this place is about…"></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="address">Address</label>
          <input type="text" id="address" name="address" maxlength="150" placeholder="123 Main St, Greeley">
        </div>
        <div class="form-group">
          <label for="phone">Phone</label>
          <input type="text" id="phone" name="phone" maxlength="30" placeholder="(970) 555-0100">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="hours">Hours</label>
          <input type="text" id="hours" name="hours" maxlength="100" placeholder="Mon–Fri 9am–6pm">
        </div>
        <div class="form-group">
          <label for="website">Website</label>
          <input type="url" id="website" name="website" maxlength="250" placeholder="https://…">
        </div>
      </div>

      <div class="form-group">
        <label for="image">Photo <span class="field-hint">(optional, max 10MB)</span></label>
        <input type="file" id="image" name="image" accept="image/*">
      </div>

      <div class="form-actions">
        <a href="/local" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">Submit for Review</button>
      </div>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
