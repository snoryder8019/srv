<%- include('../partials/head', { title: 'Enter Your Verification Code' }) %>
<%- include('../partials/nav') %>
<main class="page-main">
  <%- include('../partials/flash') %>
  <div class="verify-container">
    <div class="verify-header">
      <h1>Enter Your Code</h1>
      <p>Check your postcard and enter the <strong>4-character code</strong> printed on it (e.g. <code>GRV-4X9B</code>).</p>
    </div>
    <form class="verify-form" action="/verify/confirm" method="POST">
      <div class="form-group">
        <label>Verification Code</label>
        <input type="text" name="code" required placeholder="GRV-XXXX" maxlength="8" style="text-transform:uppercase;font-size:1.4rem;letter-spacing:4px;text-align:center;" />
      </div>
      <button type="submit" class="btn btn-primary btn-lg btn-block">Activate My Badge</button>
    </form>
    <p class="verify-note" style="margin-top:1.5rem;">Haven't received your postcard? Allow 3–7 business days. <a href="/profile">Back to Profile</a></p>
  </div>
</main>
<%- include('../partials/footer') %>
