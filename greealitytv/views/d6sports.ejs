          <div class="card-meta">
            <span>(970) 348-5200</span>
            <span class="dot">&middot;</span>
            <span>Comprehensive</span>
          </div>
          <div class="d6-sports-list">
            <small>Football &middot; Basketball &middot; Soccer &middot; Volleyball &middot; Tennis &middot; Swimming &middot; Baseball &middot; Softball &middot; XC &middot; Track &middot; Wrestling &middot; Golf</small>
