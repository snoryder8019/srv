<%- include('partials/head', { title: 'District 6 Sports' }) %>
<%- include('partials/nav') %>

<main>
  <%- include('partials/flash') %>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-eyebrow">GreeAlityTV x District 6</div>
      <h1 class="hero-headline">High School<br>Sports.<br><span class="hero-accent">Live.</span></h1>
      <p class="hero-sub">Connecting Greeley families to our city's rising talent — live broadcasts from the stands, the fieldhouses, and every court in between.</p>
      <div class="hero-cta">
        <a href="#schools" class="btn btn-primary btn-lg">The Schools</a>
        <a href="#venues" class="btn btn-outline btn-lg">The Venues</a>
      </div>
    </div>
    <div class="hero-badge">
      <div class="badge-ring">
        <span>SPORTS</span>
        <span class="badge-city">DISTRICT 6</span>
        <span>LIVE</span>
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section class="home-section" id="mission">
    <div class="section-header">
      <h2>The Mission</h2>
    </div>
    <div class="d6-mission">
      <p>GreeAlityTV is partnering with Greeley-Evans School District 6 to bring <strong>live high school sports broadcasts</strong> to every family in Greeley. Whether it's parent delegates streaming from the bleachers or permanent hardware installed at fieldhouses and fields — we're building the infrastructure to make sure no family misses a moment.</p>
      <div class="d6-pillars">
        <div class="d6-pillar">
          <div class="d6-pillar-icon">&#127909;</div>
          <h4>Parent Delegates</h4>
          <p>Trained community volunteers broadcasting live from the stands with mobile kits — real fans, real angles, real energy.</p>
        </div>
        <div class="d6-pillar">
          <div class="d6-pillar-icon">&#128225;</div>
          <h4>Hardware Installs</h4>
          <p>Permanent multi-camera setups at fieldhouses, stadiums, and courts — professional-grade coverage for every home game.</p>
        </div>
        <div class="d6-pillar">
          <div class="d6-pillar-icon">&#127968;</div>
          <h4>Family Connection</h4>
          <p>From our city talent to their rising future in sports — connecting families who can't make it to the game with the moments that matter.</p>
        </div>
      </div>
    </div>
  </section>

