<%- include('../partials/head', { title: 'Become a Delegate' }) %>
<%- include('../partials/nav') %>
<main class="page-main">
  <%- include('../partials/flash') %>

  <div class="form-page">
    <h1>Become a Parent Delegate</h1>
    <p class="form-intro">Help us bring live high school sports to every family in Greeley. As a delegate, you'll broadcast games from the stands using a mobile kit we provide. Once approved, you get access to the delegate dashboard, game schedules, and recording tools.</p>

    <% if (existing) { %>
      <div class="alert alert-info">
        You've already applied. Your status: <strong><%= existing.status %></strong>
        <% if (existing.status === 'approved') { %>
          — <a href="/delegates/dashboard">Go to Dashboard</a>
        <% } %>
      </div>
    <% } else { %>

    <form action="/delegates/apply" method="POST" class="form-stack">
      <div class="form-group">
        <label for="fullName">Full Name</label>
        <input type="text" id="fullName" name="fullName" required class="form-input" placeholder="Your full legal name">
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="phone">Phone Number</label>
          <input type="tel" id="phone" name="phone" class="form-input" placeholder="(970) 555-0123">
        </div>
        <div class="form-group">
          <label for="relation">Your Relationship</label>
          <select name="relation" id="relation" class="form-input">
            <option value="parent">Parent</option>
            <option value="guardian">Guardian</option>
            <option value="teacher">Teacher</option>
            <option value="coach">Coach</option>
            <option value="community">Community Member</option>
            <option value="other">Other</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label>Which school(s) can you cover?</label>
        <div class="checkbox-grid">
          <% schools.forEach(s => { %>
            <label class="checkbox-label">
              <input type="checkbox" name="schools" value="<%= s %>">
              <span><%= s %></span>
            </label>
          <% }) %>
        </div>
      </div>

      <div class="form-group agreement-box">
        <h3>GreeAlityTV Delegate Agreement</h3>
        <div class="agreement-text">
          <p><strong>By signing below, you agree to:</strong></p>
          <ol>
            <li>Represent GreeAlityTV professionally at all District 6 sporting events.</li>
            <li>Follow all school district policies regarding recording and broadcasting on school property.</li>
            <li>Not broadcast or record any content until GreeAlityTV has a signed partnership agreement with Greeley-Evans School District 6.</li>
            <li>Use only GreeAlityTV-provided or approved equipment for official broadcasts.</li>
            <li>Respect the privacy of minors — no close-ups or identifying shots of students without parental consent forms on file with the district.</li>
            <li>Return all issued equipment upon request or upon termination of delegate status.</li>
            <li>Not monetize, redistribute, or sublicense any recordings made as a delegate.</li>
          </ol>
          <p><em>This agreement is contingent upon GreeAlityTV completing a formal partnership agreement with Greeley-Evans School District 6. No recording or broadcasting will occur until that agreement is in place.</em></p>
        </div>
        <label class="checkbox-label">
          <input type="checkbox" name="agreementSigned" required>
          <span>I have read and agree to the GreeAlityTV Delegate Agreement</span>
        </label>
      </div>

      <button type="submit" class="btn btn-primary btn-lg">Submit Application</button>
    </form>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
