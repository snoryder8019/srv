<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'OpsTrain' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .hamburger{display:none;background:none;border:none;cursor:pointer;padding:6px;color:#e4e4e7;font-size:22px;}
    @media(max-width:768px){
      .hamburger{display:block;}
      .nav-links{display:none;position:absolute;top:100%;left:0;right:0;background:#18181b;border-bottom:1px solid #27272a;padding:12px 16px;flex-direction:column;gap:6px;z-index:100;}
      .nav-links.open{display:flex;}
      .navbar{position:relative;flex-wrap:wrap;}
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <a href="/" class="nav-brand">OpsTrain</a>
    <button class="hamburger" onclick="document.querySelector('.nav-links').classList.toggle('open')">&#9776;</button>
    <div class="nav-links">
      <% if (typeof user !== 'undefined' && user) { %>
        <% if (['superadmin','admin','manager'].includes(user.role)) { %>
          <a href="/admin"><%= t('nav.dashboard') %></a>
          <% if (user.role === 'superadmin') { %>
            <a href="/admin/brands"><%= t('nav.brands') %></a>
          <% } %>
          <a href="/admin/tasks"><%= t('nav.tasks') %></a>
          <a href="/admin/qr"><%= t('nav.qrCodes') %></a>
          <a href="/admin/shifts/command"><%= lang === 'es' ? 'Turnos' : 'Shifts' %></a>
          <a href="/admin/specials"><%= t('nav.specials') %></a>
          <% if (['superadmin','admin'].includes(user.role)) { %>
            <a href="/admin/users"><%= t('nav.users') %></a>
          <% } %>
          <a href="/admin/analytics"><%= t('nav.analytics') %></a>
          <a href="/live">Live</a>
          <% if (user.role === 'superadmin') { %><a href="/superadmin" style="color:#fbbf24;">Platform</a><% } %>
          <a href="/admin/roster"><%= lang === 'es' ? 'Escaner' : 'Roster' %></a>
        <% } %>
        <span class="nav-user"><%= user.displayName %> (<%= user.role %>)</span>
        <a href="/auth/logout"><%= t('nav.logout') %></a>
      <% } else { %>
        <a href="/auth/login"><%= t('nav.login') %></a>
      <% } %>
      <a href="?lang=<%= lang === 'es' ? 'en' : 'es' %>" class="lang-toggle"><%= lang === 'es' ? 'EN' : 'ES' %></a>
    </div>
  </nav>
  <main class="container">
