<%- include('../../layout/header') %>

<div class="admin-header">
  <h1><%= t('nav.brands') %></h1>
  <a href="/admin/brands/new" class="btn btn-primary"><%= t('admin.newBrand') %></a>
</div>

<% if (brands.length === 0) { %>
  <div class="empty-state"><p><%= t('admin.noBrandsYet') %></p></div>
<% } else { %>
<table class="data-table">
  <thead>
    <tr>
      <th><%= t('fields.name') %></th>
      <th><%= t('fields.location') %></th>
      <th><%= t('fields.slug') %></th>
      <th><%= t('fields.actions') %></th>
    </tr>
  </thead>
  <tbody>
    <% brands.forEach(b => { %>
    <tr>
      <td><strong><%= b.name %></strong></td>
      <td><%= b.location || '—' %></td>
      <td><code><%= b.slug %></code></td>
      <td>
        <a href="/admin/brands/<%= b._id %>/edit" class="btn btn-sm"><%= t('admin.edit') %></a>
        <a href="/admin/tasks?brandId=<%= b._id %>" class="btn btn-sm btn-secondary"><%= t('nav.tasks') %></a>
        <a href="/admin/qr?brandId=<%= b._id %>" class="btn btn-sm btn-secondary"><%= t('nav.qrCodes') %></a>
      </td>
    </tr>
    <% }) %>
  </tbody>
</table>
<% } %>

<%- include('../../layout/footer') %>
