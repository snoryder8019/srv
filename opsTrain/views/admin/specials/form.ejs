<%- include('../../layout/header') %>

<div class="admin-header">
  <h1><%= special ? t('admin.edit') : t('admin.create') %> <%= t('nav.specials') %></h1>
</div>

<form method="POST" action="<%= special ? '/admin/specials/' + special._id : '/admin/specials' %>" class="form-card">
  <div class="form-group">
    <label><%= t('fields.brand') %> *</label>
    <select name="brandId" required>
      <option value=""><%= t('fields.selectBrand') %></option>
      <% brands.forEach(b => { %>
        <option value="<%= b._id %>" <%= brandId === b._id.toString() ? 'selected' : '' %>><%= b.name %></option>
      <% }) %>
    </select>
  </div>
  <div class="form-group">
    <label><%= t('fields.name') %> *</label>
    <input type="text" name="name" value="<%= special ? special.name : '' %>" required>
  </div>
  <div class="form-group">
    <label><%= t('fields.description') %></label>
    <textarea name="description" rows="2"><%= special ? special.description : '' %></textarea>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label><%= t('fields.price') %></label>
      <input type="text" name="price" value="<%= special ? special.price : '' %>" placeholder="$12.99">
    </div>
    <div class="form-group">
      <label><%= t('fields.shiftTime') %></label>
      <select name="shiftTime">
        <% ['all','open','mid','close'].forEach(s => { %>
          <option value="<%= s %>" <%= (special && special.shiftTime === s) ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>
    </div>
  </div>

  <div class="form-actions">
    <button type="submit" name="saveAs" value="active" class="btn btn-primary"><%= special ? t('admin.update') : t('admin.create') %></button>
    <button type="submit" name="saveAs" value="draft" class="btn btn-secondary"><%= lang === 'es' ? 'Guardar Borrador' : 'Save Draft' %></button>
    <a href="/admin/specials" class="btn btn-secondary"><%= t('admin.cancel') %></a>
  </div>
</form>

<%- include('../../layout/footer') %>
