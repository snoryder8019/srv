<%- include('../../layout/header') %>

<div class="admin-header">
  <h1><%= t('nav.specials') %></h1>
  <a href="/admin/specials/new<%= selectedBrand ? '?brandId=' + selectedBrand : '' %>" class="btn btn-primary"><%= t('admin.newSpecial') %></a>
</div>

<div class="filter-bar">
  <form method="GET" action="/admin/specials">
    <select name="brandId" onchange="this.form.submit()">
      <option value=""><%= t('admin.allBrands') %></option>
      <% brands.forEach(b => { %>
        <option value="<%= b._id %>" <%= selectedBrand === b._id.toString() ? 'selected' : '' %>><%= b.name %></option>
      <% }) %>
    </select>
  </form>
</div>

<% if (specials.length === 0) { %>
  <div class="empty-state"><p><%= t('admin.noSpecialsYet') %></p></div>
<% } else { %>
<table class="data-table">
  <thead>
    <tr><th><%= t('fields.name') %></th><th><%= t('fields.brand') %></th><th><%= t('fields.price') %></th><th><%= t('fields.shift') %></th><th>Status</th><th><%= t('fields.actions') %></th></tr>
  </thead>
  <tbody>
    <% specials.forEach(s => { %>
    <tr class="<%= s.status === 'draft' ? 'row-draft' : '' %>">
      <td><strong><%= s.name %></strong><br><span class="text-muted text-sm"><%= s.description %></span></td>
      <td><%= s.brand?.name || '—' %></td>
      <td><%= s.price || '—' %></td>
      <td><%= s.shiftTime %></td>
      <td>
        <% if (s.status === 'draft') { %>
          <span class="badge" style="background:#422006;color:#fbbf24;">draft</span>
        <% } else { %>
          <span class="badge badge-admin">live</span>
        <% } %>
      </td>
      <td>
        <a href="/admin/specials/<%= s._id %>/edit" class="btn btn-sm"><%= t('admin.edit') %></a>
        <% if (s.status === 'draft') { %>
          <form method="POST" action="/admin/specials/<%= s._id %>/publish" style="display:inline">
            <button type="submit" class="btn btn-sm btn-check"><%= lang === 'es' ? 'Publicar' : 'Publish' %></button>
          </form>
        <% } else { %>
          <form method="POST" action="/admin/specials/<%= s._id %>/unpublish" style="display:inline">
            <button type="submit" class="btn btn-sm"><%= lang === 'es' ? 'Borrador' : 'Draft' %></button>
          </form>
        <% } %>
        <form method="POST" action="/admin/specials/<%= s._id %>/delete" style="display:inline">
          <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete?')"><%= t('admin.del') %></button>
        </form>
      </td>
    </tr>
    <% }) %>
  </tbody>
</table>
<% } %>

<%- include('../../layout/footer') %>
