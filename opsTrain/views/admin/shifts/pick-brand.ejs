<%- include('../../layout/header') %>
<div class="admin-header"><h1><%= title %></h1></div>
<div class="card-grid">
  <% brands.forEach(b => { %>
    <a href="/admin/shifts/command?brandId=<%= b._id %>" class="brand-card" style="border-left:4px solid <%= b.color || '#d97706' %>;text-decoration:none;">
      <h3><%= b.name %></h3>
    </a>
  <% }) %>
</div>
<%- include('../../layout/footer') %>
