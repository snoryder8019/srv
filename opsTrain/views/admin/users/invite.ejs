<%- include('../../layout/header') %>

<div style="max-width:480px;margin:0 auto;text-align:center;">
  <h2>Manager Invite — <%= brandName %></h2>
  <p style="color:#a1a1aa;font-size:13px;margin-bottom:20px;">
    Share this link or QR code with someone you want to invite as a manager. They'll create an account and be assigned directly to your brand.
  </p>

  <div style="background:#111113;border:1px solid #27272a;border-radius:8px;padding:20px;margin-bottom:20px;">
    <img src="<%= qrDataUrl %>" alt="Invite QR" style="max-width:200px;border-radius:4px;margin-bottom:12px;">
    <div style="margin-top:12px;">
      <input type="text" value="<%= inviteUrl %>" readonly id="inviteUrlInput"
        style="width:100%;padding:8px 10px;background:#09090b;border:1px solid #3f3f46;border-radius:6px;color:#e4e4e7;font-size:12px;text-align:center;">
      <button onclick="navigator.clipboard.writeText(document.getElementById('inviteUrlInput').value);this.textContent='Copied!';setTimeout(()=>this.textContent='Copy Link',1500)"
        style="margin-top:8px;padding:8px 20px;background:#d97706;color:#09090b;border:none;border-radius:6px;font-weight:700;cursor:pointer;font-size:13px;">
        Copy Link
      </button>
    </div>
  </div>

  <p style="font-size:11px;color:#52525b;">This invite link can be used by multiple people. Generate a new one to invalidate the old link.</p>

  <a href="/admin/users" style="display:inline-block;margin-top:16px;color:#d97706;text-decoration:none;font-size:13px;">&larr; Back to Users</a>
</div>

<%- include('../../layout/footer') %>
