<%- include('../../layout/header') %>

<div class="admin-header">
  <h1><%= editUser ? t('admin.edit') : t('admin.create') %> <%= t('nav.users') %></h1>
</div>

<form method="POST" action="<%= editUser ? '/admin/users/' + editUser._id : '/admin/users' %>" class="form-card">
  <div class="form-group">
    <label><%= t('fields.brand') %> *</label>
    <select name="brandId" required>
      <option value=""><%= t('fields.selectBrand') %></option>
      <% brands.forEach(b => { %>
        <option value="<%= b._id %>" <%= brandId === b._id.toString() ? 'selected' : '' %>><%= b.name %></option>
      <% }) %>
    </select>
  </div>
  <div class="form-group">
    <label><%= t('fields.displayName') %> *</label>
    <input type="text" name="displayName" value="<%= editUser ? editUser.displayName : '' %>" required>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label><%= t('fields.firstName') %></label>
      <input type="text" name="firstName" value="<%= editUser ? editUser.firstName : '' %>">
    </div>
    <div class="form-group">
      <label><%= t('fields.lastName') %></label>
      <input type="text" name="lastName" value="<%= editUser ? editUser.lastName : '' %>">
    </div>
  </div>
  <div class="form-group">
    <label><%= t('fields.email') %></label>
    <input type="email" name="email" value="<%= editUser ? editUser.email : '' %>">
  </div>
  <div class="form-group">
    <label><%= t('settings.pinNote') %></label>
    <input type="text" name="posPin" value="<%= editUser ? editUser.posPin : '' %>" pattern="[0-9]{4,6}" placeholder="1234">
  </div>
  <div class="form-group">
    <label><%= t('fields.role') %></label>
    <select name="role">
      <% ['user','manager','admin','superadmin'].forEach(r => { %>
        <option value="<%= r %>" <%= (editUser && editUser.role === r) ? 'selected' : '' %>><%= r %></option>
      <% }) %>
    </select>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary"><%= editUser ? t('admin.update') : t('admin.create') %></button>
    <a href="/admin/users" class="btn btn-secondary"><%= t('admin.cancel') %></a>
  </div>
</form>

<%- include('../../layout/footer') %>
