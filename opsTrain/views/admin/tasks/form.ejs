<%- include('../../layout/header') %>

<div class="admin-header">
  <h1><%= task ? t('admin.edit') : t('admin.create') %> <%= t('nav.tasks') %></h1>
</div>

<form method="POST" action="<%= task ? '/admin/tasks/' + task._id : '/admin/tasks' %>" class="form-card">
  <div class="form-group">
    <label><%= t('fields.brand') %> *</label>
    <select name="brandId" required>
      <option value=""><%= t('fields.selectBrand') %></option>
      <% brands.forEach(b => { %>
        <option value="<%= b._id %>" <%= brandId === b._id.toString() ? 'selected' : '' %>><%= b.name %></option>
      <% }) %>
    </select>
  </div>
  <div class="form-group">
    <label><%= t('fields.title') %> *</label>
    <input type="text" name="title" value="<%= task ? task.title : '' %>" required>
  </div>
  <div class="form-group">
    <label><%= t('fields.description') %></label>
    <textarea name="description" rows="2"><%= task ? task.description : '' %></textarea>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label><%= t('fields.type') %></label>
      <select name="type">
        <% ['sidework','prep','cleaning','inspection','custom'].forEach(tp => { %>
          <option value="<%= tp %>" <%= (task && task.type === tp) ? 'selected' : '' %>><%= tp %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label><%= t('fields.frequency') %></label>
      <select name="frequency">
        <% ['daily','weekly','monthly','per-shift','once'].forEach(f => { %>
          <option value="<%= f %>" <%= (task && task.frequency === f) ? 'selected' : '' %>><%= f %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label><%= t('fields.shiftTime') %></label>
      <select name="shiftTime">
        <% ['any','open','mid','close'].forEach(s => { %>
          <option value="<%= s %>" <%= (task && task.shiftTime === s) ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>
    </div>
  </div>
  <div class="form-group">
    <label><%= t('fields.sortOrder') %></label>
    <input type="number" name="sortOrder" value="<%= task ? task.sortOrder : 0 %>">
  </div>
  <div class="form-check">
    <label><input type="checkbox" name="requiresPhoto" <%= (task && task.requiresPhoto) ? 'checked' : '' %>> <%= t('settings.requiresPhoto') %></label>
  </div>
  <div class="form-check">
    <label><input type="checkbox" name="requiresNote" <%= (task && task.requiresNote) ? 'checked' : '' %>> <%= t('settings.requiresNote') %></label>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary"><%= task ? t('admin.update') : t('admin.create') %></button>
    <a href="/admin/tasks" class="btn btn-secondary"><%= t('admin.cancel') %></a>
  </div>
</form>

<%- include('../../layout/footer') %>
