<%- include('../layout/header') %>

<div class="admin-header">
  <h1><%= t('admin.dashboard') %></h1>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-number"><%= stats.brandCount %></div>
    <div class="stat-label"><%= t('nav.brands') %></div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= stats.taskCount %></div>
    <div class="stat-label"><%= t('nav.tasks') %></div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= stats.qrCount %></div>
    <div class="stat-label"><%= t('nav.qrCodes') %></div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= stats.userCount %></div>
    <div class="stat-label"><%= t('nav.users') %></div>
  </div>
</div>

<% if (brands && brands.length > 0) { %>
<h2><%= t('nav.brands') %></h2>
<div class="card-grid">
  <% brands.forEach(b => { %>
    <div class="brand-card" style="border-left: 4px solid <%= b.color %>">
      <h3><%= b.name %></h3>
      <p class="text-muted"><%= b.location || '' %></p>
      <div class="brand-actions">
        <a href="/admin/tasks?brandId=<%= b._id %>" class="btn btn-sm"><%= t('nav.tasks') %></a>
        <a href="/admin/qr?brandId=<%= b._id %>" class="btn btn-sm"><%= t('nav.qrCodes') %></a>
        <a href="/admin/users?brandId=<%= b._id %>" class="btn btn-sm"><%= t('nav.users') %></a>
        <a href="/admin/shifts?brandId=<%= b._id %>" class="btn btn-sm"><%= t('nav.shiftNotes') %></a>
        <a href="/admin/qr/print?brandId=<%= b._id %>" class="btn btn-sm btn-secondary"><%= t('admin.printAll') %></a>
      </div>
    </div>
  <% }) %>
</div>
<% } else { %>
  <div class="empty-state">
    <p><%= t('admin.noBrandsYet') %></p>
    <a href="/admin/brands/new" class="btn btn-primary"><%= t('admin.createFirst') %></a>
  </div>
<% } %>

<%- include('../layout/footer') %>
