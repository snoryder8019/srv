<%- include('../layout/header') %>

<% if (typeof trialBrand !== 'undefined' && trialBrand && trialBrand.status === 'preview') { %>
<%
  const _exp = trialBrand.trialExpiresAt ? new Date(trialBrand.trialExpiresAt) : null;
  const _days = _exp ? Math.max(0, Math.ceil((_exp.getTime() - Date.now()) / 86400000)) : null;
  const _expired = _days !== null && _days <= 0;
  const _urgent = _days !== null && _days <= 2;
%>
<div style="background:<%= _expired ? 'rgba(239,68,68,0.1)' : 'rgba(251,191,36,0.08)' %>;border:1px solid <%= _expired ? 'rgba(239,68,68,0.3)' : 'rgba(251,191,36,0.2)' %>;border-left:4px solid <%= _expired ? '#ef4444' : _urgent ? '#f59e0b' : '#fbbf24' %>;border-radius:8px;padding:16px 20px;margin-bottom:20px;">
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <div>
      <div style="font-size:14px;font-weight:700;color:<%= _expired ? '#ef4444' : '#e4e4e7' %>;">
        <% if (_expired) { %>
          Preview Expired — Activate to Keep Your Account
        <% } else { %>
          Preview Mode — <%= _days %> day<%= _days !== 1 ? 's' : '' %> remaining
        <% } %>
      </div>
      <div style="font-size:12px;color:#71717a;margin-top:4px;">
        <% if (_expired) { %>
          Your trial has ended. Activate a plan to keep using OpsTrain.
        <% } else { %>
          You're on a free 7-day trial. Set up your tasks, QR codes, and team — then activate when ready.
        <% } %>
      </div>
    </div>
    <a href="#" style="display:inline-block;padding:8px 20px;background:#d97706;color:#09090b;border-radius:6px;font-size:13px;font-weight:800;text-decoration:none;white-space:nowrap;transition:background 0.2s;" onmouseover="this.style.background='#fbbf24'" onmouseout="this.style.background='#d97706'">
      <%= _expired ? 'Activate Now' : 'Go Live — $28/mo' %>
    </a>
  </div>
</div>
<% } %>

<% if (typeof trialBrand !== 'undefined' && trialBrand && trialBrand.status === 'suspended') { %>
<div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-left:4px solid #ef4444;border-radius:8px;padding:16px 20px;margin-bottom:20px;">
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <div>
      <div style="font-size:14px;font-weight:700;color:#ef4444;">Account Suspended</div>
      <div style="font-size:12px;color:#71717a;margin-top:4px;">Your trial has expired. Activate a plan to restore access.</div>
    </div>
    <a href="#" style="display:inline-block;padding:8px 20px;background:#d97706;color:#09090b;border-radius:6px;font-size:13px;font-weight:800;text-decoration:none;" onmouseover="this.style.background='#fbbf24'" onmouseout="this.style.background='#d97706'">Activate Now</a>
  </div>
</div>
<% } %>

<div class="admin-header">
  <h1><%= t('admin.dashboard') %></h1>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-number"><%= stats.brandCount %></div>
    <div class="stat-label"><%= t('nav.brands') %></div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= stats.taskCount %></div>
    <div class="stat-label"><%= t('nav.tasks') %></div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= stats.qrCount %></div>
    <div class="stat-label"><%= t('nav.qrCodes') %></div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= stats.userCount %></div>
    <div class="stat-label"><%= t('nav.users') %></div>
  </div>
</div>

<% if (brands && brands.length > 0) { %>
<h2><%= t('nav.brands') %></h2>
<div class="card-grid">
  <% brands.forEach(b => { %>
    <div class="brand-card" style="border-left: 4px solid <%= b.color %>">
      <h3><%= b.name %></h3>
      <p class="text-muted"><%= b.location || '' %></p>
      <div class="brand-actions">
        <a href="/admin/tasks?brandId=<%= b._id %>" class="btn btn-sm"><%= t('nav.tasks') %></a>
        <a href="/admin/qr?brandId=<%= b._id %>" class="btn btn-sm"><%= t('nav.qrCodes') %></a>
        <a href="/admin/users?brandId=<%= b._id %>" class="btn btn-sm"><%= t('nav.users') %></a>
        <a href="/admin/shifts?brandId=<%= b._id %>" class="btn btn-sm"><%= t('nav.shiftNotes') %></a>
        <a href="/admin/qr/print?brandId=<%= b._id %>" class="btn btn-sm btn-secondary"><%= t('admin.printAll') %></a>
      </div>
    </div>
  <% }) %>
</div>
<% } else { %>
  <div class="empty-state">
    <p><%= t('admin.noBrandsYet') %></p>
    <a href="/admin/brands/new" class="btn btn-primary"><%= t('admin.createFirst') %></a>
  </div>
<% } %>

<%- include('../layout/footer') %>
