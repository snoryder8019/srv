<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Print QR Codes — <%= brand ? brand.name : 'OpsTrain' %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial, sans-serif; padding: 20px; background: #111113; color: #e4e4e7; }
    .print-header { text-align: center; margin-bottom: 30px; }
    .print-header h1 { font-size: 24px; color: #d97706; }
    .area-section { margin-bottom: 30px; page-break-inside: avoid; }
    .area-title {
      font-size: 18px; text-transform: uppercase; letter-spacing: 1px;
      border-bottom: 2px solid #d97706; padding-bottom: 6px; margin-bottom: 16px; color: #d97706;
    }
    .qr-print-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .qr-print-item {
      border: 2px solid #2e2e35;
      border-radius: 8px;
      padding: 15px;
      text-align: center;
      background: #1c1c21;
      page-break-inside: avoid;
    }
    .qr-print-item img { width: 160px; height: 160px; }
    .qr-print-item h3 { font-size: 13px; margin: 8px 0 4px; color: #e4e4e7; }
    .qr-print-item p { font-size: 11px; color: #8b8b94; }
    .qr-print-item .station-tag {
      display: inline-block; background: #2e2e35; color: #d97706;
      font-size: 10px; padding: 2px 8px; border-radius: 10px; margin-top: 4px;
      text-transform: uppercase; font-weight: 600;
    }
    .no-print { margin-bottom: 20px; }
    .no-print button {
      padding: 10px 20px; font-size: 16px; cursor: pointer;
      background: #d97706; color: #111; border: none; border-radius: 6px; font-weight: 600;
    }
    .no-print a { margin-left: 10px; color: #8b8b94; }
    @media print {
      .no-print { display: none; }
      body { padding: 0; background: #fff; color: #111; }
      .area-title { color: #333; border-color: #333; }
      .qr-print-item { border-color: #333; background: #fff; }
      .qr-print-item h3 { color: #111; }
      .qr-print-item .station-tag { background: #eee; color: #333; }
    }
  </style>
</head>
<body>
  <div class="no-print">
    <button onclick="window.print()">Print QR Codes</button>
    <a href="/admin/qr?brandId=<%= brand ? brand._id : '' %>">Back to QR list</a>
  </div>

  <div class="print-header">
    <h1><%= brand ? brand.name : '' %> — QR Codes</h1>
    <p style="color:#8b8b94;">Scan with any camera app</p>
  </div>

  <% Object.keys(grouped).forEach(area => { %>
    <div class="area-section">
      <h2 class="area-title"><%= area %></h2>
      <div class="qr-print-grid">
        <% grouped[area].forEach(qr => { %>
          <div class="qr-print-item">
            <img src="<%= qr.dataUrl %>" alt="<%= qr.label %>">
            <h3><%= qr.label %></h3>
            <p><%= qr.type %></p>
            <% if (qr.position) { %><span class="station-tag"><%= qr.position %></span><% } %>
            <% if (qr.task) { %><p>Task: <%= qr.task.title %></p><% } %>
          </div>
        <% }) %>
      </div>
    </div>
  <% }) %>
</body>
</html>
