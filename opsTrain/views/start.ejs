<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OpsTrain — <%= lang==='es'?'Empezar':'Get Started' %></title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap');
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:'Inter',sans-serif;background:#09090b;color:#e4e4e7;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;}
    .card{background:#18181b;border:1px solid #27272a;border-radius:16px;padding:32px;max-width:460px;width:100%;}
    .logo{font-size:20px;font-weight:900;color:#d97706;text-align:center;margin-bottom:4px;}
    .sub{text-align:center;font-size:12px;color:#71717a;margin-bottom:20px;}
    .trial-badge{text-align:center;margin-bottom:20px;}
    .trial-badge span{display:inline-block;font-size:11px;font-weight:700;color:#fbbf24;background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.2);border-radius:20px;padding:4px 14px;}
    h2{font-size:18px;font-weight:800;margin-bottom:16px;text-align:center;}
    .error-msg{background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#ef4444;padding:8px 12px;border-radius:6px;font-size:12px;margin-bottom:14px;}

    /* Auth tabs */
    .auth-tabs{display:flex;gap:0;margin-bottom:16px;border:1px solid #3f3f46;border-radius:6px;overflow:hidden;}
    .auth-tab{flex:1;padding:8px 0;text-align:center;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;background:#111113;color:#71717a;border:none;cursor:pointer;transition:all 0.15s;font-family:'Inter',sans-serif;}
    .auth-tab:not(:last-child){border-right:1px solid #3f3f46;}
    .auth-tab:hover{color:#e4e4e7;}
    .auth-tab.active{background:#d97706;color:#09090b;}
    .auth-panel{display:none;}.auth-panel.active{display:block;}

    label{display:block;font-size:11px;font-weight:700;color:#71717a;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;}
    input,select{width:100%;padding:10px 12px;background:#111113;border:1px solid #3f3f46;border-radius:6px;
      color:#e4e4e7;font-size:14px;font-family:inherit;margin-bottom:12px;}
    input:focus,select:focus{outline:none;border-color:#d97706;}
    .row{display:flex;gap:8px;}
    .row>div{flex:1;}
    .hint{font-size:10px;color:#52525b;margin:-8px 0 12px;}
    .submit{width:100%;padding:12px;background:#d97706;color:#09090b;border:none;border-radius:8px;
      font-size:15px;font-weight:800;cursor:pointer;margin-top:8px;transition:all 0.2s;}
    .submit:hover{background:#fbbf24;transform:translateY(-1px);}
    .submit:disabled{background:#3f3f46;color:#71717a;cursor:not-allowed;transform:none;}

    .g-btn{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:12px;
      background:#fff;color:#333;border:none;border-radius:8px;font-size:14px;font-weight:700;
      cursor:pointer;text-decoration:none;margin-bottom:16px;transition:all 0.2s;font-family:'Inter',sans-serif;}
    .g-btn:hover{background:#f0f0f0;transform:translateY(-1px);}
    .g-btn svg{width:18px;height:18px;}

    .note{text-align:center;font-size:10px;color:#52525b;margin-top:12px;}
    .note a{color:#d97706;text-decoration:none;}
    .back{display:block;text-align:center;color:#52525b;font-size:12px;margin-top:16px;text-decoration:none;}
    .back:hover{color:#d97706;}
    .signin-link{text-align:center;margin-top:12px;font-size:12px;color:#52525b;}
    .signin-link a{color:#d97706;text-decoration:none;}

    @media(max-width:520px){.row{flex-direction:column;gap:0;}.row>div{flex:none;}}
  </style>
  <script src="https://accounts.google.com/gsi/client" async defer></script>
</head>
<body>
  <div class="card">
    <div class="logo">OpsTrain</div>
    <div class="sub"><%= lang==='es'?'Gestion de operaciones para restaurantes':'Operations management for restaurants' %></div>
    <div class="trial-badge"><span><%= lang==='es'?'7 dias gratis — sin tarjeta de credito':'7 days free — no credit card' %></span></div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>

    <!-- Auth method tabs -->
    <div class="auth-tabs">
      <button class="auth-tab active" data-tab="email" onclick="switchTab('email')">Email</button>
      <button class="auth-tab" data-tab="google" onclick="switchTab('google')">Google</button>
    </div>

    <!-- EMAIL SIGNUP -->
    <div class="auth-panel active" id="panel-email">
      <form action="/start/signup" method="POST" id="signupForm">
        <label><%= lang==='es'?'Nombre del Restaurante':'Restaurant / Business Name' %> *</label>
        <input type="text" name="restaurantName" required placeholder="<%= lang==='es'?'Ej: Taqueria El Sol':'e.g. Scotty\'s Bar & Grill' %>">

        <div class="row">
          <div>
            <label><%= lang==='es'?'Tu Nombre':'Your Name' %></label>
            <input type="text" name="ownerName" placeholder="<%= lang==='es'?'Nombre completo':'Full name' %>">
          </div>
          <div>
            <label><%= lang==='es'?'Telefono':'Phone' %></label>
            <input type="tel" name="phone">
          </div>
        </div>

        <label>Email *</label>
        <input type="email" name="email" required placeholder="you@restaurant.com">

        <div class="row">
          <div>
            <label><%= lang==='es'?'Contrasena':'Password' %> *</label>
            <input type="password" name="password" required minlength="8" autocomplete="new-password">
            <div class="hint"><%= lang==='es'?'Minimo 8 caracteres':'Min 8 characters' %></div>
          </div>
          <div>
            <label><%= lang==='es'?'Confirmar':'Confirm' %> *</label>
            <input type="password" name="passwordConfirm" required autocomplete="new-password">
          </div>
        </div>

        <div class="row">
          <div>
            <label><%= lang==='es'?'Ubicacion':'Location' %></label>
            <input type="text" name="location" placeholder="<%= lang==='es'?'Ciudad, Estado':'City, State' %>">
          </div>
          <div>
            <label><%= lang==='es'?'Zona Horaria':'Timezone' %></label>
            <select name="timezone">
              <option value="America/New_York">Eastern</option>
              <option value="America/Chicago">Central</option>
              <option value="America/Denver">Mountain</option>
              <option value="America/Los_Angeles">Pacific</option>
            </select>
          </div>
        </div>

        <button type="submit" class="submit"><%= lang==='es'?'Crear Mi Restaurante':'Create My Restaurant' %></button>
      </form>
    </div>

    <!-- GOOGLE SIGNUP -->
    <div class="auth-panel" id="panel-google">
      <div style="margin-bottom:16px;">
        <label><%= lang==='es'?'Nombre del Restaurante':'Restaurant / Business Name' %> *</label>
        <input type="text" id="g-restaurantName" required placeholder="<%= lang==='es'?'Ej: Taqueria El Sol':'e.g. Scotty\'s Bar & Grill' %>">

        <div class="row">
          <div>
            <label><%= lang==='es'?'Ubicacion':'Location' %></label>
            <input type="text" id="g-location" placeholder="<%= lang==='es'?'Ciudad, Estado':'City, State' %>">
          </div>
          <div>
            <label><%= lang==='es'?'Zona Horaria':'Timezone' %></label>
            <select id="g-timezone">
              <option value="America/New_York">Eastern</option>
              <option value="America/Chicago">Central</option>
              <option value="America/Denver">Mountain</option>
              <option value="America/Los_Angeles">Pacific</option>
            </select>
          </div>
        </div>
      </div>

      <div id="googleOneTapWrap" style="display:flex;justify-content:center;margin-bottom:10px;"></div>
      <button type="button" id="googleSignupBtn" class="g-btn">
        <svg viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
        <%= lang==='es'?'Registrarse con Google':'Sign up with Google' %>
      </button>
      <div style="font-size:11px;color:#52525b;text-align:center;"><%= lang==='es'?'No necesitas contrasena':'No password needed' %></div>
    </div>

    <div class="signin-link"><%= lang==='es'?'Ya tienes cuenta?':'Already have an account?' %> <a href="/auth/login"><%= lang==='es'?'Entrar':'Sign in' %></a></div>
    <p class="note"><%= lang==='es'?'Al registrarte aceptas los':'By signing up you agree to the' %> <a href="#"><%= lang==='es'?'terminos de servicio':'terms of service' %></a></p>
    <a href="/" class="back">&larr; <%= lang==='es'?'Volver':'Back' %></a>
  </div>

<script>
function switchTab(tab) {
  document.querySelectorAll('.auth-tab').forEach(function(t) { t.classList.toggle('active', t.dataset.tab === tab); });
  document.querySelectorAll('.auth-panel').forEach(function(p) { p.classList.remove('active'); });
  var panel = document.getElementById('panel-' + tab);
  if (panel) panel.classList.add('active');
}

// Google One Tap
window.onload = function() {
  if (typeof google === 'undefined' || !google.accounts) return;
  var cid = '<%= typeof process !== "undefined" ? process.env.GGLCID || "" : "" %>';
  if (!cid) return;

  google.accounts.id.initialize({ client_id: cid, callback: handleGoogleSignup });
  google.accounts.id.renderButton(document.getElementById('googleOneTapWrap'), {
    theme: 'filled_black', size: 'large', width: 380, text: 'signup_with',
  });

  document.getElementById('googleSignupBtn').addEventListener('click', function() {
    google.accounts.id.prompt();
  });
};

async function handleGoogleSignup(response) {
  var name = document.getElementById('g-restaurantName').value.trim();
  if (!name) { document.getElementById('g-restaurantName').focus(); alert('Restaurant name is required'); return; }

  try {
    var res = await fetch('/start/google-signup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        credential: response.credential,
        restaurantName: name,
        location: document.getElementById('g-location').value.trim(),
        timezone: document.getElementById('g-timezone').value,
      }),
    });
    var data = await res.json();
    if (data.ok) {
      window.location.href = data.redirect || '/admin';
    } else {
      alert(data.error || 'Signup failed');
    }
  } catch(e) {
    alert('Network error');
  }
}
</script>
</body>
</html>
