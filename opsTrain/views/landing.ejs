<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OpsTrain</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap');
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:'Inter',sans-serif;background:#09090b;color:#e4e4e7;overflow-x:hidden;}

    /* Grid bg */
    .grid-bg{position:fixed;inset:0;z-index:0;
      background-image:linear-gradient(rgba(217,119,6,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(217,119,6,0.04) 1px,transparent 1px);
      background-size:40px 40px;
    }
    .grid-fade{position:fixed;inset:0;z-index:1;
      background:radial-gradient(ellipse at 50% 0%,transparent 0%,#09090b 70%);
    }

    /* Glow orb */
    .glow{position:fixed;width:500px;height:500px;border-radius:50%;z-index:0;filter:blur(120px);opacity:0.15;
      background:radial-gradient(circle,#d97706,transparent 70%);top:-100px;left:50%;transform:translateX(-50%);
      animation:glowPulse 6s ease infinite;
    }
    @keyframes glowPulse{0%,100%{opacity:0.12;transform:translateX(-50%) scale(1);}50%{opacity:0.2;transform:translateX(-50%) scale(1.1);}}

    .page{position:relative;z-index:2;max-width:900px;margin:0 auto;padding:0 20px;}

    /* Nav */
    .lp-nav{display:flex;align-items:center;justify-content:space-between;padding:20px 0;}
    .lp-logo{font-size:20px;font-weight:900;color:#d97706;letter-spacing:-0.5px;text-decoration:none;}
    .lp-nav-links{display:flex;gap:12px;align-items:center;}
    .lp-nav-links a{color:#71717a;text-decoration:none;font-size:13px;font-weight:600;transition:color 0.2s;}
    .lp-nav-links a:hover{color:#e4e4e7;}
    .lp-lang{font-size:11px;font-weight:800;color:#d97706;border:1px solid #3f3f46;border-radius:4px;padding:2px 6px;}

    /* Hero */
    .hero-section{text-align:center;padding:80px 0 60px;}
    .hero-tag{display:inline-block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:2px;
      color:#d97706;background:rgba(217,119,6,0.1);border:1px solid rgba(217,119,6,0.2);border-radius:20px;padding:4px 14px;margin-bottom:20px;}
    .hero-h1{font-size:clamp(36px,8vw,64px);font-weight:900;line-height:1;letter-spacing:-2px;margin-bottom:16px;}
    .hero-h1 span{background:linear-gradient(135deg,#d97706,#fbbf24);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
    .hero-sub{font-size:clamp(15px,2.5vw,18px);color:#a1a1aa;max-width:520px;margin:0 auto 32px;line-height:1.5;}
    .hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
    .btn-hero{padding:12px 28px;border-radius:8px;font-size:14px;font-weight:700;text-decoration:none;transition:all 0.2s;}
    .btn-amber{background:#d97706;color:#09090b;border:none;}
    .btn-amber:hover{background:#fbbf24;transform:translateY(-1px);box-shadow:0 8px 24px rgba(217,119,6,0.3);}
    .btn-ghost{background:transparent;color:#e4e4e7;border:1px solid #3f3f46;}
    .btn-ghost:hover{border-color:#d97706;color:#d97706;}
    .hero-promo{margin-top:16px;font-size:13px;font-weight:700;color:#fbbf24;letter-spacing:0.5px;animation:promoPulse 3s ease infinite;}
    @keyframes promoPulse{0%,100%{opacity:0.7;}50%{opacity:1;}}

    /* Bento grid */
    .bento{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:60px;}
    .bento-card{background:#18181b;border:1px solid #27272a;border-radius:12px;padding:24px;position:relative;overflow:hidden;transition:border-color 0.3s,transform 0.2s;}
    .bento-card:hover{border-color:#d97706;transform:translateY(-2px);}
    .bento-wide{grid-column:span 2;}
    .bento-icon{font-size:28px;margin-bottom:12px;display:block;}
    .bento-card h3{font-size:15px;font-weight:800;margin-bottom:6px;color:#e4e4e7;}
    .bento-card p{font-size:12px;color:#71717a;line-height:1.5;}

    /* Fake ticket inside bento */
    .bento-ticket{background:#111113;border:1px solid #27272a;border-left:3px solid #d97706;border-radius:6px;padding:6px 10px;margin-top:12px;font-size:10px;}
    .bento-ticket .tt-dot{display:inline-block;width:6px;height:6px;border-radius:50%;margin-right:4px;}
    .bento-ticket .tt-open{background:#d97706;}
    .bento-ticket .tt-done{background:#22c55e;}

    /* Stats strip */
    .stats-strip{display:flex;justify-content:center;gap:40px;padding:40px 0;border-top:1px solid #1c1c1f;border-bottom:1px solid #1c1c1f;margin-bottom:60px;}
    .stats-strip .ss-item{text-align:center;}
    .ss-num{font-size:32px;font-weight:900;color:#d97706;display:block;line-height:1;}
    .ss-lbl{font-size:10px;text-transform:uppercase;letter-spacing:1px;color:#52525b;}

    /* Pricing */
    .pricing{display:flex;justify-content:center;padding:20px 0 60px;}
    .pricing-card{background:#18181b;border:2px solid #d97706;border-radius:16px;padding:32px;max-width:380px;width:100%;text-align:center;}
    .pricing-tag{font-size:10px;font-weight:800;letter-spacing:2px;color:#d97706;margin-bottom:8px;}
    .pricing-amount{font-size:56px;font-weight:900;color:#e4e4e7;line-height:1;}
    .pricing-dollar{font-size:28px;vertical-align:super;color:#71717a;margin-right:2px;}
    .pricing-mo{font-size:16px;font-weight:600;color:#71717a;}
    .pricing-promo{font-size:14px;font-weight:700;color:#fbbf24;margin:8px 0 6px;padding:6px;background:rgba(251,191,36,0.08);border-radius:6px;}
    .pricing-multi{font-size:12px;color:#a1a1aa;margin-bottom:20px;}
    .pricing-list{list-style:none;text-align:left;margin-bottom:8px;}
    .pricing-list li{font-size:13px;color:#a1a1aa;padding:6px 0;border-bottom:1px solid #27272a;padding-left:20px;position:relative;}
    .pricing-list li::before{content:'';position:absolute;left:0;top:10px;width:8px;height:8px;border-radius:50%;background:#d97706;}
    .pricing-note{font-size:11px;color:#52525b;margin-top:10px;}

    /* CTA */
    .cta{text-align:center;padding:40px 0 80px;}
    .cta h2{font-size:28px;font-weight:900;margin-bottom:12px;}
    .cta h2 span{color:#d97706;}
    .cta p{color:#71717a;font-size:14px;margin-bottom:24px;}

    /* Footer */
    .lp-footer{text-align:center;padding:20px 0;color:#3f3f46;font-size:11px;border-top:1px solid #1c1c1f;}

    @media(max-width:640px){
      .bento{grid-template-columns:1fr;}
      .bento-wide{grid-column:span 1;}
      .stats-strip{flex-wrap:wrap;gap:24px;}
      .hero-section{padding:50px 0 40px;}
    }
  </style>
</head>
<body>
  <div class="grid-bg"></div>
  <div class="grid-fade"></div>
  <div class="glow"></div>

  <div class="page">
    <nav class="lp-nav">
      <a href="/" class="lp-logo">OpsTrain</a>
      <div class="lp-nav-links">
        <a href="#pricing"><%= lang==='es'?'Precios':'Pricing' %></a>
        <a href="/auth/login" style="opacity:0.5;"><%= lang==='es'?'Entrar':'Sign In' %></a>
        <a href="?lang=<%= lang==='es'?'en':'es' %>" class="lp-lang"><%= lang==='es'?'EN':'ES' %></a>
      </div>
    </nav>

    <section class="hero-section">
      <div class="hero-tag"><%= lang==='es'?'GESTION DE OPERACIONES':'OPERATIONS MANAGEMENT' %></div>
      <h1 class="hero-h1"><span>OpsTrain</span></h1>
      <p class="hero-sub"><%= t('landing.heroSub') %></p>
      <div class="hero-btns">
        <a href="/start" class="btn-hero btn-amber"><%= lang==='es'?'50% Off — Empezar':'50% Off — Get Started' %></a>
        <a href="#features" class="btn-hero btn-ghost"><%= lang==='es'?'Ver Mas':'Learn More' %></a>
      </div>
      <p class="hero-promo"><%= lang==='es'?'Primeros 30 dias a mitad de precio':'First 30 days at half price' %></p>
    </section>

    <div class="bento" id="features">
      <div class="bento-card bento-wide">
        <span class="bento-icon">&#9634;</span>
        <h3><%= t('landing.feat1Title') %></h3>
        <p><%= t('landing.feat1Desc') %></p>
        <div class="bento-ticket"><span class="tt-dot tt-open"></span> Sweep & mop front of house <span style="float:right;color:#52525b;">close</span></div>
        <div class="bento-ticket"><span class="tt-dot tt-done"></span> <span style="color:#52525b;">Restock bar napkins</span> <span style="float:right;color:#22c55e;">Mike T.</span></div>
      </div>
      <div class="bento-card">
        <span class="bento-icon">&#9881;</span>
        <h3><%= t('landing.feat3Title') %></h3>
        <p><%= t('landing.feat3Desc') %></p>
      </div>
      <div class="bento-card">
        <span class="bento-icon">&#9733;</span>
        <h3><%= t('landing.feat2Title') %></h3>
        <p><%= t('landing.feat2Desc') %></p>
      </div>
      <div class="bento-card bento-wide">
        <span class="bento-icon">&#9673;</span>
        <h3><%= t('landing.feat4Title') %></h3>
        <p><%= t('landing.feat4Desc') %></p>
      </div>
    </div>

    <!-- Pricing -->
    <div class="pricing" id="pricing">
      <div class="pricing-card">
        <div class="pricing-tag"><%= lang==='es'?'POR RESTAURANTE':'PER RESTAURANT' %></div>
        <div class="pricing-amount"><span class="pricing-dollar">$</span>28<span class="pricing-mo">/<%= lang==='es'?'mes':'mo' %></span></div>
        <div class="pricing-promo"><%= lang==='es'?'$14/mes los primeros 30 dias':'$14/mo for your first 30 days' %></div>
        <div class="pricing-multi"><%= lang==='es'?'20% off por cada restaurante adicional':'20% off each additional restaurant' %></div>
        <ul class="pricing-list">
          <li><%= lang==='es'?'Tareas y QR ilimitados':'Unlimited tasks & QR codes' %></li>
          <li><%= lang==='es'?'Usuarios ilimitados por marca':'Unlimited staff per brand' %></li>
          <li><%= lang==='es'?'Vista en vivo + analiticas':'Live view + analytics' %></li>
          <li><%= lang==='es'?'Escaner de lista OCR':'Roster scanner OCR' %></li>
          <li><%= lang==='es'?'Quiz de turno con IA':'AI shift quiz' %></li>
          <li><%= lang==='es'?'Webhooks QR (refrigerador, basura, equipo)':'QR webhooks (fridge, trash, equipment)' %></li>
          <li><%= lang==='es'?'Espanol + Ingles':'Spanish + English' %></li>
          <li><%= lang==='es'?'Multi-marca con un solo login':'Multi-brand under one login' %></li>
        </ul>
        <a href="/start" class="btn-hero btn-amber" style="width:100%;text-align:center;margin-top:16px;"><%= lang==='es'?'Empezar Ahora':'Get Started' %></a>
        <p class="pricing-note"><%= lang==='es'?'Cancela cuando quieras. Sin contratos.':'Cancel anytime. No contracts.' %></p>
      </div>
    </div>

    <section class="cta">
      <h2><%- lang==='es'?'Tu equipo. <span>Tu turno.</span> Tu data.':'Your crew. <span>Your shift.</span> Your data.' %></h2>
      <p><%= lang==='es'?'Escanea. Completa. Repite.':'Scan. Complete. Repeat.' %></p>
      <a href="/start" class="btn-hero btn-amber"><%= lang==='es'?'50% Off — Empezar':'50% Off — Get Started' %></a>
    </section>

    <footer class="lp-footer">&copy; <%= new Date().getFullYear() %> OpsTrain &mdash; MadLads Lab</footer>
  </div>
</body>
</html>
