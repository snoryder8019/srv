<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OpsTrain &mdash; MadLads Lab</title>
  <meta name="description" content="OpsTrain is a restaurant operations product from MadLads Lab. Visit madladslab.com to learn more.">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&family=JetBrains+Mono:wght@500;700&display=swap');
    *{margin:0;padding:0;box-sizing:border-box;}
    html,body{min-height:100%;}
    body{font-family:'Inter',sans-serif;background:#09090b;color:#e4e4e7;overflow-x:hidden;}

    /* Grid bg */
    .grid-bg{position:fixed;inset:0;z-index:0;
      background-image:linear-gradient(rgba(217,119,6,0.05) 1px,transparent 1px),linear-gradient(90deg,rgba(217,119,6,0.05) 1px,transparent 1px);
      background-size:40px 40px;
    }
    .grid-fade{position:fixed;inset:0;z-index:1;
      background:radial-gradient(ellipse at 50% 0%,transparent 0%,#09090b 70%);
    }
    .glow{position:fixed;width:560px;height:560px;border-radius:50%;z-index:0;filter:blur(120px);opacity:0.15;
      background:radial-gradient(circle,#d97706,transparent 70%);top:-140px;left:50%;transform:translateX(-50%);
      animation:glowPulse 6s ease infinite;
    }
    @keyframes glowPulse{0%,100%{opacity:0.12;transform:translateX(-50%) scale(1);}50%{opacity:0.2;transform:translateX(-50%) scale(1.1);}}

    .page{position:relative;z-index:2;max-width:840px;margin:0 auto;padding:0 20px;min-height:100vh;display:flex;flex-direction:column;}

    /* Nav */
    .lp-nav{display:flex;align-items:center;justify-content:space-between;padding:22px 0;}
    .lp-logo{font-size:20px;font-weight:900;color:#d97706;letter-spacing:-0.5px;text-decoration:none;}
    .lp-nav-links{display:flex;gap:14px;align-items:center;}
    .lp-nav-links a{color:#71717a;text-decoration:none;font-size:13px;font-weight:600;transition:color 0.2s;}
    .lp-nav-links a:hover{color:#e4e4e7;}
    .lp-lang{font-size:11px;font-weight:800;color:#d97706;border:1px solid #3f3f46;border-radius:4px;padding:2px 6px;}

    /* Hero */
    .hero{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:60px 0;}
    .eyebrow{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;letter-spacing:5px;color:#d97706;
      background:rgba(217,119,6,0.08);border:1px solid rgba(217,119,6,0.25);border-radius:20px;padding:6px 16px;margin-bottom:24px;}
    .h1{font-size:clamp(48px,10vw,84px);font-weight:900;line-height:1;letter-spacing:-2.5px;margin-bottom:18px;}
    .h1 span{background:linear-gradient(135deg,#d97706,#fbbf24);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
    .sub{font-size:clamp(15px,2.5vw,18px);color:#a1a1aa;max-width:540px;line-height:1.6;margin:0 auto 36px;}
    .btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
    .btn{padding:14px 30px;border-radius:8px;font-size:14px;font-weight:700;text-decoration:none;transition:all 0.2s;letter-spacing:0.5px;}
    .btn-amber{background:#d97706;color:#09090b;border:none;}
    .btn-amber:hover{background:#fbbf24;transform:translateY(-1px);box-shadow:0 8px 24px rgba(217,119,6,0.3);}
    .btn-ghost{background:transparent;color:#e4e4e7;border:1px solid #3f3f46;}
    .btn-ghost:hover{border-color:#d97706;color:#d97706;}

    /* Suite strip */
    .suite{margin-top:60px;padding:32px 28px;background:#111113;border:1px solid #1c1c1f;border-radius:12px;text-align:left;}
    .suite-tag{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:3px;color:#52525b;margin-bottom:10px;text-transform:uppercase;}
    .suite-title{font-size:18px;font-weight:800;color:#e4e4e7;margin-bottom:8px;}
    .suite-desc{font-size:13px;color:#a1a1aa;line-height:1.6;margin-bottom:16px;}
    .suite-link{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:700;color:#d97706;text-decoration:none;letter-spacing:1px;}
    .suite-link:hover{color:#fbbf24;}

    /* Footer */
    .lp-footer{text-align:center;padding:24px 0;color:#3f3f46;font-size:11px;border-top:1px solid #1c1c1f;font-family:'JetBrains Mono',monospace;letter-spacing:2px;}

    @media(max-width:640px){
      .btns{flex-direction:column;width:100%;max-width:280px;margin:0 auto;}
      .btn{width:100%;text-align:center;}
    }
  </style>
</head>
<body>
  <div class="grid-bg"></div>
  <div class="grid-fade"></div>
  <div class="glow"></div>

  <div class="page">
    <nav class="lp-nav">
      <a href="/" class="lp-logo">OpsTrain</a>
      <div class="lp-nav-links">
        <a href="https://madladslab.com" target="_blank" rel="noopener">madladslab.com</a>
        <a href="/auth/login"><%= lang==='es'?'Entrar':'Sign In' %></a>
        <a href="?lang=<%= lang==='es'?'en':'es' %>" class="lp-lang"><%= lang==='es'?'EN':'ES' %></a>
      </div>
    </nav>

    <section class="hero">
      <div class="eyebrow"><%= lang==='es'?'UN PRODUCTO DE MADLADS LAB':'A MADLADS LAB PRODUCT' %></div>
      <h1 class="h1"><span>OpsTrain</span></h1>
      <p class="sub"><%= lang==='es'
        ? 'Operaciones de restaurante con QR: tareas, turnos, escaneo de lista, quizzes de IA y vista en vivo. Construido y operado por MadLads Lab.'
        : 'QR-driven restaurant operations: tasks, shifts, roster scanning, AI quizzes, and a live view. Built and operated by MadLads Lab.' %></p>
      <div class="btns">
        <a href="https://madladslab.com" class="btn btn-amber" target="_blank" rel="noopener"><%= lang==='es'?'Visitar madladslab.com  →':'Visit madladslab.com  →' %></a>
        <a href="/auth/login" class="btn btn-ghost"><%= lang==='es'?'Entrar':'Sign In' %></a>
      </div>

      <div class="suite">
        <div class="suite-tag"><%= lang==='es'?'PARTE DE LA PLATAFORMA':'PART OF THE PLATFORM' %></div>
        <div class="suite-title"><%= lang==='es'?'MadLads Lab':'MadLads Lab' %></div>
        <p class="suite-desc"><%= lang==='es'
          ? 'OpsTrain es uno de varios productos en la suite de MadLads Lab. Para precios, demos y la lista completa de herramientas, visita el sitio principal.'
          : 'OpsTrain is one of several tools in the MadLads Lab suite. For pricing, demos, and the full lineup, head to the main site.' %></p>
        <a href="https://madladslab.com" class="suite-link" target="_blank" rel="noopener">madladslab.com →</a>
      </div>
    </section>

    <footer class="lp-footer">&copy; <%= new Date().getFullYear() %> &middot; OPSTRAIN &middot; MADLADS LAB</footer>
  </div>
</body>
</html>
