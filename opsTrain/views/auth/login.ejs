<%- include('../layout/header') %>

<div class="auth-page">
  <div class="auth-card">
    <h2><%= t('auth.adminLogin') %></h2>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <!-- Auth method tabs -->
    <div class="auth-tabs">
      <button class="auth-tab active" data-tab="email" onclick="switchTab('email')">Email</button>
      <button class="auth-tab" data-tab="google" onclick="switchTab('google')">Google</button>
    </div>

    <!-- EMAIL panel -->
    <div class="auth-panel active" id="panel-email">
      <form method="POST" action="/auth/login">
        <div class="form-field">
          <label>Email</label>
          <input type="email" name="email" placeholder="you@business.com" required autocomplete="email">
        </div>
        <div class="form-field">
          <label>Password</label>
          <input type="password" name="password" placeholder="Your password" required autocomplete="current-password">
        </div>
        <button type="submit" class="btn btn-amber btn-full">Sign In</button>
      </form>
      <p class="auth-note" style="margin-top:12px;">
        Don't have an account? <a href="/auth/register" style="color:#d97706;">Register</a>
      </p>
    </div>

    <!-- GOOGLE panel -->
    <div class="auth-panel" id="panel-google">
      <a href="/auth/google" class="btn btn-google">
        <svg width="18" height="18" viewBox="0 0 48 48" style="vertical-align:middle;margin-right:8px;">
          <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
          <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
          <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
        </svg>
        <%= t('auth.signInGoogle') %>
      </a>
      <p class="auth-note"><%= t('auth.authNote') %></p>
    </div>
  </div>
</div>

<style>
  .auth-tabs { display:flex; gap:0; margin-bottom:16px; border:1px solid #3f3f46; border-radius:6px; overflow:hidden; }
  .auth-tab { flex:1; padding:8px 0; text-align:center; font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; background:#18181b; color:#71717a; border:none; cursor:pointer; transition:all 0.15s; font-family:'Inter',sans-serif; }
  .auth-tab:not(:last-child) { border-right:1px solid #3f3f46; }
  .auth-tab:hover { color:#e4e4e7; }
  .auth-tab.active { background:#d97706; color:#09090b; }
  .auth-panel { display:none; } .auth-panel.active { display:block; }
  .form-field { margin-bottom:12px; }
  .form-field label { display:block; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#71717a; margin-bottom:4px; }
  .form-field input { width:100%; padding:10px 12px; background:#18181b; border:1px solid #3f3f46; border-radius:6px; color:#e4e4e7; font-family:'Inter',sans-serif; font-size:14px; outline:none; transition:border-color 0.2s; }
  .form-field input:focus { border-color:#d97706; }
  .btn-full { width:100%; }
  .btn-amber { display:inline-block; padding:10px 20px; background:#d97706; color:#09090b; border:none; border-radius:6px; font-size:14px; font-weight:700; cursor:pointer; transition:background 0.2s; font-family:'Inter',sans-serif; }
  .btn-amber:hover { background:#fbbf24; }
  .alert-success { background:rgba(34,197,94,0.1); border:1px solid rgba(34,197,94,0.3); color:#22c55e; padding:8px 12px; border-radius:6px; font-size:13px; margin-bottom:12px; }
</style>

<script>
function switchTab(tab) {
  document.querySelectorAll('.auth-tab').forEach(function(t) { t.classList.toggle('active', t.dataset.tab === tab); });
  document.querySelectorAll('.auth-panel').forEach(function(p) { p.classList.remove('active'); });
  var panel = document.getElementById('panel-' + tab);
  if (panel) panel.classList.add('active');
}
</script>

<%- include('../layout/footer') %>
