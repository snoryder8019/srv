<%- include('../layout/header') %>

<div class="shift-page">
  <div class="shift-card scan-result">
    <div class="scan-icon">&#10003;</div>
    <h2><%= t('scan.scanLogged') %></h2>
    <% if (brand) { %>
      <p style="color: <%= brand.color || '#d97706' %>"><strong><%= brand.name %></strong></p>
    <% } %>
    <p><strong><%= qrCode.label %></strong></p>
    <% if (qrCode.webhookCategory) { %>
      <p class="text-muted"><%= t('fields.category') %>: <%= qrCode.webhookCategory %></p>
    <% } %>
    <% if (qrCode.area || qrCode.position) { %>
      <p class="text-muted"><%= t('fields.area') %>: <%= qrCode.area %> <%= qrCode.position %></p>
    <% } %>
    <p class="text-muted"><%= t('scan.loggedAt') %> <%= new Date().toLocaleTimeString() %></p>
  </div>
</div>

<%- include('scanner') %>
<%- include('../layout/footer') %>
