<%- include('../layout/header') %>

<div class="shift-page">
  <div class="shift-card scan-result">
    <div class="scan-icon">&#128247;</div>
    <h2><%= t('scan.qrScanned') %></h2>
    <% if (brand) { %>
      <p style="color: <%= brand.color || '#d97706' %>"><strong><%= brand.name %></strong></p>
    <% } %>
    <p><strong><%= qrCode.label %></strong></p>
    <p class="text-muted"><%= t('fields.type') %>: <%= qrCode.type %></p>
    <p class="text-muted"><%= t('scan.scannedAt') %> <%= new Date().toLocaleTimeString() %></p>
  </div>
</div>

<%- include('scanner') %>
<%- include('../layout/footer') %>
