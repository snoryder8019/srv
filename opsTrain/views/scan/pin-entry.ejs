<%- include('../layout/header') %>

<div class="shift-page">
  <div class="shift-card">
    <% if (brand) { %>
      <h2 style="color: <%= brand.color || '#d97706' %>"><%= brand.name %></h2>
      <p class="text-muted"><%= brand.location || '' %></p>
    <% } %>

    <div class="scan-type-badge">
      <span class="badge"><%= qrCode.type %></span>
      <% if (qrCode.label) { %><p style="margin-top:6px;"><strong><%= qrCode.label %></strong></p><% } %>
      <% if (qrCode.area || qrCode.position) { %>
        <p class="text-sm text-muted"><%= qrCode.area %> <%= qrCode.position %></p>
      <% } %>
    </div>

    <p style="margin-top:16px;"><%= t('scan.enterPos') %></p>

    <form id="pinForm" class="pin-form">
      <div class="pin-input-group">
        <input type="tel" name="pin" id="pinInput" maxlength="6" pattern="[0-9]{4,6}" placeholder="PIN" autofocus required>
      </div>
      <button type="submit" class="btn btn-primary btn-lg"><%= t('scan.go') %></button>
    </form>

    <div id="pinError" class="alert alert-error" style="display:none;margin-top:12px;"></div>
    <div id="pinSuccess" class="alert alert-success" style="display:none;margin-top:12px;"></div>
  </div>
</div>

<script>
document.getElementById('pinForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const pin = document.getElementById('pinInput').value;
  const errEl = document.getElementById('pinError');
  const okEl = document.getElementById('pinSuccess');
  errEl.style.display = 'none';
  okEl.style.display = 'none';

  try {
    const res = await fetch('/scan/<%= qrCode.code %>/identify', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ pin })
    });
    const data = await res.json();
    if (data.success) {
      okEl.textContent = '<%= t("scan.hey") %> ' + data.user + '!';
      okEl.style.display = 'block';
      setTimeout(() => { window.location.href = data.redirect; }, 600);
    } else {
      errEl.textContent = data.message || '<%= t("scan.pinNotRecognized") %>';
      errEl.style.display = 'block';
      document.getElementById('pinInput').value = '';
      document.getElementById('pinInput').focus();
    }
  } catch (err) {
    errEl.textContent = 'Connection error';
    errEl.style.display = 'block';
  }
});
</script>

<%- include('../layout/footer') %>
