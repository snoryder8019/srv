<%- include('../layout/header') %>
<div style="max-width:500px;margin:40px auto;text-align:center;">
  <h1 style="color:var(--primary);margin-bottom:16px;">Live View</h1>
  <div class="card-grid">
    <% brands.forEach(b => { %>
      <a href="/live?brandId=<%= b._id %>" class="brand-card" style="border-left:4px solid <%= b.color || '#d97706' %>;text-decoration:none;">
        <h3><%= b.name %></h3>
      </a>
    <% }) %>
  </div>
</div>
<%- include('../layout/footer') %>
