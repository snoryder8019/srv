<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap');
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:'Inter',sans-serif;background:#09090b;color:#e4e4e7;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;}
    .card{background:#18181b;border:1px solid #27272a;border-radius:16px;padding:32px;max-width:420px;width:100%;}
    .logo{font-size:20px;font-weight:900;color:#d97706;text-align:center;margin-bottom:4px;}
    .sub{text-align:center;font-size:12px;color:#71717a;margin-bottom:6px;}
    .invite-badge{text-align:center;margin-bottom:20px;}
    .invite-badge span{display:inline-block;font-size:11px;font-weight:700;color:#818cf8;background:rgba(129,140,248,0.1);border:1px solid rgba(129,140,248,0.2);border-radius:20px;padding:4px 14px;}
    h2{font-size:16px;font-weight:700;text-align:center;margin-bottom:16px;}
    .error-msg{background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#ef4444;padding:8px 12px;border-radius:6px;font-size:12px;margin-bottom:14px;}
    label{display:block;font-size:11px;font-weight:700;color:#71717a;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;}
    input{width:100%;padding:10px 12px;background:#111113;border:1px solid #3f3f46;border-radius:6px;color:#e4e4e7;font-size:14px;font-family:inherit;margin-bottom:12px;}
    input:focus{outline:none;border-color:#d97706;}
    .row{display:flex;gap:8px;}
    .row>div{flex:1;}
    .hint{font-size:10px;color:#52525b;margin:-8px 0 12px;}
    .submit{width:100%;padding:12px;background:#d97706;color:#09090b;border:none;border-radius:8px;font-size:15px;font-weight:800;cursor:pointer;margin-top:8px;transition:all 0.2s;}
    .submit:hover{background:#fbbf24;transform:translateY(-1px);}
    .note{text-align:center;font-size:10px;color:#52525b;margin-top:12px;}
    .signin-link{text-align:center;margin-top:12px;font-size:12px;color:#52525b;}
    .signin-link a{color:#d97706;text-decoration:none;}
    @media(max-width:520px){.row{flex-direction:column;gap:0;}.row>div{flex:none;}}
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">OpsTrain</div>
    <div class="sub">You've been invited to manage</div>
    <div class="invite-badge"><span>Manager — <%= brand.name %></span></div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>

    <form action="/invite/<%= token %>" method="POST">
      <label>Your Name *</label>
      <input type="text" name="displayName" required placeholder="Full name">

      <label>Email *</label>
      <input type="email" name="email" required placeholder="you@email.com">

      <div class="row">
        <div>
          <label>Password *</label>
          <input type="password" name="password" required minlength="8" autocomplete="new-password">
          <div class="hint">Min 8 characters</div>
        </div>
        <div>
          <label>Confirm *</label>
          <input type="password" name="passwordConfirm" required autocomplete="new-password">
        </div>
      </div>

      <button type="submit" class="submit">Join as Manager</button>
    </form>

    <div class="signin-link">Already have an account? <a href="/auth/login">Sign in</a></div>
    <p class="note">You'll have manager access to <%= brand.name %>'s operations dashboard.</p>
  </div>
</body>
</html>
