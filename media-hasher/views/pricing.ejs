<%- include('_header') %>
  <section class="pricing">
    <h1>One price. Lifetime license.</h1>
    <div class="price-card">
      <div class="price">$<%= (priceCents/100).toFixed(2) %></div>
      <ul>
        <li>Lifetime license — pay once</li>
        <li>Activate on up to 2 devices</li>
        <li>All future updates included</li>
        <li><%= trialDays %>-day free trial, no card required</li>
      </ul>

      <% if (paypalEnabled) { %>
        <form method="POST" action="/checkout/paypal/create" class="buy-form">
          <% if (!user) { %>
            <input type="email" name="email" placeholder="you@email.com" required>
          <% } %>
          <button class="btn primary" type="submit">Buy with PayPal</button>
        </form>
      <% } %>

      <% if (stripeEnabled) { %>
        <form method="POST" action="/checkout/stripe/create" class="buy-form">
          <% if (!user) { %>
            <input type="email" name="email" placeholder="you@email.com" required>
          <% } %>
          <button class="btn ghost" type="submit">Buy with card (Stripe)</button>
        </form>
      <% } %>

      <form method="POST" action="/trial/start" class="buy-form">
        <% if (!user) { %>
          <input type="email" name="email" placeholder="you@email.com" required>
        <% } %>
        <button class="btn link" type="submit">Start free trial instead</button>
      </form>
    </div>
  </section>
<%- include('_footer') %>
