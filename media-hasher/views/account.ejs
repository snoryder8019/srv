<%- include('_header') %>
  <section class="account">
    <% if (welcome) { %>
      <div class="banner success">Thanks for your purchase! Your license is below — check your email for a copy.</div>
    <% } %>
    <h1>Your account</h1>
    <p>Signed in as <strong><%= user.email %></strong></p>

    <h2>Licenses</h2>
    <% if (!licenses.length) { %>
      <p>No licenses yet. <a href="/pricing">Get MediaHasher</a>.</p>
    <% } else { %>
      <table class="data">
        <thead><tr><th>Key</th><th>Type</th><th>Status</th><th>Activations</th><th>Expires</th></tr></thead>
        <tbody>
          <% licenses.forEach(l => { %>
            <tr>
              <td><code><%= l.key %></code></td>
              <td><%= l.type %></td>
              <td><%= l.status %></td>
              <td><%= (l.activations||[]).length %> / <%= l.maxActivations %></td>
              <td><%= l.trialExpiresAt ? new Date(l.trialExpiresAt).toLocaleDateString() : '—' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <p><a class="btn primary" href="/download">Download MediaHasher</a></p>
    <% } %>

    <h2>Purchases</h2>
    <% if (!purchases.length) { %>
      <p>No purchases yet.</p>
    <% } else { %>
      <table class="data">
        <thead><tr><th>Date</th><th>Processor</th><th>Amount</th><th>Status</th></tr></thead>
        <tbody>
          <% purchases.forEach(p => { %>
            <tr>
              <td><%= new Date(p.createdAt).toLocaleString() %></td>
              <td><%= p.processor %></td>
              <td>$<%= (p.amount/100).toFixed(2) %></td>
              <td><%= p.status %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>
<%- include('_footer') %>
