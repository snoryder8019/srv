<%- include('_header') %>
  <section class="hero">
    <h1>Find duplicates. Pick the best. Reclaim your storage.</h1>
    <p class="lede">A decade of phone dumps in one place — MediaHasher groups near-duplicate photos and video bursts so you can keep the best and delete the rest, locally.</p>
    <div class="cta-row">
      <a class="btn primary" href="/pricing">Get MediaHasher · $<%= (priceCents/100).toFixed(2) %></a>
      <form method="POST" action="/trial/start" class="trial-inline">
        <input type="email" name="email" placeholder="you@email.com" required>
        <button class="btn ghost" type="submit">Start <%= trialDays %>-day free trial</button>
      </form>
    </div>
  </section>
  <section class="features">
    <div class="feature">
      <h3>Local-first</h3>
      <p>Everything runs on your machine. Your photos never leave your computer.</p>
    </div>
    <div class="feature">
      <h3>Smart grouping</h3>
      <p>Perceptual hashing + EXIF burst detection clusters near-duplicates automatically.</p>
    </div>
    <div class="feature">
      <h3>Best-of picker</h3>
      <p>Sharpness, exposure, and face scoring suggest the keeper. You decide.</p>
    </div>
    <div class="feature">
      <h3>Safe deletes</h3>
      <p>Quarantine folder for 30 days before anything is permanently removed.</p>
    </div>
  </section>
<%- include('_footer') %>
