# --- Server ---
PORT=3604
NODE_ENV=development
DOMAIN=https://mediahasher.madladslab.com

# --- MongoDB Atlas (own DB: mediaHasher) ---
DB_URL=mongodb+srv://USER:PASS@cluster0.tpmae.mongodb.net
DB_NAME=mediaHasher

# --- Sessions / JWT ---
SESHSEC=change_me_in_prod
JWT_SECRET=change_me_in_prod_license_jwt

# --- Google OAuth (shared creds with other madladslab services) ---
GGLCID=
GGLSEC=

# --- PayPal (primary payment processor) ---
PAYPAL_CID=
PAYPAL_SEC=
PAYPAL_MODE=sandbox

# --- Stripe (optional / disabled by default — leave blank to disable) ---
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# --- Linode Object Storage (Electron installer hosting) ---
LINODE_ACCESS=
LINODE_SECRET=
LINODE_URL=https://us-ord-1.linodeobjects.com
LINODE_REGION=us-ord-1
LINODE_BUCKET=madladslab
LINODE_PREFIX=mediahasher/installers

# --- Zoho mail (license keys, trial expiry notices) ---
ZOHO_USER=
ZOHO_PASS=
ZOHO_FROM_NAME=MediaHasher

# --- Product config ---
PRODUCT_PRICE_CENTS=499
TRIAL_DAYS=7
MAX_ACTIVATIONS=2
LICENSE_HEARTBEAT_DAYS=14
